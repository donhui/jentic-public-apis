{
  "openapi": "3.0.3",
  "info": {
    "title": "Sauce Labs API",
    "description": "Sauce Labs provides a comprehensive cloud-based platform for automated testing of web and mobile applications. This API allows you to manage test jobs, builds, accounts, Sauce Connect tunnels, app storage, platform information, test insights, and real devices.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.saucelabs.com/dev/api/"
  },
  "servers": [
    {
      "url": "https://api.us-west-1.saucelabs.com",
      "description": "US West Data Center"
    },
    {
      "url": "https://api.us-east-4.saucelabs.com",
      "description": "US East Data Center"
    },
    {
      "url": "https://api.eu-central-1.saucelabs.com",
      "description": "EU Central Data Center"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    { "name": "Jobs", "description": "Manage test jobs, job assets, and job lifecycle" },
    { "name": "Builds", "description": "Manage builds and lookup build-job associations" },
    { "name": "Accounts", "description": "Manage teams, users, and service accounts" },
    { "name": "SauceConnect", "description": "Manage Sauce Connect proxy tunnels" },
    { "name": "Storage", "description": "Upload, manage, and download app files" },
    { "name": "Platform", "description": "Get platform status and supported browser/device information" },
    { "name": "Insights", "description": "Analytics, trends, test metrics, coverage, and activity reporting" },
    { "name": "RealDevices", "description": "Manage real devices, real device jobs, and private device settings" }
  ],
  "paths": {
    "/rest/v1/{username}/jobs": {
      "get": {
        "operationId": "listJobs",
        "summary": "Get jobs for a user",
        "description": "Returns a list of jobs associated with the specified user. Results can be filtered by time range and paginated.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "name": "limit", "in": "query", "description": "Maximum number of jobs to return", "schema": { "type": "integer" } },
          { "name": "skip", "in": "query", "description": "Number of jobs to skip for pagination", "schema": { "type": "integer" } },
          { "name": "from", "in": "query", "description": "Return jobs run on or after this Unix timestamp", "schema": { "type": "integer", "format": "int64" } },
          { "name": "to", "in": "query", "description": "Return jobs run on or before this Unix timestamp", "schema": { "type": "integer", "format": "int64" } },
          { "name": "format", "in": "query", "description": "Results format", "schema": { "type": "string", "enum": ["json", "csv"] } }
        ],
        "responses": {
          "200": {
            "description": "List of jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Job" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/rest/v1/{username}/jobs/{job_id}": {
      "get": {
        "operationId": "getJobDetails",
        "summary": "Get job details",
        "description": "Returns detailed information about a specific job.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Job details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Job" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "operationId": "updateJob",
        "summary": "Update a job",
        "description": "Update attributes of a specific job such as name, tags, visibility, and pass/fail status.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/JobUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated job",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Job" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "deleteJob",
        "summary": "Delete a job",
        "description": "Delete a specific job and all its associated assets.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "204": { "description": "Job deleted successfully" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/rest/v1/{username}/jobs/{job_id}/stop": {
      "put": {
        "operationId": "stopJob",
        "summary": "Stop a running job",
        "description": "Stops a currently running job.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Job stopped",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Job" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/rest/v1/{username}/jobs/{job_id}/assets": {
      "get": {
        "operationId": "listJobAssets",
        "summary": "List job assets",
        "description": "Returns a list of available assets (logs, screenshots, video, etc.) for a specific job.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Job assets listing",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/JobAssets" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "deleteJobAssets",
        "summary": "Delete job assets",
        "description": "Delete all assets associated with a specific job.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Deleted assets listing",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "size": { "type": "integer" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/rest/v1/{username}/jobs/{job_id}/assets/{file_name}": {
      "get": {
        "operationId": "getJobAssetFile",
        "summary": "Download a job asset file",
        "description": "Download a specific asset file (log, video, screenshot, etc.) for a job.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "$ref": "#/components/parameters/JobIdPathParam" },
          {
            "name": "file_name",
            "in": "path",
            "required": true,
            "description": "The name of the asset file to download",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Asset file content",
            "content": {
              "application/octet-stream": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v2/builds/{build_source}/": {
      "get": {
        "operationId": "listBuilds",
        "summary": "Lookup builds",
        "description": "Returns a list of builds for the specified source (real device or virtual device cloud).",
        "tags": ["Builds"],
        "parameters": [
          { "$ref": "#/components/parameters/BuildSourcePathParam" },
          { "name": "user_id", "in": "query", "description": "Filter by user ID", "schema": { "type": "string" } },
          { "name": "org_id", "in": "query", "description": "Filter by organization ID", "schema": { "type": "string" } },
          { "name": "group_id", "in": "query", "description": "Filter by group ID", "schema": { "type": "string" } },
          { "name": "team_id", "in": "query", "description": "Filter by team ID", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "description": "Filter by build status", "schema": { "type": "string", "enum": ["running", "error", "failed", "complete", "success"] } },
          { "name": "start", "in": "query", "description": "Start time filter (ISO 8601)", "schema": { "type": "string", "format": "date-time" } },
          { "name": "end", "in": "query", "description": "End time filter (ISO 8601)", "schema": { "type": "string", "format": "date-time" } },
          { "name": "limit", "in": "query", "description": "Maximum number of results", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "description": "Number of results to skip", "schema": { "type": "integer" } },
          { "name": "name", "in": "query", "description": "Filter by build name", "schema": { "type": "string" } },
          { "name": "sort", "in": "query", "description": "Sort order", "schema": { "type": "string", "enum": ["asc", "desc"] } }
        ],
        "responses": {
          "200": {
            "description": "List of builds",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "builds": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Build" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/builds/{build_source}/{build_id}/": {
      "get": {
        "operationId": "getBuildDetails",
        "summary": "Get a specific build",
        "description": "Returns detailed information about a specific build.",
        "tags": ["Builds"],
        "parameters": [
          { "$ref": "#/components/parameters/BuildSourcePathParam" },
          { "$ref": "#/components/parameters/BuildIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Build details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Build" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v2/builds/{build_source}/jobs/{job_id}/build/": {
      "get": {
        "operationId": "getBuildForJob",
        "summary": "Lookup build for a specific job",
        "description": "Returns the build associated with a specific job.",
        "tags": ["Builds"],
        "parameters": [
          { "$ref": "#/components/parameters/BuildSourcePathParam" },
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Build for the job",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Build" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v2/builds/{build_source}/{build_id}/jobs/": {
      "get": {
        "operationId": "listBuildJobs",
        "summary": "List jobs in a build",
        "description": "Returns all jobs associated with a specific build.",
        "tags": ["Builds"],
        "parameters": [
          { "$ref": "#/components/parameters/BuildSourcePathParam" },
          { "$ref": "#/components/parameters/BuildIdPathParam" },
          { "name": "modified_since", "in": "query", "description": "Filter jobs modified since this time", "schema": { "type": "string", "format": "date-time" } },
          { "name": "completed", "in": "query", "schema": { "type": "boolean" } },
          { "name": "errored", "in": "query", "schema": { "type": "boolean" } },
          { "name": "failed", "in": "query", "schema": { "type": "boolean" } },
          { "name": "finished", "in": "query", "schema": { "type": "boolean" } },
          { "name": "passed", "in": "query", "schema": { "type": "boolean" } },
          { "name": "queued", "in": "query", "schema": { "type": "boolean" } },
          { "name": "running", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Jobs in the build",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jobs": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/BuildJob" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/team-management/v1/teams/": {
      "get": {
        "operationId": "listTeams",
        "summary": "Lookup teams",
        "description": "Returns a list of teams in the organization.",
        "tags": ["Accounts"],
        "parameters": [
          { "name": "name", "in": "query", "description": "Filter by team name", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of teams",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TeamListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createTeam",
        "summary": "Create a team",
        "description": "Create a new team in the organization.",
        "tags": ["Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TeamCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Team created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Team" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/team-management/v1/teams/{team_id}/": {
      "get": {
        "operationId": "getTeamDetails",
        "summary": "Get a specific team",
        "description": "Returns detailed information about a specific team.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Team details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Team" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "operationId": "updateTeam",
        "summary": "Update a team",
        "description": "Fully update a team's attributes.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamIdPathParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TeamCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated team",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Team" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "operationId": "partialUpdateTeam",
        "summary": "Partially update a team",
        "description": "Update specific attributes of a team without replacing the entire resource.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamIdPathParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TeamPatch" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated team",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Team" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "deleteTeam",
        "summary": "Delete a team",
        "description": "Delete a specific team from the organization.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamIdPathParam" }
        ],
        "responses": {
          "204": { "description": "Team deleted successfully" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/team-management/v1/teams/{team_id}/members/": {
      "get": {
        "operationId": "listTeamMembers",
        "summary": "List team members",
        "description": "Returns a list of members belonging to a specific team.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Team members",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/team-management/v1/teams/{team_id}/reset-access-key/": {
      "post": {
        "operationId": "resetTeamAccessKeys",
        "summary": "Reset team access keys",
        "description": "Reset access keys for all members of a team.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Access keys reset",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": {} }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/team-management/v1/users/": {
      "get": {
        "operationId": "listUsers",
        "summary": "Lookup users",
        "description": "Returns a list of users in the organization. Results can be filtered by various criteria.",
        "tags": ["Accounts"],
        "parameters": [
          { "name": "username", "in": "query", "description": "Filter by username", "schema": { "type": "string" } },
          { "name": "teams", "in": "query", "description": "Filter by team ID", "schema": { "type": "string" } },
          { "name": "roles", "in": "query", "description": "Filter by role", "schema": { "type": "string" } },
          { "name": "phrase", "in": "query", "description": "Search phrase for name or email", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "description": "Filter by user status", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "description": "Maximum results (max 100)", "schema": { "type": "integer", "maximum": 100 } },
          { "name": "offset", "in": "query", "description": "Number of results to skip", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create a user",
        "description": "Create a new user in the organization.",
        "tags": ["Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/team-management/v1/users/{user_id}/": {
      "get": {
        "operationId": "getUserDetails",
        "summary": "Get a specific user",
        "description": "Returns detailed information about a specific user.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/UserIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/team-management/v1/users/{user_id}": {
      "put": {
        "operationId": "updateUser",
        "summary": "Update a user",
        "description": "Fully update a user's profile information.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/UserIdPathParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
