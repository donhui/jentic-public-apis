    "/rest/v1/{username}/tunnels": {
      "get": {
        "operationId": "listTunnels",
        "summary": "Get tunnels for a user",
        "description": "Returns a list of Sauce Connect tunnel IDs or tunnel objects for the specified user.",
        "tags": ["SauceConnect"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "name": "full", "in": "query", "description": "Return full tunnel info instead of just IDs", "schema": { "type": "boolean" } },
          { "name": "all", "in": "query", "description": "Include shared tunnels from the same team", "schema": { "type": "boolean" } },
          { "name": "filter", "in": "query", "description": "Filter tunnel results", "schema": { "type": "string", "enum": ["one_per_pool", "v2alpha"] } }
        ],
        "responses": {
          "200": {
            "description": "List of tunnels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Tunnel" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/rest/v1/{username}/tunnels/{tunnel_id}": {
      "get": {
        "operationId": "getTunnelDetails",
        "summary": "Get tunnel information",
        "description": "Returns detailed information about a specific Sauce Connect tunnel.",
        "tags": ["SauceConnect"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
