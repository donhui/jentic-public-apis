          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "stopTunnel",
        "summary": "Stop a tunnel",
        "description": "Shut down a specific Sauce Connect tunnel.",
        "tags": ["SauceConnect"],
        "parameters": [
          { "$ref": "#/components/parameters/UsernamePathParam" },
          { "$ref": "#/components/parameters/TunnelIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Tunnel stopped",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
