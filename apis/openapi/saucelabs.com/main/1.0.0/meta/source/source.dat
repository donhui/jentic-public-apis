        "tags": ["RealDevices"],
        "parameters": [
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "200": {
            "description": "Job details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RealDeviceJob" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "operationId": "updateRealDeviceJob",
        "summary": "Update a real device job",
        "description": "Update attributes of a real device job.",
        "tags": ["RealDevices"],
        "parameters": [
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "build": { "type": "string" },
                  "passed": { "type": "boolean" },
                  "tags": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated job",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RealDeviceJob" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "deleteRealDeviceJob",
        "summary": "Delete a real device job",
        "description": "Delete a specific real device job.",
        "tags": ["RealDevices"],
        "parameters": [
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "204": { "description": "Job deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v1/rdc/jobs/{job_id}/stop": {
      "put": {
        "operationId": "stopRealDeviceJob",
        "summary": "Stop a real device job",
        "description": "Stop a currently running real device job.",
        "tags": ["RealDevices"],
        "parameters": [
          { "$ref": "#/components/parameters/JobIdPathParam" }
        ],
        "responses": {
          "200": { "description": "Job stopped" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v1/rdc/jobs/{job_id}/{asset_type}": {
      "get": {
        "operationId": "downloadRealDeviceJobAsset",
        "summary": "Download a real device job asset",
        "description": "Download a specific asset (deviceLogs, video.mp4, junit.xml, etc.) from a real device job.",
        "tags": ["RealDevices"],
        "parameters": [
          { "$ref": "#/components/parameters/JobIdPathParam" },
          {
            "name": "asset_type",
            "in": "path",
            "required": true,
            "description": "Asset type to download (e.g., deviceLogs, video.mp4, junit.xml)",
            "schema": { "type": "string" }
          },
          { "name": "download", "in": "query", "description": "Force compressed download", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Asset file",
            "content": {
              "application/octet-stream": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v1/rdc/device-management/devices": {
      "get": {
        "operationId": "listPrivateRealDevices",
        "summary": "Get private real devices",
        "description": "Returns a list of private real devices and their configurations.",
        "tags": ["RealDevices"],
        "responses": {
          "200": {
            "description": "Private devices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PrivateRealDevice" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/rdc/device-management/devices/{device_id}/teams": {
      "put": {
        "operationId": "assignDeviceToTeams",
        "summary": "Assign device to teams",
        "description": "Assign a private real device to one or more teams.",
        "tags": ["RealDevices"],
        "parameters": [
          { "$ref": "#/components/parameters/DeviceIdPathParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ids"],
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Team identifiers to assign the device to"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Device assigned to teams" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v1/rdc/device-management/devices/{device_id}/settings": {
      "put": {
        "operationId": "updateDeviceSettings",
        "summary": "Update private device settings",
        "description": "Update configuration settings for a private real device.",
        "tags": ["RealDevices"],
        "parameters": [
          { "$ref": "#/components/parameters/DeviceIdPathParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeviceSettings" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated device",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PrivateRealDevice" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using your Sauce Labs username and access key"
      }
    },
    "parameters": {
      "UsernamePathParam": {
        "name": "username",
        "in": "path",
        "required": true,
        "description": "The Sauce Labs username",
        "schema": { "type": "string" }
      },
      "JobIdPathParam": {
        "name": "job_id",
        "in": "path",
        "required": true,
        "description": "The unique job identifier",
        "schema": { "type": "string" }
      },
      "BuildIdPathParam": {
        "name": "build_id",
        "in": "path",
        "required": true,
        "description": "The unique build identifier",
        "schema": { "type": "string" }
      },
      "BuildSourcePathParam": {
        "name": "build_source",
        "in": "path",
        "required": true,
        "description": "The build source type",
        "schema": { "type": "string", "enum": ["rdc", "vdc"] }
      },
      "TeamIdPathParam": {
        "name": "team_id",
        "in": "path",
        "required": true,
        "description": "The unique team identifier",
        "schema": { "type": "string" }
      },
      "UserIdPathParam": {
        "name": "user_id",
        "in": "path",
        "required": true,
        "description": "The unique user identifier",
        "schema": { "type": "string" }
      },
      "TunnelIdPathParam": {
        "name": "tunnel_id",
        "in": "path",
        "required": true,
        "description": "The unique tunnel identifier",
        "schema": { "type": "string" }
      },
      "GroupIdPathParam": {
        "name": "group_id",
        "in": "path",
        "required": true,
        "description": "The app group identifier",
        "schema": { "type": "string" }
      },
      "DeviceIdPathParam": {
        "name": "device_id",
        "in": "path",
        "required": true,
        "description": "The unique device identifier",
        "schema": { "type": "string" }
      },
      "InsightsSourcePathParam": {
        "name": "source",
        "in": "path",
        "required": true,
        "description": "Data source: real device cloud or virtual device cloud",
        "schema": { "type": "string", "enum": ["rdc", "vdc"] }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters or malformed request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing authentication credentials",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer", "description": "HTTP status code" },
          "title": { "type": "string", "description": "Error title" },
          "detail": { "type": "string", "description": "Detailed error message" },
          "message": { "type": "string", "description": "Human-readable error message" }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique job identifier" },
          "name": { "type": "string", "description": "Job name" },
          "owner": { "type": "string", "description": "Username of job owner" },
          "status": { "type": "string", "description": "Current job status" },
          "passed": { "type": "boolean", "nullable": true, "description": "Whether the job passed" },
          "build": { "type": "string", "description": "Build name" },
          "browser": { "type": "string", "description": "Browser name" },
          "browser_version": { "type": "string", "description": "Browser version" },
          "browser_short_version": { "type": "string" },
          "os": { "type": "string", "description": "Operating system" },
          "automation_backend": { "type": "string", "description": "Automation framework used" },
          "creation_time": { "type": "integer", "format": "int64", "description": "Job creation Unix timestamp" },
          "start_time": { "type": "integer", "format": "int64", "description": "Job start Unix timestamp" },
          "end_time": { "type": "integer", "format": "int64", "description": "Job end Unix timestamp" },
          "video_url": { "type": "string", "description": "URL of the job video recording" },
          "record_video": { "type": "boolean" },
          "record_screenshots": { "type": "boolean" },
          "public": { "type": "string", "description": "Visibility level" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "custom-data": { "type": "object", "additionalProperties": true },
          "performance_enabled": { "type": "boolean" },
          "command_counts": { "type": "object", "additionalProperties": { "type": "integer" } }
        }
      },
      "JobUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "New job name" },
          "tags": { "type": "array", "items": { "type": "string" }, "description": "Distinguishing tags" },
          "public": { "type": "string", "enum": ["public", "public restricted", "share", "team", "private"], "description": "Visibility level" },
          "passed": { "type": "boolean", "description": "Pass/fail assertion" },
          "build": { "type": "string", "description": "Build name to assign" },
          "custom-data": { "type": "object", "additionalProperties": true, "description": "Custom key-value pairs" }
        }
      },
      "JobAssets": {
        "type": "object",
        "properties": {
          "automator.log": { "type": "string" },
          "network.har": { "type": "string" },
          "video.mp4": { "type": "string" },
          "selenium-log": { "type": "string" },
          "performance.json": { "type": "string" },
          "sauce-log": { "type": "string" },
          "screenshots": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Build": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique build identifier" },
          "name": { "type": "string", "description": "Build name" },
          "status": { "type": "string", "description": "Build status" },
          "passed": { "type": "boolean", "nullable": true },
          "public": { "type": "boolean" },
          "owner_id": { "type": "string" },
          "org_id": { "type": "string" },
          "team_id": { "type": "string" },
          "group_id": { "type": "string" },
          "jobs": { "type": "object", "description": "Jobs summary" },
          "creation_time": { "type": "string", "format": "date-time" },
          "start_time": { "type": "string", "format": "date-time" },
          "end_time": { "type": "string", "format": "date-time" },
          "modification_time": { "type": "string", "format": "date-time" },
          "deletion_time": { "type": "string", "format": "date-time", "nullable": true },
          "run": { "type": "integer" }
        }
      },
      "BuildJob": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "creation_time": { "type": "string", "format": "date-time" },
          "modification_time": { "type": "string", "format": "date-time" },
          "deletion_time": { "type": "string", "format": "date-time", "nullable": true },
          "state": {
            "type": "object",
            "properties": {
              "completed": { "type": "boolean" },
              "errored": { "type": "boolean" },
              "failed": { "type": "boolean" },
              "finished": { "type": "boolean" },
              "new": { "type": "boolean" },
              "passed": { "type": "boolean" },
              "public": { "type": "boolean" },
              "queued": { "type": "boolean" },
              "running": { "type": "boolean" }
            }
          }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "org_uuid": { "type": "string" },
          "group": { "type": "object" },
          "description": { "type": "string" },
          "is_default": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "settings": {
            "type": "object",
            "properties": {
              "virtual_machines": { "type": "integer", "description": "VM concurrency limit" }
            }
          },
          "links": { "type": "object" }
        }
      },
      "TeamCreate": {
        "type": "object",
        "required": ["name", "settings"],
        "properties": {
          "name": { "type": "string", "description": "Team name" },
          "settings": {
            "type": "object",
            "required": ["virtual_machines"],
            "properties": {
              "virtual_machines": { "type": "integer" }
            }
          },
          "description": { "type": "string" }
        }
      },
      "TeamPatch": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "settings": {
            "type": "object",
            "properties": {
              "virtual_machines": { "type": "integer" }
            }
          },
          "description": { "type": "string" }
        }
      },
      "TeamListResponse": {
        "type": "object",
        "properties": {
          "links": { "type": "object" },
          "count": { "type": "integer" },
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/Team" } }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "is_active": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "teams": { "type": "array", "items": { "type": "object" } },
          "roles": { "type": "array", "items": { "type": "object" } },
          "is_staff": { "type": "boolean" },
          "is_superuser": { "type": "boolean" },
          "user_type": { "type": "string" },
          "groups": { "type": "array", "items": { "type": "object" } },
          "organization": { "type": "object" },
          "is_organization_admin": { "type": "boolean" },
          "is_team_admin": { "type": "boolean" }
        }
      },
      "UserCreate": {
        "type": "object",
        "required": ["first_name", "last_name", "email", "username", "password"],
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "username": { "type": "string" },
          "password": { "type": "string", "format": "password" },
          "role": { "type": "integer", "enum": [1, 3, 4], "description": "User role ID" },
          "team": { "type": "string", "description": "Team UUID to assign" }
        }
      },
      "UserUpdate": {
        "type": "object",
        "required": ["first_name", "last_name", "password", "verify_password"],
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "password": { "type": "string", "format": "password" },
          "verify_password": { "type": "string", "format": "password" }
        }
      },
      "UserPatch": {
        "type": "object",
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "password": { "type": "string", "format": "password" },
          "verify_password": { "type": "string", "format": "password" }
        }
      },
      "UserListResponse": {
        "type": "object",
        "properties": {
          "links": { "type": "object" },
          "count": { "type": "integer" },
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/User" } }
        }
      },
      "AccessKeyResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "access_key": { "type": "string" }
        }
      },
      "ConcurrencyResponse": {
        "type": "object",
        "properties": {
          "concurrency": {
            "type": "object",
            "properties": {
              "organization": {
                "type": "object",
                "properties": {
                  "allowed": { "$ref": "#/components/schemas/ConcurrencyLimits" },
                  "current": { "$ref": "#/components/schemas/ConcurrencyLimits" }
                }
              },
              "team": {
                "type": "object",
                "properties": {
                  "allowed": { "$ref": "#/components/schemas/ConcurrencyLimits" },
                  "current": { "$ref": "#/components/schemas/ConcurrencyLimits" }
                }
              }
            }
          },
          "timestamp": { "type": "number" }
        }
      },
      "ConcurrencyLimits": {
        "type": "object",
        "properties": {
          "mac_vms": { "type": "integer" },
          "rds": { "type": "integer" },
          "vms": { "type": "integer" }
        }
      },
      "Tunnel": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "owner": { "type": "string" },
          "status": { "type": "string" },
          "is_ready": { "type": "boolean" },
          "creation_time": { "type": "integer", "format": "int64" },
          "domain_names": { "type": "array", "items": { "type": "string" } },
          "team_ids": { "type": "array", "items": { "type": "string" } },
          "tunnel_identifier": { "type": "string" },
          "host": { "type": "string" },
          "last_connected": { "type": "integer", "format": "int64" },
          "launch_time": { "type": "integer", "format": "int64" },
          "vm_version": { "type": "string" },
          "shared_tunnel": { "type": "boolean" },
          "shutdown_reason": { "type": "string", "nullable": true },
          "extra_info": { "type": "object" }
        }
      },
      "TunnelVersionInfo": {
        "type": "object",
        "properties": {
          "downloads": { "type": "object", "additionalProperties": { "type": "string" } },
          "latest_version": { "type": "string" },
          "info_url": { "type": "string" },
          "warning": { "type": "string" },
          "sha1": { "type": "string" },
          "download_url": { "type": "string" },
          "all_downloads": { "type": "object" }
        }
      },
      "StorageFile": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "owner": { "type": "object", "properties": { "id": { "type": "string" }, "org_id": { "type": "string" } } },
          "name": { "type": "string" },
          "upload_timestamp": { "type": "integer", "format": "int64" },
          "etag": { "type": "string" },
          "kind": { "type": "string", "enum": ["android", "ios", "other"] },
          "group_id": { "type": "integer" },
          "size": { "type": "integer" },
          "description": { "type": "string", "nullable": true },
          "tags": { "type": "array", "items": { "type": "string" } },
          "metadata": { "type": "object" },
          "access": { "type": "object" },
          "sha256": { "type": "string" }
        }
      },
      "StorageFileListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/StorageFile" } },
          "links": { "type": "object" },
          "page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total_items": { "type": "integer" }
        }
      },
      "StorageGroupListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" },
                "project_path": { "type": "string" },
                "recent": { "$ref": "#/components/schemas/StorageFile" },
                "access": { "type": "object" },
                "count": { "type": "integer" },
                "settings": { "type": "object" }
              }
            }
          },
          "links": { "type": "object" },
          "page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total_items": { "type": "integer" }
        }
      },
      "StorageGroupSettings": {
        "type": "object",
        "properties": {
          "settings": {
            "type": "object",
            "properties": {
              "proxy": { "type": "object" },
              "audio_capture": { "type": "boolean" },
              "proxy_enabled": { "type": "boolean" },
              "lang": { "type": "string" },
              "orientation": { "type": "string" },
              "resigning_enabled": { "type": "boolean" },
              "resigning": { "type": "object" }
            }
          },
          "kind": { "type": "string" },
          "identifier": { "type": "string" }
        }
      },
      "PaginatedStringList": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "type": "string" } },
          "links": { "type": "object" },
          "page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total_items": { "type": "integer" }
        }
      },
      "PlatformStatus": {
        "type": "object",
        "properties": {
          "wait_time": { "type": "number", "description": "Current average wait time in seconds" },
          "service_operational": { "type": "boolean", "description": "Whether the service is operational" },
          "status_message": { "type": "string", "description": "Human-readable status message" }
        }
      },
      "PlatformEntry": {
        "type": "object",
        "properties": {
          "short_version": { "type": "string" },
          "long_name": { "type": "string" },
          "api_name": { "type": "string" },
          "long_version": { "type": "string" },
          "device": { "type": "string" },
          "latest_stable_version": { "type": "string" },
          "automation_backend": { "type": "string" },
          "os": { "type": "string" },
          "recommended_backend_version": { "type": "string" },
          "supported_backend_versions": { "type": "array", "items": { "type": "string" } },
          "deprecated_backend_versions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "AnalyticsTestResults": {
        "type": "object",
        "properties": {
          "has_more": { "type": "boolean" },
          "items": { "type": "array", "items": { "type": "object" } },
          "meta": { "type": "object", "properties": { "status": { "type": "string" } } }
        }
      },
      "TestMetricsSummary": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "fastestRun": { "type": "number" },
          "slowestRun": { "type": "number" },
          "statuses": { "type": "object", "additionalProperties": { "type": "integer" } },
          "totalQueueTime": { "type": "number" },
          "totalRunTime": { "type": "number" }
        }
      },
      "TrendBuckets": {
        "type": "object",
        "properties": {
          "buckets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "timestamp": { "type": "integer", "format": "int64" },
                "datetime": { "type": "string" },
                "count": { "type": "integer" },
                "aggs": { "type": "object" }
              }
            }
          },
          "metrics": { "type": "object" }
        }
      },
      "InsightsTestResults": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "type": "object" } },
          "total": { "type": "integer" },
          "statuses": { "type": "object", "additionalProperties": { "type": "integer" } },
          "max_duration": { "type": "number" }
        }
      },
      "InsightsFilters": {
        "type": "object",
        "properties": {
          "automation_backend": { "type": "array", "items": { "$ref": "#/components/schemas/FilterItem" } },
          "browser": { "type": "array", "items": { "$ref": "#/components/schemas/FilterItem" } },
          "build": { "type": "array", "items": { "$ref": "#/components/schemas/FilterItem" } },
          "os": { "type": "array", "items": { "$ref": "#/components/schemas/FilterItem" } },
          "device": { "type": "array", "items": { "$ref": "#/components/schemas/FilterItem" } },
          "tag": { "type": "array", "items": { "$ref": "#/components/schemas/FilterItem" } }
        }
      },
      "FilterItem": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "count": { "type": "integer" }
        }
      },
      "InsightsErrorResults": {
        "type": "object",
        "properties": {
          "buckets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "count": { "type": "integer" }
              }
            }
          },
          "all_items_count": { "type": "integer" },
          "total": { "type": "integer" }
        }
      },
      "InsightsTestCaseResults": {
        "type": "object",
        "properties": {
          "test_cases": { "type": "array", "items": { "type": "object" } },
          "total": { "type": "integer" },
          "statuses": { "type": "object", "additionalProperties": { "type": "integer" } },
          "avg_runtime": { "type": "number" }
        }
      },
      "InsightsCoverageResults": {
        "type": "object",
        "properties": {
          "coverage": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "count": { "type": "integer" },
                "total_duration": { "type": "number" }
              }
            }
          },
          "max_count": { "type": "integer" }
        }
      },
      "ActivityResponse": {
        "type": "object",
        "properties": {
          "ccy_exec_mean": { "type": "array", "items": { "type": "number" } },
          "ccy_exec_peak": { "type": "array", "items": { "type": "number" } },
          "datestamp": { "type": "array", "items": { "type": "string" } },
          "jobs": { "type": "array", "items": { "type": "integer" } },
          "minutes": { "type": "array", "items": { "type": "number" } }
        }
      },
      "RealDevice": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "os": { "type": "string" },
          "osVersion": { "type": "string" },
          "manufacturer": { "type": "string" },
          "resolutionWidth": { "type": "integer" },
          "resolutionHeight": { "type": "integer" },
          "ramSize": { "type": "integer" },
          "cpuType": { "type": "string" },
          "cpuCores": { "type": "integer" },
          "cpuFrequency": { "type": "integer" },
          "formFactor": { "type": "string" },
          "screenSize": { "type": "number" },
          "dpiName": { "type": "string" },
          "isPrivate": { "type": "boolean" },
          "supportsAppiumWebAppTesting": { "type": "boolean" },
          "supportsGlobalProxy": { "type": "boolean" },
          "supportsMinicapSocketConnection": { "type": "boolean" },
          "modelNumber": { "type": "string" },
          "internalStorageSize": { "type": "integer" },
          "abiType": { "type": "string" },
          "apiLevel": { "type": "integer" }
        }
      },
      "DeviceStatusResponse": {
        "type": "object",
        "properties": {
          "devices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "descriptor": { "type": "string" },
                "state": { "type": "string", "enum": ["AVAILABLE", "IN_USE", "CLEANING", "MAINTENANCE", "REBOOTING", "OFFLINE"] },
                "inUseBy": { "type": "string", "nullable": true },
                "isPrivateDevice": { "type": "boolean" }
              }
            }
          }
        }
      },
      "RealDeviceJob": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "device_name": { "type": "string" },
          "os": { "type": "string" },
          "os_version": { "type": "string" },
          "start_time": { "type": "integer", "format": "int64" },
          "end_time": { "type": "integer", "format": "int64" },
          "video_url": { "type": "string" },
          "device_log_url": { "type": "string" },
          "passed": { "type": "boolean", "nullable": true },
          "build": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "automation_backend": { "type": "string" },
          "test_framework": { "type": "string" },
          "app_id": { "type": "string" },
          "error": { "type": "string", "nullable": true }
        }
      },
      "RealDeviceJobListResponse": {
        "type": "object",
        "properties": {
          "entities": { "type": "array", "items": { "$ref": "#/components/schemas/RealDeviceJob" } },
          "metaData": {
            "type": "object",
            "properties": {
              "offset": { "type": "integer" },
              "limit": { "type": "integer" },
              "moreAvailable": { "type": "boolean" }
            }
          }
        }
      },
      "PrivateRealDevice": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "os": { "type": "string" },
          "state": { "type": "string" },
          "team": { "type": "object" },
          "appWhitelist": { "type": "array", "items": { "type": "string" } },
          "accountWhitelist": { "type": "array", "items": { "type": "string" } },
          "systemAppAllowlist": { "type": "array", "items": { "type": "string" } },
          "applePaySupportEnabled": { "type": "boolean" },
          "skipCleaningFolders": { "type": "array", "items": { "type": "string" } }
        }
      },
      "DeviceSettings": {
        "type": "object",
        "required": ["appWhitelist", "accountWhitelist", "systemAppAllowlist", "applePaySupportEnabled", "skipCleaningFolders"],
        "properties": {
          "appWhitelist": { "type": "array", "items": { "type": "string" } },
          "accountWhitelist": { "type": "array", "items": { "type": "string" } },
          "systemAppAllowlist": { "type": "array", "items": { "type": "string" } },
          "applePaySupportEnabled": { "type": "boolean" },
          "skipCleaningFolders": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}