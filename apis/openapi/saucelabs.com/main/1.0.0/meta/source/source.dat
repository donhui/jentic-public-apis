          { "name": "time_range", "in": "query", "description": "Predefined time range", "schema": { "type": "string" } },
          { "name": "scope", "in": "query", "description": "Scope of results", "schema": { "type": "string" } },
          { "name": "owner", "in": "query", "description": "Filter by owner", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "description": "Filter by test status", "schema": { "type": "string" } },
          { "name": "build", "in": "query", "description": "Filter by build name", "schema": { "type": "string" } },
