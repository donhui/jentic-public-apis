{
  "openapi": "3.0.3",
  "info": {
    "title": "Peerdom API",
    "description": "Peerdom helps teams navigate change with smart org charts that boost collaboration and performance. This API provides access to manage peers, roles, groups, projects, maps, and tenant information.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.peerdom.app/v1/docs"
  },
  "servers": [
    {
      "url": "https://api.peerdom.app/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Peers",
      "description": "Operations related to managing peers"
    },
    {
      "name": "Roles",
      "description": "Operations related to managing roles and role holders"
    },
    {
      "name": "Groups",
      "description": "Operations related to managing groups"
    },
    {
      "name": "Projects",
      "description": "Operations related to projects"
    },
    {
      "name": "Maps",
      "description": "Operations related to organizational maps"
    },
    {
      "name": "Tenant",
      "description": "Operations related to tenant information"
    }
  ],
  "paths": {
    "/peers": {
      "get": {
        "tags": ["Peers"],
        "summary": "Get List of Peers",
        "description": "Retrieve a paginated list of all peers with optional custom fields",
        "operationId": "getPeers",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Pagination limit",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "with",
            "in": "query",
            "description": "Include additional data (e.g., 'customfields')",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Peer"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - API access not available"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "post": {
        "tags": ["Peers"],
        "summary": "Create New Peer",
        "description": "Create a new peer with the provided information",
        "operationId": "createPeer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PeerInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Peer created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Peer"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/peers/{id}": {
      "get": {
        "tags": ["Peers"],
        "summary": "Get Single Peer",
        "description": "Retrieve a single peer by ID",
        "operationId": "getPeerById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID of the peer",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "with",
            "in": "query",
            "description": "Include additional data (e.g., 'customfields')",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Peer"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "tags": ["Peers"],
        "summary": "Update A Peer",
        "description": "Update an existing peer's information",
        "operationId": "updatePeer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID of the peer",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PeerInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Peer updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Peer"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "tags": ["Peers"],
        "summary": "Delete A Peer",
        "description": "Delete an existing peer",
        "operationId": "deletePeer",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID of the peer",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Peer deleted successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/roles": {
      "get": {
        "tags": ["Roles"],
        "summary": "Get List Of Roles",
        "description": "Retrieve a list of roles with optional filters and inclusions",
        "operationId": "getRoles",
