    "/roles/{roleId}/peers": {
      "post": {
        "tags": ["Roles"],
        "summary": "Assign existing role to a peer",
        "description": "Assign a role to a peer with optional percentage and focus",
        "operationId": "assignRole",
        "parameters": [
          {
            "name": "roleId",
            "in": "path",
