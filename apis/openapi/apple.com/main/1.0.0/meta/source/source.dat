{
  "openapi": "3.0.3",
  "info": {
    "title": "iTunes Search API",
    "description": "The iTunes Search API allows you to search for content within the iTunes Store, App Store, iBooks Store, and Mac App Store. You can also look up content by iTunes ID, AMG ID, UPC/EAN, or ISBN.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.apple.com/library/archive/documentation/AudioVideo/Conceptual/iTuneSearchAPI/index.html"
  },
  "servers": [
    {
      "url": "https://itunes.apple.com",
      "description": "iTunes Search API production server"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchContent",
        "summary": "Search for content in the iTunes Store",
        "description": "Search for content within the iTunes Store, App Store, iBooks Store, and Mac App Store using a text-based query.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "required": true,
            "description": "The URL-encoded text string you want to search for. For example: jack+johnson.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country",
            "in": "query",
            "required": false,
            "description": "The two-letter country code for the store you want to search. The search uses the default store front for the specified country.",
            "schema": {
              "type": "string",
              "default": "US"
            }
          },
          {
            "name": "media",
            "in": "query",
            "required": false,
            "description": "The media type you want to search for.",
            "schema": {
              "type": "string",
              "enum": [
                "movie",
                "podcast",
                "music",
                "musicVideo",
                "audiobook",
                "shortFilm",
                "tvShow",
                "software",
                "ebook",
                "all"
              ],
              "default": "all"
            }
          },
          {
            "name": "entity",
            "in": "query",
            "required": false,
            "description": "The type of results you want returned, relative to the specified media type.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attribute",
            "in": "query",
            "required": false,
            "description": "The attribute you want to search for in the stores, relative to the specified media type.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The number of search results you want the iTunes Store to return.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "The language, English or Japanese, you want to use when returning search results.",
            "schema": {
              "type": "string",
              "enum": [
                "en_us",
                "ja_jp"
              ],
              "default": "en_us"
            }
          },
          {
            "name": "version",
            "in": "query",
            "required": false,
            "description": "The search result key version you want to receive back from your search.",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2
              ],
              "default": 2
            }
          },
          {
            "name": "explicit",
            "in": "query",
            "required": false,
            "description": "A flag indicating whether or not you want to include explicit content in your results.",
            "schema": {
              "type": "string",
              "enum": [
                "Yes",
                "No"
              ],
              "default": "Yes"
            }
          },
          {
            "name": "callback",
            "in": "query",
            "required": false,
            "description": "The name of the Javascript callback function you want to use when returning search results to your website (JSONP).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - rate limit exceeded"
          }
        }
      }
    },
    "/lookup": {
      "get": {
        "operationId": "lookupContent",
        "summary": "Look up content by ID",
        "description": "Look up content in the iTunes Store by iTunes ID, AMG ID, UPC, EAN, or ISBN. Lookups are faster and contain fewer false-positive results than text-based searches.",
        "tags": ["Lookup"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": false,
            "description": "iTunes ID of the content. Use a comma-separated list for multiple IDs.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "amgArtistId",
            "in": "query",
            "required": false,
            "description": "AMG artist ID. Use a comma-separated list for multiple IDs.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "amgAlbumId",
            "in": "query",
            "required": false,
            "description": "AMG album ID. Use a comma-separated list for multiple IDs.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "amgVideoId",
            "in": "query",
            "required": false,
            "description": "AMG video ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "upc",
            "in": "query",
            "required": false,
            "description": "UPC or EAN barcode of the content.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "isbn",
            "in": "query",
            "required": false,
            "description": "13-digit ISBN of the content.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entity",
            "in": "query",
            "required": false,
            "description": "The type of results you want returned.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The number of results to return per ID.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "The sort order for results.",
            "schema": {
              "type": "string",
              "enum": [
                "recent"
              ]
            }
          },
          {
            "name": "callback",
            "in": "query",
            "required": false,
            "description": "The name of the Javascript callback function for JSONP.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful lookup response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - rate limit exceeded"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "properties": {
          "resultCount": {
            "type": "integer",
            "description": "The number of results returned."
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            },
            "description": "An array of result objects."
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "wrapperType": {
            "type": "string",
            "description": "The type of result (track, collection, artist)."
          },
          "kind": {
            "type": "string",
            "description": "The kind of content (song, feature-movie, podcast, etc.)."
          },
          "artistId": {
            "type": "integer",
            "description": "The iTunes artist ID."
          },
          "collectionId": {
            "type": "integer",
            "description": "The iTunes collection ID."
          },
          "trackId": {
            "type": "integer",
            "description": "The iTunes track ID."
          },
          "artistName": {
            "type": "string",
            "description": "The name of the artist."
          },
          "collectionName": {
            "type": "string",
            "description": "The name of the collection."
          },
          "trackName": {
            "type": "string",
            "description": "The name of the track."
          },
          "artworkUrl60": {
            "type": "string",
            "description": "URL for 60x60 artwork image."
          },
          "artworkUrl100": {
            "type": "string",
            "description": "URL for 100x100 artwork image."
          },
          "collectionPrice": {
            "type": "number",
            "description": "The collection price."
          },
          "trackPrice": {
            "type": "number",
            "description": "The track price."
          },
          "releaseDate": {
            "type": "string",
            "format": "date-time",
            "description": "The release date."
          },
          "primaryGenreName": {
            "type": "string",
            "description": "The primary genre name."
          },
          "country": {
            "type": "string",
            "description": "The country code."
          },
          "currency": {
            "type": "string",
            "description": "The currency code."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "errorMessage": {
            "type": "string",
            "description": "Error message describing the issue."
          },
          "queryParameters": {
            "type": "object",
            "description": "The query parameters that caused the error."
          }
        }
      }
    }
  },
  "security": []
}