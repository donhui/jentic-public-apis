                "example": "wJlCDLIl6KTWypN7T6vc6nWEmEYe99Hjf1XY1xmqV-M=#"
              }
            }
          }
        },
        "required": [
          "paging_metadata"
        ]
      },
      "PackageDescription": {
        "properties": {
          "aasIds": {
            "items": {
