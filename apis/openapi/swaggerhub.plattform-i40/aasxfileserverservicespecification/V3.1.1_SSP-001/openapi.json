                      "type": "string"
                    }
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "fileName": {
                    "type": "string"
                  }
                }
              },
              "encoding": {
                "file": {
                  "contentType": "application/asset-administration-shell-package"
                }
              }
            }
