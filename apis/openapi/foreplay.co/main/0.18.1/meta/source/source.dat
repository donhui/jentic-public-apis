{
  "openapi": "3.0.3",
  "info": {
    "title": "Foreplay Public API",
    "description": "The Foreplay Public API enables programmatic access to a vast database of advertisements and brands. Search, filter, and analyze ads across platforms including Facebook, Instagram, and Messenger. Manage swipefile collections, boards, and track brands via Spyder subscriptions.",
    "version": "0.18.1",
    "contact": {
      "name": "Foreplay",
      "url": "https://foreplay.co"
    },
    "x-jentic-source-url": "https://docs.foreplay.co/"
  },
  "servers": [
    {
      "url": "https://public.api.foreplay.co",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Swipefile",
      "description": "Personal saved ad collections"
    },
    {
      "name": "Boards",
      "description": "Organizational boards for ads and brands"
    },
    {
      "name": "Spyder",
      "description": "Brand subscription tracking"
    },
    {
      "name": "Ads",
      "description": "Individual ad retrieval and analysis"
    },
    {
      "name": "Brands",
      "description": "Brand lookup and ad retrieval by brand"
    }
  ],
  "paths": {
    "/api/swipefile/ads": {
      "get": {
        "operationId": "getSwipefileAds",
        "summary": "Retrieve ads from the user's personal swipefile collection",
        "tags": ["Swipefile"],
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "description": "Start date filter (YYYY-MM-DD or timestamp)",
            "schema": { "type": "string" }
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "End date filter (YYYY-MM-DD or timestamp)",
            "schema": { "type": "string" }
          },
          {
            "name": "live",
            "in": "query",
            "description": "Filter by active/inactive status",
            "schema": { "type": "boolean" }
          },
          {
            "name": "display_format",
            "in": "query",
            "description": "Filter by ad display format",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["video", "image", "carousel", "dco", "story", "reels"]
              }
            }
          },
          {
            "name": "publisher_platform",
            "in": "query",
            "description": "Filter by publisher platform",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["facebook", "instagram", "audience_network", "messenger"]
              }
            }
          },
          {
            "name": "niches",
            "in": "query",
            "description": "Filter by category/niche",
            "schema": { "type": "array", "items": { "type": "string" } }
          },
          {
            "name": "market_target",
            "in": "query",
            "description": "Filter by market target",
            "schema": {
              "type": "array",
              "items": { "type": "string", "enum": ["b2b", "b2c"] }
            }
          },
          {
            "name": "languages",
            "in": "query",
            "description": "Filter by language codes",
            "schema": { "type": "array", "items": { "type": "string" } }
          },
          {
            "name": "video_duration_min",
            "in": "query",
            "description": "Minimum video duration in seconds",
            "schema": { "type": "number" }
          },
          {
            "name": "video_duration_max",
            "in": "query",
            "description": "Maximum video duration in seconds",
            "schema": { "type": "number" }
          },
          {
            "name": "running_duration_min_days",
            "in": "query",
            "description": "Minimum running duration in days",
            "schema": { "type": "integer" }
          },
          {
            "name": "running_duration_max_days",
            "in": "query",
            "description": "Maximum running duration in days",
            "schema": { "type": "integer" }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Results per page (max 250)",
            "schema": { "type": "integer", "default": 10, "maximum": 250 }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order for results",
            "schema": {
              "type": "string",
              "enum": ["saved_newest", "newest", "oldest", "longest_running", "most_relevant"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with ads",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdsListResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "402": { "description": "Insufficient credits", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "429": { "description": "Rate limit exceeded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/boards": {
      "get": {
        "operationId": "getBoards",
        "summary": "Get all boards for the authenticated user",
        "tags": ["Boards"],
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Results per page (max 10)",
            "schema": { "type": "integer", "default": 10, "maximum": 10 }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with boards",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BaseResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/board/brands": {
      "get": {
        "operationId": "getBrandsByBoardId",
        "summary": "Get all brands for a specific board",
        "tags": ["Boards"],
        "parameters": [
          {
            "name": "board_id",
            "in": "query",
            "required": true,
            "description": "Board identifier",
            "schema": { "type": "string" }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Results per page (max 10)",
            "schema": { "type": "integer", "default": 10, "maximum": 10 }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with brands",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BrandsListResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Board not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/board/ads": {
      "get": {
        "operationId": "getBoardAds",
        "summary": "Get ads by board ID with filters",
        "tags": ["Boards"],
        "parameters": [
          {
            "name": "board_id",
            "in": "query",
            "required": true,
            "description": "Board identifier",
            "schema": { "type": "string" }
          },
          { "name": "start_date", "in": "query", "description": "Start date filter", "schema": { "type": "string" } },
          { "name": "end_date", "in": "query", "description": "End date filter", "schema": { "type": "string" } },
          { "name": "live", "in": "query", "description": "Filter by active/inactive", "schema": { "type": "boolean" } },
          { "name": "display_format", "in": "query", "description": "Filter by display format", "schema": { "type": "array", "items": { "type": "string", "enum": ["video", "image", "carousel", "dco", "story", "reels"] } } },
          { "name": "publisher_platform", "in": "query", "description": "Filter by platform", "schema": { "type": "array", "items": { "type": "string", "enum": ["facebook", "instagram", "audience_network", "messenger"] } } },
          { "name": "niches", "in": "query", "description": "Filter by niche", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "market_target", "in": "query", "description": "Filter by market target", "schema": { "type": "array", "items": { "type": "string", "enum": ["b2b", "b2c"] } } },
          { "name": "languages", "in": "query", "description": "Filter by languages", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "video_duration_min", "in": "query", "description": "Min video duration (seconds)", "schema": { "type": "number" } },
          { "name": "video_duration_max", "in": "query", "description": "Max video duration (seconds)", "schema": { "type": "number" } },
          { "name": "running_duration_min_days", "in": "query", "description": "Min running duration (days)", "schema": { "type": "integer" } },
          { "name": "running_duration_max_days", "in": "query", "description": "Max running duration (days)", "schema": { "type": "integer" } },
          { "name": "cursor", "in": "query", "description": "Pagination cursor", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "description": "Results per page (max 250)", "schema": { "type": "integer", "default": 10, "maximum": 250 } },
          { "name": "order", "in": "query", "description": "Sort order", "schema": { "type": "string", "enum": ["newest", "oldest", "longest_running", "most_relevant"] } }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdsListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Board not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/spyder/brands": {
      "get": {
        "operationId": "getSpyderBrands",
        "summary": "Get user's Spyder tracked brands",
        "tags": ["Spyder"],
        "parameters": [
          { "name": "offset", "in": "query", "description": "Pagination offset", "schema": { "type": "integer", "default": 0 } },
          { "name": "limit", "in": "query", "description": "Results per page (max 10)", "schema": { "type": "integer", "default": 10, "maximum": 10 } }
        ],
        "responses": {
          "200": { "description": "Successful response with brands", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BrandsListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/spyder/brand": {
      "get": {
        "operationId": "getSpyderBrand",
        "summary": "Get a specific Spyder tracked brand",
        "tags": ["Spyder"],
        "parameters": [
          { "name": "brand_id", "in": "query", "required": true, "description": "Brand identifier", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response with brand", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BrandResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Brand not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/spyder/brand/ads": {
      "get": {
        "operationId": "getSpyderBrandAds",
        "summary": "Get ads for a brand tracked in Spyder",
        "tags": ["Spyder"],
        "parameters": [
          { "name": "brand_id", "in": "query", "required": true, "description": "Brand identifier", "schema": { "type": "string" } },
          { "name": "start_date", "in": "query", "description": "Start date filter", "schema": { "type": "string" } },
          { "name": "end_date", "in": "query", "description": "End date filter", "schema": { "type": "string" } },
          { "name": "live", "in": "query", "description": "Filter by active/inactive", "schema": { "type": "boolean" } },
          { "name": "display_format", "in": "query", "description": "Filter by display format", "schema": { "type": "array", "items": { "type": "string", "enum": ["video", "image", "carousel", "dco", "story", "reels"] } } },
          { "name": "publisher_platform", "in": "query", "description": "Filter by platform", "schema": { "type": "array", "items": { "type": "string", "enum": ["facebook", "instagram", "audience_network", "messenger"] } } },
          { "name": "niches", "in": "query", "description": "Filter by niche", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "market_target", "in": "query", "description": "Filter by market target", "schema": { "type": "array", "items": { "type": "string", "enum": ["b2b", "b2c"] } } },
          { "name": "languages", "in": "query", "description": "Filter by languages", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "video_duration_min", "in": "query", "description": "Min video duration (seconds)", "schema": { "type": "number" } },
          { "name": "video_duration_max", "in": "query", "description": "Max video duration (seconds)", "schema": { "type": "number" } },
          { "name": "running_duration_min_days", "in": "query", "description": "Min running duration (days)", "schema": { "type": "integer" } },
          { "name": "running_duration_max_days", "in": "query", "description": "Max running duration (days)", "schema": { "type": "integer" } },
          { "name": "cursor", "in": "query", "description": "Pagination cursor", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "description": "Results per page (max 250)", "schema": { "type": "integer", "default": 10, "maximum": 250 } },
          { "name": "order", "in": "query", "description": "Sort order", "schema": { "type": "string", "enum": ["newest", "oldest", "longest_running", "most_relevant"] } }
        ],
        "responses": {
          "200": { "description": "Successful response with ads", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdsListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Brand not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/ad": {
      "get": {
        "operationId": "getAdByAdIdQuery",
        "summary": "Get ad details by ad ID (query parameter)",
        "tags": ["Ads"],
        "parameters": [
          { "name": "ad_id", "in": "query", "required": true, "description": "Ad identifier", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response with ad", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Ad not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/ad/{ad_id}": {
      "get": {
        "operationId": "getAdById",
        "summary": "Get ad details by ID (path parameter)",
        "tags": ["Ads"],
        "parameters": [
          { "name": "ad_id", "in": "path", "required": true, "description": "Ad identifier", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response with ad", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Ad not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/ad/duplicates/{ad_id}": {
      "get": {
        "operationId": "getAdDuplicates",
        "summary": "Get group of ads using the same image or video",
        "tags": ["Ads"],
        "parameters": [
          { "name": "ad_id", "in": "path", "required": true, "description": "Ad identifier", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response with duplicate ads", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdsListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Ad not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/brand/getAdsByBrandId": {
      "get": {
        "operationId": "getAdsByBrandIds",
        "summary": "Get ads by brand IDs with filters",
        "tags": ["Brands"],
        "parameters": [
          { "name": "brand_ids", "in": "query", "required": true, "description": "Array of brand identifiers", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "start_date", "in": "query", "description": "Start date filter", "schema": { "type": "string" } },
          { "name": "end_date", "in": "query", "description": "End date filter", "schema": { "type": "string" } },
          { "name": "live", "in": "query", "description": "Filter by active/inactive", "schema": { "type": "boolean" } },
          { "name": "display_format", "in": "query", "description": "Filter by display format", "schema": { "type": "array", "items": { "type": "string", "enum": ["video", "image", "carousel", "dco", "story", "reels"] } } },
          { "name": "publisher_platform", "in": "query", "description": "Filter by platform", "schema": { "type": "array", "items": { "type": "string", "enum": ["facebook", "instagram", "audience_network", "messenger"] } } },
          { "name": "niches", "in": "query", "description": "Filter by niche", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "market_target", "in": "query", "description": "Filter by market target", "schema": { "type": "array", "items": { "type": "string", "enum": ["b2b", "b2c"] } } },
          { "name": "languages", "in": "query", "description": "Filter by languages", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "video_duration_min", "in": "query", "description": "Min video duration (seconds)", "schema": { "type": "number" } },
          { "name": "video_duration_max", "in": "query", "description": "Max video duration (seconds)", "schema": { "type": "number" } },
          { "name": "running_duration_min_days", "in": "query", "description": "Min running duration (days)", "schema": { "type": "integer" } },
          { "name": "running_duration_max_days", "in": "query", "description": "Max running duration (days)", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "description": "Sort order", "schema": { "type": "string", "enum": ["newest", "oldest", "longest_running", "most_relevant"] } },
          { "name": "cursor", "in": "query", "description": "Pagination cursor", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "description": "Results per page (max 250)", "schema": { "type": "integer", "default": 10, "maximum": 250 } }
        ],
        "responses": {
          "200": { "description": "Successful response with ads", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdsListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/brand/getAdsByPageId": {
      "get": {
        "operationId": "getAdsByPageId",
        "summary": "Get ads by Facebook page ID with filters",
        "tags": ["Brands"],
        "parameters": [
          { "name": "page_id", "in": "query", "required": true, "description": "Facebook page identifier", "schema": { "type": "string" } },
          { "name": "start_date", "in": "query", "description": "Start date filter", "schema": { "type": "string" } },
          { "name": "end_date", "in": "query", "description": "End date filter", "schema": { "type": "string" } },
          { "name": "live", "in": "query", "description": "Filter by active/inactive", "schema": { "type": "boolean" } },
          { "name": "display_format", "in": "query", "description": "Filter by display format", "schema": { "type": "array", "items": { "type": "string", "enum": ["video", "image", "carousel", "dco", "story", "reels"] } } },
          { "name": "publisher_platform", "in": "query", "description": "Filter by platform", "schema": { "type": "array", "items": { "type": "string", "enum": ["facebook", "instagram", "audience_network", "messenger"] } } },
          { "name": "niches", "in": "query", "description": "Filter by niche", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "market_target", "in": "query", "description": "Filter by market target", "schema": { "type": "array", "items": { "type": "string", "enum": ["b2b", "b2c"] } } },
          { "name": "languages", "in": "query", "description": "Filter by languages", "schema": { "type": "array", "items": { "type": "string" } } },
          { "name": "video_duration_min", "in": "query", "description": "Min video duration (seconds)", "schema": { "type": "number" } },
          { "name": "video_duration_max", "in": "query", "description": "Max video duration (seconds)", "schema": { "type": "number" } },
          { "name": "running_duration_min_days", "in": "query", "description": "Min running duration (days)", "schema": { "type": "integer" } },
          { "name": "running_duration_max_days", "in": "query", "description": "Max running duration (days)", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "description": "Sort order", "schema": { "type": "string", "enum": ["newest", "oldest", "longest_running", "most_relevant"] } },
          { "name": "cursor", "in": "query", "description": "Pagination cursor", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "description": "Results per page (max 250)", "schema": { "type": "integer", "default": 10, "maximum": 250 } }
        ],
        "responses": {
          "200": { "description": "Successful response with ads", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdsListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/brand/getBrandsByDomain": {
      "get": {
        "operationId": "getBrandsByDomain",
        "summary": "Get brands by domain name",
        "tags": ["Brands"],
        "parameters": [
          { "name": "domain", "in": "query", "required": true, "description": "Domain name or URL to search", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "description": "Results per page", "schema": { "type": "integer", "default": 10 } },
          { "name": "order", "in": "query", "description": "Sort order", "schema": { "type": "string", "enum": ["most_ranked", "least_ranked"] } }
        ],
        "responses": {
          "200": { "description": "Successful response with brands", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BrandsListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for authentication. Generate from your Foreplay dashboard."
      }
    },
    "schemas": {
      "BaseResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {}
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        }
      },
      "AdsListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Ad" }
          },
          "metadata": { "$ref": "#/components/schemas/Metadata" }
        }
      },
      "AdResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Ad" },
          "metadata": { "$ref": "#/components/schemas/Metadata" }
        }
      },
      "BrandsListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Brand" }
          },
          "metadata": { "$ref": "#/components/schemas/Metadata" }
        }
      },
      "BrandResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Brand" },
          "metadata": { "$ref": "#/components/schemas/Metadata" }
        }
      },
      "Metadata": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "status_code": { "type": "integer" },
          "message": { "type": "string" },
          "processed_at": { "type": "string", "format": "date-time" },
          "cursor": { "type": "string", "nullable": true },
          "filters": { "type": "object" },
          "count": { "type": "integer" },
          "order": { "type": "string" }
        }
      },
      "Ad": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique identifier" },
          "ad_id": { "type": "string", "description": "Platform-specific ad ID" },
          "name": { "type": "string", "description": "Ad headline/title" },
          "brand_id": { "type": "string", "description": "Associated brand ID" },
          "description": { "type": "string" },
          "headline": { "type": "string" },
          "cta_title": { "type": "string", "description": "Call-to-action text" },
          "cta_type": { "type": "string" },
          "categories": { "type": "array", "items": { "type": "string" } },
          "creative_targeting": { "type": "string" },
          "languages": { "type": "array", "items": { "type": "string" } },
          "market_target": { "type": "string" },
          "niches": { "type": "array", "items": { "type": "string" } },
          "product_category": { "type": "string" },
          "full_transcription": { "type": "string", "nullable": true },
          "timestamped_transcription": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/TranscriptionSegment"
            }
          },
          "cards": { "type": "array", "items": { "type": "object" }, "description": "Cards for carousel/DCO/DPA ads" },
          "avatar": { "type": "string", "format": "uri" },
          "display_format": { "type": "string", "enum": ["video", "image", "carousel", "dco", "dpa", "story", "reels"] },
          "emotional_drivers": { "type": "array", "nullable": true, "items": { "type": "string" } },
          "link_url": { "type": "string", "format": "uri" },
          "live": { "type": "boolean" },
          "persona": { "type": "string", "nullable": true },
          "publisher_platform": { "type": "array", "items": { "type": "string" } },
          "started_running": { "type": "string", "format": "date-time" },
          "thumbnail": { "type": "string", "format": "uri" },
          "video": { "type": "string", "format": "uri", "nullable": true },
          "image": { "type": "string", "format": "uri", "nullable": true },
          "content_filter": { "type": "object", "nullable": true },
          "video_duration": { "type": "number", "description": "Duration in seconds" },
          "running_duration": {
            "type": "object",
            "properties": {
              "days": { "type": "integer" }
            }
          }
        }
      },
      "Brand": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique identifier" },
          "name": { "type": "string" },
          "description": {
            "type": "object",
            "properties": {
              "text": { "type": "string" }
            }
          },
          "category": { "type": "string" },
          "niches": { "type": "array", "items": { "type": "string" } },
          "verification_status": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "websites": { "type": "array", "items": { "type": "string", "format": "uri" } },
          "avatar": { "type": "string", "format": "uri" },
          "ad_library_id": { "type": "string" },
          "is_delegate_page_with_linked_primary_profile": { "type": "boolean" }
        }
      },
      "TranscriptionSegment": {
        "type": "object",
        "properties": {
          "startTime": { "type": "number" },
          "endTime": { "type": "number" },
          "sentence": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "success": { "type": "boolean" },
              "message": { "type": "string" },
              "status_code": { "type": "integer" },
              "processed_at": { "type": "string", "format": "date-time" }
            }
          },
          "error": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "data": { "type": "array", "items": {} }
        }
      }
    }
  }
}