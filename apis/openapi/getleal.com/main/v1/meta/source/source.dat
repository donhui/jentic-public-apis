{
  "openapi": "3.0.3",
  "info": {
    "title": "Leal Loyalty API",
    "version": "v1",
    "description": "REST API for managing your Leal loyalty program - stores, customers, cards, rewards, and more.",
    "x-jentic-source-url": "https://app.getleal.com/docs/api.html"
  },
  "servers": [
    {
      "url": "https://app.getleal.com/api/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cards",
      "description": "Manage loyalty stamp card templates"
    },
    {
      "name": "Customer Cards",
      "description": "View a customer's loyalty card progress"
    },
    {
      "name": "Customers",
      "description": "Manage store customers"
    },
    {
      "name": "Locations",
      "description": "Manage physical store locations"
    },
    {
      "name": "Posters",
      "description": "Manage QR code signup posters"
    },
    {
      "name": "Rewards",
      "description": "Manage loyalty card rewards"
    },
    {
      "name": "Stores",
      "description": "Manage stores (accounts)"
    }
  ],
  "paths": {
    "/accounts/{account_id}/cards": {
      "get": {
        "operationId": "listcards",
        "summary": "List all cards",
        "tags": [
          "Cards"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The account_id"
          }
        ],
        "responses": {
          "200": {
            "description": "List of card templates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Card"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createcard",
        "summary": "Create a card",
        "tags": [
          "Cards"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The account_id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CardCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Card"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/accounts/{account_id}/cards/{id}": {
