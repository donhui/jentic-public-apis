{
  "openapi": "3.0.3",
  "info": {
    "title": "Paperspace API",
    "version": "1.0.0",
    "description": "The Paperspace API allows you to programmatically manage Paperspace resources including projects, deployments, and machine learning infrastructure using conventional HTTP requests.",
    "x-jentic-source-url": "https://docs.digitalocean.com/reference/paperspace/"
  },
  "servers": [
    {
      "url": "https://api.paperspace.com/v1"
    }
  ],
  "paths": {
    "/auth/session": {
      "get": {
        "operationId": "getAuthSession",
        "summary": "Get current user session",
        "description": "Retrieves the current user session information, including team and user details.",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Session details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "description": "List projects with pagination and sorting support.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "after",
            "in": "query",
            "description": "Pagination cursor",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of items per page",
            "schema": { "type": "integer", "minimum": 1, "maximum": 120 }
          },
          {
            "name": "orderBy",
            "in": "query",
            "description": "Field to sort by",
            "schema": { "type": "string", "enum": ["dtCreated"] }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction",
            "schema": { "type": "string", "enum": ["asc", "desc"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedProjectList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create a project",
        "description": "Create a new project.",
        "tags": ["Projects"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProjectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/projects/{id}": {
      "get": {
        "operationId": "getProject",
        "summary": "Get a project",
        "description": "Retrieve a specific project by ID.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Project details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "operationId": "updateProject",
        "summary": "Update a project",
        "description": "Update a project's name.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateProjectRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Project updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "operationId": "deleteProject",
        "summary": "Delete a project",
        "description": "Delete a project by ID.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": { "description": "Project deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/projects/{id}/activity": {
      "get": {
        "operationId": "listProjectActivity",
        "summary": "List project activity",
        "description": "Fetches a list of activity items for a given project.",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "after", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 120 } },
          { "name": "deploymentId", "in": "query", "description": "Filter by deployment ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Activity list" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/projects/{id}/collaborators": {
      "get": {
        "operationId": "listProjectCollaborators",
        "summary": "List project collaborators",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Collaborator list" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "addProjectCollaborator",
        "summary": "Add a project collaborator",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["userId"],
                "properties": {
                  "userId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Collaborator added" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/projects/{id}/collaborators/{userId}": {
      "delete": {
        "operationId": "removeProjectCollaborator",
        "summary": "Remove a project collaborator",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "userId", "in": "path", "required": true, "description": "User ID", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Collaborator removed" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/projects/{id}/secrets": {
      "get": {
        "operationId": "listProjectSecrets",
        "summary": "List project secrets",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Secrets list" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "createProjectSecret",
        "summary": "Create a project secret",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SecretRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Secret created" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/projects/{id}/secrets/{name}": {
      "get": {
        "operationId": "getProjectSecret",
        "summary": "Get a project secret",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "name", "in": "path", "required": true, "description": "Secret name", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Secret details" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "patch": {
        "operationId": "updateProjectSecret",
        "summary": "Update a project secret",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "name", "in": "path", "required": true, "description": "Secret name", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["value"],
                "properties": { "value": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Secret updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "operationId": "deleteProjectSecret",
        "summary": "Delete a project secret",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "name", "in": "path", "required": true, "description": "Secret name", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Secret deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/projects/{id}/tags": {
      "get": {
        "operationId": "listProjectTags",
        "summary": "List project tags",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Tags list" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "addProjectTag",
        "summary": "Add a tag to project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Tag added" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "operationId": "removeProjectTag",
        "summary": "Remove a tag from project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "name", "in": "query", "required": true, "description": "Tag name", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Tag removed" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/deployments": {
      "get": {
        "operationId": "listDeployments",
        "summary": "List deployments",
        "description": "List deployments with pagination and sorting.",
        "tags": ["Deployments"],
        "parameters": [
          { "name": "after", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 120 } },
          { "name": "orderBy", "in": "query", "schema": { "type": "string" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] } }
        ],
        "responses": {
          "200": { "description": "List of deployments", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedDeploymentList" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "upsertDeployment",
        "summary": "Create or update a deployment",
        "description": "Upsert a deployment with the given configuration.",
        "tags": ["Deployments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeploymentRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Deployment created or updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Deployment" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/deployments/{id}": {
      "get": {
        "operationId": "getDeployment",
        "summary": "Get a deployment",
        "tags": ["Deployments"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Deployment ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Deployment details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Deployment" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "operationId": "deleteDeployment",
        "summary": "Delete a deployment",
        "tags": ["Deployments"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Deployment ID", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Deployment deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/deployments/{id}/history": {
      "get": {
        "operationId": "listDeploymentHistory",
        "summary": "List deployment history",
        "tags": ["Deployments"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Deployment ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "after", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Deployment history" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/deployments/{id}/logs": {
      "get": {
        "operationId": "listDeploymentLogs",
        "summary": "List deployment logs",
        "tags": ["Deployments"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Deployment ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "after", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "instanceId", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Deployment logs" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/deployments/{id}/metrics": {
      "get": {
        "operationId": "listDeploymentMetrics",
        "summary": "List deployment metrics",
        "tags": ["Deployments"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Deployment ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "metric", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "timeframe", "in": "query", "schema": { "type": "string", "enum": ["hour", "12_hours", "day", "1_week", "2_weeks"] } }
        ],
        "responses": {
          "200": { "description": "Metric data points" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/deployments/{id}/runs": {
      "get": {
        "operationId": "listDeploymentRuns",
        "summary": "List deployment runs",
        "tags": ["Deployments"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Deployment ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Deployment runs" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/projects/{id}/deployments": {
      "get": {
        "operationId": "listProjectDeployments",
        "summary": "List project deployments",
        "tags": ["Projects", "Deployments"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Project ID", "schema": { "type": "string", "format": "uuid" } },
          { "name": "after", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 120 } },
          { "name": "name", "in": "query", "description": "Filter by deployment name", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Project deployments" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/projects/{id}/models": {
      "get": {
        "operationId": "listProjectModels",
        "summary": "List project models",
        "tags": ["Projects"],
        "parameters": [
