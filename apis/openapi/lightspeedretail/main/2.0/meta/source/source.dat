{
  "openapi": "3.0.3",
  "info": {
    "title": "Lightspeed Retail X-Series API",
    "version": "2.0",
    "description": "Lightspeed Retail (X-Series) API for managing retail operations including products, customers, sales, inventory, consignments, and more.",
    "x-jentic-source-url": "https://x-series-api.lightspeedhq.com/"
  },
  "servers": [
    {
      "url": "https://api.lightspeedhq.com/api/2.0",
      "description": "Lightspeed Retail X-Series API v2.0"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {"name": "Brands", "description": "Manage product brands"},
    {"name": "Products", "description": "Manage products and inventory"},
    {"name": "Customers", "description": "Manage customer records"},
    {"name": "Sales", "description": "Manage sales transactions"},
    {"name": "Consignments", "description": "Manage stock consignments"},
    {"name": "ConsignmentProducts", "description": "Manage products within consignments"},
    {"name": "Registers", "description": "Manage POS registers"},
    {"name": "Outlets", "description": "Manage store outlets"},
    {"name": "Suppliers", "description": "Manage suppliers"},
    {"name": "Tags", "description": "Manage product tags"},
    {"name": "Taxes", "description": "Manage tax configurations"},
    {"name": "PriceBooks", "description": "Manage price books"},
    {"name": "Users", "description": "Manage users"},
    {"name": "Webhooks", "description": "Manage webhooks"},
    {"name": "Inventory", "description": "Manage inventory records and levels"},
    {"name": "Search", "description": "Search resources"},
    {"name": "Audit", "description": "Audit and security events"},
    {"name": "Channels", "description": "Channel request logs"}
  ],
