        ],
        "responses": {
          "200": { "description": "Test details", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/inbox-placement/automated/{testId}/pause": {
      "post": {
        "operationId": "pauseAutomatedTest",
        "summary": "Pause an automated inbox placement test",
        "tags": ["InboxPlacement"],
        "parameters": [
          { "name": "testId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Test paused", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
