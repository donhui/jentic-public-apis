      "delete": {
        "operationId": "deleteInboxPlacementTest",
        "summary": "Delete an inbox placement test",
        "tags": ["InboxPlacement"],
        "parameters": [
          { "name": "testId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Test deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/inbox-placement/{testId}/rename": {
      "put": {
        "operationId": "renameInboxPlacementTest",
        "summary": "Rename an inbox placement test",
        "tags": ["InboxPlacement"],
        "parameters": [
          { "name": "testId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
