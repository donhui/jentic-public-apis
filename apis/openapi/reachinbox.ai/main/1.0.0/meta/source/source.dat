                "required": ["name"],
                "properties": { "name": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Test duplicated", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key obtained from ReachInbox Dashboard > Settings > Integrations > API. Rate limit: 5 requests/second."
      }
    },
    "schemas": {
      "MessageResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer" },
          "message": { "type": "string" }
        }
      },
      "CampaignResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "AddSequenceRequest": {
        "type": "object",
        "required": ["campaignId", "sequences"],
        "properties": {
          "campaignId": { "type": "integer" },
          "sequences": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "steps": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "variants": { "type": "array", "items": { "type": "object" } },
                      "type": { "type": "string" },
                      "delay": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "SetScheduleRequest": {
        "type": "object",
        "required": ["campaignId"],
        "properties": {
          "campaignId": { "type": "integer" },
          "startDate": { "type": "string", "format": "date-time" },
          "endDate": { "type": "string", "format": "date-time" },
          "schedules": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "timing": { "type": "object" },
                "days": { "type": "array", "items": { "type": "string" } },
                "timezone": { "type": "string" }
              }
            }
          }
        }
      },
      "UpdateCampaignDetailsRequest": {
        "type": "object",
        "required": ["campaignId"],
        "properties": {
          "campaignId": { "type": "integer" },
          "dailyLimit": { "type": "integer", "default": 200 },
          "tracking": { "type": "boolean" },
          "linkTracking": { "type": "boolean" },
          "stopOnReply": { "type": "boolean", "default": true },
          "stopOnDomainReply": { "type": "boolean" },
          "deliveryOptimizations": { "type": "integer", "enum": [0, 1, 2] },
          "blockquote": { "type": "boolean" },
          "cc": { "type": "array", "items": { "type": "string" } },
          "bcc": { "type": "array", "items": { "type": "string" } },
          "unsubscribeHeader": { "type": "boolean" },
          "globalUnsubscribe": { "type": "boolean" },
          "maxNewLeads": { "type": "integer" },
          "prioritizeNewLeads": { "type": "boolean" },
          "automaticReschedule": { "type": "integer", "nullable": true },
          "providerMatchingEnabled": { "type": "integer", "enum": [0, 1, 2] },
          "targetLeadEsp": { "type": "string" },
          "bounceProtection": { "type": "boolean" },
          "notificationEmail": { "type": "string" },
          "minimumExtraDelay": { "type": "integer" },
          "maximumExtraDelay": { "type": "integer" },
          "aiTimeGapsEnabled": { "type": "boolean", "default": true },
          "prioritizeSubsequenceLeads": { "type": "boolean" },
          "autoOptimizeAzMetric": { "type": "string", "nullable": true, "enum": ["REPLY_RATE", "OPEN_RATE", "CLICK_RATE", null] }
        }
      },
      "LeadsResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "leadDetails": {
                "type": "object",
                "properties": {
                  "leadsContactedCount": { "type": "integer" },
                  "totalLeadsCount": { "type": "integer" }
                }
              },
              "leads": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Lead" }
              }
            }
          }
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "campaignId": { "type": "integer" },
          "email": { "type": "string" },
          "attributes": { "type": "object", "additionalProperties": { "type": "string" } },
          "stepNumber": { "type": "integer" },
          "status": { "type": "string", "enum": ["IN_PROGRESS", "COMPLETED"] },
          "emailUsedToSend": { "type": "string" },
          "emailOpened": { "type": "boolean" },
          "replyReceived": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "LeadDetailResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "integer" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "campaignId": { "type": "integer" },
              "email": { "type": "string" },
              "attributes": { "type": "object", "additionalProperties": { "type": "string" } },
              "stepNumber": { "type": "integer" },
              "isPaused": { "type": "boolean" },
              "status": { "type": "string" },
              "leadStatus": { "type": "string" },
              "replyReceived": { "type": "boolean" },
              "emailOpened": { "type": "boolean" },
              "createdAt": { "type": "string", "format": "date-time" },
              "updatedAt": { "type": "string", "format": "date-time" },
              "allActivities": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "stepNumber": { "type": "integer" },
                    "type": { "type": "string" },
                    "occurredAt": { "type": "string", "format": "date-time" },
                    "fromEmail": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "UpdateLeadRequest": {
        "type": "object",
        "required": ["campaignId", "leadId"],
        "properties": {
          "campaignId": { "type": "integer" },
          "leadId": { "type": "integer" },
          "email": { "type": "string" },
          "attributes": { "type": "object", "additionalProperties": { "type": "string" } },
          "leadStatus": { "type": "string" }
        }
      },
      "DeleteLeadsRequest": {
        "type": "object",
        "required": ["campaignId"],
        "properties": {
          "campaignId": { "type": "integer" },
          "leadIds": { "type": "array", "items": { "type": "integer" } },
          "contains": { "type": "string" },
          "status": { "type": "string" },
          "exclude": { "type": "array", "items": { "type": "integer" } },
          "leadStatus": { "type": "string" }
        }
      },
      "AddLeadsRequest": {
        "type": "object",
        "required": ["campaignId", "leads"],
        "properties": {
          "campaignId": { "type": "string" },
          "leads": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": { "type": "string" },
                "firstName": { "type": "string" },
                "lastName": { "type": "string" }
              },
              "required": ["email"]
            }
          },
          "newCoreVariables": { "type": "array", "items": { "type": "string" } },
          "duplicates": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ChangeLeadStateRequest": {
        "type": "object",
        "required": ["campaignId", "updatedStatus"],
        "properties": {
          "campaignId": { "type": "string" },
          "updatedStatus": { "type": "string", "enum": ["PAUSED", "IN_PROCESS"] },
          "leadStatus": { "type": "string" },
          "status": { "type": "string" },
          "contains": { "type": "string" },
          "leadsIds": { "type": "array", "items": { "type": "integer" } },
          "excludeLeadsIds": { "type": "array", "items": { "type": "integer" } }
        }
      },
      "AnalyticsRequest": {
        "type": "object",
        "properties": {
          "campaignId": { "type": "integer" },
          "campaignAnalyticsRequired": { "type": "boolean" },
          "includeSubsequenceIds": { "type": "array", "items": { "type": "integer" } },
          "excludeSubsequenceIds": { "type": "array", "items": { "type": "integer" } },
          "filter": { "type": "string" }
        }
      },
      "AnalyticsResponse": {
        "type": "object",
        "properties": {
          "leadsContacted": { "type": "integer" },
          "opened": { "type": "integer" },
          "clicked": { "type": "integer" },
          "replied": { "type": "integer" },
          "bounced": { "type": "integer" },
          "openRate": { "type": "string" },
          "clickRate": { "type": "string" },
          "replyRate": { "type": "string" },
          "bounceRate": { "type": "string" },
          "positiveReplies": { "type": "integer" },
          "negativeReplies": { "type": "integer" },
          "campaignStatus": { "type": "string" }
        }
      },
      "OneboxListRequest": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer" },
          "offset": { "type": "integer" },
          "status": { "type": "string" },
          "inbox": { "type": "string" },
          "campaigns": { "type": "array", "items": { "type": "integer" } },
          "emailIds": { "type": "array", "items": { "type": "integer" } },
          "excludeCampaigns": { "type": "array", "items": { "type": "integer" } },
          "excludeEmails": { "type": "array", "items": { "type": "integer" } },
          "q": { "type": "string" }
        }
      },
      "BlocklistAddRequest": {
        "type": "object",
        "properties": {
          "emails": { "type": "array", "items": { "type": "string" } },
          "domains": { "type": "array", "items": { "type": "string" } },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "repliesKeywords": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ImapAccountRequest": {
        "type": "object",
        "required": ["type", "email"],
        "properties": {
          "type": { "type": "string", "enum": ["imapSingle"] },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "smtpUsername": { "type": "string" },
          "smtpPassword": { "type": "string" },
          "smtpHost": { "type": "string" },
          "smtpPort": { "type": "integer" },
          "imapUsername": { "type": "string" },
          "imapPassword": { "type": "string" },
          "imapHost": { "type": "string" },
          "imapPort": { "type": "integer" }
        }
      }
    }
  }
}