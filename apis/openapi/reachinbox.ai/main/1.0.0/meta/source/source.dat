          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "ids": { "type": "array", "items": { "type": "integer" } } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Entries deleted", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "integer" }, "message": { "type": "string" }, "data": { "type": "object", "properties": { "deletedCount": { "type": "integer" } } } } } } } }
        }
      }
    },
