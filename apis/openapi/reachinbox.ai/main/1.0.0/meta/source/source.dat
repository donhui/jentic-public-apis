      "post": {
        "operationId": "resumeAutomatedTest",
        "summary": "Resume an automated inbox placement test",
        "tags": ["InboxPlacement"],
        "parameters": [
          { "name": "testId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Test resumed", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
