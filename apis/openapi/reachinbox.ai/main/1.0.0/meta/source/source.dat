{
  "openapi": "3.0.3",
  "info": {
    "title": "Reachinbox API",
    "description": "Reachinbox.ai is a cold outreach automation platform. This API provides endpoints for managing campaigns, leads, accounts, analytics, onebox email, blocklists, lead lists, and inbox placement tests.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.reachinbox.ai/"
  },
  "servers": [
    {
      "url": "https://api.reachinbox.ai",
      "description": "Reachinbox API Production Server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    { "name": "Campaigns", "description": "Campaign management" },
    { "name": "Leads", "description": "Lead operations within campaigns" },
    { "name": "LeadLists", "description": "Global lead list management" },
    { "name": "Accounts", "description": "Email account configuration" },
    { "name": "Analytics", "description": "Campaign and warmup analytics" },
    { "name": "Onebox", "description": "Unified inbox email management" },
    { "name": "Blocklist", "description": "Blocklist management" },
    { "name": "InboxPlacement", "description": "Inbox placement testing" }
  ],
  "paths": {
    "/api/v1/campaigns/create": {
      "post": {
        "operationId": "createCampaign",
        "summary": "Create a new campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "description": "Campaign name" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campaign created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CampaignResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/campaigns/add-sequence": {
      "post": {
        "operationId": "addSequenceToCampaign",
        "summary": "Add sequences to a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddSequenceRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Sequences added successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/set-schedule": {
      "put": {
        "operationId": "setCampaignSchedule",
        "summary": "Set campaign schedule",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SetScheduleRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Schedule set", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/update-details": {
      "post": {
        "operationId": "updateCampaignOptions",
        "summary": "Update campaign options and settings",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateCampaignDetailsRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Campaign updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/set-accounts": {
      "put": {
        "operationId": "setCampaignAccounts",
        "summary": "Set sending accounts for a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId", "accountsToUse"],
                "properties": {
                  "campaignId": { "type": "integer" },
                  "accountsToUse": { "type": "array", "items": { "type": "string" }, "description": "Email addresses for sending" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Accounts set", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/campaigns/add-email": {
      "post": {
        "operationId": "addEmailsToCampaign",
        "summary": "Add recipient emails to a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId", "emails"],
                "properties": {
                  "campaignId": { "type": "integer" },
                  "emails": { "type": "array", "items": { "type": "string", "format": "email" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Emails added", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/remove-email": {
      "post": {
        "operationId": "removeEmailFromCampaign",
        "summary": "Remove an email from a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId", "email"],
                "properties": {
                  "campaignId": { "type": "integer" },
                  "email": { "type": "string", "format": "email" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Email removed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/start": {
      "post": {
        "operationId": "startCampaign",
        "summary": "Start a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId"],
                "properties": {
                  "campaignId": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Campaign started", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "integer" }, "data": { "type": "boolean" } } } } } }
        }
      }
    },
    "/api/v1/campaigns/pause": {
      "post": {
        "operationId": "pauseCampaign",
        "summary": "Pause a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId"],
                "properties": {
                  "campaignId": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Campaign paused", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/set-name": {
      "put": {
        "operationId": "updateCampaignName",
        "summary": "Update campaign name",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId", "name"],
                "properties": {
                  "campaignId": { "type": "string" },
                  "name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Name updated", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/campaigns/all": {
      "get": {
        "operationId": "listCampaigns",
        "summary": "List all campaigns",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "contains", "in": "query", "schema": { "type": "string" } },
          { "name": "sort", "in": "query", "schema": { "type": "string" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "filter", "in": "query", "schema": { "type": "string", "enum": ["All", "Active", "Paused", "Draft", "Completed", "Offschedule"] } },
          { "name": "filterTagId", "in": "query", "schema": { "type": "string" } },
          { "name": "isArchived", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": { "description": "List of campaigns", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "integer" }, "data": { "type": "array", "items": { "$ref": "#/components/schemas/CampaignResponse" } } } } } } }
        }
      }
    },
    "/api/v1/campaigns/status": {
      "get": {
        "operationId": "getCampaignStatus",
        "summary": "Get campaign status",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignId", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Campaign status", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "integer" }, "data": { "type": "object", "properties": { "state": { "type": "string" }, "active": { "type": "boolean" }, "started": { "type": "boolean" } } } } } } } }
        }
      }
    },
    "/api/v1/campaigns/name": {
      "get": {
        "operationId": "getCampaignName",
        "summary": "Get campaign name",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignId", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Campaign name", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/campaigns/accounts": {
      "get": {
        "operationId": "getCampaignAccounts",
        "summary": "Get accounts linked to a campaign",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignId", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Campaign accounts", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/campaigns/duplicate": {
      "post": {
        "operationId": "duplicateCampaign",
        "summary": "Duplicate a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId", "name"],
                "properties": {
                  "campaignId": { "type": "integer" },
                  "name": { "type": "string", "description": "New campaign name" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Campaign duplicated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CampaignResponse" } } } }
        }
      }
    },
    "/api/v1/leads": {
      "get": {
        "operationId": "getLeads",
        "summary": "Get all leads for a campaign",
        "tags": ["Leads"],
        "parameters": [
          { "name": "campaignId", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "lastLead", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Leads fetched", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LeadsResponse" } } } }
        }
      },
      "post": {
        "operationId": "updateLead",
        "summary": "Update a lead or its status",
        "tags": ["Leads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateLeadRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Lead updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/leads/details": {
      "get": {
        "operationId": "getLeadDetails",
        "summary": "Get lead details by email or ID",
        "tags": ["Leads"],
        "parameters": [
          { "name": "campaignId", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "email", "in": "query", "schema": { "type": "string" } },
          { "name": "id", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Lead details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LeadDetailResponse" } } } }
        }
      }
    },
    "/api/v1/leads/delete": {
      "post": {
        "operationId": "deleteLeads",
        "summary": "Delete leads from a campaign",
        "tags": ["Leads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeleteLeadsRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Deletion started", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/leads/add": {
      "post": {
        "operationId": "addLeads",
        "summary": "Add leads to a campaign",
        "tags": ["Leads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddLeadsRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Leads added", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/leads/change-state": {
      "post": {
        "operationId": "changeLeadState",
        "summary": "Pause or resume leads",
        "tags": ["Leads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChangeLeadStateRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "State changed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/lead-list/create": {
      "post": {
        "operationId": "createLeadList",
        "summary": "Create a lead list",
        "tags": ["LeadLists"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": { "name": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Lead list created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/lead-list/all": {
      "get": {
        "operationId": "getAllLeadLists",
        "summary": "Get all lead lists",
        "tags": ["LeadLists"],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "contains", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Lead lists", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/lead-list/details": {
      "get": {
        "operationId": "getLeadListDetails",
        "summary": "Get lead list details",
        "tags": ["LeadLists"],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Lead list details", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/lead-list/update": {
      "put": {
        "operationId": "updateLeadList",
        "summary": "Update a lead list name",
        "tags": ["LeadLists"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["leadsListId", "name"],
                "properties": { "leadsListId": { "type": "integer" }, "name": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Lead list updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/lead-list/delete": {
      "delete": {
        "operationId": "deleteLeadList",
        "summary": "Delete a lead list",
        "tags": ["LeadLists"],
        "parameters": [
          { "name": "leadsListId", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Lead list deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/lead-list/add-leads": {
      "post": {
        "operationId": "addLeadsToList",
        "summary": "Add leads to a list",
        "tags": ["LeadLists"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["leadsListId", "leads"],
                "properties": {
                  "leadsListId": { "type": "integer" },
                  "leads": { "type": "array", "items": { "type": "object", "properties": { "email": { "type": "string" }, "firstName": { "type": "string" }, "lastName": { "type": "string" } } } },
                  "newCoreVariables": { "type": "array", "items": { "type": "string" } },
                  "duplicates": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Leads added to list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/lead-list/get-leads": {
      "get": {
        "operationId": "getLeadsFromList",
        "summary": "Get leads from a list",
        "tags": ["LeadLists"],
        "parameters": [
          { "name": "leadsListId", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "contains", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Leads from list", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/lead-list/update-lead": {
      "put": {
        "operationId": "updateLeadInList",
        "summary": "Update a lead in a list",
        "tags": ["LeadLists"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["leadsListId", "leadId"],
                "properties": {
                  "leadsListId": { "type": "integer" },
                  "leadId": { "type": "integer" },
                  "attributes": { "type": "object", "additionalProperties": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Lead updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/lead-list/delete-leads": {
      "delete": {
        "operationId": "deleteLeadsFromList",
        "summary": "Delete leads from a list",
        "tags": ["LeadLists"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["leadsListId", "leadIds"],
                "properties": {
                  "leadsListId": { "type": "integer" },
                  "leadIds": { "oneOf": [{ "type": "array", "items": { "type": "integer" } }, { "type": "string", "enum": ["ALL"] }] },
                  "excludeIds": { "type": "array", "items": { "type": "integer" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Leads deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/lead-list/copy-leads-to-campaign": {
      "post": {
        "operationId": "copyLeadsToCampaign",
        "summary": "Copy leads from a list to a campaign",
        "tags": ["LeadLists"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId", "leadsListId"],
                "properties": {
                  "campaignId": { "type": "integer" },
                  "leadsListId": { "type": "integer" },
                  "leadsIds": { "type": "array", "items": { "type": "integer" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Copy initiated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
    "/api/v1/account/all": {
      "get": {
        "operationId": "getAllAccounts",
        "summary": "Get all email accounts",
        "tags": ["Accounts"],
        "parameters": [
          { "name": "contains", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "sortField", "in": "query", "schema": { "type": "string" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["ASC", "DESC"] } }
        ],
        "responses": {
          "200": { "description": "List of accounts", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/account/dns": {
      "post": {
        "operationId": "checkDns",
        "summary": "Check DNS records for accounts",
        "tags": ["Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accounts": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "email": { "type": "string" },
                        "type": { "type": "string" },
                        "dkimSelector": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "DNS verification results", "content": { "application/json": { "schema": { "type": "object" } } } }
        }
      }
    },
    "/api/v1/account/warmup/enable": {
      "post": {
        "operationId": "enableWarmup",
        "summary": "Enable warmup for accounts",
        "tags": ["Accounts"],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "contains", "in": "query", "schema": { "type": "string" } },
          { "name": "filterTagId", "in": "query", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ids": { "oneOf": [{ "type": "array", "items": { "type": "integer" } }, { "type": "string", "enum": ["ALL"] }] },
                  "exclude": { "type": "array", "items": { "type": "integer" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Warmup enabled", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } }
        }
      }
    },
