      "get": {
        "operationId": "listCustomerCards",
        "summary": "View customer's loyalty card progress",
        "tags": ["CustomerCards"],
        "parameters": [
          {"name": "account_id", "in": "path", "required": true, "schema": {"type": "string"}},
