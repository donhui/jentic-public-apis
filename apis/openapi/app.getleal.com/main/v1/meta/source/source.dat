{
  "openapi": "3.0.3",
  "info": {
    "title": "Leal Loyalty API",
    "version": "v1",
    "description": "Leal is a digital loyalty platform that lets retail stores create and manage mobile reward cards to increase repeat customers and engagement.",
    "x-jentic-source-url": "https://app.getleal.com/docs/api.html"
  },
  "servers": [
    {
      "url": "https://app.getleal.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "Stores", "description": "Store/account management"},
    {"name": "Cards", "description": "Loyalty card template management"},
    {"name": "CustomerCards", "description": "Customer card progress and actions"},
    {"name": "Customers", "description": "Customer management"},
    {"name": "Locations", "description": "Physical store locations"},
    {"name": "Posters", "description": "QR code signup posters"},
    {"name": "Rewards", "description": "Loyalty rewards"}
  ],
  "paths": {
    "/api/v1/accounts": {
      "get": {
        "operationId": "listStores",
        "summary": "List all stores",
        "tags": ["Stores"],
        "responses": {
          "200": {"description": "List of stores", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Store"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/accounts/{id}": {
      "get": {
        "operationId": "getStore",
        "summary": "Retrieve specific store details",
        "tags": ["Stores"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Store details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Store"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateStore",
        "summary": "Update store configuration",
        "tags": ["Stores"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/StoreUpdate"}}}},
        "responses": {
          "200": {"description": "Store updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Store"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/accounts/{account_id}/cards": {
      "get": {
        "operationId": "listCards",
        "summary": "List loyalty card templates",
        "tags": ["Cards"],
        "parameters": [{"name": "account_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "List of card templates", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Card"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createCard",
        "summary": "Create a new card template",
        "tags": ["Cards"],
        "parameters": [{"name": "account_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CardCreate"}}}},
        "responses": {
          "200": {"description": "Card created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Card"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/accounts/{account_id}/cards/{id}": {
      "get": {
        "operationId": "getCard",
        "summary": "Retrieve a specific card template",
        "tags": ["Cards"],
        "parameters": [
          {"name": "account_id", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Card details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Card"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateCard",
        "summary": "Update a card template",
        "tags": ["Cards"],
        "parameters": [
          {"name": "account_id", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
