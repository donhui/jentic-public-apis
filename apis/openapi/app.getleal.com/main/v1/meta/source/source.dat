  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Store": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"}
        }
      },
      "StoreUpdate": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"}
        }
      },
      "Card": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "stamps_required": {"type": "integer"},
          "active": {"type": "boolean"}
        }
      },
      "CardCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "stamps_required": {"type": "integer"},
          "active": {"type": "boolean"}
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "email": {"type": "string"},
          "phone": {"type": "string"}
        }
      },
      "CustomerCreate": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "email": {"type": "string"},
          "phone": {"type": "string"}
        }
      },
      "CustomerCard": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "card_id": {"type": "string"},
          "customer_id": {"type": "string"},
          "stamps_collected": {"type": "integer"},
          "redeemed": {"type": "boolean"}
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "address": {"type": "string"}
        }
      },
      "LocationCreate": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "address": {"type": "string"}
        }
      },
      "Poster": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "qr_code_url": {"type": "string"}
        }
      },
      "PosterCreate": {
        "type": "object",
        "properties": {
          "name": {"type": "string"}
        }
      },
      "Reward": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "value": {"type": "string"}
        }
      },
      "RewardCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "value": {"type": "string"}
        }
      }
    }
  }
}