{
  "openapi": "3.0.3",
  "info": {
    "title": "Forismatic API",
    "version": "1.0",
    "description": "A simple API for retrieving random inspirational quotes in multiple languages and formats.",
    "x-jentic-source-url": "https://forismatic.com/en/api"
  },
  "servers": [
    {
      "url": "https://api.forismatic.com/api/1.0"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getQuote",
        "summary": "Get a random inspirational quote",
        "description": "Selects a random quote using an optional numeric key. If no key is specified, the server generates a random one.",
        "tags": ["Quotes"],
        "parameters": [
          {
            "name": "method",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["getQuote"]
            },
            "description": "API method to call"
          },
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["json", "xml", "jsonp", "html", "text"]
            },
            "description": "Response format"
          },
          {
            "name": "key",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "maxLength": 6
            },
            "description": "Numeric key influencing quote selection"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["en", "ru"]
            },
            "description": "Language preference"
          },
          {
            "name": "jsonp",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "JSONP callback function name (required when format is jsonp)"
          }
        ],
        "responses": {
          "200": {
            "description": "A random quote",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "getQuotePost",
        "summary": "Get a random inspirational quote via POST",
        "description": "Selects a random quote using an optional numeric key via POST request.",
        "tags": ["Quotes"],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["method", "format"],
                "properties": {
                  "method": {
                    "type": "string",
                    "enum": ["getQuote"]
                  },
                  "format": {
                    "type": "string",
                    "enum": ["json", "xml", "jsonp", "html", "text"]
                  },
                  "key": {
                    "type": "string",
                    "maxLength": 6
                  },
                  "lang": {
                    "type": "string",
                    "enum": ["en", "ru"]
                  },
                  "jsonp": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A random quote",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Quote": {
        "type": "object",
        "properties": {
          "quoteText": {
            "type": "string",
            "description": "The quote text"
          },
          "quoteAuthor": {
            "type": "string",
            "description": "Author of the quote (may be empty)"
          },
          "senderName": {
            "type": "string",
            "description": "Name of the contributor"
          },
          "senderLink": {
            "type": "string",
            "description": "Email or website of the contributor"
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}
