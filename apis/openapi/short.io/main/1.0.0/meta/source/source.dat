                                                ]
                                              },
                                              {
                                                "type": "null"
                                              }
                                            ]
                                          },
                                          "email": {
                                            "type": "string",
                                            "description": "Creator email",
                                            "examples": [
                                              "a@example.com"
                                            ]
                                          },
                                          "photoURL": {
                                            "anyOf": [
                                              {
                                                "type": "string",
                                                "description": "User photo URL",
                                                "examples": [
