                  "type": "object",
                  "required": [
                    "id",
                    "DomainId",
                    "UserId",
                    "LinkIdString"
                  ],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "DomainId": {
                      "type": "integer"
                    },
                    "UserId": {
                      "type": "integer"
                    },
                    "LinkIdString": {
                      "type": "string",
                      "pattern": "lnk_[0-9a-zA-Z]+_[0-9a-zA-Z]+",
                      "description": "Link ID",
                      "example": "lnk_abc123_abcdef"
                    }
                  }
                }
              }
