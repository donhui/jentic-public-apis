                        "type": "string",
                        "format": "iso-date-time",
                        "nullable": true
                      },
                      {
                        "type": "integer",
                        "nullable": true
                      }
                    ],
                    "description": "Time to live in milliseconds or ISO string",
                    "example": "2026-04-01T12:00:00.454Z"
