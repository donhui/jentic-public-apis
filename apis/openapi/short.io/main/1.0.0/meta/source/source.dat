                          ]
                        },
                        "OwnerId": {
                          "type": "integer",
                          "description": "Owner ID",
                          "examples": [
                            1
                          ]
                        },
                        "hasPassword": {
                          "type": "boolean",
                          "description": "Link has password",
                          "default": false
