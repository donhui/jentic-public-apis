                              ]
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "displayPath": {
                          "anyOf": [
                            {
                              "type": "string",
                              "description": "Original path preserving the case as provided during creation. Set only for case-insensitive domains when the path contains uppercase characters, otherwise null.",
                              "examples": [
