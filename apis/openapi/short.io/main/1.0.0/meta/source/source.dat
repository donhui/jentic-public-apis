    "/links/expand": {
      "get": {
        "summary": "Get link info by path",
        "tags": [
          "Link queries"
        ],
        "description": "Get link info by path. Rate limit: 20/s",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "domain",
            "required": true,
            "description": "Domain hostname"
          },
          {
            "schema": {
