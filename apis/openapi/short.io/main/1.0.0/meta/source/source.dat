                        "source": {
                          "enum": [
                            "website",
                            "api",
                            "public",
                            "spreadsheets",
                            "slack",
                            "telegram",
                            ""
                          ],
                          "description": "Link source",
                          "examples": [
                            "api"
                          ]
                        },
                        "User": {
                          "anyOf": [
                            {
                              "type": "object",
                              "required": [
                                "id",
                                "name",
                                "email",
                                "photoURL"
                              ],
                              "properties": {
                                "id": {
                                  "type": "integer",
                                  "description": "Creator user ID",
                                  "examples": [
