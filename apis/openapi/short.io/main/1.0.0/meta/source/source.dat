                                                ]
                                              },
                                              {
                                                "type": "null"
                                              }
                                            ]
                                          }
                                        }
                                      },
                                      {
                                        "type": "null"
                                      }
                                    ]
                                  }
                                }
                              }
                            ]
                          },
                          {
                            "type": "object",
                            "properties": {
                              "success": {
                                "type": "boolean",
                                "default": true
                              },
                              "duplicate": {
                                "type": "boolean",
                                "default": false
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          },
