                        "format": "hostname"
                      },
                      "unicodeHostname": {
                        "type": "string",
                        "format": "fqdn"
                      },
                      "state": {
                        "enum": [
                          "extra_records",
                          "not_registered",
                          "configured",
                          "not_configured",
                          "registration_pending",
                          "not_verified"
