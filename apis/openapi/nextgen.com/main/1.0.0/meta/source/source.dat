    "/fhir/r4/Procedure/{id}": {
      "get": {
        "tags": [
          "Procedure"
        ],
        "description": "Fetches a single Procedure by id. \n \n FHIR Resource: Procedure \n *  Procedures",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The id of the resource",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Procedure"
