          "401": {
            "description": "Resource not authorized to be viewed by this user",
            "content": {}
          }
        }
      }
    },
    "/fhir/r4/Procedure": {
      "get": {
        "tags": [
          "Procedure"
        ],
        "description": "Fetches a bundled resource containing the valid procedures for the patient mentioned in the request. The procedures pertain to the encounters available for the patient. \n \n FHIR Resource: Procedure \n *  Procedures",
        "parameters": [
          {
            "name": "patient",
            "in": "query",
            "description": "The id of the patient",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "A date parameter searches on a date/time or period. The only supported prefixes are - gt, lt, ge, le, eq. Example-gt2015-01-15. See https://www.hl7.org/fhir/R4/search.html#date.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcedureBundled"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {}
          },
          "401": {
            "description": "Resource not authorized to be viewed by this user",
            "content": {}
          }
        }
      }
    },
    "/fhir/r4/Condition/{id}": {
      "get": {
        "tags": [
          "Condition"
        ],
        "description": "Fetches a bundled resource containing the condition/problem associated with the provided resource id.  \n \n FHIR Resource: Condition \n *  Health Concerns \n * Problems \n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The id of the resource with prefix values PL | HC | ED with hyphen.Example PL-123",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Condition"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {}
          },
          "401": {
            "description": "Resource not authorized to be viewed by this user",
            "content": {}
          }
        }
      }
    },
    "/fhir/r4/Condition": {
      "get": {
        "tags": [
          "Condition"
        ],
        "description": "Fetches a bundled resource containing the conditions/problems for the patient mentioned in the request. All conditions are mapped to SNOMED codes.  \n \n FHIR Resource: Condition \n *  Health Concerns \n * Problems \n",
        "parameters": [
          {
            "name": "patient",
            "in": "query",
            "description": "The id of the patient",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "The category of the condition. See http://hl7.org/fhir/R4/valueset-condition-category.html",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "description": "A date parameter searches on a date/time or period. The only supported prefixes are - gt, lt, ge, le, eq. Example-gt2015-01-15. See https://www.hl7.org/fhir/R4/search.html#date.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConditionBundled"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {}
          },
          "401": {
            "description": "Resource not authorized to be viewed by this user",
            "content": {}
          }
        }
      }
    },
