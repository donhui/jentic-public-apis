      "get": {
        "tags": [
          "Encounter"
        ],
        "description": "Fetches a bundled resource containing the valid encounters for the patient mentioned in the request.  \n \n FHIR Resource: Encounter \n *  Encounters \n \n FHIR Resource: Location \n * Location \n",
        "parameters": [
          {
            "name": "patient",
            "in": "query",
            "description": "The id of the patient",
            "required": true,
            "schema": {
              "type": "string"
