          },
          "object": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "pickup_address": {
            "type": "string"
          },
          "dropoff_address": {
            "type": "string"
          },
          "pickup_store_id": {
            "type": "string"
          },
          "dropoff_store_id": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            }
          },
          "pickup_at": {
            "type": "string",
            "format": "date-time"
          },
          "dropoff_at": {
            "type": "string",
            "format": "date-time"
          },
          "order_value": {
            "type": "integer"
          },
          "industry": {
            "type": "string",
            "enum": [
              "alcohol",
              "auto_parts",
              "cannabis_cbd",
              "catering",
              "ecommerce_parcel",
              "flowers",
              "food",
              "grocery",
              "laundry_dry_cleaning",
              "pharmacy",
              "vape_tobacco",
              "retail"
            ]
          },
          "signature": {
            "type": "boolean"
          },
          "contactless": {
            "type": "boolean"
          },
          "dropoff_pincode": {
            "type": "boolean"
          }
        }
      },
      "CreateRouteRequest": {
        "type": "object",
        "properties": {
          "order_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Identifiers of existing orders to include in the multi-order delivery route"
          },
          "pickup_address": {
            "type": "string"
          },
          "dropoff_address": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            }
          }
        }
      },
      "DeliveryIncident": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique incident identifier"
          },
          "delivery_id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}