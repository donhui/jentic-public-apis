{
  "openapi": "3.0.3",
  "info": {
    "title": "Burq Delivery API",
    "version": "1.3.1",
    "description": "Burq provides a delivery API and dashboard to help businesses offer on-demand and same-day delivery. The API enables generating quotes from multiple delivery providers, creating and managing deliveries, managing stores, handling orders, and setting up multi-order delivery routes.",
    "x-jentic-source-url": "https://burq.readme.io/reference"
  },
  "servers": [
    {
      "url": "https://api.burqup.com/v1",
      "description": "Burq Production API"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Quotes",
      "description": "Generate delivery quotes from multiple providers"
    },
    {
      "name": "Deliveries",
      "description": "Create, manage, and track deliveries"
    },
    {
      "name": "Stores",
      "description": "Manage pickup and dropoff store locations"
    },
    {
      "name": "Orders",
      "description": "Create and manage delivery orders (Beta)"
    },
    {
      "name": "Routes",
      "description": "Multi-order delivery routes"
    },
    {
      "name": "Delivery Incidents",
      "description": "Report and manage delivery incidents"
    },
    {
      "name": "Connected Accounts",
      "description": "Manage connected account invitations"
    }
  ],
  "paths": {
    "/quote": {
      "post": {
        "operationId": "createQuotes",
        "summary": "Create Quotes",
        "description": "Generate delivery quotes from multiple providers based on pickup and dropoff addresses, items, and delivery preferences.",
        "tags": ["Quotes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQuoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with array of quotes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Quote"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/delivery_information": {
      "post": {
        "operationId": "createDelivery",
        "summary": "Create Delivery",
        "description": "Create a new delivery request. Can optionally initiate the delivery immediately by setting the initiate flag to true.",
        "tags": ["Deliveries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDeliveryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/initiate_delivery": {
      "post": {
        "operationId": "initiateDelivery",
        "summary": "Initiate Delivery",
        "description": "Initiate a previously created delivery using the delivery information ID.",
        "tags": ["Deliveries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["deliveryInfoId"],
                "properties": {
                  "deliveryInfoId": {
                    "type": "string",
                    "description": "The delivery information ID to initiate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/delivery/{id}/cancel": {
      "post": {
        "operationId": "cancelDelivery",
        "summary": "Cancel Delivery",
        "description": "Cancel a delivery. An error will be returned if the delivery cannot be canceled (usually due to driver already enroute).",
        "tags": ["Deliveries"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the delivery"
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery canceled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Delivery cannot be canceled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/delivery/{id}": {
      "get": {
        "operationId": "getDelivery",
        "summary": "Get Delivery",
        "description": "Retrieve the latest information about a specific delivery.",
        "tags": ["Deliveries"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the delivery"
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/deliveries": {
      "get": {
        "operationId": "listDeliveries",
        "summary": "List Deliveries",
        "description": "Retrieve a paginated list of all deliveries for the current account.",
        "tags": ["Deliveries"],
        "responses": {
          "200": {
            "description": "Paginated list of deliveries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Delivery"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/stores": {
      "post": {
        "operationId": "createStore",
        "summary": "Create Store",
        "description": "Create a new store location for use as a pickup or dropoff point in deliveries.",
        "tags": ["Stores"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStoreRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Store created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Store"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listStores",
        "summary": "List Stores",
        "description": "Retrieve all store locations under the current account.",
        "tags": ["Stores"],
        "responses": {
          "200": {
            "description": "List of stores",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Store"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/stores/{id}": {
      "get": {
        "operationId": "getStore",
        "summary": "Get Store",
        "description": "Retrieve details of a specific store by its unique identifier.",
        "tags": ["Stores"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the store"
          }
        ],
        "responses": {
          "200": {
            "description": "Store details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Store"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateStore",
        "summary": "Update Store",
        "description": "Update an existing store's details.",
        "tags": ["Stores"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the store"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStoreRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Store updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Store"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteStore",
        "summary": "Delete Store",
        "description": "Delete a store by its unique identifier.",
        "tags": ["Stores"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the store"
          }
        ],
        "responses": {
          "200": {
            "description": "Store deleted successfully"
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/orders": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create Order",
        "description": "Create a new delivery order with pickup and dropoff details, items, and delivery preferences.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listOrders",
        "summary": "List Orders",
        "description": "Retrieve a paginated list of all orders.",
        "tags": ["Orders"],
        "responses": {
          "200": {
            "description": "Paginated list of orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Delivery"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get Order",
        "description": "Returns the latest information about the requested order.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the order"
          }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateOrder",
        "summary": "Update Order",
        "description": "Update an existing order's details.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the order"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteOrder",
        "summary": "Delete Order",
        "description": "Delete an order. Only works if the order has not yet been initiated.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the order"
          }
        ],
        "responses": {
          "200": {
            "description": "Order deleted successfully"
          },
          "400": {
            "description": "Order cannot be deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/orders/{id}/cancel": {
      "post": {
        "operationId": "cancelOrder",
        "summary": "Cancel Order",
        "description": "Cancel the latest delivery within an order. Will fail if the driver is already en route.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the order"
          }
        ],
        "responses": {
          "200": {
            "description": "Order canceled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Order cannot be canceled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/orders/{id}/quotes": {
      "post": {
        "operationId": "createOrderQuotes",
        "summary": "Create Order Quotes",
        "description": "Generate delivery quotes for a specific order from multiple providers.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the order"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQuoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order quotes generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Quote"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/quotes/{id}/accept": {
      "post": {
        "operationId": "acceptOrderQuote",
        "summary": "Accept Order Quote",
        "description": "Accept a specific quote to transition it into an active delivery order.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the quote to accept"
          }
        ],
        "responses": {
          "200": {
            "description": "Quote accepted, delivery initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/routes": {
      "post": {
        "operationId": "createRoute",
        "summary": "Create Route",
        "description": "Create a multi-order delivery route combining multiple orders into a single delivery.",
        "tags": ["Routes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRouteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Route created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/routes/{id}/cancel": {
      "post": {
        "operationId": "cancelRoute",
        "summary": "Cancel Route",
        "description": "Cancel a multi-order delivery route. An error will be returned if the route cannot be cancelled.",
        "tags": ["Routes"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the route"
          }
        ],
        "responses": {
          "200": {
            "description": "Route canceled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Route cannot be canceled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/routes/quotes": {
      "post": {
        "operationId": "createRouteQuote",
        "summary": "Create Route Quote",
        "description": "Generate multi-order delivery quotes for a set of orders, allowing comparison of pricing from different delivery providers.",
        "tags": ["Routes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRouteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Route quotes generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Quote"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/delivery_incidents": {
      "post": {
        "operationId": "createDeliveryIncident",
        "summary": "Create Delivery Incident",
        "description": "Report a delivery incident.",
        "tags": ["Delivery Incidents"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "delivery_id": {
                    "type": "string",
                    "description": "The delivery ID associated with the incident"
                  },
                  "type": {
                    "type": "string",
                    "description": "Type of incident"
                  },
                  "description": {
                    "type": "string",
                    "description": "Description of the incident"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery incident created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeliveryIncident"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listDeliveryIncidents",
        "summary": "List Delivery Incidents",
        "description": "Retrieve a list of all delivery incidents.",
        "tags": ["Delivery Incidents"],
        "responses": {
          "200": {
            "description": "List of delivery incidents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DeliveryIncident"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/delivery_incidents/{id}": {
      "get": {
        "operationId": "getDeliveryIncident",
        "summary": "Get Delivery Incident",
        "description": "Retrieve a specific delivery incident by its unique identifier.",
        "tags": ["Delivery Incidents"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the delivery incident"
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery incident details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeliveryIncident"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/connected_account_invitations": {
      "post": {
        "operationId": "createConnectedAccountInvitation",
        "summary": "Create Connected Account Invitation",
        "description": "Create an invitation for a connected account.",
        "tags": ["Connected Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address for the invitation"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invitation created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Unique invitation identifier"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/connected_account_invitations/{id}": {
      "get": {
        "operationId": "getConnectedAccountInvitation",
        "summary": "Get Connected Account Invitation",
        "description": "Retrieve details for a specific connected account invitation.",
        "tags": ["Connected Accounts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the connected account invitation"
          }
        ],
        "responses": {
          "200": {
            "description": "Invitation details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Burq API key for your account"
      }
    },
    "schemas": {
      "ApiError": {
        "type": "object",
        "properties": {
          "object": {
            "type": "string",
            "enum": ["error"]
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "type": {
            "type": "string",
            "description": "Error classification",
            "enum": ["validation_error", "provider_error", "server_error"]
          },
          "code": {
            "type": "string",
            "description": "Specific error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error description"
          }
        }
      },
      "DeliveryItem": {
        "type": "object",
        "required": ["name", "quantity", "size"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Item name"
          },
          "quantity": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000,
            "description": "Item quantity"
          },
          "size": {
            "type": "string",
            "enum": ["small", "medium", "large", "xlarge"],
            "description": "Item size category"
          }
        }
      },
      "AddressDetails": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "ProviderSettings": {
        "type": "object",
        "properties": {
          "signature": {
            "type": "boolean"
          },
          "contactless": {
            "type": "boolean"
          },
          "age_verification": {
            "type": "boolean"
          },
          "proof_of_pickup": {
            "type": "boolean"
          },
          "dropoff_pincode": {
            "type": "boolean"
          },
          "tsa_certified_driver": {
            "type": "boolean"
          }
        }
      },
      "ProviderCapability": {
        "type": "object",
        "properties": {
          "signature": {
            "type": "boolean"
          },
          "contactless": {
            "type": "boolean"
          },
          "age_verification": {
            "type": "boolean"
          },
          "proof_of_pickup": {
            "type": "boolean"
          },
          "undeliverable_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dropoff_pincode": {
            "type": "boolean"
          },
          "tsa_certified_driver": {
            "type": "boolean"
          }
        }
      },
      "Provider": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Provider identifier"
          },
          "name": {
            "type": "string",
            "description": "Provider name"
          }
        }
      },
      "Quote": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique quote identifier"
          },
          "object": {
            "type": "string",
            "enum": ["quote"]
          },
          "fee": {
            "type": "integer",
            "description": "Delivery cost in specified currency"
          },
          "burq_fee": {
            "type": "integer",
            "description": "Burq surcharge"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Quote generation timestamp"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "expires": {
            "type": "string",
            "format": "date-time",
            "description": "Quote expiration time"
          },
          "provider": {
            "$ref": "#/components/schemas/Provider"
          },
          "pickup_eta": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated pickup arrival"
          },
          "dropoff_eta": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated delivery arrival"
          },
          "pickup_at": {
            "type": "string",
            "format": "date-time"
          },
          "dropoff_at": {
            "type": "string",
            "format": "date-time"
          },
          "provider_capability": {
            "$ref": "#/components/schemas/ProviderCapability"
          },
          "vehicle": {
            "type": "string",
            "description": "Vehicle type"
          },
          "pickup_store_id": {
            "type": "string"
          },
          "dropoff_store_id": {
            "type": "string"
          },
          "account_id": {
            "type": "string"
          },
          "contains_alcohol": {
            "type": "boolean"
          },
          "is_preferred": {
            "type": "boolean"
          }
        }
      },
      "CreateQuoteRequest": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "pickup_address": {
            "type": "string",
            "description": "Full pickup location address. Include all components including street, city, zipcode, and country."
          },
          "dropoff_address": {
            "type": "string",
            "description": "Full dropoff location address. Include all components including street, city, zipcode, and country."
          },
          "pickup_store_id": {
            "type": "string",
            "description": "Burq store identifier for pickup location (alternative to pickup_address)"
          },
          "dropoff_store_id": {
            "type": "string",
            "description": "Burq store identifier for dropoff location (alternative to dropoff_address)"
          },
          "pickup_unit": {
            "type": "string",
            "description": "Unit number at pickup location"
          },
          "dropoff_unit": {
            "type": "string",
            "description": "Unit number at dropoff location"
          },
          "pickup_at": {
            "type": "string",
            "format": "date-time",
            "description": "Requested pickup timestamp in ISO 8601 format"
          },
          "dropoff_at": {
            "type": "string",
            "format": "date-time",
            "description": "Requested delivery timestamp in ISO 8601 format"
          },
          "pickup_name": {
            "type": "string",
            "description": "Pickup location name"
          },
          "dropoff_name": {
            "type": "string",
            "description": "Recipient name"
          },
          "pickup_phone_number": {
            "type": "string",
            "description": "Pickup contact phone number"
          },
          "dropoff_phone_number": {
            "type": "string",
            "description": "Dropoff contact phone number"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            },
            "description": "Array of delivery items"
          },
          "order_value": {
            "type": "integer",
            "description": "Total item value in cents"
          },
          "industry": {
            "type": "string",
            "enum": [
              "alcohol",
              "auto_parts",
              "cannabis_cbd",
              "catering",
              "ecommerce_parcel",
              "flowers",
              "food",
              "grocery",
              "laundry_dry_cleaning",
              "pharmacy",
              "vape_tobacco",
              "retail"
            ],
            "description": "Industry category"
          },
          "contains_alcohol": {
            "type": "boolean",
            "description": "Whether the delivery contains alcoholic items"
          },
          "required_provider_settings": {
            "$ref": "#/components/schemas/ProviderSettings"
          },
          "preferred_provider_settings": {
            "$ref": "#/components/schemas/ProviderSettings"
          },
          "pickup_address_details": {
            "$ref": "#/components/schemas/AddressDetails"
          },
          "dropoff_address_details": {
            "$ref": "#/components/schemas/AddressDetails"
          }
        }
      },
      "CreateDeliveryRequest": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "initiate": {
            "type": "boolean",
            "description": "When set to true, delivery is initiated immediately with the cheapest option auto-selected"
          },
          "pickup_address": {
            "type": "string",
            "description": "Full pickup location address"
          },
          "dropoff_address": {
            "type": "string",
            "description": "Full dropoff location address"
          },
          "pickup_store_id": {
            "type": "string"
          },
          "dropoff_store_id": {
            "type": "string"
          },
          "pickup_name": {
            "type": "string"
          },
          "dropoff_name": {
            "type": "string"
          },
          "pickup_phone_number": {
            "type": "string"
          },
          "dropoff_phone_number": {
            "type": "string"
          },
          "pickup_unit": {
            "type": "string"
          },
          "dropoff_unit": {
            "type": "string"
          },
          "pickup_at": {
            "type": "string",
            "format": "date-time",
            "description": "Requested pickup time (ISO 8601). Mutually exclusive with dropoff_at."
          },
          "dropoff_at": {
            "type": "string",
            "format": "date-time",
            "description": "Requested delivery time (ISO 8601). Mutually exclusive with pickup_at."
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            }
          },
          "quote_id": {
            "type": "string",
            "description": "Quote ID to use for this delivery"
          },
          "external_order_ref": {
            "type": "string",
            "description": "External order reference"
          },
          "tip": {
            "type": "integer",
            "description": "Tip amount in cents"
          },
          "order_value": {
            "type": "integer",
            "description": "Total item value in cents"
          },
          "contactless_delivery": {
            "type": "boolean"
          },
          "signature": {
            "type": "boolean"
          },
          "contains_alcohol": {
            "type": "boolean"
          },
          "pickup_notes": {
            "type": "string"
          },
          "dropoff_notes": {
            "type": "string"
          },
          "required_provider_settings": {
            "$ref": "#/components/schemas/ProviderSettings"
          },
          "preferred_provider_settings": {
            "$ref": "#/components/schemas/ProviderSettings"
          },
          "connected_account_id": {
            "type": "string"
          },
          "vehicle": {
            "type": "string"
          }
        }
      },
      "Dropoff": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "eta": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "Delivery": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique delivery identifier"
          },
          "object": {
            "type": "string",
            "enum": ["delivery"]
          },
          "status": {
            "type": "string",
            "enum": [
              "request",
              "delivery_created",
              "driver_assigned",
              "driver_not_assigned",
              "pickup_enroute",
              "pickup_arrived",
              "pickup_complete",
              "dropoff_enroute",
              "dropoff_arrived",
              "delivered",
              "canceled",
              "returned",
              "failed"
            ],
            "description": "Current delivery status"
          },
          "delivery_type": {
            "type": "string",
            "enum": ["asap", "scheduled"],
            "description": "Delivery type"
          },
          "provider": {
            "$ref": "#/components/schemas/Provider"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "payment_amount": {
            "type": "integer",
            "description": "Total cost before tip in cents"
          },
          "tip": {
            "type": "integer",
            "description": "Tip amount in cents"
          },
          "fee": {
            "type": "integer",
            "description": "Delivery fee in cents"
          },
          "tracking_url": {
            "type": "string",
            "description": "URL of the customer tracking page"
          },
          "pickup_tracking_url": {
            "type": "string"
          },
          "dropoff_tracking_url": {
            "type": "string"
          },
          "pickup_eta": {
            "type": "string",
            "format": "date-time"
          },
          "dropoff_eta": {
            "type": "string",
            "format": "date-time"
          },
          "pickup_address": {
            "type": "string"
          },
          "dropoff_address": {
            "type": "string"
          },
          "pickup_name": {
            "type": "string"
          },
          "pickup_phone_number": {
            "type": "string"
          },
          "dropoffs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dropoff"
            }
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            }
          },
          "courier_name": {
            "type": "string"
          },
          "courier_img": {
            "type": "string"
          },
          "courier_phone_number_for_customer": {
            "type": "string"
          },
          "courier_location_lat": {
            "type": "number",
            "format": "double"
          },
          "courier_location_lng": {
            "type": "number",
            "format": "double"
          },
          "proof_of_delivery": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proof_of_pickup": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cancellation_reason": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "status_history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      },
      "CreateStoreRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Store name"
          },
          "address": {
            "type": "string",
            "description": "Store address"
          },
          "phone_number": {
            "type": "string",
            "description": "Store phone number"
          }
        }
