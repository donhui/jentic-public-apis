    "/v6/flows/search": {
      "post": {
        "tags": [
          "Flow"
        ],
        "description": "[V6] Search flows by filter parameters\n## JSON object description:\n\n* * *\n## getFlowsByFilterRequest:\n\n### Filter request containing CustomFields (Key-value pairs) and SignatureFlowStatus. Status values: Open=0, Approved=1, Declined=2, Stopped=3, Suspended=4\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| CustomFields | KeyValuePair\\<String,String\\>[] | Search flows be CustomFields property Key+Value |\n| SignatureFlowStatus | ***Nullable\\<SignatureFlowStatus\\>*** | Search flow by Flow status |\n| Signer | ***ParticipantKey*** | Searche by the flow signer |\n| Sender | ***ParticipantKey*** | Search by the user that create the flow (sender) |\n| FromDate | Nullable\\<DateTime\\> | Search by flow create date - from |\n| ToDate | Nullable\\<DateTime\\> | Search by flow create date - to |\n| Description | String | Search by flow description name |\n| KitId | String | Search by kit Id |\n\n* * *\n### ParticipantKey:\n\n### Allow to locate Doxi user by:UserEmail=1UserPhone=2\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Key | String | User search value |\n| Type | ***ParticipantKeyType*** | Search type:UserEmail=1,UserPhone=2 |\n\n* * *\n### ParticipantKeyType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | UserId |\n| 1 | UserEmail |\n| 2 | UserPhone |\n| 3 | UserName |\n| 4 | GroupId |\n\n* * *\n### SignatureFlowStatus:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Open |\n| 1 | Approved |\n| 2 | Declined |\n| 3 | Stopped |\n| 4 | Suspended |\n| 5 | Expired |\n",
        "parameters": [
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/GetFlowsByFilterRequest"
              },
              "example": {
                "CustomFields": [
                  {
                    "Key": "MyFieldName",
                    "Value": "some-value"
                  },
                  {
                    "Key": "MyFieldName2",
                    "Value": "some-value"
                  }
                ],
                "SignatureFlowStatus": 0
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetFlowsByFilterRequest"
              },
              "example": {
                "CustomFields": [
                  {
                    "Key": "MyFieldName",
                    "Value": "some-value"
                  },
                  {
                    "Key": "MyFieldName2",
                    "Value": "some-value"
                  }
                ],
                "SignatureFlowStatus": 0
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/GetFlowsByFilterRequest"
              },
              "example": {
                "CustomFields": [
                  {
                    "Key": "MyFieldName",
                    "Value": "some-value"
                  },
                  {
                    "Key": "MyFieldName2",
                    "Value": "some-value"
                  }
                ],
                "SignatureFlowStatus": 0
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/GetFlowsByFilterRequest"
              },
              "example": {
                "CustomFields": [
                  {
                    "Key": "MyFieldName",
                    "Value": "some-value"
                  },
                  {
                    "Key": "MyFieldName2",
                    "Value": "some-value"
                  }
                ],
                "SignatureFlowStatus": 0
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid filter parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtentionExample"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/v6/flows/{signFlowId}/document": {
      "get": {
        "tags": [
          "Flow"
        ],
        "description": "[V6] Get the PDF document with all filled data and signatures",
        "parameters": [
          {
            "name": "signFlowId",
            "in": "path",
            "description": "The unique identifier (GUID) of the flow",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "withSigns",
            "in": "query",
            "description": "If true, return the PDF with digital signatures; if false, return without digital signatures (default: true)",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PDF document retrieved successfully",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid flow ID format",
            "content": {
              "application/pdf": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtentionExample"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "404": {
            "description": "Flow not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
