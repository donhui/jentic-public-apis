    "/v6/flows/{signFlowId}/attachments": {
      "get": {
        "tags": [
          "Flow"
        ],
        "description": "[V6] Get all flow attachments by flow ID as a ZIP archive",
        "parameters": [
          {
            "name": "signFlowId",
            "in": "path",
            "description": "The unique identifier (GUID) of the flow",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attachments retrieved successfully as ZIP archive",
            "content": {
              "application/zip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "204": {
            "description": "No attachments found for this flow"
          },
          "400": {
            "description": "Invalid flow ID format",
            "content": {
              "application/zip": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtention"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "404": {
            "description": "Flow not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "post": {
        "tags": [
          "Flow"
        ],
        "description": "[V6] Upload file attachment to existing flow\n\n* * *\n## signFlowId:\n\n### The unique identifier (GUID) of the flow\n\n* * *\n## file:\n\n### The file to attach to the flow. Supported file types: PDF, DOCX, DOC, XLSX, XLS, JPG, JPEG, PNG, and other common document formats\n\n* * *\n## addAttachmentToFlowRequest:\n\n### Request containing attachment metadata including the user who added the file (UserAddedTheFile participant key)\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| UserAddedTheFile | ***ParticipantKey*** | User that add the file to the flow |\n| IsSignerAttachment | Nullable\\<Boolean\\> | An indication of whether the attachment was added to the flow in creation mode,or assigned to a specific signer. |\n\n* * *\n### ParticipantKey:\n\n### Allow to locate Doxi user by:UserEmail=1UserPhone=2\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Key | String | User search value |\n| Type | ***ParticipantKeyType*** | Search type:UserEmail=1,UserPhone=2 |\n\n* * *\n### ParticipantKeyType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | UserId |\n| 1 | UserEmail |\n| 2 | UserPhone |\n| 3 | UserName |\n| 4 | GroupId |\n",
        "parameters": [
          {
            "name": "signFlowId",
            "in": "path",
            "description": "The unique identifier (GUID) of the flow",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file",
                  "addAttachmentToFlowRequest"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "The file to attach to the flow. Supported file types: PDF, DOCX, DOC, XLSX, XLS, JPG, JPEG, PNG, and other common document formats",
                    "format": "binary"
                  },
                  "addAttachmentToFlowRequest": {
                    "type": "string",
                    "description": "Request containing attachment metadata including the user who added the file (UserAddedTheFile participant key)",
                    "format": "json",
                    "example": "{\n  \"SignFlowId\": null,\n  \"UserMail\": null,\n  \"UserAddedTheFile\": {\n    \"Key\": \"user@example.com\",\n    \"Type\": 1\n  },\n  \"IsSignerAttachment\": false\n}"
                  }
                }
              },
              "example": {
                "UserAddedTheFile": {
                  "Key": "user@example.com",
                  "Type": 1
                },
                "IsSignerAttachment": false
              },
              "encoding": {
                "file": {
                  "style": "form"
                },
                "SignFlowId": {
                  "style": "form"
                },
                "UserMail": {
                  "style": "form"
                },
                "UserAddedTheFile.Key": {
                  "style": "form"
                },
                "UserAddedTheFile.Type": {
                  "style": "form"
                },
                "IsSignerAttachment": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File attached successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid flow ID format, invalid file, or invalid request data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtention"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "404": {
            "description": "Flow not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/v6/flows/{signFlowId}/attachments/base64": {
      "post": {
        "tags": [
          "Flow"
        ],
        "description": "[V6] Upload file attachment as base64 encoded string to existing flow\n\n* * *\n## signFlowId:\n\n### The unique identifier (GUID) of the flow\n\n* * *\n## addAttachmentToFlowRequest:\n\n### Request containing base64 encoded file (File property with Base64File object), attachment metadata, and user information (UserAddedTheFile participant key)\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * File | ***Base64File*** | Base64 attachment file data |\n| * UserAddedTheFile | ***ParticipantKey*** | The user that add the attachment |\n\n* * *\n### ParticipantKey:\n\n### Allow to locate Doxi user by:UserEmail=1UserPhone=2\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Key | String | User search value |\n| Type | ***ParticipantKeyType*** | Search type:UserEmail=1,UserPhone=2 |\n\n* * *\n### ParticipantKeyType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | UserId |\n| 1 | UserEmail |\n| 2 | UserPhone |\n| 3 | UserName |\n| 4 | GroupId |\n\n* * *\n### Base64File:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| FileName | String | File name with extention |\n| File | String | Base64 file data |\n",
        "parameters": [
          {
            "name": "signFlowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
