              },
              "example": {
                "File": {
                  "FileName": "attachment.pdf",
                  "File": ""
                },
                "UserAddedTheFile": {
                  "Key": "user@example.com",
                  "Type": 1
                }
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddAttachmentBase64ToFlowRequest"
