    "/v6/flows/{signFlowId}/attachment-field": {
      "post": {
        "tags": [
          "Flow"
        ],
        "description": "[V6] Get flow attachment field by flow ID, signer key, and element label\n\n* * *\n## signFlowId:\n\n### The unique identifier (GUID) of the flow\n\n* * *\n## getFlowAttachmentFieldRequest:\n\n### Request containing signer key (participant key with type and value) and element label (the label/name of the attachment field element) to retrieve the specific attachment\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| SignFlowId | String | Doxi flow ID |\n| SignerKey | ***ParticipantKey*** | The Signer user that add the attachment |\n| ElementLabel | String | The attachment element lable description |\n\n* * *\n### ParticipantKey:\n\n### Allow to locate Doxi user by:UserEmail=1UserPhone=2\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Key | String | User search value |\n| Type | ***ParticipantKeyType*** | Search type:UserEmail=1,UserPhone=2 |\n\n* * *\n### ParticipantKeyType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | UserId |\n| 1 | UserEmail |\n| 2 | UserPhone |\n| 3 | UserName |\n| 4 | GroupId |\n",
        "parameters": [
          {
            "name": "signFlowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/GetFlowAttachmentFieldRequest"
              },
              "example": {
                "SignerKey": {
                  "Key": "signer@example.com",
                  "Type": 1
                },
                "ElementLabel": "AttachmentField1"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetFlowAttachmentFieldRequest"
              },
              "example": {
                "SignerKey": {
                  "Key": "signer@example.com",
                  "Type": 1
                },
                "ElementLabel": "AttachmentField1"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/GetFlowAttachmentFieldRequest"
              },
              "example": {
                "SignerKey": {
                  "Key": "signer@example.com",
                  "Type": 1
                },
                "ElementLabel": "AttachmentField1"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/GetFlowAttachmentFieldRequest"
              },
              "example": {
                "SignerKey": {
                  "Key": "signer@example.com",
                  "Type": 1
                },
                "ElementLabel": "AttachmentField1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attachment field retrieved successfully",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "204": {
            "description": "No attachment found for the specified field"
          },
          "400": {
            "description": "Invalid flow ID format, invalid signer key, or invalid element label",
            "content": {
              "application/pdf": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtention"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "404": {
            "description": "Flow not found, signer not found in flow, or element label not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
