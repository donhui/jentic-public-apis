    "/v6/documents/analyze": {
      "post": {
        "tags": [
          "Document"
        ],
        "description": "[V6] Get document info from uploaded file stream\n## JSON object description:\n\n* * *\n## document:\n\n### Document file to analyze\n",
        "parameters": [
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "document": {
                    "type": "string",
                    "description": "Document file to analyze",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "document": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document analyzed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetDocumentInfoResponse"
                },
                "example": {
                  "NumberOfPages": 5
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or document format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtentionExample"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtentionExample"
                }
              }
            }
          }
        }
      }
    },
    "/v6/documents/analyze-base64": {
      "post": {
        "tags": [
          "Document"
        ],
        "description": "[V6] Get document info from uploaded file base64\n## JSON object description:\n\n* * *\n## getDocumentInfoRquest:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| File | String | Base 64 PDF document file |\n",
        "parameters": [
          {
            "name": "X-Tenant",
            "in": "header",
