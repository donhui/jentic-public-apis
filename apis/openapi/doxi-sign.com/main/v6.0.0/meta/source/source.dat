    "/ex/template/{templateId}": {
      "get": {
        "tags": [
          "Obsolete"
        ],
        "description": "Get all template elements and PDF document",
        "parameters": [
          {
            "name": "templateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetExTemplateInfoResponse"
                },
                "example": {
                  "DocumentFileName": "API Example.pdf",
                  "Users": [
                    {
                      "UserIndex": 1,
                      "Title": "Customer",
                      "SignerType": 0,
                      "IsSuspended": false,
                      "IsNoDecline": false,
                      "IsChangable": true,
                      "ForceApprovalOnSignature": false
                    }
                  ],
                  "Base64DocumentFile": "",
                  "TemplateName": "API Example",
                  "FlowElements": [
                    {
                      "UserIndex": 1,
                      "SignerIndex": 1,
                      "ElementType": 0,
                      "ElementSubType": 0,
                      "PageNumber": 1,
                      "Position": {
                        "Top": 291.0,
                        "Left": 401.0,
                        "Width": 114.0,
                        "Height": 38.0
                      },
                      "IsEditorElement": false,
                      "TextSize": 0,
                      "IsRequired": true,
                      "DisplayValueInFlowDecription": false,
                      "IsDisableAttachment": false
                    }
                  ],
                  "SendMethodType": 0,
                  "TemplateType": 0,
                  "CaptchaDisabled": false,
                  "IsAutomaticRemainder": false,
                  "DayesForAutomaticRemainder": 0,
                  "IsSendApprovalMailToAllSigners": false,
                  "DisableSBS": false,
                  "SenderUserName": "someuser",
                  "IsNoDecline": false
                }
              }
            }
          }
        },
        "deprecated": true
      },
      "put": {
        "tags": [
          "Obsolete"
        ],
        "description": "Update existing template\n\n* * *\n## templateId:\n\n\n* * *\n## exUpdateTemplateRequest:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * TemplateName | String | The name of the template |\n| FlowElements | ***ExTemplatFlowElement[]*** | All the elements of the template |\n| Users | ***ExTemplateUser[]*** | The users of the template |\n| SendMethodType | ***SendMethodType*** | Distribution method of the template |\n| TemplateType | ***Nullable\\<TemplateType\\>*** | The type of the template : Standard=0,AnonymousEnable=1,AnonymousDisable=2 |\n| CaptchaDisabled | Boolean | Disable/Enable captcha (only in anonymous template) |\n| PreliminaryText | String | Preliminary text of the flow - that will be created from this template (display only in side by side mode) |\n| SignFlowDescriptionMessage | String | Description of the document in the email |\n| IsAutomaticRemainder | Boolean | Enable/Disable send automatic remainder |\n| DayesForAutomaticRemainder | Int32 | Number of the days for getting automatic remainder  |\n| IsSendApprovalMailToAllSigners | Boolean | Enable/Disable send email to all signers (when the flow approved)  |\n| Recipients | ***ParticipantKey\\<ParticipantKeyType\\>[]*** | All the CC users of the flow (that will be created from this template) |\n| DisableSBS | Boolean | Disable/Enable dispaly side by side mode in the flow (that will be created from this template) |\n| FlowTwoFactorEnabled | Nullable\\<Boolean\\> | Enable/Disable Two Factor on the flow (that will created from this template) |\n| FlowExpirationDate | Nullable\\<DateTime\\> |  Expiration date of the flow (that will created from this template) |\n| ImagesList | Dictionary\\<String,String\\> | Dictionary of images for flow elements of type Image. |\n| SenderNotificationMailsToSend | ***NotificationMails[]*** | Types of notifications will be sent to the sender |\n\n* * *\n### TemplateType:\n\n### Types of templates \n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Standard |\n| 1 | AnonymousEnable |\n| 2 | AnonymousDisable |\n| 3 | Organizational |\n\n* * *\n### SendMethodType:\n\n### Distribution method of the flow\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | QueuedFlow |\n| 1 | ParallelFlow |\n\n* * *\n### ExTemplateUser:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| UserIndex | Int32 | The order of signer in the template |\n| Title | String | The title of the singer |\n| FixedSignerKey | ***ParticipantKey*** | The id of the fixed signer |\n| SignerType | ***Nullable\\<SignerType\\>*** | The type of the user |\n| IsDisableAttachment | Nullable\\<Boolean\\> | Disabled/Enabled add attachments to the flow (that will be created from the template) |\n| IsSuspended | Boolean | Set status flow to suspended (that will be created from the template) |\n| IsNoDecline | Boolean | Disable/Endable Decline the flow (that will be created from the template) |\n| MinimumSignatures | Nullable\\<Int32\\> |  |\n| ForceApprovalOnSignature | Boolean |  |\n| PersonalMessage | String(300) Validation: The field cannot contain script, vbscript, or style tags. |  |\n| NotificationMailsToSend | ***NotificationMails[]*** | Types of notifications will be sent to the signer |\n\n* * *\n### NotificationMails[]:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | All |\n| 1 | None |\n| 2 | SignFlow |\n| 3 | FlowApproved |\n| 4 | FlowDeclined |\n| 5 | FlowStart |\n| 6 | ReminderToSignFlow |\n| 7 | FlowStoppedToSender |\n| 8 | FlowStoppedToSigner |\n| 9 | KitCompleted |\n| 10 | SignKit |\n| 11 | ReminderToSignKit |\n| 12 | KitCreated |\n| 13 | FlowExpired |\n| 14 | FlowCCApproved |\n| 15 | FlowCCDeclined |\n\n* * *\n### SignerType:\n\n### Types of signers\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Changeable |\n| 1 | Static |\n| 2 | Anonymous |\n\n* * *\n### ParticipantKey:\n\n### Allow to locate Doxi user by:UserEmail=1UserPhone=2\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Key | String | User search value |\n| Type | ***ParticipantKeyType*** | Search type:UserEmail=1,UserPhone=2 |\n\n* * *\n### ParticipantKeyType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | UserId |\n| 1 | UserEmail |\n| 2 | UserPhone |\n| 3 | UserName |\n| 4 | GroupId |\n\n* * *\n### ExTemplatFlowElement:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| UserIndex | Int32 | The order of the user in the template |\n| * ElementType | ***ElementType*** | Type of element |\n| ElementSubType | ***ElementSubType*** | Type of subject element |\n| * PageNumber | Int32 | The page number of the element |\n| * Position | ***ElementPosition*** | Position of the element on the page |\n| TextValue | String(200) | The text of the element |\n| TextSize | Int32 | The size of the text element |\n| TextFont | String | The font of the text element |\n| ElementLabel | String | The label of the element |\n| ElementHelp | String | Information about the element (helps to know more about the element) |\n| ValueName | String | The value name of element (only on radio-button/checkbox elemets) |\n| HorizontalAlignment | ***Nullable\\<ExHorizontalAlignment\\>*** | Alignment the text of the element: Right=0,Center=1,Left=2 |\n| IsRequired | Nullable\\<Boolean\\> | Set required to element |\n| Validations | ***ExValidation[]*** | Set validation to element |\n| DateTimeValidation | ***ExDateTimeValidation*** | Set Date validation to element (only on Date element) |\n| DropDownList | ***ExDropDownField[]*** | Values of drop list element |\n| AdditionalInfo | KeyValuePair\\<String,String\\>[] | Add additional data to the element |\n| DuplicateElementInfo | ***DuplicateElementInfo*** | Set element as duplicate (make the element to parent) |\n| DisplayValueInFlowDecription | Boolean | Display/Not dispaly the value of element in the flow decription |\n| ZIndex | Nullable\\<Int32\\> | The order of the element on the page |\n\n* * *\n### DuplicateElementInfo:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| IsAllPagesFromCurrent | Boolean | Duplicate element at all pages  |\n| PageRange | String | Duplicate element on a specific page (for example : 1,5,8 - the element will duplicated on these pages) |\n\n* * *\n### ExDropDownField:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| Values | ***ExDropDownItem[]*** | List of values |\n\n* * *\n### ExDropDownItem:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| Key | String | Key of Item |\n| Value | String | Value of Item |\n\n* * *\n### ExDateTimeValidation:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| DateTimeFormat | String | Format of the date |\n| DateFormatLanguage | String | language : 'en-US','he-IL' |\n| IsCurrentDateTime | Boolean | Set the date to the current signing date  |\n| MinimumDate | Nullable\\<DateTime\\> | Minimum value of date |\n| MaximumDate | Nullable\\<DateTime\\> | Maximum value of date |\n\n* * *\n### ExValidation:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| Regex | String | The Regex on the value |\n| ErrorCode | ***ElementValidationError*** | Errors of regex |\n\n* * *\n### ElementValidationError:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 4 | Email |\n| 5 | IdNumber |\n| 6 | PhoneNumber |\n| 7 | LicensePlate |\n| 8 | PostalCode |\n| 10 | MandatoryElements |\n| 11 | smallChar |\n| 12 | BigChar |\n| 13 | SmallDate |\n| 14 | BigDate |\n| 15 | CreditCard |\n| 16 | CwCredit |\n| 17 | SmallNumber |\n| 18 | BigNumber |\n| 19 | RequiredElements |\n| 20 | FieldValueMustBeNumeric |\n\n* * *\n### ExHorizontalAlignment:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Right |\n| 1 | Center |\n| 2 | Left |\n\n* * *\n### ElementPosition:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Top | Single | Position of the element related to top of the page (in points) |\n| * Left | Single | Position of the element related to left of the page (in points) |\n| * Width | Single | Width of the element (in points) |\n| * Height | Single | Height of the element (in points) |\n\n* * *\n### ElementSubType:\n\n### Sub type of element\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Custom |\n| 1 | FullName |\n| 2 | FirstName |\n| 3 | LastName |\n| 4 | Email |\n| 5 | IdentityNumber |\n| 6 | PhoneNumber |\n| 7 | License |\n| 8 | PostalCode |\n| 9 | EditorText |\n| 10 | Initials |\n\n* * *\n### ElementType:\n\n###  Types of Elements\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Sign |\n| 1 | Text |\n| 2 | Date |\n| 3 | Erase |\n| 4 | Highlight |\n| 5 | Blackout |\n| 9 | EditorText |\n| 10 | Checkbox |\n| 11 | Numeric |\n| 12 | Radio |\n| 13 | Dropdown |\n| 14 | Attachment |\n| 17 | Image |\n",
        "parameters": [
          {
            "name": "templateId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
