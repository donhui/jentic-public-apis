    "/ex/flow/{signFlowId}/attachments": {
      "get": {
        "tags": [
          "Obsolete"
        ],
        "description": "Get all flow attachments by flow id",
        "parameters": [
          {
            "name": "signFlowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "deprecated": true
      },
      "post": {
        "tags": [
          "Obsolete"
        ],
        "description": " Upload file to existing flow\n\n* * *\n## signFlowId:\n\n\n* * *\n## file:\n\n\n* * *\n## addAttachmentToFlowRequest:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| UserAddedTheFile | ***ParticipantKey*** | User that add the file to the flow |\n| IsSignerAttachment | Nullable\\<Boolean\\> | An indication of whether the attachment was added to the flow in creation mode,or assigned to a specific signer. |\n\n* * *\n### ParticipantKey:\n\n### Allow to locate Doxi user by:UserEmail=1UserPhone=2\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Key | String | User search value |\n| Type | ***ParticipantKeyType*** | Search type:UserEmail=1,UserPhone=2 |\n\n* * *\n### ParticipantKeyType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | UserId |\n| 1 | UserEmail |\n| 2 | UserPhone |\n| 3 | UserName |\n| 4 | GroupId |\n",
        "parameters": [
          {
            "name": "signFlowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file",
                  "addAttachmentToFlowRequest"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "addAttachmentToFlowRequest": {
                    "type": "string",
                    "format": "json",
                    "example": "{\n  \"UserAddedTheFile\": {\n    \"Key\": \"user@example.com\",\n    \"Type\": 1\n  },\n  \"IsSignerAttachment\": false\n}\n\n"
                  }
                }
              },
              "encoding": {
                "file": {
                  "style": "form"
                },
                "SignFlowId": {
                  "style": "form"
                },
                "UserMail": {
                  "style": "form"
                },
                "UserAddedTheFile.Key": {
                  "style": "form"
                },
                "UserAddedTheFile.Type": {
                  "style": "form"
                },
                "IsSignerAttachment": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "deprecated": true
      }
    },
    "/ex/flow/{signFlowId}/attachments/base64": {
      "post": {
        "tags": [
          "Obsolete"
        ],
        "description": " Upload file as base64 to existing flow\n\n* * *\n## signFlowId:\n\n\n* * *\n## addAttachmentToFlowRequest:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * File | ***Base64File*** | Base64 attachment file data |\n| * UserAddedTheFile | ***ParticipantKey*** | The user that add the attachment |\n\n* * *\n### ParticipantKey:\n\n### Allow to locate Doxi user by:UserEmail=1UserPhone=2\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Key | String | User search value |\n| Type | ***ParticipantKeyType*** | Search type:UserEmail=1,UserPhone=2 |\n\n* * *\n### ParticipantKeyType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | UserId |\n| 1 | UserEmail |\n| 2 | UserPhone |\n| 3 | UserName |\n| 4 | GroupId |\n\n* * *\n### Base64File:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| FileName | String | File name with extention |\n| File | String | Base64 file data |\n",
        "parameters": [
          {
            "name": "signFlowId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/AddAttachmentBase64ToFlowRequest"
              },
              "example": {
                "File": {
                  "FileName": "attachment.pdf",
                  "File": ""
                },
                "UserAddedTheFile": {
                  "Key": "user@example.com",
                  "Type": 1
                }
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddAttachmentBase64ToFlowRequest"
              },
              "example": {
                "File": {
                  "FileName": "attachment.pdf",
                  "File": ""
                },
                "UserAddedTheFile": {
                  "Key": "user@example.com",
                  "Type": 1
                }
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddAttachmentBase64ToFlowRequest"
              },
              "example": {
                "File": {
                  "FileName": "attachment.pdf",
                  "File": ""
                },
                "UserAddedTheFile": {
                  "Key": "user@example.com",
                  "Type": 1
                }
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddAttachmentBase64ToFlowRequest"
              },
              "example": {
                "File": {
                  "FileName": "attachment.pdf",
                  "File": ""
                },
                "UserAddedTheFile": {
                  "Key": "user@example.com",
                  "Type": 1
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddAttachmentAsBase64ToFlowResponse"
                },
                "example": {
                  "AttachmentId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
                }
              }
            }
          }
        },
        "deprecated": true
      }
    },
