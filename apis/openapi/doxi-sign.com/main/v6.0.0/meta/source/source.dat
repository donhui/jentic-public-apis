    "/v6/templates/{templateId}/attachments": {
      "post": {
        "tags": [
          "Template"
        ],
        "description": "[V6] Upload file attachment to existing template\n\n* * *\n## templateId:\n\n### The unique identifier (GUID) of the template\n\n* * *\n## file:\n\n### The file to attach to the template. Supported file types: PDF, DOCX, DOC, XLSX, XLS, JPG, JPEG, PNG, and other common document formats\n\n* * *\n## addAttachmentRequest:\n\n### Request containing attachment metadata including the user who added the file (UserAddedTheFile participant key)\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| UserAddedTheFile | ***ParticipantKey*** | User that add the file to the flow |\n| IsSignerAttachment | Nullable\\<Boolean\\> | An indication of whether the attachment was added to the flow in creation mode,or assigned to a specific signer. |\n\n* * *\n### ParticipantKey:\n\n### Allow to locate Doxi user by:UserEmail=1UserPhone=2\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| * Key | String | User search value |\n| Type | ***ParticipantKeyType*** | Search type:UserEmail=1,UserPhone=2 |\n\n* * *\n### ParticipantKeyType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | UserId |\n| 1 | UserEmail |\n| 2 | UserPhone |\n| 3 | UserName |\n| 4 | GroupId |\n",
        "parameters": [
          {
            "name": "templateId",
            "in": "path",
            "description": "The unique identifier (GUID) of the template",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "The file to attach to the template. Supported file types: PDF, DOCX, DOC, XLSX, XLS, JPG, JPEG, PNG, and other common document formats",
                    "format": "binary"
                  },
                  "addAttachmentRequest": {
                    "type": "string",
                    "description": "Request containing attachment metadata including the user who added the file (UserAddedTheFile participant key)",
                    "format": "json",
                    "example": "{\n  \"SignFlowId\": null,\n  \"UserMail\": null,\n  \"UserAddedTheFile\": {\n    \"Key\": \"user@example.com\",\n    \"Type\": 1\n  },\n  \"IsSignerAttachment\": false\n}"
                  }
                }
              },
              "example": {
                "UserAddedTheFile": {
                  "Key": "user@example.com",
                  "Type": 1
                },
                "IsSignerAttachment": false
              },
              "encoding": {
                "file": {
                  "style": "form"
                },
                "SignFlowId": {
                  "style": "form"
                },
                "UserMail": {
                  "style": "form"
                },
                "UserAddedTheFile.Key": {
                  "style": "form"
                },
                "UserAddedTheFile.Type": {
                  "style": "form"
                },
                "IsSignerAttachment": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File attached successfully to template",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid template ID format, invalid file, or invalid request data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtentionExample"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "404": {
            "description": "Template not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/v6/templates/{templateId}/attachments/{attachmentId}": {
      "delete": {
        "tags": [
          "Template"
        ],
        "description": "[V6] Delete file attachment from existing template",
        "parameters": [
          {
