    "/v6/webhooks": {
      "post": {
        "tags": [
          "Webhook"
        ],
        "description": "[V6] Create a new webhook subscription\n## JSON object description:\n\n* * *\n## webhookSubscription:\n\n### Webhook subscription configuration including webhook URL (webhookUri), events to subscribe to (webhookEvents array), authentication headers (headers object), encryption settings (isEncryptData), and consumer information (webhookConsumer)\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| WebhookUri | String | Subscription webhook endpoint |\n| IsActive | Boolean | Is subscription active |\n| WebhookEvents | ***WebhookEvent[]*** | Publish the event with filter is matching   |\n| Headers | IDictionary\\<String,String\\> | Gets a set of additional HTTP headers. That headers will be sent with the webhook. |\n| IsEncryptData | Boolean | If to make the data encrypted |\n| WebhookConsumer | ***WebhookConsumer*** | Webhook consumer details |\n\n* * *\n### WebhookConsumer:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| Company | String |  The company of the consumer |\n| Description | String | The description of the  consumer |\n| ContactInfo | String | The contact info of the consumer |\n\n* * *\n### WebhookEvent:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| WebhookEventType | ***WebhookEventType*** |  |\n| SignFlowEventFilter | ***SignFlowEventFilter*** | Flow event filter parameters:Only then WebhookEventType=SignFlowStatusChanged. |\n| SignerEventFilter | ***SignerEventFilter*** | Signer event filter parameters :Only then WebhookEventType=SignerStatusChanged. |\n| OpenFlowEventFilter | ***OpenFlowEventFilter*** | Open flow event filter:Only then WebhookEventType=OpenFlowFirstTime. |\n| KitEventFilter | ***KitEventFilter*** | Kit event filter parameters :Only then WebhookEventType=KitStatusChanged. |\n| UserEventFilter | ***UserEventFilter*** | User event filter parameters :Only then WebhookEventType=UsersChanged. |\n\n* * *\n### UserEventFilter:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| UserType | ***Nullable\\<UserType\\>*** | User's type |\n| Company | String | User's company |\n\n* * *\n### UserType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Administrator |\n| 1 | Creator |\n| 2 | Signer |\n\n* * *\n### KitEventFilter:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| KitStatus | ***Nullable\\<KitStatusType\\>*** | Status of the kit |\n\n* * *\n### KitStatusType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Open |\n| 1 | Completed |\n| 2 | NotSend |\n| 3 | Deleted |\n| 4 | InProgress |\n\n* * *\n### OpenFlowEventFilter:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| CustomFieldsKeys | String[] | Additional data keys |\n| SourceTemplateId | String | The template id the flow was created from  |\n\n* * *\n### SignerEventFilter:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| SignStatus | ***Nullable\\<SignStatus\\>*** | Status of the signer |\n| CustomFieldsKeys | String[] | Additional data keys |\n| SourceTemplateId | String | The template id the flow was created from  |\n\n* * *\n### SignStatus:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | NotSend |\n| 1 | WaitingForApproval |\n| 2 | Approved |\n| 3 | Declined |\n| 4 | Stopped |\n| 5 | FailedToSent |\n| 6 | Suspended |\n| 7 | Expired |\n| 8 | InProgress |\n\n* * *\n### SignFlowEventFilter:\n\n| ***filed*** | ***type*** | ***description*** |\n| ------ | ------ | ------ |\n| SignatureFlowStatus | ***Nullable\\<SignatureFlowStatus\\>*** | Status of the flow |\n| CustomFieldsKeys | String[] | Additional data keys |\n| SourceTemplateId | String | The template id the flow was created from  |\n\n* * *\n### SignatureFlowStatus:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | Open |\n| 1 | Approved |\n| 2 | Declined |\n| 3 | Stopped |\n| 4 | Suspended |\n| 5 | Expired |\n\n* * *\n### WebhookEventType:\n\n| ***value*** | ***description*** |\n| ------ | ------ |\n| 0 | FlowStatusChangedEvent |\n| 1 | SignerStatusChangedEvent |\n| 2 | FlowOpenedEvent |\n| 3 | KitStatusChangedEvent |\n| 4 | AddUserEvent |\n| 5 | FlowsLimitEvent |\n",
        "parameters": [
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json-patch+json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscription"
              },
              "example": {
                "WebhookUri": "https://example.com/webhooks/doxi",
                "IsActive": true,
                "Webhooks": [],
                "WebhookEvents": [
                  {
                    "WebhookEventType": 0,
                    "SignFlowEventFilter": {
                      "SignatureFlowStatus": 1,
                      "CustomFieldsKeys": [
                        "ContractId",
                        "InvoiceNumber"
                      ]
                    }
                  },
                  {
                    "WebhookEventType": 1,
                    "SignerEventFilter": {
                      "SignStatus": 1,
                      "CustomFieldsKeys": []
                    }
                  }
                ],
                "Headers": {
                  "Authorization": "Bearer your-token-here",
                  "X-Custom-Header": "value"
                },
                "IsEncryptData": true,
                "WebhookConsumer": {
                  "Company": "Example Corp",
                  "Description": "Production webhook endpoint",
                  "ContactInfo": "admin@example.com"
                }
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscription"
              },
              "example": {
                "WebhookUri": "https://example.com/webhooks/doxi",
                "IsActive": true,
                "Webhooks": [],
                "WebhookEvents": [
                  {
                    "WebhookEventType": 0,
                    "SignFlowEventFilter": {
                      "SignatureFlowStatus": 1,
                      "CustomFieldsKeys": [
                        "ContractId",
                        "InvoiceNumber"
                      ]
                    }
                  },
                  {
                    "WebhookEventType": 1,
                    "SignerEventFilter": {
                      "SignStatus": 1,
                      "CustomFieldsKeys": []
                    }
                  }
                ],
                "Headers": {
                  "Authorization": "Bearer your-token-here",
                  "X-Custom-Header": "value"
                },
                "IsEncryptData": true,
                "WebhookConsumer": {
                  "Company": "Example Corp",
                  "Description": "Production webhook endpoint",
                  "ContactInfo": "admin@example.com"
                }
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscription"
              },
              "example": {
                "WebhookUri": "https://example.com/webhooks/doxi",
                "IsActive": true,
                "Webhooks": [],
                "WebhookEvents": [
                  {
                    "WebhookEventType": 0,
                    "SignFlowEventFilter": {
                      "SignatureFlowStatus": 1,
                      "CustomFieldsKeys": [
                        "ContractId",
                        "InvoiceNumber"
                      ]
                    }
                  },
                  {
                    "WebhookEventType": 1,
                    "SignerEventFilter": {
                      "SignStatus": 1,
                      "CustomFieldsKeys": []
                    }
                  }
                ],
                "Headers": {
                  "Authorization": "Bearer your-token-here",
                  "X-Custom-Header": "value"
                },
                "IsEncryptData": true,
                "WebhookConsumer": {
                  "Company": "Example Corp",
                  "Description": "Production webhook endpoint",
                  "ContactInfo": "admin@example.com"
                }
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscription"
              },
              "example": {
                "WebhookUri": "https://example.com/webhooks/doxi",
                "IsActive": true,
                "Webhooks": [],
                "WebhookEvents": [
                  {
                    "WebhookEventType": 0,
                    "SignFlowEventFilter": {
                      "SignatureFlowStatus": 1,
                      "CustomFieldsKeys": [
                        "ContractId",
                        "InvoiceNumber"
                      ]
                    }
                  },
                  {
                    "WebhookEventType": 1,
                    "SignerEventFilter": {
                      "SignStatus": 1,
                      "CustomFieldsKeys": []
                    }
                  }
                ],
                "Headers": {
                  "Authorization": "Bearer your-token-here",
                  "X-Custom-Header": "value"
                },
                "IsEncryptData": true,
                "WebhookConsumer": {
                  "Company": "Example Corp",
                  "Description": "Production webhook endpoint",
                  "ContactInfo": "admin@example.com"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook subscription created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddWebHookSubscriptionResponse"
                },
                "example": {
                  "SubscriptionId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                  "Secret": "WebhookSubscriptionSecretPrefix-a1b2c3d4e5f67890abcdef1234567890"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request - Missing required fields, invalid URL format, or invalid event configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtentionExample"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
