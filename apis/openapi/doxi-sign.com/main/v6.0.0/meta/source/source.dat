                  "9a4f3e12-8d7c-4b6a-91e2-0c5f6a7b8d90"
                ],
                "KitDescription": "Employment contract signing kit",
                "SenderKey": {
                  "Key": "sender@example.com",
                  "Type": 1
                },
                "PreliminaryText": "Please review and sign the attached documents. Contact HR if you have any questions.",
                "ExternalLinks": [
