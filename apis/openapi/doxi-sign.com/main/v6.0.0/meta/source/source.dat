            "$ref": "#/components/schemas/Base64File"
          },
          "UserAddedTheFile": {
            "$ref": "#/components/schemas/ParticipantKeyTypeParticipantKey"
          }
        },
        "additionalProperties": false
      },
      "AddNewSignatureFlowApiFlowElement": {
        "type": "object",
        "properties": {
          "ElementId": {
            "type": "string",
            "nullable": true
          },
          "SignerIndex": {
            "type": "integer",
            "format": "int32"
          },
          "GroupId": {
            "type": "string",
            "nullable": true
          },
          "Signer": {
            "$ref": "#/components/schemas/Participant"
          },
          "ElementType": {
            "enum": [
              "0 - Sign",
              "1 - Text",
              "2 - Date",
              "3 - Erase",
              "4 - Highlight",
              "5 - Blackout",
              "9 - EditorText",
              "10 - Checkbox",
              "11 - Numeric",
              "12 - Radio",
              "13 - Dropdown",
              "14 - Attachment",
              "17 - Image"
            ],
            "type": "integer",
            "format": "int32"
          },
          "ElementSubType": {
            "enum": [
              "0 - Custom",
              "1 - FullName",
              "2 - FirstName",
              "3 - LastName",
              "4 - Email",
              "5 - IdentityNumber",
              "6 - PhoneNumber",
              "7 - License",
              "8 - PostalCode",
              "9 - EditorText",
              "10 - Initials"
            ],
            "type": "integer",
            "format": "int32"
          },
          "PageNumber": {
            "type": "integer",
            "format": "int32"
          },
          "TopRelative": {
            "type": "number",
            "format": "float"
          },
          "LeftRelative": {
            "type": "number",
            "format": "float"
          },
