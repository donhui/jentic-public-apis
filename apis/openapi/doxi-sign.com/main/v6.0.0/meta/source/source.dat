              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/GetDocumentInfoRquest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document analyzed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetDocumentInfoResponse"
                },
                "example": {
