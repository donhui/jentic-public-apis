    "/v6/documents/search": {
      "post": {
        "tags": [
          "Document"
        ],
        "description": "[V6] Search for text within a document\n\n* * *\n## file:\n\n### Document file to search\n\n* * *\n## searchText:\n\n### Text to search for\n\n* * *\n## pages:\n\n### Optional pages to search (comma-separated, e.g., \"0,2-5,7\")\n\n* * *\n## isCaseSensitive:\n\n### Whether search should be case-sensitive (default: false)\n",
        "parameters": [
          {
            "name": "X-Tenant",
            "in": "header",
            "description": "Tenant Name",
            "required": true,
            "schema": {
              "type": "string",
              "default": "{{Tenant}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "searchText"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "Document file to search",
                    "format": "binary"
                  },
                  "searchText": {
                    "type": "string",
                    "description": "Text to search for"
                  },
                  "pages": {
                    "type": "string",
                    "description": "Optional pages to search (comma-separated, e.g., \"0,2-5,7\")"
                  },
                  "isCaseSensitive": {
                    "type": "boolean",
                    "description": "Whether search should be case-sensitive (default: false)",
                    "default": false
                  }
                }
              },
              "encoding": {
                "file": {
                  "style": "form"
                },
                "searchText": {
                  "style": "form"
                },
                "pages": {
                  "style": "form"
                },
                "isCaseSensitive": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchDocumentResponse"
                },
                "example": {
                  "Pages": [
                    {
                      "PageNumber": 0,
                      "MatchCount": 2,
                      "Elements": [
                        {
                          "Index": 0,
                          "Angle": 0,
                          "Text": "Sample Text",
                          "Position": {
                            "Top": 100.5,
                            "Left": 200.3,
                            "Width": 150.0,
                            "Height": 20.0
                          }
                        },
                        {
                          "Index": 1,
                          "Angle": 0,
                          "Text": "Sample Text",
                          "Position": {
                            "Top": 150.5,
                            "Left": 200.3,
                            "Width": 150.0,
                            "Height": 20.0
                          }
                        }
                      ]
                    },
                    {
                      "PageNumber": 1,
                      "MatchCount": 1,
                      "Elements": [
                        {
                          "Index": 0,
                          "Angle": 0,
                          "Text": "Sample Text",
                          "Position": {
                            "Top": 100.5,
                            "Left": 200.3,
                            "Width": 150.0,
                            "Height": 20.0
                          }
                        }
                      ]
                    }
                  ],
                  "TotalMatches": 3
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or document format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtentionExample"
                },
                "example": {
                  "Code": 1001,
                  "Type": "https://tools.ietf.org/html/rfc7231#section-6.5.1",
                  "Title": "One or more validation errors occurred.",
                  "Status": 400,
                  "Detail": "The request parameter is invalid or missing.",
                  "Instance": "/some-api-method",
                  "Extensions": {}
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid authentication token"
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetailsExtentionExample"
                }
              }
            }
          }
        }
      }
    },
