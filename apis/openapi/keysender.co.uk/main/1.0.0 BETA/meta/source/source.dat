                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Catalog"
        ],
        "summary": "Get order details",
        "description": "Retrieve details of a specific order.\n",
        "operationId": "getOrder",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "order_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "additional_information",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogOrderDetailsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogOrderResponse"
                }
              }
            }
          },
          "401": {
            "description": "Incorrect Credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCredentialsResponse"
                },
                "example": {
                  "message": "Unauthorized"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogOrderResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogOrderResponse"
                }
              }
            }
          }
        }
      }
    },
    "/catalog/order/cancel-item": {
      "post": {
        "tags": [
          "Catalog"
        ],
        "summary": "Cancel an item from the order",
        "description": "Cancel a specific item from an order.\n",
        "operationId": "cancelOrderItem",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "increment_id",
                  "line_item_id"
                ],
                "properties": {
                  "increment_id": {
                    "type": "string"
                  },
                  "line_item_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Item cancelled successfully (no content)"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogCancelItemResponse"
                }
              }
            }
          },
          "401": {
            "description": "Incorrect Credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCredentialsResponse"
                },
                "example": {
                  "message": "Unauthorized"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogCancelItemResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogCancelItemResponse"
                }
              }
            }
          },
          "502": {
            "description": "External System Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogCancelItemResponse"
                }
              }
            }
          }
        }
      }
    },
    "/catalog/order/top-up": {
      "post": {
        "summary": "Top up a product using ICCID and SKU",
        "description": "Top up a product using ICCID and SKU.\n",
        "tags": [
          "Catalog"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "top_up_sku",
                  "iccid",
                  "order_id"
                ],
                "properties": {
                  "top_up_sku": {
                    "type": "string",
                    "example": "TOPUP-001"
                  },
                  "iccid": {
                    "type": "string",
                    "example": "8945001234567890123"
                  },
                  "order_id": {
                    "type": "string",
                    "example": "KS/PO/0000000/00/2025"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Top-up successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogTopUpResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "error_code": {
                      "type": "string",
                      "example": "VALIDATION_ERROR"
                    },
                    "message": {
                      "type": "string",
                      "example": "order_id is required field. iccid is required field. top_up_sku is required field."
                    }
                  }
                }
              }
            }
          },
          "502": {
            "description": "System error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "error_code": {
                      "type": "string",
                      "example": "SYSTEM_ERROR"
                    },
                    "message": {
                      "type": "string",
                      "example": "System error."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "API error from Purchase Order",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "error"
                    },
                    "error_code": {
                      "type": "string",
                      "example": "ORDER_NOT_FOUND"
                    },
                    "message": {
                      "type": "string",
                      "example": "Order not found in the external system."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
