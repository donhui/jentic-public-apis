            "lang": "ActionScript",
            "label": "General text codes",
            "source": "POST {{host}}/api/v1.0/code?database_id=DATABASE_ID\nAccept: application/json\nContent-Type: application/json\nAuthorization: Bearer {{access_token}}\n\n[{\"value\":\"code1\"},{\"value\":\"code2\"}]\n"
