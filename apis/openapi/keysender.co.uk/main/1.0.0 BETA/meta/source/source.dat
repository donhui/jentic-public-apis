            "schema": {
              "type": "string"
            },
            "example": "Bearer <TOKEN>"
          },
          {
            "name": "sku",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "test"
          },
          {
            "name": "additional_information",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "example": 1
          }
        ],
        "responses": {
          "401": {
