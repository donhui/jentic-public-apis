    "/catalog/reserve": {
      "post": {
        "tags": [
          "Catalog"
        ],
        "summary": "Reserve items in catalog",
        "description": "Reserve items in the catalog for later purchase.\n",
        "operationId": "reserveItems",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "order_id",
                  "order_items"
                ],
                "properties": {
                  "order_id": {
                    "type": "string",
                    "example": "123-234-345"
                  },
                  "order_items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "sku",
                        "quantity"
                      ],
                      "properties": {
                        "sku": {
                          "type": "string",
                          "example": "test-sku-1"
                        },
                        "quantity": {
                          "type": "integer",
                          "example": 2
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reservation successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogReservationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogOrderResponse"
                }
              }
            }
          },
          "401": {
            "description": "Incorrect Credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCredentialsResponse"
                },
                "example": {
                  "message": "Unauthorized"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogOrderResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogOrderResponse"
                }
              }
            }
          }
        }
      }
    },
    "/catalog/order": {
      "post": {
        "tags": [
          "Catalog"
        ],
        "summary": "Create order from reservation",
        "description": "Create an order from a previously created reservation.\n",
        "operationId": "createOrder",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "reservation_id"
                ],
                "properties": {
                  "reservation_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogCreateOrderResponse"
                }
              }
            }
          },
          "401": {
            "description": "Incorrect Credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCredentialsResponse"
                },
                "example": {
                  "message": "Unauthorized"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCatalogCreateOrderResponse"
                }
              }
