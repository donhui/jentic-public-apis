            "example": 0
          },
          {
            "name": "pagesize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "example": 20
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Available filters: type, value, status. Statuses: 0 - code is available, 1 - code has been used. Code types: 1 - text code, 2 - file code",
            "example": "[{\"value\":\"food\"},{\"type\":0}]"
          }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
