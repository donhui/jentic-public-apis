{
  "openapi": "3.0.3",
  "servers": [
    {
      "url": "https://panel.keysender.co.uk/api/v1.0",
      "description": "Default server"
    }
  ],
  "info": {
    "description": "# Introduction\nAn Application Programming Interface (or API) is a way for two web pages and/or pieces of software to communicate with each other.\nAn API works as a middleman, taking the request from one piece of software, and then replying with the appropriate response from the other.\n\n# Authentication\nThe Keysender offers OAuth2 authentication.\nOAuth2 is an open protocol to allow secure authorization in a simple and standard method from web, mobile and desktop applications.\n\n[The OAuth 2.0 Authorization Framework: Bearer Token Usage](https://tools.ietf.org/html/rfc6750)\n\nThis specification describes how to use bearer tokens in HTTP requests to access OAuth 2.0 protected resources.\nAny party in possession of a bearer token (a \"bearer\") can use it to get access to the associated resources (without demonstrating possession of a cryptographic key).\nTo prevent misuse, bearer tokens need to be protected from disclosure in storage and in transport.\n\n<security-definitions />\n",
    "version": "1.0.0 BETA",
    "title": "Keysender API",
    "x-logo": {
      "url": "/assets/img/keysender.png",
      "altText": "keysender logo"
    },
    "x-jentic-source-url": "https://panel.keysender.co.uk/api"
  },
  "tags": [
    {
      "name": "User",
      "description": "Operations about user"
    },
    {
      "name": "Database",
      "description": "Operations about database"
    },
    {
      "name": "Code",
      "description": "Operations about codes"
    },
    {
      "name": "Transaction",
      "description": "Operations about transactions"
    },
    {
      "name": "Customer",
      "description": "Operations about customer"
    },
    {
      "name": "Catalog",
      "description": "Operations about catalog"
    }
  ],
  "x-tagGroups": [
    {
      "name": "User Management",
      "tags": [
        "User"
      ]
    },
    {
      "name": "Database and Codes",
      "tags": [
        "Database",
        "Code"
      ]
    },
    {
      "name": "Transactions",
      "tags": [
        "Transaction"
      ]
    },
    {
      "name": "Customer",
      "tags": [
        "Customer"
      ]
    },
    {
      "name": "Catalog",
      "tags": [
        "Catalog"
      ]
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "tags": [
          "User"
        ],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "api_secret"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Your API key for authentication"
                  },
                  "api_secret": {
                    "type": "string",
                    "format": "password",
                    "description": "Your API secret for authentication"
                  }
                }
              },
              "example": {
                "api_key": "your_api_key_here",
                "api_secret": "your_api_secret_here"
              }
            }
          }
        },
        "responses": {
          "401": {
            "description": "incorrect credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCredentialsResponse"
                },
                "example": {
                  "message": "Unauthorized"
                }
              }
            }
          },
          "422": {
            "description": "Incorrect parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "ack": "Failure",
                  "message": "The api_key field is required.",
                  "code": 1001
                }
              }
            }
          },
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        },
        "x-code-samples": [
          {
            "lang": "ActionScript",
            "label": "General",
            "source": "POST {{host}}/login\nAccept: application/json\nContent-Type: application/json\nCache-Control: no-cache\n\n{\"api_key\": \"your_api_key_here\", \"api_secret\": \"your_api_secret_here\"}\n"
          },
          {
            "lang": "Vim script",
            "label": "Curl",
            "source": "curl \\\n  -X POST \"https://keysender.co.uk/api/login\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"api_key\": \"your_api_key_here\", \"api_secret\": \"your_api_secret_here\"}'\n"
          }
        ]
      }
    },
    "/logout": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Logs out current logged in user session",
        "description": "",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "Bearer <TOKEN>"
          }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCredentialsResponse"
                },
                "example": {
                  "message": "Unauthorized"
                }
              }
            }
          },
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "example": {
                  "message": "Successfully logged out"
                }
              }
            }
          }
        }
      }
    },
