  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Sailthru API key. Also requires api_sig (HMAC-MD5 signature) and optionally format=json."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "integer"
          },
          "errormsg": {
            "type": "string"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "verified": {
            "type": "integer"
          },
          "lists": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            }
          },
          "vars": {
            "type": "object",
            "additionalProperties": true
          },
          "optout": {
            "type": "string"
          },
          "create_time": {
            "type": "string"
          }
        }
      },
      "UserUpdateRequest": {
        "type": "object",
        "required": [
          "api_key",
          "api_sig",
          "email"
        ],
        "properties": {
          "api_key": {
            "type": "string"
          },
          "api_sig": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "lists": {
            "type": "string",
            "description": "JSON object of list memberships"
          },
          "vars": {
            "type": "string",
            "description": "JSON object of user variables"
          },
          "optout": {
            "type": "string"
          }
        }
      },
      "SendRequest": {
        "type": "object",
        "required": [
          "api_key",
          "api_sig",
          "template",
          "email"
        ],
        "properties": {
          "api_key": {
            "type": "string"
          },
          "api_sig": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "vars": {
            "type": "string",
            "description": "JSON object of template variables"
          },
          "send_time": {
            "type": "string"
          }
        }
      },
      "SendResponse": {
        "type": "object",
        "properties": {
          "send_id": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "BlastRequest": {
        "type": "object",
        "required": [
          "api_key",
          "api_sig",
          "name",
          "list",
          "schedule_time",
          "from_name",
          "from_email",
          "subject"
        ],
        "properties": {
          "api_key": {
            "type": "string"
          },
          "api_sig": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "list": {
            "type": "string"
          },
          "schedule_time": {
            "type": "string"
          },
          "from_name": {
            "type": "string"
          },
          "from_email": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "content_html": {
            "type": "string"
          },
          "content_text": {
            "type": "string"
          }
        }
      },
      "Blast": {
        "type": "object",
        "properties": {
          "blast_id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "list": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "schedule_time": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "email_count": {
            "type": "integer"
          }
        }
      },
      "List": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "list": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "create_time": {
            "type": "string"
          }
        }
      },
      "ListRequest": {
        "type": "object",
        "required": [
          "api_key",
          "api_sig",
          "list"
        ],
        "properties": {
          "api_key": {
            "type": "string"
          },
          "api_sig": {
            "type": "string"
          },
          "list": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "from_name": {
            "type": "string"
          },
          "from_email": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "content_html": {
            "type": "string"
          },
          "content_text": {
            "type": "string"
          }
        }
      },
      "TemplateRequest": {
        "type": "object",
        "required": [
          "api_key",
          "api_sig",
          "template"
        ],
        "properties": {
          "api_key": {
            "type": "string"
          },
          "api_sig": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "from_name": {
            "type": "string"
          },
          "from_email": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "content_html": {
            "type": "string"
          },
          "content_text": {
            "type": "string"
          }
        }
      }
    }
  },
