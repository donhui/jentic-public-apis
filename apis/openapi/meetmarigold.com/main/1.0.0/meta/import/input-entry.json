            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get a user's profile by email"
      },
      "post": {
        "operationId": "createOrUpdateUser",
        "tags": [
          "Users"
