{
  "openapi": "3.0.3",
  "info": {
    "title": "Memegen.link",
    "version": "11.2",
    "description": "The free and open source API to generate memes. Fetch templates, add text, and create custom memes programmatically.",
    "x-jentic-source-url": "https://api.memegen.link/docs/openapi.json",
    "license": {
      "name": "View the license",
      "url": "https://github.com/jacebrowning/memegen/blob/main/LICENSE.txt"
    },
    "contact": {
      "name": "support",
      "email": "support@maketested.com"
    }
  },
  "servers": [
    {
      "url": "https://api.memegen.link",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {"name": "Clients"},
    {"name": "Fonts"},
    {"name": "Images"},
    {"name": "Templates"},
    {"name": "Shortcuts"}
  ],
  "paths": {
    "/auth": {
      "post": {
        "operationId": "validateApiKey",
        "summary": "Validate your API key",
        "tags": ["Clients"],
        "responses": {
          "200": {
            "description": "Your API key is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Your API key is invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/images/preview.jpg": {
      "get": {
        "operationId": "previewMeme",
        "summary": "Display a preview of a custom meme",
        "tags": ["Clients"],
        "parameters": [
          {"name": "layout", "schema": {"type": "string"}, "description": "Text position: default or top", "in": "query"},
          {"name": "template", "schema": {"type": "string"}, "description": "Template ID, URL, or custom background", "in": "query"},
          {"name": "style", "schema": {"type": "string"}, "description": "Style name or custom overlay", "in": "query"},
          {"name": "text[]", "schema": {"type": "string"}, "description": "Lines of text to render", "in": "query"}
        ],
        "responses": {
          "200": {
            "description": "Successfully displayed a custom meme",
            "content": {
              "image/jpeg": {
                "schema": {"type": "string", "format": "binary"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/fonts": {
      "get": {
        "operationId": "listFonts",
        "summary": "List available fonts",
        "tags": ["Fonts"],
        "responses": {
          "200": {
            "description": "Successfully returned a list of fonts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Font"}
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/fonts/{id}": {
      "get": {
        "operationId": "getFont",
        "summary": "View a specific font",
        "tags": ["Fonts"],
        "parameters": [
          {"name": "id", "schema": {"type": "string"}, "description": "ID of a font", "required": true, "in": "path"}
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a specific font",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Font"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "404": {
            "description": "Font not found"
          }
        }
      }
    },
    "/templates": {
      "get": {
        "operationId": "listTemplates",
        "summary": "List all templates",
        "tags": ["Templates"],
        "parameters": [
          {"name": "filter", "schema": {"type": "string"}, "description": "Part of the name, keyword, or example to match", "in": "query"},
          {"name": "animated", "schema": {"type": "boolean"}, "description": "Limit results to templates supporting animation", "in": "query"}
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a list of all templates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Template"}
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/templates/{id}": {
      "get": {
        "operationId": "getTemplate",
        "summary": "View a specific template",
        "tags": ["Templates"],
        "parameters": [
          {"name": "id", "schema": {"type": "string"}, "description": "ID of a meme template", "required": true, "in": "path"}
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a specific template",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Template"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "404": {
            "description": "Template not found"
          }
        }
      },
      "post": {
        "operationId": "createMemeFromTemplate",
        "summary": "Create a meme from a template",
        "tags": ["Templates"],
        "parameters": [
          {"name": "id", "schema": {"type": "string"}, "description": "ID of a meme template", "required": true, "in": "path"}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/MemeRequest"}
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successfully created a meme from a template",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/MemeResponse"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/templates/custom": {
      "post": {
        "operationId": "createMemeFromCustomImage",
        "summary": "Create a meme from any image",
        "tags": ["Templates"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CustomMemeRequest"}
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successfully created a meme from a custom image",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/MemeResponse"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/images": {
      "get": {
        "operationId": "listExampleMemes",
        "summary": "List example memes",
        "tags": ["Images"],
        "parameters": [
          {"name": "filter", "schema": {"type": "string"}, "description": "Part of the template name or example to match", "in": "query"}
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a list of example memes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/ExampleMeme"}
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createMeme",
        "summary": "Create a meme from a template",
        "tags": ["Images"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "template_id": {"type": "string"},
                  "style": {"type": "array", "items": {"type": "string"}},
                  "text": {"type": "array", "items": {"type": "string"}},
                  "layout": {"type": "string"},
                  "font": {"type": "string"},
                  "extension": {"type": "string"},
                  "redirect": {"type": "boolean"}
                },
                "required": ["template_id"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successfully created a meme",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/MemeResponse"}
              }
            }
          },
          "400": {
            "description": "Required template_id missing in request body",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "404": {
            "description": "Specified template_id does not exist",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/images/custom": {
      "get": {
        "operationId": "listCustomMemes",
        "summary": "List popular custom memes",
        "tags": ["Images"],
        "parameters": [
          {"name": "filter", "schema": {"type": "string"}, "description": "Part of the meme's text to match", "in": "query"},
          {"name": "safe", "schema": {"type": "boolean"}, "description": "Exclude NSFW results", "in": "query"}
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a list of custom memes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/MemeResponse"}
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCustomMeme",
        "summary": "Create a meme from any image",
        "tags": ["Images"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CustomMemeRequest"}
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successfully created a meme from a custom image",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/MemeResponse"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/images/automatic": {
      "post": {
        "operationId": "createAutomaticMeme",
        "summary": "Create a meme from word or phrase",
        "tags": ["Images"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {"type": "string"},
                  "safe": {"type": "boolean"},
                  "redirect": {"type": "boolean"}
                },
                "required": ["text"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successfully created a meme",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/MemeResponse"}
              }
            }
          },
          "400": {
            "description": "Required text missing in request body",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/images/{template_filename}": {
      "get": {
        "operationId": "getTemplateBackground",
        "summary": "Display a template background",
        "tags": ["Images"],
        "parameters": [
          {"name": "template_filename", "schema": {"type": "string"}, "description": "Template ID and image format: <template_id>.<extension>", "required": true, "in": "path"}
        ],
        "responses": {
          "200": {
            "description": "Successfully displayed a template background",
            "content": {
              "image/*": {
                "schema": {"type": "string", "format": "binary"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "404": {
            "description": "Template not found"
          }
        }
      }
    },
    "/images/{template_id}/{text_filepath}": {
      "get": {
        "operationId": "getCustomMemeImage",
        "summary": "Display a custom meme",
        "tags": ["Images"],
        "parameters": [
          {"name": "template_id", "schema": {"type": "string"}, "description": "ID of a meme template", "required": true, "in": "path"},
          {"name": "text_filepath", "schema": {"type": "string"}, "description": "Lines of text and image format: <line1>/<line2>.<extension>", "required": true, "in": "path"}
        ],
        "responses": {
          "200": {
            "description": "Successfully displayed a custom meme",
            "content": {
              "image/*": {
                "schema": {"type": "string", "format": "binary"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "404": {
            "description": "Template not found"
          },
          "414": {
            "description": "Custom text too long (length >200)"
          },
          "415": {
            "description": "Unable to download image URL"
          },
          "422": {
            "description": "Invalid style for template or no image URL specified for custom template"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "name": "X-API-KEY",
        "in": "header"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {"type": "string"}
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "email": {"type": "string"},
          "image_access": {"type": "boolean"},
          "search_access": {"type": "boolean"},
          "created": {"type": "string", "format": "date-time"},
          "modified": {"type": "string", "format": "date-time"}
        }
      },
      "Font": {
        "type": "object",
        "properties": {
          "filename": {"type": "string"},
          "id": {"type": "string"},
          "alias": {"type": "string"}
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "lines": {"type": "integer"},
          "overlays": {"type": "integer"},
          "styles": {"type": "array", "items": {"type": "string"}},
          "blank": {"type": "string"},
          "example": {
            "$ref": "#/components/schemas/TemplateExample"
          },
          "source": {"type": "string"}
        }
      },
      "TemplateExample": {
        "type": "object",
        "properties": {
          "text": {"type": "array", "items": {"type": "string"}},
          "url": {"type": "string"}
        }
      },
      "MemeRequest": {
        "type": "object",
        "properties": {
          "style": {"type": "array", "items": {"type": "string"}},
          "text": {"type": "array", "items": {"type": "string"}},
          "layout": {"type": "string"},
          "font": {"type": "string"},
          "extension": {"type": "string"},
          "redirect": {"type": "boolean"}
        }
      },
      "CustomMemeRequest": {
        "type": "object",
        "properties": {
          "background": {"type": "string"},
          "style": {"type": "string"},
          "text": {"type": "array", "items": {"type": "string"}},
          "layout": {"type": "string"},
          "font": {"type": "string"},
          "extension": {"type": "string"},
          "redirect": {"type": "boolean"}
        },
        "required": ["background"]
      },
      "MemeResponse": {
        "type": "object",
        "properties": {
          "url": {"type": "string"}
        }
      },
      "ExampleMeme": {
        "type": "object",
        "properties": {
          "url": {"type": "string"},
          "template": {"type": "string"}
        }
      }
    }
  }
}