{
  "openapi": "3.0.3",
  "info": {
    "title": "Glide Big Tables API",
    "version": "2.0.0",
    "description": "Glide API v2 for managing Big Tables, rows, jobs, stashes, and file uploads in Glide applications.",
    "x-jentic-source-url": "https://apidocs.glideapps.com/api-reference/v2/general/introduction"
  },
  "servers": [
    {
      "url": "https://api.glideapps.com"
    }
  ],
  "paths": {
    "/tables": {
      "get": {
        "operationId": "getAllTables",
        "summary": "Get all Big Tables",
        "description": "Gets all Big Tables in the current team.",
        "tags": ["Tables"],
        "responses": {
          "200": {
            "description": "List of Big Tables",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TablesListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createTable",
        "summary": "Create a new Big Table",
        "description": "Creates a new Big Table.",
        "tags": ["Tables"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTableRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Table created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Table"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tables/{tableId}": {
      "put": {
        "operationId": "replaceTable",
        "summary": "Replace a Big Table",
        "description": "Replaces the schema and/or data of a Big Table.",
        "tags": ["Tables"],
        "parameters": [
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "description": "The Big Table identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReplaceTableRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Table replaced successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Table"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tables/{tableId}/rows": {
      "get": {
        "operationId": "getRows",
        "summary": "Get rows from a Big Table",
        "description": "Gets rows from a Big Table.",
        "tags": ["Rows"],
        "parameters": [
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "description": "The Big Table identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of rows to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Number of rows to skip",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Rows retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RowsListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "head": {
        "operationId": "getRowVersion",
        "summary": "Get row version information",
        "description": "Retrieve row version information for a Big Table.",
        "tags": ["Rows"],
        "parameters": [
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "description": "The Big Table identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Row version headers returned"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "addRows",
        "summary": "Add rows to a Big Table",
        "description": "Adds rows to a Big Table.",
        "tags": ["Rows"],
        "parameters": [
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "description": "The Big Table identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddRowsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rows added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddRowsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tables/{tableId}/rows/{rowId}": {
      "get": {
        "operationId": "getRow",
        "summary": "Get a single row",
        "description": "Gets a single row from a Big Table by row ID.",
        "tags": ["Rows"],
        "parameters": [
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "description": "The Big Table identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rowId",
            "in": "path",
            "required": true,
            "description": "The row identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Row retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Row"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateRow",
        "summary": "Update a row",
        "description": "Updates a row in a Big Table.",
        "tags": ["Rows"],
        "parameters": [
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "description": "The Big Table identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rowId",
            "in": "path",
            "required": true,
            "description": "The row identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRowRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Row updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Row"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteRow",
        "summary": "Delete a row",
        "description": "Deletes a row from a Big Table.",
        "tags": ["Rows"],
        "parameters": [
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "description": "The Big Table identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rowId",
            "in": "path",
            "required": true,
            "description": "The row identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Row deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}": {
      "get": {
        "operationId": "getJob",
        "summary": "Get a job",
        "description": "Check whether a job is finished, and get its result.",
        "tags": ["Jobs"],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "description": "The job identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stashes/{stashId}": {
      "delete": {
        "operationId": "deleteStash",
        "summary": "Delete a stash",
        "description": "Deletes a stash and all its data.",
        "tags": ["Stashes"],
        "parameters": [
          {
            "name": "stashId",
            "in": "path",
            "required": true,
            "description": "The stash identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stash deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stashes/{stashId}/data": {
      "put": {
        "operationId": "setStashData",
        "summary": "Set stash data",
        "description": "Sets the content of a chunk of data inside a stash.",
        "tags": ["Stashes"],
        "parameters": [
          {
            "name": "stashId",
            "in": "path",
            "required": true,
            "description": "The stash identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Data chunk to set in the stash"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stash data set successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/uploads": {
      "post": {
        "operationId": "initiateUpload",
        "summary": "Initiate a file upload",
        "description": "Initiate a file upload to Glide.",
        "tags": ["Uploads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InitiateUploadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/uploads/{uploadId}/complete": {
      "post": {
        "operationId": "completeUpload",
        "summary": "Complete a file upload",
        "description": "Finalize a file upload.",
        "tags": ["Uploads"],
        "parameters": [
          {
            "name": "uploadId",
            "in": "path",
            "required": true,
            "description": "The upload identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Upload completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadCompleteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Table": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Table identifier"
          },
          "name": {
            "type": "string",
            "description": "Table name"
          },
          "schema": {
            "type": "object",
            "description": "Table schema definition"
          }
        }
      },
      "TablesListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Table"
            }
          }
        }
      },
      "Row": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Row identifier"
          }
        },
        "additionalProperties": true,
        "description": "A row in a Big Table with dynamic column values"
      },
      "RowsListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Row"
            }
          },
          "next": {
            "type": "string",
            "description": "Pagination cursor for next page"
          }
        }
      },
      "CreateTableRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the new Big Table"
          },
          "schema": {
            "type": "object",
            "description": "Schema definition for the table"
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Initial rows to populate the table"
          }
        }
      },
      "ReplaceTableRequest": {
        "type": "object",
        "properties": {
          "schema": {
            "type": "object",
            "description": "New schema definition"
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "New row data"
          }
        }
      },
      "AddRowsRequest": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Rows to add to the table"
          }
        }
      },
      "AddRowsResponse": {
        "type": "object",
        "properties": {
          "rowIDs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of the newly added rows"
          }
        }
      },
      "UpdateRowRequest": {
        "type": "object",
        "additionalProperties": true,
        "description": "Column values to update"
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Job identifier"
          },
          "status": {
            "type": "string",
            "description": "Job status"
          },
          "result": {
            "type": "object",
            "description": "Job result when completed"
          }
        }
      },
      "InitiateUploadRequest": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "description": "Name of the file to upload"
          },
          "contentType": {
            "type": "string",
            "description": "MIME type of the file"
          }
        }
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "uploadId": {
            "type": "string",
            "description": "Identifier for the upload"
          },
          "uploadUrl": {
            "type": "string",
            "description": "Presigned URL to upload the file to"
          }
        }
      },
      "UploadCompleteResponse": {
        "type": "object",
        "properties": {
          "fileUrl": {
            "type": "string",
            "description": "URL of the uploaded file"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Glide API token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}