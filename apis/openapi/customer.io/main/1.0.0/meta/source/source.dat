{
  "openapi": "3.0.3",
  "info": {
    "title": "Customer.io Track API",
    "version": "1.0.0",
    "description": "Customer.io Track API for adding people to your audience and triggering campaigns based on customer behavior. Supports identifying customers, tracking events, managing devices, segments, and batch operations.",
    "x-jentic-source-url": "http://learn.customer.io/api/"
  },
  "servers": [
    {
      "url": "https://track.customer.io",
      "description": "Customer.io Track API (US)"
    },
    {
      "url": "https://track-eu.customer.io",
      "description": "Customer.io Track API (EU)"
    }
  ],
  "security": [
    {
      "TrackingApiKey": []
    }
  ],
  "tags": [
    {"name": "Customers", "description": "Customer identity and profile management"},
    {"name": "Events", "description": "Track customer and anonymous events"},
    {"name": "Devices", "description": "Manage customer devices"},
    {"name": "Segments", "description": "Manage manual segments"},
    {"name": "Forms", "description": "Form submissions"},
    {"name": "Merge", "description": "Merge duplicate customers"},
    {"name": "Metrics", "description": "Report delivery metrics"},
    {"name": "Batch", "description": "Batch operations"},
    {"name": "Account", "description": "Account information"}
  ],
  "paths": {
    "/api/v1/accounts/region": {
      "get": {
        "tags": ["Account"],
        "operationId": "getRegion",
        "summary": "Find your account region",
        "responses": {
          "200": {
            "description": "Region info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RegionResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/customers/{identifier}": {
      "put": {
        "tags": ["Customers"],
        "operationId": "identify",
        "summary": "Add or update a customer",
        "parameters": [{ "$ref": "#/components/parameters/CustomerIdentifier" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CustomerAttributes" }
            }
          }
        },
        "responses": {
          "200": { "description": "Customer identified" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "tags": ["Customers"],
        "operationId": "deleteCustomer",
        "summary": "Delete a customer",
        "parameters": [{ "$ref": "#/components/parameters/CustomerIdentifier" }],
        "responses": {
          "200": { "description": "Customer deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/customers/{identifier}/devices": {
      "put": {
        "tags": ["Devices"],
        "operationId": "addDevice",
        "summary": "Add or update a customer device",
        "parameters": [{ "$ref": "#/components/parameters/CustomerIdentifier" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeviceInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Device added" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/customers/{identifier}/devices/{device_id}": {
      "delete": {
        "tags": ["Devices"],
        "operationId": "deleteDevice",
        "summary": "Delete a customer device",
        "parameters": [
          { "$ref": "#/components/parameters/CustomerIdentifier" },
          { "name": "device_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Device deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/customers/{identifier}/suppress": {
      "post": {
        "tags": ["Customers"],
        "operationId": "suppressCustomer",
        "summary": "Suppress a customer profile",
        "parameters": [{ "$ref": "#/components/parameters/CustomerIdentifier" }],
        "responses": {
          "200": { "description": "Customer suppressed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/customers/{identifier}/unsuppress": {
      "post": {
        "tags": ["Customers"],
        "operationId": "unsuppressCustomer",
        "summary": "Unsuppress a customer profile",
        "parameters": [{ "$ref": "#/components/parameters/CustomerIdentifier" }],
        "responses": {
          "200": { "description": "Customer unsuppressed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/customers/{identifier}/events": {
      "post": {
        "tags": ["Events"],
        "operationId": "trackEvent",
        "summary": "Track a customer event",
        "parameters": [{ "$ref": "#/components/parameters/CustomerIdentifier" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EventInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Event tracked" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/events": {
      "post": {
        "tags": ["Events"],
        "operationId": "trackAnonymousEvent",
        "summary": "Track an anonymous event",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AnonymousEventInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Event tracked" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/forms/{form_id}/submit": {
      "post": {
        "tags": ["Forms"],
        "operationId": "submitForm",
        "summary": "Submit a form",
        "parameters": [
          { "name": "form_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FormSubmitInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Form submitted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/merge_customers": {
      "post": {
        "tags": ["Merge"],
        "operationId": "mergeCustomers",
        "summary": "Merge duplicate people",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MergeInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Customers merged" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/segments/{segment_id}/add_customers": {
      "post": {
        "tags": ["Segments"],
        "operationId": "addToSegment",
        "summary": "Add people to a manual segment",
        "parameters": [
          { "name": "segment_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SegmentMembershipInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Customers added to segment" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/segments/{segment_id}/remove_customers": {
      "post": {
        "tags": ["Segments"],
        "operationId": "removeFromSegment",
        "summary": "Remove people from a manual segment",
        "parameters": [
          { "name": "segment_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SegmentMembershipInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Customers removed from segment" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/metrics": {
      "post": {
        "tags": ["Metrics"],
        "operationId": "reportMetrics",
        "summary": "Report delivery metrics",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MetricsInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Metrics reported" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v2/entity": {
      "post": {
        "tags": ["Batch"],
        "operationId": "singleEntity",
        "summary": "Make a single request (v2)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EntityInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Request processed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v2/batch": {
      "post": {
        "tags": ["Batch"],
        "operationId": "batchRequests",
        "summary": "Send multiple requests in batch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BatchInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Batch processed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "TrackingApiKey": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic auth with site_id as username and Tracking API key as password"
      }
    },
    "parameters": {
      "CustomerIdentifier": {
        "name": "identifier",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Customer identifier (ID or email)"
      }
    },
    "responses": {
      "BadRequest": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Unauthorized": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
    },
    "schemas": {
      "Error": { "type": "object", "properties": { "meta": { "type": "object", "properties": { "error": { "type": "string" } } } } },
      "RegionResponse": { "type": "object", "properties": { "region": { "type": "string" }, "url": { "type": "string" } } },
      "CustomerAttributes": { "type": "object", "properties": { "email": { "type": "string" }, "created_at": { "type": "integer" } }, "additionalProperties": true },
      "DeviceInput": { "type": "object", "properties": { "device": { "type": "object", "properties": { "id": { "type": "string" }, "platform": { "type": "string", "enum": ["ios", "android"] }, "last_used": { "type": "integer" } }, "required": ["id", "platform"] } } },
      "EventInput": { "type": "object", "properties": { "name": { "type": "string" }, "data": { "type": "object" } }, "required": ["name"] },
      "AnonymousEventInput": { "type": "object", "properties": { "name": { "type": "string" }, "data": { "type": "object" } }, "required": ["name"] },
      "FormSubmitInput": { "type": "object", "properties": { "data": { "type": "object" }, "customer_id": { "type": "string" } } },
      "MergeInput": { "type": "object", "properties": { "primary": { "type": "object", "properties": { "id": { "type": "string" } } }, "secondary": { "type": "object", "properties": { "id": { "type": "string" } } } } },
      "SegmentMembershipInput": { "type": "object", "properties": { "ids": { "type": "array", "items": { "type": "string" } } }, "required": ["ids"] },
      "MetricsInput": { "type": "object", "properties": { "deliveries": { "type": "array", "items": { "type": "object" } } } },
      "EntityInput": { "type": "object", "properties": { "type": { "type": "string" }, "action": { "type": "string" }, "identifiers": { "type": "object" }, "attributes": { "type": "object" } } },
      "BatchInput": { "type": "object", "properties": { "batch": { "type": "array", "items": { "$ref": "#/components/schemas/EntityInput" } } } }
    }
  }
}