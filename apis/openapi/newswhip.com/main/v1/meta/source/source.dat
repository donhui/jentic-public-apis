{
  "openapi": "3.0.3",
  "info": {
    "title": "NewsWhip API",
    "version": "v1",
    "description": "NewsWhip API provides access to social engagement data for articles and Facebook posts, including historical data, statistics, influencer identification, and content discovery by region, publisher, or search terms.",
    "x-jentic-source-url": "https://developer.newswhip.com/"
  },
  "servers": [
    {
      "url": "https://api.newswhip.com/v1"
    }
  ],
  "paths": {
    "/region": {
      "get": {
        "operationId": "getRegionContent",
        "summary": "Get content by region",
        "description": "Retrieve trending or popular content filtered by geographic region.",
        "tags": ["QuickStart"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with regional content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/publisher": {
      "get": {
        "operationId": "getPublisherContent",
        "summary": "Get content by publisher",
        "description": "Retrieve content from a specific publisher.",
        "tags": ["QuickStart"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with publisher content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/local": {
      "get": {
        "operationId": "getLocalContent",
        "summary": "Get local content",
        "description": "Retrieve localized content based on geographic area.",
        "tags": ["QuickStart"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with local content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "searchContent",
        "summary": "Search content",
        "description": "General content search across the NewsWhip database.",
        "tags": ["QuickStart"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/articles": {
      "post": {
        "operationId": "searchArticles",
        "summary": "Search articles with engagement data",
        "description": "Search for articles by topic, keyword, publisher, or author. Returns articles with social engagement metrics from Facebook, Twitter, LinkedIn, and Pinterest.",
        "tags": ["Historical"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArticleSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with articles and engagement data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/fbPosts": {
      "post": {
        "operationId": "searchFacebookPosts",
        "summary": "Search Facebook posts",
        "description": "Search for Facebook posts from specific authors and publishers, with performance metrics.",
        "tags": ["Historical"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArticleSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with Facebook posts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FacebookPostListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/stats": {
      "post": {
        "operationId": "getStatistics",
        "summary": "Get aggregated statistics",
        "description": "Retrieve aggregated statistics and rankings by domain or language, with grouping capabilities.",
        "tags": ["Historical"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StatsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with aggregated statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/fbInfluencers": {
      "post": {
        "operationId": "getFacebookInfluencers",
        "summary": "Identify Facebook influencers",
        "description": "Identify influential Facebook publishers and authors based on engagement metrics.",
        "tags": ["Historical"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArticleSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with influencer data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfluencerListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/articlesByHrefs": {
      "post": {
        "operationId": "getArticlesByUrls",
        "summary": "Get articles by URLs",
        "description": "Retrieve article data and current/predicted engagement levels for multiple URLs per request.",
        "tags": ["Historical"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArticlesByHrefsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with article data for the given URLs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/syndicatedArticles": {
      "post": {
        "operationId": "searchSyndicatedArticles",
        "summary": "Search syndicated articles",
        "description": "Access syndicated content data across publishers.",
        "tags": ["Syndication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArticleSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with syndicated articles",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ArticleSearchRequest": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Domain or category filters"
          },
          "from": {
            "type": "integer",
            "format": "int64",
            "description": "Start timestamp in Unix milliseconds"
          },
          "to": {
            "type": "integer",
            "format": "int64",
            "description": "End timestamp in Unix milliseconds"
          },
          "size": {
            "type": "integer",
            "description": "Maximum number of results to return"
          },
          "language": {
            "type": "string",
            "description": "Two-letter language code (e.g., 'en')"
          },
          "sort_by": {
            "type": "string",
            "description": "Field to sort results by",
            "enum": ["fb_total", "fb_tw_and_li", "predicted_interactions", "created_at"]
          }
        }
      },
      "StatsRequest": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Domain or category filters"
          },
          "from": {
            "type": "integer",
            "format": "int64",
            "description": "Start timestamp in Unix milliseconds"
          },
          "to": {
            "type": "integer",
            "format": "int64",
            "description": "End timestamp in Unix milliseconds"
          },
          "size": {
            "type": "integer",
            "description": "Number of results to return"
          },
          "language": {
            "type": "string",
            "description": "Two-letter language code"
          },
          "sort_by": {
            "type": "string",
            "description": "Sort field"
          },
          "aggregate_by": {
            "type": "string",
            "description": "Aggregation dimension (e.g., domain, language)"
          }
        }
      },
      "ArticlesByHrefsRequest": {
        "type": "object",
        "required": ["hrefs"],
        "properties": {
          "hrefs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of article URLs to look up"
          }
        }
      },
      "ArticleListResponse": {
        "type": "object",
        "properties": {
          "articles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Article"
            }
          }
        }
      },
      "Article": {
        "type": "object",
        "properties": {
          "headline": {
            "type": "string",
            "description": "Article headline"
          },
          "excerpt": {
            "type": "string",
            "description": "Article excerpt or summary"
          },
          "link": {
            "type": "string",
            "description": "Article URL"
          },
          "source": {
            "type": "object",
            "properties": {
              "publisher": {
                "type": "string"
              },
              "domain": {
                "type": "string"
              }
            }
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "publication_timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "Publication time in Unix milliseconds"
          },
          "fb_data": {
            "type": "object",
            "properties": {
              "total_engagement_count": {
                "type": "integer"
              },
              "likes": {
                "type": "integer"
              },
              "shares": {
                "type": "integer"
              },
              "comments": {
                "type": "integer"
              }
            }
          },
          "tw_data": {
            "type": "object",
            "properties": {
              "tw_count": {
                "type": "integer"
              }
            }
          },
          "li_data": {
            "type": "object",
            "properties": {
              "li_count": {
                "type": "integer"
              }
            }
          },
          "pi_data": {
            "type": "object",
            "properties": {
              "pi_count": {
                "type": "integer"
              }
            }
          },
          "predicted_interactions": {
            "type": "integer",
            "description": "Predicted total engagement"
          }
        }
      },
      "FacebookPostListResponse": {
        "type": "object",
        "properties": {
          "fb_posts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FacebookPost"
            }
          }
        }
      },
      "FacebookPost": {
        "type": "object",
        "properties": {
          "post_url": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "total_engagement": {
            "type": "integer"
          },
          "likes": {
            "type": "integer"
          },
          "shares": {
            "type": "integer"
          },
          "comments": {
            "type": "integer"
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "stats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StatEntry"
            }
          }
        }
      },
      "StatEntry": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Aggregation key (e.g., domain name)"
          },
          "count": {
            "type": "integer",
            "description": "Number of articles"
          },
          "total_engagement": {
            "type": "integer",
            "description": "Total social engagement"
          }
        }
      },
      "InfluencerListResponse": {
        "type": "object",
        "properties": {
          "influencers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Influencer"
            }
          }
        }
      },
      "Influencer": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "page_url": {
            "type": "string"
          },
          "total_engagement": {
            "type": "integer"
          },
          "post_count": {
            "type": "integer"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}
