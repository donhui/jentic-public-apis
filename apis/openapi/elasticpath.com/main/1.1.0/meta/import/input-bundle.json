{
  "openapi": "3.0.3",
  "info": {
    "title": "EPCC-Kount Risk Evaluation API",
    "version": "1.1.0",
    "description": "Risk evaluation endpoint for eCommerce checkout flow.\nThis API evaluates fraud risk for a cart before checkout using Kount's fraud detection services.\n",
    "x-jentic-source-url": "https://developer.elasticpath.com/assets/files/risk-evaluation-api-457c777e23d1eb1f86422cf361493961.yaml"
  },
  "servers": [
    {
      "url": "https://hooks.{region}.elasticpathintegrations.com",
      "description": "Prismatic webhook endpoint (region-specific)",
      "variables": {
        "region": {
          "default": "us-east-2",
          "description": "Region where your Integrations Hub instance is deployed",
          "enum": [
            "us-east-2",
            "eu-west-1"
          ]
        }
      }
    }
  ],
  "paths": {
    "/trigger/{flowId}": {
      "post": {
        "summary": "Evaluate Order Risk",
        "description": "Evaluates fraud risk for a cart before checkout using Kount fraud detection.",
        "parameters": [
          {
            "name": "flowId",
            "in": "path",
            "required": true,
            "description": "Base64-encoded flow configuration ID generated by Integrations Hub",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RiskEvaluationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Risk evaluation completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RiskEvaluationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Cart not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RiskEvaluationRequest": {
        "type": "object",
        "required": [
          "cartId",
          "orderNumber",
          "billingAddress",
          "userIp"
        ],
        "properties": {
          "cartId": {
            "type": "string",
            "description": "EPCC cart identifier"
          },
          "orderNumber": {
            "type": "string",
            "description": "Merchant-managed order number used as Kount merchant order ID"
          },
          "shippingAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "billingAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "deviceSessionId": {
            "type": "string",
            "nullable": true,
            "description": "Kount device session identifier"
          },
          "userIp": {
            "type": "string",
            "format": "ipv4",
            "description": "Customer IP address"
          },
          "customFields": {
            "type": "object",
            "additionalProperties": true,
            "description": "Optional merchant-specific data"
          },
          "riskInquiry": {
            "type": "boolean",
            "description": "Enable immediate risk inquiry evaluation"
          },
          "channelIdentifier": {
            "type": "string",
            "description": "Channel identifier for order classification"
          },
          "fulfillmentType": {
            "type": "string",
            "enum": [
              "SHIPPED",
              "DIGITAL",
              "STORE_PICK_UP"
            ],
            "description": "Fulfillment type for the order"
          }
        }
      },
      "RiskEvaluationResponse": {
        "type": "object",
        "required": [
          "decision",
          "score",
          "kountOrderId",
          "correlationId",
          "processingTimeMs"
        ],
        "properties": {
          "decision": {
            "type": "string",
            "enum": [
              "APPROVE",
              "DECLINE",
              "REVIEW"
            ],
            "description": "Risk assessment decision"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Risk score (higher = safer)"
          },
          "kountOrderId": {
            "type": "string",
            "description": "Kount order identifier for tracking"
          },
          "correlationId": {
            "type": "string",
            "format": "uuid",
            "description": "Request correlation identifier"
          },
          "processingTimeMs": {
            "type": "integer",
            "description": "Processing time in milliseconds"
          },
          "fallback": {
            "type": "boolean",
            "description": "Indicates if this was a fallback decision"
          },
          "fallbackReason": {
            "type": "string",
            "description": "Reason for fallback decision"
          }
        }
      },
      "Address": {
        "type": "object",
        "required": [
          "firstName",
          "lastName",
          "line1",
          "city",
          "region",
          "postalCode",
          "countryCode"
        ],
        "properties": {
          "firstName": {
            "type": "string",
            "maxLength": 50
          },
          "lastName": {
            "type": "string",
            "maxLength": 50
          },
          "company": {
            "type": "string",
            "maxLength": 100
          },
          "line1": {
            "type": "string",
            "maxLength": 100
          },
          "line2": {
            "type": "string",
            "maxLength": 100
          },
          "city": {
            "type": "string",
            "maxLength": 50
          },
          "region": {
            "type": "string",
            "maxLength": 10
          },
          "postalCode": {
            "type": "string",
            "maxLength": 20
          },
          "countryCode": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          },
          "phoneNumber": {
            "type": "string",
            "maxLength": 20
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "code",
              "message",
              "correlationId",
              "timestamp"
            ],
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "VALIDATION_ERROR",
                  "CART_NOT_FOUND",
                  "KOUNT_API_ERROR",
                  "EPCC_API_ERROR",
                  "NETWORK_ERROR",
                  "INTERNAL_ERROR",
                  "RATE_LIMIT_EXCEEDED"
                ]
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "string"
              },
              "correlationId": {
                "type": "string",
                "format": "uuid"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      }
    }
  }
}