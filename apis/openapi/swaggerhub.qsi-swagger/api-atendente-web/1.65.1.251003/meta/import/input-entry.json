                  "force": {
                    "type": "boolean",
                    "description": "Forçar logout mesmo com atendimento em andamento",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout realizado com sucesso",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Status da mesa após logout"
                }
              }
            }
          }
        },
        "operationId": "post-logout"
      }
    },
