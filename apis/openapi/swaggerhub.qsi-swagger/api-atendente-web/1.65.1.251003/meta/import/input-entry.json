  "paths": {
    "/token": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Gerar token de acesso",
        "security": [
          {
            "BasicAuth": []
          }
        ],
        "description": "Gera token JWT para autenticação nos demais endpoints",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/LoginPassword"
                  },
                  {
                    "$ref": "#/components/schemas/LoginPanelCode"
                  },
                  {
                    "$ref": "#/components/schemas/LoginTotemCode"
                  },
                  {
                    "$ref": "#/components/schemas/LoginSchedulingCode"
                  },
                  {
                    "$ref": "#/components/schemas/RefreshToken"
                  }
                ]
              },
              "examples": {
                "password": {
                  "summary": "Login com usuário e senha",
                  "value": {
                    "grant_type": "password",
                    "username": "SEU_USERNAME",
                    "password": "SUA_PASSWORD"
                  }
                },
                "panel_code": {
                  "summary": "Login com código do painel",
                  "value": {
                    "grant_type": "panel_code",
                    "code": "PAINEL001"
                  }
                },
                "refresh_token": {
                  "summary": "Renovar token",
                  "value": {
                    "grant_type": "refresh_token",
                    "refresh_token": "eyJhbGciOiJIUzI1NiJ9..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token gerado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "operationId": "post-token"
      }
    },
    "/me": {
      "get": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Informações do usuário logado",
        "description": "Retorna as informações da entidade logada (atendente, painel ou totem)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Informações da entidade logada",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/UsuarioInfo"
                    },
                    {
                      "$ref": "#/components/schemas/PainelInfo"
                    },
                    {
                      "$ref": "#/components/schemas/TotemInfo"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Token inválido ou expirado"
          }
        },
        "operationId": "get-me"
      }
    },
    "/associar-mesa": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Associar mesa ao atendente",
        "description": "Associa uma mesa específica ao atendente logado",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "branch",
                  "codigoMesa"
                ],
                "properties": {
                  "branch": {
                    "type": "string",
                    "description": "ID da unidade",
                    "example": "17"
                  },
                  "codigoMesa": {
                    "type": "string",
                    "description": "Código da mesa",
                    "example": "001"
                  },
                  "atendenteTablet": {
                    "type": "boolean",
                    "description": "Indica se é acesso via tablet",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mesa associada com sucesso"
          },
          "400": {
            "description": "Dados inválidos para associação"
          },
          "409": {
            "description": "Mesa já está em uso"
          }
        },
        "operationId": "post-associar-mesa"
      }
    },
    "/logout": {
      "post": {
