        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtido através do endpoint POST /v1/token."
      },
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Autenticação com username, password, client_id e secret_id"
      }
    },
    "schemas": {
      "LoginPassword": {
        "type": "object",
        "required": [
          "grant_type",
          "username",
          "password"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "password"
            ],
            "example": "password"
          },
          "username": {
            "type": "string",
            "description": "Login do usuário",
            "example": "SEU_USERNAME"
          },
          "password": {
            "type": "string",
            "description": "Senha do usuário",
            "example": "SUA_PASSWORD"
          }
        }
      },
      "LoginPanelCode": {
        "type": "object",
        "required": [
          "grant_type",
          "code"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "panel_code"
            ]
          },
          "code": {
            "type": "string",
            "description": "Código do painel",
            "example": "PAINEL001"
          }
        }
      },
      "LoginTotemCode": {
        "type": "object",
        "required": [
          "grant_type",
          "code"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "totem_code"
            ]
          },
          "code": {
            "type": "string",
            "description": "Código do totem",
            "example": "TOTEM001"
          }
        }
      },
      "LoginSchedulingCode": {
        "type": "object",
        "required": [
          "grant_type",
          "client_id"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "scheduling_code"
            ]
          },
          "client_id": {
            "type": "string",
            "description": "ID do cliente para agendamento",
            "example": "agendamento_client"
          }
        }
      },
      "RefreshToken": {
        "type": "object",
        "required": [
          "grant_type",
          "refresh_token"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "refresh_token"
            ]
          },
          "refresh_token": {
            "type": "string",
            "description": "Token de refresh",
            "example": "eyJhbGciOiJIUzI1NiJ9..."
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Token de acesso JWT",
            "example": "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
          },
          "refresh_token": {
            "type": "string",
            "description": "Token para renovação",
            "example": "eyJhbGciOiJIUzI1NiJ9.refresh_content.signature"
          },
          "token_type": {
            "type": "string",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "description": "Tempo de expiração em segundos",
            "example": 3600
          }
        }
      },
      "UsuarioInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID do usuário"
          },
          "nome": {
            "type": "string",
            "description": "Nome do atendente",
            "example": "João Silva"
          },
          "login": {
            "type": "string",
            "description": "Login do usuário",
            "example": "joao.silva"
          },
          "mesa": {
            "$ref": "#/components/schemas/Mesa"
          },
          "unidade": {
            "$ref": "#/components/schemas/Unidade"
          }
        }
      },
      "PainelInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "nome": {
            "type": "string",
            "description": "Nome do painel"
          },
          "codigo": {
            "type": "string",
            "description": "Código do painel"
          }
        }
      },
      "TotemInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "nome": {
            "type": "string",
            "description": "Nome do totem"
          },
          "codigo": {
            "type": "string",
            "description": "Código do totem"
          }
        }
      },
      "Mesa": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "numero": {
            "type": "string",
            "description": "Número da mesa"
          },
          "status": {
            "type": "string",
            "description": "Status atual da mesa",
            "enum": [
              "ABERTA",
              "FECHADA",
              "INTERVALO"
            ]
          }
        }
      },
      "Unidade": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID da unidade",
            "example": 17
          },
          "nome": {
            "type": "string",
            "description": "Nome da unidade",
            "example": "Agência Centro"
          },
          "endereco": {
            "type": "string",
            "description": "Endereço da unidade"
          }
        }
      },
      "Servico": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID do serviço",
            "example": 490
          },
          "descricao": {
            "type": "string",
            "description": "Descrição completa do serviço",
            "example": "Alteração de titularidade"
          },
          "descricaoResumida": {
            "type": "string",
            "description": "Descrição resumida",
            "example": "Alt. titularidade"
          },
          "codigo": {
            "type": "string",
            "description": "Código do serviço",
            "example": "AT001"
          },
          "permitirCriarNovaAtividade": {
            "type": "boolean",
            "description": "Permite criar nova atividade"
          }
        }
      },
      "ServicoResponse": {
        "type": "object",
        "properties": {
          "isOk": {
            "type": "string",
            "description": "Status da operação",
            "example": "true"
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID do serviço"
          },
          "tempoMaximo": {
            "type": "string",
            "description": "Tempo máximo formatado",
            "example": "00:15:00"
          },
          "tempoMaximoInt": {
            "type": "integer",
            "description": "Tempo máximo em minutos",
            "example": 15
          },
          "tempoAtendimento": {
            "type": "integer",
            "description": "Tempo de atendimento em minutos",
            "example": 10
          }
        }
      },
      "Categoria": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID da categoria"
          },
          "descricao": {
            "type": "string",
            "description": "Descrição da categoria"
          },
          "servicos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Servico"
            }
          }
        }
      },
      "TipoAtendimento": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID do tipo de atendimento"
          },
          "descricao": {
            "type": "string",
            "description": "Descrição do tipo",
            "example": "Normal"
          },
          "cor": {
            "type": "string",
            "description": "Cor associada",
            "example": "#00FF00"
          }
        }
      },
      "TipoEmissao": {
        "type": "object",
        "properties": {
          "idServico": {
            "type": "integer",
            "format": "int64",
            "description": "ID do serviço"
          },
          "idPrioridade": {
            "type": "integer",
            "format": "int64",
            "description": "ID da prioridade"
          },
          "prefixo": {
            "type": "string",
            "description": "Prefixo da senha",
            "example": "N"
          },
          "cor": {
            "type": "string",
            "description": "Cor da categoria",
            "example": "#0066CC"
          }
        }
      },
      "Cliente": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID do cliente"
          },
          "nome": {
            "type": "string",
            "description": "Nome do cliente",
            "example": "Maria Santos"
          },
          "numero": {
            "type": "string",
            "description": "Número de identificação",
            "example": "12345678901"
          },
          "telefone": {
            "type": "string",
            "description": "Telefone do cliente",
            "example": "(11) 99999-9999"
          },
          "email": {
            "type": "string",
            "description": "Email do cliente",
            "example": "maria@email.com"
          }
        }
      },
      "ClienteInput": {
        "type": "object",
        "required": [
          "numero",
          "nome"
        ],
        "properties": {
          "numero": {
            "type": "string",
            "description": "Número de identificação"
          },
          "nome": {
            "type": "string",
            "description": "Nome do cliente"
          },
          "telefone": {
            "type": "string",
            "description": "Telefone do cliente"
          },
          "email": {
            "type": "string",
            "description": "Email do cliente"
          }
        }
      },
      "SenhaEspera": {
        "type": "object",
        "properties": {
          "numeroSenha": {
            "type": "string",
            "description": "Número da senha",
            "example": "N001"
          },
          "servico": {
            "type": "string",
            "description": "Nome do serviço"
          },
          "prioridade": {
            "type": "string",
            "description": "Tipo de prioridade"
          },
          "tempoEspera": {
            "type": "string",
            "description": "Tempo de espera formatado",
            "example": "00:15:30"
          },
          "cliente": {
            "type": "string",
            "description": "Nome do cliente"
          }
        }
      },
      "EstatisticaAtendente": {
        "type": "object",
        "properties": {
          "qtdAtendimentosDia": {
            "type": "integer",
            "description": "Quantidade de atendimentos no dia"
          },
          "qtdAtendimentosSemana": {
            "type": "integer",
            "description": "Quantidade de atendimentos na semana"
          },
          "qtdAtendimentosMes": {
            "type": "integer",
            "description": "Quantidade de atendimentos no mês"
          },
          "tmaDiaAtendente": {
            "type": "string",
            "description": "Tempo médio de atendimento do dia",
            "example": "00:12:30"
          },
          "tmeDiaLoja": {
            "type": "string",
            "description": "Tempo médio de espera da loja",
            "example": "00:08:15"
          }
        }
      },
      "ConfigAttendance": {
        "type": "object",
        "properties": {
          "proximoAutomatico": {
            "type": "boolean",
            "description": "Próximo atendimento automático"
          },
          "utilizarOpine": {
            "type": "boolean",
            "description": "Utilizar sistema de avaliação"
          },
          "gravarAtendimento": {
            "type": "boolean",
            "description": "Gravar atendimentos"
          },
          "clienteObrigatorio": {
            "type": "string",
            "description": "Configuração de dados obrigatórios do cliente",
            "enum": [
              "NAO",
              "TODOS",
              "NUMERO_NOME",
              "NUMERO_NOME_TELEFONE",
              "NUMERO_NOME_TELEFONE_EMAIL",
              "NUMERO_NOME_TELEFONE_IDENTIFICADOR"
            ]
          }
        }
      },
      "AtendimentoInfoDto": {
        "type": "object",
        "description": "Informações detalhadas do atendimento",
        "properties": {
          "idSenha": {
            "type": "integer",
            "format": "int64",
            "description": "ID da senha do atendimento",
            "example": 12345
          },
          "statusSenha": {
            "type": "integer",
            "format": "int64",
            "description": "Status numérico da senha",
            "example": 4
          },
          "statusSenhaFormatado": {
            "type": "string",
            "description": "Status da senha formatado",
            "example": "Finalizado"
          },
          "idAgencia": {
            "type": "integer",
            "format": "int64",
            "description": "ID da agência/unidade",
            "example": 17
          },
          "nomeSubsidiaria": {
            "type": "string",
            "description": "Nome da subsidiária",
            "example": "ENERGISA SERGIPE"
          },
          "permiteVideoAtendimento": {
            "type": "boolean",
            "description": "Indica se o atendimento permite videoAtendimento baseado no serviço mais antigo",
            "example": true
          },
          "servicos": {
            "type": "array",
            "description": "Lista de serviços executados no atendimento (ordenados por data de início)",
            "items": {
              "$ref": "#/components/schemas/ServicoInfoDto"
            }
          }
        }
      },
      "ServicoInfoDto": {
        "type": "object",
        "description": "Informações resumidas do serviço",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID do serviço",
            "example": 490
          },
          "nome": {
            "type": "string",
            "description": "Nome/descrição resumida do serviço",
            "example": "Alteração de titularidade"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Tipo do erro",
            "example": "access_denied"
          },
          "error_description": {
            "type": "string",
            "description": "Descrição detalhada do erro",
            "example": "Usuário ou senha incorreto!"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp do erro"
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Autenticação",
      "description": "Endpoints para autenticação e autorização"
    },
    {
      "name": "Atendimento",
      "description": "Endpoints relacionados aos atendimentos"
    },
    {
      "name": "Atendente",
      "description": "Endpoints relacionados aos atendentes"
    }
  ]
}