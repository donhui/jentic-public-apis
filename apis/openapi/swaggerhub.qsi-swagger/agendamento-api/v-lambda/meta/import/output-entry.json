{
  "openapi": "3.0.1",
  "info": {
    "title": "AgendamentoAPI",
    "description": "Documentação da API para o agendamento do sistema Attendance",
    "version": "v-lambda",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/QSI_SWAGGER/agendamento-api/v-lambda/swagger.json"
  },
  "servers": [
    {
      "url": "https://00quby2xbh.execute-api.us-east-1.amazonaws.com/dev/agendamento"
    }
  ],
  "paths": {
    "/gerar-token": {
      "post": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Gerar token de acesso",
        "description": "Gera um token de acesso utilizando um usuário válido do sistema \n\n O token de acesso é válido para o dia no qual o mesmo foi gerado.",
        "requestBody": {
          "$ref": "#/components/requestBodies/DadosLogin"
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Token de acesso",
                  "example": "$2a$12$eWzBtjJYvZXgvAS.6a2Kae283AvGsAsAo4UoZEBCyTBcI6YFLddpO"
                }
              }
            }
          },
          "401": {
            "description": "Acesso não autorizado"
          }
        }
      }
    },
    "/listarServicosAgendamento": {
      "get": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Listar serviços disponíveis",
        "description": "Lista os serviços disponíveis para agendamento",
        "parameters": [
          {
            "name": "nomeEmpresa",
            "in": "query",
            "description": "Nome da empresa(resumido) no cadastro de unidade",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "manam"
          },
          {
            "name": "idEmpresa",
            "in": "query",
            "description": "id da empresa no banco de dados",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "example": 5
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Servico"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Acesso não autorizado"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
