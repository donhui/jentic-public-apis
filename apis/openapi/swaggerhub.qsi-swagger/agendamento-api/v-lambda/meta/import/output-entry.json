  "components": {
    "schemas": {
      "DadosLogin": {
        "type": "object",
        "properties": {
          "usuario": {
            "type": "string",
            "description": "login do usuário",
            "example": "agendamento"
          },
          "senha": {
            "type": "string",
            "description": "senha do usuário",
            "example": "14785Ag"
          }
        }
      },
      "Exigencia": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Id da exigência",
            "format": "int64",
            "example": 1000
          },
          "codigo": {
            "type": "integer",
            "description": "Código da exigência",
            "format": "int32",
            "example": 10
          },
          "descricao": {
            "type": "string",
            "description": "Descrição da exigência",
            "example": "CPF"
          }
        }
      },
      "Servico": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Id do serviço",
            "format": "int64",
            "example": 1000
          },
          "descricao": {
            "type": "string",
            "description": "Descrição do serviço",
            "example": "Alteração de titularidade da conta de água/esgoto"
          },
          "descricaoResumida": {
            "type": "string",
            "description": "Descrição resumida do serviço",
            "example": "Troca de titularidade"
          },
          "codigo": {
            "type": "string",
            "description": "Código do serviço",
            "example": "AT499"
          },
          "permitirCriarNovaAtividade": {
            "type": "boolean",
            "description": "Campo utilizado pelo fluxo de atendimentos",
            "example": false
          },
          "exigencias": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Exigencia"
            }
          }
        }
      },
      "Unidade": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Id da unidade",
            "format": "int64",
            "example": 17
          },
          "nome": {
            "type": "string",
            "description": "Nome da unidade",
            "example": "PAC-Alvorada"
          },
          "endereco": {
            "type": "string",
            "description": "Endereço da unidade",
            "example": "Av. Desembargador João Machado, 4922 - Planalto - Manaus - AM CEP:  69029-520"
          }
        }
      },
      "Cliente": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Id do cliente",
            "format": "int64",
            "example": 418578
          },
          "nome": {
            "type": "string",
            "description": "Nome do cliente",
            "example": "João de Deus"
          },
          "codigo": {
            "type": "string",
            "description": "Código de identificação do cliente (Ex. CPF, B.I, Matrícula)",
            "example": "547815414"
          },
          "email": {
            "type": "string",
            "description": "E-mail do cliente",
            "example": "joao@email.com"
          },
          "telefone": {
            "type": "string",
            "description": "Telefone do cliente",
            "example": "(81) 95484-4545"
          },
          "observacao": {
            "type": "string",
            "description": "Observações relacionadas ao cliente",
            "example": "Problemas cardíacos"
          },
          "contrato": {
            "type": "string",
            "description": "Número do contrato do cliente na empresa",
            "example": "145487425-002"
          }
        }
      },
      "Agendamento": {
        "type": "object",
        "properties": {
          "idAgendamento": {
            "type": "integer",
            "description": "Id do agendamento",
            "format": "int64",
            "example": 37
          },
          "servico": {
            "$ref": "#/components/schemas/Servico"
          },
          "cliente": {
            "$ref": "#/components/schemas/Cliente"
          },
          "unidade": {
            "$ref": "#/components/schemas/Unidade"
          },
          "dataAgendamento": {
            "type": "integer",
            "description": "Valor numérico da data de agendamento referente a data universal (Date.getTime())",
            "format": "int64",
            "example": 1558666800000
          },
          "horaAgendamento": {
            "type": "integer",
            "description": "Valor numérico da hora de agendamento referente a data universal (Date.getTime())",
            "format": "int64",
            "example": 1558724400000
          },
          "numeroSenha": {
            "type": "string",
            "description": "Número da senha de atendimento",
            "example": "AG004"
          },
          "protocolo": {
            "type": "string",
            "description": "Número do protocolo do agendamento",
            "example": "20123456"
          },
          "statusAgendamento": {
            "type": "string",
            "description": "Status do agendamento",
            "example": "ATENDIDO",
            "enum": [
              "AGENDADO",
              "ATENDIDO",
              "CANCELADO",
              "EXPIRADO",
              "LIBERADO"
            ]
          },
          "dataEmissao": {
            "type": "integer",
            "description": "Valor numérico da data da criação do agendamento referente a data universal (Date().getTime())",
            "format": "int64",
            "example": 1558696595937
          },
          "dataHoraAgendamentoFormatada": {
            "type": "string",
            "description": "Data e hora do agendamento",
            "example": "24/05/2019 16:00:00"
          },
          "dataAgendamentoFormatada": {
            "type": "string",
            "description": "Data do agendamento",
            "example": "24/05/2019"
          },
          "horaAgendamentoFormatada": {
            "type": "string",
            "description": "Hora do agendamento",
            "example": "16:00:00"
          },
