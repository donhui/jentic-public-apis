    "/pesquisarAgendamentosCliente": {
      "get": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Pesquisar agendamento do cliente",
        "description": "Lista todos os agendamento do cliente\nA pesquisa pode ser feita pelos campos: \n\n\t -numero \n\n\t -contrato \n\n\t -telefone \n\n\t -nome \n\n\t -email \n\n\t -protocolo",
        "parameters": [
          {
            "name": "numero",
            "in": "query",
            "description": "Número de identificação do cliente",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "45579841"
          },
          {
            "name": "contrato",
            "in": "query",
            "description": "Contrato do cliente",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "542154-003"
          },
          {
            "name": "telefone",
            "in": "query",
            "description": "Telefone do cliente",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "(81) 94121-4545"
          },
          {
            "name": "nome",
            "in": "query",
            "description": "Nome do cliente",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "João de Deus"
          },
          {
            "name": "email",
            "in": "query",
            "description": "E-mail do cliente",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "joao@email.com"
          },
          {
            "name": "protocolo",
            "in": "query",
            "description": "Protocolo do agendamento",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "20123456"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Agendamento"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Acesso não autorizado"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/pesquisarAgendamentosAgendado": {
      "get": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Pesquisar agendamento agendados",
        "description": "Lista todos os agendamento agendados no período.\nCaso não seja informado o período serão listados os agendamentos agendados do dia atual.",
        "parameters": [
          {
            "name": "inicio",
            "in": "query",
            "description": "Data inicial do período no formato yyyy-MM-dd",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "2020-06-01"
          },
          {
            "name": "fim",
            "in": "query",
            "description": "Data final do período no formato yyyy-MM-dd",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "2020-06-30"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Agendamento"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Acesso não autorizado"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/listarGruposAgendamento": {
      "get": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Listar dias e horários disponíveis para agendamento",
        "description": "Lista os dias e horários disponíveis para agendamento conforme configuração realizada no sistema \n\n Na lista de dias há um lista de horarios informando a quantidade máxima de agendamentos para o horário, a quantidade de agendamentos já realizados para esse horário e a quantidade de agendamentos disponíveis para o horário",
        "parameters": [
          {
            "name": "idUnidade",
            "in": "query",
            "description": "Id da unidade",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "example": 17
          }
        ],
        "responses": {
