          {
            "name": "nomeEmpresa",
            "in": "query",
            "description": "Nome da empresa(resumido) no cadastro de unidade",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "manam"
          },
          {
            "name": "idEmpresa",
            "in": "query",
            "description": "id da empresa no banco de dados",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "example": 5
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Servico"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Acesso n\u00e3o autorizado"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
