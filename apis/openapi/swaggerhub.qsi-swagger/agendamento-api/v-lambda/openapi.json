    "/pesquisarAgendamentosCliente": {
      "get": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Pesquisar agendamento do cliente",
        "description": "Lista todos os agendamento do cliente\nA pesquisa pode ser feita pelos campos: \n\n\t -numero \n\n\t -contrato \n\n\t -telefone \n\n\t -nome \n\n\t -email \n\n\t -protocolo",
        "parameters": [
          {
            "name": "numero",
            "in": "query",
            "description": "N\u00famero de identifica\u00e7\u00e3o do cliente",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "45579841"
          },
          {
            "name": "contrato",
            "in": "query",
            "description": "Contrato do cliente",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "542154-003"
          },
          {
            "name": "telefone",
            "in": "query",
            "description": "Telefone do cliente",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "(81) 94121-4545"
          },
          {
            "name": "nome",
            "in": "query",
            "description": "Nome do cliente",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "Jo\u00e3o de Deus"
          },
          {
            "name": "email",
            "in": "query",
            "description": "E-mail do cliente",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "joao@email.com"
          },
          {
            "name": "protocolo",
            "in": "query",
            "description": "Protocolo do agendamento",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "20123456"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Agendamento"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Acesso n\u00e3o autorizado"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/pesquisarAgendamentosAgendado": {
      "get": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Pesquisar agendamento agendados",
        "description": "Lista todos os agendamento agendados no per\u00edodo.\nCaso n\u00e3o seja informado o per\u00edodo ser\u00e3o listados os agendamentos agendados do dia atual.",
        "parameters": [
          {
            "name": "inicio",
            "in": "query",
            "description": "Data inicial do per\u00edodo no formato yyyy-MM-dd",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "2020-06-01"
          },
          {
            "name": "fim",
            "in": "query",
            "description": "Data final do per\u00edodo no formato yyyy-MM-dd",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "2020-06-30"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Agendamento"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Acesso n\u00e3o autorizado"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/listarGruposAgendamento": {
      "get": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Listar dias e hor\u00e1rios dispon\u00edveis para agendamento",
        "description": "Lista os dias e hor\u00e1rios dispon\u00edveis para agendamento conforme configura\u00e7\u00e3o realizada no sistema \n\n Na lista de dias h\u00e1 um lista de horarios informando a quantidade m\u00e1xima de agendamentos para o hor\u00e1rio, a quantidade de agendamentos j\u00e1 realizados para esse hor\u00e1rio e a quantidade de agendamentos dispon\u00edveis para o hor\u00e1rio",
        "parameters": [
          {
            "name": "idUnidade",
            "in": "query",
            "description": "Id da unidade",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "example": 17
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GrupoAgendamento"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Acesso n\u00e3o autorizado"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
