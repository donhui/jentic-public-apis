  "paths": {
    "/gerar-token": {
      "post": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Gerar token de acesso",
        "description": "Gera um token de acesso utilizando um usu\u00e1rio v\u00e1lido do sistema \n\n O token de acesso \u00e9 v\u00e1lido para o dia no qual o mesmo foi gerado.",
        "requestBody": {
          "$ref": "#/components/requestBodies/DadosLogin"
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Token de acesso",
                  "example": "$2a$12$eWzBtjJYvZXgvAS.6a2Kae283AvGsAsAo4UoZEBCyTBcI6YFLddpO"
                }
              }
            }
          },
          "401": {
            "description": "Acesso n\u00e3o autorizado"
          }
        }
      }
    },
    "/listarServicosAgendamento": {
      "get": {
        "tags": [
          "Agendamento"
        ],
        "summary": "Listar servi\u00e7os dispon\u00edveis",
