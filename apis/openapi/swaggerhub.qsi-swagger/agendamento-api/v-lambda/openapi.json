  "components": {
    "schemas": {
      "DadosLogin": {
        "type": "object",
        "properties": {
          "usuario": {
            "type": "string",
            "description": "login do usu\u00e1rio",
            "example": "agendamento"
          },
          "senha": {
            "type": "string",
            "description": "senha do usu\u00e1rio",
            "example": "14785Ag"
          }
        }
      },
      "Exigencia": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Id da exig\u00eancia",
            "format": "int64",
            "example": 1000
          },
          "codigo": {
            "type": "integer",
            "description": "C\u00f3digo da exig\u00eancia",
            "format": "int32",
            "example": 10
          },
          "descricao": {
            "type": "string",
            "description": "Descri\u00e7\u00e3o da exig\u00eancia",
            "example": "CPF"
          }
        }
      },
      "Servico": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Id do servi\u00e7o",
            "format": "int64",
            "example": 1000
          },
          "descricao": {
            "type": "string",
            "description": "Descri\u00e7\u00e3o do servi\u00e7o",
            "example": "Altera\u00e7\u00e3o de titularidade da conta de \u00e1gua/esgoto"
          },
          "descricaoResumida": {
            "type": "string",
            "description": "Descri\u00e7\u00e3o resumida do servi\u00e7o",
            "example": "Troca de titularidade"
          },
          "codigo": {
            "type": "string",
            "description": "C\u00f3digo do servi\u00e7o",
            "example": "AT499"
          },
          "permitirCriarNovaAtividade": {
            "type": "boolean",
            "description": "Campo utilizado pelo fluxo de atendimentos",
            "example": false
          },
          "exigencias": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Exigencia"
            }
          }
        }
      },
      "Unidade": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Id da unidade",
            "format": "int64",
            "example": 17
          },
          "nome": {
            "type": "string",
            "description": "Nome da unidade",
            "example": "PAC-Alvorada"
          },
          "endereco": {
            "type": "string",
            "description": "Endere\u00e7o da unidade",
            "example": "Av. Desembargador Jo\u00e3o Machado, 4922 - Planalto - Manaus - AM CEP:  69029-520"
          }
        }
      },
      "Cliente": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Id do cliente",
            "format": "int64",
            "example": 418578
          },
          "nome": {
            "type": "string",
            "description": "Nome do cliente",
            "example": "Jo\u00e3o de Deus"
          },
          "codigo": {
            "type": "string",
            "description": "C\u00f3digo de identifica\u00e7\u00e3o do cliente (Ex. CPF, B.I, Matr\u00edcula)",
            "example": "547815414"
          },
          "email": {
            "type": "string",
            "description": "E-mail do cliente",
            "example": "joao@email.com"
          },
          "telefone": {
            "type": "string",
            "description": "Telefone do cliente",
            "example": "(81) 95484-4545"
          },
          "observacao": {
            "type": "string",
            "description": "Observa\u00e7\u00f5es relacionadas ao cliente",
            "example": "Problemas card\u00edacos"
          },
          "contrato": {
            "type": "string",
            "description": "N\u00famero do contrato do cliente na empresa",
            "example": "145487425-002"
          }
        }
      },
      "Agendamento": {
        "type": "object",
        "properties": {
          "idAgendamento": {
            "type": "integer",
            "description": "Id do agendamento",
            "format": "int64",
            "example": 37
          },
          "servico": {
            "$ref": "#/components/schemas/Servico"
          },
          "cliente": {
            "$ref": "#/components/schemas/Cliente"
          },
          "unidade": {
            "$ref": "#/components/schemas/Unidade"
          },
          "dataAgendamento": {
            "type": "integer",
            "description": "Valor num\u00e9rico da data de agendamento referente a data universal (Date.getTime())",
            "format": "int64",
            "example": 1558666800000
          },
          "horaAgendamento": {
