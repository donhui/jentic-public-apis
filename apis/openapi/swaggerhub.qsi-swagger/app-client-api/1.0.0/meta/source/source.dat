{
  "openapi": "3.0.0",
  "servers": [
    {
      "url": "https://ryp3x2nx4g.execute-api.us-east-1.amazonaws.com/prod/api/"
    }
  ],
  "info": {
    "version": "1.0.0",
    "title": "API do App client do Attendance",
    "description": "Documenta\u00e7\u00e3o da API para o App do cliente do sistema Attendance",
    "contact": {
      "email": "suporte@qsintelligence.com.br"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/QSI_SWAGGER/app-client-api/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "AppClientAttendanceAPI",
      "description": "Servi\u00e7os dispon\u00edveis para o App do cliente do sistema Attendance"
    }
  ],
  "paths": {
    "/recuperar-atendimento": {
      "get": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Recuperar um atendimento do sistema Attendance",
        "description": "Recupera o atendimento no sistema Attendance baseado no token Bearer JWT \ninformado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Atendimento recuperado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DadosAtendimento"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Requisi\u00e7\u00e3o inv\u00e1lida"
          },
          "403": {
            "description": "Token inv\u00e1lido ou expirado"
          },
          "404": {
            "description": "Cliente n\u00e3o encontrado"
          }
        }
      }
    },
    "/reativar-atendimento": {
      "post": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Reativa um atendimento no sistema Attendance",
        "description": "Reativa o atendimento no sistema Attendance colocando-o novamente em espera.\nO atendimento \u00e9 recuperado baseado no token Bearer JWT informado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Atendimento reativado com sucesso"
          },
          "400": {
            "description": "Requisi\u00e7\u00e3o inv\u00e1lida"
          },
          "403": {
            "description": "Token inv\u00e1lido/expirado ou atendimento expirado"
          },
          "404": {
            "description": "Cliente n\u00e3o encontrado"
          }
        }
      }
    },
    "/get-numero-whatsapp": {
      "get": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Recuperar o n\u00famero do whatsapp da unidade",
        "description": "Recupera o n\u00famero do whatsapp da unidade do atendimento no sistema Attendance.\nO atendimento \u00e9 recuperado baseado no token Bearer JWT informado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "N\u00famero do whatsapp recuperado com sucesso",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "+5581999999999"
                }
              }
            }
          },
          "400": {
            "description": "Requisi\u00e7\u00e3o inv\u00e1lida"
          },
          "403": {
            "description": "Token inv\u00e1lido ou expirado"
          },
          "404": {
            "description": "Cliente n\u00e3o encontrado"
          }
        }
      }
    },
    "/confirmar-atendimento-whatsapp": {
      "post": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Confirma o atendimento pelo whatsapp",
        "description": "Finaliza o atendimento, colocando sua origem como 'WHATSAPP', identificando que o mesmo\nfoi/ser\u00e1 atendido por um atendente via Whatsapp.\nO atendimento \u00e9 recuperado baseado no token Bearer JWT informado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Atendimento enviado para o whatsapp com sucesso"
          },
          "400": {
            "description": "Requisi\u00e7\u00e3o inv\u00e1lida"
          },
          "403": {
            "description": "Token inv\u00e1lido/expirado ou atendimento expirado"
          },
          "404": {
            "description": "Cliente n\u00e3o encontrado"
          }
        }
      }
    },
    "/recuperar-link-pesquisa": {
      "get": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Recuperar o link da pesquisa da unidade",
        "description": "Recupera o link da pesquisa da unidade do atendimento no sistema Attendance.\nO atendimento \u00e9 recuperado baseado no token Bearer JWT informado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Link da pesquisa do atendimento",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "http://pesquisa.atendimento.ai/ncdjksr"
                }
              }
            }
          },
          "400": {
            "description": "Requisi\u00e7\u00e3o inv\u00e1lida"
          },
          "403": {
            "description": "Token inv\u00e1lido ou expirado"
          },
          "404": {
            "description": "Cliente n\u00e3o encontrado"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "DadosAtendimento": {
        "type": "object",
        "properties": {
          "expirado": {
            "type": "boolean",
            "description": "Atendimento expirado",
            "example": true
          },
          "numeroSenha": {
            "type": "string",
            "description": "N\u00famero da senha",
            "example": "N025"
          },
          "previsao": {
            "type": "string",
            "description": "Previs\u00e3o de atendimento (HH:mm)",
            "example": "00:30"
          },
          "dataEmissao": {
            "type": "string",
            "description": "Data de emiss\u00e3o do atendimento (HH:mm)",
            "example": "09:30"
          },
          "dataInicio": {
            "type": "string",
            "description": "Data de in\u00edcio do atendimento (HH:mm)",
            "example": "09:31"
          },
          "dataFinal": {
            "type": "string",
            "description": "Data de finaliza\u00e7\u00e3o do atendimento (HH:mm)",
            "example": "10:30"
          },
          "tempoEspera": {
            "type": "string",
            "description": "Tempo de espera do atendimento (HH:mm)",
            "example": "10:05"
          },
          "tempoAtendimento": {
            "type": "string",
            "description": "Tempo de dura\u00e7\u00e3o do atendimento (HH:mm)",
            "example": "45:30"
          },
          "prioridade": {
            "type": "string",
            "description": "Prioridade do atendimento",
            "example": "Normal"
          },
          "statusAtendimento": {
            "type": "string",
            "description": "Status do atendimento",
            "example": "EM_ESPERA",
            "enum": [
              "EM_ESPERA",
              "EM_ATENDIMENTO",
              "ENCERRADO",
              "CANCELADO",
              "PRE_ATENDIDO",
              "RESERVADO",
              "AGENDADO",
              "FORA_DE_ORDEM",
              "CONGELADO",
              "DESCONGELADO",
              "TRANSFERIDO",
              "TRANSFERIDO_FILA"
            ]
          },
          "protocolo": {
            "type": "string",
            "description": "Protocolo do atendimento",
            "example": "20230154814"
          },
          "nomeAtendente": {
            "type": "string",
            "description": "Nome do atendente",
            "example": "Jos\u00e9 Luiz"
          },
          "servicoDescricao": {
            "type": "string",
            "description": "Descri\u00e7\u00e3o do servi\u00e7o atual do atendimento",
            "example": "2\u00ba via de conta"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}