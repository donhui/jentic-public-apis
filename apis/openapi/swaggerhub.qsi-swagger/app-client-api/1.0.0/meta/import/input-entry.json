{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "API do App client do Attendance",
    "description": "Documentação da API para o App do cliente do sistema Attendance",
    "contact": {
      "email": "suporte@qsintelligence.com.br"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/QSI_SWAGGER/app-client-api/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://ryp3x2nx4g.execute-api.us-east-1.amazonaws.com/prod/api/"
    }
  ],
  "paths": {
    "/recuperar-atendimento": {
      "get": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Recuperar um atendimento do sistema Attendance",
        "description": "Recupera o atendimento no sistema Attendance baseado no token Bearer JWT \ninformado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Atendimento recuperado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DadosAtendimento"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Requisição inválida"
          },
          "403": {
            "description": "Token inválido ou expirado"
          },
          "404": {
            "description": "Cliente não encontrado"
          }
        }
      }
    },
    "/reativar-atendimento": {
      "post": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Reativa um atendimento no sistema Attendance",
        "description": "Reativa o atendimento no sistema Attendance colocando-o novamente em espera.\nO atendimento é recuperado baseado no token Bearer JWT informado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Atendimento reativado com sucesso"
          },
          "400": {
            "description": "Requisição inválida"
          },
          "403": {
            "description": "Token inválido/expirado ou atendimento expirado"
          },
          "404": {
            "description": "Cliente não encontrado"
          }
        }
      }
    },
    "/get-numero-whatsapp": {
      "get": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Recuperar o número do whatsapp da unidade",
        "description": "Recupera o número do whatsapp da unidade do atendimento no sistema Attendance.\nO atendimento é recuperado baseado no token Bearer JWT informado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Número do whatsapp recuperado com sucesso",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "+5581999999999"
                }
              }
            }
          },
          "400": {
            "description": "Requisição inválida"
          },
          "403": {
            "description": "Token inválido ou expirado"
          },
          "404": {
            "description": "Cliente não encontrado"
          }
        }
      }
    },
    "/confirmar-atendimento-whatsapp": {
      "post": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Confirma o atendimento pelo whatsapp",
        "description": "Finaliza o atendimento, colocando sua origem como 'WHATSAPP', identificando que o mesmo\nfoi/será atendido por um atendente via Whatsapp.\nO atendimento é recuperado baseado no token Bearer JWT informado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Atendimento enviado para o whatsapp com sucesso"
          },
          "400": {
            "description": "Requisição inválida"
          },
          "403": {
            "description": "Token inválido/expirado ou atendimento expirado"
          },
          "404": {
            "description": "Cliente não encontrado"
          }
        }
      }
    },
    "/recuperar-link-pesquisa": {
      "get": {
        "tags": [
          "AppClientAttendanceAPI"
        ],
        "summary": "Recuperar o link da pesquisa da unidade",
        "description": "Recupera o link da pesquisa da unidade do atendimento no sistema Attendance.\nO atendimento é recuperado baseado no token Bearer JWT informado no header \"Authorization\".\n",
        "responses": {
          "200": {
            "description": "Link da pesquisa do atendimento",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "http://pesquisa.atendimento.ai/ncdjksr"
                }
              }
            }
          },
          "400": {
            "description": "Requisição inválida"
          },
          "403": {
            "description": "Token inválido ou expirado"
          },
          "404": {
            "description": "Cliente não encontrado"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "DadosAtendimento": {
        "type": "object",
        "properties": {
          "expirado": {
            "type": "boolean",
            "description": "Atendimento expirado",
            "example": true
          },
          "numeroSenha": {
            "type": "string",
            "description": "Número da senha",
            "example": "N025"
          },
          "previsao": {
            "type": "string",
            "description": "Previsão de atendimento (HH:mm)",
            "example": "00:30"
          },
          "dataEmissao": {
            "type": "string",
            "description": "Data de emissão do atendimento (HH:mm)",
            "example": "09:30"
          },
          "dataInicio": {
            "type": "string",
            "description": "Data de início do atendimento (HH:mm)",
            "example": "09:31"
          },
          "dataFinal": {
            "type": "string",
            "description": "Data de finalização do atendimento (HH:mm)",
            "example": "10:30"
          },
          "tempoEspera": {
            "type": "string",
            "description": "Tempo de espera do atendimento (HH:mm)",
            "example": "10:05"
          },
          "tempoAtendimento": {
            "type": "string",
            "description": "Tempo de duração do atendimento (HH:mm)",
            "example": "45:30"
          },
          "prioridade": {
            "type": "string",
            "description": "Prioridade do atendimento",
            "example": "Normal"
          },
          "statusAtendimento": {
            "type": "string",
            "description": "Status do atendimento",
            "example": "EM_ESPERA",
            "enum": [
              "EM_ESPERA",
              "EM_ATENDIMENTO",
              "ENCERRADO",
              "CANCELADO",
              "PRE_ATENDIDO",
              "RESERVADO",
              "AGENDADO",
              "FORA_DE_ORDEM",
              "CONGELADO",
              "DESCONGELADO",
              "TRANSFERIDO",
              "TRANSFERIDO_FILA"
            ]
          },
          "protocolo": {
            "type": "string",
            "description": "Protocolo do atendimento",
            "example": "20230154814"
          },
          "nomeAtendente": {
            "type": "string",
            "description": "Nome do atendente",
            "example": "José Luiz"
          },
          "servicoDescricao": {
            "type": "string",
            "description": "Descrição do serviço atual do atendimento",
            "example": "2º via de conta"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "AppClientAttendanceAPI",
      "description": "Serviços disponíveis para o App do cliente do sistema Attendance"
    }
  ]
}