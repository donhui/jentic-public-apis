{
  "openapi": "3.0.3",
  "info": {
    "title": "Outlook Calendar",
    "description": "Microsoft Graph Calendar API - Manage calendars, events, and scheduling for users and groups via the Microsoft Graph REST API.",
    "version": "v1.0",
    "x-jentic-source-url": "https://learn.microsoft.com/en-us/graph/api/resources/calendar"
  },
  "servers": [
    {
      "url": "https://graph.microsoft.com/v1.0",
      "description": "Microsoft Graph v1.0"
    }
  ],
  "security": [
    {
      "oauth2": []
    },
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/me/calendars": {
      "get": {
        "operationId": "listCalendars",
        "summary": "List calendars",
        "description": "Get all the user's calendars.",
        "tags": ["Calendars"],
        "parameters": [
          {
            "$ref": "#/components/parameters/selectParam"
          },
          {
            "$ref": "#/components/parameters/filterParam"
          },
          {
            "$ref": "#/components/parameters/topParam"
          },
          {
            "$ref": "#/components/parameters/skipParam"
          }
        ],
        "responses": {
          "200": {
            "description": "A collection of calendars.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CalendarCollectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createCalendar",
        "summary": "Create calendar",
        "description": "Create a new calendar for the user.",
        "tags": ["Calendars"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Calendar"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created calendar.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Calendar"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/me/calendar": {
      "get": {
        "operationId": "getDefaultCalendar",
        "summary": "Get default calendar",
        "description": "Get the properties and relationships of the user's default calendar.",
        "tags": ["Calendars"],
        "parameters": [
          {
            "$ref": "#/components/parameters/selectParam"
          }
        ],
        "responses": {
          "200": {
            "description": "The calendar object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Calendar"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updateDefaultCalendar",
        "summary": "Update default calendar",
        "description": "Update the properties of the user's default calendar.",
        "tags": ["Calendars"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalendarUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated calendar.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Calendar"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/me/calendars/{calendarId}": {
      "get": {
        "operationId": "getCalendar",
        "summary": "Get calendar",
        "description": "Get the properties and relationships of a calendar object.",
        "tags": ["Calendars"],
        "parameters": [
          {
            "$ref": "#/components/parameters/calendarIdParam"
          },
          {
            "$ref": "#/components/parameters/selectParam"
          }
        ],
        "responses": {
          "200": {
            "description": "The calendar object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Calendar"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updateCalendar",
        "summary": "Update calendar",
        "description": "Update the properties of a calendar object.",
        "tags": ["Calendars"],
        "parameters": [
          {
            "$ref": "#/components/parameters/calendarIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalendarUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated calendar.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Calendar"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteCalendar",
        "summary": "Delete calendar",
        "description": "Delete a calendar other than the default calendar.",
        "tags": ["Calendars"],
        "parameters": [
          {
            "$ref": "#/components/parameters/calendarIdParam"
          }
        ],
        "responses": {
          "204": {
            "description": "No content."
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/me/calendar/events": {
      "get": {
        "operationId": "listCalendarEvents",
        "summary": "List events",
        "description": "Retrieve a list of events in the user's default calendar. The list contains single instance meetings and series masters.",
        "tags": ["Events"],
        "parameters": [
          {
            "$ref": "#/components/parameters/selectParam"
          },
          {
            "$ref": "#/components/parameters/filterParam"
          },
          {
            "$ref": "#/components/parameters/topParam"
          },
          {
            "$ref": "#/components/parameters/skipParam"
          },
          {
            "$ref": "#/components/parameters/orderbyParam"
          },
          {
            "name": "Prefer",
            "in": "header",
            "description": "Preferred timezone for start and end times in the response, e.g., outlook.timezone=\"Pacific Standard Time\".",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A collection of events.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventCollectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createEvent",
        "summary": "Create event",
        "description": "Create a new event in the user's default calendar.",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Event"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created event.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/me/calendars/{calendarId}/events": {
      "get": {
        "operationId": "listEventsInCalendar",
        "summary": "List events in a specific calendar",
        "description": "Retrieve a list of events in a specified calendar.",
        "tags": ["Events"],
        "parameters": [
          {
            "$ref": "#/components/parameters/calendarIdParam"
          },
          {
            "$ref": "#/components/parameters/selectParam"
          },
          {
            "$ref": "#/components/parameters/filterParam"
          },
          {
            "$ref": "#/components/parameters/topParam"
          },
          {
            "$ref": "#/components/parameters/skipParam"
          },
          {
            "$ref": "#/components/parameters/orderbyParam"
          }
        ],
        "responses": {
          "200": {
            "description": "A collection of events.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventCollectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createEventInCalendar",
        "summary": "Create event in a specific calendar",
        "description": "Create a new event in a specified calendar.",
        "tags": ["Events"],
        "parameters": [
          {
            "$ref": "#/components/parameters/calendarIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Event"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created event.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/me/calendar/calendarView": {
      "get": {
        "operationId": "listCalendarView",
        "summary": "List calendar view",
        "description": "Get the occurrences, exceptions, and single instances of events in a calendar view defined by a time range, from the user's default calendar.",
        "tags": ["CalendarView"],
        "parameters": [
          {
            "name": "startDateTime",
            "in": "query",
            "required": true,
            "description": "The start date and time of the time range, represented in ISO 8601 format.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDateTime",
            "in": "query",
            "required": true,
            "description": "The end date and time of the time range, represented in ISO 8601 format.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "$ref": "#/components/parameters/selectParam"
          },
          {
            "$ref": "#/components/parameters/filterParam"
          },
          {
            "$ref": "#/components/parameters/topParam"
          },
          {
            "$ref": "#/components/parameters/skipParam"
          },
          {
            "name": "Prefer",
            "in": "header",
            "description": "Preferred timezone for start and end times in the response.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A collection of events in the calendar view.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventCollectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/me/calendars/{calendarId}/calendarView": {
      "get": {
        "operationId": "listCalendarViewForCalendar",
        "summary": "List calendar view for a specific calendar",
        "description": "Get the occurrences, exceptions, and single instances of events in a calendar view defined by a time range, from a specified calendar.",
        "tags": ["CalendarView"],
        "parameters": [
          {
            "$ref": "#/components/parameters/calendarIdParam"
          },
          {
            "name": "startDateTime",
            "in": "query",
            "required": true,
            "description": "The start date and time of the time range, represented in ISO 8601 format.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDateTime",
            "in": "query",
            "required": true,
            "description": "The end date and time of the time range, represented in ISO 8601 format.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "$ref": "#/components/parameters/selectParam"
          },
          {
            "$ref": "#/components/parameters/filterParam"
          },
          {
            "$ref": "#/components/parameters/topParam"
          },
          {
            "$ref": "#/components/parameters/skipParam"
          }
        ],
        "responses": {
          "200": {
            "description": "A collection of events in the calendar view.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventCollectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/me/calendar/getSchedule": {
      "post": {
        "operationId": "getSchedule",
        "summary": "Get free/busy schedule",
        "description": "Get the free/busy availability information for a collection of users, distribution lists, or resources for a specified time period.",
        "tags": ["Schedule"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetScheduleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A collection of schedule information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleInformationCollectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authorization using Microsoft identity platform.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
            "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
            "scopes": {
              "Calendars.ReadBasic": "Read basic calendar information",
              "Calendars.Read": "Read user calendars",
              "Calendars.ReadWrite": "Read and write user calendars"
            }
          }
        }
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token authentication using a Microsoft identity platform access token."
      }
    },
    "parameters": {
      "calendarIdParam": {
        "name": "calendarId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the calendar.",
        "schema": {
          "type": "string"
        }
      },
      "selectParam": {
        "name": "$select",
        "in": "query",
        "required": false,
        "description": "Select specific properties to return.",
        "schema": {
          "type": "string"
        }
      },
      "filterParam": {
        "name": "$filter",
        "in": "query",
        "required": false,
        "description": "Filter the results.",
        "schema": {
          "type": "string"
        }
      },
      "topParam": {
        "name": "$top",
        "in": "query",
        "required": false,
        "description": "Limit the number of results.",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        }
      },
      "skipParam": {
        "name": "$skip",
        "in": "query",
        "required": false,
        "description": "Skip a number of results.",
        "schema": {
          "type": "integer"
        }
      },
      "orderbyParam": {
        "name": "$orderby",
        "in": "query",
        "required": false,
        "description": "Order the results.",
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request. The request was malformed or invalid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ODataError"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized. Authentication is required or the provided credentials are invalid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ODataError"
            }
          }
        }
      }
    },
    "schemas": {
      "Calendar": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true,
            "description": "The calendar's unique identifier."
          },
          "name": {
            "type": "string",
            "description": "The calendar name."
          },
          "color": {
            "type": "string",
            "description": "Color theme for the calendar.",
            "enum": ["auto", "lightBlue", "lightGreen", "lightOrange", "lightGray", "lightYellow", "lightTeal", "lightPink", "lightBrown", "lightRed", "maxColor"]
          },
          "hexColor": {
            "type": "string",
            "readOnly": true,
            "description": "The calendar color as a hex color code."
          },
          "isDefaultCalendar": {
            "type": "boolean",
            "description": "True if this is the default calendar."
          },
          "changeKey": {
            "type": "string",
            "readOnly": true,
            "description": "Identifies the version of the calendar object."
          },
          "canShare": {
            "type": "boolean",
            "readOnly": true,
            "description": "True if the user can share the calendar."
          },
          "canViewPrivateItems": {
            "type": "boolean",
            "readOnly": true,
            "description": "True if the user can read private items."
          },
          "canEdit": {
            "type": "boolean",
            "readOnly": true,
            "description": "True if the user can write to the calendar."
          },
          "allowedOnlineMeetingProviders": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["unknown", "skypeForBusiness", "skypeForConsumer", "teamsForBusiness"]
            },
            "description": "Online meeting providers for this calendar."
          },
          "defaultOnlineMeetingProvider": {
            "type": "string",
            "enum": ["unknown", "skypeForBusiness", "skypeForConsumer", "teamsForBusiness"],
            "description": "Default online meeting provider."
          },
          "isTallyingResponses": {
            "type": "boolean",
            "description": "Whether this calendar supports tracking meeting responses."
          },
          "isRemovable": {
            "type": "boolean",
            "readOnly": true,
            "description": "Whether this calendar can be deleted."
          },
          "owner": {
            "$ref": "#/components/schemas/EmailAddress"
          }
        }
      },
      "CalendarUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The calendar name."
          },
          "color": {
            "type": "string",
            "description": "Color theme for the calendar.",
            "enum": ["auto", "lightBlue", "lightGreen", "lightOrange", "lightGray", "lightYellow", "lightTeal", "lightPink", "lightBrown", "lightRed", "maxColor"]
          },
          "isDefaultCalendar": {
            "type": "boolean",
            "description": "True if this is the default calendar."
          }
        }
      },
      "CalendarCollectionResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string"
          },
          "@odata.nextLink": {
            "type": "string"
          },
          "value": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Calendar"
            }
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true,
            "description": "Unique identifier."
          },
          "subject": {
            "type": "string",
            "description": "The event subject."
          },
          "body": {
            "$ref": "#/components/schemas/ItemBody"
          },
          "bodyPreview": {
            "type": "string",
            "readOnly": true,
            "description": "Preview of the body content."
          },
          "start": {
            "$ref": "#/components/schemas/DateTimeTimeZone"
          },
          "end": {
            "$ref": "#/components/schemas/DateTimeTimeZone"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "locations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Location"
            }
          },
          "attendees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attendee"
            }
          },
          "organizer": {
            "$ref": "#/components/schemas/Recipient"
          },
          "isAllDay": {
            "type": "boolean",
            "description": "Whether the event is an all-day event."
          },
          "isCancelled": {
            "type": "boolean",
            "readOnly": true,
            "description": "Whether the event has been cancelled."
          },
          "isDraft": {
            "type": "boolean",
            "readOnly": true,
            "description": "Whether the event is a draft."
          },
          "isOnlineMeeting": {
            "type": "boolean",
            "description": "Whether the event is an online meeting."
          },
          "isOrganizer": {
            "type": "boolean",
            "readOnly": true,
            "description": "Whether the user is the organizer."
          },
          "isReminderOn": {
            "type": "boolean",
            "description": "Whether a reminder is set."
          },
          "onlineMeetingProvider": {
            "type": "string",
            "enum": ["unknown", "skypeForBusiness", "skypeForConsumer", "teamsForBusiness"],
            "description": "The online meeting provider."
          },
          "onlineMeeting": {
            "$ref": "#/components/schemas/OnlineMeetingInfo"
          },
          "onlineMeetingUrl": {
            "type": "string",
            "nullable": true,
            "description": "URL for an online meeting."
          },
          "recurrence": {
            "$ref": "#/components/schemas/PatternedRecurrence"
          },
          "reminderMinutesBeforeStart": {
            "type": "integer",
            "description": "Minutes before event to trigger reminder."
          },
          "responseRequested": {
            "type": "boolean",
            "description": "Whether the organizer wants responses."
          },
          "responseStatus": {
            "$ref": "#/components/schemas/ResponseStatus"
          },
          "sensitivity": {
            "type": "string",
            "enum": ["normal", "personal", "private", "confidential"]
          },
          "importance": {
            "type": "string",
            "enum": ["low", "normal", "high"]
          },
          "showAs": {
            "type": "string",
            "enum": ["free", "tentative", "busy", "oof", "workingElsewhere", "unknown"]
          },
          "type": {
            "type": "string",
            "readOnly": true,
            "enum": ["singleInstance", "occurrence", "exception", "seriesMaster"]
          },
          "seriesMasterId": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "iCalUId": {
            "type": "string",
            "readOnly": true,
            "description": "Unique identifier across calendars."
          },
          "transactionId": {
            "type": "string",
            "description": "Custom identifier for client deduplication."
          },
          "webLink": {
            "type": "string",
            "readOnly": true,
            "description": "URL to open the event in Outlook on the web."
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hasAttachments": {
            "type": "boolean",
            "readOnly": true
          },
          "hideAttendees": {
            "type": "boolean"
          },
          "allowNewTimeProposals": {
            "type": "boolean"
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "lastModifiedDateTime": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "changeKey": {
            "type": "string",
            "readOnly": true
          },
          "originalStartTimeZone": {
            "type": "string",
            "readOnly": true
          },
          "originalEndTimeZone": {
            "type": "string",
            "readOnly": true
          }
        }
      },
      "EventCollectionResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string"
          },
          "@odata.nextLink": {
            "type": "string"
          },
          "value": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          }
        }
      },
      "GetScheduleRequest": {
        "type": "object",
        "required": ["schedules", "startTime", "endTime"],
        "properties": {
          "schedules": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "A collection of SMTP addresses of users, distribution lists, or resources."
          },
          "startTime": {
            "$ref": "#/components/schemas/DateTimeTimeZone"
          },
          "endTime": {
            "$ref": "#/components/schemas/DateTimeTimeZone"
          },
          "availabilityViewInterval": {
            "type": "integer",
            "minimum": 5,
            "maximum": 1440,
            "default": 30,
            "description": "Duration of a time slot in minutes in the availability view."
          }
        }
      },
      "ScheduleInformation": {
        "type": "object",
        "properties": {
          "scheduleId": {
            "type": "string",
            "description": "SMTP address identifying a user, distribution list, or resource."
          },
          "availabilityView": {
            "type": "string",
            "description": "Merged view of availability. 0=free, 1=tentative, 2=busy, 3=oof."
          },
          "scheduleItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ScheduleItem"
            }
          },
          "workingHours": {
            "$ref": "#/components/schemas/WorkingHours"
          }
        }
      },
      "ScheduleInformationCollectionResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string"
          },
          "value": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ScheduleInformation"
            }
          }
        }
      },
      "ScheduleItem": {
        "type": "object",
        "properties": {
          "isPrivate": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": ["free", "tentative", "busy", "oof", "workingElsewhere", "unknown"]
          },
          "subject": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "start": {
            "$ref": "#/components/schemas/DateTimeTimeZone"
          },
          "end": {
            "$ref": "#/components/schemas/DateTimeTimeZone"
          }
        }
      },
      "WorkingHours": {
        "type": "object",
        "properties": {
          "daysOfWeek": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["sunday", "monday", "tuesday", "wednesday", "thursday", "friday", "saturday"]
            }
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "timeZone": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      },
      "DateTimeTimeZone": {
        "type": "object",
        "properties": {
          "dateTime": {
            "type": "string",
            "description": "Date and time in ISO 8601 format."
          },
          "timeZone": {
            "type": "string",
            "description": "Timezone identifier, e.g. 'Pacific Standard Time' or 'UTC'."
          }
        }
      },
      "ItemBody": {
        "type": "object",
        "properties": {
          "contentType": {
            "type": "string",
            "enum": ["text", "html"],
            "description": "The type of the content."
          },
          "content": {
            "type": "string",
            "description": "The content."
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "The name associated with the location."
          },
          "locationType": {
            "type": "string",
            "enum": ["default", "conferenceRoom", "homeAddress", "businessAddress", "geoCoordinates", "streetAddress", "hotel", "restaurant", "localBusiness", "postalAddress"]
          },
          "uniqueId": {
            "type": "string"
          },
          "uniqueIdType": {
            "type": "string",
            "enum": ["unknown", "locationStore", "directory", "private", "bing"]
          }
        }
      },
      "Attendee": {
        "type": "object",
        "properties": {
          "emailAddress": {
            "$ref": "#/components/schemas/EmailAddress"
          },
          "type": {
            "type": "string",
            "enum": ["required", "optional", "resource"],
            "description": "The attendee type."
          },
          "status": {
            "$ref": "#/components/schemas/ResponseStatus"
          }
        }
      },
      "Recipient": {
        "type": "object",
        "properties": {
          "emailAddress": {
            "$ref": "#/components/schemas/EmailAddress"
          }
        }
      },
      "EmailAddress": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The display name."
          },
          "address": {
            "type": "string",
            "description": "The email address."
          }
        }
      },
      "ResponseStatus": {
        "type": "object",
        "properties": {
          "response": {
            "type": "string",
            "enum": ["none", "organizer", "tentativelyAccepted", "accepted", "declined", "notResponded"]
          },
          "time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OnlineMeetingInfo": {
        "type": "object",
        "properties": {
          "joinUrl": {
            "type": "string",
            "description": "URL to join the online meeting."
          },
          "conferenceId": {
            "type": "string"
          },
          "tollNumber": {
            "type": "string"
          }
        }
      },
      "PatternedRecurrence": {
        "type": "object",
        "nullable": true,
        "properties": {
          "pattern": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["daily", "weekly", "absoluteMonthly", "relativeMonthly", "absoluteYearly", "relativeYearly"]
              },
              "interval": {
                "type": "integer"
              },
              "daysOfWeek": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "dayOfMonth": {
                "type": "integer"
              },
              "month": {
                "type": "integer"
              },
              "firstDayOfWeek": {
                "type": "string"
              },
              "index": {
                "type": "string",
                "enum": ["first", "second", "third", "fourth", "last"]
              }
            }
          },
          "range": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["endDate", "noEnd", "numbered"]
              },
              "startDate": {
                "type": "string",
                "format": "date"
              },
              "endDate": {
                "type": "string",
                "format": "date"
              },
              "numberOfOccurrences": {
                "type": "integer"
              },
              "recurrenceTimeZone": {
                "type": "string"
              }
            }
          }
        }
      },
      "ODataError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code."
              },
              "message": {
                "type": "string",
                "description": "Error message."
              },
              "innerError": {
                "type": "object",
                "properties": {
                  "request-id": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}