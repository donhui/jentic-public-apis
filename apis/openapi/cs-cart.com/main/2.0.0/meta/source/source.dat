  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic HTTP Authentication using admin email and API key"
      }
    },
    "parameters": {
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "default": 1 }
      },
      "ItemsPerPage": {
        "name": "items_per_page",
        "in": "query",
        "schema": { "type": "integer", "default": 10 }
      },
      "SortBy": {
        "name": "sort_by",
        "in": "query",
        "schema": { "type": "string" }
      },
      "SortOrder": {
        "name": "sort_order",
        "in": "query",
        "schema": { "type": "string", "enum": ["asc", "desc"] }
      },
      "ProductId": {
        "name": "product_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "CategoryId": {
        "name": "category_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "OrderId": {
        "name": "order_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "UserId": {
        "name": "user_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      }
    },
    "schemas": {
      "PaginationParams": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "items_per_page": { "type": "integer" },
          "total_items": { "type": "integer" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "product": { "type": "string" },
          "product_code": { "type": "string" },
          "price": { "type": "string" },
          "list_price": { "type": "string" },
          "amount": { "type": "integer" },
          "weight": { "type": "string" },
          "status": { "type": "string" },
          "category_ids": { "type": "array", "items": { "type": "integer" } },
          "main_category": { "type": "integer" },
          "full_description": { "type": "string" },
          "short_description": { "type": "string" },
          "company_id": { "type": "integer" }
        }
      },
      "ProductInput": {
        "type": "object",
        "properties": {
          "product": { "type": "string" },
          "product_code": { "type": "string" },
          "price": { "type": "string" },
          "list_price": { "type": "string" },
          "amount": { "type": "integer" },
          "weight": { "type": "string" },
          "status": { "type": "string", "enum": ["A", "D", "H"] },
          "category_ids": { "type": "array", "items": { "type": "integer" } },
          "main_category": { "type": "integer" },
          "full_description": { "type": "string" },
          "short_description": { "type": "string" }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "category_id": { "type": "string" },
          "category": { "type": "string" },
          "parent_id": { "type": "integer" },
          "status": { "type": "string" },
          "position": { "type": "integer" },
          "company_id": { "type": "integer" }
        }
      },
      "CategoryInput": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "parent_id": { "type": "integer" },
          "status": { "type": "string", "enum": ["A", "D", "H"] },
          "position": { "type": "integer" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "order_id": { "type": "string" },
          "user_id": { "type": "integer" },
          "status": { "type": "string" },
          "total": { "type": "string" },
          "subtotal": { "type": "string" },
          "timestamp": { "type": "integer" },
          "company_id": { "type": "integer" },
          "payment_id": { "type": "integer" },
          "shipping_ids": { "type": "string" },
          "products": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrderProduct" }
          }
        }
      },
      "OrderInput": {
        "type": "object",
        "properties": {
          "user_id": { "type": "integer" },
          "status": { "type": "string" },
          "payment_id": { "type": "integer" },
          "shipping_ids": { "type": "string" },
          "products": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "product_id": { "type": "integer" },
                "amount": { "type": "integer" }
              }
            }
          }
        }
      },
      "OrderProduct": {
        "type": "object",
        "properties": {
          "product_id": { "type": "integer" },
          "product": { "type": "string" },
          "amount": { "type": "integer" },
          "price": { "type": "string" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "user_id": { "type": "string" },
          "email": { "type": "string" },
          "user_type": { "type": "string" },
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "company": { "type": "string" },
          "status": { "type": "string" },
          "phone": { "type": "string" }
        }
      },
      "UserInput": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "user_type": { "type": "string" },
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "company": { "type": "string" },
          "status": { "type": "string", "enum": ["A", "D"] },
          "phone": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "Cart": {
        "type": "object",
        "properties": {
          "user_id": { "type": "integer" },
          "products": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrderProduct" }
          },
          "total": { "type": "string" }
        }
      },
      "Shipment": {
        "type": "object",
        "properties": {
          "shipment_id": { "type": "string" },
          "order_id": { "type": "integer" },
          "shipping_id": { "type": "integer" },
          "tracking_number": { "type": "string" },
          "carrier": { "type": "string" },
          "timestamp": { "type": "integer" }
        }
      },
      "ShipmentInput": {
        "type": "object",
        "properties": {
          "order_id": { "type": "integer" },
          "shipping_id": { "type": "integer" },
          "tracking_number": { "type": "string" },
          "carrier": { "type": "string" },
          "products": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "amount": { "type": "integer" }
              }
            }
          }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "payment_id": { "type": "string" },
          "payment": { "type": "string" },
          "processor_id": { "type": "integer" },
          "status": { "type": "string" },
          "position": { "type": "integer" }
        }
      },
      "Vendor": {
        "type": "object",
        "properties": {
          "company_id": { "type": "string" },
          "company": { "type": "string" },
          "email": { "type": "string" },
          "status": { "type": "string" },
          "phone": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "VendorInput": {
        "type": "object",
        "properties": {
          "company": { "type": "string" },
          "email": { "type": "string" },
          "status": { "type": "string", "enum": ["A", "D", "N"] },
          "phone": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "Store": {
        "type": "object",
        "properties": {
          "company_id": { "type": "string" },
          "company": { "type": "string" },
          "status": { "type": "string" },
          "storefront": { "type": "string" }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "status_id": { "type": "string" },
          "status": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "Tax": {
        "type": "object",
        "properties": {
          "tax_id": { "type": "string" },
          "tax": { "type": "string" },
          "regnumber": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "CmsPage": {
        "type": "object",
        "properties": {
          "page_id": { "type": "string" },
          "page": { "type": "string" },
          "page_type": { "type": "string" },
          "parent_id": { "type": "integer" },
          "status": { "type": "string" },
          "description": { "type": "string" },
          "position": { "type": "integer" }
        }
      },
      "CmsPageInput": {
        "type": "object",
        "properties": {
          "page": { "type": "string" },
          "page_type": { "type": "string" },
          "parent_id": { "type": "integer" },
          "status": { "type": "string", "enum": ["A", "D", "H"] },
          "description": { "type": "string" },
          "position": { "type": "integer" }
        }
      },
      "Usergroup": {
        "type": "object",
        "properties": {
          "usergroup_id": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "usergroup": { "type": "string" }
        }
      },
      "Language": {
        "type": "object",
        "properties": {
          "lang_id": { "type": "string" },
          "lang_code": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "ShippingMethod": {
        "type": "object",
        "properties": {
          "shipping_id": { "type": "string" },
          "shipping": { "type": "string" },
          "status": { "type": "string" },
          "position": { "type": "integer" },
          "delivery_time": { "type": "string" }
        }
      },
      "ProductFeature": {
        "type": "object",
        "properties": {
          "feature_id": { "type": "string" },
          "description": { "type": "string" },
          "feature_type": { "type": "string" },
          "status": { "type": "string" },
          "position": { "type": "integer" }
        }
      },
      "ProductOption": {
        "type": "object",
        "properties": {
          "option_id": { "type": "string" },
          "option_name": { "type": "string" },
          "option_type": { "type": "string" },
          "status": { "type": "string" },
          "position": { "type": "integer" },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "variant_id": { "type": "string" },
                "variant_name": { "type": "string" },
                "position": { "type": "integer" }
              }
            }
          }
        }
      },
      "Setting": {
        "type": "object",
        "properties": {
          "object_id": { "type": "string" },
          "name": { "type": "string" },
          "value": { "type": "string" },
          "section_id": { "type": "string" }
        }
      },
      "SettingInput": {
        "type": "object",
        "properties": {
          "value": { "type": "string" }
        }
      }
    }
  }
}