  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using admin email and API key"
      }
    },
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "integer",
            "description": "Unique product identifier"
          },
          "product": {
            "type": "string",
            "description": "Product name"
          },
          "category_ids": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Array of category IDs"
          },
          "price": {
            "type": "number",
            "format": "float",
            "description": "Product price"
          },
          "list_price": {
            "type": "number",
            "format": "float",
            "description": "List price"
          },
          "amount": {
            "type": "integer",
            "description": "Stock quantity"
          },
          "weight": {
            "type": "number",
            "format": "float",
            "description": "Product weight"
          },
          "status": {
            "type": "string",
            "enum": ["A", "D", "H"],
            "description": "Product status: A=Active, D=Disabled, H=Hidden"
          },
          "company_id": {
            "type": "integer",
            "description": "Vendor company ID"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "integer",
            "description": "Unique order identifier"
          },
          "user_id": {
            "type": "integer",
            "description": "Customer user ID"
          },
          "total": {
            "type": "number",
            "format": "float",
            "description": "Order total amount"
          },
          "subtotal": {
            "type": "number",
            "format": "float",
            "description": "Order subtotal"
          },
          "status": {
            "type": "string",
            "description": "Order status code"
          },
          "timestamp": {
            "type": "integer",
            "description": "Order creation timestamp"
          },
          "products": {
            "type": "object",
            "description": "Order products"
          },
          "shipping": {
            "type": "object",
            "description": "Shipping information"
          },
          "billing": {
            "type": "object",
            "description": "Billing information"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "integer",
            "description": "Unique user identifier"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          },
          "firstname": {
            "type": "string",
            "description": "First name"
          },
          "lastname": {
            "type": "string",
            "description": "Last name"
          },
          "company": {
            "type": "string",
            "description": "Company name"
          },
          "user_type": {
            "type": "string",
            "enum": ["C", "A", "V"],
            "description": "User type: C=Customer, A=Admin, V=Vendor"
          },
          "status": {
            "type": "string",
            "enum": ["A", "D"],
            "description": "User status: A=Active, D=Disabled"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "category_id": {
            "type": "integer",
            "description": "Unique category identifier"
          },
          "category": {
            "type": "string",
            "description": "Category name"
          },
          "parent_id": {
            "type": "integer",
            "description": "Parent category ID"
          },
          "position": {
            "type": "integer",
            "description": "Display position"
          },
          "status": {
            "type": "string",
            "enum": ["A", "D", "H"],
            "description": "Category status: A=Active, D=Disabled, H=Hidden"
          },
          "company_id": {
            "type": "integer",
            "description": "Vendor company ID"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Products",
      "description": "Product management operations"
    },
    {
      "name": "Orders",
      "description": "Order management operations"
    },
    {
      "name": "Users",
      "description": "User account management operations"
    },
    {
      "name": "Categories",
      "description": "Category management operations"
    }
  ]
}
