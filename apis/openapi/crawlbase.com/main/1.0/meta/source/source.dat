{
  "openapi": "3.0.3",
  "info": {
    "title": "Crawlbase Crawling API",
    "version": "1.0",
    "description": "Crawlbase Crawling API for web crawling and scraping. Supports both standard and JavaScript-rendered page crawling with various output formats.",
    "x-jentic-source-url": "https://crawlbase.com/docs/crawling-api"
  },
  "servers": [
    {
      "url": "https://api.crawlbase.com",
      "description": "Crawlbase API"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "crawlUrl",
        "summary": "Crawl a URL",
        "description": "Crawl a URL and return the page content. Supports standard and JavaScript-rendered content via different tokens.",
        "tags": ["Crawling"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "URL to crawl (must be URL-encoded)",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": ["html", "json"],
              "default": "html"
            }
          },
          {
            "name": "user_agent",
            "in": "query",
            "required": false,
            "description": "Custom user agent string",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page_wait",
            "in": "query",
            "required": false,
            "description": "Milliseconds to wait before capturing HTML (JavaScript token only)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "ajax_wait",
            "in": "query",
            "required": false,
            "description": "Wait for AJAX requests to complete (JavaScript token only)",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "css_click_selector",
            "in": "query",
            "required": false,
            "description": "CSS selector(s) to click before capture. Multiple selectors separated by pipe (|)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "device",
            "in": "query",
            "required": false,
            "description": "Device type for rendering",
            "schema": {
              "type": "string",
              "enum": ["desktop", "mobile"]
            }
          },
          {
            "name": "get_cookies",
            "in": "query",
            "required": false,
            "description": "Include cookies from original response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "get_headers",
            "in": "query",
            "required": false,
            "description": "Include response headers",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "request_headers",
            "in": "query",
            "required": false,
            "description": "Custom request headers formatted as key:value|key:value",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "set_cookies",
            "in": "query",
            "required": false,
            "description": "Cookies to send formatted as key=value; key=value",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cookies_session",
            "in": "query",
            "required": false,
            "description": "Session identifier for cookie persistence (max 32 chars)",
            "schema": {
              "type": "string",
              "maxLength": 32
            }
          },
          {
            "name": "screenshot",
            "in": "query",
            "required": false,
            "description": "Capture JPEG screenshot of the page",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "store",
            "in": "query",
            "required": false,
            "description": "Store response in Crawlbase Cloud Storage",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "scraper",
            "in": "query",
            "required": false,
            "description": "Use predefined data scraper for structured extraction",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "async",
            "in": "query",
            "required": false,
            "description": "Enable asynchronous crawling; returns request ID",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "autoparse",
            "in": "query",
            "required": false,
            "description": "Automatically parse and structure page data as JSON",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "country",
            "in": "query",
            "required": false,
            "description": "Geolocation via two-character country code",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            }
          },
          {
            "name": "tor_network",
            "in": "query",
            "required": false,
            "description": "Route through Tor network for .onion sites",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "scroll",
            "in": "query",
            "required": false,
            "description": "Enable automated scrolling for dynamic content",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "scroll_interval",
            "in": "query",
            "required": false,
            "description": "Scrolling duration in seconds (default 10, max 60)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 60
            }
          },
          {
            "name": "custom_success_codes",
            "in": "query",
            "required": false,
            "description": "Comma-separated HTTP status codes to treat as successful",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Crawled page content",
            "headers": {
              "original_status": {
                "description": "Original HTTP status received when crawling the URL",
                "schema": {
                  "type": "string"
                }
              },
              "pc_status": {
                "description": "Crawlbase status code (the effective status)",
                "schema": {
                  "type": "string"
                }
              },
              "url": {
                "description": "Final URL after redirects",
                "schema": {
                  "type": "string"
                }
              },
              "X-Domain-Complexity": {
                "description": "Crawl difficulty indicator: standard, moderate, or complex",
                "schema": {
                  "type": "string",
                  "enum": ["standard", "moderate", "complex"]
                }
              }
            },
            "content": {
              "text/html": {
                "schema": {
                  "type": "string",
                  "description": "Raw HTML content of the crawled page"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CrawlJsonResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid token"
          },
          "429": {
            "description": "Rate limit exceeded (20 requests per second per token)"
          }
        }
      },
      "post": {
        "operationId": "crawlUrlPost",
        "summary": "Crawl a URL via POST",
        "description": "Crawl a URL using POST method. Supports the same parameters as the GET endpoint.",
        "tags": ["Crawling"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "URL to crawl (must be URL-encoded)",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": ["html", "json"],
              "default": "html"
            }
          }
        ],
        "requestBody": {
          "description": "POST body to send to the target URL",
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Crawled page content",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CrawlJsonResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "Authentication token. Use normal token for standard crawling or JavaScript token for JS-rendered content."
      }
    },
    "schemas": {
      "CrawlJsonResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Final URL after redirects"
          },
          "original_status": {
            "type": "string",
            "description": "HTTP status received when crawling the target URL"
          },
          "pc_status": {
            "type": "integer",
            "description": "Crawlbase status code"
          },
          "body": {
            "type": "string",
            "description": "Page content"
          }
        }
      }
    }
  }
}