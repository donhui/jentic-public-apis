{
  "openapi": "3.0.3",
  "info": {
    "title": "Priority Software REST API",
    "description": "Priority Software REST API leveraging the OData protocol for accessing and modifying data in Priority forms. Supports CRUD operations, filtering, sorting, pagination, and batch operations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://prioritysoftware.github.io"
  },
  "servers": [
    {
      "url": "https://{host}/odata/Priority/{tabula_ini}/{environment}",
      "description": "Priority OData service root",
      "variables": {
        "host": {
          "default": "t.eu.priority-connect.online",
          "description": "Priority server hostname"
        },
        "tabula_ini": {
          "default": "tabbtd38.ini",
          "description": "Priority configuration file"
        },
        "environment": {
          "default": "usdemo",
          "description": "Priority environment name"
        }
      }
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getserviceroot",
        "summary": "Get available resources",
        "description": "Returns a basic list of the resources available through the service.",
        "tags": [
          "Metadata"
        ],
        "responses": {
          "200": {
            "description": "List of available entity sets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceRootResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/$metadata": {
      "get": {
        "operationId": "getmetadata",
        "summary": "Get OData metadata",
        "description": "Retrieves the complete OData schema document describing all entity types and relationships.",
        "tags": [
          "Metadata"
        ],
        "responses": {
          "200": {
            "description": "OData metadata document",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/GetMetadataFor(entity='{entityName}')": {
      "get": {
        "operationId": "getentitymetadata",
        "summary": "Get metadata for a specific entity",
        "description": "Fetches metadata for a specific entity. Available in Priority v25.0 and later.",
        "tags": [
          "Metadata"
        ],
        "parameters": [
          {
            "name": "entityName",
            "in": "path",
            "required": true,
            "description": "Name of the entity to retrieve metadata for",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entity metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/GetPriorityVersion()": {
      "get": {
        "operationId": "getpriorityversion",
        "summary": "Get Priority version",
        "description": "Returns the Priority version and server IP information.",
        "tags": [
          "Metadata"
        ],
        "responses": {
          "200": {
            "description": "Version information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{entitySet}": {
      "get": {
        "operationId": "listentities",
        "summary": "List entities in a collection",
        "description": "Returns entities from a Priority form. Supports OData query parameters for filtering, sorting, and pagination. Default limit is governed by MAXAPILINES constant (2000 records in v25.1+).",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "entitySet",
            "in": "path",
            "required": true,
            "description": "Name of the entity set (Priority form)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$filter",
            "in": "query",
            "description": "OData filter expression",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$select",
            "in": "query",
            "description": "Comma-separated list of fields to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$expand",
            "in": "query",
            "description": "Related entities to include inline",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$top",
            "in": "query",
            "description": "Maximum number of entities to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "$skip",
            "in": "query",
            "description": "Number of entities to skip",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "$orderby",
            "in": "query",
            "description": "Field name and direction for sorting (e.g., 'Name asc')",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entity collection returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityCollectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Entity set not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (100 calls/minute per user on cloud)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createentity",
        "summary": "Create an entity",
        "description": "Creates a new entity in the specified entity set.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "entitySet",
            "in": "path",
            "required": true,
            "description": "Name of the entity set (Priority form)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Entity properties as defined in the metadata"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entity created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - entity already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{entitySet}('{key}')": {
      "get": {
        "operationId": "getentity",
        "summary": "Get an entity by key",
        "description": "Retrieves an individual entity by its key value.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "entitySet",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "path",
            "required": true,
            "description": "Entity key value",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$select",
            "in": "query",
            "description": "Comma-separated list of fields to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$expand",
            "in": "query",
            "description": "Related entities to include inline",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entity returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateentity",
        "summary": "Update an entity",
        "description": "Updates an existing entity with partial data.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "entitySet",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "path",
            "required": true,
            "description": "Entity key value",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Entity properties to update"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entity updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteentity",
        "summary": "Delete an entity",
        "description": "Deletes an entity by its key value.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "entitySet",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "path",
            "required": true,
            "description": "Entity key value",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Entity deleted successfully (no content)"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{entitySet}('{key}')/{navigationProperty}": {
      "get": {
        "operationId": "getrelatedentities",
        "summary": "Get related entities",
        "description": "Accesses related entities (subforms) via navigation properties.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "entitySet",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "navigationProperty",
            "in": "path",
            "required": true,
            "description": "Name of the navigation property (subform)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$filter",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$select",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$top",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "$skip",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Related entities returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityCollectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ServiceRootResponse": {
        "type": "object",
        "properties": {
          "value": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Entity set name"
                },
                "kind": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "EntityCollectionResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string",
            "description": "OData context URL"
          },
          "value": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Array of entity objects"
          },
          "@odata.nextLink": {
            "type": "string",
            "description": "URL for next page of results"
          }
        }
      },
      "VersionResponse": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "description": "Priority version number"
          },
          "serverIp": {
            "type": "string",
            "description": "Server IP address"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication with Priority username and password"
      },
      "PersonalAccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Personal Access Token (PAT) for token-based authentication"
      },
      "AppLicense": {
        "type": "apiKey",
        "in": "header",
        "name": "X-App-Id",
        "description": "Application license identifier paired with X-App-Key header"
      }
    }
  },
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Metadata",
      "description": "Service metadata and version information"
    },
    {
      "name": "Data",
      "description": "CRUD operations on Priority entities and forms"
    }
  ]
}