{
  "openapi": "3.0.3",
  "info": {
    "title": "Truffle API",
    "version": "1.0.0",
    "description": "API for Truffle - an AI-driven one-way interview platform that generates ranked, culture-fit candidate shortlists.",
    "x-jentic-source-url": "https://app.hiretruffle.com/docs/#tag/Jobs"
  },
  "servers": [
    {
      "url": "https://api.truffle.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "Job": {
        "type": "object",
        "properties": {
          "job_sid": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "job_function": {
            "type": "string",
            "enum": [
              "sales",
              "marketing",
              "finance",
              "operations",
              "support",
              "admin",
              "technical",
              "delivery",
              "other"
            ]
          },
          "employment_type": {
            "type": "string",
            "enum": [
              "unspecified",
              "full_time",
              "part_time",
              "contract",
              "freelance",
              "internship"
            ]
          },
          "description": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "location_type": {
            "type": "string",
            "enum": [
              "unspecified",
              "on_site",
              "remote",
              "hybrid",
              "field_based",
              "flexible",
              "multiple_locations"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "draft",
              "open",
              "in_review",
              "closed",
              "on_hold",
              "filled",
              "cancelled",
              "archived",
              "expired",
              "pending_approval",
              "rejected"
            ]
          },
          "salary": {
            "type": "integer",
            "nullable": true
          },
          "company_sid": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "department_sid": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "candidate_profile": {
            "type": "object"
          },
          "logo_type": {
            "type": "string",
            "enum": [
              "none",
              "job",
              "company"
            ]
          },
          "welcome_message_type": {
            "type": "string",
            "enum": [
              "none",
              "text",
              "video"
            ]
          },
          "welcome_message": {
            "type": "string",
            "nullable": true
          },
          "prescreening": {
            "type": "object",
            "nullable": true
          },
          "screening": {
            "type": "object",
            "nullable": true
          },
          "archived": {
            "type": "boolean",
            "default": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "job_sid",
          "title"
        ]
      },
      "CreateJob": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "job_function": {
            "type": "string",
            "enum": [
              "sales",
              "marketing",
              "finance",
              "operations",
              "support",
              "admin",
              "technical",
              "delivery",
              "other"
            ],
            "default": "other"
          },
          "employment_type": {
            "type": "string",
            "enum": [
              "unspecified",
              "full_time",
              "part_time",
              "contract",
              "freelance",
              "internship"
            ],
            "default": "unspecified"
          },
          "description": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "location_type": {
            "type": "string",
            "enum": [
              "unspecified",
              "on_site",
              "remote",
              "hybrid",
              "field_based",
              "flexible",
              "multiple_locations"
            ],
            "default": "unspecified"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "draft",
              "open",
              "in_review",
              "closed",
              "on_hold",
              "filled",
              "cancelled",
              "archived",
              "expired",
              "pending_approval",
              "rejected"
            ],
            "default": "draft"
          },
          "salary": {
            "type": "integer"
          },
          "department_sid": {
            "type": "string",
            "format": "uuid"
          },
          "candidate_profile": {
            "type": "object"
          },
          "prescreening": {
            "type": "object"
          },
          "screening": {
            "type": "object"
          },
          "archived": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "title",
          "job_function",
          "employment_type",
          "description"
        ]
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "webhook_sid": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "description": {
            "type": "string"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive"
            ]
          },
          "timeout": {
            "type": "integer",
            "default": 30
          },
          "max_retries": {
            "type": "integer",
            "default": 3
          }
        }
      },
      "CreateWebhook": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "description": {
            "type": "string"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "integration_group": {
            "type": "string",
            "maxLength": 40
          },
          "headers": {
            "type": "object"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive"
            ],
            "default": "active"
          },
          "timeout": {
            "type": "integer",
            "default": 30
          },
          "max_retries": {
            "type": "integer",
            "default": 3
          },
          "retry_delay": {
            "type": "integer",
            "default": 60
          }
        },
        "required": [
          "name",
          "url",
          "events"
        ]
      },
      "Interview": {
        "type": "object",
        "properties": {
          "interview_sid": {
            "type": "string",
            "format": "uuid"
          },
          "job_sid": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "integer"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Jobs",
      "description": "Job management"
    },
    {
      "name": "Webhooks",
      "description": "Webhook management"
    },
    {
      "name": "Interviews",
      "description": "Interview management"
    }
  ],
  "paths": {
    "/v1/jobs": {
      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "Get a list of jobs",
        "operationId": "listJobs",
        "responses": {
          "200": {
            "description": "A list of jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Job"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "Jobs"
        ],
        "summary": "Create a new job",
        "operationId": "createJob",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJob"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/v1/jobs/{job_sid}": {
      "get": {
        "tags": [
          "Jobs"
        ],
        "summary": "Get a single job",
        "operationId": "getJob",
        "parameters": [
          {
            "name": "job_sid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "tags": [
          "Jobs"
        ],
        "summary": "Update a job",
        "operationId": "updateJob",
        "parameters": [
          {
            "name": "job_sid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJob"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "tags": [
          "Jobs"
        ],
        "summary": "Delete a job",
        "operationId": "deleteJob",
        "parameters": [
          {
            "name": "job_sid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Job deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/v1/jobs/{job_sid}/invite": {
      "post": {
        "tags": [
          "Jobs"
        ],
        "summary": "Send job invitation",
        "operationId": "inviteToJob",
        "parameters": [
          {
            "name": "job_sid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Invitation sent"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/webhooks": {
      "get": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Get a list of webhooks",
        "operationId": "listWebhooks",
        "responses": {
          "200": {
            "description": "A list of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Webhook"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Create a new webhook",
        "operationId": "createWebhook",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWebhook"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/webhooks/{webhook_sid}": {
      "get": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Get a single webhook",
        "operationId": "getWebhook",
        "parameters": [
          {
            "name": "webhook_sid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Update a webhook",
        "operationId": "updateWebhook",
        "parameters": [
          {
            "name": "webhook_sid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWebhook"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Delete a webhook",
        "operationId": "deleteWebhook",
        "parameters": [
          {
            "name": "webhook_sid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Webhook deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/v1/interviews": {
      "get": {
        "tags": [
          "Interviews"
        ],
        "summary": "Get a list of interviews",
        "operationId": "listInterviews",
        "responses": {
          "200": {
            "description": "A list of interviews",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Interview"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/interviews/{interview_sid}": {
      "get": {
        "tags": [
          "Interviews"
        ],
        "summary": "Get a single interview",
        "operationId": "getInterview",
        "parameters": [
          {
            "name": "interview_sid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Interview details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Interview"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    }
  }
}