{
  "openapi": "3.0.3",
  "info": {
    "title": "iFirma Orders API",
    "description": "iFirma API for managing e-commerce orders. Supports creating and updating orders from custom integrations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.ifirma.pl/zamowienia"
  },
  "servers": [
    {
      "url": "https://www.ifirma.pl/hub/user/platform/CUSTOM/V1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Orders",
      "description": "Order management operations"
    }
  ],
  "paths": {
    "/orders/order": {
      "post": {
        "operationId": "createorder",
        "summary": "Create a new order",
        "tags": [
          "Orders"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateorder",
        "summary": "Update an existing order",
        "tags": [
          "Orders"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT bearer token obtained from iFirma store integration configuration."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type"
          },
          "message": {
            "type": "string",
            "description": "Error description"
          }
        }
      },
      "OrderRequest": {
        "type": "object",
        "required": [
          "id",
          "status",
          "created",
          "currency",
          "shippingTotal",
          "productsTotalNet"
        ],
        "properties": {
          "id": {
            "type": "string",
            "maxLength": 40,
            "description": "Order identifier"
          },
          "customId": {
            "type": "string",
            "maxLength": 40,
            "description": "Custom order identifier"
          },
          "status": {
            "type": "string",
            "maxLength": 100,
            "description": "Order status. Use 'Anulowane' for canceled orders."
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Order creation date (yyyy-MM-dd'T'HH:mm:ss.SSS)"
          },
          "modified": {
            "type": "string",
            "format": "date-time",
            "description": "Last modification date"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code (PLN, EUR, GBP, USD, etc.)"
          },
          "discountTotal": {
            "type": "number",
            "minimum": 0,
            "description": "Total discount amount"
          },
          "discountTax": {
            "type": "number",
            "minimum": 0,
            "description": "Tax on discount"
          },
          "shippingTotal": {
            "type": "number",
            "minimum": 0,
            "description": "Total shipping cost"
          },
          "shippingTax": {
            "type": "number",
            "minimum": 0,
            "description": "Tax on shipping"
          },
          "productsTotalNet": {
            "type": "number",
            "exclusiveMinimum": true,
            "minimum": 0,
            "description": "Net total for all products"
          },
          "productsTotalTax": {
            "type": "number",
            "minimum": 0,
            "description": "Tax total for all products"
          },
          "customerId": {
            "type": "string",
            "maxLength": 100,
            "description": "Customer identifier"
          },
          "paymentMethod": {
            "type": "string",
            "maxLength": 250,
            "description": "Payment method name"
          },
          "transactionId": {
            "type": "string",
            "maxLength": 250,
            "description": "Transaction identifier"
          },
          "paid": {
            "type": "boolean",
            "description": "Whether the order has been paid"
          },
          "completed": {
            "type": "string",
            "format": "date-time",
            "description": "Completion date"
          },
          "clientLogin": {
            "type": "string",
            "maxLength": 100,
            "description": "Client login/username"
          },
          "message": {
            "type": "string",
            "maxLength": 5000,
            "description": "Order message or notes"
          },
          "deliveryType": {
            "type": "string",
            "maxLength": 250,
            "description": "Delivery type"
          },
          "invoiceRequired": {
            "type": "boolean",
            "description": "Whether an invoice is required"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          },
          "billing": {
            "$ref": "#/components/schemas/BillingAddress"
          },
          "shipping": {
            "$ref": "#/components/schemas/ShippingAddress"
          },
          "trackingList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TrackingInfo"
            }
          },
          "pickupPoint": {
            "$ref": "#/components/schemas/PickupPoint"
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 250,
            "description": "Product name"
          },
          "quantity": {
            "type": "number",
            "description": "Quantity ordered"
          },
          "price": {
            "type": "number",
            "description": "Unit price"
          },
          "totalPrice": {
            "type": "number",
            "description": "Total price for this line item"
          },
          "sku": {
            "type": "string",
            "maxLength": 100,
            "description": "SKU code"
          },
          "ean": {
            "type": "string",
            "maxLength": 20,
            "description": "EAN barcode"
          },
          "taxRate": {
            "type": "number",
            "description": "Tax rate percentage"
          }
        }
      },
      "BillingAddress": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "maxLength": 100
          },
          "lastName": {
            "type": "string",
            "maxLength": 100
          },
          "company": {
            "type": "string",
            "maxLength": 250
          },
          "address": {
            "type": "string",
            "maxLength": 250
          },
          "city": {
            "type": "string",
            "maxLength": 100
          },
          "postcode": {
            "type": "string",
            "maxLength": 20
          },
          "country": {
            "type": "string",
            "maxLength": 100
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 100
          },
          "phone": {
            "type": "string",
            "maxLength": 20
          },
          "NIP": {
            "type": "string",
            "maxLength": 20,
            "description": "Tax identification number"
          },
          "REGON": {
            "type": "string",
            "maxLength": 20,
            "description": "National business registry number"
          }
        }
      },
      "ShippingAddress": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "maxLength": 100
          },
          "lastName": {
            "type": "string",
            "maxLength": 100
          },
          "company": {
            "type": "string",
            "maxLength": 250
          },
          "address": {
            "type": "string",
            "maxLength": 250
          },
          "city": {
            "type": "string",
            "maxLength": 100
          },
          "postcode": {
            "type": "string",
            "maxLength": 20
          },
          "country": {
            "type": "string",
            "maxLength": 100
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 100
          },
          "phone": {
            "type": "string",
            "maxLength": 20
          }
        }
      },
      "TrackingInfo": {
        "type": "object",
        "properties": {
          "trackingNumber": {
            "type": "string",
            "description": "Tracking number"
          },
          "carrier": {
            "type": "string",
            "description": "Carrier name"
          }
        }
      },
      "PickupPoint": {
        "type": "object",
        "properties": {
          "method": {
            "type": "string",
            "description": "Pickup method"
          },
          "externalId": {
            "type": "string",
            "description": "External pickup point ID"
          },
          "name": {
            "type": "string",
            "description": "Pickup point name"
          },
          "address": {
            "type": "string",
            "description": "Pickup point address"
          },
          "city": {
            "type": "string",
            "description": "Pickup point city"
          },
          "zipCode": {
            "type": "string",
            "description": "Pickup point zip code"
          },
          "countryCode": {
            "type": "string",
            "description": "Pickup point country code"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Order identifier"
          },
          "status": {
            "type": "string",
            "description": "Order status"
          },
          "message": {
            "type": "string",
            "description": "Response message"
          }
        }
      }
    }
  }
}