      "DateRangeDto": {
        "title": "DateRangeDto",
        "type": "object",
        "properties": {
          "from": {
            "description": "Corresponds to the minimum threshold (included) of the range.<br/> Must be less than or equal to .to (if set).<br/> As Unix timestamp in milliseconds.",
            "type": "integer",
            "format": "int64",
            "example": 1456763982000
          },
          "to": {
            "description": "Corresponds to the maximum threshold (included) of the range.<br/> Must be greater than or equal to .from (if set).<br/> As Unix timestamp in milliseconds.",
            "type": "integer",
            "format": "int64",
            "example": 1456763982000
          }
        }
      },
      "Period": {
        "title": "Period",
        "description": "String representation of a duration/period.<br/> Format should follow <a href=\"https://en.wikipedia.org/wiki/ISO_8601#Durations\">ISO_8601</a> Duration specification.<br/> For example, \"P3D\" for a 3 days period, \"P3W\" for a 3 weeks duration, \"P1M\" for a 1 month duration.",
        "type": "string",
        "example": "P3D"
      },
      "DateFilterDto": {
        "title": "DateFilterDto",
        "description": "Filter documents based on the date field referenced by this filter.<br/> <u>One and only one field can be set:</u><br/> - Use <u>\"isBetween\"</u> to filter documents having the referenced date <u>between</u> <b>\"from\"</b> and <b>\"to\"</b> <u>(inclusive)</u> of the date range provided.<br/> - Use <u>\"isAfter\"</u> to filter documents having the referenced date <u>after</u> <u>(inclusive)</u> <b>the provided timestamp</b>.<br/> - Use <u>\"isBefore\"</u> to filter documents having the referenced date <u>before</u> <u>(inclusive)</u> <b>the provided timestamp</b>.<br/> - Use <u>\"isWithinTheNext\"</u> to filter documents having the referenced date <u>between</u> <b>now</b> and <b>now + the provided period</b>.<br/> - Use <u>\"isWithinTheLast\"</u> to filter documents having the referenced date <u>between</u> <b>now - the provided period</b> and <b>now</b>.<br/> - Use <u>\"isMoreThan\"</u> to filter documents having the referenced date <u>before</u> <b>now - the provided period</b>.<br/> - Use <u>\"isBlankFilter\"</u> to filter documents having the referenced date <b>Blank</b> or <b>Not Blank</b>.</br> When <b>isBetween, isAfter, isBefore, isWithinTheNext, isWithinTheLast or isMoreThan</b> are used, documents with a blank referenced date will always be filtered out.<br/> <u>NB:</u> isBetween={from=x, to=null} will be converted to isAfter=x and isBetween={from=null, to=y} will be converted to isBefore=y",
        "type": "object",
        "properties": {
          "isBetween": {
            "$ref": "#/components/schemas/DateRangeDto"
          },
          "isAfter": {
            "description": "Filter documents having the referenced date <u>after</u> <u>(inclusive)</u> <b>the provided timestamp</b>.<br/> As Unix timestamp in milliseconds.",
            "type": "integer",
            "format": "int64",
            "example": 1456763982000
          },
          "isBefore": {
            "description": "Filter documents having the referenced date <u>before</u> <u>(inclusive)</u> <b>the provided timestamp</b>.<br/> As Unix timestamp in milliseconds.",
            "type": "integer",
            "format": "int64",
            "example": 1456763982000
          },
          "isWithinTheNext": {
            "$ref": "#/components/schemas/Period"
          },
          "isWithinTheLast": {
            "$ref": "#/components/schemas/Period"
          },
          "isMoreThan": {
            "$ref": "#/components/schemas/Period"
          },
          "isBlank": {
            "description": "Filter on Agreement's referenced date:<br/> - If <b>true</b>, only agreements <b>without</b> the referenced date will be returned.<br/> - If <b>false</b>, only agreements <b>with</b> the referenced date will be returned.<br/> - If not sent, agreements <b>with</b> and <b>without</b> the referenced date will be returned.",
            "type": "boolean",
            "example": true
          }
        }
      },
      "EndDateFilterDto": {
        "title": "DateFilterDto",
        "description": "Filter documents based on the date field referenced by this filter.<br/> <u>One and only one field can be set:</u><br/> - Use <u>\"isBetween\"</u> to filter documents having the referenced date <u>between</u> <b>\"from\"</b> and <b>\"to\"</b> <u>(inclusive)</u> of the date range provided.<br/> - Use <u>\"isAfter\"</u> to filter documents having the referenced date <u>after</u> <u>(inclusive)</u> <b>the provided timestamp</b>.<br/> - Use <u>\"isBefore\"</u> to filter documents having the referenced date <u>before</u> <u>(inclusive)</u> <b>the provided timestamp</b>.<br/> - Use <u>\"isWithinTheNext\"</u> to filter documents having the referenced date <u>between</u> <b>now</b> and <b>now + the provided period</b>.<br/> - Use <u>\"isWithinTheLast\"</u> to filter documents having the referenced date <u>between</u> <b>now - the provided period</b> and <b>now</b>.<br/> - Use <u>\"isMoreThan\"</u> to filter documents having the referenced date <u>before</u> <b>now - the provided period</b>.<br/> - Use <u>\"isBlankFilter\"</u> to filter documents having the referenced date <b>Blank</b> or <b>Not Blank</b>.</br> When <b>isBetween, isAfter, isBefore, isWithinTheNext, isWithinTheLast or isMoreThan</b> are used, documents with a blank referenced date will always be filtered out.<br/> <u>NB:</u> isBetween={from=x, to=null} will be converted to isAfter=x and isBetween={from=null, to=y} will be converted to isBefore=y",
        "type": "object",
        "properties": {
          "isBetween": {
            "$ref": "#/components/schemas/DateRangeDto"
          },
          "isAfter": {
            "description": "Filter documents having the referenced date <u>after</u> <u>(inclusive)</u> <b>the provided timestamp</b>.<br/> As Unix timestamp in milliseconds.",
            "type": "integer",
            "format": "int64",
            "example": 1456763982000
          },
          "isBefore": {
            "description": "Filter documents having the referenced date <u>before</u> <u>(inclusive)</u> <b>the provided timestamp</b>.<br/> As Unix timestamp in milliseconds.",
            "type": "integer",
            "format": "int64",
            "example": 1456763982000
          },
          "isWithinTheNext": {
            "$ref": "#/components/schemas/Period"
          },
          "isWithinTheLast": {
            "$ref": "#/components/schemas/Period"
          },
          "isMoreThan": {
            "$ref": "#/components/schemas/Period"
          },
          "isBlank": {
            "description": "Filter on Agreement's referenced date:<br/> - If <b>true</b>, only agreements <b>without</b> the referenced date will be returned.<br/> - If <b>false</b>, only agreements <b>with</b> the referenced date will be returned.<br/> - If not sent, agreements <b>with</b> and <b>without</b> the referenced date will be returned.",
            "type": "boolean",
            "example": true
          },
          "isPermanent": {
            "description": "Filter on Agreement's referenced date:<br/> - If <b>true</b>, only agreements <b>without</b> the referenced date and in undetermined duration (Permanent duration) will be returned.<br/> - If <b>false</b>, only agreements <b>with</b> the referenced date or unknown duration will be returned.<br/> - If not sent, no filter is done.",
            "type": "boolean",
            "example": true
          },
          "isUnknown": {
            "description": "Filter on Agreement's referenced date:<br/> - If <b>true</b>, only agreements <b>without</b> the referenced date and in unknown duration will be returned.<br/> - If <b>false</b>, only agreements <b>with</b> the referenced date or not in unknown duration will be returned.<br/> - If not sent, no filter is done.",
            "type": "boolean",
            "example": true
          }
        }
      },
      "FilterDto": {
        "title": "FilterDto",
        "type": "object",
        "properties": {
          "tagNames": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "filter on tags names if it is specified. The noTags Filter should be false."
          },
          "tagIds": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "int64"
            },
            "description": "filter on tags ID if it is specified. The noTags Filter should be false."
          },
          "noTags": {
            "type": "boolean",
            "description": "filter document that do not contain tags. It must have the value false when the filter tagNames or tagIds is specified.",
            "example": false
          },
          "statuses": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": ""
          },
          "search": {
            "type": "string",
            "description": "limited to 300 characters.",
            "example": "text"
          },
          "inboxed": {
            "type": "boolean",
            "description": "Display only documents that appear in the inbox (false to display also archived documents).",
            "example": false
          },
          "createdBy": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "Display only documents created by the list of specified id users."
          },
          "createdAt": {
            "$ref": "#/components/schemas/DateFilterDto"
          },
          "modifiedAt": {
            "$ref": "#/components/schemas/DateFilterDto"
          },
          "endAt": {
            "$ref": "#/components/schemas/EndDateFilterDto"
          },
          "signatureDate": {
            "$ref": "#/components/schemas/DateFilterDto"
          },
          "parties": {
            "description": "Filter on property party value ID",
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 22,
              "maxLength": 22
            },
            "example": "01sp9L4YEZNcLHaSV8447N"
          },
          "sharedWith": {
            "description": "Filter on property shared with value ID",
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 22,
              "maxLength": 22
            },
            "example": "01sp9L4YEZNcLHaSV8447N"
          }
        }
      },
      "ReportDto": {
        "title": "ReportDto",
