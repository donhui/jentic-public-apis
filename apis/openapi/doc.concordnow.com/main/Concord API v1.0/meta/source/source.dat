      "NotificationRuleDto": {
        "title": "NotificationRuleDto",
        "required": [
          "notificationType"
        ],
        "type": "object",
        "properties": {
          "notificationType": {
            "$ref": "#/components/schemas/NotificationTypeEnum"
          },
          "fromColleaguesActive": {
            "type": "boolean",
            "example": true
          },
          "fromThirdPartiesActive": {
            "type": "boolean",
            "example": true
          },
          "inDailyDigest": {
            "type": "boolean",
            "example": true
          }
        }
