            "format": "int32"
          },
          "createdAt": {
            "type": "integer",
            "format": "int64"
          },
          "contact": {
            "$ref": "#/components/schemas/Contact"
          },
          "authorities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "name": {
            "type": "string"
          },
