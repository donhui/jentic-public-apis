        "description": "Numeric value"
      },
      "ShortTextPropertyValueDto": {
        "title": "ShortTextPropertyValueDto",
        "type": "string",
        "maxLength": 256,
        "description": "Short text value",
        "example": "Contract Agreement 2022"
      },
      "LongTextPropertyValueDto": {
        "title": "LongTextPropertyValueDto",
        "type": "string",
        "maxLength": 10000,
        "description": "Long text value",
        "example": "Long text value"
      },
      "DatePropertyValueDto": {
        "title": "DatePropertyValueDto",
        "type": "string",
        "format": "date",
        "description": "Date value",
        "example": "2023-12-31"
