      "DateTimePropertyValueDto": {
        "title": "DateTimePropertyValueDto",
        "type": "string",
        "format": "date-time",
        "description": "Datetime value",
        "example": "2017-07-21T17:32:28Z"
      },
      "MonetaryAmountPropertyValueDto": {
        "title": "MonetaryValuePropertyValueDto",
        "type": "object",
        "description": "An object holding a pair amount/currency-code to represent a monetary value",
        "required": [
          "amount",
          "currency"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "description": "The amount of money held by the currency object"
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the object.<br/> Must be a valid code in the <a href=\"https://www.iso.org/iso-4217-currency-codes.html\" target=\"_blank\">ISO-4217</a> standard.<br/> examples: \"USD\", \"EUR\", \"CAD\"",
            "examples": [
              "USD",
              "EUR",
              "CAD"
            ]
          }
        }
      },
      "PropertyReferenceTypeEnum": {
        "title": "PropertyReferenceTypeEnum",
        "enum": [
          "USER",
          "CUSTOM",
          "FOLDER",
          "ORGANIZATION"
        ],
        "type": "string"
      },
      "UserPicturesDto": {
        "title": "UserPicturesDto",
        "required": [
          "small",
          "normal"
        ],
        "type": "object",
        "properties": {
          "small": {
            "type": "string",
            "example": "/static/img/users/b0c8b9d2-2944-49d3-af3a-c216ddf089ca/small.jpg"
          },
          "normal": {
            "type": "string",
            "example": "/static/img/users/b0c8b9d2-2944-49d3-af3a-c216ddf089ca/normal.jpg"
          },
          "special": {
            "type": "string",
            "example": "/static/img/users/b0c8b9d2-2944-49d3-af3a-c216ddf089ca/special.jpg"
          }
        }
      },
      "DeletionStatusEnum": {
        "title": "DeletionStatusEnum",
        "default": "ACTIVE",
        "enum": [
          "ACTIVE",
          "SOFT_DELETED"
        ],
        "type": "string"
      },
      "PropertyValueUserDto": {
        "title": "PropertyValueUserDto",
        "type": "object",
        "required": [
          "userId",
          "emailAddress",
          "fullName",
          "external"
        ],
        "properties": {
          "userId": {
            "type": "string",
            "minLength": 22,
            "maxLength": 22,
            "description": "User ID",
            "example": "01sp9L4YEZNcLHaSV8447N"
          },
          "emailAddress": {
            "type": "string",
            "format": "email",
            "example": "john@doe.com"
          },
          "hasPicture": {
            "type": "boolean"
          },
          "pictures": {
            "$ref": "#/components/schemas/UserPicturesDto"
          },
          "fullName": {
            "type": "string",
            "example": "John Doe"
          },
          "status": {
            "$ref": "#/components/schemas/DeletionStatusEnum"
          },
          "external": {
            "type": "boolean",
            "description": "Indicates if the user is external to the organization."
          }
        }
      },
      "PropertyValueCustomDto": {
        "title": "PropertyValueCustomDto",
        "type": "object",
        "required": [
          "valueText"
        ],
        "properties": {
          "valueText": {
            "type": "string"
          }
        }
      },
      "SingleSelectPropertyValueDto": {
        "title": "SingleSelectPropertyValueDto",
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "valueText"
          ],
          "properties": {
            "propertyValueId": {
              "type": "string",
              "description": "Unique identifier of the property value."
            },
            "valueText": {
              "type": "string",
              "description": "Text value."
            },
            "referenceType": {
              "$ref": "#/components/schemas/PropertyReferenceTypeEnum"
            },
            "value": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/PropertyValueUserDto"
                },
                {
                  "$ref": "#/components/schemas/PropertyValueCustomDto"
                }
              ],
              "discriminator": {
                "propertyName": "type",
                "mapping": {
                  "USER": "#/components/schemas/PropertyValueUserDto",
                  "CUSTOM": "#/components/schemas/PropertyValueCustomDto"
                }
              }
            }
          }
        }
      },
      "MultiSelectPropertyValueDto": {
        "title": "MultiSelectPropertyValueDto",
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "valueText"
          ],
          "properties": {
            "propertyValueId": {
              "type": "string",
              "description": "Unique identifier of the property value."
            },
            "valueText": {
              "type": "string",
              "description": "Text value."
            },
            "referenceType": {
              "$ref": "#/components/schemas/PropertyReferenceTypeEnum"
            },
            "value": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/PropertyValueUserDto"
                },
                {
                  "$ref": "#/components/schemas/PropertyValueCustomDto"
                }
              ],
              "discriminator": {
                "propertyName": "type",
                "mapping": {
                  "USER": "#/components/schemas/PropertyValueUserDto",
                  "CUSTOM": "#/components/schemas/PropertyValueCustomDto"
                }
              }
            }
          }
        }
      },
      "PropertyValueDto": {
        "title": "PropertyValueDto",
        "type": "object",
        "required": [
          "type",
          "value"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/PropertyTypeEnumDto",
            "description": "Type of property value"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "value": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/NumericPropertyValueDto"
              },
              {
                "$ref": "#/components/schemas/ShortTextPropertyValueDto"
              },
              {
                "$ref": "#/components/schemas/LongTextPropertyValueDto"
              },
              {
                "$ref": "#/components/schemas/DatePropertyValueDto"
              },
              {
                "$ref": "#/components/schemas/DateTimePropertyValueDto"
              },
              {
                "$ref": "#/components/schemas/MonetaryAmountPropertyValueDto"
              },
              {
                "$ref": "#/components/schemas/SingleSelectPropertyValueDto"
              },
              {
                "$ref": "#/components/schemas/MultiSelectPropertyValueDto"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "AgreementListItemPropertyDto": {
        "title": "AgreementListItemPropertyDto",
        "type": "object",
        "required": [
          "propertyId",
          "propertySource",
          "visibility",
          "content"
        ],
        "properties": {
          "propertyId": {
            "type": "string",
            "minLength": 22,
            "maxLength": 22,
            "description": "Unique identifier for the property ID"
          },
          "propertySource": {
            "type": "string",
            "enum": [
              "USER",
              "SYSTEM"
            ],
            "description": "Property source"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "COMPANY",
              "ALL"
            ],
            "description": "Visibility"
          },
          "propertyName": {
            "type": "string",
            "description": "Name of the property"
          },
          "content": {
            "$ref": "#/components/schemas/PropertyValueDto",
            "description": "Property value (depending of the property schema)"
          }
        }
      },
      "AgreementListItemDto": {
        "title": "AgreementListItemDto",
        "required": [
          "accessFromRole",
          "accessType",
          "createdAt",
          "createdBy",
          "createdByName",
          "documentType",
          "isInboxed",
          "isBookmarked",
          "modifiedAt",
          "organizationId",
          "parties",
          "status",
          "tags",
          "title",
          "uuid"
        ],
        "type": "object",
        "properties": {
          "accessFromRole": {
            "type": "boolean",
            "description": "Admin oversight access",
            "example": false
          },
          "accessType": {
            "$ref": "#/components/schemas/AgreementAccessType"
          },
          "createdAt": {
            "type": "number",
            "description": "Creation date as Unix timestamp in milliseconds",
            "example": 1456763982000
          },
          "createdBy": {
            "type": "integer",
            "format": "int64",
            "description": "creator ID",
            "example": 123
          },
          "createdByIsActive": {
            "type": "boolean",
            "description": "true if the creator account is active",
            "example": true
          },
          "createdByName": {
            "type": "string",
            "description": "The creator name",
            "example": "John doe"
          },
          "description": {
            "type": "string",
            "description": "Agreement description",
            "example": "NDA"
          },
          "documentType": {
            "$ref": "#/components/schemas/DocumentType"
          },
          "endDate": {
            "type": "integer",
            "format": "int64",
            "description": "End date as Unix timestamp in millisecond",
            "example": 1548979200000
          },
          "endDateUnknown": {
            "type": "boolean",
            "example": true
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldDtoBase"
            },
            "description": "Agreement smart fields"
          },
          "folderId": {
            "type": "integer",
            "format": "int64",
            "description": "ID of the folder containing this agreement",
            "example": 123
          },
          "hasSigned": {
            "type": "boolean",
            "example": true,
            "description": "true if the current user has already signed this agreement."
          },
          "isInboxed": {
            "type": "boolean",
            "example": true
          },
          "isBookmarked": {
            "type": "boolean",
            "example": true
          },
          "modifiedAt": {
            "type": "number",
            "description": "Modification date as Unix timestamp in milliseconds",
            "example": 1456763982000
          },
          "mustValidate": {
            "type": "boolean",
            "example": false
          },
          "organizationId": {
            "type": "number",
            "description": "ID of the organization that created/owns this agreement.",
            "example": 1
          },
          "organizationName": {
            "type": "string",
            "description": "Name of the organization this agreement belongs to.\nOnly present when performing cross-organization AI searches.\n",
            "example": "Acme Corporation"
          },
          "accessOrganizationId": {
            "type": "number",
            "description": "Organization ID through which the current user has access to this agreement.\nOnly present when performing cross-organization AI searches.\nUse this instead of organizationId when navigating to the agreement, as organizationId\nalways refers to the creator organization which may differ from the user's access organization.\n",
            "example": 143305
          },
          "signatureCount": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "signatureDate": {
            "type": "number",
            "description": "Signature date as Unix timestamp in millisecond",
            "example": 1548979200000
          },
          "signatureDateUnknown": {
            "type": "boolean",
            "example": false
          },
          "signatureRequired": {
            "type": "number",
            "example": 1
          },
          "signatureProvider": {
            "$ref": "#/components/schemas/SignatureProvider"
          },
          "status": {
            "type": "string",
            "description": "Agreement status",
            "example": "UNKNOWN_CONTRACT"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagDto"
            },
            "description": "Agreement tags"
          },
          "properties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgreementListItemPropertyDto"
            },
            "description": "Agreement properties"
          },
          "title": {
            "type": "string",
            "description": "Disclosure Agreement (string) - Agreement title",
            "example": "Non"
          },
          "unread": {
            "type": "boolean",
            "example": false
          },
          "uuid": {
            "$ref": "#/components/schemas/AgreementUid"
          },
          "validated": {
            "type": "boolean",
            "example": false
          },
          "validationCount": {
            "type": "number",
            "example": 1
          },
          "validationRequired": {
            "type": "number",
            "example": 1
          }
        }
      },
      "AgreementListDto": {
        "title": "AgreementListDto",
        "required": [
          "items",
          "numberOfItems",
          "numberOfItemsByPage",
          "page",
          "total",
          "totalInvitations"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgreementListItemDto"
            },
            "description": "Array of agreements"
          },
          "numberOfItems": {
            "type": "number",
            "description": "Number of items in the response",
            "example": 36
          },
          "numberOfItemsByPage": {
            "type": "number",
            "description": "Maximum number of items in a single page",
            "example": 25
          },
          "page": {
            "type": "number",
            "description": "Current page number",
            "example": 0
          },
          "result": {
            "type": "string",
            "description": "Result status",
            "example": "success"
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "Total number of documents and invitations matching the request parameters",
            "example": 10
          },
          "totalInvitations": {
            "type": "integer",
            "format": "int64",
            "description": "Total number of invitations",
            "example": 2
          }
        }
      },
      "AgreementsCountDto": {
        "title": "AgreementsCountDto",
        "type": "object",
        "properties": {
          "draftCount": {
            "type": "number",
            "description": "Count of drafts",
            "example": 42
          },
          "brokenCount": {
            "type": "number",
            "description": "Count of broken agreements",
            "example": 42
          },
          "archivedBrokenCount": {
            "type": "number",
            "description": "Count of broken archived agreements",
            "example": 42
          },
          "contractCount": {
            "type": "number",
            "description": "Count of contracts",
            "example": 42
          },
          "negotiationCount": {
            "type": "number",
            "description": "Count of agreements with status negotiation",
            "example": 42
          },
          "signingCount": {
            "type": "number",
            "description": "Count of agreements with status signing",
            "example": 42
          },
          "templateCount": {
            "type": "number",
            "description": "Count of templates",
            "example": 42
          },
          "trashedCount": {
            "type": "number",
            "description": "Count of trashed agreements",
            "example": 42
          },
          "validationCount": {
            "type": "number",
            "description": "Count of agreements with status validation",
            "example": 42
          },
          "inboxCount": {
            "type": "number",
            "description": "Total agreement count",
            "example": 42
          }
        }
      },
