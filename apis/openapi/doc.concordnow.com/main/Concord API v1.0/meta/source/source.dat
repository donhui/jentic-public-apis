              "format": "int64"
            }
          },
          {
            "name": "emails",
            "in": "query",
            "description": "The emails of the potential users.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "roleId",
            "in": "query",
            "description": "Role ID in organization. If not provided, the value will be the default role's id\nin the organization.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionDto"
                }
              }
            }
          }
        }
