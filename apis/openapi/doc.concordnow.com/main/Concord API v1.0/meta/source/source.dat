    "/organizations/{organizationId}/agreements/{agreementUid}/rules/{id}": {
      "parameters": [
        {
          "in": "path",
          "name": "organizationId",
          "description": "Organization ID",
          "required": true,
          "schema": {
            "type": "integer",
            "format": "int64"
          }
        },
        {
          "name": "agreementUid",
          "in": "path",
          "description": "Agreement UID.",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/AgreementUid"
          }
        },
        {
          "name": "id",
          "in": "path",
          "description": "Rule ID.",
          "required": true,
          "schema": {
            "type": "integer",
            "format": "int64"
          }
        }
      ],
      "patch": {
        "tags": [
          "Agreement"
        ],
        "summary": "Send an action to a rule for the agreement",
        "description": "Performs an action on a specific rule in the agreement approval workflow. This allows users to accept, refuse, cancel, or request validation for a rule.",
        "operationId": "Sendanactiontoarulefortheagreement",
        "requestBody": {
          "description": "Rule action to perform",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "ACCEPT",
                      "REFUSE",
                      "CANCEL",
                      "ASK"
                    ],
                    "description": "The action to perform on the rule:\n* `ACCEPT` - Accept/approve the rule\n* `REFUSE` - Refuse/reject the rule\n* `CANCEL` - Cancel an existing approval or refusal\n* `ASK` - Ask for validation of the rule\n"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Action successfully performed on the rule"
          }
        }
      }
    },
