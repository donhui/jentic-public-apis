      "RuleType": {
        "title": "RuleType",
        "description": "Determines how validations within a rule are applied:\n* `ONE` - Only one validation needs to be approved for the rule to be considered approved\n* `ALL` - All validations must be approved for the rule to be considered approved\n",
        "enum": [
          "ONE",
          "ALL"
        ],
        "type": "string",
        "example": "ALL"
      },
      "ValidationStatus": {
        "title": "ValidationStatus",
        "description": "Represents the approval status:\n* `APPROVED` - The validation has been approved\n* `REFUSED` - The validation has been rejected\n* `PENDING` - The validation is awaiting approval\n",
        "enum": [
          "REFUSED",
          "PENDING",
          "APPROVED"
        ],
        "type": "string",
        "example": "PENDING"
      },
      "RuleUserDto": {
        "title": "RuleUserDto",
        "allOf": [
          {
            "$ref": "#/components/schemas/UserDto"
          },
          {
            "type": "object",
            "required": [
              "organizationId"
            ],
            "properties": {
              "organizationId": {
                "type": "integer",
                "format": "int64",
                "example": 69
              }
            }
          }
        ]
      },
      "RuleUserGroupDto": {
        "title": "RuleUserGroupDto",
        "description": "Represents a user group assigned to a validation rule (response)",
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier of the group",
            "example": 42
          },
          "name": {
            "type": "string",
            "description": "Display name of the group",
            "example": "Legal Team"
          },
          "description": {
            "type": "string",
            "description": "Description of the group's purpose",
            "example": "Legal department approval group"
          },
          "organizationId": {
            "type": "integer",
            "format": "int64",
            "description": "ID of the organization this group belongs to",
            "example": 123
          },
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserDto"
            },
            "description": "List of users belonging to this group"
          }
        }
      },
      "ValidationDto": {
        "title": "ValidationDto",
        "description": "Represents a specific validation requirement within a rule (response)",
        "oneOf": [
          {
            "title": "UserValidation",
            "type": "object",
            "required": [
              "type",
              "user"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64",
                "description": "Unique identifier for this validation",
                "example": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "USER"
                ],
                "description": "Indicates this is a user validation"
              },
              "status": {
                "$ref": "#/components/schemas/ValidationStatus",
                "description": "The current approval status for this validation"
              },
              "user": {
                "$ref": "#/components/schemas/RuleUserDto",
                "description": "The user assigned to this validation"
              }
            }
          },
          {
            "title": "GroupValidation",
            "type": "object",
            "required": [
              "type",
              "group"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64",
                "description": "Unique identifier for this validation",
                "example": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "GROUP"
                ],
                "description": "Indicates this is a group validation"
              },
              "status": {
                "$ref": "#/components/schemas/ValidationStatus",
                "description": "The current approval status for this validation"
              },
              "group": {
                "$ref": "#/components/schemas/RuleUserGroupDto",
                "description": "The group assigned to this validation"
              },
              "user": {
                "$ref": "#/components/schemas/RuleUserDto",
                "description": "The user who performed the validation (if already validated)"
              }
            }
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "USER": "#/components/schemas/0",
            "GROUP": "#/components/schemas/1"
          }
        }
      },
      "ActivationDto": {
        "title": "ActivationDto",
        "type": "object",
        "properties": {
          "expression": {
            "type": "object"
          }
        }
      },
      "RuleGetDto": {
        "title": "RuleGetDto",
        "description": "Represents a single approval rule within an approval workflow",
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "description": "Unique identifier for the rule",
            "example": 17
          },
          "type": {
            "$ref": "#/components/schemas/RuleType",
            "description": "Determines how validations are applied - either ALL validations must be approved or only ONE is needed"
          },
          "status": {
            "$ref": "#/components/schemas/ValidationStatus",
            "description": "The current status of the rule (APPROVED, REFUSED, or PENDING)"
          },
          "validations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationDto"
            },
            "description": "List of validations defining who needs to approve this rule. Each validation can be assigned to a user or a group."
          },
          "active": {
            "type": "boolean",
            "description": "Indicates whether the rule is currently active. If conditions are defined, the rule is only active when conditions are met."
          },
          "requestSent": {
            "type": "boolean",
            "description": "Indicates whether an approval request has been sent for this rule. Used to track notification status."
          },
          "conditions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ActivationDto"
            },
            "description": "Optional conditions that determine when this rule is active. If no conditions are specified, the rule is always active."
          }
        }
      },
      "ApprovalStatus": {
        "title": "ApprovalStatus",
        "description": "Represents the overall approval status of an agreement:\n* `APPROVED` - The agreement has been fully approved according to all active rules\n* `REFUSED` - The agreement has been rejected by at least one required approver\n* `PENDING` - The agreement is still awaiting approval from one or more approvers\n",
        "enum": [
          "REFUSED",
          "PENDING",
          "APPROVED"
        ],
        "type": "string",
        "example": "PENDING"
      },
      "AgreementApprovalDto": {
        "title": "AgreementApprovalDto",
        "description": "Represents the approval workflow for an agreement, defining the validation rules and approval process",
        "required": [
          "blockThirdPartySignature"
        ],
        "type": "object",
        "properties": {
          "organizationApprovalId": {
            "type": "integer",
            "format": "int64",
            "description": "ID of the organization-level approval workflow template that this agreement approval is based on. If set, the agreement uses a predefined organizational workflow rather than a custom one.",
            "example": 234
          },
          "organizationApprovalTitle": {
            "type": "string",
            "description": "Title of the organization-level approval workflow template",
            "example": "Legal Department Approval Process"
          },
          "blockThirdPartySignature": {
            "type": "boolean",
            "description": "When true, prevents external users (non-organization members) from signing the agreement until all validation rules are satisfied. This ensures internal approvals are completed before external signatures are collected.",
            "example": true
          },
          "autoNotificationEnabled": {
            "type": "boolean",
            "description": "Controls whether automatic notifications are sent when validation is required. When enabled, the system proactively notifies relevant users or groups when their approval is needed.",
            "example": true
          },
          "rules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RuleGetDto"
            },
            "description": "List of approval rules that define who needs to approve the agreement and under what conditions. Each rule can be assigned to users or groups and has its own validation status."
          },
          "status": {
            "$ref": "#/components/schemas/ApprovalStatus",
            "description": "The overall approval status of the agreement. Derived from the validation states of all rules and determines whether the agreement can proceed to signing."
          }
        }
      },
