          "createdAt",
          "contact",
          "authorities",
          "name",
          "hasAcceptedTerms",
          "extern",
          "passwordExpired",
          "passwordCompliant",
          "newUserId"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "email": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "hasPassword": {
            "type": "boolean"
          },
          "hasPicture": {
            "type": "boolean"
          },
