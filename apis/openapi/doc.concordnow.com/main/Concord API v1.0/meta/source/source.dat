    "/organizations/{organizationId}/agreements/{agreementUid}/attachments": {
      "parameters": [
        {
          "in": "path",
          "name": "organizationId",
          "description": "Organization ID",
          "required": true,
          "schema": {
            "type": "integer",
            "format": "int64"
          }
        },
        {
          "name": "agreementUid",
          "in": "path",
          "description": "Agreement UID.",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/AgreementUid"
          }
        }
      ],
      "get": {
        "tags": [
          "Agreement"
        ],
        "summary": "List the attachments",
        "description": "The uid parameter in the endpoint is the uid associated with the agreement.",
        "operationId": "Listtheattachments",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Listtheattachmentsresponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Agreement"
        ],
        "summary": "Create an attachment",
        "description": "The uid parameter in the endpoint is the uid associated with the agreement. To create an new non existing attachment a POST request is used.\nThe body of the request should be multipart encoded.\nThree optional parameters name, description and isSignedContract can be specified.\nWhen present, the name should be an UTF-8 string smaller than 256 characters.\nWhen present, the description should be an UTF-8 string smaller than 1024 characters.\nWhen present, the isSignedContract should be a boolean. It indicates whether the attachment is the signed contract itself or not.",
        "operationId": "Createanattachment",
        "requestBody": {
          "description": "",
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "name"
                  },
                  "description": {
                    "type": "string",
                    "example": "description"
                  },
                  "isSignedContract": {
                    "type": "boolean"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Createanattachmentresponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{organizationId}/agreements/{agreementUid}/attachments/{id}": {
      "parameters": [
        {
          "in": "path",
          "name": "organizationId",
          "description": "Organization ID",
          "required": true,
          "schema": {
            "type": "integer",
            "format": "int64"
          }
        },
        {
          "name": "agreementUid",
          "in": "path",
          "description": "Agreement UID.",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/AgreementUid"
          }
        },
        {
          "name": "id",
          "in": "path",
          "description": "Attachment ID.",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "tags": [
          "Agreement"
        ],
        "summary": "Get an attachment",
        "description": "The uid parameter in the endpoint is the uid associated with the agreement.\nThe id parameter in the endpoint identifies the attachment within the agreement.\nTo retrieve the id associated within an agreement, see above.",
        "operationId": "Getanattachment",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "The body of the answer will contain the attachment data.\nNote that\n  the answer contains a Content-Transfer-Encoding header with a value of binary\n  the answer contains a Content-Type header with a value of application/force-download;charset=UTF-8\n  the answer may or may not contain a Content-Length header\n  caching header (Expires, pragma no cache) may or may not be present\nThe value of the above headers can change without notice."
                },
                "example": "The body of the answer will contain the attachment data.\nNote that\n  the answer contains a Content-Transfer-Encoding header with a value of binary\n  the answer contains a Content-Type header with a value of application/force-download;charset=UTF-8\n  the answer may or may not contain a Content-Length header\n  caching header (Expires, pragma no cache) may or may not be present\nThe value of the above headers can change without notice."
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Agreement"
        ],
        "summary": "Update an attachment",
        "description": "The uid parameter in the endpoint is the uid associated with the agreement.\nThe id parameter in the endpoint identifies the attachment within the agreement.\nUpdates the name and description of an attachment.",
        "operationId": "Updateanattachment",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "maxLength": 256
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 1024
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": ""
          }
        }
      },
      "delete": {
        "tags": [
          "Agreement"
        ],
        "summary": "Delete an attachment",
        "description": "The uid parameter in the endpoint is the uid associated with the agreement.\nThe id parameter in the endpoint identifies the attachment within the agreement.\nTo retrieve the id associated within an agreement, see above.",
        "operationId": "Deleteanattachment",
        "responses": {
          "204": {
            "description": ""
          }
        }
      }
    },
