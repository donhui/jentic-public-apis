      "GuestInvitationOtpExemptionPeriod": {
        "title": "GuestInvitationOtpExemptionPeriod",
        "type": "string",
        "description": "Period during which external guests are exempt from OTP verification after receiving their invitation.\nDefines how long a guest can access agreements without requiring OTP verification.\n\n- **TEN_MINUTES**: Guest exempt from OTP for 10 minutes after invitation sent\n- **ONE_DAY**: Guest exempt from OTP for 1 day after invitation sent\n- **TWO_WEEKS**: Guest exempt from OTP for 2 weeks after invitation sent\n- **ONE_MONTH**: Guest exempt from OTP for 1 month (30 days) after invitation sent\n- **SIX_MONTHS**: Guest exempt from OTP for 6 months (180 days) after invitation sent\n",
        "enum": [
          "TEN_MINUTES",
          "ONE_DAY",
          "TWO_WEEKS",
          "ONE_MONTH",
          "SIX_MONTHS"
        ],
        "example": "ONE_DAY"
      },
      "FullOrganizationDto": {
        "title": "FullOrganizationDto",
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string",
            "description": "Length 1-191",
