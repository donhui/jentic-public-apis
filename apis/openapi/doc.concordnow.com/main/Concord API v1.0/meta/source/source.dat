      "OrganizationEvent": {
        "title": "Event",
        "required": [
          "id",
          "createdAt",
          "type",
          "actor",
          "event"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "createdAt": {
            "type": "integer",
            "format": "int64"
          },
          "type": {
            "type": "string",
            "enum": [
              "ORGANIZATION_ADD_USER",
              "ORGANIZATION_ADD_SUBSIDIARY",
              "AGREEMENT_CREATE",
              "AGREEMENT_DELETE",
              "AGREEMENT_INVITE",
              "AGREEMENT_UPDATE",
              "AGREEMENT_SIGN",
              "AGREEMENT_DELAYED",
              "AGREEMENT_JOIN",
              "AGREEMENT_VIEW",
              "AGREEMENT_OPENED_DOWNLOAD_LINK"
            ]
          },
          "actor": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/EventDataOrganization"
              },
              {
                "$ref": "#/components/schemas/EventDataUser"
              }
            ]
          },
          "event": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/EventDataAgreement"
              },
              {
                "$ref": "#/components/schemas/EventDataOrganization"
              },
              {
                "$ref": "#/components/schemas/EventDataUser"
              }
            ]
          }
        },
        "example": {
          "id": 128538,
          "createdAt": 1510657155000,
          "type": "AGREEMENT_SIGN",
          "actor": {
            "name": "John Doe",
            "id": 70,
            "type": "USER",
            "hasAvatar": true,
            "email": "john@doe.com",
            "job": "none",
            "organization": "Acme Corp"
          },
          "event": {
            "name": "Non-Disclosure Agreement",
            "id": "02xjNQD6nBXcaVLCJJGfN0",
            "type": "AGREEMENT",
            "status": "NEGOTIATION"
          }
        }
      },
