    "/organizations/{organizationId}/events": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "Get List all organization events",
        "description": "Only a user with the Administrator role can list events from an organization.",
        "operationId": "GetListallorganizationevents",
        "parameters": [
          {
            "in": "path",
            "name": "organizationId",
            "description": "Organization ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "The start date (yyyy-MM-dd format). The range between `start` and `end` **must** be lesser or equals to 7 days.",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "The end date (yyyy-MM-dd format). The range between `start` and `end` **must** be lesser or equals to 7 days.",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string",
              "example": "2024-01-07"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetListallorganizationeventsresponse"
                }
              }
            }
          }
        }
      }
    },
