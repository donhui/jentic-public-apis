      "PartialOrganizationDto": {
        "title": "PartialOrganizationDto",
        "type": "object",
        "required": [
          "id",
          "newOrganizationId",
          "name"
        ],
        "properties": {
          "id": {
            "type": "number",
            "example": 69
          },
          "name": {
            "type": "string",
            "description": "Length 1-191",
            "example": "orgName"
          }
        }
      },
      "UserGroupDto": {
        "title": "UserGroupDto",
        "required": [
          "id",
          "name",
          "invitations",
          "users"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 69,
            "readOnly": true
          },
          "name": {
            "type": "string",
            "example": "groupName"
          },
          "description": {
            "type": "string",
            "example": "desc"
          },
          "users": {
