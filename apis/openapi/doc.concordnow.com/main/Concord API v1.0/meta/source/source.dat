      "SignatureInfoSlotGet": {
        "title": "SignatureInfoSlot",
        "description": "Details of a signature slot.",
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "slot id",
            "example": 33
          },
          "reservation": {
            "$ref": "#/components/schemas/SlotReservationGet"
          },
          "signature": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "format": "date-time"
              },
              "type": {
                "description": "Type of signature",
                "type": "string",
                "enum": [
                  "TEXT",
                  "DRAWN_IMAGE"
                ]
              },
              "info": {
                "description": "Details on signatory.",
                "type": "object",
                "properties": {
                  "name": {
                    "description": "Signatory name.",
                    "type": "string",
                    "example": "John Smith"
                  },
                  "organization": {
                    "description": "Signatory organization name.",
                    "type": "string",
                    "example": "Acme Corp"
                  },
                  "job": {
                    "description": "Signatory job.",
                    "type": "string",
                    "example": "Lawyer"
                  },
                  "email": {
                    "description": "Signatory user email.",
                    "type": "string",
                    "format": "email"
                  },
                  "image": {
                    "description": "Signature image when directly drawing signature.",
                    "type": "string",
                    "example": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAkwAAABMCAYAAACf..."
                  },
                  "font": {
                    "description": "Signature font.",
                    "type": "string",
                    "example": "daniel"
                  },
                  "signature": {
                    "description": "Signature text.",
                    "type": "string",
                    "example": "John Smith"
                  },
                  "timezone": {
                    "description": "Timezone used at signature time (IANA identifier)",
                    "type": "string",
                    "example": "America/Chicago"
                  }
                }
              }
            }
          }
        }
      },
