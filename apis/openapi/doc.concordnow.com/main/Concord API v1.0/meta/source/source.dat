    "/organizations/{organizationId}/agreements/{agreementUid}/approval": {
      "parameters": [
        {
          "in": "path",
          "name": "organizationId",
          "description": "Organization ID",
          "required": true,
          "schema": {
            "type": "integer",
            "format": "int64"
          }
        },
        {
          "name": "agreementUid",
          "in": "path",
          "description": "Agreement UID.",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/AgreementUid"
          }
        }
      ],
      "get": {
        "tags": [
          "Agreement"
        ],
        "summary": "Get the approval workflow for an agreement",
        "description": "Retrieves the current approval workflow for the specified agreement, including all rules and their validation status.\n\nAn approval workflow governs who needs to approve the agreement before it can proceed to signatures. It consists of:\n- A setting to block third-party signatures until approval is complete\n- A list of rules defining who needs to approve and in what order\n- The current approval status\n\nEach rule has a type (ONE or ALL) that determines if one or all validations are needed for approval.",
        "operationId": "GetAgreementApproval",
        "responses": {
          "200": {
            "description": "Returns the approval workflow for the agreement, including rules and validation status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgreementApprovalDto"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Agreement"
        ],
        "summary": "Replace any approval",
        "description": "To replace an approval, the field organizationApprovalId and the field rules are mutually exclusive.\nIf a request contains both fields, the organizationApprovalId is used and the rules array is ignored.\nIn case the approval contains rules with activations, the field 'active' is calculated and set by the system.",
        "operationId": "UpsertAgreementApproval",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgreementApprovalDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": ""
          }
        }
      },
      "delete": {
        "tags": [
          "Agreement"
        ],
        "summary": "Discard approval from agreement",
        "description": "",
        "operationId": "DeleteAgreementApproval",
        "responses": {
          "204": {
            "description": ""
          }
        }
      }
    },
