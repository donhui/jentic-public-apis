  "webhooks": {
    "newAgreement": {
      "post": {
        "tags": [
          "Webhooks"
        ],
        "security": [],
        "summary": "Agreement event",
        "description": "Those events are triggered when an action occurs on an agreement.<br> If you subscribed to the triggered event, you will be notified on the URL you specified.<br><br> [Here is the documentation to enable Webhooks on you Concord account](https://help.concord.app/hc/en-us/articles/4417525871508-create-a-webhook-integration)",
        "operationId": "postAgreementEvent",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Return a 200 status to indicate that the data was received successfully"
          },
          "201": {
            "description": "Return a 201 status to indicate that the data was received successfully"
          },
          "202": {
            "description": "Return a 202 status to indicate that the data was received successfully"
          },
          "203": {
            "description": "Return a 203 status to indicate that the data was received successfully"
          },
          "204": {
            "description": "Return a 204 status to indicate that the data was received successfully"
          },
          "default": {
            "description": "Any other status code will be handled as an error by our system"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuthentication": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "Users authenticate themselves through the HTTP Header X-API-KEY. You can generate as many API Keys as needed from your Concord account.\nIf the HTTP Header is missing or if the API Key is invalid, the HTTP Response will be 401 Unauthorized.",
        "x-jentic-source-url": "https://api.doc.concordnow.com/"
      }
    },
    "schemas": {
      "0": {
        "title": "UserValidation",
        "type": "object",
        "required": [
          "type",
          "user"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for this validation",
            "example": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "USER"
            ],
            "description": "Indicates this is a user validation"
          },
          "status": {
            "$ref": "#/components/schemas/ValidationStatus",
            "description": "The current approval status for this validation"
          },
          "user": {
            "$ref": "#/components/schemas/RuleUserDto",
            "description": "The user assigned to this validation"
          }
        }
      },
      "1": {
        "title": "GroupValidation",
        "type": "object",
        "required": [
          "type",
          "group"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for this validation",
            "example": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "GROUP"
            ],
            "description": "Indicates this is a group validation"
          },
          "status": {
            "$ref": "#/components/schemas/ValidationStatus",
            "description": "The current approval status for this validation"
          },
          "group": {
            "$ref": "#/components/schemas/RuleUserGroupDto",
            "description": "The group assigned to this validation"
          },
          "user": {
            "$ref": "#/components/schemas/RuleUserDto",
            "description": "The user who performed the validation (if already validated)"
          }
        }
      },
      "AgreementUid": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 22,
            "maxLength": 22,
            "description": "Concord agreement unique identifier. (new format)"
          },
          {
            "type": "string",
            "minLength": 6,
            "maxLength": 6,
            "description": "Concord agreement unique identifier. (old format)"
          }
        ],
        "examples": [
          "01sp9L4YEZNcLHaSV8447N",
          "G4VIX7"
        ]
      },
      "AgreementCreationStatusEnum": {
        "title": "AgreementCreationStatusEnum",
        "enum": [
          "DRAFT",
          "TEMPLATE",
          "CONTRACT"
        ],
        "type": "string"
      },
      "ParametersSource": {
        "type": "string",
        "description": "Source of parameters for the document",
        "enum": [
          "NONE",
          "EXCEL",
          "SALESFORCE",
          "HUBSPOT",
          "INTAKE"
        ]
      },
      "AgreementCreate": {
        "title": "CreateanewAgreementrequest",
        "type": "object",
        "properties": {
          "source": {
            "type": "object",
            "description": "Source agreement information. Used when an agreement is created from another agreement. Currently only contract and templates are supported as source agreement.\nIt also allows to supply parameters for template containing variables.\nIt allows draft creation from template and copying a contract.\n",
            "properties": {
              "uid": {
                "$ref": "#/components/schemas/AgreementUid"
              },
              "templatingParameters": {
                "description": "Key-value map for templating parameters replacement when creating an agreement from a parameterized template.\n",
                "type": "object",
                "additionalProperties": {
                  "type": "string",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "text": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "folderId": {
            "type": "number",
            "example": 456
          },
          "status": {
            "$ref": "#/components/schemas/AgreementCreationStatusEnum"
          },
          "parametersSource": {
            "$ref": "#/components/schemas/ParametersSource"
          },
          "title": {
            "type": "string",
            "example": "Non-Disclosure Agreement"
          },
          "description": {
            "type": "string",
            "example": "This NDA covers the company for 10 years."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": ""
          }
        }
      },
      "ContractLibraryStatusEnum": {
        "title": "ContractLibraryStatusEnum",
        "enum": [
          "DRAFT",
          "VALIDATION",
          "NEGOTIATION",
          "SIGNING",
          "UNKNOWN_CONTRACT",
          "FUTURE_CONTRACT",
          "CURRENT_CONTRACT",
          "COMPLETED_CONTRACT",
          "COMPLETED_CANCEL_CONTRACT",
          "COMPLETED_CONTRACT_RENEWABLE",
          "BROKEN",
          "TRASHED",
          "NEGO_INVITE",
          "TEMPLATE",
          "TEMPLATE_AUTO"
        ],
        "type": "string"
      },
      "AgreementAccessType": {
        "type": "string",
        "enum": [
          "DIRECT",
          "FOLDER",
          "ORGANIZATION",
          "TAG"
        ],
        "example": "FOLDER"
      },
      "DocumentType": {
        "type": "string",
        "enum": [
          "HTML",
          "PDF",
          "WORD_MODE",
          "WORD_LIVE_EDITING",
          "SIGNED"
        ],
        "example": "PDF"
      },
      "OrganizationFieldItemDto": {
        "title": "OrganizationFieldItemDto",
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "FieldDtoBase": {
        "title": "FieldDtoBase",
