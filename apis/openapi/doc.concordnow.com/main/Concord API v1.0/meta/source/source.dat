          },
          "region": {
            "$ref": "#/components/schemas/StoreRegion"
          },
          "subsidiaries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "number",
            "description": "epoch timestamp ms",
