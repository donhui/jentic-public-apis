    "/organizations/{organizationId}/agreements/{agreementUid}/signature/request": {
      "post": {
        "tags": [
          "Signature"
        ],
        "summary": "Request signature",
        "description": "Requests signers to sign. </br> If the signer is not yet a member of the agreement, it will either: </br> - add the signer to the agreement and request the signature (if the signer is a colleague in the organization that created the agreement)</br> - send an email invitation to the signer (if the signer is external to the creator's organization)</br> If signing order is enabled, the request will be sent to the next signer in the signing order.",
        "operationId": "RequestSignature",
        "parameters": [
          {
            "in": "path",
            "name": "organizationId",
            "description": "Organization ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
          },
          {
            "in": "path",
            "name": "agreementUid",
            "description": "Agreement UID",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/AgreementUid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully requested signatures.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestSignaturesResponse"
                }
              }
            }
          }
        }
      }
    },
