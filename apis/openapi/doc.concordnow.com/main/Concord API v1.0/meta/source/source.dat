      "UserSettingsGetDto": {
        "title": "UserSettingsGetDto",
        "type": "object",
        "properties": {
          "mobile": {
            "type": "string",
            "example": "+33 6 00 00 00 00"
          },
          "mobileCode": {
            "type": "number",
            "example": 33
          },
          "deadlinesNotificationDays": {
            "type": "number",
            "description": "Min: 7 Max: 365",
            "example": 10
          },
          "deadlinesNotificationEnabled": {
            "type": "boolean",
            "example": true
          },
          "displayCorporationSuggestions": {
            "type": "boolean",
            "example": true
          },
          "newDocumentShortcuts": {
            "type": "boolean",
            "example": true
          },
          "name": {
            "type": "string",
            "description": "Length 3-220",
            "example": "John Doe"
          },
          "language": {
            "type": "string",
            "description": "ISO 639-1",
            "example": "fr"
          },
          "phone": {
            "type": "string",
            "example": "+33 1 00 00 00 00"
          },
          "phoneCode": {
            "type": "number",
            "example": 33
          },
          "notificationRules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NotificationRuleDto"
            },
            "description": "Rules notification"
          },
          "dateFormat": {
            "type": "string",
            "description": "Date format string compatible with the <a href=\"https://docs.oracle.com/en/java/javase/17/docs/api/java.base/java/text/SimpleDateFormat.html\">java date format standards</a>",
            "example": "MM/dd/yyyy"
          }
        }
      },
