      "UserOrganizationDto": {
        "title": "UserOrganizationDto",
        "type": "object",
        "required": [
          "user",
          "id",
          "newOrganizationId",
          "name",
          "subscription",
          "createdAt",
          "isParent",
          "isSubsidiary"
        ],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserInfosDto"
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 69
          },
          "newOrganizationId": {
            "type": "string",
            "minLength": 22,
            "maxLength": 22,
            "description": "Unique identifier for the organization ID",
            "example": "02z1s7yQ9dTKQDO8hGwDMt"
          },
          "name": {
            "type": "string",
            "description": "Length 1-191",
            "example": "orgName"
          },
          "subscription": {
            "$ref": "#/components/schemas/SubscriptionEnum"
          },
          "createdAt": {
            "type": "number",
            "description": "Creation date as Unix timestamp in milliseconds",
            "example": 1456763982000
          },
          "isParent": {
            "type": "boolean"
          },
          "isSubsidiary": {
            "type": "boolean"
          },
          "parentId": {
            "type": "integer",
            "format": "int64"
          },
          "subsidiaries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserOrganizationSubsidiaryDto"
            }
          },
