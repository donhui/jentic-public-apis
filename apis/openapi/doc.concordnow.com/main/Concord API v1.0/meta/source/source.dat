      "ActivityAudit": {
        "title": "ActivityAudit",
        "required": [
          "id",
          "organization",
          "createdAt",
          "action",
          "status",
          "params",
          "userOrganization",
          "visibility"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "organization": {
            "$ref": "#/components/schemas/ActivityOrganization"
          },
          "createdAt": {
            "type": "integer",
            "format": "int64"
          },
          "action": {
            "type": "string",
            "enum": [
              "AGREEMENT_REVOKE_SIGNATURE",
              "AGREEMENT_SIGNATURE_FINALIZE",
              "AGREEMENT_SIGNING_AUTHENTICATION",
              "AGREEMENT_DOCUSIGN_SIGNING",
              "AGREEMENT_DOCUSIGN_COMPLETED",
              "AGREEMENT_OTP_SENT",
              "AGREEMENT_OTP_VERIFIED",
              "AGREEMENT_JOIN",
              "AGREEMENT_VIEW",
              "AGREEMENT_MOVE",
              "AGREEMENT_OPENED_DOWNLOAD_LINK",
              "AGREEMENT_ACTIVATE_SHAREDLINK",
              "AGREEMENT_WORKFLOW_CREATE",
              "AGREEMENT_WORKFLOW_DELETE",
              "AGREEMENT_WORKFLOW_UPDATE",
              "AGREEMENT_WORKFLOW_RESET",
              "AGREEMENT_ORGANIZATION_WORKFLOW_CREATE",
              "AGREEMENT_ORGANIZATION_WORKFLOW_DELETE",
              "VALIDATION_ASK",
              "VALIDATION_AUTO_ASK",
              "VALIDATION_REFUSE",
              "VALIDATION_ACCEPT",
              "VALIDATION_CANCEL_APPROVAL",
              "VALIDATION_CANCEL_REFUSAL",
              "CONTRACT_ADD",
              "AGREEMENT_CLAUSES_MODIFY",
              "CONTRACT_LIFE_CYCLE_MODIFY",
              "CONTRACT_MODIFY",
              "CONTRACT_RENEW",
              "CONTRACT_CANCEL_RENEW",
              "DOWNLOAD_AGREEMENT_WORD",
              "DOWNLOAD_AGREEMENT_PDF",
              "DOWNLOAD_AGREEMENT_SIGNATURE_CERTIFICATE",
              "DOWNLOAD_AGREEMENT_WORD_SIGNED",
              "DOWNLOAD_AGREEMENT_IMPORTED_SIGNED",
              "CONTRACT_RESILIATE",
              "CONTRACT_CANCEL_RESILIATE",
              "NEGOTIATION_CREATE",
              "NEGOTIATION_NEW_VERSION",
              "NEGOTIATION_APPROVE",
              "NEGOTIATION_BREAK_NEGOTIATION",
              "NEGOTIATION_LEAVE",
              "NEGOTIATION_INVITE_USER",
              "NEGOTIATION_GO_TO_NEGO",
              "NEGOTIATION_BREAK_VALIDATION",
              "NEGOTIATION_ATTACH_FILE",
              "NEGOTIATION_DELETTE_ATTACHED_FILE",
              "NEGOTIATION_REMOVE_INVITE",
              "NEGOTIATION_INVITE_DELAYED",
              "NEGOTIATION_REMOVE_DELAYED",
              "NEGOTIATION_REMOVE_ACCESS",
              "NEGOTIATION_MOVE_TO_SIGNING",
              "INVITATION_READ",
              "INVITATION_BOUNCED",
              "DRAFT_CREATE",
              "DRAFT_NEW_VERSION",
              "DRAFT_INVITE_DELAYED",
              "DRAFT_REMOVE_DELAYED",
              "SENT_TO_DOCUSIGN",
              "SENT_TO_GOOGLE_DOCS",
              "TEMPLATE_CREATE",
              "TEMPLATE_NEW_VERSION",
              "AGREEMENT_SIGNATURE_REQUIRE",
              "AGREEMENT_SIGNATURE_REQUIRE_AUTO",
              "ORGANIZATION_CLAUSE_UPDATE",
              "SIGNATURE_BLOCKS_ENABLED",
              "SIGNATURE_BLOCKS_DISABLED",
              "ORGANIZATION_DELETE",
              "ORGANIZATION_ADD",
              "ORGANIZATION_MODIFY",
              "USER_DELETE",
              "USER_ADD",
              "USER_MODIFY",
              "DOCUMENT_DELETE",
              "CONTRACT_DELETE",
              "CLAUSE_DELETE",
              "DOCUMENT_ADD",
              "CLAUSE_ADD",
              "CONTRACT_MAIN_CLAUSES_MODIFY",
              "CONTRACT_FINANCIAL_CLAUSES_MODIFY",
              "CONTRACT_GENERAL_INFORMATION_MODIFY",
              "DOCUMENT_MODIFY",
              "CLAUSE_MODIFY",
              "CONTRACT_UPLOAD",
              "DOCUMENT_DOWNLOAD",
              "CONTRACT_LINK_UPDATE",
              "NEGOTIATION_REVOKE_APPROVAL",
              "NEGOTIATION_BACK_TO_NEGOTIATION",
              "NEGOTIATION_ACCEPT_INVITATION",
              "NEGOTIATION_REFUSE_INVITATION",
              "NEGOTIATION_BACK_TO_VALIDATION"
            ],
            "description": "Audit trail action:\n  * `AGREEMENT_REVOKE_SIGNATURE` - User reset all signatures\n  * `AGREEMENT_SIGNATURE_FINALIZE` - User finalized document signatures\n  * `AGREEMENT_SIGNING_AUTHENTICATION` - User signed using double authentication\n  * `AGREEMENT_DOCUSIGN_SIGNING` - Document in signing process with Docusign\n  * `AGREEMENT_DOCUSIGN_COMPLETED` - Document has been completed on Docusign\n  * `AGREEMENT_OTP_SENT` - OTP was created and sent to the guest\n  * `AGREEMENT_OTP_VERIFIED` - OTP was verified for the guest\n  * `AGREEMENT_JOIN` - User joined the contract (administrator)\n  * `AGREEMENT_VIEW` - User read the contract\n  * `AGREEMENT_MOVE` - User moved the document to\n  * `AGREEMENT_OPENED_DOWNLOAD_LINK` - User read the contract by downloading it from the invitation\n  * `AGREEMENT_ACTIVATE_SHAREDLINK` - User has activated the shareable link\n  * `AGREEMENT_WORKFLOW_CREATE` - User added a custom approval\n  * `AGREEMENT_WORKFLOW_DELETE` - User deleted the approval\n  * `AGREEMENT_WORKFLOW_UPDATE` - User edited the approval\n  * `AGREEMENT_WORKFLOW_RESET` - User has reset the document approval by\n  * `AGREEMENT_ORGANIZATION_WORKFLOW_CREATE` - User added a company approval\n  * `AGREEMENT_ORGANIZATION_WORKFLOW_DELETE` - User deleted a company approval\n  * `VALIDATION_ASK` - User sent a request for the approval\n  * `VALIDATION_AUTO_ASK` - Approval request for next step has been sent\n  * `VALIDATION_REFUSE` - User refused the approval\n  * `VALIDATION_ACCEPT` - User granted the approval\n  * `VALIDATION_CANCEL_APPROVAL` - User canceled the approval\n  * `VALIDATION_CANCEL_REFUSAL` - User canceled the refusal of approval\n  * `CONTRACT_ADD` - User added the contract\n  * `AGREEMENT_CLAUSES_MODIFY` - User changed the clauses of the contract\n  * `CONTRACT_LIFE_CYCLE_MODIFY` - User changed the contract's lifecycle\n  * `CONTRACT_MODIFY` - User changed the contract\n  * `CONTRACT_RENEW` - User renewed the contract\n  * `CONTRACT_CANCEL_RENEW` - User canceled the renewal of the contract\n  * `DOWNLOAD_AGREEMENT_WORD` - User exported Word document\n  * `DOWNLOAD_AGREEMENT_PDF` - User exported PDF document\n  * `DOWNLOAD_AGREEMENT_SIGNATURE_CERTIFICATE` - User exported signature certificate\n  * `DOWNLOAD_AGREEMENT_WORD_SIGNED` - User exported Word document (not e-signed)\n  * `DOWNLOAD_AGREEMENT_IMPORTED_SIGNED` - User exported document\n  * `CONTRACT_RESILIATE` - User terminated the contract\n  * `CONTRACT_CANCEL_RESILIATE` - User canceled the contract termination\n  * `NEGOTIATION_CREATE` - User created document in review\n  * `NEGOTIATION_NEW_VERSION` - User added a new version\n  * `NEGOTIATION_APPROVE` - User signed the contract\n  * `NEGOTIATION_BREAK_NEGOTIATION` - User broke the review\n  * `NEGOTIATION_LEAVE` - User left the review\n  * `NEGOTIATION_INVITE_USER` - User invited a user\n  * `NEGOTIATION_GO_TO_NEGO` - User moved document to review\n  * `NEGOTIATION_BREAK_VALIDATION` - User broke the review\n  * `NEGOTIATION_ATTACH_FILE` - User added the attachment\n  * `NEGOTIATION_DELETTE_ATTACHED_FILE` - User deleted the attachment\n  * `NEGOTIATION_REMOVE_INVITE` - User removed the invitation\n  * `NEGOTIATION_INVITE_DELAYED` - User saved an invitation for later for\n  * `NEGOTIATION_REMOVE_DELAYED` - User deleted the invitation saved for later for\n  * `NEGOTIATION_REMOVE_ACCESS` - User removed access to the contract for\n  * `NEGOTIATION_MOVE_TO_SIGNING` - User moved the document to sign\n  * `INVITATION_READ` - User read the invitation email\n  * `INVITATION_BOUNCED` - User invited an invalid email\n  * `DRAFT_CREATE` - User created draft\n  * `DRAFT_NEW_VERSION` - User added a new version\n  * `DRAFT_INVITE_DELAYED` - User saved an invitation for later for\n  * `DRAFT_REMOVE_DELAYED` - User deleted the invitation saved for later for\n  * `SENT_TO_DOCUSIGN` - User exported document to DocuSign\n  * `SENT_TO_GOOGLE_DOCS` - User exported document to Google Docs\n  * `TEMPLATE_CREATE` - User created template\n  * `TEMPLATE_NEW_VERSION` - User added a new version\n  * `AGREEMENT_SIGNATURE_REQUIRE` - User sent a request for signature to\n  * `AGREEMENT_SIGNATURE_REQUIRE_AUTO` - User has triggered auto-request for signature to\n  * `ORGANIZATION_CLAUSE_UPDATE` - User updated the library clause\n  * `SIGNATURE_BLOCKS_ENABLED` - User enabled the pre-set signature block\n  * `SIGNATURE_BLOCKS_DISABLED` - User disabled the pre-set signature block\n  * `ORGANIZATION_DELETE` - (Deprecated) User deleted an account\n  * `ORGANIZATION_ADD` - (Deprecated) User added the account\n  * `ORGANIZATION_MODIFY` - (Deprecated) User modified the account\n  * `USER_DELETE` - (Deprecated) User deleted a user\n  * `USER_ADD` - (Deprecated) User added a new user\n  * `USER_MODIFY` - (Deprecated) User modified the user\n  * `DOCUMENT_DELETE` - (Deprecated) User deleted the following document\n  * `CONTRACT_DELETE` - (Deprecated) User deleted the contract\n  * `DOCUMENT_ADD` - (Deprecated) User added document\n  * `CLAUSE_ADD` - (Deprecated) User added clause\n  * `CONTRACT_MAIN_CLAUSES_MODIFY` - (Deprecated) User changed the main clauses of the contract\n  * `CONTRACT_FINANCIAL_CLAUSES_MODIFY` - (Deprecated) User changed the financial terms of the contract\n  * `CONTRACT_GENERAL_INFORMATION_MODIFY` - (Deprecated) User changed this contract's general information\n  * `DOCUMENT_MODIFY` - (Deprecated) User changed document\n  * `CLAUSE_MODIFY` - (Deprecated) User changed clause\n  * `DOCUMENT_DOWNLOAD` - (Deprecated) User downloaded document\n  * `CONTRACT_LINK_UPDATE` - (Deprecated) User changed the contract's links\n  * `NEGOTIATION_REVOKE_APPROVAL` - (Deprecated) User asked for a return to reviews\n  * `NEGOTIATION_BACK_TO_NEGOTIATION` - (Deprecated) User asked for a return to reviews\n  * `NEGOTIATION_ACCEPT_INVITATION` - (Deprecated) User accepted the invitation\n  * `NEGOTIATION_REFUSE_INVITATION` - (Deprecated) User refused the invitation\n  * `NEGOTIATION_BACK_TO_VALIDATION` - (Deprecated) User asked for a return to reviews\n"
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "NEGOTIATION",
              "TEMPLATE",
              "CONTRACT"
            ]
          },
          "params": {
            "type": "string"
          },
          "creator": {
            "$ref": "#/components/schemas/ActivityActor"
          },
          "userOrganization": {
            "$ref": "#/components/schemas/ActivityUserOrganization"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "ALL",
              "COMPANY",
              "ME"
            ]
          }
        }
      },
      "GetActivitiesAuditResponse": {
        "title": "GetActivitiesAuditResponse",
        "required": [
          "activities"
        ],
        "type": "object",
        "properties": {
          "activities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ActivityAudit"
            }
          }
        }
      },
      "ActivityChat": {
        "title": "ActivityChat",
        "required": [
          "id",
          "createdAt",
          "action",
          "status",
          "params",
          "userOrganization",
          "visibility",
          "text",
          "type",
          "displayVersion"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "createdAt": {
            "type": "integer",
            "format": "int64"
          },
          "action": {
            "type": "string",
            "enum": [
              "DRAFT_TXT",
              "NEGOTIATION_TXT",
              "CONTRACT_TXT",
              "TEMPLATE_TXT"
            ],
            "description": "Chat message action:\n  * `DRAFT_TXT` - User posted a message on a draft\n  * `NEGOTIATION_TXT` - User posted a message on a document in review\n  * `CONTRACT_TXT` - User posted a message on a signed contract\n  * `TEMPLATE_TXT` - User posted a message on a template\n"
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "NEGOTIATION",
              "TEMPLATE",
              "CONTRACT"
            ]
          },
          "params": {
            "type": "string"
          },
          "userOrganization": {
            "$ref": "#/components/schemas/ActivityUserOrganization"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "ALL",
              "COMPANY",
              "ME"
            ]
          },
          "text": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "INVITATION",
              "CHAT"
            ]
          },
          "displayVersion": {
            "type": "string"
          }
        }
      },
      "GetActivitiesChatResponse": {
        "title": "GetActivitiesChatResponse",
        "required": [
          "activities"
        ],
        "type": "object",
        "properties": {
          "activities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ActivityChat"
            }
          }
        }
      },
      "WebHookIntegrationEvent": {
        "title": "WebHookIntegrationEvent",
        "type": "array",
        "items": {
          "type": "string",
          "description": "Events triggering webhook",
          "enum": [
            "AGREEMENT_EXECUTED",
            "AGREEMENT_NEW_SIGNATURE",
            "AGREEMENT_APPROVED",
            "AGREEMENT_EXPIRED",
            "AGREEMENT_CUSTOM_FIELDS_ADDED",
            "AGREEMENT_CUSTOM_FIELDS_UPDATED",
            "AGREEMENT_CUSTOM_FIELDS_DELETED",
            "AGREEMENT_LIFECYCLE_UPDATED",
            "AGREEMENT_CANCELLED",
            "AGREEMENT_BACK_TO_REVIEW"
          ]
        }
      },
      "WebHookIntegrationCreate": {
        "title": "WebHookIntegrationCreate",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Integration's display name",
            "example": "My webhook integration"
          },
          "events": {
            "$ref": "#/components/schemas/WebHookIntegrationEvent"
          },
          "customHeaderName": {
            "type": "string",
            "description": "Custom header name for webhook requests",
            "example": "Authorization"
          },
          "customHeaderValue": {
            "type": "string",
            "description": "Custom header value for webhook requests",
            "example": "Bearer token123"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook location"
          }
        }
      },
      "WebHookIntegrationGet": {
        "title": "WebHookIntegrationGet",
        "allOf": [
          {
            "$ref": "#/components/schemas/WebHookIntegrationCreate"
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64",
                "description": "Unique identifier"
              },
              "createdAt": {
                "type": "integer",
                "format": "int64",
                "description": "Creation timestamp in milliseconds"
              },
              "modifiedAt": {
                "type": "integer",
                "format": "int64",
                "description": "Last modification timestamp in milliseconds"
              },
              "lastAccessAt": {
                "type": "integer",
                "format": "int64",
                "description": "Last access timestamp in milliseconds"
              }
            }
          }
        ]
      },
      "WebHooksIntegrationsList": {
        "title": "WebHooksIntegrationsList",
        "required": [
          "size",
          "integrations"
        ],
        "type": "object",
        "properties": {
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "integrations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WebHookIntegrationGet"
            }
          }
        }
      },
      "WebhookUser": {
        "title": "Webhook User",
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "the user's unique ID"
          },
          "name": {
            "type": "string",
            "description": "the user's name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "the user's email"
          },
          "organization": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64",
                "description": "the organization's unique ID"
              },
              "name": {
                "type": "string",
                "description": "the organization's name"
              }
            }
          }
        }
      },
      "WebhookEvent": {
        "title": "Webhook Event",
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string",
            "format": "uuid",
            "example": "bb468a0e-d84b-44ab-8b23-29b2a0c6a7a3",
            "description": "Unique event ID"
          },
          "event_name": {
            "type": "string",
            "enum": [
              "AGREEMENT_EXECUTED",
              "AGREEMENT_NEW_SIGNATURE",
              "AGREEMENT_APPROVED",
              "AGREEMENT_EXPIRED",
              "AGREEMENT_CUSTOM_FIELDS_ADDED",
              "AGREEMENT_CUSTOM_FIELDS_UPDATED",
              "AGREEMENT_CUSTOM_FIELDS_DELETED",
              "AGREEMENT_LIFECYCLE_UPDATED",
              "AGREEMENT_CANCELLED",
              "AGREEMENT_BACK_TO_REVIEW",
              "AGREEMENT_NEGOTIATION_CREATED",
              "AGREEMENT_MOVE_TO_SIGNING",
              "AGREEMENT_NEGOTIATION_SHARED",
              "AGREEMENT_NEW_VERSION",
              "AGREEMENT_NEGOTIATION_JOINED"
            ],
            "description": "`AGREEMENT_EXECUTED`: sent when the document is fully signed. When a review/negotiation is fully signed, a contract is created. In this case, the `agreement.uid` field contains the review/negotiation UID, and the `agreement.signedAgreementUid` field contains the newly created contract UID.<br> `AGREEMENT_NEW_SIGNATURE`: sent when a new signature is added on the agreement.<br> `AGREEMENT_APPROVED`: sent when the worklow is fully approved.<br> `AGREEMENT_EXPIRED`: sent when the contract is expired.<br> `AGREEMENT_CUSTOM_FIELDS_ADDED`: sent when custom fields are added.<br> `AGREEMENT_CUSTOM_FIELDS_UPDATED`: sent when custom fields are updated.<br> `AGREEMENT_CUSTOM_FIELDS_DELETED`: sent when custom fields are deleted.<br> `AGREEMENT_LIFECYCLE_UPDATED`: sent when the document lifecycle is updated.<br> `AGREEMENT_CANCELLED`: sent when the document is cancelled.<br> `AGREEMENT_BACK_TO_REVIEW`: sent when a document in signing phase goes back to review.<br> `AGREEMENT_NEGOTIATION_CREATED`: sent when a new negotiation has been created in the organization.<br> `AGREEMENT_MOVE_TO_SIGNING`: sent when an agreement has been moved to signing status.<br> `AGREEMENT_NEGOTIATION_SHARED`: sent when a negotiation has been shared internally or externally.<br> `AGREEMENT_NEW_VERSION`: sent when a new version of the agreement has been created.<br> `AGREEMENT_NEGOTIATION_JOINED`: sent when a user has joined a negotiation.\n"
          },
          "occured_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO-8601 representation of the time when this event had occured."
          },
          "source": {
            "type": "string",
            "enum": [
              "USER",
              "SCHEDULED"
            ],
            "description": "`USER`: the event has been triggered by a user's action.<br> `SCHEDULED`: the event has been triggered automatically (ex: when contract is expiring).\n"
          },
          "content": {
            "type": "object",
            "properties": {
              "user": {
                "$ref": "#/components/schemas/WebhookUser",
                "description": "The user that triggered the event.<br> Only present when the event source is `USER`.\n"
              },
              "agreement": {
                "type": "object",
                "description": "The agreement impacted by the event.",
                "properties": {
                  "uid": {
                    "$ref": "#/components/schemas/AgreementUid"
                  },
                  "title": {
                    "type": "string",
                    "description": "Agreement's title"
                  },
                  "description": {
                    "type": "string",
                    "description": "Agreement's description"
                  },
                  "signedAgreementUid": {
                    "$ref": "#/components/schemas/AgreementUid",
                    "description": "The UID of the newly created signed contract.<br>\nThis field is only present for `AGREEMENT_EXECUTED` events when a review/negotiation is fully signed and a contract is created.<br>\n"
                  },
                  "externalResource": {
                    "type": "object",
                    "description": "Agreement's external infos",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Provider resource id associated to the concord agreement"
                      },
                      "provider": {
                        "type": "string",
                        "description": "Provider",
                        "enum": [
                          "HUBSPOT"
                        ]
                      },
                      "type": {
                        "type": "string",
                        "description": "Provider type of resource associated to the agreement",
                        "example": "Deal"
                      }
                    }
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "DRAFT",
                      "VALIDATION",
                      "NEGOTIATION",
                      "SIGNING",
                      "CONTRACT"
                    ],
                    "description": "Agreement's type"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL link to the agreement"
                  },
                  "file": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL link to download the agreement's PDF"
                  },
                  "folder": {
                    "type": "object",
                    "description": "Agreement's folder",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Folder's unique ID"
                      },
                      "name": {
                        "type": "string",
                        "description": "Folder's name"
                      }
                    }
                  },
                  "lifecycle": {
                    "$ref": "#/components/schemas/Lifecycle"
                  },
                  "tags": {
                    "type": "array",
                    "description": "List of agreement's tags",
                    "items": {
                      "type": "string"
                    }
                  },
                  "smartfields": {
                    "type": "array",
                    "description": "List of agreement's smart fields",
                    "items": {
                      "type": "object",
                      "properties": {
                        "uuid": {
                          "type": "string",
                          "format": "uuid",
                          "description": "Smart field's unique ID"
                        },
                        "name": {
                          "type": "string",
                          "description": "Smart field's name"
                        },
                        "required": {
                          "type": "boolean",
                          "description": "True if the smart field is required, false otherwise"
                        },
                        "type": {
                          "type": "string",
                          "enum": [
                            "TEXT",
                            "NUMBER"
                          ],
                          "description": "Smart field's type"
                        },
                        "value": {
                          "type": "string",
                          "description": "Smart field's value inside the agreement"
                        }
                      }
                    }
                  },
                  "members": {
                    "type": "object",
                    "description": "Agreement's members",
                    "properties": {
                      "users": {
                        "type": "array",
                        "description": "Members that are active users",
                        "items": {
                          "$ref": "#/components/schemas/WebhookUser"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "restCode": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}