      "CustomEmailContent": {
        "title": "CustomEmailContent",
        "oneOf": [
          {
            "type": "object",
            "required": [
              "enabled",
              "url"
            ],
            "properties": {
              "enabled": {
                "type": "boolean",
                "enum": [
                  true
                ]
              },
              "url": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "enabled"
            ],
            "properties": {
              "enabled": {
                "type": "boolean",
                "enum": [
                  false
                ]
              }
            }
          }
        ],
        "example": {
          "enabled": true,
          "url": "https://secure.concordnow.com/static/img/organizations/1"
        }
      },
      "CustomEmailSender": {
        "title": "CustomEmailSender",
        "type": "object",
        "required": [
          "enabled"
        ],
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "senderName": {
            "type": "string",
            "description": "Name of the sender",
            "example": "John Doe"
          },
          "senderEmail": {
            "type": "string",
            "description": "Email address of the sender",
            "example": "john.doe@company.com"
          },
          "verified": {
            "type": "boolean",
            "description": "Indicates whether the domain's DKIM and ReturnPath are verified on Postmark"
          },
          "senderDomain": {
            "type": "string",
            "description": "Domain of the sender (must be the same as the domain in the email address)"
          },
          "dkimHost": {
            "type": "string",
            "description": "DKIM DNS record hostname",
            "example": "dkim._domainkey.company.com"
          },
          "dkimValue": {
            "type": "string",
            "description": "DKIM DNS record value",
            "example": "v=DKIM1; k=rsa; p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQC+W6scd3XWwvC/hPRksfDYFi3ztgyS9OSqnnjtNQeDdTSD1DRx/xFar2wjmzxp2+SnJ5pspaF77VZveN3P/HVmXZVghr3asoV9WBx/uW1nDIUxU35L4juXiTwsMAbgMyh3NqIKTNKyMDy4P8vpEhtH1iv/BrwMdBjHDVCycB8WnwIDAQAB"
          },
          "returnPathDomain": {
            "type": "string",
            "description": "Return path domain",
            "example": "pm-bounces.company.com"
          },
          "returnPathValue": {
            "type": "string",
            "description": "Return path CNAME value",
            "example": "pm.mtasv.net"
          }
        }
      },
      "CustomAgreementView": {
        "title": "CustomAgreementView",
        "required": [
