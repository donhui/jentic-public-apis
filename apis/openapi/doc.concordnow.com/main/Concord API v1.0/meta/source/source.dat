    "/user/me/organizations/{organizationId}/agreements": {
      "parameters": [
        {
          "in": "path",
          "name": "organizationId",
          "description": "Organization ID",
          "required": true,
          "schema": {
            "type": "integer",
            "format": "int64"
          }
        }
      ],
      "get": {
        "tags": [
          "Agreement"
        ],
        "summary": "List Agreements",
        "description": "This lists Agreements of the inbox for an organization. This allows to filter results with many options.",
        "operationId": "ListAgreements",
        "parameters": [
          {
            "name": "statuses",
            "in": "query",
            "description": "Filter on Agreement stage. Provide statuses to get query results.\nAllowed statuses are:\n* `DRAFT` - Draft, Agreement private to one user.\n* `VALIDATION` - Review, Agreement is shared and content is under review and elaboration internally.\n* `NEGOTIATION` - Review, Agreement contains at least one public version. It happens when the agreement is shared with a third-party (somebody from outside the negotiation organization).\n* `SIGNING` - Signing, Agreement currently waiting for signatures.\n* `UNKNOWN_CONTRACT` - Signed, Signed agreement of which we do not know the end.\n* `FUTURE_CONTRACT` - Signed, Signed agreement which has not started yet (effective date is not reached yet).\n* `CURRENT_CONTRACT` - Signed, Signed agreement currently effective.\n* `COMPLETED_CONTRACT` - Signed, Signed non-renewable agreement which is expired (end is already past)\n* `COMPLETED_CANCEL_CONTRACT` - Signed, Signed agreement which has been canceled before its normal expiration date.\n* `COMPLETED_CONTRACT_RENEWABLE` - Signed, Signed \"tacit\" or \"manual\" renewable agreement.\n* `BROKEN` - Canceled, Agreement canceled during review.\n* `TRASHED` - Trashed, Agreement that was trashed\n* `NEGO_INVITE` - Invitation to a negotiation\n* `TEMPLATE` - Template, Non-automated agreement template.\n* `TEMPLATE_AUTO` - Template, Automated agreement template. Contains fields that can be filled through Salesforce or Excel to generate agreements.\n",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/ContractLibraryStatusEnum"
              }
            }
          },
          {
            "name": "createdBy",
            "in": "query",
            "description": "Display only documents created by the list of specified id users.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int64"
              }
            }
          },
          {
            "name": "isInboxed",
            "in": "query",
            "description": "Display only documents that appear in the inbox (false to display also archived documents).",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "isBookmarked",
            "in": "query",
            "description": "Display only bookmarked documents.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page to display.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "numberOfItemsByPage",
            "in": "query",
            "description": "Number to display per page.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "sortByColumn",
            "in": "query",
            "description": "Sorting column.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string",
              "example": "TITLE"
            }
          },
          {
            "name": "sortByAsc",
            "in": "query",
            "description": "Set ascending sorting type.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": false
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Filter on Agreement name, description.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string",
              "example": "Search pattern"
            }
          },
          {
            "name": "tagNames",
            "in": "query",
            "description": "Filter on Agreement tags names.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "example": [
                "Tag1",
                "Tag2"
              ]
            },
            "deprecated": true
          },
          {
            "name": "tagIds",
            "in": "query",
            "description": "Filter on Agreement tag's ids.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int64"
              },
              "example": [
                1,
                13,
                157
              ]
            }
          },
          {
            "name": "noTags",
            "in": "query",
            "description": "Filter on Agreement that have no tags.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": false
            }
          },
          {
            "name": "directAccessOnly",
            "in": "query",
            "description": "Filter agreements which you have only direct access to.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": false
            }
          },
          {
            "name": "includeOrganizationFields",
            "in": "query",
            "description": "include organization fields into agreements.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": false
            }
          },
          {
            "name": "createdAt.from",
            "in": "query",
            "description": "Filter on Agreement.createdAt >= createdAt.from<br/> As Unix timestamp in milliseconds.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1456763982000
            }
          },
          {
            "name": "createdAt.to",
            "in": "query",
            "description": "Filter on Agreement.createdAt <= createdAt.to<br/> As Unix timestamp in milliseconds.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1456763982000
            }
          },
          {
            "name": "createdAt.isBlank",
            "in": "query",
            "description": "Filter on Agreement.createdAt:<br/> - If true, only agreements <b>without</b> createdAt will be returned.<br/> - If false, only agreements <b>with</b> createdAt will be returned.<br/> - If not sent, agreements <b>with</b> and <b>without</b> the createdAt date will be returned.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "modifiedAt.from",
            "in": "query",
            "description": "Filter on Agreement.modifiedAt >= modifiedAt.from<br/> As Unix timestamp in milliseconds.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1456763982000
            }
          },
          {
            "name": "modifiedAt.to",
            "in": "query",
            "description": "Filter on Agreement.modifiedAt <= modifiedAt.to<br/> As Unix timestamp in milliseconds.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1456763982000
            }
          },
          {
            "name": "modifiedAt.isBlank",
            "in": "query",
            "description": "Filter on Agreement.modifiedAt:<br/> - If true, only agreements <b>without</b> modifiedAt will be returned.<br/> - If false, only agreements <b>with</b> modifiedAt will be returned.<br/> - If not sent, agreements <b>with</b> and <b>without</b> the modifiedAt date will be returned.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "endAt.from",
            "in": "query",
            "description": "Filter on Agreement.endAt >= endAt.from<br/> As Unix timestamp in milliseconds.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1456763982000
            }
          },
          {
            "name": "endAt.to",
            "in": "query",
            "description": "Filter on Agreement.endAt <= endAt.to<br/> As Unix timestamp in milliseconds.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1456763982000
            }
          },
          {
            "name": "endAt.isBlank",
            "in": "query",
            "description": "Filter on Agreement.endAt:<br/> - If true, only agreements <b>without</b> endAt will be returned.<br/> - If false, only agreements <b>with</b> endAt will be returned.<br/> - If not sent, agreements <b>with</b> and <b>without</b> the endAt date will be returned.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": true
            },
            "deprecated": true
          },
          {
            "name": "endAt.isPermanent",
            "in": "query",
            "description": "Filter on Agreement's end date:<br/> - If <b>true</b>, only agreements <b>without</b> the end date and in undetermined duration (Permanent duration) will be returned.<br/> - If <b>false</b>, only agreements <b>with</b> the end date or not in undetermined duration will be returned.<br/> - If not sent, no filter is done.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "endAt.isUnknown",
            "in": "query",
            "description": "Filter on Agreement's end date and duration type:<br/> - If <b>true</b>, only agreements <b>without</b> the end date and in unknown duration will be returned.<br/> - If <b>false</b>, only agreements <b>with</b> the end date or not unknown duration will be returned.<br/> - If not sent, no filter is done.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "signatureDate.from",
            "in": "query",
            "description": "Filter on Agreement.signatureDate >= signatureDate.from<br/> As Unix timestamp in milliseconds.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1456763982000
            }
          },
          {
            "name": "signatureDate.to",
            "in": "query",
            "description": "Filter on Agreement.signatureDate <= signatureDate.to<br/> As Unix timestamp in milliseconds.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1456763982000
            }
          },
          {
            "name": "signatureDate.isBlank",
            "in": "query",
            "description": "Filter on Agreement.signatureDate:<br/> - If true, only agreements <b>without</b> signatureDate will be returned.<br/> - If false, only agreements <b>with</b> signatureDate will be returned.<br/> - If not sent, agreements <b>with</b> and <b>without</b> the signatureDate date will be returned.",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "boolean",
              "example": true
            }
          },
          {
            "name": "parties",
            "in": "query",
            "description": "Filter on property party value ID",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 22,
                "maxLength": 22
              },
              "example": [
                "01sp9L4YEZNcLHaSV8447N",
                "02wsHEv8BxuJTZobtyW69i"
              ]
            }
          },
          {
            "name": "sharedWith",
            "in": "query",
            "description": "Filter on property shared with value ID",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 22,
                "maxLength": 22
              },
              "example": [
                "01sp9L4YEZNcLHaSV8447N"
              ]
            }
          },
          {
            "name": "encodedPropertyFilters",
            "in": "query",
            "description": "JWS encoded filters on custom properties. To get encoded filters, see endpoint /organizations@{organizationId}@agreements/properties/search",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string",
              "example": "JWS string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgreementListDto"
                }
              }
            }
          }
        }
      }
    },
