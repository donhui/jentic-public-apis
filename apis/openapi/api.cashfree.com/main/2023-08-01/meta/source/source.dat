{
  "openapi": "3.0.3",
  "info": {
    "title": "Cashfree Payment Links API",
    "version": "2023-08-01",
    "description": "Cashfree Payments API for creating and managing payment links. Allows merchants to generate payment links for collecting payments from customers via various payment methods.",
    "x-jentic-source-url": "https://docs.cashfree.com/reference/pgcreatelink"
  },
  "servers": [
    {
      "url": "https://api.cashfree.com/pg",
      "description": "Production"
    },
    {
      "url": "https://sandbox.cashfree.com/pg",
      "description": "Sandbox"
    }
  ],
  "paths": {
    "/links": {
      "post": {
        "operationId": "createPaymentLink",
        "summary": "Create a payment link",
        "description": "Creates a new payment link for collecting payments.",
        "tags": ["Payment Links"],
        "parameters": [
          {
            "name": "x-api-version",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2023-08-01"
            },
            "description": "API version in YYYY-MM-DD format"
          },
          {
            "name": "x-request-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "UUID for request tracking"
          },
          {
            "name": "x-idempotency-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "UUID for idempotent retries"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLinkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment link created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkEntity"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Duplicate link ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Idempotency error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/links/{link_id}": {
      "get": {
        "operationId": "fetchPaymentLink",
        "summary": "Fetch a payment link",
        "description": "Retrieves details of an existing payment link by its ID.",
        "tags": ["Payment Links"],
        "parameters": [
          {
            "name": "link_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The payment link identifier"
          },
          {
            "name": "x-api-version",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2023-08-01"
            },
            "description": "API version in YYYY-MM-DD format"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment link details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkEntity"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/links/{link_id}/cancel": {
      "post": {
        "operationId": "cancelPaymentLink",
        "summary": "Cancel a payment link",
        "description": "Cancels an active payment link.",
        "tags": ["Payment Links"],
        "parameters": [
          {
            "name": "link_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The payment link identifier"
          },
          {
            "name": "x-api-version",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2023-08-01"
            },
            "description": "API version in YYYY-MM-DD format"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment link cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkEntity"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/links/{link_id}/orders": {
      "get": {
        "operationId": "getPaymentLinkOrders",
        "summary": "Get orders for a payment link",
        "description": "Retrieves all orders associated with a payment link.",
        "tags": ["Payment Links"],
        "parameters": [
          {
            "name": "link_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The payment link identifier"
          },
          {
            "name": "x-api-version",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "2023-08-01"
            },
            "description": "API version in YYYY-MM-DD format"
          }
        ],
        "responses": {
          "200": {
            "description": "List of orders for the payment link",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LinkOrderEntity"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateLinkRequest": {
        "type": "object",
        "required": ["link_id", "link_amount", "link_currency", "link_purpose", "customer_details"],
        "properties": {
          "link_id": {
            "type": "string",
            "maxLength": 50,
            "description": "Unique identifier for the link (alphanumeric, hyphens, underscores)"
          },
          "link_amount": {
            "type": "number",
            "description": "Amount for the payment link (up to 2 decimal places)"
          },
          "link_currency": {
            "type": "string",
            "default": "INR",
            "description": "Currency code"
          },
          "link_purpose": {
            "type": "string",
            "maxLength": 500,
            "description": "Description of payment purpose"
          },
          "link_partial_payments": {
            "type": "boolean",
            "description": "Allow partial payments"
          },
          "link_minimum_partial_amount": {
            "type": "number",
            "description": "Minimum amount for partial payment"
          },
          "link_expiry_time": {
            "type": "string",
            "format": "date-time",
            "description": "Link expiry time in ISO 8601 format (default: 30 days)"
          },
          "link_notify": {
            "$ref": "#/components/schemas/LinkNotify"
          },
          "link_auto_reminders": {
            "type": "boolean",
            "description": "Enable auto reminders"
          },
          "link_notes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Key-value pairs (max 5)"
          },
          "link_meta": {
            "$ref": "#/components/schemas/LinkMeta"
          },
          "customer_details": {
            "$ref": "#/components/schemas/CustomerDetails"
          },
          "order_splits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderSplit"
            },
            "description": "Split payment configuration"
          }
        }
      },
      "CustomerDetails": {
        "type": "object",
        "required": ["customer_phone"],
        "properties": {
          "customer_phone": {
            "type": "string",
            "description": "Customer phone number"
          },
          "customer_email": {
            "type": "string",
            "description": "Customer email address"
          },
          "customer_name": {
            "type": "string",
            "description": "Customer name"
          },
          "customer_bank_account_number": {
            "type": "string",
            "description": "Customer bank account number"
          },
          "customer_bank_ifsc": {
            "type": "string",
            "description": "Customer bank IFSC code"
          },
          "customer_bank_code": {
            "type": "integer",
            "description": "Customer bank code"
          }
        }
      },
      "LinkNotify": {
        "type": "object",
        "properties": {
          "send_sms": {
            "type": "boolean"
          },
          "send_email": {
            "type": "boolean"
          }
        }
      },
      "LinkMeta": {
        "type": "object",
        "properties": {
          "notify_url": {
            "type": "string",
            "description": "Webhook notification URL"
          },
          "return_url": {
            "type": "string",
            "description": "Return URL after payment"
          },
          "upi_intent": {
            "type": "boolean",
            "description": "Enable UPI intent"
          },
          "payment_methods": {
            "type": "string",
            "description": "Allowed payment methods"
          }
        }
      },
      "LinkEntity": {
        "type": "object",
        "properties": {
          "cf_link_id": {
            "type": "string",
            "description": "Cashfree link ID"
          },
          "link_id": {
            "type": "string"
          },
          "link_status": {
            "type": "string"
          },
          "link_currency": {
            "type": "string"
          },
          "link_amount": {
            "type": "number"
          },
          "link_amount_paid": {
            "type": "number"
          },
          "link_partial_payments": {
            "type": "boolean"
          },
          "link_minimum_partial_amount": {
            "type": "number"
          },
          "link_purpose": {
            "type": "string"
          },
          "link_created_at": {
            "type": "string",
            "format": "date-time"
          },
          "customer_details": {
            "$ref": "#/components/schemas/CustomerDetails"
          },
          "link_meta": {
            "$ref": "#/components/schemas/LinkMeta"
          },
          "link_url": {
            "type": "string",
            "description": "Generated payment URL"
          },
          "link_expiry_time": {
            "type": "string",
            "format": "date-time"
          },
          "link_notes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "link_auto_reminders": {
            "type": "boolean"
          },
          "link_notify": {
            "$ref": "#/components/schemas/LinkNotify"
          },
          "link_qrcode": {
            "type": "string",
            "description": "Base64-encoded QR code PNG"
          },
          "order_splits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderSplit"
            }
          }
        }
      },
      "LinkOrderEntity": {
        "type": "object",
        "properties": {
          "cf_order_id": {
            "type": "string"
          },
          "order_id": {
            "type": "string"
          },
          "order_amount": {
            "type": "number"
          },
          "order_status": {
            "type": "string"
          },
          "payment_session_id": {
            "type": "string"
          }
        }
      },
      "OrderSplit": {
        "type": "object",
        "properties": {
          "vendor_id": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "percentage": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "XClientAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-client-id",
        "description": "Client ID for authentication"
      },
      "XClientSecret": {
        "type": "apiKey",
        "in": "header",
        "name": "x-client-secret",
        "description": "Client secret for authentication"
      }
    }
  },
  "security": [
    {
      "XClientAuth": [],
      "XClientSecret": []
    }
  ]
}