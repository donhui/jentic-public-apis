            }
          },
          {
            "description": "(whitelist) select all entities that have the same type;  (blacklist) - select all entities that have not the same type.",
            "in": "query",
            "name": "policy",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "possible annotations for a text"
          }
        },
        "tags": [
          "Candidates"
        ],
        "description": "A 2(two) step process -  Spotting, Candidate Mapping -  for linking unstructured information sources  \n",
        "operationId": "get-candidates",
        "summary": "Returns candidates from an URL"
      }
    },
    "/spot": {
      "get": {
        "parameters": [
          {
            "description": "text to be annotated.",
            "in": "query",
