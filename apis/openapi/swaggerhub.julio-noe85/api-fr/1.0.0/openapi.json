            "in": "query",
            "name": "policy",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "spots for a text"
          }
        },
        "tags": [
          "Annotate"
        ],
        "description": "A 1(one) step process -  Spotting -  for linking unstructured information sources  \n",
        "operationId": "get-spot",
        "summary": "Returns candidates from an URL"
      }
    }
  },
  "components": {},
