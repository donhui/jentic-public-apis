{
  "openapi": "3.0.3",
  "info": {
    "title": "Dripcel API",
    "version": "1.0.0",
    "description": "Dripcel REST API for automated SMS marketing and communication platform. Manage campaigns, contacts, deliveries, tags, sales, and send SMS messages programmatically.",
    "x-jentic-source-url": "https://docs.dripcel.com"
  },
  "servers": [
    {
      "url": "https://api.dripcel.com",
      "description": "Dripcel API Server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/balance": {
      "get": {
        "operationId": "getbalance",
        "summary": "Get credit balance",
        "description": "Returns the organisation's credit balance.",
        "tags": [
          "Balance"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/campaigns": {
      "get": {
        "operationId": "listcampaigns",
        "summary": "View all campaigns",
        "description": "View a list of all your campaigns.",
        "tags": [
          "Campaigns"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Campaign"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/campaigns/{campaign_id}": {
      "get": {
        "operationId": "getcampaign",
        "summary": "View a single campaign",
        "description": "View a single campaign by its ID.",
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "campaign_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the campaign"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Campaign"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contacts/{cell}": {
      "get": {
        "operationId": "getcontact",
        "summary": "Get a single contact",
        "description": "Get a single contact by their cell number (MSISDN).",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "cell",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The MSISDN of the contact"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Contact"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid cell number",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contacts/search": {
      "post": {
        "operationId": "searchcontacts",
        "summary": "Search for contacts",
        "description": "Run a search query on your contacts. Costs 10 credits per request.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "find": {
                    "type": "object",
                    "description": "Search query filter"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Number of results to return"
                  },
                  "skip": {
                    "type": "integer",
                    "description": "Number of results to skip"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Contact"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/send/sms": {
      "post": {
        "operationId": "sendsms",
        "summary": "Send a single SMS",
        "description": "Send a single SMS to a contact.",
        "tags": [
          "Send"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendSmsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tags": {
      "get": {
        "operationId": "listtags",
        "summary": "View all tags",
        "description": "View a list of all your tags.",
        "tags": [
          "Tags"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Tag"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tags/{tag_id}": {
      "get": {
        "operationId": "gettag",
        "summary": "View a single tag",
        "description": "View a single tag by its ID.",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "tag_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the tag"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Tag"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deletetag",
        "summary": "Delete a single tag",
        "description": "Delete a single tag. This will also remove the tag from all contacts and campaigns that have it.",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "tag_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the tag"
          }
        ],
        "responses": {
          "200": {
            "description": "Tag deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Tag"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/deliveries": {
      "get": {
        "operationId": "listdeliveries",
        "summary": "View all deliveries",
        "description": "View a list of deliveries. At least one of cell or customerId must be provided.",
        "tags": [
          "Deliveries"
        ],
        "parameters": [
          {
            "name": "cell",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The MSISDN of the contact to query"
          },
          {
            "name": "customerId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The unique id of a particular send to query"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Delivery"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/compliance/send": {
      "post": {
        "operationId": "checkcompliance",
        "summary": "Check compliance for cell numbers",
        "description": "Query a list of cell numbers against a campaign's targeting criteria. Costs 0.14 credits per cell queried.",
        "tags": [
          "Compliance"
        ],
        "parameters": [
          {
            "name": "campaign_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Query against a given campaign's targeting criteria. If empty, only global opt-outs will be checked."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "cells",
                  "country"
                ],
                "properties": {
                  "cells": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "The MSISDNs to check"
                  },
                  "country": {
                    "type": "string",
                    "description": "The country code"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compliance check results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/replies": {
      "get": {
        "operationId": "listreplies",
        "summary": "View replies",
        "description": "View the replies you've received.",
        "tags": [
          "Replies"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Reply"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sales": {
      "post": {
        "operationId": "uploadsales",
        "summary": "Upload sales",
        "description": "Upload bulk sales to Dripcel.",
        "tags": [
          "Sales"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SaleInput"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sales uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/send-logs/{send_id}": {
      "get": {
        "operationId": "getsendlog",
        "summary": "View a single send log",
        "description": "View a single send log by its ID.",
        "tags": [
          "SendLogs"
        ],
        "parameters": [
          {
            "name": "send_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The _id of the send to fetch"
          },
          {
            "name": "group_destinations",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "count",
                "list"
              ]
            },
            "description": "How to group destinations. 'count' returns a number, 'list' returns an array of cell numbers."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/SendLog"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/email/templates": {
      "get": {
        "operationId": "listemailtemplates",
        "summary": "Fetch all email templates",
        "description": "Fetch all email templates.",
        "tags": [
          "EmailTemplates"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "templates": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/EmailTemplate"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exchange/buyer/transaction/{id}/status": {
      "put": {
        "operationId": "updatetransactionstatus",
        "summary": "Update transaction status",
        "description": "As a buyer, accept or reject a pending transaction.",
        "tags": [
          "Exchange"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The transaction ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "completed",
                      "rejected"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/exchange/buyer/transaction/search": {
      "post": {
        "operationId": "searchtransactions",
        "summary": "Search transactions",
        "description": "Search for exchange transactions.",
        "tags": [
          "Exchange"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "_id": {
                    "description": "The transaction IDs to search for",
                    "oneOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as Bearer token in Authorization header"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string"
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "cell": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Delivery": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "cell": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Reply": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "Msisdn": {
            "type": "string",
            "description": "Cell number in full international format"
          },
          "Message": {
            "type": "string",
            "description": "Content of the reply"
          },
          "campaign_id": {
            "type": "string"
          },
          "UserReference": {
            "type": "string",
            "description": "The _id of the send being replied to"
          },
          "kind": {
            "type": "string"
          }
        }
      },
      "SendLog": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "triggeredBy": {
            "type": "string"
          },
          "startDeliveryAt": {
            "type": "string",
            "format": "date-time"
          },
          "destinations": {
            "description": "Number of contacts or array of cell numbers depending on group_destinations param"
          }
        }
      },
      "EmailTemplate": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        }
      },
      "SendSmsRequest": {
        "type": "object",
        "required": [
          "content",
          "cell",
          "skipNonContacts",
          "country",
          "deliveryMethod"
        ],
        "properties": {
          "content": {
            "type": "string",
            "description": "The content of the SMS. Can include templates."
          },
          "cell": {
            "type": "string",
            "description": "The cell number of the contact"
          },
          "skipNonContacts": {
            "type": "boolean",
            "description": "Whether to skip sending to contacts not in your org"
          },
          "country": {
            "type": "string",
            "description": "The country code to send to"
          },
          "deliveryMethod": {
            "type": "string",
            "enum": [
              "reverse",
              "standard",
              "transactional"
            ],
            "description": "The delivery method to use"
          },
          "campaign_id": {
            "type": "string",
            "description": "The id of the campaign to associate with this send"
          },
          "sendOptions": {
            "type": "object",
            "description": "Additional options for the SMS"
          }
        }
      },
      "SaleInput": {
        "type": "object",
        "required": [
          "campaign_id",
          "cell"
        ],
        "properties": {
          "campaign_id": {
            "type": "string",
            "description": "The campaign ID associated with the sale"
          },
          "send_id": {
            "type": "string",
            "description": "The send_id associated with the sale"
          },
          "click_id": {
            "type": "string",
            "description": "The click_id associated with the sale"
          },
          "cell": {
            "type": "string",
            "description": "The cell number of the contact who converted"
          },
          "soldAt": {
            "type": "string",
            "description": "The date the sale was made (ISO format YYYY-MM-DD)"
          },
          "saleValue": {
            "type": "number",
            "description": "The value of the sale"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Balance",
      "description": "Operations related to Balance"
    },
    {
      "name": "Campaigns",
      "description": "Operations related to Campaigns"
    },
    {
      "name": "Compliance",
      "description": "Operations related to Compliance"
    },
    {
      "name": "Contacts",
      "description": "Operations related to Contacts"
    },
    {
      "name": "Deliveries",
      "description": "Operations related to Deliveries"
    },
    {
      "name": "EmailTemplates",
      "description": "Operations related to EmailTemplates"
    },
    {
      "name": "Exchange",
      "description": "Operations related to Exchange"
    },
    {
      "name": "Replies",
      "description": "Operations related to Replies"
    },
    {
      "name": "Sales",
      "description": "Operations related to Sales"
    },
    {
      "name": "Send",
      "description": "Operations related to Send"
    },
    {
      "name": "SendLogs",
      "description": "Operations related to SendLogs"
    },
    {
      "name": "Tags",
      "description": "Operations related to Tags"
    }
  ]
}