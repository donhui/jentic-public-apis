              "minimum": 1,
              "example": 1
            },
            "required": false
          },
          {
            "description": "Page size",
            "in": "query",
            "name": "pageSize",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 10,
              "example": 10
            },
            "required": false
          },
          {
            "description": "Task status",
            "in": "query",
            "name": "status",
            "schema": {
              "type": "string",
              "enum": [
                "failed",
                "successful",
                "in-progress"
              ],
              "example": "successful"
            },
            "required": false
          },
          {
            "description": "filter the result based on robot bulk run ID",
