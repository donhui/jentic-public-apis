                "description": "account holder's name(s).",
                "items": {
                  "type": "string"
                }
              },
              "emails": {
                "type": "array",
                "nullable": true,
                "description": "account holder's email(s).",
                "items": {
                  "type": "string"
                }
              },
              "phone_numbers": {
                "type": "array",
                "nullable": true,
                "description": "account holder's phone number(s).",
                "items": {
                  "type": "string"
                }
              },
              "addresses": {
                "type": "array",
                "nullable": true,
                "description": "account holder's address(es).",
                "items": {
                  "type": "object",
                  "properties": {
                    "city": {
                      "type": "string"
                    },
                    "state": {
                      "type": "string"
                    },
                    "street": {
                      "type": "string"
                    },
