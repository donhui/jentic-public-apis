                "schema": {
                  "$ref": "#/components/schemas/CreatedReportResponse"
                },
                "example": {
                  "data": {
                    "id": "509574324735183486",
                    "customer_id": "499952892392769962",
                    "customer_identifier": "test@email.com",
                    "connection_ids": [
                      "499953130209806766",
                      "499953130209806767",
                      "499953130209806768"
                    ],
                    "status": "initialized",
                    "created_at": "2026-03-27T14:33:29Z"
                  }
                }
              }
            }
