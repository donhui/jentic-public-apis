                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "in": "query",
            "name": "connection_id",
            "required": false,
            "schema": {
              "type": "string",
              "description": "the `id` of the connection whose holder info are to be fetched"
            }
          }
        ]
      }
    },
