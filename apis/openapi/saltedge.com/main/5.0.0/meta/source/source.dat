    "/categories/learn": {
      "post": {
        "summary": "Improve transaction categorization",
        "description": "Your customers can change the category of some of their transactions, thus improving the categorization accuracy.\n",
        "tags": [
          "Categories"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LearnCategoryResponse"
                },
                "example": {
                  "data": {
                    "learned": true
                  }
                }
              }
            }
          },
          "400": {
            "description": "We have received some other request format instead of JSON, or the body could not be parsed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CategoriesRequestBody"
              }
            }
          }
        }
      }
    },
