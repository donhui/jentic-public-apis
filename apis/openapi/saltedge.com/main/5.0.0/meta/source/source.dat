                      "automatic_fetch": true,
                      "user_present": true,
                      "daily_refresh": false,
                      "categorize": true,
                      "created_at": "2026-03-27T13:53:29Z",
                      "customer_last_logged_at": "2026-03-27T11:33:29Z",
                      "custom_fields": {},
                      "device_type": "desktop",
                      "remote_ip": "93.184.216.34",
