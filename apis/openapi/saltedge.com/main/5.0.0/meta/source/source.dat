    "/reports": {
      "post": {
        "summary": "Create Financial Insights report",
        "description": "Allows you to create a report for a [customer](#customers) for a specific date range.\n",
        "tags": [
          "Reports"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
