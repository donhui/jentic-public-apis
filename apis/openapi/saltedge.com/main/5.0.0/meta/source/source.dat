                    }
                  ],
                  "meta": {
                    "next_id": "509574324735183488",
                    "next_page": "/api/v5/reports/?from_id=509574324735183488"
                  }
                }
              }
            }
          },
          "406": {
            "description": "The client has been disabled. You can find out more about the disabled status on [Disabled](<%= general_link('disabled') %>) guides page",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
