    "/oauth_providers/authorize": {
      "put": {
        "summary": "Authorize a connection",
        "description": "Used to authorize a connection for an OAuth provider when using client owned [provider keys](/account_information/v5/#client_provider_keys). In this flow, once the end-user will be authorized on the provider's side, they will be redirected to the `return_to` URL indicated in the [previous request](#oauth_providers-create), with a bunch of parameters appended to it by the provider that are needed for authorizing the connection.\n",
        "tags": [
          "Oauth Providers"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OauthAuthorizedResponse"
                },
                "example": {
                  "data": {
                    "country_code": "XF",
                    "created_at": "2026-03-26T14:33:29Z",
                    "customer_id": "222222222222222222",
                    "daily_refresh": false,
                    "id": "111111111111111111",
                    "categorization": "personal",
                    "show_consent_confirmation": false,
                    "last_consent_id": "555555555555555555",
                    "last_attempt": {
                      "api_mode": "service",
