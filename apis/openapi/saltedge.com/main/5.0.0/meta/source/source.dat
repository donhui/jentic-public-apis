    "schemas": {
      "Account": {
        "type": "object",
        "required": [
          "id",
          "name",
          "nature",
          "balance",
          "currency_code",
          "extra",
          "connection_id",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "the `id` of the account"
          },
          "name": {
            "type": "string",
            "description": "the unique name of the account\n\n<strong>Note:</strong> The name directly identifies the account. In case the account’s name has changed (in the bank’s WEB/API interface, through code changes, etc.) a new account will be created.\n"
          },
          "nature": {
            "type": "string",
            "enum": [
              "account",
              "bonus",
              "card",
              "checking",
              "credit",
              "credit_card",
              "debit_card",
              "ewallet",
              "insurance",
              "investment",
              "loan",
              "mortgage",
              "savings"
            ],
            "description": "the type of the account\n\n<strong>Note:</strong> for `credit_card` nature, the balance represents the sum of all negative transactions, the positive ones do not count.\n"
          },
          "balance": {
            "type": "number",
            "description": "the account's current balance"
          },
          "currency_code": {
            "type": "string",
            "description": "one of the possible values for [currency codes](#currencies). Maximum 3 letters.\n\n<strong>Note:</strong> The currency directly identifies the account. In case the account’s currency code has changed (in the bank’s WEB/API interface, through code changes, etc.) a new account will be created.\n"
          },
          "extra": {
            "$ref": "#/components/schemas/AccountExtra"
          },
          "connection_id": {
            "type": "string",
            "description": "the `id` of the connection the account belongs to"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "time and date when the account was imported"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "the last time when the account's balance was changed or new transactions were imported"
          }
        }
      },
      "AccountExtra": {
        "allOf": [
