            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "in": "query",
            "name": "customer_id",
            "required": false,
            "schema": {
              "type": "string",
              "description": "the `id` of the [customer](#customers) for which the report(s) has been requested"
            }
          },
          {
            "in": "query",
            "name": "from_id",
            "required": false,
            "schema": {
              "type": "string",
              "description": "the `id` of the report which the list starts with"
            }
          }
        ]
      }
