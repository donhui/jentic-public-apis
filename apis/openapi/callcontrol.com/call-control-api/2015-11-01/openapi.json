{
    "openapi": "3.0.0",
    "info": {
        "version": "2015-11-01",
        "title": "Call Control API",
        "description": "API for blocking phone calls with Call Control. Data is from crowdsourced community blacklist from 12+ million users and government agencies (FTC, FCC, IRS).",
        "contact": {
            "name": "Call Control",
            "url": "https://www.callcontrol.com/documentation",
            "email": "info@kedlin.com"
        },
        "x-jentic-source-url": "https://www.callcontrol.com/js/swagger/swagger.json"
    },
    "paths": {
        "/api/2015-11-01/Complaints/{phoneNumber}": {
            "get": {
                "tags": [
                    "Complaints"
                ],
                "summary": "Complaints: Free service providing community and government complaint lookup by phone number.",
                "operationId": "Complaints_Complaints",
                "parameters": [
                    {
                        "name": "phoneNumber",
                        "in": "path",
                        "description": "phone number to search",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Complaints"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/2015-11-01/Enterprise/ShouldBlock/{phoneNumber}/{userPhoneNumber}": {
            "get": {
                "tags": [
                    "EnterpriseApi"
                ],
                "summary": "Enterprise GET: ShouldBlock - returns a call block proceed decision.",
                "operationId": "EnterpriseApi_ShouldBlock",
                "parameters": [
                    {
                        "name": "phoneNumber",
                        "in": "path",
                        "description": "phone number to search",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "userPhoneNumber",
                        "in": "path",
                        "description": "phone number of user to look up block rules",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "true(block) false (no block)",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "enum": [
                                        "allow",
                                        "voiceMail",
                                        "block"
                                    ],
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request (invalid phone number)"
                    }
                }
            }
        },
        "/api/2015-11-01/Enterprise/GetUser/{phoneNumber}": {
            "get": {
                "tags": [
                    "EnterpriseApi"
                ],
                "summary": "Enterprise GET: GetUser - Returns current information from the user.",
                "operationId": "EnterpriseApi_GetUser",
                "parameters": [
                    {
                        "name": "phoneNumber",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User Object",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/CallControlUser"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request (invalid phone number)"
                    }
                }
            }
        },
        "/api/2015-11-01/Enterprise/UpsertUser": {
            "post": {
                "tags": [
                    "EnterpriseApi"
                ],
                "summary": "UpsertUser: insert or update all properties from a user.",
                "operationId": "EnterpriseApi_UpsertUser",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CallControlUser"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Ok"
                    },
                    "400": {
                        "description": "Bad request"
                    }
                }
            }
        },
        "/api/2015-11-01/Reputation/{phoneNumber}": {
            "get": {
                "tags": [
                    "Reputation"
                ],
                "summary": "Reputation: Premium service returning reputation information of a phone number.",
                "operationId": "Reputation_Reputation",
                "parameters": [
                    {
                        "name": "phoneNumber",
                        "in": "path",
                        "description": "phone number to search",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Reputation information",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Reputation"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request (invalid phone number)"
                    }
                }
            }
        },
        "/api/2015-11-01/Report": {
            "post": {
                "tags": [
                    "Reputation"
                ],
                "summary": "Report: report spam calls received to tune algorithms.",
                "operationId": "Reputation_Report",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CallReport"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "400": {
                        "description": "Bad request"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://api.callcontrol.com"
        }
    ],
    "components": {
        "securitySchemes": {
            "apiKey": {
                "type": "apiKey",
                "description": "API Key Authentication",
                "name": "apiKey",
                "in": "header"
            }
        },
        "schemas": {
            "Complaints": {
                "type": "object",
                "properties": {
                    "ReportedCallerName": {
                        "type": "string"
                    },
                    "TotalNumberOfComplaints": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "ComplaintsByEntity": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    "LastComplaintDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "Tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "CallControlUser": {
                "type": "object",
                "properties": {
                    "PhoneNumber": {
                        "type": "string"
                    },
                    "WhiteList": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "BlackList": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "QuietHourList": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/QuietHour"
                        }
                    },
                    "UseCommunityBlacklist": {
                        "type": "boolean"
                    },
                    "BreakThroughQhWithMultipleCalls": {
                        "type": "boolean"
                    },
                    "WhiteListBreaksQh": {
                        "type": "boolean"
                    },
                    "BlockBehavior": {
                        "type": "string",
                        "enum": [
                            "allow",
                            "voiceMail",
                            "block"
                        ]
                    },
                    "Email": {
                        "type": "string"
                    },
                    "FirstName": {
                        "type": "string"
                    },
                    "LastName": {
                        "type": "string"
                    }
                }
            },
            "QuietHour": {
                "type": "object",
                "properties": {
                    "DayOfWeekList": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "Sunday",
                                "Monday",
                                "Tuesday",
                                "Wednesday",
                                "Thursday",
                                "Friday",
                                "Saturday"
                            ]
                        }
                    },
                    "StartHourLocal": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "StartMinLocal": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "DurationMin": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "TimeZoneName": {
                        "type": "string"
                    }
                }
            },
            "Reputation": {
                "type": "object",
                "properties": {
                    "CallType": {
                        "type": "string",
                        "readOnly": true
                    },
                    "Confidence": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "IsSpam": {
                        "type": "boolean"
                    },
                    "LastComplaintDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "ReportedCallerName": {
                        "type": "string"
                    },
                    "Tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "CallReport": {
                "type": "object",
                "properties": {
                    "PhoneNumber": {
                        "type": "string"
                    },
                    "ReportedCallerName": {
                        "type": "string"
                    },
                    "CallerType": {
                        "type": "string",
                        "enum": [
                            "Unknown",
                            "Telemarketing",
                            "Collection_Agency",
                            "Political",
                            "Surveyor",
                            "Prank_Call",
                            "Fund_Raiser",
                            "Other_Commercial",
                            "Scam",
                            "VOIP",
                            "Business",
                            "Reminder_Notification_Call",
                            "Junk_Fax",
                            "Fax_Machine",
                            "Spam_Text",
                            "RoboCall",
                            "NotSpam",
                            "Callback"
                        ]
                    },
                    "Comment": {
                        "type": "string"
                    },
                    "UnwantedCall": {
                        "type": "boolean"
                    },
                    "CallTime": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            }
        }
    }
}