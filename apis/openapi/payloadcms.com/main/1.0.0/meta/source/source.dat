{
  "openapi": "3.0.3",
  "info": {
    "title": "Payload Headless CMS API",
    "version": "1.0.0",
    "description": "Payload CMS REST API for managing collections. Payload provides a generic REST API pattern for all collections: find, find by ID, create, update, update by ID, and delete. Also supports auth operations, global documents, and preferences.",
    "x-jentic-source-url": "https://payloadcms.com/docs/rest-api/overview"
  },
  "servers": [
    {
      "url": "https://{your-domain}/api",
      "description": "Payload CMS API",
      "variables": {
        "your-domain": {
          "default": "localhost:3000",
          "description": "Your Payload CMS deployment domain"
        }
      }
    }
  ],
  "paths": {
    "/{collection}": {
      "get": {
        "operationId": "findDocuments",
        "summary": "Find documents in a collection",
        "description": "Returns a paginated list of documents in the specified collection. Supports filtering via query parameters using where operators.",
        "tags": ["Collections"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}, "description": "Collection slug"},
          {"name": "depth", "in": "query", "schema": {"type": "integer"}, "description": "Depth of population for relationship fields"},
          {"name": "locale", "in": "query", "schema": {"type": "string"}, "description": "Locale for localized fields"},
          {"name": "fallback-locale", "in": "query", "schema": {"type": "string"}, "description": "Fallback locale"},
          {"name": "limit", "in": "query", "schema": {"type": "integer"}, "description": "Max results per page"},
          {"name": "page", "in": "query", "schema": {"type": "integer"}, "description": "Page number"},
          {"name": "sort", "in": "query", "schema": {"type": "string"}, "description": "Field to sort by (prefix with - for descending)"},
          {"name": "where", "in": "query", "schema": {"type": "object"}, "description": "Query filter using Payload query operators"},
          {"name": "draft", "in": "query", "schema": {"type": "boolean"}, "description": "Whether to include draft documents"}
        ],
        "responses": {
          "200": {
            "description": "Paginated list of documents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "post": {
        "operationId": "createDocument",
        "summary": "Create a document",
        "description": "Creates a new document in the specified collection.",
        "tags": ["Collections"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}, "description": "Collection slug"},
          {"name": "depth", "in": "query", "schema": {"type": "integer"}},
          {"name": "locale", "in": "query", "schema": {"type": "string"}},
          {"name": "draft", "in": "query", "schema": {"type": "boolean"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Document fields matching the collection schema"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request / validation error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "patch": {
        "operationId": "updateDocumentsByQuery",
        "summary": "Update documents by query",
        "description": "Updates multiple documents matching a query in the collection.",
        "tags": ["Collections"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "where", "in": "query", "schema": {"type": "object"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Documents updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "delete": {
        "operationId": "deleteDocumentsByQuery",
        "summary": "Delete documents by query",
        "description": "Deletes documents matching a query.",
        "tags": ["Collections"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "where", "in": "query", "schema": {"type": "object"}}
        ],
        "responses": {
          "200": {"description": "Documents deleted", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/{collection}/{id}": {
      "get": {
        "operationId": "getDocumentById",
        "summary": "Get a document by ID",
        "description": "Retrieves a single document by its ID.",
        "tags": ["Collections"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "depth", "in": "query", "schema": {"type": "integer"}},
          {"name": "locale", "in": "query", "schema": {"type": "string"}},
          {"name": "draft", "in": "query", "schema": {"type": "boolean"}}
        ],
        "responses": {
          "200": {"description": "Document details", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "404": {"description": "Document not found"}
        }
      },
      "patch": {
        "operationId": "updateDocumentById",
        "summary": "Update a document by ID",
        "description": "Updates a single document by its ID.",
        "tags": ["Collections"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "depth", "in": "query", "schema": {"type": "integer"}},
          {"name": "locale", "in": "query", "schema": {"type": "string"}},
          {"name": "draft", "in": "query", "schema": {"type": "boolean"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {
          "200": {"description": "Document updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DocumentResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "delete": {
        "operationId": "deleteDocumentById",
        "summary": "Delete a document by ID",
        "description": "Deletes a single document by its ID.",
        "tags": ["Collections"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Document deleted", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DocumentResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/{collection}/login": {
      "post": {
        "operationId": "loginToCollection",
        "summary": "Login to an auth-enabled collection",
        "description": "Authenticates against a collection with auth enabled and returns a JWT token.",
        "tags": ["Auth"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {"type": "string", "format": "email"},
                  "password": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {"type": "string"},
                    "user": {"type": "object"},
                    "token": {"type": "string"},
                    "exp": {"type": "integer"}
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Invalid credentials", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        },
        "security": []
      }
    },
    "/{collection}/logout": {
      "post": {
        "operationId": "logoutFromCollection",
        "summary": "Logout from an auth-enabled collection",
        "tags": ["Auth"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Logged out"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/{collection}/me": {
      "get": {
        "operationId": "getCurrentAuthUser",
        "summary": "Get current authenticated user",
        "description": "Returns the currently authenticated user for the collection.",
        "tags": ["Auth"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {"type": "object"},
                    "token": {"type": "string"},
                    "exp": {"type": "integer"},
                    "collection": {"type": "string"}
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/{collection}/refresh-token": {
      "post": {
        "operationId": "refreshToken",
        "summary": "Refresh authentication token",
        "tags": ["Auth"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {"type": "string"},
                    "refreshedToken": {"type": "string"},
                    "exp": {"type": "integer"},
                    "user": {"type": "object"}
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/{collection}/forgot-password": {
      "post": {
        "operationId": "forgotPassword",
        "summary": "Send password reset email",
        "tags": ["Auth"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": {"type": "string", "format": "email"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Reset email sent"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        },
        "security": []
      }
    },
    "/{collection}/reset-password": {
      "post": {
        "operationId": "resetPassword",
        "summary": "Reset password with token",
        "tags": ["Auth"],
        "parameters": [
          {"name": "collection", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "password"],
                "properties": {
                  "token": {"type": "string"},
                  "password": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Password reset", "content": {"application/json": {"schema": {"type": "object", "properties": {"message": {"type": "string"}, "token": {"type": "string"}, "user": {"type": "object"}}}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        },
        "security": []
      }
    },
    "/globals/{global_slug}": {
      "get": {
        "operationId": "getGlobal",
        "summary": "Get a global document",
        "description": "Retrieves a single global document.",
        "tags": ["Globals"],
        "parameters": [
          {"name": "global_slug", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "depth", "in": "query", "schema": {"type": "integer"}},
          {"name": "locale", "in": "query", "schema": {"type": "string"}},
          {"name": "draft", "in": "query", "schema": {"type": "boolean"}}
        ],
        "responses": {
          "200": {"description": "Global document", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "post": {
        "operationId": "updateGlobal",
        "summary": "Update a global document",
        "tags": ["Globals"],
        "parameters": [
          {"name": "global_slug", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "depth", "in": "query", "schema": {"type": "integer"}},
          {"name": "locale", "in": "query", "schema": {"type": "string"}},
          {"name": "draft", "in": "query", "schema": {"type": "boolean"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {
          "200": {"description": "Global updated", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from the login endpoint"
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "payload-token",
        "description": "HTTP-only cookie set during login"
      }
    },
    "schemas": {
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "docs": {
            "type": "array",
            "items": {"type": "object"}
          },
          "totalDocs": {"type": "integer"},
          "limit": {"type": "integer"},
          "totalPages": {"type": "integer"},
          "page": {"type": "integer"},
          "pagingCounter": {"type": "integer"},
          "hasPrevPage": {"type": "boolean"},
          "hasNextPage": {"type": "boolean"},
          "prevPage": {"type": "integer", "nullable": true},
          "nextPage": {"type": "integer", "nullable": true}
        }
      },
      "DocumentResponse": {
        "type": "object",
        "properties": {
          "message": {"type": "string"},
          "doc": {"type": "object"}
        }
      },
      "BulkResponse": {
        "type": "object",
        "properties": {
          "message": {"type": "string"},
          "docs": {
            "type": "array",
            "items": {"type": "object"}
          },
          "errors": {
            "type": "array",
            "items": {"type": "object"}
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "message": {"type": "string"},
                "data": {"type": "object"}
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {"bearerAuth": []},
    {"cookieAuth": []}
  ],
  "tags": [
    {"name": "Collections", "description": "CRUD operations on collection documents"},
    {"name": "Auth", "description": "Authentication operations for auth-enabled collections"},
    {"name": "Globals", "description": "Global document management"}
  ]
}