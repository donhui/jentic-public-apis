{
  "openapi": "3.0.3",
  "info": {
    "title": "Ron Swanson Quotes API",
    "description": "A free REST API that returns random Ron Swanson quotes. Supports retrieving single quotes, multiple quotes, and searching quotes by keyword.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://github.com/jamesseanwright/ron-swanson-quotes"
  },
  "servers": [
    {
      "url": "https://ron-swanson-quotes.herokuapp.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/v2/quotes": {
      "get": {
        "operationId": "getRandomQuote",
        "summary": "Get a random quote",
        "description": "Retrieves a single random Ron Swanson quote.",
        "responses": {
          "200": {
            "description": "A single random quote returned as an array",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotesResponse"
                },
                "example": [
                  "Capitalism: God's way of determining who is smart and who is poor."
                ]
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v2/quotes/{count}": {
      "get": {
        "operationId": "getMultipleRandomQuotes",
        "summary": "Get multiple random quotes",
        "description": "Returns the specified number of random Ron Swanson quotes.",
        "parameters": [
          {
            "name": "count",
            "in": "path",
            "required": true,
            "description": "The number of random quotes to retrieve.",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of random quotes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v2/schema": {
      "get": {
        "operationId": "getSchema",
        "summary": "Get OpenAPI 3 specification",
        "description": "Returns the OpenAPI 3 specification document for this API.",
        "responses": {
          "200": {
            "description": "The OpenAPI 3 specification document",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "OpenAPI 3 specification document"
                }
              }
            }
          }
        }
      }
    },
    "/v2/quotes/search/{term}": {
      "get": {
        "operationId": "searchQuotes",
        "summary": "Search quotes by keyword",
        "description": "Searches for Ron Swanson quotes that match the provided search term. The search is case-insensitive.",
        "parameters": [
          {
            "name": "term",
            "in": "path",
            "required": true,
            "description": "The search keyword to find matching quotes.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of quotes matching the search term",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QuotesResponse": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "An array of Ron Swanson quote strings."
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message describing what went wrong."
          }
        }
      }
    }
  },
  "security": [],
  "tags": [
    {
      "name": "Quotes",
      "description": "Operations for retrieving Ron Swanson quotes"
    }
  ]
}