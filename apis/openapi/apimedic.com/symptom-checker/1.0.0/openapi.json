  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "name": "token",
        "in": "query",
        "description": "API token obtained by authenticating with your API key credentials via the login endpoint. Token is an HMAC-MD5 hash of the API key using the secret key."
      }
    },
    "schemas": {
      "SymptomItem": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer",
            "description": "Symptom identifier"
          },
          "Name": {
            "type": "string",
            "description": "Symptom name"
          }
        }
      },
      "DiagnosisItem": {
        "type": "object",
        "properties": {
          "Issue": {
            "$ref": "#/components/schemas/IssueItem"
          },
          "Specialisation": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpecialisationItem"
            }
          }
        }
      },
      "IssueItem": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer",
            "description": "Issue/disease identifier"
          },
          "Name": {
            "type": "string",
            "description": "Issue/disease name"
          },
          "Accuracy": {
            "type": "number",
            "format": "float",
            "description": "Accuracy/probability percentage of the diagnosis (0-100)"
          },
          "Icd": {
            "type": "string",
            "description": "ICD code"
          },
          "IcdName": {
            "type": "string",
            "description": "ICD code name"
          },
          "ProfName": {
            "type": "string",
            "description": "Professional medical name"
          },
          "Ranking": {
            "type": "integer",
            "description": "Ranking position"
          }
        }
      },
      "IssueInfo": {
        "type": "object",
        "properties": {
          "Description": {
            "type": "string",
            "description": "General description of the health issue"
          },
          "DescriptionShort": {
            "type": "string",
            "description": "Short description"
          },
          "MedicalCondition": {
            "type": "string",
            "description": "Medical condition details"
          },
          "Name": {
            "type": "string"
          },
          "PossibleSymptoms": {
            "type": "string",
            "description": "Comma-separated list of possible symptoms"
          },
          "ProfName": {
            "type": "string",
            "description": "Professional/medical name"
          },
          "TreatmentDescription": {
            "type": "string",
            "description": "Treatment information"
          }
        }
      },
      "BodyLocation": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer"
          },
          "Name": {
            "type": "string"
          }
        }
      },
      "BodySubLocation": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer"
          },
          "Name": {
            "type": "string"
          }
        }
      },
      "SpecialisationItem": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer"
          },
          "Name": {
            "type": "string",
            "description": "Specialisation name (e.g., General practice, Cardiology)"
          },
          "SpecialistID": {
            "type": "integer"
          }
        }
      }
    }
  }
}
