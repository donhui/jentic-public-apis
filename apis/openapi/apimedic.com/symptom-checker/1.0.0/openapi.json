{
  "openapi": "3.0.3",
  "info": {
    "title": "ApiMedic Symptom Checker API",
    "description": "ApiMedic offers a medical symptom checker API primarily for patients. It provides symptom-based diagnosis suggestions by calculating disease likelihood based on entered symptoms. The API covers symptoms, diagnoses, body locations, and health issues.",
    "version": "1.0.0",
    "contact": {
      "name": "ApiMedic",
      "url": "https://apimedic.com"
    }
  },
  "servers": [
    {
      "url": "https://sandbox-healthservice.priaid.ch",
      "description": "Sandbox/Test Environment"
    },
    {
      "url": "https://healthservice.priaid.ch",
      "description": "Production Environment"
    }
  ],
  "security": [
    {
      "apiToken": []
    }
  ],
  "paths": {
    "/symptoms": {
      "get": {
        "operationId": "getSymptoms",
        "summary": "Get all symptoms",
        "description": "Returns a list of all available symptoms. Used to populate the symptom selection for the checker.",
        "tags": ["Symptoms"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "Authentication token obtained via the login endpoint.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": true,
            "description": "Language code (e.g., en-gb, de-ch, fr-fr, es-es).",
            "schema": {
              "type": "string",
              "default": "en-gb"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format.",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SymptomItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/symptoms/{symptomId}/man": {
      "get": {
        "operationId": "getSymptomRedFlagTextForMan",
        "summary": "Get red flag text for a symptom (male)",
