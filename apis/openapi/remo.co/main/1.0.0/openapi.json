{
  "openapi": "3.0.3",
  "info": {
    "title": "Remo API",
    "version": "1.0.0",
    "description": "Remo Conference API for managing virtual events and registrations.",
    "contact": {
      "email": "russell@remo.co"
    },
    "x-jentic-source-url": "https://app.swaggerhub.com/apis-docs/russellremo/remo-api/1.0.0"
  },
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/russellremo/remo-api/1.0.0",
      "description": "SwaggerHub Virtual Server"
    }
  ],
  "paths": {
    "/api/v1/zapier/new-event-users": {
      "get": {
        "tags": [
          "developers"
        ],
        "summary": "Notify user when there are new registrations",
        "operationId": "newEventNotification",
        "responses": {
          "200": {
            "description": "New registration data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewEventUsersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad input parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "NewEventUsersResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EventUser"
            }
          }
        }
      },
      "EventUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email"
          },
          "name": {
            "type": "string",
            "description": "User name"
          },
          "registered_at": {
            "type": "string",
            "format": "date-time",
            "description": "Registration timestamp"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "admins",
      "description": "Secured Admin-only calls"
    },
    {
      "name": "developers",
      "description": "Operations available to regular developers"
    }
  ]
}