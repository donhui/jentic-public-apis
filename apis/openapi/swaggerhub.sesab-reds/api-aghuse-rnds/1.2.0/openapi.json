{
  "openapi": "3.0.0",
  "info": {
    "version": "1.2.0",
    "title": "api-aghuse-rnds",
    "description": "API definida para expor os dados do AGHUSE no formato JSON simplificado, para consumo por rotinas respons\u00e1veis pela integra\u00e7\u00e3o e envio para RNDS.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/SESAB-REDS/api-aghuse-rnds/1.2.0/swagger.json"
  },
  "paths": {
    "/aghu-api/p/paciente/rnds": {
      "get": {
        "tags": [
          "Atendimentos Cl\u00ednicos"
        ],
        "description": "Este endpoint tem como objetivo retornar de forma paginada dados de prontu\u00e1rio registrados no AGHUSE. Quando modelo for rac, s\u00e3o retornados Registros de Atendimentos Cl\u00ednicos (RAC) ambulatoriais, conclu\u00eddos, ordenados pela data de in\u00edcio do atendimento de forma ascendente. Assim, dados de atendimentos de emerg\u00eancia e interna\u00e7\u00f5es n\u00e3o s\u00e3o retornados.",
        "operationId": "getAtendimentosClinicos",
        "parameters": [
          {
            "in": "query",
            "name": "modelo",
            "required": true,
            "schema": {
              "type": "string",
              "example": "RAC",
              "items": {
                "type": "string"
              }
            },
            "description": "Modelo de informa\u00e7\u00e3o requisitado"
          },
          {
            "in": "query",
            "name": "page",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "N\u00famero da p\u00e1gina."
          },
          {
            "in": "query",
            "name": "pageSize",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Tamanho da p\u00e1gina."
          },
          {
            "in": "query",
            "name": "cdCnes",
            "required": true,
            "schema": {
              "type": "string",
              "example": "0004073",
              "items": {
                "type": "string"
              }
            },
            "description": "C\u00f3digo CNES do estabelecimento de sa\u00fade onde os atendimentos foram realizados."
          },
          {
            "in": "query",
            "name": "dtMomentInic",
            "required": true,
            "schema": {
              "type": "string",
              "example": "2024-01-04 00:00:00"
            },
            "description": "Data/Hora m\u00ednima de in\u00edcio do atendimento para filtro (formato yyyy-MM-dd HH:mm:ss)."
          },
          {
            "in": "query",
            "name": "dtMomentFim",
            "required": true,
            "schema": {
              "type": "string",
              "example": "2024-01-04 23:59:59"
            },
            "description": "Data/Hora m\u00e1xima de in\u00edcio do atendimento para filtro (formato yyyy-MM-dd HH:mm:ss)."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageAtendimentoClinico"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PageAtendimentoClinico": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "example": 0,
            "description": "N\u00famero da p\u00e1gina."
          },
          "perPage": {
            "type": "integer",
            "example": 10,
            "description": "Tamanho da p\u00e1gina."
          },
          "totalpagesInTimeRange": {
            "type": "integer",
            "example": 1,
            "description": "N\u00famero total de p\u00e1ginas no intervalo de tempo."
          },
          "totalElementsInTimeRange": {
            "type": "integer",
            "example": 1,
            "description": "N\u00famero total de elementos no intervalo de tempo."
          },
          "listaRegistrosRac": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AtendimentoClinico"
            }
          }
        }
      },
      "AtendimentoClinico": {
        "type": "object",
        "properties": {
          "idAtend": {
            "type": "string",
            "example": 87236,
            "description": "Identificador \u00fanico do atendimento no AGHUSE."
          },
          "cdCnes": {
            "type": "string",
            "minLength": 7,
            "maxLength": 7,
            "example": "0004073",
            "description": "C\u00f3digo CNES do estabelecimento de sa\u00fade onde foi realizado o atendimento."
          },
          "dtMomentInic": {
            "type": "string",
            "example": "2024-01-04 17:51:43",
            "description": "Data e hora de in\u00edcio do atendimento no formato yyyy-MM-dd HH:mm:ss."
          },
          "dtMomentFim": {
            "type": "string",
            "example": "2024-01-04 18:16:59",
            "description": "Data e hora de fim do atendimento no formato yyyy-MM-dd HH:mm:ss."
          },
          "dsProcdn": {
            "type": "string",
            "enum": [
              "Demanda espont\u00e2nea",
              "Ordem Judicial",
              "Retorno",
              "Demanda referenciada",
              "Informa\u00e7\u00e3o ausente no modelo de origem"
            ],
            "description": "Proced\u00eancia do atendimento. Identifica o servi\u00e7o que encaminhou o indiv\u00edduo ou a sua iniciativa/de seu respons\u00e1vel na busca pelo acesso ao servi\u00e7o de sa\u00fade."
          },
          "dsModalAssist": {
            "type": "string",
            "enum": [
              "Aten\u00e7\u00e3o B\u00e1sica",
              "Aten\u00e7\u00e3o Domiciliar",
              "Aten\u00e7\u00e3o Intermedi\u00e1ria",
              "Aten\u00e7\u00e3o Hospitalar",
              "Aten\u00e7\u00e3o Psicossocial",
              "Aten\u00e7\u00e3o \u00e0 Urg\u00eancia/Emerg\u00eancia",
              "Ambulatorial Especializada",
              "Assist\u00eancia Farmac\u00eautica",
              "Assist\u00eancia Ambulatorial"
            ],
            "description": "Modalidade assistencial. Classifica os contatos assistenciais de acordo com as especificidades do modo, local e dura\u00e7\u00e3o do atendimento."
          },
          "dsModalCaratAtend": {
            "type": "string",
            "enum": [
              "Eletivo",
              "Urg\u00eancia",
              "Consulta agendada",
              "Consulta agendada programada: cuidado continuado",
              "Demanda espont\u00e2nea (DE): consulta no dia",
              "Demanda espont\u00e2nea (DE): atendimento de urg\u00eancia",
              "Sem registro no modelo de informa\u00e7\u00e3o de origem"
            ],
            "description": "Car\u00e1ter do atendimento. Terminologia que classifica a prioridade de realiza\u00e7\u00e3o de um Contato Assistencial."
          },
          "dsMotivDesfech": {
            "type": "string",
            "enum": [
              "Alta cl\u00ednica",
              "Alta Volunt\u00e1ria",
              "Encaminhamento",
              "Evas\u00e3o",
              "Ordem Judicial",
              "\u00d3bito",
              "Perman\u00eancia",
              "Retorno",
              "Transfer\u00eancia",
              "Sem registro no modelo de informa\u00e7\u00e3o de origem"
            ],
            "description": "Desfecho do atendimento. Caracteriza o motivo de conclus\u00e3o total ou parcial do contato assistencial."
          },
          "conduta": {
            "type": "string",
            "default": "\"\"",
            "example": "RETORNO COM 30 DIAS COM RESULTADO DE CVC.",
            "description": "Conduta prescrita pelo profissional de sa\u00fade para o paciente."
          },
          "paciente": {
            "$ref": "#/components/schemas/Paciente"
          },
          "profis": {
            "$ref": "#/components/schemas/Profissional"
          },
          "diagnosticos": {
            "type": "array",
            "description": "Lista de diagn\u00f3sticos do atendimento.",
            "items": {
              "$ref": "#/components/schemas/Diagnostico"
            }
          },
          "procedimentos": {
            "type": "array",
            "description": "Lista de procedimentos realizados no atendimento.",
            "items": {
              "$ref": "#/components/schemas/Procedimento"
            }
          },
          "atestados": {
            "type": "array",
            "description": "Lista de atestados do atendimento.",
            "items": {
              "$ref": "#/components/schemas/Atestado"
            }
          }
        },
        "required": [
          "idAtend",
          "cdCnes",
          "dtMomentInic",
          "dtMomentFim",
          "dsProcdn",
          "dsModalAssist",
          "dsModalCaratAtend",
          "dsMotivDesfech",
          "conduta",
          "paciente",
          "profis",
          "diagnosticos",
          "procedimentos"
        ]
      },
      "Paciente": {
        "description": "Informa\u00e7\u00f5es referente ao paciente do atendimento. Dever\u00e1 ser informado ao menos uma das propriedades, CPF ou CNS.",
        "type": "object",
        "properties": {
          "cdCpf": {
            "description": "CPF do paciente, contendo apenas n\u00fameros e com exatamente 11 caracteres.",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "example": "00000000000",
            "default": "\"\""
          },
          "cdCns": {
            "description": "CNS do paciente, contendo apenas n\u00fameros e com exatamente 15 caracteres.",
            "type": "string",
            "minLength": 15,
            "maxLength": 15,
            "example": "000000000000000",
            "default": "\"\""
          }
        },
        "required": [
          "cdCpf",
          "cdCns"
        ]
      },
      "Profissional": {
        "description": "Informa\u00e7\u00f5es referente ao profissional de sa\u00fade. Dever\u00e1 ser informado ao menos uma das propriedades, CPF ou CNS.",
        "type": "object",
        "properties": {
          "cdCpf": {
            "description": "CPF do profissional, contendo apenas n\u00fameros e com exatamente 11 caracteres.",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "example": "00000000000"
          },
          "cdCns": {
            "description": "CNS do profissional, contendo apenas n\u00fameros e com exatamente 15 caracteres.",
            "type": "string",
            "minLength": 15,
            "maxLength": 15,
            "example": "000000000000000"
          },
          "cdCbo": {
            "type": "string",
            "description": "CBO do profissional.",
            "example": "225112"
          }
        },
        "required": [
          "cdCpf",
          "cdCns",
          "cdCbo"
        ]
      },
      "Diagnostico": {
        "description": "Diagn\u00f3stico atribu\u00eddo pelo profissional de sa\u00fade ao indiv\u00edduo no contato assistencial.",
        "type": "object",
        "properties": {
          "flDiagnPrincipal": {
            "description": "Indica se \u00e9 o diagn\u00f3stico principal. 1 para sim e 0 para n\u00e3o.",
            "type": "string",
            "enum": [
              "1",
              "0",
              "\"\""
            ],
            "default": "\"\"",
            "example": "1"
          },
          "dsStatus": {
            "description": "Situa\u00e7\u00e3o que o diagn\u00f3stico se encontra no momento da informa\u00e7\u00e3o.",
            "type": "string",
            "default": "\"\"",
            "example": "active",
            "enum": [
              "active",
              "recurrence",
              "relapse",
              "inactive",
              "remission",
              "resolved",
              "\"\""
            ]
          },
          "cdDiag": {
            "description": "C\u00f3digo CID10 ou CIAP2.",
            "type": "string",
            "example": "K30"
          },
          "dsDiagn": {
            "description": "Informa\u00e7\u00f5es complementares a respeito do diagn\u00f3stico. Este atributo \u00e9 opcional se n\u00e3o houver valor informar como string vazia",
            "type": "string",
            "default": "\"\"",
            "example": "Dispepsia"
          }
        },
        "required": [
          "flDiagnPrincipal",
          "dsStatus",
          "cdDiag",
          "dsDiagn"
        ]
      },
      "Procedimento": {
        "description": "Procedimento realizado no indiv\u00edduo.",
        "type": "object",
        "properties": {
          "qtdProced": {
            "description": "N\u00famero  de vezes que o procedimento foi realizado.",
            "type": "string",
            "example": 1
          },
          "dtProced": {
            "description": "Data de execu\u00e7\u00e3o do procedimento no formato yyyy-MM-dd HH:mm:ss.",
            "type": "string",
            "example": "2024-01-04 00:00:00"
          },
          "cdProced": {
            "description": "C\u00f3digo SIGTAP do procedimento que foi realizado.",
            "type": "string",
            "example": 35938368
          },
          "profisResp": {
            "$ref": "#/components/schemas/Profissional"
          }
        },
        "required": [
          "nuQuant",
          "dtProced",
          "cdProced",
          "profisResp"
        ]
      },
      "Atestado": {
        "description": "Informa\u00e7\u00f5es referente ao atestado m\u00e9dico do atendimento. Dever\u00e1 ser informado tanto a data de in\u00edcio quanto a quantidade de dias do afastamento.",
        "type": "object",
        "properties": {
          "dsStatus": {
            "description": "Situa\u00e7\u00e3o que o diagn\u00f3stico se encontra no momento da informa\u00e7\u00e3o.",
            "type": "string",
            "default": "\"\"",
            "example": "active",
            "enum": [
              "active",
              "recurrence",
              "relapse",
              "inactive",
              "remission",
              "resolved",
              "\"\""
            ]
          },
          "cdDiag": {
            "description": "C\u00f3digo CID10 ou CIAP2.",
            "type": "string",
            "example": "K30"
          },
          "dtInicioAtestado": {
            "description": "Data de inicio do afastamento no formato yyyy-MM-dd.",
            "type": "string",
            "example": "2024-01-04"
          },
          "nuPeriodo": {
            "description": "Tempo do afastamento quantificado em dias.",
            "type": "string",
            "example": 3
          },
          "dsObsClinica": {
            "description": "Informa\u00e7\u00f5es complementares a respeito do afastamento. Este atributo \u00e9 opcional se n\u00e3o houver valor informar como string vazia.",
            "type": "string",
            "default": "\"\"",
            "example": "Necessita muito"
          }
        },
        "required": [
          "dtInicioAtestado",
          "nuPeriodo"
        ]
      }
    }
  }
}