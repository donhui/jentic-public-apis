{
  "openapi": "3.0.0",
  "info": {
    "title": "API de Contatos",
    "version": "1.0.0",
    "description": "Aplica\u00e7\u00e3o para gerenciamento de contatos de pessoas e organiza\u00e7\u00f5es",
    "contact": {
      "email": "rommelcarneiro@servidor.net",
