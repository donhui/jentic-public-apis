      "url": "https://virtserver.swaggerhub.com/rommelcarneiro/APIContatos/1.0.0-oas3"
    },
    {
      "url": "http://localhost:5500",
      "variables": {},
      "description": "Servidor Local"
    }
  ],
  "paths": {
    "/pessoas": {
      "summary": "Manipular informa\u00e7\u00f5es relacionadas \u00e0s pessoas da aplica\u00e7\u00e3o",
      "get": {
        "summary": "Listar pessoas cadastradas",
        "tags": [
          "Pessoas"
        ],
        "description": "Retorna um array de pessoas ",
        "operationId": "listaPessoas",
        "parameters": [
          {
            "in": "query",
            "name": "search",
            "description": "Texto a ser procurado no nome das pessoas",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "order",
            "description": "Crit\u00e9rio de ordena\u00e7\u00e3o dos resultados (ascendente | descedente)",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          },
          {
            "in": "query",
            "name": "tags",
            "description": "Tags a serem procuradas nas pessoas cadastradas",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Opera\u00e7\u00e3o bem sucedida",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Pessoa"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Cadastrar uma pessoa",
        "tags": [
          "Pessoas"
        ],
        "description": "",
        "operationId": "inserePessoa",
        "requestBody": {
          "description": "Pessoa a ser inserida",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Pessoa"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Recurso inserido com sucesso"
          }
        }
      }
    },
    "/pessoas/{idPessoa}": {
      "get": {
        "summary": "Obter uma pessoa espec\u00edfica por meio do ID",
        "operationId": "listaPessoaPorId",
        "tags": [
          "Pessoas"
        ],
        "parameters": [
          {
            "in": "path",
            "required": true,
            "name": "idPessoa",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Opera\u00e7\u00e3o bem sucedida",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pessoa"
                }
              }
            }
          },
          "404": {
            "description": "Pessoa n\u00e3o encontrada"
          }
        }
      },
      "put": {
        "summary": "Alterar uma pessoa espec\u00edfica por meio do ID",
        "operationId": "alteraPessoa",
        "tags": [
          "Pessoas"
        ],
        "parameters": [
          {
            "in": "path",
            "required": true,
            "name": "idPessoa",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Recurso alterado com sucesso"
          },
          "400": {
            "description": "Erro ao alterar o recurso no servidor"
          }
        }
      },
      "delete": {
        "summary": "Alterar uma pessoa espec\u00edfica por meio do ID",
        "tags": [
          "Pessoas"
        ],
        "parameters": [
          {
            "in": "path",
            "required": true,
            "name": "idPessoa",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Recurso exclu\u00eddo com sucesso"
          },
          "400": {
            "description": "Erro ao excluir o recurso no servidor"
          }
        }
      }
    },
    "/pessoas/{tag}": {
      "get": {
        "summary": "Listar pessoas cadastradas",
        "tags": [
          "Pessoas"
        ],
        "parameters": [
          {
            "in": "path",
            "required": true,
            "name": "tag",
            "schema": {
              "type": "string"
            }
          }
        ],
        "description": "",
        "operationId": "listaPessoasPorTag",
        "responses": {
          "200": {
            "description": "Opera\u00e7\u00e3o bem sucedida",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Pessoa"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Pessoa": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "nome": {
            "type": "string",
            "description": "Nome da referida pessoa"
          },
          "email": {
            "type": "string",
            "description": "Endere\u00e7o eletr\u00f4nico da pessoa"
          },
          "telefone": {
            "type": "string",
            "description": "Endere\u00e7o eletr\u00f4nico da pessoa"
          },
          "Organizacao": {
            "$ref": "#/components/schemas/Organizacao"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "nome",
          "email"
        ],
        "example": {
          "id": 5,
          "nome": "Francis Ford Copolla",
          "email": "copolla@hollywood.com",
          "telefone": "001-124-2111",
          "organizacao": null,
          "tags": [
            "cinema",
            "trabalho"
          ]
        }
      },
      "Organizacao": {
        "title": "Organizacao",
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "nome": {
            "type": "string"
          },
          "segmento": {
            "type": "string"
          },
          "endereco": {
            "type": "string"
          },
          "cidade": {
            "type": "string"
          },
          "cep": {
            "type": "string"
          },
          "estado": {
            "type": "string"
          },
          "telefones": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "nome",
          "segmento"
        ],
        "example": {
          "id": 1,
          "nome": "Acme Corporation",
          "segmento": "Varejo",
          "endereco": "Av. Rebol\u00e7as, 422 - Centro",
          "cidade": "S\u00e3o Paulo",
          "cep": "33422-990",
          "estado": "SP",
          "telefones": [
            "11-3234-5543",
            "11-4425-5544"
          ]
        }
      }
    }
  }
}