    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/semcompany-ae4/APIContatos2/1.0.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/semcompany-ae4/APIContatos2/1.0.0"
