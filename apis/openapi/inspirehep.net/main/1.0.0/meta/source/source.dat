{
  "openapi": "3.0.3",
  "info": {
    "title": "INSPIRE HEP API",
    "description": "INSPIRE is a trusted community hub that helps researchers in high energy physics and related fields to share and find accurate scholarly information on literature, authors, institutions, conferences, journals, jobs, experiments, seminars, and data. Rate limited to 15 requests per 5 seconds per IP.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://github.com/inspirehep/rest-api-doc"
  },
  "servers": [
    {
      "url": "https://inspirehep.net/api",
      "description": "Production server"
    }
  ],
  "security": [],
  "paths": {
    "/literature": {
      "get": {
        "operationId": "searchLiterature",
        "summary": "Search literature records",
        "description": "Search and list literature records with pagination. Supports INSPIRE search syntax and ElasticSearch queries.",
        "tags": [
          "Literature"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query using INSPIRE search syntax"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "mostrecent",
                "mostcited"
              ]
            },
            "description": "Sort order for results"
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 1000
            },
            "description": "Number of results per page"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of metadata fields to return"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "json-expanded",
                "bibtex",
                "latex-eu",
                "latex-us",
                "cv"
              ]
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/literature/{id}": {
      "get": {
        "operationId": "getLiterature",
        "summary": "Get a literature record by ID",
        "description": "Retrieve a specific literature record by its INSPIRE record ID.",
        "tags": [
          "Literature"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "INSPIRE record identifier"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "json-expanded",
                "bibtex",
                "latex-eu",
                "latex-us",
                "cv"
              ]
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Literature record",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Record not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
