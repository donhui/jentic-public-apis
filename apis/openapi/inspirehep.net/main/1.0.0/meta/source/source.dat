    "/bibliography-generator": {
      "post": {
        "operationId": "generateBibliography",
        "summary": "Generate bibliography from TeX file",
        "description": "Upload a TeX document with \\cite commands and generate a bibliography file in the specified format.",
        "tags": [
          "Bibliography"
        ],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "bibtex",
                "latex_eu",
                "latex_us"
              ]
            },
            "description": "Output bibliography format"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "TeX document file containing \\cite commands"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated bibliography",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BibliographyResult"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/data": {
      "get": {
        "operationId": "searchData",
        "summary": "Search data records",
        "description": "Search and list data records (e.g., HEPData entries) with pagination.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 1000
            },
            "description": "Results per page"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/data/{id}": {
      "get": {
        "operationId": "getData",
        "summary": "Get a data record by ID",
        "description": "Retrieve a specific data record by its INSPIRE record ID.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "INSPIRE record identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Data record",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Record not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Record": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Record identifier"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "UTC timestamp of record creation"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "UTC timestamp of last modification"
          },
          "links": {
            "type": "object",
            "description": "Related resource URLs",
            "properties": {
              "json": {
                "type": "string",
                "description": "JSON format URL"
              },
              "bibtex": {
                "type": "string",
                "description": "BibTeX format URL"
              }
            }
          },
          "metadata": {
            "type": "object",
            "description": "Record metadata (varies by record type)"
          }
        }
      },
      "SearchResults": {
        "type": "object",
        "properties": {
          "hits": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "description": "Total number of matching results"
              },
              "hits": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Record"
                },
                "description": "Array of record objects"
              }
            }
          },
          "links": {
            "type": "object",
            "properties": {
              "self": {
                "type": "string",
                "description": "URL for current page"
              },
              "next": {
                "type": "string",
                "description": "URL for next page of results"
              },
              "prev": {
                "type": "string",
                "description": "URL for previous page of results"
              }
            }
          }
        }
      },
      "BibliographyResult": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "download_url": {
                "type": "string",
                "description": "URL to download the generated bibliography file"
              },
              "errors": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Any errors encountered during generation"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Literature",
      "description": "Literature records search and retrieval"
    },
    {
      "name": "Authors",
      "description": "Author records search and retrieval"
    },
    {
      "name": "Institutions",
      "description": "Institution records search and retrieval"
    },
    {
      "name": "Conferences",
      "description": "Conference records search and retrieval"
    },
    {
      "name": "Journals",
      "description": "Journal records search and retrieval"
    },
    {
      "name": "Jobs",
      "description": "Job posting records search and retrieval"
    },
    {
      "name": "Experiments",
      "description": "Experiment records search and retrieval"
    },
    {
      "name": "Seminars",
      "description": "Seminar records search and retrieval"
    },
    {
      "name": "External Identifiers",
      "description": "Lookup records by DOI, arXiv ID, or ORCID"
    },
    {
      "name": "Bibliography",
      "description": "Bibliography generation from TeX files"
    },
    {
      "name": "Data",
      "description": "Data records (e.g., HEPData) search and retrieval"
    }
  ]
}