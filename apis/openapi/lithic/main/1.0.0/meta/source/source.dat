              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Lithic API key. Provide as Bearer token in Authorization header."
      }
    },
    "schemas": {
      "Card": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid",
            "description": "Unique card identifier"
          },
          "account_token": {
            "type": "string",
            "format": "uuid",
            "description": "Associated account identifier"
          },
          "card_program_token": {
            "type": "string",
            "format": "uuid",
            "description": "Card program reference"
          },
          "type": {
            "type": "string",
            "description": "Card type",
            "enum": ["VIRTUAL", "PHYSICAL", "MERCHANT_LOCKED", "SINGLE_USE"]
          },
          "state": {
            "type": "string",
            "description": "Current card state",
            "enum": ["OPEN", "PAUSED", "CLOSED", "PENDING_FULFILLMENT", "PENDING_ACTIVATION"]
          },
          "last_four": {
            "type": "string",
            "description": "Last four digits of the card number"
          },
          "pan": {
            "type": "string",
            "description": "Primary account number (full card number)"
          },
          "exp_month": {
            "type": "integer",
            "description": "Expiration month"
          },
          "exp_year": {
            "type": "integer",
            "description": "Expiration year"
          },
          "memo": {
            "type": "string",
            "description": "Internal reference note"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          }
        }
      },
      "CardListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Card"
            }
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more results"
          }
        }
      },
      "CreateCardRequest": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Card type",
            "enum": ["VIRTUAL", "PHYSICAL", "MERCHANT_LOCKED", "SINGLE_USE"]
          },
          "account_token": {
            "type": "string",
            "format": "uuid",
            "description": "Account identifier for card association"
          },
          "card_program_token": {
            "type": "string",
            "format": "uuid",
            "description": "Specific card program selection"
          },
          "product_id": {
            "type": "string",
            "description": "Product identifier (physical cards only)"
          },
          "shipping_address": {
            "$ref": "#/components/schemas/ShippingAddress"
          },
          "memo": {
            "type": "string",
            "description": "Internal reference note"
          }
        }
      },
      "UpdateCardRequest": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "description": "Card state to update to",
            "enum": ["OPEN", "PAUSED", "CLOSED"]
          },
          "memo": {
            "type": "string",
            "description": "Internal reference note"
          }
        }
      },
      "ProvisionCardRequest": {
        "type": "object",
        "properties": {
          "digital_wallet": {
            "type": "string",
            "description": "Target digital wallet",
            "enum": ["APPLE_PAY", "GOOGLE_PAY", "SAMSUNG_PAY"]
          },
          "nonce": {
            "type": "string",
            "description": "Nonce from the digital wallet provider"
          },
          "nonce_signature": {
            "type": "string",
            "description": "Signature of the nonce"
          },
          "certificate": {
            "type": "string",
            "description": "Certificate from the digital wallet provider"
          }
        }
      },
      "ProvisionCardResponse": {
        "type": "object",
        "properties": {
          "provisioning_payload": {
            "type": "string",
            "description": "Provisioning payload to pass to the digital wallet"
          }
        }
      },
      "ShippingAddress": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "line1": {
            "type": "string"
          },
          "line2": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-3 country code"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique account identifier"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Account creation timestamp"
          },
          "status": {
            "type": "string",
            "description": "KYC/KYB evaluation status"
          },
          "email": {
            "type": "string",
            "description": "Primary email address"
          },
          "phone_number": {
            "type": "string",
            "description": "Contact phone number in E.164 format"
          },
          "external_id": {
            "type": "string",
            "description": "Customer-provided external identifier"
          },
          "user_type": {
            "type": "string",
            "description": "Account holder type",
            "enum": ["INDIVIDUAL", "BUSINESS"]
          }
        }
      },
      "AccountListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Account"
            }
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more accounts"
          }
        }
      },
      "UpdateAccountRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Updated email address"
          },
          "phone_number": {
            "type": "string",
            "description": "Updated phone number in E.164 format"
          }
        }
      },
      "SpendLimits": {
        "type": "object",
        "properties": {
          "daily": {
            "type": "object",
            "properties": {
              "available": {
                "type": "integer",
                "description": "Available daily spend in smallest currency unit"
              },
              "limit": {
                "type": "integer",
                "description": "Daily spend limit in smallest currency unit"
              },
              "used": {
                "type": "integer",
                "description": "Amount used today in smallest currency unit"
              }
            }
          },
          "monthly": {
            "type": "object",
            "properties": {
              "available": {
                "type": "integer",
                "description": "Available monthly spend"
              },
              "limit": {
                "type": "integer",
                "description": "Monthly spend limit"
              },
              "used": {
                "type": "integer",
                "description": "Amount used this month"
              }
            }
          },
          "lifetime": {
            "type": "object",
            "properties": {
              "available": {
                "type": "integer",
                "description": "Available lifetime spend"
              },
              "limit": {
                "type": "integer",
                "description": "Lifetime spend limit"
              },
              "used": {
                "type": "integer",
                "description": "Amount used lifetime"
              }
            }
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid",
            "description": "Unique transaction identifier"
          },
          "card_token": {
            "type": "string",
            "format": "uuid",
            "description": "Token of the card used"
          },
          "account_token": {
            "type": "string",
            "format": "uuid",
            "description": "Token of the associated account"
          },
          "amount": {
            "type": "integer",
            "description": "Transaction amount in smallest currency unit"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "status": {
            "type": "string",
            "description": "Transaction status",
            "enum": ["PENDING", "VOIDED", "SETTLED", "DECLINED", "EXPIRED"]
          },
          "result": {
            "type": "string",
            "description": "Transaction result",
            "enum": ["APPROVED", "DECLINED"]
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Transaction creation timestamp"
          },
          "merchant": {
            "type": "object",
            "properties": {
              "descriptor": {
                "type": "string",
                "description": "Merchant descriptor"
              },
              "mcc": {
                "type": "string",
                "description": "Merchant category code"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "country": {
                "type": "string"
              }
            }
          }
        }
      },
      "TransactionListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more transactions"
          }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid",
            "description": "Unique payment identifier"
          },
          "category": {
            "type": "string",
            "description": "Payment category"
          },
          "status": {
            "type": "string",
            "description": "Payment status"
          },
          "result": {
            "type": "string",
            "description": "Payment result"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Payment creation timestamp"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          },
          "financial_account_token": {
            "type": "string",
            "format": "uuid",
            "description": "Financial account token"
          },
          "direction": {
            "type": "string",
            "description": "Payment direction",
            "enum": ["CREDIT", "DEBIT"]
          },
          "method": {
            "type": "string",
            "description": "Payment method",
            "enum": ["ACH_NEXT_DAY", "ACH_SAME_DAY"]
          }
        }
      },
      "PaymentListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Payment"
            }
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more payments"
          }
        }
      },
      "CreatePaymentRequest": {
        "type": "object",
        "required": ["amount", "financial_account_token", "external_bank_account_token", "method", "type"],
        "properties": {
          "amount": {
            "type": "integer",
            "description": "Amount in smallest currency unit"
          },
          "financial_account_token": {
            "type": "string",
            "format": "uuid",
            "description": "Financial account token"
          },
          "external_bank_account_token": {
            "type": "string",
            "format": "uuid",
            "description": "External bank account token"
          },
          "method": {
            "type": "string",
            "description": "Payment method",
            "enum": ["ACH_NEXT_DAY", "ACH_SAME_DAY"]
          },
          "type": {
            "type": "string",
            "description": "Payment type",
            "enum": ["COLLECTION", "PAYMENT"]
          },
          "memo": {
            "type": "string",
            "description": "Memo for the payment"
          }
        }
      },
      "ThreeDsAuthentication": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid",
            "description": "3DS authentication token"
          },
          "card_token": {
            "type": "string",
            "format": "uuid",
            "description": "Card token"
          },
          "transaction_token": {
            "type": "string",
            "format": "uuid",
            "description": "Transaction token"
          },
          "authentication_result": {
            "type": "string",
            "description": "Authentication result"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          }
        }
      },
      "SimulateThreeDsRequest": {
        "type": "object",
        "properties": {
          "merchant": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "mcc": {
                "type": "string"
              },
              "country": {
                "type": "string"
              }
            }
          },
          "pan": {
            "type": "string",
            "description": "Card PAN"
          },
          "transaction": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "integer"
              },
              "currency": {
                "type": "string"
              }
            }
          }
        }
      },
      "SimulateAuthorizationRequest": {
        "type": "object",
        "required": ["amount", "descriptor", "pan"],
        "properties": {
          "amount": {
            "type": "integer",
            "description": "Authorization amount in smallest currency unit"
          },
          "descriptor": {
            "type": "string",
            "description": "Merchant descriptor"
          },
          "pan": {
            "type": "string",
            "description": "Card PAN to authorize against"
          },
          "mcc": {
            "type": "string",
            "description": "Merchant category code"
          },
          "merchant_currency": {
            "type": "string",
            "description": "Merchant currency"
          }
        }
      },
      "SimulateAuthorizationResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid",
            "description": "Transaction token"
          },
          "debugging_request_id": {
            "type": "string",
            "description": "Request ID for debugging"
          }
        }
      },
      "SimulateClearingRequest": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid",
            "description": "Transaction token to clear"
          },
          "amount": {
            "type": "integer",
            "description": "Clearing amount (defaults to authorization amount)"
          }
        }
      },
      "SimulateClearingResponse": {
        "type": "object",
        "properties": {
          "debugging_request_id": {
            "type": "string",
            "description": "Request ID for debugging"
          }
        }
      },
      "AuthRule": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "format": "uuid",
            "description": "Unique rule identifier"
          },
          "state": {
            "type": "string",
            "description": "Rule state",
            "enum": ["ACTIVE", "INACTIVE"]
          },
          "program_level": {
            "type": "boolean",
            "description": "Whether this is a program-level rule"
          },
          "card_tokens": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Cards this rule applies to"
          },
          "account_tokens": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Accounts this rule applies to"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AuthRuleListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthRule"
            }
          },
          "has_more": {
            "type": "boolean"
          }
        }
      },
      "CreateAuthRuleRequest": {
        "type": "object",
        "properties": {
          "card_tokens": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
