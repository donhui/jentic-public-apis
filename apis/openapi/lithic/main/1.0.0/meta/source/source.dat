{
  "openapi": "3.0.3",
  "info": {
    "title": "Lithic Card Issuing API",
    "description": "Lithic API for card issuing, transaction management, and account operations. Provides programmatic access to create and manage virtual and physical cards, process transactions, and manage accounts.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.lithic.com/reference"
  },
  "servers": [
    {
      "url": "https://api.lithic.com",
      "description": "Production"
    },
    {
      "url": "https://sandbox.lithic.com",
      "description": "Sandbox"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cards",
      "description": "Card creation and management"
    },
    {
      "name": "Accounts",
      "description": "Account management"
    },
    {
      "name": "Transactions",
      "description": "Transaction operations"
    },
    {
      "name": "Payments",
      "description": "Payment operations"
    },
    {
      "name": "ThreeDS",
      "description": "3DS authentication operations"
    },
    {
      "name": "AuthRules",
      "description": "Authorization rules management"
    },
    {
      "name": "Simulation",
      "description": "Sandbox simulation endpoints"
    }
  ],
  "paths": {
    "/v1/cards": {
      "get": {
        "operationId": "listCards",
        "summary": "List all cards",
        "description": "Returns a paginated list of cards.",
        "tags": ["Cards"],
        "parameters": [
          {
            "name": "begin",
            "in": "query",
            "description": "Date string in RFC 3339 format. Only entries created after the specified time will be included.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "Date string in RFC 3339 format. Only entries created before the specified time will be included.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of cards to return.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "starting_after",
            "in": "query",
            "description": "A cursor representing an item's token after which a page of results should begin.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ending_before",
            "in": "query",
            "description": "A cursor representing an item's token before which a page of results should end.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of cards",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CardListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCard",
        "summary": "Create a new card",
        "description": "Creates a new virtual or physical card associated with an account.",
        "tags": ["Cards"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCardRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Card"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/cards/{card_token}": {
      "get": {
        "operationId": "getCard",
        "summary": "Get a card",
        "description": "Retrieves details of a specific card by its token.",
        "tags": ["Cards"],
        "parameters": [
          {
            "name": "card_token",
            "in": "path",
            "required": true,
            "description": "Unique card token identifier.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Card details",
