    "/v2/auth_rules": {
      "get": {
        "operationId": "listAuthRules",
        "summary": "List authorization rules",
        "description": "Returns a list of authorization rules.",
        "tags": ["AuthRules"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of rules to return.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "starting_after",
            "in": "query",
            "description": "A cursor for pagination.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ending_before",
            "in": "query",
            "description": "A cursor for pagination.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of authorization rules",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthRuleListResponse"
