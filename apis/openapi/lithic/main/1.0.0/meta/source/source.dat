            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAuthRule",
        "summary": "Delete an authorization rule",
        "description": "Deletes an authorization rule.",
        "tags": ["AuthRules"],
        "parameters": [
          {
            "name": "auth_rule_token",
            "in": "path",
            "required": true,
            "description": "Unique authorization rule token.",
            "schema": {
