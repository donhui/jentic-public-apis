    "/v1/transactions": {
      "get": {
        "operationId": "listTransactions",
        "summary": "List transactions",
        "description": "Returns a paginated list of transactions. All amounts are in the smallest unit of their respective currency.",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "begin",
            "in": "query",
            "description": "Date string in RFC 3339 format. Only entries created after the specified time will be included. UTC time zone.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "Date string in RFC 3339 format. Only entries created before the specified time will be included. UTC time zone.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of transactions to return.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "starting_after",
            "in": "query",
            "description": "A cursor representing an item's token after which a page of results should begin.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ending_before",
            "in": "query",
            "description": "A cursor representing an item's token before which a page of results should end.",
            "schema": {
              "type": "string"
            }
