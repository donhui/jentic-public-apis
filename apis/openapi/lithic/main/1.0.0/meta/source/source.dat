          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProvisionCardRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Provisioning result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvisionCardResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
