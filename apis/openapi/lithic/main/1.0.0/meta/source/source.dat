              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Authorization rule deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "format": "uuid",
