{
  "openapi": "3.0.3",
  "info": {
    "title": "Dots.eco Impact API",
    "description": "Dots.eco Impact API for creating environmental impact certificates, managing allocations, and retrieving impact summaries.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.impact.dots.eco",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "authToken": []
    }
  ],
  "paths": {
    "/certificateRequestAllocation/": {
      "post": {
        "summary": "Create certificate",
        "description": "Create a new environmental impact certificate",
        "operationId": "createCertificate",
        "tags": ["Certificates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "impactType": { "type": "string", "description": "Desired impact type" },
                  "impactQuantity": { "type": "number", "description": "Impact quantity" },
                  "endUserIdentifier": { "type": "string", "description": "End-user identifier" },
                  "companyIdentifier": { "type": "string", "description": "Company identifier" },
                  "applicationIdentifier": { "type": "string", "description": "Application (APP) identifier" },
                  "userEmail": { "type": "string", "format": "email", "description": "User email (optional)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Certificate created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Certificate" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/ecoClubAdd/": {
      "post": {
        "summary": "Create certificate with redeem code",
        "operationId": "createCertificateWithRedeemCode",
        "tags": ["Certificates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "Certificate created with redeem code" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/appRequests/": {
      "post": {
        "summary": "Create an app",
        "operationId": "createApp",
        "tags": ["Applications"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "App created" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/certificateList/": {
      "get": {
        "summary": "Get certificate list",
        "operationId": "listCertificates",
        "tags": ["Certificates"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Certificate" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/singleCertificate/": {
      "get": {
        "summary": "Retrieve single certificate",
        "operationId": "getCertificate",
        "tags": ["Certificates"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Certificate" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/singleCertificateByAppIdAndExternalUniqueId/": {
      "get": {
        "summary": "Retrieve certificate by app ID and external ID",
        "operationId": "getCertificateByAppAndExternalId",
        "tags": ["Certificates"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Certificate" }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/ecoClubOfferingList/": {
      "get": {
        "summary": "List eco club offerings",
        "operationId": "listEcoClubOfferings",
        "tags": ["Eco Club"],
        "responses": {
          "200": { "description": "Successful response" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/impactSummary/": {
      "get": {
        "summary": "Impact summary by project",
        "operationId": "getImpactSummary",
        "tags": ["Impact"],
        "responses": {
          "200": { "description": "Successful response" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/allocationByCompany/": {
      "get": {
        "summary": "List available allocations",
        "operationId": "listAllocations",
        "tags": ["Allocations"],
        "responses": {
          "200": { "description": "Successful response" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/impactSummaryTotals/": {
      "get": {
        "summary": "Impact summary totals",
        "operationId": "getImpactSummaryTotals",
        "tags": ["Impact"],
        "responses": {
          "200": { "description": "Successful response" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/applicationBalance/": {
      "get": {
        "summary": "Application balance",
        "operationId": "getApplicationBalance",
        "tags": ["Applications"],
        "responses": {
          "200": { "description": "Successful response" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "authToken": {
        "type": "apiKey",
        "in": "header",
        "name": "auth-token"
      }
    },
    "schemas": {
      "Certificate": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "impactType": { "type": "string" },
          "impactQuantity": { "type": "number" },
          "endUserIdentifier": { "type": "string" },
          "companyIdentifier": { "type": "string" },
          "applicationIdentifier": { "type": "string" },
          "userEmail": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}