{
  "openapi": "3.0.3",
  "info": {
    "title": "Text In Church API",
    "description": "Text In Church messaging and contact management API for church communications, including messaging, contacts, groups, calls, workflows, and connect cards.",
    "version": "1.0",
    "x-jentic-source-url": "https://api-docs.textinchurch.com/"
  },
  "servers": [
    {
      "url": "https://api.textinchurch.com/API/1_0",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Account",
      "description": "Account management"
    },
    {
      "name": "Contacts",
      "description": "Contact management"
    },
    {
      "name": "Messages",
      "description": "Messaging and conversations"
    },
    {
      "name": "Groups",
      "description": "Group management"
    },
    {
      "name": "Calls",
      "description": "Call management"
    },
    {
      "name": "Connect Cards",
      "description": "Connect card management"
    },
    {
      "name": "Workflows",
      "description": "Workflow automation"
    },
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Webhooks",
      "description": "Webhook management"
    },
    {
      "name": "Files",
      "description": "File management"
    }
  ],
  "paths": {
    "/account.php": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account details",
        "tags": ["Account"],
        "parameters": [
          { "name": "account_id", "in": "query", "schema": { "type": "string" } },
          { "name": "account_name", "in": "query", "schema": { "type": "string" } },
          { "name": "hash", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "load_approval_status", "in": "query", "schema": { "type": "string" } },
          { "name": "load_connections", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "string" } },
          { "name": "offset", "in": "query", "schema": { "type": "string" } },
          { "name": "order_by", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Account details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AccountResponse" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
