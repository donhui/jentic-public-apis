{
  "openapi": "3.0.0",
  "info": {
    "version": "3.0.0",
    "title": "av_controller_digicel",
    "description": "This is the NiFi controller used for Digicel.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/airvantage-team/av_controller_digicel/3.0.0/swagger.json"
  },
  "paths": {
    "/getAdvanceBalance": {
      "get": {
        "operationId": "GET_getAdvanceBalance",
        "summary": "This endpoint is used to get a subscriber's balance.",
        "tags": [
          "Internal"
        ],
        "description": "This endpoint is used to perform a balance check for a given MSISDN.\n\n<b>Business Errors:</b>\n\nSince the payment feed is offline, the balances in the Airvantage databases will momentarily be out of sync with the balances at Digicel from time to time. As such, we have accounted for two possible error responses\n\n200_business_error_1: This is a response obtained when the subscriber's balance reigistered at Airvantage is greater than that at Digicel i.e av_balance > digicel_balance\n\n200_business_error_2: This is a response obtained when the subscriber's balance reigistered at Airvantage is less that at Digicel i.e av_balance < digicel_balance",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "description": "The MSISDN unique to the subscrier.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        }
      }
    },
    "/processAdvance": {
      "get": {
        "operationId": "GET_processAdvance",
        "summary": "This endpoint is called when a subscriber's advance should be processed.",
        "tags": [
          "Internal"
        ],
        "description": "The process advance endpoint can be called by av_microservice_ussd to add an advance to the advance table of av_microservice_lending for the respective island i.e. jamaica/barbados.\n\nThe av_controller_digicel will first check if the subscriber doesn't have an open advance, etc. The getAdvanceStatusSummary endpoint will be called on av_microservice_lending.\n\nIf the subscriber doesn't have an advance the controller will be held responsible for adding the advance and sending a advance confirmation SMS to the subscriber.\n\nThis endpoint also allows for multiple advaces to be taken by a single subscriber.",
        "parameters": [
          {
            "name": "entityType",
            "in": "query",
            "description": "This is the type of recharge being made. \n1 - MoMo \n2 - Airtime\n3 - Data\n\ndefault: 2",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "loanAmount",
            "in": "query",
            "description": "The amount the subscriber wants to borrow.\n\n",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "loanDate",
            "in": "query",
            "description": "The date that the loan is taken. The format of the date should be yyyy/MM/dd HH:mm:ss",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "msisdn",
            "in": "query",
            "description": "The MSISDN unique to the subscrier.\n\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "profileTierId",
            "in": "query",
            "description": "The profileTierId from av_microservice_profiler.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "serviceAmount",
            "in": "query",
            "description": "The service fee amount that is allocated to AV for granting the recharge amount. Usually dynamic.",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "qualifiedAmount",
            "in": "query",
            "description": "The amount that the subscriber qualified for from av_microservice_profiler.",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "denomListId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "channelId",
            "in": "query",
            "description": "1- UNKNOWN<br>\n2 - USSD</br>\n3 - SMS<br>\n4 - ZERO BALANCE",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "rechargeAmount",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        }
      }
    },
    "/getAvailablePlansESIF": {
      "get": {
        "operationId": "GET_getAvailablePlansESIF",
        "summary": "This endpoint is called to retrieve the available plans for a subscriber who wants to take a data advance.",
        "tags": [
          "Internal"
        ],
        "description": "The available plans retrieved is checked on both what the usbscriber qualifies for via a  call to av_microservice_profiler/getLoanableAmount and which plans are available to the subscriber via a call to av_integration_digicel/getAvailablePlansESIF. \nThe two responses from the two calls are then filtered based on what has been returned from the  denomination list from the profiler and which plans the subscriber qualifies for. ",
        "parameters": [
          {
            "name": "ext",
            "in": "query",
            "description": "Extend response to include allowed denominations, recharge lists and service fees.\next=1 -> separate arrays for different value ranges\next=2 -> JSON array per different recharge item",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2
            }
          },
          {
            "name": "msisdn",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 8,
              "maxLength": 13
            }
          },
          {
            "name": "queryParameterA",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "denomId",
            "in": "query",
            "description": "Which list of denominations should be displayed?  ",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          }
        ],
        "responses": {
          "202": {
            "description": "MAX",
            "content": {
              "application/text": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "profilingcode": {
                          "type": "string"
                        },
                        "loanamount": {
                          "type": "string"
                        },
                        "repaydays": {
                          "type": "string"
                        },
                        "gracePeriod": {
                          "type": "string"
                        },
                        "profiletierid": {
                          "type": "string"
                        },
                        "recommendedDenom": {
                          "type": "string"
                        },
                        "recommendedDenomWithCurrency": {
                          "type": "string"
                        },
                        "recommendedRecharge": {
                          "type": "string"
                        },
                        "recommendedServiceFee": {
                          "type": "string"
                        }
                      }
                    },
                    "denominationList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "denominationListWithCurrency": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "rechargeList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "serviceFeeList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "otherList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "serviceIdList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": "{\n  \"result\": {\n    \"success\": true,\n    \"profilingcode\": \"1\",\n    \"loanamount\": \"7.00\",\n    \"repaydays\": \"30\",\n    \"gracePeriod\": \"0\",\n    \"profiletierid\": \"6\",\n    \"recommendedServiceFee\": \"2.00\",\n    \"recommendedDenomValue\": \"5.00\",\n    \"recommendedDisplayValue\": \"R$5 + R$2\",\n    \"recommendedRechargeValue\": \"5.00\",    \n  },\n  \"denominationList\": [\n    \"5.00\",\n    \"3.00\",\n    \"150.00\"\n  ],\n  \"denominationListWithCurrency\": [\n    \"R$5 + R$2\",\n    \"R$3 + R$1.20\",\n    \"MAX\"\n  ],\n  \"rechargeList\": [\n    \"5.00\",\n    \"3.00\",\n    \"150.00\"\n  ],\n  \"serviceFeeList\": [\n    \"2.00\",\n    \"1.20\",\n    \"15.00\"\n  ],\n  \"otherList\": [\n    \"Simple Airtime\",\n    \"Two Day Bundle\",\n    \"10-day bundle\"\n  ],\n  \"serviceIdList\": [\n    \"2\",\n    \"1\",\n    \"1\"\n  ]                        \n}"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/getDenomDetailIdx": {
      "get": {
        "operationId": "GET_getDenomDetailIdx",
        "summary": "This endpoint retrieves specific information from a cached response for a subscriber based on the index of a denomination.",
        "tags": [
