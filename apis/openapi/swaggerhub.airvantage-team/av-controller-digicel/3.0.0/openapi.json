        ],
        "description": "",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "description": "The MSISDN unique to the subscrier.\n\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "denomListId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "DenomDetailIdx",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "profilingcode": {
                          "type": "string"
                        },
                        "loanamount": {
                          "type": "string"
                        },
                        "repaydays": {
                          "type": "string"
                        },
                        "gracePeriod": {
                          "type": "string"
                        },
                        "profiletierid": {
                          "type": "string"
                        },
                        "servicefee": {
                          "type": "string"
                        },
                        "denomvalue": {
                          "type": "string"
                        },
                        "displayvalue": {
                          "type": "string"
                        },
                        "rechargevalue": {
                          "type": "string"
                        },
                        "maxexplainvalue": {
                          "type": "string"
                        },
                        "maxexplainfee": {
                          "type": "string"
                        },
                        "ismaxvalue": {
                          "type": "string"
                        },
                        "serviceId": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "DenomDetailIdx": {
                    "value": {
                      "result": {
                        "success": true,
                        "profilingcode": "1",
                        "loanamount": "165.00",
                        "repaydays": "30",
                        "profiletierid": "102",
                        "servicefee": "16.00",
                        "denomvalue": "160.00",
                        "displayvalue": "$160.00",
                        "rechargevalue": "160.00",
                        "serviceId": "2"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Internal"
    }
  ]
}