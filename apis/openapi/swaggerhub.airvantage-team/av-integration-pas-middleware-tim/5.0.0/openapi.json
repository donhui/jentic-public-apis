{
  "openapi": "3.0.0",
  "info": {
    "version": "5.0.0",
    "title": "av_integration_pas_middleware_tim",
    "description": "This integration provides endpoints for the USSD to communicate with the middleware of TIM</br> Release Notes <table> <tr><td><b>Version</b></td><td><b>Detail</b></td></tr> <tr><td>5.0.120</td><td>New channel_tag table</td></tr> <tr><td>4.0.115</td><td>tag parameter on /canGetAdvance</td></tr> </table>",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/airvantage-team/av_integration_pas_middleware_tim/5.0.0/swagger.json"
  },
  "paths": {
    "/canGetAdvance": {
      "get": {
        "operationId": "GET_canGetAdvance",
        "summary": "canGetAdvance",
        "tags": [
          "Endpoints"
        ],
        "description": "On the middleware integration, when a client/partner calls <b></i>/canGetAdvance</i></b>, this service will first call <b>av_microservice_sentry_tim/getEligible</b> to check if a subscriber is on a valid tariff plan that allows advances.<br>\nIf this check passes and the subscriber is on a valid tariff plan, the service will call <b>av_microservice_pas_tim/getLoanableAmount</b> to check if the subscriber has no outstanding advances and for how much a subscriber qualifies for.\n\n<b><font color=red>Deprecated process:</font></b></br>\nOn the middleware integration, when a client/partner calls <b></i>/canGetAdvance</i></b>, it calls a SOAP end-point in TIM (<b>CRM_Consult_SpecialCredit</b>). \n\nTIM performs a check on the PFE system, which in turns checks OPSC to check if the subscriber is eligible. If the subscriber is eligible for 'Credito Especial', the PFE proceeds to call the Airvantage profiler to retrieve the list of denominations a person qualifies for.<br><br>\n\nThe channel id sent as a parameter is mapped to TIM's client-id name as follows:<br>\n2, 11: USSD<br>\n3, 10: SMS<br>\n4: RTDM<br>\n9: -- <br>",
        "parameters": [
          {
            "name": "channel",
            "in": "query",
            "description": "Who is calling this endpoint? \n\n1 - IVR\n2 - USSD\n3 \u2013 SMS MKT\n4 - RTDM\n5 - LOW BALANCE\n6 - MEU TIM WEB\n7 - MEU TIM APP\n8 - CAPTIVE PORTAL\n9 - CALL INTERCEPTION\n0 - INTERNAL (for Airvantage use only)\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "msisdn",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entityType",
            "in": "query",
            "description": "What type of lending is this? 1 = mobile money, 2 = airtime, 3 = Data",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "denomListId",
            "in": "query",
            "description": "Multiple denomination lists can be used. Default = 1",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "the tag is optional and forwarded to the Profiler so that success/failures can be stored in the Profiler based on the tag",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "loanamount": {
                          "type": "string"
                        },
                        "repaydays": {
                          "type": "string"
                        },
                        "profiletierid": {
                          "type": "string"
                        },
                        "protocolnr": {
                          "type": "string"
                        }
                      }
                    },
                    "denominationList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "denominationListWithCurrency": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "rechargeList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "serviceFeeList": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "result": {
                        "success": true,
                        "loanamount": "100",
                        "repaydays": "30",
                        "profiletierid": "32",
                        "protocolnr": "12345ABC"
                      },
                      "denominationList": [
                        "5",
                        "10",
                        "20",
                        "50"
                      ],
                      "denominationListWithCurrency": [
                        "R5",
                        "R10",
                        "R20",
                        "R50"
                      ],
                      "rechargeList": [
                        "6",
                        "11",
                        "22",
                        "55"
                      ],
                      "serviceFeeList": [
                        "1",
                        "1",
                        "2",
                        "5"
                      ]
                    }
                  }
                }
              }
            }
          },
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "comment": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "result": {
                        "success": false,
                        "comment": "Subscriber not eligible"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/processAdvance": {
      "get": {
        "operationId": "GET_processAdvance",
        "summary": "processAdvance",
        "tags": [
          "Endpoints"
        ],
        "description": "The service/partner calls <b><i>/canGetAdvance</i></b>. \n\nIf the response is affirmative, that response would be accompanied by a list of denominations that the subscriber can choose from.\n\nSubsequently, depending on the subscriber's choice, <b></i>/processAdvance</i></b> gets called to register the advance with TIM and Airvantage. \n\nThis is done in the following order:</br>\n<b><i>/processAdvance</i></b> calls TIM middleware's <b><i>CRD_Manage_SpecialCredit</i></b> to register the advance with TIM. TIM will then call <b><i>/addAdvance</i></b> and <b><i>/updateAdvanceStatus</i></b> on the <i> av_microservice_pas_tim</i> microservice.<br><br>\n\n<b>Note on channel id</b>: Channel values of 2 (PULL USSD) and 11 (PUSH USSD) sends a client-id, client-name and subsystem name of \u201cUSSD\u201d as part of the SOAP request to TIM. Channel values of 3 (SMS MKT) and 10 (SMS/USSD Bridge) sends a client-id, client-name and subsystem name of \u201cSMS\u201d as part of the SOAP request to TIM. See section 5.1.3.1 CRD_Manage_SpecialCredit Example Request in the unified document.\n\n<font color=red>ASYNCHRONOUS CALLS:</font> add the parameter <b>async=1</b> to make the call asynchronous. The client can now send a request to grant a loan and only an acknowledge will be returned. The /processAdvance service will only pass the request on to TIM after the acknowledgement. This is useful if the client is not interested in the outcome of the request to TIM.",
        "parameters": [
          {
            "name": "channel",
            "in": "query",
            "description": "Who is calling this endpoint?\n\n1 - IVR\n2 - USSD\n3 \u2013 SMS MKT\n4 - RTDM\n5 - LOW BALANCE\n6 - MEU TIM WEB\n7 - MEU TIM APP\n8 - CAPTIVE PORTAL\n9 - CALL INTERCEPTION\n10 - SMS/USSD Bridge\n11 - PUSH USSD\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "msisdn",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "loanAmount",
            "in": "query",
            "description": "Amount to be transferred from Airvantage account into subscriber account.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "serviceAmount",
            "in": "query",
            "description": "Service fee (part of the /canGetAdvance response)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rechargeAmount",
            "in": "query",
            "description": "Typically same as \"loanAmount\".  ",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "profileTierId",
            "in": "query",
            "description": "Part of the /canGetAdvance response",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repayDays",
            "in": "query",
            "description": "Part of the /canGetAdvance response",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "async",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "result": {
                        "success": true
                      }
                    }
                  }
                }
              }
            }
          },
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "result": {
                        "success": false
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Endpoints"
    }
  ]
}