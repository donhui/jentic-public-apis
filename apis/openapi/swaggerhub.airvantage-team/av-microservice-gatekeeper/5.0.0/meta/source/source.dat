                        },
                        "message": {
                          "type": "string"
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Success": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Success",
                        "responseCode": "01"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Private"
    }
  ],
  "components": {
    "parameters": {
      "trait_queryParamActiondate_actionDate": {
        "name": "actionDate",
        "in": "query",
        "description": "Used to represent event Dates",
        "required": true,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "trait_queryParamAdvanceid_advanceId": {
        "name": "advanceId",
        "in": "query",
        "description": "Unique identifier of new Advance (/addAdvance) or which advance to repay (/addRepayment)",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "trait_queryParamLoanamount_loanAmt": {
        "name": "loanAmt",
        "in": "query",
        "description": "Amount borrowed by subscriber OR\nAmount being allocated to repaying the Loan (/addRepayment)",
        "required": true,
        "schema": {
          "type": "number"
        }
      },
      "trait_queryParamDenomlistid_denomListId": {
        "name": "denomListId",
        "in": "query",
        "description": "Which list of denominations should be displayed?  ",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "default": 1
        }
      },
      "trait_queryParamEntitytype_entityType": {
        "name": "entityType",
        "in": "query",
        "description": "1. MoMo\n2. Airtime\n3. Data",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "default": 2
        }
      },
      "trait_queryParamLoandate_loanDate": {
        "name": "loanDate",
        "in": "query",
        "description": "Timestamp of loan taken\nyyyy/mm/dd HH:mm:ss",
        "schema": {
          "type": "string"
        }
      },
      "trait_queryParamMsisdn_msisdn": {
        "name": "msisdn",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 8,
          "maxLength": 13
        }
      },
      "trait_queryParamProfiletierid_profileTierId": {
        "name": "profileTierId",
        "in": "query",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999
        }
      },
      "trait_queryParamRechargeamt_rechargeAmt": {
        "name": "rechargeAmt",
        "in": "query",
        "description": "Amount being recharged ",
        "required": true,
        "schema": {
          "type": "number"
        }
      },
      "trait_queryParamRechargedate_rechargeDate": {
        "name": "rechargeDate",
        "in": "query",
        "description": "Timestamp of recharge\nyyyy/mm/dd HH:mm:ss",
        "schema": {
          "type": "string"
        }
      },
      "trait_queryParamReconcilesource_source": {
        "name": "source",
        "in": "query",
        "description": "1 - CDR\n2 - Daily/Periodical Recon Task",
        "schema": {
          "type": "integer",
          "default": 1
        }
      },
      "trait_queryParamRepaydate_repayDate": {
        "name": "repayDate",
        "in": "query",
        "description": "Timestamp of loan repaid\nyyyy/mm/dd HH:mm:ss",
        "schema": {
          "type": "string"
        }
      },
      "trait_queryParamServiceamt_serviceAmt": {
        "name": "serviceAmt",
        "in": "query",
        "description": "Amount being allocated to the service fee",
        "required": true,
        "schema": {
          "type": "number"
        }
      },
      "trait_queryParamServiceid_serviceId": {
        "name": "serviceId",
        "in": "query",
        "description": "This is the service ID which will indicate </br>1 - Airtime Once-off; </br>2 - Airtime Auto_Topup and </br>3 - Data",
        "schema": {
          "type": "string"
        }
      },
      "trait_queryParamStatusid_statusId": {
        "name": "statusId",
        "in": "query",
        "description": "2 - Confirmed advance/payment\n3 - Cancelled advance/payment\n6 -  Queued advance/payment",
        "required": true,
        "schema": {
          "type": "integer",
          "enum": [
