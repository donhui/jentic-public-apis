    "/reconcilePayment": {
      "get": {
        "operationId": "GET_reconcilePayment",
        "summary": "Indicate that this repayment has been reconciled.",
        "tags": [
          "Public"
        ],
        "description": "Flags a payment as having been reconciled.\n\nThis can be done if a secondary source of truth (DCR records, etc) can confirm that the payment was in fact successfully recovered.\n\nThe end-point flags the entry in the Lending micro-service's <b>payment</b> table as having been <i>reconciled</i>.\n\nThis reconcilaition can be performed using either the third party's <strong>paymentTransactionId</strong> or Airvantage's <strong>paymentId.</strong>\n\nThe source determines what type of reconciliation we are processing, for online reconcilation of payments the value of 1 would be used. For offline reconciliation a 2 would be used. <strike>If the payments are split into two records, we would use 3 and 4 for loan and service fee payments respecitvely.\n\nin the latter 2 scenarios the values will be stored as binary values indicating the reconciliation state.\n\n<b>0:</b> The default state, indicating that both types have not been reconciled\n\n<b>1:</b> Indicates that the service fee payment has been reconciled\n\n<b>10:</b> Indicates that the loan payment has been reconciled\n\n<b>11:</b> Indicates that the loan payment and service fee payment has been reconciled\n\nPartial payments will always show a reconciliation state of 1 or 10.</strike>\n\n\n<b>Note:</b> It also updates the <i>statusid</i> to <b>2 - Success</b>",
        "parameters": [
          {
            "name": "paymentId",
            "in": "query",
            "description": "Airvantage's paymentId",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cdrTimestamp",
            "in": "query",
            "description": "Format: yyyy/mm/dd hh:mm:ss\n\nWhen given, will save the timestamp from the CDR file for this advance, into the cdrtimestamp column\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "source",
            "in": "query",
            "description": "1 - CDR (minute/hour/interval)\n2 - DAILY (daily recon process)\n3 - Loan payment reconciliation\n4 - Service fee payment reconciliation",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2,
                3,
                4
              ],
              "default": 1
            }
          },
          {
            "name": "paymentTransactionId",
            "in": "query",
            "description": "third party paymentId ",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "examples": {
                  "success": {
                    "value": {
                      "success": true,
                      "detail": {
                        "paymentId": "28",
                        "previousStatusId": "2",
                        "previousReconcile": 0,
                        "comment": "Success"
                      }
                    }
                  },
                  "response": {
                    "value": {
                      "success": false,
                      "detail": {
                        "paymentTransactionId": "-1",
                        "comment": "The paymentTransactionId does not exist"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/updateAdvanceStatus": {
      "get": {
        "operationId": "GET_updateAdvanceStatus",
        "summary": "Updates the advance status.",
        "tags": [
          "Public"
        ],
        "description": "Updates the status of an Advance</br>\n\n<b><font color=red>IMPORTANT</font></b>\n<b>One-directional transitions allowed ONLY</b>\n\nOne can only update the status from \n\n1 (unconfirmed) to 2 (confirmed)\n\n<b>OR</b>\n\n1 (unconfirmed) to 3 (cancelled)\n\n<b>OR</b>\n\n1 (unconfirmed) to 6 (queued)\n\n<b>Any other statusIDs will be ignored</b>",
        "parameters": [
          {
            "name": "externalref",
            "in": "query",
            "description": "An optional reference provided by a third party or operator to identify the advance transaction",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "$ref": "#/components/parameters/trait_queryParamAdvanceid_advanceId"
          },
          {
            "$ref": "#/components/parameters/trait_queryParamStatusid_statusId"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "indicates if the response is sucessfull or not"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "description": "A message indicating the status of the requests execution "
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Success",
                        "responseCode": "01"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/updatePaymentStatus": {
      "get": {
        "operationId": "GET_updatePaymentStatus",
        "summary": "Updates the payment status.",
        "tags": [
          "Public"
        ],
        "description": "Updates the status of a Payment</br>\n\n<b><font color=red>IMPORTANT</font></b>\n<b>One-directional transitions allowed ONLY</b>\n\nOne can only update the status from \n\n1 (unconfirmed) to 2 (confirmed)\n\n<b>OR</b>\n\n1 (unconfirmed) to 3 (cancelled)\n\n<b>Any other statusIDs will be ignored</b>",
        "parameters": [
          {
            "name": "paymentId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/trait_queryParamStatusid_statusId"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string"
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Success",
                        "responseCode": "01"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/getPaymentStatusConsolidated": {
      "get": {
        "operationId": "GET_getPaymentStatusConsolidated",
        "summary": "Returns a consolidated view of payments for multiple open advances.",
        "tags": [
          "Public"
        ],
        "description": "This endpoint is used on sites where AV offers multiple open loans as a feature to the subscriber and will report on all <b>unconfirmed payments</b>.\n\n <b>Status ID are:</br></b>\n 1 - <b>Unconfirmed</b> Payment was recorded, but we haven't received an ACK from the IN that it was processed on the telco's side yet)\n \n 2 - <b>Confirmed</b> (Payment was recorded, and an entry in the CDRs confirmed that amount was paid over)\n\n 3 - <b>Cancelled</b> (Payment was recorded, and after we failed to receive an ACK from the IN, was cancelled)",
        "parameters": [
          {
            "name": "paymentTransactionId",
            "in": "query",
            "description": "This is the transaction ID that the operator will use for a payment, AV's paymenttransid in this microservice should correlate to that of the operator. ",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "msisdn",
            "in": "query",
            "description": "This is a unique identifier of a subscriber.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "msisdn": {
                          "type": "string"
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Success": {
                    "value": {
                      "success": true,
                      "detail": {
                        "responseCode": "01",
                        "msisdn": "0123456789",
                        "entityType": "2",
                        "statusId": "1",
                        "paymentTransactionId": "111",
                        "deductedConsolidatedLoanAmt": "300.00",
                        "deductedConsolidatedServicefeeAmt": "30.00",
                        "deductedConsolidatedTotalAmt": "330.00",
                        "charges": [
                          {
                            "transactionType": "ServiceFee",
                            "amt": "30.00"
                          }
                        ],
                        "paymentCount": "2"
                      }
                    }
                  },
                  "Validation error": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Missing parameter for paymentTransactionId.",
                        "responseCode": "03"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/reconcilePaymentConsolidated": {
      "get": {
        "operationId": "GET_reconcilePaymentConsolidated",
        "summary": "Reconciles multiple open advances.",
        "tags": [
          "Public"
        ],
        "description": "This endpoint is used to reconcile multiple payments that have the same paymentTransactionId. \n\nThis will then flag a payment or more than one payment with the same paymentTransactionId as having been reconciled. \n\nThis can be done if a secondary source of truth (DCR records, etc) can confirm that the payment was in fact successfully recovered.\n\nThe source determines what type of reconciliation we are processing, for online reconcilation of payments the value of 1 would be used. For offline reconciliation a 2 would be used. If the payments are split into two records, we would use 3 and 4 for loan and service fee payments respecitvely.\n\nin the latter 2 scenarios the values will be stored as binary values indicating the reconciliation state.\n\n<b>0:</b> The default state, indicating that both types have not been reconciled\n\n<b>1:</b> Indicates that the service fee payment has been reconciled\n\n<b>10:</b> Indicates that the loan payment has been reconciled\n\n<b>11:</b> Indicates that the loan payment and service fee payment has been reconciled\n\nPartial payments will always show a reconciliation state of 1 or 10.\n\n\n<b>Note:</b> It also updates the <i>statusid</i> to <b>2 - Success</b>",
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "description": "1 - CDR (minute/hour/interval) 2 - DAILY (daily recon process) 3 - Loan payment reconciliation 4 - Service fee payment reconciliation",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "paymentTransactionId",
            "in": "query",
            "description": "This is the third party/operator's transaction ID.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cdrTimestamp",
            "in": "query",
            "description": "When given, will save the timestamp from the CDR file for this advance, into the cdrtimestamp column",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date",
              "pattern": "yyyy/mm/dd hh:mm:ss"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string"
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Missing parameter for paymentTransactionId",
                        "responseCode": "03",
                        "previousReconcile": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/getAdvanceAttribute": {
      "get": {
        "operationId": "GET_getAdvanceAttribute",
        "summary": "Retrieves the value of the specified advance attribute",
        "tags": [
          "Public"
        ],
        "description": "Retrieves the value of the specified advance attribute. If no attribute is specified, then return all available attributes.",
        "parameters": [
          {
            "name": "advanceid",
            "in": "query",
            "description": "Attribute for this Advance id will be retrieved",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributekey",
            "in": "query",
            "description": "Attribute key",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string"
                        },
                        "responseCode": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "attribute doesn't exist": {
                    "value": {
                      "success": true,
                      "detail": {
                        "attributeKey": "language",
                        "message": "Attribute doesn't exist",
                        "responseCode": "00"
                      }
                    }
                  },
                  "attribute exists": {
                    "value": {
                      "success": true,
                      "detail": {
                        "attributeKey": "language",
                        "attributeValue": "English",
                        "responseCode": "01"
                      }
                    }
                  },
                  "attribute not specified": {
                    "value": {
                      "success": true,
                      "detail": {
                        "attributeKey": "",
                        "message": "{\"IMEI\":\"123123123\",\"model\":\"LF-2023\", \"language\":\"English\" }",
                        "responseCode": "01"
                      }
                    }
                  },
                  "validation failed": {
                    "value": {
                      "success": true,
                      "detail": {
                        "message": "Missing parameter for ...",
                        "responseCode": "03"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
