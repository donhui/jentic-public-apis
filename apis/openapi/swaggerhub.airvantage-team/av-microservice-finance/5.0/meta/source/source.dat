    "/getAdvanceStatusSummary": {
      "get": {
        "operationId": "GET_getAdvanceStatusSummary",
        "summary": "Returns a summarised version of the advance status for this subscriber.",
        "tags": [
          "Public"
        ],
        "description": "Response includes an <b>entityType<font color=red>X</font></b><br> </br>\n<i>[ entityType<font color=red>1</font> / entityType<font color=red>2</font> / entityType<font color=red>3</font> ]</i>\n\n<b>0</b> - Open loan<br>\n<b>1</b> - Loan is presently being queued<br>\n<b>2</b> - No outstanding loan<br>\n\nThe response also includes <b>totalrepaybalance</b>\n</br>\n</br>\n<b>totalrepaybalance</b> = totaladvancebalance + totalservicefeebalance\n<br><br>\n<b>Overdue:</b> If \"overdue\" = true in the response, it means that there is an unpaid open advance that is past the due date.\n<br><br>\n<b>Queued:</b> If \"queued\" = true in the response, it means that there is an advance that is in a queued state and currently being processed. <br><br><b>Note:</b> This call gets cached if <font color=green>'PROF_CACHE_LIVENESS_SECONDS'</font>>0 <br>In other words, calling the endpoint with the same query parameters within the <font color=green>'PROF_CACHE_LIVENESS_SECONDS'</font>, will not access the DB again, but will simply return the previously generated http response.",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "responseCode": {
                          "type": "string"
                        },
                        "msisdn": {
                          "type": "string"
                        },
                        "entityType1": {
                          "type": "string"
                        },
                        "balance1": {
                          "type": "string"
                        },
                        "entityType2": {
                          "type": "string"
                        },
                        "balance2": {
                          "type": "string"
                        },
                        "entityType3": {
                          "type": "string"
                        },
                        "balance3": {
                          "type": "string"
                        },
                        "totalAdvanceBalance": {
                          "type": "string"
                        },
                        "totalServiceFeeBalance": {
                          "type": "string"
                        },
                        "totalRepayBalance": {
                          "type": "string"
                        },
                        "overdue": {
                          "type": "boolean"
                        },
                        "queued": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "Success": {
                    "value": {
                      "success": true,
                      "detail": {
                        "responseCode": "01",
                        "msisdn": "1234567890",
                        "entityType1": "2",
                        "balance1": "0.00",
                        "entityType2": "0",
                        "balance2": "14.00",
                        "entityType3": "2",
                        "balance3": "0.00",
                        "totalAdvanceBalance": "14.00",
                        "totalServiceFeeBalance": "2.00",
                        "totalRepayBalance": "17.00",
                        "totalInterestBalance": "1.00",
                        "mostImmediateRepaymentDate": "2021/02/22",
                        "overdue": true,
                        "queued": false
                      }
                    }
                  },
                  "Validation error": {
                    "value": {
                      "success": false,
                      "detail": {
                        "responseCode": "03",
                        "comment": "msisdn Shorter than 10"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/getPaymentStatus": {
      "get": {
        "operationId": "GET_getPaymentStatus",
        "summary": "Returns the payment status.",
        "tags": [
          "Public"
        ],
        "description": "Returns a JSON response for the given MSISDN, and IN-TimeStamp\n\nThe purpose of this call is to retrieve any payments made for a given MSISDN at a certain time\n\n\n --------------\n \n <b>Status ID are:</br></b>\n 1 - <b>Unconfirmed</b> Payment was recorded, but we haven't received an ACK from the IN that it was processed on the telco's side yet)\n \n 2 - <b>Confirmed</b> (Payment was recorded, and an entry in the CDRs confirmed that amount was paid over)\n \n\n 3 - <b>Cancelled</b> (Payment was recorded, and after we failed to receive an ACK from the IN, was cancelled)",
        "parameters": [
          {
            "name": "rechargeDate",
            "in": "query",
            "description": "Timestamp of recharge from the IN\nyyyy/mm/dd hh:mm:ss",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/trait_queryParamMsisdn_msisdn"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "advanceId": {
                          "type": "integer"
                        },
                        "msisdn": {
                          "type": "string"
                        },
                        "paymentId": {
                          "type": "string"
                        },
                        "entityType": {
                          "type": "string"
                        },
                        "statusId": {
                          "type": "string"
                        },
                        "networkTransactionId": {
                          "type": "string"
                        },
                        "paymentTransactionId": {
                          "type": "string"
                        },
                        "deductedLoanAmt": {
                          "type": "number"
                        },
                        "deductedServiceFeeAmt": {
                          "type": "number"
                        },
                        "deductedInterestAmt": {
                          "type": "number"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "success": true,
                      "detail": {
                        "advanceId": 4,
                        "msisdn": "1623216974",
                        "paymentId": "13",
                        "deducatedLoanAmt": 35,
                        "deductedServicefeeAmt": 5,
                        "deductedInterestAmt": 5,
                        "entityType": "2",
                        "statusId": "2",
                        "networkTransactionId": "1",
                        "paymentTransactionId": "1"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/getChargeHistory": {
      "post": {
        "operationId": "GET_getChargeHistory",
        "summary": "Returns a history of charges that have been made by a subscriber.",
        "tags": [
          "Public"
        ],
        "description": "A JSON response is returned for a list of advanceId's. \n\nThe purpose of this call is to retrieve any charges made for a given advanceId. This endpoint is mostly used for GUI purposes. </br> </br>\nAn example request will look like this:  {\n \"advance\": [\n{\n    \"advanceId\": 4\n}, {\n    \"advanceId\": 5\n}, {\n    \"advanceId\": 6\n}, {\n    \"advanceId\": 7\n}, {\n    \"advanceId\": 8\n}, {\n    \"advanceId\": 9\n}, {\n    \"advanceId\": 10\n} ]\n }",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  }
                }
              },
              "examples": {
                "validresponse": {
                  "summary": "valid request",
                  "value": {
                    "advance": [
                      {
                        "advanceId": 4
                      },
                      {
                        "advanceId": 5
                      },
                      {
                        "advanceId": 6
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "responseCode": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        },
                        "payments": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "success": true,
                      "detail": {
                        "responseCode": "01",
                        "message": "Successfully retrieved charges.",
                        "charges": [
                          {
                            "advanceid": "11333482",
                            "chargedate": "2020-11-13 15:31:36",
                            "amount": 10,
                            "transtypeid": 1,
                            "caption": "Loan"
                          },
                          {
                            "advanceid": "11333482",
                            "chargedate": "2020-11-13 15:31:36",
                            "amount": 2,
                            "transtypeid": 2,
                            "caption": "Service fee"
                          },
                          {
                            "advanceid": "11333482",
                            "chargedate": "2020-11-13 15:31:36",
                            "amount": 1.12,
                            "transtypeid": 4,
                            "caption": "Tax"
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
