    "/getStatus": {
      "$ref": "https://api.swaggerhub.com/domains/airvantage-team/AVCommons/3.0.0#/components/pathitems/GetStatus"
    },
    "/reconcileAdvance": {
      "get": {
        "operationId": "GET_reconcileAdvance",
        "summary": "Indicates that the advance has been reconciled.",
        "tags": [
          "Public"
        ],
        "description": "Flags an advance as having been reconciled.\n\nThis can be done if a secondary source of truth (DCR records, etc) can confirm that an advance was in fact granted and paid to the subscriber.\n\nThe end-point flags the entry in the Lending micro-service's <b>advance</b> table as having been <i>reconciled</i>.",
        "parameters": [
          {
            "name": "cdrTimestamp",
            "in": "query",
            "description": "Format: yyyy/mm/dd hh:mm:ss\n\nWhen given, will save the timestamp from the CDR file for this advance, into the cdrtimestamp column\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "externalref",
            "in": "query",
            "description": "An optional reference provided by a third party or operator to identify the advance transaction. If this externalRef is not provided, then the advanceId parameter is required.",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "$ref": "#/components/parameters/trait_queryParamAdvanceid_advanceId"
          },
          {
            "$ref": "#/components/parameters/trait_queryParamReconcilesource_source"
          },
          {
            "name": "updatedExternalRef",
            "in": "query",
            "description": "An optional external reference that can be supplied along with the advanceid parameter. This value will then replace the previous externalref value in the db with this new value",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
