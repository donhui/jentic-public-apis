    "/getSubscriberStatus": {
      "get": {
        "operationId": "GET_getSubscriberStatus",
        "summary": "Returns the payment status.",
        "tags": [
          "Public"
        ],
        "description": "Returns a JSON response for the given MSISDN.\nThe purpose of this call is to retrieve the current status of the subscriber. \n\n --------------\n \n <b>Status IDs are:</br></b>\n 0 - <b>Inactive</b></br>\n 1 - <b>Active</b> ",
        "parameters": [
          {
            "name": "msisdn",
            "in": "query",
            "description": "The unique subscriber identifier. ",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "detail": {
                      "type": "object",
                      "properties": {
                        "responseCode": {
                          "type": "string"
                        },
                        "activationDate": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "success": {
                    "value": {
                      "success": true,
                      "detail": {
                        "responseCode": "01",
                        "activationDate": "2022-01-01 12:00:00",
                        "status": "1",
                        "message": "Subscriber is currently active."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/getDetailedBalance": {
