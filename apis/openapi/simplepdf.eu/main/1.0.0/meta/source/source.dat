      "delete": {
        "operationId": "deleteDocument",
        "description": "Delete the document. This action is irreversible. Deleting the document will also delete the stored file as well as all submissions.",
        "tags": [
          "Document"
        ],
        "security": [
          {
            "Authorization": []
          }
        ],
        "parameters": [
          {
            "in": "path",
