                  "$ref": "#/components/schemas/Abbyy.Vantage.PublicApi.Contract.Transactions.Results.CreatedTransactionResult"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/Abbyy.Vantage.PublicApi.Contract.Transactions.Results.CreatedTransactionResult"
                }
              }
            }
          },
          "400": {
