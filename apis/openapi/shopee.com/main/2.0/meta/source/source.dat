    "/api/v2/media_space/upload_image": {
      "post": {
        "summary": "upload_image",
        "operationId": "upload_image",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code. Empty string means success."
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message details."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier for debugging."
                    },
                    "response": {
                      "type": "object",
                      "description": "Response payload."
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "MediaSpace"
        ],
        "description": "# v2.media_space.upload_image\n\nUpload video image file.\n\n## Common Parameters\n\n| **Name** | **Type** |\n| --- | --- |\n| partner_id | int |\n| timestamp | timestamp |\n| sign | string |\n\n## Request Parameters\n\n| **Name** | **Type** | **Required** |\n| --- | --- | --- |\n| image | file | **True** |\n| scene | string | False |",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        }
      }
    },
