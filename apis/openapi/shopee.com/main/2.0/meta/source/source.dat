{
  "openapi": "3.0.3",
  "info": {
    "title": "Shopee Open Platform API",
    "description": "Shopee Open Platform API v2.0 for e-commerce operations across Southeast Asia and other Shopee markets. Enables sellers and partners to manage products, orders, logistics, discounts, shops, and media programmatically on the Shopee marketplace.",
    "version": "2.0",
    "contact": {
      "name": "Shopee Open Platform",
      "url": "https://open.shopee.com"
    },
    "termsOfService": "https://open.shopee.com/documents?module=63&type=2&id=56"
  },
  "externalDocs": {
    "description": "Shopee Open Platform Documentation",
    "url": "https://open.shopee.com/documents"
  },
  "servers": [
    {
      "url": "https://partner.shopeemobile.com",
      "description": "Shopee Partner API (Production)"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication and authorization endpoints for the OAuth 2.0 flow."
    },
    {
      "name": "Discount",
      "description": "Discount and promotion management"
    },
    {
      "name": "Logistics",
      "description": "Shipping and logistics management"
    },
    {
      "name": "MediaSpace",
      "description": "Image and media upload"
    },
    {
      "name": "Order",
      "description": "Order management and tracking"
    },
    {
      "name": "Product",
      "description": "Product catalog management"
    },
    {
      "name": "Shop",
      "description": "Shop information and management"
    }
  ],
  "paths": {
    "/api/v2/auth/access_token/get": {
      "post": {
        "summary": "Refresh Access Token",
        "operationId": "refresh_access_token",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code. Empty string means success."
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message details."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier for debugging."
                    },
                    "response": {
                      "type": "object",
                      "description": "Response payload."
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Use the refresh token to obtain a new access token when the current one expires.",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v2/auth/token/get": {
      "post": {
        "summary": "Get Access Token",
        "operationId": "get_token",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code. Empty string means success."
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message details."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier for debugging."
                    },
                    "response": {
                      "type": "object",
                      "description": "Response payload."
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Auth"
        ],
        "description": "Exchange the authorization code for an access token and refresh token after the seller authorizes the app."
      }
    },
