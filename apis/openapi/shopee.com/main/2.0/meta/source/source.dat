    "/api/v2/logistics/get_shipping_document_data_info": {
      "post": {
        "summary": "get_shipping_document_info",
        "operationId": "get_shipping_document_info",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code. Empty string means success."
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message details."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier for debugging."
                    },
                    "response": {
                      "type": "object",
                      "description": "Response payload."
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Logistics"
        ],
        "description": "# v2.logistics.get_tracking_info\n\nUse this api to get the logistics tracking information of an order.\n\n## Request Parameters\n\n| **Name** | **Type** | **Required** |\n| --- | --- | --- |\n| order_sn | string | True |\n| package_number | string | False |\n\n**More info at:** [Get Tracking Info](https://open.shopee.com/documents/v2/v2.logistics.get_tracking_info?module=95&type=1)",
        "parameters": [
          {
            "name": "order_sn",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Shopee's unique identifier for an order.",
            "example": "2209075DYGRGPN"
          }
        ]
      }
    },
    "/api/v2/logistics/get_shipping_parameter": {
