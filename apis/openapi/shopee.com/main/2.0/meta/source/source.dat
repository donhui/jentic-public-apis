  "components": {
    "securitySchemes": {
      "shopeeAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "sign",
        "description": "HMAC-SHA256 signature computed from partner_key, API path, and timestamp."
      }
    },
    "parameters": {
      "partnerId": {
        "name": "partner_id",
        "in": "query",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "The ID assigned to the partner upon registration."
      },
      "shopId": {
        "name": "shop_id",
        "in": "query",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "The ID of the shop."
      },
      "timestamp": {
        "name": "timestamp",
        "in": "query",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Current UNIX timestamp in seconds."
      },
      "accessToken": {
        "name": "access_token",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Access token obtained via the OAuth flow."
      },
      "sign": {
        "name": "sign",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "HMAC-SHA256 signature for request verification."
      }
    }
  },
  "security": [
    {
      "shopeeAuth": []
    }
  ]
}