              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code. Empty string means success."
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message details."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier for debugging."
                    },
                    "response": {
                      "type": "object",
                      "description": "Response payload."
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Logistics"
        ],
        "parameters": [
          {
            "name": "order_sn",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Shopee's unique identifier for an order.",
            "example": "22072127JPBX98"
          }
        ],
        "description": "Get shipping parameters required to arrange shipment for an order."
      }
    },
