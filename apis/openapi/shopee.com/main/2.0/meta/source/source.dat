        "description": "# v2.order.get_order_detail\n\nUse this api to get order detail.\n\n## Request Parameters\n\n| **Name** | **Type** | **Required** |\n| --- | --- | --- |\n| order_sn_list | string\\[\\] | True |\n| response_optional_fields | string\\[\\] | False |"
      }
    },
    "/api/v2/order/get_order_detail": {
      "get": {
        "summary": "get_order_detail",
        "operationId": "get_order_detail",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code. Empty string means success."
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message details."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier for debugging."
                    },
                    "response": {
                      "type": "object",
                      "description": "Response payload."
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Order"
        ],
        "description": "# v2.order.get_order_detail\n\nUse this api to get order detail.\n\n## Request Parameters\n\n| **Name** | **Type** | **Required** |\n| --- | --- | --- |\n| order_sn_list | string\\[\\] | True |\n| response_optional_fields | string\\[\\] | False |",
        "parameters": [
          {
            "name": "order_sn_list",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The set of order_sn. If there are multiple order_sn, you need to use English comma to connect them. limit [1,50]",
            "example": "2209075DYGRGPN"
          },
          {
            "name": "response_optional_fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Indicate response fields you want to get. Please select from the below response parameters. If you input an object field, all the params under it will be included automatically in the response. If there are multiple response fields you want to get, you need to use English comma to connect them. Available values: buyer_user_id,buyer_username,estimated_shipping_fee,recipient_address,actual_shipping_fee ,goods_to_declare,note,note_update_time,item_list,pay_time,dropshipper,dropshipper_phone,split_up,buyer_cancel_reason,cancel_by,cancel_reason,actual_shipping_fee_confirmed,buyer_cpf_id,fulfillment_flag,pickup_done_time,package_list,shipping_carrier,payment_method,total_amount,buyer_username,invoice_data, checkout_shipping_carrier, reverse_shipping_fee, order_chargeable_weight_gram etc.",
            "example": "buyer_user_id,buyer_username,estimated_shipping_fee"
          }
        ]
      }
    },
    "/api/v2/order/get_order_list": {
      "get": {
        "summary": "get_order_list",
        "operationId": "get_order_list",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code. Empty string means success."
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message details."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier for debugging."
                    },
                    "response": {
                      "type": "object",
                      "description": "Response payload."
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Order"
        ],
        "description": "# v2.order.get_order_list\n\nUse this api to search orders.\n\n## Common Parameters\n\n| **Name** | **Type** |\n| --- | --- |\n| partner_id | int |\n| timestamp | timestamp |\n| access_token | string |\n| shop_id | int |\n| sign | string |\n\n## Request Parameters\n\n| **Name** | **Type** | **Required** |\n| --- | --- | --- |\n| time_range_field | string | True |\n| time_from | int | True |\n| time_to | int | True |\n| page_size | int | True |\n| cursor | string | False |\n| order_status | string | False |\n| response_optional_fields | string | False |\n\n**More info at:** [Get Order List](https://open.shopee.com/documents/v2/v2.order.get_order_list?module=94&type=1)",
        "parameters": [
          {
            "name": "time_range_field",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The kind of time_from and time_to. Available value: create_time, update_time.",
            "example": "create_time"
          },
          {
            "name": "time_from",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The time_from and time_to fields specify a date range for retrieving orders (based on the time_range_field). The time_from field is the starting date range. The maximum date range that may be specified with the time_from and time_to fields is 15 days."
          },
          {
            "name": "time_to",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The time_from and time_to fields specify a date range for retrieving orders (based on the time_range_field). The time_from field is the starting date range. The maximum date range that may be specified with the time_from and time_to fields is 15 days."
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Each result set is returned as a page of entries. Use the \"page_size\" filters to control the maximum number of entries to retrieve per page (i.e., per call). This integer value is used to specify the maximum number of entries to return in a single \"page\" of data.The limit of page_size if between 1 and 100.",
            "example": "20"
          },
          {
            "name": "order_status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The order_status filter for retriveing orders and each one only every request. Available value: UNPAID/READY_TO_SHIP/PROCESSED/SHIPPED/COMPLETED/IN_CANCEL/CANCELLED/INVOICE_PENDING",
            "example": "READY_TO_SHIP"
          }
        ]
      }
    },
    "/api/v2/product/add_item": {
      "post": {
        "summary": "add_item",
        "operationId": "add_item",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Error code. Empty string means success."
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message details."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique request identifier for debugging."
                    },
                    "response": {
                      "type": "object",
                      "description": "Response payload."
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Product"
        ],
        "description": "# v2.product.add_item\n\nAdd item to Shopee Seller Catalog.\n\n## Request Parameters\n\n| **Name** | **Type** | **Required** | **Description** |\n| --- | --- | --- | --- |\n| original_price | float | True |   <br>  <br>Item price  <br>  <br>For CO local VAT responsible seller\uff1aPlease remember the price you set in here must be VAT inclusive. If you have any doubts on how to calculate VAT for your product please refer to the Seller Education Hub\uff08[https://seller.shopee.com.co/edu/article/13565\uff09](https://seller.shopee.com.co/edu/article/13565\uff09)  <br>  <br>For SG/MY/BR/MX/PL/ES/AR seller: Sellers can set the price with two decimal place, other regions can only set the price as an integer.  <br>  <br> |\n| description | string | True | if description_type is normal , Description information should be set by this field. |\n| weight | float | False | Weight of item |\n| item_name | string | True | Item name |\n| item_status | string | False | Item status, could be UNLIST or NORMAL |\n| dimension | object | False | Item dimension |\n| package_height | int | True |   <br>  <br>Package height, unit is cm  <br>  <br> |\n| package_length | int | True |   <br>  <br>Package height, unit is cm  <br>  <br> |\n| package_width | int | True |   <br>  <br>Package height, unit is cm  <br>  <br> |\n| normal_stock | int | True | Item stock |\n| logistic_info | object\\[\\] | True | Logistic channel setting |\n| size_id | int | False | Size ID, If specify logistic fee_type is SIZE_SELECTION size_id is required. |\n| shipping_fee | float | False | Shipping fee, Only needed when logistics fee_type = CUSTOM_PRICE. |\n| enabled | boolean | True | Whether channel is enabled for this item |\n| logistic_id | int | True | ID of the channel |\n| is_free | boolean | False | Whether cover shipping fee for buyer |\n| attribute_list | object\\[\\] | False |   <br>  <br>This field is optional(expect Indonesia) depending on the specific attribute under different categories. Should call get_attribute api to get attribute first. Must contain all all mandatory attribute.  <br>  <br> |\n| attribute_id | int | True | ID of attribute |\n| attribute_value_list | object\\[\\] | False |  |\n| value_id | int | True | Value ID. In the following cases, the value id needs to be uploaded as 0, and original_value_name is mandatory, needs to be filled in customized value. (1) AttributeInputType is TEXT_FILED; (2) AttributeInputType is COMBO_BOX or MULTIPLE_SELECT_COMBO_BOX, and the seller want to fill in a customized value. |\n| original_value_name | string | False | Value name. original_value_name from product.get_attributes api. If value id=0, this field is required. If AttributeType is DATE_TYPE or TIMESTAMP_TYPE, you can upload timestamp(string type) as the original_value_name. |\n| value_unit | string | False | Unit of attribute value (quantitative attribute only). |\n| category_id | int | True | ID of category |\n| image | object | True | Item images |\n| image_id_list | string\\[\\] | True | ID of image |\n| pre_order | object | False | Pre order setting |\n| is_pre_order | boolean | True | Whether item is pre order |\n| days_to_ship | int | False | The guaranteed days to ship orders. Please get the days_to_ship range from get_dts_limit api |\n| item_sku | string | False | SKU tag of item |\n| condition | string | False | Condition of item, could be USED or NEW |\n| wholesale | object\\[\\] | False |   <br>  <br>Wholesale setting.  <br>  <br> |\n| min_count | int | True | Minimum count of this tier |\n| max_count | int | True | Maximum count of this tier |\n| unit_price | float | True |   <br>  <br>Unit price of this tier.  <br>  <br>For SG/MY/BR/MX/PL/ES/AR seller: Sellers can set the price with two decimal place, other regions can only set the price as an integer.  <br>  <br>  <br> |\n| video_upload_id | string\\[\\] | False | Video upload ID returned from video uploading API. Only accept one video_upload_id. |\n| brand | object | False |  |\n| brand_id | int | True | Id of brand. |\n| item_dangerous | int | False | This field is only applicable for local sellers in Indonesia and Malaysia. Use this field to identify whether a product is a dangerous product. 0 for non-dangerous product and 1 for dangerous product. For more information, please visit the market's respective Seller Education Hub. |\n| tax_info | object | False | Tax information |\n| ncm | string | False | Mercosur Common Nomenclature, it is a convention between Mercosur member countries to easily recognize goods, services and productive factors negotiated among themselves. (BR region) |\n| same_state_cfop | string | False | Tax Code of Operations and Installments for orders that seller and buyer are in the same state. It identifies a specific operation by category at the time of issuing the invoice.(BR region) |\n| diff_state_cfop | string | False | Tax Code of Operations and Installments for orders that seller and buyer are in different states. It identifies a specific operation by category at the time of issuing the invoice.(BR region) |\n| csosn | string | False | Code of Operation Status \u2013 Simples Nacional, code for company operations to identify the origin of the goods and the taxation regime of the operations.(BR region) |\n| origin | string | False | Product source, domestic or foreig (BR region) |\n| cest | string | False | (BR region) |\n| measure_unit | string | False | (BR region) |\n| invoice_option | string | False | Value shuold be one of NO_INVOICES VAT_MARGIN_SCHEME_INVOICES VAT_INVOICES NON_VAT_INVOICES and if value is NON_VAT_INVOICE vat_rate should be null (PL region) |\n| vat_rate | string | False | Value should be one of 0% 5% 8% 23% NO_VAT_RATE (PL region) |\n| hs_code | string | True | HS Code (Only for IN region) |\n| tax_code | string | True | Tax Code (Only for IN region) |\n| complaint_policy | object | False | Complaint Policy for item. Only required for local PL sellers, ignored otherwise. |\n| warranty_time | string | False | Value should be in one of ONE_YEAR TWO_YEARS OVER_TWO_YEARS. |\n| exclude_entrepreneur_warranty | boolean | False | Whether to exclude warranty complaints for entrepreneurs.If True means \"I exclude warranty complaints for entrepreneur\" |\n| complaint_address_id | int | False | Address for complaint. Fetch available addresses using v2.logistics.get_address_list, and use address_id returned from it. |\n| additional_information | string | False | Additional information for warranty claim. Should be less than 1000 characters. |\n| description_info | object | False | New description field. Only whitelist sellers can use it. If you use the field, please upload the description_type=extended otherwise api will return error. If you don't use this field, you don't need to upload the description_type or upload description_type=normal |\n| extended_description | object | False | If description_type is extended , Description information should be set by this field. |\n| field_list | object\\[\\] | False | Field of extended description. |\n| field_type | string | False | Type of extended description field: values: See Data Definition- description_field_type (text , image). |\n| text | string | False | If field_type is text, text information will be set by this field. |\n| image_info | object | False | If field_type is image, image url will be set by this field. |\n| image_id | string | False | Image id. |\n| description_type | string | False |   <br>  <br>description_type (normal , extended). If you want to use extended_description, this field must be inputed  <br>  <br> |\n| seller_stock | object\\[\\] | False |   <br>  <br>seller stock\uff08Please notice that stock(including Seller Stock and Shopee Stock) should be larger than or equal to real-time reserved stock\uff09  <br>  <br>  <br> |\n| location_id | string | False |   <br>  <br>location id, you can get the location id from v2.shop.get_warehouse_detail api, if seller don't have any warehouses, you don't need to upload this field.  <br>  <br>  <br> |\n| stock | int | True |   <br>  <br>stock  <br>  <br> |\n\n**More info at:** [Add Item](https://open.shopee.com/documents/v2/v2.product.add_item?module=89&type=1)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "item_name": {
                    "type": "string"
                  },
                  "category_id": {
                    "type": "integer"
                  },
                  "weight": {
                    "type": "number"
                  },
                  "item_status": {
                    "type": "string"
                  },
                  "original_price": {
                    "type": "number"
                  },
                  "logistic_info": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "enabled": {
                          "type": "boolean"
                        },
                        "is_free": {
                          "type": "boolean"
                        },
                        "logistic_id": {
                          "type": "integer"
                        }
                      }
                    }
                  },
                  "image": {
                    "type": "object",
                    "properties": {
                      "image_id_list": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "brand": {
                    "type": "object",
                    "properties": {
                      "brand_id": {
                        "type": "integer"
                      },
                      "original_brand_name": {
                        "type": "string"
                      }
                    }
                  },
                  "dimension": {
                    "type": "object",
                    "properties": {
                      "package_height": {
                        "type": "integer"
                      },
                      "package_length": {
                        "type": "integer"
                      },
                      "package_width": {
                        "type": "integer"
                      }
                    }
                  },
                  "seller_stock": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "stock": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "description": "Mochila Escolar Bolsa Lapicera Lonchera Para Hombre Y Mujer",
                "item_name": "Mochila Escolar Bolsa Lapicera Lonchera Para Hombre Y Mujer",
                "category_id": 101744,
                "weight": 1.17,
                "item_status": "UNLIST",
                "original_price": 350.0,
                "logistic_info": [
                  {
                    "enabled": true,
                    "is_free": false,
                    "logistic_id": 100020
                  }
                ],
                "image": {
                  "image_id_list": [
                    "95f8f5061264033b2d49630c35ba1152",
                    "c8ad19856dd7e2be8352063f1a75907a",
                    "68f308a1ce811a2d2105edc51275b548",
                    "14b58922779b050a6286bf24c1f70004",
                    "9978ca3e99d8ea90065901af980ca813",
                    "af43ca4cf4abfdcdf130e95b328a4bba",
                    "14154583ce4f6c722c33b29ce01db910",
                    "4115e926a4416ef7379d5885f1d88ad7",
                    "32193c008e7f0a826efbd8cba2f8b13e"
                  ]
                },
                "brand": {
                  "brand_id": 0,
                  "original_brand_name": "NoBrand"
                },
                "dimension": {
                  "package_height": 10,
                  "package_length": 10,
                  "package_width": 10
                },
                "seller_stock": [
                  {
                    "stock": 703
                  }
                ]
              }
            }
          }
        }
      }
    },
