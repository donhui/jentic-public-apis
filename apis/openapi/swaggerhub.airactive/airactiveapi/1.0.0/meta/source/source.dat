{
    "openapi": "3.0.0",
    "info": {
        "version": "1.0.0",
        "title": "Air Active API",
        "description": "This document aims at providing a complete and exhaustive description of AirActive API.\nClients connecting to Air Active service needs to fetch a valid token to initiate the communication.\nThe token will be used and injected in all the query as an Authorization header field.\nIf the client fails to login then a 401 error code is sent as a response (Unauthorized).\n",
        "contact": {
            "name": "API support",
            "url": "http://airactiveapp.com/",
            "email": "support@airactiveapp.com"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/AirActive/AirActiveAPI/1.0.0/swagger.json"
    },
    "paths": {
        "/api/v1/activities": {
            "post": {
                "tags": [
                    "Activities"
                ],
                "operationId": "ApiV1ActivitiesPost",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ActivitesModel"
                            }
                        }
                    },
                    "description": "Create activities",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ActivitiesResultModel"
                                }
                            }
                        }
                    }
                },
                "deprecated": false
            }
        },
