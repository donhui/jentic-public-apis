{
  "openapi": "3.0.0",
  "info": {
    "description": "API to fetch non-transmitted entries to API calling application\nEntries can be fetched in both XML or JSON format.\n\nThe Link is https://beta.onyxone.com/restapi/siport_api_call.xml?changeStatus=1\nThe apikey will be provided by OnyxOne for external system\n\n\nChangelog:\n* 2.0.0 (Expected beta release: 03/10/2023, Expected live release: 03/10/2023)\n* * Not backward compatible change: UIN is removed from the response\n\n\n* 1.4.0 (Expected beta release: 04/08/2023, Expected live release: 30/08/2023)\n* * Fixed limosa_date format to show full date instead of just the year\n* * Added belgian_identification_number to the user response\n\n\n* 1.3.0 (Expected beta release: 01/02/2023, Expected live release: 15/02/2023)\n* * Added profile_qr_code_url to users details\n* * Added site_location information to entry details\n* * Added new endpoints that use a cursor to handle paginated requests\n\n\n* 1.2.0\n* * Added final_access_till_date to the user's fields\n* * Given a valid API key you can now call the beta environment's API directly from SwaggerHub\n",
    "version": "2.1.0",
    "title": "Api Access Entries",
    "contact": {
      "email": "lennert@onyx.be"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Lennert-Onyx/ApiAccessEntries/2.1.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/Lennert-Onyx/ApiAccessEntries/2.1.0"
    },
    {
      "url": "https://beta.onyxone.com/restapi",
      "description": "OnyxOne beta server"
    }
  ],
  "paths": {
    "/siport_api_call.json": {
      "get": {
        "summary": "Fetch non-transmitted entries in JSON format",
        "operationId": "getEntriesJSON",
        "parameters": [
          {
            "name": "apikey",
            "in": "header",
            "description": "the authorization key, provided by OnyxOne",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "changeStatus",
            "in": "query",
            "description": "changeStatus 1 will flag the entries as submitted",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ResponseJSON"
                    },
                    {
                      "$ref": "#/components/schemas/ResponseJSONNoRelated"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/siport_api_call.xml": {
      "get": {
        "summary": "Fetch non-transmitted entries in XML format",
        "operationId": "getEntriesXML",
        "parameters": [
          {
            "name": "apikey",
            "in": "header",
            "description": "the authorization key, provided by OnyxOne",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "changeStatus",
            "in": "query",
            "description": "changeStatus 1 will flag the entries as submitted",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Note that the entry id will not be its own element, but will be the value of the entry element, there is currently no way to describe this in our API documentation editor. <br> Example: \\<entry ...\\>123\\</ entry\\>",
            "content": {
              "application/xml": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ResponseXML"
                    },
                    {
                      "$ref": "#/components/schemas/ResponseXMLNoRelated"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/entriesWithCursor.json": {
      "get": {
        "summary": "Fetch entries in JSON format with cursor",
        "operationId": "getEntriesWithCursorJSON",
        "parameters": [
          {
            "name": "apikey",
            "in": "header",
            "description": "the authorization key, provided by OnyxOne",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "changeStatus",
            "in": "query",
            "description": "changeStatus 1 will flag the entries as submitted",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "after",
            "in": "query",
            "description": "the cursor that only fetches entries updated after the provided id",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ResponseCursorJSON"
                    },
                    {
                      "$ref": "#/components/schemas/ResponseCursorJSONNoRelated"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
