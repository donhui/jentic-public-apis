{
  "openapi": "3.0.0",
  "info": {
    "description": "API to fetch contractor/user information from OnyxOne.\n\nThe apikey will be provided by OnyxOne upon request\n\n\nChangelog:\n* 2.0.0 (Expected beta release: 03/10/2023, Expected live release: 03/10/2023)\n* * Not backward compatible change: UIN is removed from the user response\n",
    "version": "2.0.0",
    "title": "Api2Clients",
    "contact": {
      "email": "lennert.hofman@onyxonlinelearning.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Lennert-Onyx/Api2Clients/2.0.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/Lennert-Onyx/Api2Clients/2.0.0"
    },
    {
      "url": "https://beta.onyxone.com/restapi/",
      "description": "OnyxOne beta server"
    }
  ],
  "paths": {
    "/companies": {
      "get": {
        "summary": "Fetch contractor info",
        "description": "Available on beta from 28/06/2021, available on live from 05/07/2021",
        "parameters": [
          {
            "$ref": "#/components/parameters/apiKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Contractor info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Fetch user info",
        "description": "Available on beta from 28/06/2021, available on live from 05/07/2021",
        "parameters": [
          {
            "$ref": "#/components/parameters/apiKey"
          },
          {
            "name": "companyId",
            "description": "The company for which you want to fetch the users",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "apiKey": {
        "name": "apiKey",
        "in": "header",
        "description": "the key provided by onyxone to authorize the request",
        "required": true,
        "schema": {
          "type": "string",
          "example": "1LgW57ShzoEyUOma0MB9T16iPGN02gi4wgQD5pDn"
        }
      }
    },
    "responses": {
      "unauthorized": {
        "description": "Unauthorized request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "success": {
                  "type": "boolean",
                  "example": false
                },
                "message": {
                  "type": "string",
                  "example": "Invalid api token provided"
                }
              }
            }
          }
        }
      }
    },
    "schemas": {
      "Company": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "example": 1
            },
            "name": {
              "type": "string",
              "example": "Onyx Online Learning"
            },
            "UIN": {
              "type": "string",
              "example": "BE1234567890"
            },
            "country": {
              "type": "string",
              "example": "BE"
            },
            "street": {
              "type": "string",
              "example": "Stationstraat",
              "nullable": true
            },
            "number": {
              "type": "string",
              "example": "221B",
              "nullable": true
            },
            "zip": {
              "type": "string",
              "example": "9000",
              "nullable": true
            },
            "city": {
              "type": "string",
              "example": "Gent",
              "nullable": true
            },
            "CQ": {
              "type": "object",
              "properties": {
                "[field]": {
                  "type": "string",
                  "nullable": true,
                  "example": "iban_no: 'BE43000000008001' //iban_no will be the key instead of [field]"
                }
              }
            }
          }
        }
      },
      "User": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "example": 123
            },
            "firstName": {
              "type": "string",
              "example": "Lennert"
            },
            "lastName": {
              "type": "string",
              "example": "Hofman"
            },
            "username": {
              "type": "string",
              "example": "lennerthofman1"
            },
            "email": {
              "type": "string",
              "example": "lennert.hofman@onyxonlinelearning.com"
            },
            "uinExpirationDate": {
              "type": "string",
              "example": "2024-02-29",
              "nullable": true
            },
            "payrolCompanyId": {
              "type": "integer",
              "example": 1,
              "nullable": true
            },
            "payrolCompanyName": {
              "type": "string",
              "example": "Onyx Online Learning",
              "nullable": true
            },
            "user_status": {
              "type": "integer",
              "enum": [
                1,
                2
              ],
              "description": "User status on the portal\n * `1` - User is active\n * `2` - User is inactive\n"
            },
            "is_blacklisted": {
              "type": "integer",
              "enum": [
                1,
                0
              ],
              "description": "User status on the portal\n * `1` - User is blacklisted\n * `0` - User is not blacklisted\n"
            },
            "PQ": {
              "type": "object",
              "properties": {
                "[field]": {
                  "type": "string",
                  "nullable": true,
                  "example": "vca_certificate_exp_date: '2021-21-31' //vca_certificate_exp_date will be the key instead of [field]"
                }
              }
            }
          }
        }
      }
    }
  }
}