{
  "openapi": "3.0.3",
  "info": {
    "title": "CryptAPI",
    "version": "1.0.0",
    "description": "CryptAPI provides cryptocurrency payment processing APIs for creating payment addresses, tracking transactions, generating QR codes, estimating fees, and converting prices across multiple blockchains.",
    "x-jentic-source-url": "https://docs.cryptapi.io"
  },
  "servers": [
    {
      "url": "https://api.cryptapi.io",
      "description": "CryptAPI Production"
    }
  ],
  "tags": [
    { "name": "Info", "description": "Cryptocurrency information endpoints" },
    { "name": "Payment", "description": "Payment address and tracking endpoints" },
    { "name": "Tools", "description": "QR code, estimation, and conversion tools" }
  ],
  "paths": {
    "/info/": {
      "get": {
        "operationId": "getSupportedCoins",
        "summary": "Get all supported cryptocurrencies with pricing and fee information",
        "tags": ["Info"],
        "parameters": [
          {
            "name": "prices",
            "in": "query",
            "required": false,
            "description": "Set to 1 to include exchange rate data",
            "schema": { "type": "integer", "enum": [0, 1] }
          }
        ],
        "responses": {
          "200": {
            "description": "Supported cryptocurrencies with pricing data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SupportedCoinsResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/{ticker}/info/": {
      "get": {
        "operationId": "getTickerInfo",
        "summary": "Get information for a specific cryptocurrency",
        "tags": ["Info"],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency ticker (e.g., btc, eth, trc20/usdt)",
            "schema": { "type": "string" }
          },
          {
            "name": "prices",
            "in": "query",
            "required": false,
            "description": "Set to 1 to include exchange rate data",
            "schema": { "type": "integer", "enum": [0, 1] }
          }
        ],
        "responses": {
          "200": {
            "description": "Cryptocurrency information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TickerInfoResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/{ticker}/create/": {
      "get": {
        "operationId": "createPaymentAddress",
        "summary": "Create a new payment address for receiving cryptocurrency",
        "tags": ["Payment"],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency ticker (e.g., btc, eth, trc20/usdt)",
            "schema": { "type": "string" }
          },
          {
            "name": "callback",
            "in": "query",
            "required": true,
            "description": "Callback URL for payment notifications (URL encoded)",
            "schema": { "type": "string" }
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "description": "Forwarding address. Supports split payments: percentage_1@address_1|percentage_2@address_2",
            "schema": { "type": "string" }
          },
          {
            "name": "pending",
            "in": "query",
            "required": false,
            "description": "Set to 1 to receive pending transaction notifications",
            "schema": { "type": "integer", "enum": [0, 1] }
          },
          {
            "name": "confirmations",
            "in": "query",
            "required": false,
            "description": "Number of blockchain confirmations required (minimum 1)",
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "post",
            "in": "query",
            "required": false,
            "description": "Set to 1 to send callback as POST (incompatible with json)",
            "schema": { "type": "integer", "enum": [0, 1] }
          },
          {
            "name": "json",
            "in": "query",
            "required": false,
            "description": "Set to 1 to send callback body as JSON (incompatible with post)",
            "schema": { "type": "integer", "enum": [0, 1] }
          },
          {
            "name": "priority",
            "in": "query",
            "required": false,
            "description": "Transaction priority (BTC, ETH/ERC-20, LTC only)",
            "schema": { "type": "string" }
          },
          {
            "name": "multi_token",
            "in": "query",
            "required": false,
            "description": "Set to 1 to allow payments in different tokens (TRC20/EVM only)",
            "schema": { "type": "integer", "enum": [0, 1] }
          },
          {
            "name": "convert",
            "in": "query",
            "required": false,
            "description": "Set to 1 to return FIAT conversion values in callback",
            "schema": { "type": "integer", "enum": [0, 1] }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment address created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateAddressResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/{ticker}/logs/": {
      "get": {
        "operationId": "getPaymentLogs",
        "summary": "Get payment logs and callback history for an address",
        "tags": ["Payment"],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency ticker",
            "schema": { "type": "string" }
          },
          {
            "name": "callback",
            "in": "query",
            "required": true,
            "description": "The callback URL used when creating the payment address (must match exactly, URL encoded)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment logs",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaymentLogsResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/{ticker}/qrcode/": {
      "get": {
        "operationId": "generateQrCode",
        "summary": "Generate a QR code for a payment address",
        "tags": ["Tools"],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency ticker",
            "schema": { "type": "string" }
          },
          {
            "name": "address",
            "in": "query",
            "required": true,
            "description": "Payment address",
            "schema": { "type": "string" }
          },
          {
            "name": "value",
            "in": "query",
            "required": false,
            "description": "Amount to request (may not be recognized by all wallets)",
            "schema": { "type": "integer" }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "QR code size in pixels (64-1024)",
            "schema": { "type": "integer", "minimum": 64, "maximum": 1024 }
          }
        ],
        "responses": {
          "200": {
            "description": "QR code generated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QrCodeResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/{ticker}/estimate/": {
      "get": {
        "operationId": "estimateBlockchainFees",
        "summary": "Estimate blockchain transaction fees",
        "tags": ["Tools"],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency ticker",
            "schema": { "type": "string" }
          },
          {
            "name": "addresses",
            "in": "query",
            "required": false,
            "description": "Number of forwarding addresses (higher increases fees)",
            "schema": { "type": "integer" }
          },
          {
            "name": "priority",
            "in": "query",
            "required": false,
            "description": "Transaction priority level (BTC, ETH/ERC-20, LTC only)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Fee estimation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FeeEstimateResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/{ticker}/convert/": {
      "get": {
        "operationId": "convertPrice",
        "summary": "Convert between cryptocurrency and fiat currencies",
        "tags": ["Tools"],
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency ticker",
            "schema": { "type": "string" }
          },
          {
            "name": "value",
            "in": "query",
            "required": true,
            "description": "Amount to convert",
            "schema": { "type": "number" }
          },
          {
            "name": "from",
            "in": "query",
            "required": true,
            "description": "Source currency (FIAT or crypto code)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversion result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConvertResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SupportedCoinsResponse": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "coin": { "type": "string" },
            "logo": { "type": "string" },
            "ticker": { "type": "string" },
            "minimum_transaction_coin": { "type": "string" },
            "minimum_fee_coin": { "type": "string" },
            "fee_percent": { "type": "number" },
            "network_fee_estimation": { "type": "string" },
            "prices": { "type": "object", "additionalProperties": { "type": "number" } },
            "prices_updated": { "type": "string" }
          }
        }
      },
      "TickerInfoResponse": {
        "type": "object",
        "properties": {
          "coin": { "type": "string" },
          "logo": { "type": "string" },
          "ticker": { "type": "string" },
          "minimum_transaction_coin": { "type": "string" },
          "minimum_fee_coin": { "type": "string" },
          "fee_percent": { "type": "number" },
          "network_fee_estimation": { "type": "string" },
          "status": { "type": "string" },
          "prices": { "type": "object", "additionalProperties": { "type": "number" } },
          "prices_updated": { "type": "string" }
        }
      },
      "CreateAddressResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "address_in": { "type": "string", "description": "Generated payment address" },
          "address_out": { "type": "string", "description": "Forwarding address" },
          "callback_url": { "type": "string" },
          "priority": { "type": "string" },
          "minimum_transaction_coin": { "type": "number" }
        }
      },
      "PaymentLogsResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "address_in": { "type": "string" },
          "address_out": { "type": "string" },
          "callback_url": { "type": "string" },
          "notify_pending": { "type": "boolean" },
          "notify_confirmations": { "type": "integer" },
          "priority": { "type": "string" },
          "callbacks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "txid_in": { "type": "string" },
                "txid_out": { "type": "string" },
                "value_coin": { "type": "number" },
                "value_forwarded_coin": { "type": "number" },
                "confirmations": { "type": "integer" },
                "result": { "type": "string", "enum": ["pending", "sent", "done"] },
                "logs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "request_url": { "type": "string" },
                      "response": { "type": "string" },
                      "http_code": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "QrCodeResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "qr_code": { "type": "string", "description": "Base64-encoded QR code image" },
          "payment_uri": { "type": "string", "description": "Payment URI for clickable buttons" }
        }
      },
      "FeeEstimateResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "estimated_cost": { "type": "string", "description": "Fee in native cryptocurrency" },
          "estimated_cost_currency": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Fee estimates in fiat currencies"
          }
        }
      },
      "ConvertResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "value_coin": { "type": "string", "description": "Converted value" },
          "exchange_rate": { "type": "string", "description": "Exchange rate between currencies" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "error" },
          "error": { "type": "string", "description": "Error message" }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}