              "vitamin_k_mcg": {
                "description": "Vitamin K in micrograms",
                "examples": [
                  120
                ],
                "type": "number"
              },
              "zinc_mg": {
                "description": "Zinc in milligrams",
                "examples": [
                  11
                ],
                "type": "number"
              }
            },
            "type": "object"
          },
          "serving_size": {
            "description": "Serving size in metric units",
            "examples": [
              120
            ],
            "format": "double",
            "type": "number"
          },
          "unit": {
            "description": "Metric unit (g for solids, ml for liquids)",
            "enum": [
              "g",
              "mg",
              "mcg",
              "ml",
              "kcal"
            ],
            "examples": [
              "g"
            ],
            "type": "string"
          }
        },
        "required": [
          "name",
          "serving_size",
          "unit"
        ],
        "type": "object"
      },
