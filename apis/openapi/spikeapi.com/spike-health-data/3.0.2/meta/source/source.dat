              ],
              "type": "string"
            }
          },
          {
            "explode": false,
            "in": "query",
            "name": "providers",
            "schema": {
              "items": {
                "enum": [
                  "strava",
                  "health_connect",
                  "fitbit",
                  "garmin",
                  "huawei",
                  "dexcom",
                  "whoop",
                  "withings",
                  "suunto",
                  "apple",
                  "freestyle_libre",
                  "oura",
