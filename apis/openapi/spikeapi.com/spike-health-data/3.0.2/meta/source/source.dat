        "additionalProperties": false,
        "properties": {
          "collection_date": {
            "type": "string"
          },
          "lab_information": {
            "$ref": "#/components/schemas/LabInformation"
          },
          "modified_at": {
            "format": "date-time",
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "original_record_id": {
            "type": "string"
          },
          "parsing_error": {
