          },
          {
            "description": "The OS that is sending the request",
            "example": "iOS",
            "in": "header",
            "name": "x-spike-os",
            "schema": {
              "description": "The OS that is sending the request",
              "examples": [
                "iOS"
              ],
              "type": "string"
            }
          },
          {
