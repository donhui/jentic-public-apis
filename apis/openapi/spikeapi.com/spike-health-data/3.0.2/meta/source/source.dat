                "cadence",
                "cadence_min",
                "cadence_max",
                "pace",
                "body_mass_index",
                "weight",
                "height",
                "vo2max",
                "body_temperature",
                "body_temperature_max",
                "body_temperature_min",
                "basal_body_temperature",
                "basal_body_temperature_max",
                "basal_body_temperature_min",
