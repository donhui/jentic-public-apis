          },
          {
            "description": "Exclude manual metrics from the statistics",
            "explode": false,
            "in": "query",
            "name": "exclude_manual",
            "schema": {
              "default": false,
              "description": "Exclude manual metrics from the statistics",
              "type": "boolean"
