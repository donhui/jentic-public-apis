                  "scale",
                  "ring",
                  "head_mounted",
                  "fitness_band",
                  "chest_strap",
                  "smart_display",
                  "accessory"
                ],
                "type": "string"
              },
              "type": "array"
            }
          }
        ],
        "responses": {
          "200": {
