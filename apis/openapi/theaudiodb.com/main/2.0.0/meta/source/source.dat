{
  "openapi": "3.0.3",
  "info": {
    "title": "TheAudioDB API",
    "description": "TheAudioDB is a community-driven music database providing information about artists, albums, tracks, and music videos. It offers search, lookup, and listing endpoints for comprehensive music metadata.",
    "version": "2.0.0",
    "contact": {
      "name": "TheAudioDB",
      "url": "https://www.theaudiodb.com"
    },
    "x-jentic-source-url": "https://www.theaudiodb.com/free_music_api"
  },
  "servers": [
    {
      "url": "https://www.theaudiodb.com/api/v2/json",
      "description": "TheAudioDB API v2 (Premium, header-based auth)"
    }
  ],
  "security": [
    {
      "ApiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Search",
      "description": "Search for artists, albums, and tracks by name"
    },
    {
      "name": "Lookup",
      "description": "Look up specific artists, albums, or tracks by ID"
    },
    {
      "name": "List",
      "description": "List discographies, music videos, top tracks, and trending items"
    }
  ],
  "paths": {
    "/search/artist/{text}": {
      "get": {
        "operationId": "searchArtist",
        "summary": "Search for an artist by name",
        "description": "Search for artists matching the given text. Returns up to 10 results.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "text",
            "in": "path",
            "required": true,
            "description": "Artist name to search for",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtistSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/search/album/{text}": {
      "get": {
        "operationId": "searchAlbum",
        "summary": "Search for an album by name",
        "description": "Search for albums matching the given text. Returns up to 10 results.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "text",
            "in": "path",
            "required": true,
            "description": "Album name to search for",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlbumSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/search/track/{text}": {
      "get": {
        "operationId": "searchTrack",
        "summary": "Search for a track by name",
        "description": "Search for tracks matching the given text. Returns up to 10 results.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "text",
            "in": "path",
            "required": true,
            "description": "Track name to search for",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/lookup/artist/{id}": {
      "get": {
        "operationId": "lookupArtist",
        "summary": "Look up an artist by ID",
        "description": "Retrieve detailed information about a specific artist by their TheAudioDB ID.",
        "tags": ["Lookup"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "TheAudioDB artist ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtistSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/lookup/album/{id}": {
      "get": {
        "operationId": "lookupAlbum",
        "summary": "Look up an album by ID",
        "description": "Retrieve detailed information about a specific album by its TheAudioDB ID.",
        "tags": ["Lookup"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "TheAudioDB album ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlbumSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/lookup/track/{id}": {
      "get": {
        "operationId": "lookupTrack",
        "summary": "Look up a track by ID",
        "description": "Retrieve detailed information about a specific track by its TheAudioDB ID.",
        "tags": ["Lookup"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "TheAudioDB track ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/list/discography/{artistId}": {
      "get": {
        "operationId": "listDiscography",
        "summary": "List an artist's discography",
        "description": "Retrieve the full discography for an artist. Returns up to 500 albums.",
        "tags": ["List"],
        "parameters": [
          {
            "name": "artistId",
            "in": "path",
            "required": true,
            "description": "TheAudioDB artist ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlbumSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "Premium API key provided after subscription. Free tier uses test key '1' in v1 URL path."
      }
    },
    "schemas": {
      "Artist": {
        "type": "object",
        "properties": {
          "idArtist": {
            "type": "string",
            "description": "Unique artist identifier"
          },
          "strArtist": {
            "type": "string",
            "description": "Artist name"
          },
          "strArtistAlternate": {
            "type": "string",
            "nullable": true,
            "description": "Alternate artist name"
          },
          "strLabel": {
            "type": "string",
            "nullable": true,
            "description": "Record label"
          },
          "idLabel": {
            "type": "string",
            "nullable": true,
            "description": "Label ID"
          },
          "intFormedYear": {
            "type": "string",
            "nullable": true,
            "description": "Year the artist/band formed"
          },
          "intBornYear": {
            "type": "string",
            "nullable": true,
            "description": "Birth year for solo artists"
          },
          "strGenre": {
            "type": "string",
            "nullable": true,
            "description": "Primary genre"
          },
          "strStyle": {
            "type": "string",
            "nullable": true,
            "description": "Musical style"
          },
          "strMood": {
            "type": "string",
            "nullable": true,
            "description": "Musical mood"
          },
          "strWebsite": {
            "type": "string",
            "nullable": true,
            "description": "Official website URL"
          },
          "strFacebook": {
            "type": "string",
            "nullable": true,
            "description": "Facebook page URL"
          },
          "strTwitter": {
            "type": "string",
            "nullable": true,
            "description": "Twitter handle"
          },
          "strBiographyEN": {
            "type": "string",
            "nullable": true,
            "description": "English biography"
          },
          "strCountry": {
            "type": "string",
            "nullable": true,
            "description": "Country of origin"
          },
          "strArtistThumb": {
            "type": "string",
            "nullable": true,
            "description": "Thumbnail image URL"
          },
          "strArtistFanart": {
            "type": "string",
            "nullable": true,
            "description": "Fan art image URL"
          },
          "strArtistBanner": {
            "type": "string",
            "nullable": true,
            "description": "Banner image URL"
          },
          "strArtistLogo": {
            "type": "string",
            "nullable": true,
            "description": "Artist logo image URL"
          },
          "intMembers": {
            "type": "string",
            "nullable": true,
            "description": "Number of members"
          }
        }
      },
      "Album": {
        "type": "object",
        "properties": {
          "idAlbum": {
            "type": "string",
            "description": "Unique album identifier"
          },
          "idArtist": {
            "type": "string",
            "description": "Artist identifier"
          },
          "strAlbum": {
            "type": "string",
            "description": "Album title"
          },
          "strArtist": {
            "type": "string",
            "description": "Artist name"
          },
          "intYearReleased": {
            "type": "string",
            "nullable": true,
            "description": "Release year"
          },
          "strGenre": {
            "type": "string",
            "nullable": true,
            "description": "Album genre"
          },
          "strStyle": {
            "type": "string",
            "nullable": true,
            "description": "Album style"
          },
          "strLabel": {
            "type": "string",
            "nullable": true,
            "description": "Record label"
          },
          "strDescriptionEN": {
            "type": "string",
            "nullable": true,
            "description": "English description"
          },
          "strAlbumThumb": {
            "type": "string",
            "nullable": true,
            "description": "Album cover thumbnail URL"
          },
          "intScore": {
            "type": "string",
            "nullable": true,
            "description": "User rating score"
          },
          "intScoreVotes": {
            "type": "string",
            "nullable": true,
            "description": "Number of rating votes"
          },
          "strMusicBrainzID": {
            "type": "string",
            "nullable": true,
            "description": "MusicBrainz album ID"
          }
        }
      },
      "Track": {
        "type": "object",
        "properties": {
          "idTrack": {
            "type": "string",
            "description": "Unique track identifier"
          },
          "idAlbum": {
            "type": "string",
            "description": "Album identifier"
          },
          "idArtist": {
            "type": "string",
            "description": "Artist identifier"
          },
          "strTrack": {
            "type": "string",
            "description": "Track title"
          },
          "strAlbum": {
            "type": "string",
            "description": "Album name"
          },
          "strArtist": {
            "type": "string",
            "description": "Artist name"
          },
          "intDuration": {
            "type": "string",
            "nullable": true,
            "description": "Track duration in milliseconds"
          },
          "strGenre": {
            "type": "string",
            "nullable": true,
            "description": "Track genre"
          },
          "strDescriptionEN": {
            "type": "string",
            "nullable": true,
            "description": "English description"
          },
          "strTrackThumb": {
            "type": "string",
            "nullable": true,
            "description": "Track thumbnail URL"
          },
          "strMusicVid": {
            "type": "string",
            "nullable": true,
            "description": "Music video URL"
          },
          "intTrackNumber": {
            "type": "string",
            "nullable": true,
            "description": "Track number on album"
          },
          "intScore": {
            "type": "string",
            "nullable": true,
            "description": "User rating score"
          },
          "strMusicBrainzID": {
            "type": "string",
            "nullable": true,
            "description": "MusicBrainz track ID"
          }
        }
      },
      "ArtistSearchResponse": {
        "type": "object",
        "properties": {
          "artists": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/Artist"
            }
          }
        }
      },
      "AlbumSearchResponse": {
        "type": "object",
        "properties": {
          "album": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/Album"
            }
          }
        }
      },
      "TrackSearchResponse": {
        "type": "object",
        "properties": {
          "track": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/Track"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}
