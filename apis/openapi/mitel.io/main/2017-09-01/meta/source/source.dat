    "/saml2/start": {
      "post": {
        "tags": [
          "IdentityProviders"
        ],
        "summary": "Initiate SAML2.0 based authentication",
        "description": "Generate a SAML Request for a user",
        "operationId": "saml2Start",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "redirect_uri": {
                    "type": "string"
                  },
                  "account_id": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "force_authn": {
                    "type": "boolean"
                  },
                  "state": {
                    "type": "string"
                  },
                  "code_challenge": {
                    "type": "string"
                  },
                  "code_challenge_method": {
                    "type": "string"
                  }
                },
                "required": [
                  "username",
                  "client_id",
                  "redirect_uri"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Success response containing redirection URL towards identity provider"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "MissingBodyInRequest",
                        "MissingMandatoryParams"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "InvalidLoginCredentials"
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "InactiveAccount",
                        "InactiveIdentityProvider"
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "NoneMatching",
                        "AccountNotFound",
                        "IdentityProviderNotFound"
                      ]
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ConflictResponse"
                }
              }
            }
          },
          "500": {
            "description": "Failure response"
          }
        }
      }
    },
    "/saml2/{accountId}/cs": {
      "post": {
        "tags": [
          "IdentityProviders"
        ],
        "summary": "Process SAML claims from 3rd party Identity Providers",
        "description": "Exchange SAML claims from an Identity Provider and issue an authorization code",
        "operationId": "saml2Response",
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
