    "/sso/{providerId}": {
      "get": {
        "tags": [
          "SSO"
        ],
        "summary": "This route is deprecated as the funtionality is no longer supported.",
        "description": "This route is deprecated as the funtionality is no longer supported.",
        "operationId": "loginSsoProvider",
        "parameters": [
          {
            "name": "providerId",
            "in": "path",
            "description": "The sso provider to trigger the flow, for instance google or facebook",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "description": "A registered client_id / application in the admin system.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "description": "The url to redirect back to upon success or failure. Success redirects look like <redirect_uri>?code=abc123... and failure redirects look like <redirect_uri>?error=errorCode?info=info",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "action",
            "in": "query",
            "description": "The action to perform upon successful validation by an SSO provider. Login does an authenticate against our system, sign-up will create a user in an account and link will allow this third party to be linked to an existing identity. Guest will allow a guest access on the given account. Defaults to 'login'.  Link is not supported yet.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "login",
                "sign-up",
                "link",
                "guest"
              ]
            }
          },
          {
            "name": "scopes",
            "in": "query",
            "description": "Additional scopes to include in the sign-on process. Comma separated",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/accountIdParam"
          },
          {
            "$ref": "#/components/parameters/userIdParam"
          },
          {
            "name": "accessCode",
            "in": "query",
            "description": "accessCode is REQUIRED when dealing with the 'link' flow only. If you are linking a user account you must provide and accountId, userId, and accessCode to link.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/accountIdParam"
          },
          {
            "$ref": "#/components/parameters/userIdParam"
          }
        ],
        "responses": {
          "410": {
            "description": "410 Gone"
          },
          "500": {
            "description": "500 Internal Server Error"
          }
        }
      }
    },
