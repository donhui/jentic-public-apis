      "credential": {
        "allOf": [
          {
            "$ref": "#/components/schemas/resource"
          },
          {
            "type": "object",
            "required": [
              "credentialId",
              "type",
              "owner"
            ],
            "properties": {
              "credentialId": {
                "type": "string",
                "description": "The credential identifier, it is also the key id of the key pair"
              },
              "accountId": {
                "type": "string",
                "description": "The account ID of the credential"
              },
              "name": {
                "type": "string",
                "description": "The name of the credential"
              },
              "type": {
                "type": "string",
                "description": "The type of credential specified",
                "enum": [
                  "jwk",
                  "oauthToken",
                  "token",
                  "clientCredentials"
                ]
              },
              "target": {
                "type": "string",
                "description": "The intended target (destination) of the credential. Refers to the system that the credential applies to.",
                "example": "https://mitel.io"
              },
              "owner": {
                "type": "string",
                "description": "The owner of the credential"
              },
              "status": {
                "type": "string",
                "enum": [
                  "active",
                  "inactive",
                  "pendingDeletion"
                ],
                "description": "The status of this credential"
              },
              "accessRestriction": {
                "type": "string",
                "enum": [
                  "global",
                  "account",
                  "principal",
                  "owner"
                ],
                "description": "The access restriction applied to the credential refers to the level of access required to manage or to be returned the private portion of the given credential.  global - those with system credentials, account - those with admin access within the account, principal - those with principal (user) access within the account, owner - only the owner."
              },
              "expiry": {
                "type": "string",
                "format": "date-time",
                "description": "The intended expiry of this credential, if any"
              },
              "linkedCredentialId": {
                "type": "string",
                "description": "A reference to another credential ID in the account to which this credential is dependent upon. For instance, the oauthToken may depend on the clientCredentials for certain operations."
              },
              "publicKey": {
                "type": "object",
                "description": "The public portion of the credential"
              },
              "privateKey": {
                "type": "object",
                "description": "The private portion of the credential.  Only returned for those with sufficient priveledge to view"
              }
            }
          }
        ]
      },
      "credentialCollection": {
        "allOf": [
          {
            "$ref": "#/components/schemas/resourceCollection"
          },
          {
            "type": "object",
            "properties": {
              "_embedded": {
                "type": "object",
                "required": [
                  "items"
                ],
                "description": "Used for embedded objects",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/credential"
                    }
                  },
                  "expand": {
                    "type": "object",
                    "properties": {
                      "keys": {
                        "type": "array",
                        "description": "The set of json web keys",
                        "items": {
                          "type": "object"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "credentialCommand": {
        "type": "object",
        "required": [
          "action",
          "options"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "encode",
              "decode",
              "authorize"
            ]
          },
          "options": {
            "type": "object",
            "description": "The command options corresponding to the requested action.  \nFor encoding jwt actions a 'payload' object is supplied containing the supported fields 'subject' (string), 'audience' (array of strings), 'scope' (string), and 'expiryDate' (date-time).\nFor decoding jwt type actions a 'token' (string) field would contain the jwt to decode"
          }
        }
      },
      "credentialCommandResponse": {
        "type": "object",
        "description": "The response of the credential command.  For encoding a jwk type credential this would include the property 'jwt' as string.  For decoding a jwk type credential this would include the property 'jwt' as object."
      },
      "credentialsPostRequest": {
        "type": "object",
        "required": [
          "type",
          "accessRestriction"
        ],
        "properties": {
          "accountId": {
            "type": "string",
            "description": "The account ID for this credential. Can only be specified by GLOBAL_ADMIN role."
          },
          "name": {
            "type": "string",
            "description": "The name of the credential"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive"
            ],
            "description": "The status of this credential",
            "default": "active"
          },
          "type": {
            "type": "string",
            "enum": [
              "jwk",
              "oauthToken",
              "token",
              "clientCredentials"
            ],
            "description": "The type of this credential"
          },
          "target": {
            "type": "string",
            "description": "The intended target (destination) of the credential. Refers to the system that the credential applies to.",
            "example": "https://mitel.io"
          },
          "accessRestriction": {
            "type": "string",
            "enum": [
              "global",
              "account",
              "principal",
              "owner"
            ],
            "description": "The access restriction applied to the credential refers to the level of access required to manage or to be returned the private portion of the given credential.  global - those with system credentials, account - those with admin access within the account, principal - those with principal (user) access within the account, owner - only the owner."
          },
          "publicKey": {
            "type": "object",
            "description": "The public portion of the given credential if any"
          },
          "privateKey": {
            "type": "object",
            "description": "The private portion of the given credential if any"
          },
          "linkedCredentialId": {
            "type": "string",
            "description": "A reference to another credential ID in the account to which this credential is dependent upon. For instance, the oauthToken may depend on the clientCredentials for certain operations."
          }
        },
        "additionalProperties": false
      },
