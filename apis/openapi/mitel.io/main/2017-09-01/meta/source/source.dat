            "example": "https://authentication.api.mitel.io/cloudlink"
          },
          "authorization_endpoint": {
            "type": "string",
            "description": "URL of the authorization server's authorization endpoint",
            "example": "https://auth.mitel.io/authorize"
          },
          "token_endpoint": {
            "type": "string",
            "description": "URL of the authorization server's token endpoint",
            "example": "https://authentication.api.mitel.io/token"
          },
          "jwks_uri": {
            "type": "string",
            "description": "URL of the authorization server's JWK Set document for the given account",
            "example": "https://authentication.api.mitel.io/accounts/acc1234/.well-known/jwks.json"
          },
          "response_types_supported": {
            "type": "array",
            "description": "JSON array containing a list of the OAuth 2.0 response_type supported by this authorization server",
            "items": {
              "type": "string"
            },
            "example": [
              "code",
              "token"
            ]
          },
          "grant_types_supported": {
            "type": "array",
            "description": "JSON array containing a list of the OAuth 2.0 grant types supported by this authorization server",
            "items": {
              "type": "string"
            },
            "example": [
              "authorization_code",
              "implicit",
              "password",
              "client_credentials",
              "refresh_token",
              "urn:ietf:params:oauth:grant-type:token-exchange"
            ]
          },
          "token_endpoint_auth_methods_supported": {
            "type": "array",
            "description": "JSON array containing a list of client authentication methods supported by this token endpoint",
            "items": {
              "type": "string"
            },
            "example": [
              "none"
            ]
          },
          "service_documentation": {
            "type": "string",
            "description": "URL of a page containing human-readable information that developers might want or need to know when using the authorization server",
            "example": "https://developer.mitel.io/guides-resources/api-guides#authentication-api-guide"
          },
          "ui_locales_supported": {
            "type": "array",
            "description": "Languages and scripts supported for the user interface",
            "items": {
              "type": "string"
            },
            "example": [
              "en-US",
              "en-GB",
              "en-CA",
              "fr-FR",
              "fr-CA"
            ]
          },
          "op_policy_uri": {
            "type": "string",
            "description": "URL that the authorization server provides to the person registering the client to read about the authorization server's requirements on how the client can use the data provided by the authorization server",
            "example": "https://www.mitel.com/legal/mitel-cloud-services-terms-and-conditions"
          },
          "op_tos_uri": {
            "type": "string",
            "description": "URL that the authorization server provides to the person registering the client to read about the authorization server's terms of service",
            "example": "https://www.mitel.com/legal/mitel-cloud-services-terms-and-conditions"
          },
          "code_challenge_methods_supported": {
            "type": "array",
            "description": "JSON array containing a list of the OAuth 2.0 code challenge methods supported by this authorization server",
            "items": {
              "type": "string"
            },
            "example": [
              "plain",
              "S256"
            ]
          }
        },
        "additionalProperties": false
      },
      "hydraDiscoveryMetadata": {
        "type": "object",
        "description": "Hydra client discovery metadata",
        "required": [
          "apiUrl",
          "auth"
        ],
        "properties": {
          "apiUrl": {
            "type": "string",
            "description": "The discovery url for the server implementation of the hydra client API",
            "example": "https://app-proxy.api.mitel.io"
          },
          "auth": {
            "type": "object",
            "description": "The discovery urls for the oauth urls",
            "required": [
              "discoveryUrl",
              "tokenUrl",
              "authenticationUrl"
            ],
            "properties": {
              "discoveryUrl": {
                "type": "string",
                "description": "The oauth discovery endpoint",
                "example": "https://authentication.api.mitel.io/.well-known/openid-configuration"
              },
              "tokenUrl": {
                "type": "string",
                "description": "The token endpoint for the oauth flow",
                "example": "https://authentication.api.mitel.io/token"
              },
              "authorizationUrl": {
                "type": "string",
                "description": "The authorization endpoint for the oauth flow",
                "example": "https://auth.mitel.io/authorize"
              },
              "oauthClientConfigs": {
                "type": "array",
                "description": "The oauth client config hydra application variants",
                "items": {
                  "$ref": "#/components/schemas/oauthClientConfig"
                }
              }
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "paths": {
    "/token": {
      "get": {
        "tags": [
          "Token"
        ],
        "summary": "Get/validate a token",
        "description": "Used to validate/decode the passed in token to the authorization header.\n\rCan be used as a Who Am I call or a simple auth check.",
        "operationId": "getClaims",
        "responses": {
          "200": {
            "description": "200 response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/claims"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "MissingAuthToken",
                        "MissingRequestContext"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "MissingClaims"
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "AuthenticationFailure"
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "UnregisteredRoute"
                      ]
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TooManyRequestsResponse"
                }
              }
            }
          },
          "500": {
            "description": "500 response"
          }
        }
      },
      "post": {
        "tags": [
          "Token"
        ],
        "summary": "Create a token -> authenticate",
        "description": "Request an access token (OAuth 2.0 with extensions)",
        "operationId": "createToken",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "password",
                      "client_credentials",
                      "refresh_token",
                      "authorization_code",
                      "urn:ietf:params:oauth:grant-type:token-exchange"
                    ],
                    "description": "This is used to specify the type of OAuth 2.0 flow that is being requested."
                  },
                  "account_id": {
                    "type": "string",
                    "description": "The accountId or accountNumber registered on the platform. Required if the username is present in more than one account."
                  },
                  "username": {
                    "type": "string",
                    "description": "Used when the grant_type = 'password', username & password are the login credentials for the user"
                  },
                  "password": {
                    "type": "string",
                    "description": "Used when the grant_type = 'password', username & password are the login credentials for the user"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', client_id & client_secret are the login credentials for the client. Also when the grant_type = 'authorization_code', it is the client application making the request"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', client_id & client_secret are the login credentials for the client"
                  },
                  "token": {
                    "type": "string",
                    "description": "(Deprecated) Use refresh_token instead. Used when the grant_type = 'refresh_token', this is the refresh token which will be used to generate a fresh set of tokens"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Used when the grant_type = 'refresh_token', this is the refresh token which will be used to generate a fresh set of tokens"
                  },
                  "code": {
                    "type": "string",
                    "description": "Used when the grant_type = 'authorization_code' which is the code that was sent in the authorization code response"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "description": "Optionally used when the grant_type = 'authorization_code' to match the redirect_uri in the create authorization_code request"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Request for access to additional resource(s). Space delimited scope identifiers (eg: gauth). For grant_type = 'authorization_code', the scope items must match one of the scopes that was provided in create authorization_code request.\n\n Supported scope values: openid, gauth, abc, profile, read_write"
                  },
                  "principalId": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim, must not identify a real user"
                  },
                  "uniqueUserId": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim, must not identify a real user"
                  },
                  "userId": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim, must not identify a real user"
                  },
                  "name": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim."
                  },
                  "role": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim. The role cannot be higher than the client's own role"
                  },
                  "email": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim (verified), must not identify a real user"
                  },
                  "emailVerified": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with an unverified email."
                  },
                  "phone": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim (verified)."
                  },
                  "phoneVerified": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with an unverified phone"
                  },
                  "mobile": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim (verified), must not identify a real user"
                  },
                  "mobileVerified": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with an unverified mobile"
                  },
                  "extension": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim (verified)"
                  },
                  "extensionVerified": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with an unverified extension"
                  },
                  "photoUrl": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim"
                  },
                  "profileHeaderUrl": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim"
                  },
                  "languageCode": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim"
                  },
                  "loginId": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim (verified), must not identify a real user"
                  },
                  "siteId": {
                    "type": "string",
                    "description": "Used when the grant_type = 'client_credentials', will issue an anonymous user token with this claim"
                  },
                  "code_verifier": {
                    "type": "string",
                    "description": "PKCE code verifier"
                  },
                  "subject_token_type": {
                    "type": "string",
                    "description": "Used for token-exchange flow, indicates the type of subject_token provided"
                  },
                  "subject_token": {
                    "type": "string",
                    "description": "In token-exchange flow, represents the identity of the requestor"
                  },
                  "requested_subject": {
                    "type": "string",
                    "description": "In token-exchange flow, represents an identity being requested"
                  },
                  "audience": {
                    "type": "string",
                    "description": "In token-exchange flow, represents a target application for the new token"
                  }
                },
                "required": [
                  "grant_type"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "201 response containing access and refresh tokens",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/token"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "MissingParameters",
                        "InvalidGrantType",
                        "InactiveAccount",
                        "InvalidScope",
                        "MissingAuthToken",
                        "InvalidLoginCredentials",
                        "InvalidPrincipals",
                        "MissingBodyInRequest"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "InvalidLoginCredentials",
                        "InvalidVerifier",
                        "ClientSecretMismatch",
                        "ClientNotActive"
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "UnknownAuthError",
                        "AuthenticationFailure",
                        "UserNotActive",
                        "FailedImpersonation",
                        "ImpersonationNotAllowed",
                        "InvalidOrigin",
                        "InvalidClient"
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "AccountNotFound",
                        "ClientNotFound",
                        "UserNotFound",
                        "UnregisteredRoute"
                      ]
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConflictResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "error": {
                      "type": "string",
                      "description": "error code indicating failure reason.\n401 - Account locked\n451 - Password change needed\n452 - Password does not meet requirements"
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TooManyRequestsResponse"
                }
              }
            }
          },
          "500": {
            "description": "500 response"
          }
        }
      }
    },
    "/guest/token": {
      "post": {
        "tags": [
          "Token"
        ],
        "summary": "Create a guest token -> authenticate for guest access",
        "description": "Request a guest bearer token.  Only valid for those accounts with guest access enabled.",
        "operationId": "createGuestToken",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": {
                    "type": "string",
                    "description": "The account for which the guest token will be issued.  Provide this value if known."
                  },
                  "accessCode": {
                    "type": "string",
                    "description": "The meeting access code which will be used to determine the account for which the guest token will be issued."
                  },
                  "principalId": {
                    "type": "string",
                    "description": "How this client will be identified within the system (e.g. when chat messages get stored), cannot conflict with an existing principalId.  One will be generated if not provided"
                  },
                  "name": {
                    "type": "string",
                    "description": "The name of this guest user"
                  },
                  "guestEmail": {
                    "type": "string",
                    "description": "The email address of this guest user"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "The client application requesting this guest token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "201 response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/token"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "AccountMissing",
                        "PrincipalMissing",
                        "NameInvalid",
                        "AccountNotFound",
                        "EmailInvalid"
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden, account does not allow guest access or is disabled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "InactiveAccount",
                        "NotAllowed"
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Account Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/assume-role/token": {
      "post": {
        "tags": [
          "Token"
        ],
        "summary": "Create a token with alternate role",
        "description": "Request a bearer token with assumed role.  The target role must be the same or lower than current role.",
        "operationId": "createTokenWithAssumedRole",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/assumeRoleTokenPostRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "201 response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/token"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "MalformedJSON",
                        "MissingBodyInRequest",
                        "MissingRoleInRequest",
                        "InvalidRole",
                        "AssumeRoleHigh",
                        "IncorrectClaims"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "ClientNotActive"
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "InsufficientPermissions",
                        "MissingPartnerIdInClaims",
                        "UnknownAuthError",
                        "AuthenticationFailure",
                        "InactiveAccount",
                        "ImpersonationNotAllowed"
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "AccountNotFound",
                        "UnregisteredRoute"
                      ]
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "500 response"
          }
        }
      }
    },
    "/authorize": {
      "post": {
        "tags": [
          "Authorize"
        ],
        "summary": "Create an Authorizatione Code",
        "description": "Request an Authorization Code for OAuth 2.0 Authorization Code Grant.  Supports PKCE (RFC 7636) to prevent interception attacks.",
        "operationId": "createAuthorizationCode",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Application Identifier"
                  },
                  "response_type": {
                    "type": "string",
                    "description": "return type"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Allow access to particular scope. Multiple scopes can be used by creating a space-delimited, case sensitive list of scope values.\n\n Supported scope values(description): gauth(Issues a Connect Cloud Token in addtion to a CloudLink Token)"
                  },
                  "username": {
                    "type": "string",
                    "description": "username of user"
                  },
                  "password": {
                    "type": "string",
                    "description": "password for user"
                  },
                  "account_id": {
                    "type": "string",
                    "description": "Account identifier for the user. If the username exists in multiple accounts, the Account Id will be used to uniquely identify a user."
                  },
                  "redirect_uri": {
                    "type": "string",
                    "description": "uri which the code will eventually be returned to"
                  },
                  "nonce": {
                    "type": "string",
                    "description": "nonce for the session state"
                  },
                  "session_state": {
                    "type": "string",
                    "description": "session state"
                  },
                  "code_challenge_method": {
                    "type": "string",
                    "description": "PKCE code verifier transformation method. Only S256 is supported."
                  },
                  "code_challenge": {
                    "type": "string",
                    "description": "PKCE code challenge"
                  },
                  "id_token_hint": {
                    "type": "string",
                    "description": "the token to exchange for an authorization code"
                  },
                  "target_client_id": {
                    "type": "string",
                    "description": "the destination client application identifier meant to receive this authorization code"
                  }
                },
                "required": [
                  "client_id",
                  "response_type"
                ]
              }
            }
          }
        },
