      "applicationsPostRequest": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "applicationId": {
            "type": "string",
            "description": "The client application Id. For 3rd-party application, it is generated and not allowed to be assigned."
          },
          "accountId": {
            "type": "string",
            "description": "The account Id for this set of application data"
          },
          "name": {
            "type": "string",
            "description": "The name of the application"
          },
          "active": {
            "type": "boolean",
            "description": "Application is active or not. For 3rd-party application, it is always set to false until approved for use."
          },
          "description": {
            "type": "string",
            "description": "The description of this application"
          },
          "resource": {
            "type": "string",
            "description": "The resource of this application. It is required to be supplied by user for global application. However, it's not required for 3rd-party application and always set to https://mitel.io/auth/3pa-${applicationid}"
          },
          "logoUrl": {
            "type": "string",
            "description": "The Application Logo URL"
          },
          "redirectUris": {
            "type": "array",
            "description": "An array of URIs for the given application",
            "items": {
              "type": "string"
            }
          },
          "theme": {
            "type": "string",
            "description": "Theme used to render the Auth Portal"
          },
          "appLinks": {
            "type": "array",
            "description": "An array of links associated with this application. For example, Support or Legal links",
            "items": {
              "$ref": "#/components/schemas/appLink"
            }
          },
          "passwordRules": {
            "type": "array",
            "description": "Set of password rules for this application. For 3rd-party application, this is defaulted to the following: length 8-128, containing one of number, lower and upper case.",
            "items": {
              "$ref": "#/components/schemas/passwordRule"
            }
          },
          "requiredAttributes": {
            "type": "array",
            "description": "An array of user attributes required for the users of this application other than name or email.",
            "items": {
              "type": "string"
            }
          },
          "optionalAttributes": {
            "type": "array",
            "description": "An array of user attributes that are optional for the users of this application other than name or email.",
            "items": {
              "type": "string"
            }
          },
          "supportedCountries": {
            "type": "array",
            "description": "An array of supported countries in ISO 3166-1 alpha-2 format for this application",
            "items": {
              "type": "string"
            }
          },
          "providers": {
            "type": "array",
            "description": "An array of sso providers based on the requesting profile",
            "items": {
              "$ref": "#/components/schemas/ssoProviderRequest"
            }
          },
          "rules": {
            "type": "object",
            "properties": {
              "enforceRedirectUris": {
                "type": "boolean",
                "description": "Indicates whether this application will enforce redirect URI. This field is defaulted to true for 3rd-party application."
              }
            }
          }
        }
      },
      "applicationPutRequest": {
        "type": "object",
