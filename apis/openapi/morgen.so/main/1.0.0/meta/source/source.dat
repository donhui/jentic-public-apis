    "/integrations/{serviceName}/auth": {
      "get": {
        "operationId": "startOAuth",
        "summary": "Begin OAuth authentication",
        "tags": [
          "Integrations"
        ],
        "parameters": [
          {
            "name": "serviceName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to OAuth provider"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "200": {
            "description": "Successful operation"
          }
        },
        "description": "Begin OAuth authentication"
      }
    },
    "/integrations/{serviceName}": {
      "delete": {
        "operationId": "disconnectIntegration",
