{
  "openapi": "3.0.3",
  "info": {
    "title": "Qigu Open API Documentation",
    "description": "This document describes the differents endpoints you can use with the **Company Authentification Token** (provided by Qigu Admin).<br/>If you provide a **webhook url** in  Qigu Admin, our API will call yours when specific events happens.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api2.qigu.app/api/documentation/yaml"
  },
  "servers": [
    {
      "url": "https://api2.qigu.app/v1/",
      "description": "Server url"
    }
  ],
  "tags": [
    {
      "name": "countries",
      "description": "List countries"
    },
    {
      "name": "companies",
      "description": "Manage your clients"
    },
    {
      "name": "files",
      "description": "Upload pictures"
    },
    {
      "name": "journeys",
      "description": "Manage your distributions"
    },
    {
      "name": "groups",
      "description": "Manage your groups"
    },
    {
      "name": "languages",
      "description": "List languages"
    },
    {
      "name": "participants",
      "description": "Manage your participants"
    },
    {
      "name": "programs",
      "description": "Manage your programs"
    },
    {
      "name": "users",
      "description": "List your users"
    }
  ],
  "paths": {
    "/countries": {
      "get": {
        "operationId": "listCountries",
        "tags": [
          "countries"
        ],
        "summary": "Returns the list of the countries",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": -1,
            "description": "Pagination Limit (20 by default). Set -1, if you want to get all the countries"
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 0,
            "description": "Pagination Offset (0 by default)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/ListMeta"
                    },
                    "links": {
                      "type": "string",
                      "nullable": true,
                      "description": "It always equals null",
                      "default": null
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Country"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/languages": {
      "get": {
        "operationId": "listLanguages",
        "tags": [
          "languages"
        ],
        "summary": "Returns the list of the languages",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": -1,
            "description": "Pagination Limit (20 by default). Set -1, if you want to get all the languages"
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 0,
            "description": "Pagination Offset (0 by default)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/ListMeta"
                    },
                    "links": {
                      "type": "string",
                      "nullable": true,
                      "description": "It always equals null",
                      "default": null
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Language"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/companies": {
      "get": {
        "operationId": "listCompanies",
        "tags": [
          "companies"
        ],
        "summary": "Returns the list of your clients",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 20,
            "description": "Pagination Limit (20 by default). Set -1, if you want to get all the companies"
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 0,
            "description": "Pagination Offset (0 by default)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/ListMeta"
                    },
                    "links": {
                      "type": "string",
                      "nullable": true,
                      "description": "It always equals null",
                      "default": null
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Company"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCompany",
        "tags": [
          "companies"
        ],
        "summary": "Creates a new client",
        "parameters": [
          {
            "in": "query",
            "name": "sendNewPasswordEmail",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "default": 0,
            "description": "If you add a new user and you want that this user receive a create password email, you must set this property to 1"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/Company"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Company"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/companies/{id}": {
      "put": {
        "operationId": "updateCompany",
        "tags": [
          "companies"
        ],
        "summary": "Updates an existing client",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Client ID"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "required": [
                      "type",
                      "attributes",
                      "relationships"
                    ],
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "Company Id",
                        "example": 0,
                        "readOnly": true
                      },
                      "type": {
                        "type": "string",
                        "description": "Type of the object",
                        "default": "companies"
                      },
                      "attributes": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "description": "Client Name",
                            "example": "Qigu SAS"
                          },
                          "colors": {
                            "type": "object",
                            "properties": {
                              "firstGradient": {
                                "type": "string",
                                "description": "First gradient color of the companie",
                                "example": "9c1543"
                              },
                              "secondGradient": {
                                "type": "string",
                                "description": "Second gradient color of the companie",
                                "example": "700a2c"
                              }
                            }
                          },
                          "tlds": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "description": "Client Tlds (for invitation portal)",
                            "example": [
                              "qigu.app",
                              "qigu.com"
                            ]
                          },
                          "icon": {
                            "$ref": "#/components/schemas/Picture"
                          },
                          "logo": {
                            "$ref": "#/components/schemas/Picture"
                          },
                          "allowVideoConferenceRoom": {
                            "type": "boolean",
                            "description": "Activate video-conference buttons",
                            "example": true
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Company"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/programs": {
      "get": {
        "operationId": "listPrograms",
        "tags": [
          "programs"
        ],
        "summary": "Returns the list of your programs",
        "parameters": [
          {
            "in": "query",
            "name": "companies",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "description": "You can filter the list by company id"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 20,
            "description": "Pagination Limit (20 by default). Set -1, if you want to get all the programs"
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 0,
            "description": "Pagination Offset (0 by default)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/ListMeta"
                    },
                    "links": {
                      "type": "string",
                      "nullable": true,
                      "description": "It always equals null",
                      "default": null
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Program"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/journeys": {
      "get": {
        "operationId": "listJourneys",
        "tags": [
          "journeys"
        ],
        "summary": "Returns the list of your distributions",
        "parameters": [
          {
            "in": "query",
            "name": "programs",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "description": "You can filter the list by program id"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 20,
            "description": "Pagination Limit (20 by default). Set -1, if you want to get all the journeys"
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 0,
            "description": "Pagination Offset (0 by default)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/ListMeta"
                    },
                    "links": {
                      "type": "string",
                      "nullable": true,
                      "description": "It always equals null",
                      "default": null
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Journey"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createJourney",
        "tags": [
          "journeys"
        ],
        "summary": "Creates a new journey",
        "description": "### Journey Stages\nYou have two options:\n\n1. The API automatically calculates the dates of each stages.\n     * send the date of the first day of the journey in `data.attributes.dates.start` without the relationships `journeyStages` (`data.relationships.journeyStages`).\n2. You choose the dates of each stages yourself\n     * send the relationships `data.relationships.journeyStages` with their dates as in the json example\n\n---\n### Facilitators\n\nFor the relationships `facilitators` and `mainFacilitator`, you have 2 options :\n\n1. Send the user id\n```\n   {\n       \"type\":\"users\",\n       \"id\": 0\n   }\n```\n2. Send the user email/firstname/lastname\n```\n    {\n        \"type\":\"users\",\n        \"attributes\": {\n            \"firstname\":\"Eric\",\n            \"lastname\":\"Dupont\",\n            \"email\":\"eric@dupont.fr\"\n        }\n    }\n```\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "required": [
                      "type",
                      "attributes",
                      "relationships"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "description": "Type of the object",
                        "default": "journeys"
                      },
                      "attributes": {
                        "type": "object",
                        "required": [
                          "displayName"
                        ],
                        "properties": {
                          "displayName": {
                            "type": "string",
                            "description": "Distribution Name",
                            "example": "Distribution Name"
                          },
                          "description": {
                            "type": "string",
                            "description": "Distribution City",
                            "example": "Distribution City"
                          },
                          "status": {
                            "type": "object",
                            "properties": {
                              "value": {
                                "type": "integer",
                                "description": "Status name - 1= Confirmed, 0= Unconfirmed",
                                "example": 1
                              }
                            }
                          },
                          "hideDates": {
                            "type": "boolean",
                            "default": false,
                            "description": "Do not display stage dates to participants"
                          }
                        }
                      },
                      "relationships": {
                        "type": "object",
                        "required": [
                          "program",
                          "language",
                          "mainFacilitator",
                          "journeyStages"
                        ],
                        "properties": {
                          "program": {
                            "type": "object",
                            "required": [
                              "data"
                            ],
                            "properties": {
                              "data": {
                                "type": "object",
                                "required": [
                                  "id",
                                  "type"
                                ],
                                "properties": {
                                  "id": {
                                    "type": "integer",
                                    "description": "Program Id",
                                    "example": 0
                                  },
                                  "type": {
                                    "type": "string",
                                    "description": "Type of the object",
                                    "default": "programs"
                                  }
                                }
                              }
                            }
                          },
                          "language": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "object",
                                "required": [
                                  "id",
                                  "type"
                                ],
                                "properties": {
                                  "id": {
                                    "type": "integer",
                                    "description": "Language Id",
                                    "example": 47
                                  },
                                  "type": {
                                    "type": "string",
                                    "description": "Type of the object",
                                    "default": "languages"
                                  }
                                }
                              }
                            }
                          },
                          "mainFacilitator": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "object",
                                "required": [
                                  "id",
                                  "type"
                                ],
                                "oneOf": [
                                  {
                                    "$ref": "#/definitions/UserWithAttribute"
                                  },
                                  {
                                    "$ref": "#/definitions/UserRelationship"
                                  }
                                ]
                              }
                            }
                          },
                          "country": {
                            "type": "object",
                            "nullable": true,
                            "properties": {
                              "data": {
                                "type": "object",
                                "required": [
                                  "id",
                                  "type"
                                ],
                                "properties": {
                                  "id": {
                                    "type": "integer",
                                    "description": "Country Id",
                                    "example": 67
                                  },
                                  "type": {
                                    "type": "string",
                                    "description": "Type of the object",
                                    "default": "countries"
                                  }
                                }
                              }
                            }
                          },
                          "facilitators": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "oneOf": [
                                    {
                                      "$ref": "#/definitions/UserWithAttribute"
                                    },
                                    {
                                      "$ref": "#/definitions/UserRelationship"
                                    }
                                  ]
                                }
                              }
                            }
                          },
                          "journeyStages": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "array",
                                "items": {
                                  "$ref": "#/components/schemas/JourneyStage"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Journey"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/journeys/{id}": {
      "put": {
        "operationId": "updateJourney",
        "tags": [
          "journeys"
        ],
        "summary": "Updates a journey",
        "description": "### Facilitators\n\nFor the relationships `facilitators` and `mainFacilitator`, you have 2 options :\n\n1. Send the user id\n```\n   {\n       \"type\":\"users\",\n       \"id\": 0\n   }\n```\n2. Send the user email/firstname/lastname\n```\n    {\n        \"type\":\"users\",\n        \"attributes\": {\n            \"firstname\":\"Eric\",\n            \"lastname\":\"Dupont\",\n            \"email\":\"eric@dupont.fr\"\n        }\n    }\n```\n",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Journey ID"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "object",
                    "required": [
                      "type",
                      "attributes",
                      "relationships"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "description": "Type of the object",
                        "default": "journeys"
                      },
                      "attributes": {
                        "type": "object",
                        "required": [
                          "displayName"
                        ],
                        "properties": {
                          "displayName": {
                            "type": "string",
                            "description": "Distribution Name",
                            "example": "Distribution Name"
                          },
                          "description": {
                            "type": "string",
                            "description": "Distribution City",
                            "example": "Distribution City"
                          },
                          "status": {
                            "type": "object",
                            "properties": {
                              "value": {
                                "type": "integer",
                                "description": "Status name - 1= Confirmed, 0= Unconfirmed",
                                "example": 1
                              }
                            }
                          },
                          "hideDates": {
                            "type": "boolean",
                            "default": false,
                            "description": "Do not display stage dates to participants"
                          }
                        }
                      },
                      "relationships": {
                        "type": "object",
                        "required": [
                          "program",
                          "language",
                          "mainFacilitator",
                          "journeyStages"
                        ],
                        "properties": {
                          "language": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "object",
                                "required": [
                                  "id",
                                  "type"
                                ],
                                "properties": {
                                  "id": {
                                    "type": "integer",
                                    "description": "Language Id",
                                    "example": 47
                                  },
                                  "type": {
                                    "type": "string",
                                    "description": "Type of the object",
                                    "default": "languages"
                                  }
                                }
                              }
                            }
                          },
                          "mainFacilitator": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "object",
                                "required": [
                                  "id",
                                  "type"
                                ],
                                "oneOf": [
                                  {
                                    "$ref": "#/definitions/UserWithAttribute"
                                  },
                                  {
                                    "$ref": "#/definitions/UserRelationship"
                                  }
                                ]
                              }
                            }
                          },
                          "country": {
                            "type": "object",
                            "nullable": true,
                            "properties": {
                              "data": {
                                "type": "object",
                                "required": [
                                  "id",
                                  "type"
                                ],
                                "properties": {
                                  "id": {
                                    "type": "integer",
                                    "description": "Country Id",
                                    "example": 67
                                  },
                                  "type": {
                                    "type": "string",
                                    "description": "Type of the object",
                                    "default": "countries"
                                  }
                                }
                              }
                            }
                          },
                          "facilitators": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "id": {
                                      "type": "integer",
                                      "description": "Other facilitator Id",
                                      "example": 0
                                    },
                                    "type": {
                                      "type": "string",
                                      "description": "Type of the object",
                                      "default": "users"
                                    }
                                  }
                                }
                              }
                            }
                          },
                          "journeyStages": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "array",
                                "items": {
                                  "$ref": "#/components/schemas/JourneyStage"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Journey"
