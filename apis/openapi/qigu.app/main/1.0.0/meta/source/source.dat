    },
    "/journeys/{id}/stats": {
      "get": {
        "operationId": "getJourneyStats",
        "tags": [
          "journeys"
        ],
        "summary": "Returns statistics of your distribution",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Journey ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Journey"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/journeys/{id}/relationships/participants": {
      "post": {
        "operationId": "addParticipants",
        "tags": [
          "participants"
        ],
        "summary": "Add participants in a journey",
        "description": "When you add a participant, you can specify the company in which the user must be linked.<br/>If you don't provide it, it will be linked to the journey's program's company (if it is a new user) or keep its existing company (if the user already exists on the platform)",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Journey ID"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "User ID",
                          "example": 1,
                          "readOnly": true
                        },
                        "type": {
                          "type": "string",
                          "description": "Type of the object",
                          "default": "users"
                        },
                        "attributes": {
                          "type": "object",
                          "properties": {
                            "firstname": {
                              "type": "string",
                              "description": "User firstname",
                              "example": "Eric"
                            },
                            "lastname": {
                              "type": "string",
                              "description": "User lastname",
                              "example": "Dupont"
                            },
                            "email": {
                              "type": "string",
                              "description": "User email",
                              "example": "eric.dupont@qigu.app"
                            }
                          }
                        },
                        "relationships": {
                          "type": "object",
                          "properties": {
                            "company": {
                              "type": "object",
                              "properties": {
                                "data": {
                                  "type": "object",
                                  "properties": {
                                    "id": {
                                      "type": "integer",
                                      "description": "Company Id",
                                      "example": 1
                                    },
                                    "type": {
                                      "type": "string",
                                      "description": "Type of the object",
                                      "default": "companies"
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "No content"
          }
        }
      },
      "delete": {
        "operationId": "removeParticipants",
        "tags": [
          "participants"
        ],
        "summary": "Remove participants in a journey",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Journey ID"
          },
          {
            "in": "query",
            "name": "forceDelete",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "description": "If it equals 1, the participant will be deleted from the journey. If it is missing or equals 0, it will be archived",
            "example": 0
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "oneOf": [
                        {
                          "type": "object",
                          "required": [
                            "type",
                            "id"
                          ],
                          "properties": {
                            "id": {
                              "type": "integer",
                              "description": "User Id",
                              "example": 0
                            },
                            "type": {
                              "type": "string",
                              "description": "Type of the object",
                              "default": "users"
                            }
                          }
                        },
                        {
                          "type": "object",
                          "required": [
                            "type",
                            "attributes"
                          ],
                          "properties": {
                            "type": {
                              "type": "string",
                              "description": "Type of the object",
                              "default": "users"
                            },
                            "attributes": {
                              "type": "object",
                              "required": [
                                "email"
                              ],
                              "properties": {
                                "email": {
                                  "type": "string",
                                  "description": "User Email",
                                  "example": "eric.dupont@qigu.app"
                                }
                              }
                            }
                          }
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "No content"
          }
        }
      }
    },
    "/groups": {
      "get": {
        "operationId": "listGroups",
        "tags": [
          "groups"
        ],
        "summary": "Returns the list of your groups",
        "parameters": [
          {
            "in": "query",
            "name": "programs",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "description": "You can filter the list by program id"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 20,
            "description": "Pagination Limit (20 by default). Set -1, if you want to get all the groups"
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 0,
            "description": "Pagination Offset (0 by default)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/ListMeta"
                    },
                    "links": {
                      "type": "string",
                      "nullable": true,
                      "description": "It always equals null",
                      "default": null
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Group"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/files": {
      "post": {
        "operationId": "uploadFiles",
        "tags": [
          "files"
        ],
        "summary": "Upload files",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "file"
                ],
                "properties": {
                  "type": {
                    "type": "integer",
                    "default": 5,
                    "description": "Type of upload. For now, you can only pass the type 5 (company picture)"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Picture to upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "files"
                        },
                        "attributes": {
                          "type": "object",
                          "properties": {
                            "file": {
                              "type": "object",
                              "$ref": "#/components/schemas/Picture"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "operationId": "listUsers",
        "tags": [
          "users"
        ],
        "summary": "Returns the list of your users",
        "parameters": [
          {
            "in": "query",
            "name": "activeRoles",
            "schema": {
              "type": "integer"
            },
            "example": 5,
            "required": false,
            "description": "You can filter user by roles. 2 = Consultant. 3 = Admin. 4 = Analyst. 5 = Facilitator. 6 = Participant. 7 = Coach. 8 = Support. 9 = Manager. 10 = Creator"
          },
          {
            "in": "query",
            "name": "keyword",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "You can filter user by email, firstname, lastname"
          },
          {
            "in": "query",
            "name": "companies",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "description": "You can filter user by company id"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 20,
            "description": "Pagination Limit (20 by default). Set -1, if you want to get all the users"
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "type": "integer"
            },
            "required": false,
            "example": 0,
            "description": "Pagination Offset (0 by default)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/ListMeta"
                    },
                    "links": {
                      "type": "string",
                      "nullable": true,
                      "description": "It always equals null",
                      "default": null
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/User"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Company": {
        "type": "object",
        "required": [
          "type",
          "attributes",
          "relationships"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Company Id",
            "example": 1,
            "readOnly": true
          },
          "type": {
            "type": "string",
            "description": "Type of the object",
            "default": "companies"
          },
          "attributes": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Client Name",
                "example": "Qigu SAS"
              },
              "colors": {
                "type": "object",
                "properties": {
                  "firstGradient": {
                    "type": "string",
                    "description": "First gradient color of the companie",
                    "example": "9c1543"
                  },
                  "secondGradient": {
                    "type": "string",
                    "description": "Second gradient color of the companie",
                    "example": "700a2c"
                  }
                }
              },
              "tlds": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Client Tlds (for invitation portal)",
                "example": [
                  "qigu.app",
                  "qigu.com"
                ]
              },
              "icon": {
                "$ref": "#/components/schemas/Picture"
              },
              "logo": {
                "$ref": "#/components/schemas/Picture"
              },
              "allowVideoConferenceRoom": {
                "type": "boolean",
                "description": "Activate video-conference buttons",
                "example": true
              }
            }
          },
          "relationships": {
            "type": "object",
            "required": [
              "clientPrimary"
            ],
            "properties": {
              "clientPrimary": {
                "type": "object",
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      },
      "Country": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Country ID",
            "example": 67
          },
          "type": {
            "type": "string",
            "description": "Type of the object",
            "default": "countries"
          },
          "attributes": {
            "type": "object",
            "readOnly": true,
            "properties": {
              "code": {
                "type": "string",
                "description": "Country Code",
                "example": "fr"
              },
              "name": {
                "type": "string",
                "description": "Country Name",
                "example": "France"
              }
            }
          },
          "relationships": {
            "type": "object",
            "readOnly": true
          }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Group ID",
            "example": 1,
            "readOnly": true
          },
          "type": {
            "type": "string",
            "description": "Type of the object",
            "default": "groups"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Group name",
                "example": "HR"
              },
              "displayName": {
                "type": "string",
                "description": "Group Display name",
                "example": "Human Resource"
              },
              "selfRegistrable": {
                "type": "boolean",
                "description": "Allow participant to self registrate"
              }
            }
          },
          "relationships": {
            "type": "object",
            "properties": {
              "program": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "required": [
                      "id",
                      "type"
                    ],
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "Program Id",
                        "example": 1
                      },
                      "type": {
                        "type": "string",
                        "description": "Type of the object",
                        "default": "programs"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Journey": {
        "type": "object",
        "required": [
          "type",
          "attributes",
          "relationships"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Journey Id",
            "example": 1,
            "readOnly": true
          },
          "type": {
            "type": "string",
            "description": "Type of the object",
            "default": "journeys"
          },
          "attributes": {
            "type": "object",
            "required": [
              "displayName"
            ],
            "properties": {
              "displayName": {
                "type": "string",
                "description": "Distribution Name",
                "example": "Distribution Name"
              },
              "description": {
                "type": "string",
                "description": "Distribution City",
                "example": "Distribution City"
              },
              "status": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "integer",
                    "description": "Status name - 1= Confirmed, 0= Unconfirmed",
                    "example": 1
                  }
                }
              },
              "stats": {
                "type": "object",
                "properties": {
                  "participants": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "journeyKey": {
                          "type": "string"
                        },
                        "programKey": {
                          "type": "string"
                        },
                        "userKey": {
                          "type": "string"
                        },
                        "firstActivityInTheJourney": {
                          "type": "string",
                          "description": "Date formatted in ISO string"
                        },
                        "lastActivityInTheJourney": {
                          "type": "string",
                          "description": "Date formatted in ISO string"
                        },
                        "contentProgress": {
                          "type": "integer"
                        },
                        "completedAt": {
                          "type": "string",
                          "description": "Date formatted in ISO string"
                        },
                        "globalTimeSpent": {
                          "type": "integer",
                          "description": "In minutes"
                        },
                        "globalScores": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string"
                              },
                              "value": {
                                "type": "integer"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "hideDates": {
                "type": "boolean",
                "default": false,
                "description": "Do not display stage dates to participants"
              }
            }
          },
          "relationships": {
            "type": "object",
            "required": [
              "program",
              "language",
              "mainFacilitator",
              "journeyStages"
            ],
            "properties": {
              "program": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "required": [
                      "id",
                      "type"
                    ],
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "Program Id",
                        "example": 1
                      },
                      "type": {
                        "type": "string",
                        "description": "Type of the object",
                        "default": "programs"
                      }
                    }
                  }
                }
              },
              "language": {
                "type": "object",
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/Language"
                  }
                }
              },
              "mainFacilitator": {
                "type": "object",
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              },
              "country": {
                "type": "object",
                "nullable": true,
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/Country"
                  }
                }
              },
              "facilitators": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              },
              "journeyStages": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/JourneyStage"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "JourneyStage": {
        "type": "object",
        "required": [
          "type",
          "attributes",
          "relationships"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Journey Stage Id",
            "example": 1,
            "readOnly": true
          },
          "type": {
            "type": "string",
            "description": "Type of the object",
            "default": "journeyStages"
          },
          "attributes": {
            "type": "object",
            "required": [
              "dates"
            ],
            "properties": {
              "dates": {
                "type": "object",
                "required": [
                  "start",
                  "end"
                ],
                "properties": {
                  "start": {
                    "type": "string",
                    "description": "Start Date",
                    "example": "2020-12-12"
                  },
                  "end": {
                    "type": "string",
                    "description": "End Date",
                    "example": "2025-12-12"
                  }
                }
              }
            }
          },
          "relationships": {
            "type": "object",
            "required": [
              "programStage"
            ],
            "properties": {
              "programStage": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "required": [
                      "id",
                      "type"
                    ],
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "Program Stage Id",
                        "example": 0
                      },
                      "type": {
                        "type": "string",
                        "description": "Type of the object",
                        "default": "programStages"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Language": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Language ID",
            "example": 47
          },
          "type": {
            "type": "string",
            "description": "Type of the object",
            "default": "languages"
          },
          "attributes": {
            "type": "object",
            "readOnly": true,
            "properties": {
              "code": {
                "type": "string",
                "description": "Language Code",
                "example": "fr",
                "readOnly": true
              },
              "name": {
                "type": "string",
                "description": "Language Name",
                "example": "French",
                "readOnly": true
              }
            }
          },
          "relationships": {
            "type": "object",
            "readOnly": true
          }
        }
      },
      "ListMeta": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Total number of data"
          },
          "offset": {
            "type": "integer",
            "description": "Current result offset"
          },
          "limit": {
            "type": "integer",
            "description": "Current result limit"
          }
        }
      },
      "Participation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Participation ID",
            "example": 0,
            "readOnly": true
          },
          "type": {
            "type": "string",
            "description": "Type of the object",
            "default": "participations"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "archived": {
                "type": "boolean",
                "description": "Is the participant archived in the journey ?",
                "example": false
              }
            }
          },
          "relationships": {
            "type": "object",
            "properties": {
              "user": {
                "type": "object",
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              },
              "team": {
                "type": "object",
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/Team"
                  }
                }
              },
              "journey": {
                "type": "object",
                "properties": {
                  "data": {
                    "$ref": "#/components/schemas/Journey"
                  }
                }
              }
            }
          }
        }
      },
      "Picture": {
        "type": "object",
        "properties": {
          "large": {
            "type": "string",
            "description": "Large Picture",
            "example": "https://qigu.app/wp-content/uploads/2020/08/Qigu-Logo.png",
            "nullable": true,
            "readOnly": true
          },
          "thumbnail": {
            "type": "string",
            "description": "Thumbnail Picture",
            "example": "https://qigu.app/wp-content/uploads/2020/08/Qigu-Logo-300x124.png",
            "nullable": true,
            "readOnly": true
          },
          "filename": {
            "type": "string",
            "description": "Picture Filename (uploaded with the POST /files endpoint)",
            "example": "Qigu-Logo.png",
            "nullable": true
          }
        }
      },
      "Program": {
        "type": "object",
        "required": [
          "type",
          "attributes",
          "relationships"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Program Id",
            "example": 0,
            "readOnly": true
          },
          "type": {
            "type": "string",
            "description": "Type of the object",
            "default": "programs"
          },
          "attributes": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Program Name",
                "example": "Leadership"
              },
              "description": {
                "type": "string",
                "description": "Program Description",
                "nullable": true,
                "example": "Leadership is both a research area, and a practical skill encompassing the ability of an individual, group or organization to lead, influence or guide other individuals, teams, or entire organizations. Often viewed as a contested term, specialist literature debates various viewpoints, contrasting Eastern and Western approaches to leadership, and also (within the West) North American versus European approaches."
              },
              "design": {
