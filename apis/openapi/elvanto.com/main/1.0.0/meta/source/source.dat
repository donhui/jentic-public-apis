{
  "openapi": "3.0.3",
  "info": {
    "title": "Elvanto People API",
    "version": "1.0.0",
    "description": "API for managing people records in the Elvanto church management platform. Supports listing, searching, creating, editing, and retrieving people.",
    "x-jentic-source-url": "https://www.elvanto.com/api/"
  },
  "servers": [
    {
      "url": "https://api.elvanto.com/v1",
      "description": "Elvanto API Server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    },
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "People",
      "description": "Operations for managing people records"
    }
  ],
  "paths": {
    "/people/getAll.json": {
      "post": {
        "operationId": "getAllPeople",
        "summary": "Retrieve a list of all people",
        "tags": ["People"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetAllPeopleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with paginated people list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeopleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid page number or page size",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/people/getInfo.json": {
      "post": {
        "operationId": "getPersonInfo",
        "summary": "Find a person by their ID",
        "tags": ["People"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetPersonInfoRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with person details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "No person ID provided or invalid person ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/people/search.json": {
      "post": {
        "operationId": "searchPeople",
        "summary": "Search for people matching criteria",
        "tags": ["People"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchPeopleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with matching people",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeopleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid search parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/people/create.json": {
      "post": {
        "operationId": "createPerson",
        "summary": "Add a new person",
        "tags": ["People"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePersonRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Person created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonMutationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request data or category ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/people/edit.json": {
      "post": {
        "operationId": "editPerson",
        "summary": "Modify an existing person",
        "tags": ["People"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditPersonRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Person updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonMutationResponse"
                }
              }
            }
          },
          "400": {
            "description": "No person ID provided or invalid category ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using API key"
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://api.elvanto.com/oauth",
            "tokenUrl": "https://api.elvanto.com/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "GetAllPeopleRequest": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Results page to retrieve",
            "default": 1
          },
          "page_size": {
            "type": "integer",
            "description": "Records per page (range: 10-1000)",
            "default": 1000,
            "minimum": 10,
            "maximum": 1000
          },
          "category_id": {
            "type": "string",
            "description": "Filter by people category ID"
          },
          "suspended": {
            "type": "string",
            "description": "Filter suspended people",
            "enum": ["yes", "no"]
          },
          "contact": {
            "type": "string",
            "description": "Filter contacts",
            "enum": ["yes", "no"]
          },
          "archived": {
            "type": "string",
            "description": "Filter archived people",
            "enum": ["yes", "no"]
          },
          "fields": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional custom fields to retrieve"
          }
        }
      },
      "GetPersonInfoRequest": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "The ID of the person"
          },
          "fields": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional fields to retrieve"
          }
        }
      },
      "SearchPeopleRequest": {
        "type": "object",
        "required": ["search"],
        "properties": {
          "page": {
            "type": "integer",
            "default": 1
          },
          "page_size": {
            "type": "integer",
            "default": 1000,
            "minimum": 10,
            "maximum": 1000
          },
          "search": {
            "type": "object",
            "description": "Search criteria with field-keyword pairs",
            "properties": {
              "firstname": { "type": "string" },
              "lastname": { "type": "string" },
              "preferred_name": { "type": "string" },
              "email": { "type": "string" },
              "phone": { "type": "string" },
              "mobile": { "type": "string" },
              "gender": { "type": "string", "enum": ["Male", "Female"] },
              "archived": { "type": "string", "enum": ["Yes", "No"] },
              "contact": { "type": "string", "enum": ["Yes", "No"] },
              "volunteer": { "type": "string", "enum": ["Yes", "No"] },
              "birthday": { "type": "string", "format": "date" },
              "anniversary": { "type": "string", "format": "date" },
              "marital_status": { "type": "string", "enum": ["Single", "Engaged", "Married", "Widowed", "Divorced", "Separated", "Defacto"] },
              "date_added": { "type": "string", "format": "date-time" },
              "date_modified": { "type": "string", "format": "date-time" },
              "category_id": { "type": "string" }
            }
          },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "CreatePersonRequest": {
        "type": "object",
        "required": ["firstname", "lastname"],
        "properties": {
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "preferred_name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "mobile": { "type": "string" },
          "category_id": { "type": "string" },
          "archived": { "type": "string", "enum": ["yes", "no"], "default": "no" },
          "contact": { "type": "string", "enum": ["yes", "no"], "default": "no" },
          "volunteer": { "type": "string", "enum": ["yes", "no"], "default": "no" },
          "status": { "type": "string", "enum": ["active", "suspended"], "default": "active" },
          "username": { "type": "string" },
          "password": { "type": "string" },
          "family_id": { "type": "string", "description": "Existing family ID or 'new' to create family" },
          "family_relationship": {
            "type": "string",
            "enum": ["Primary Contact", "Spouse", "Partner", "Child", "Sibling", "Grandfather", "Grandmother", "Other"]
          },
          "fields": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Extra custom fields (gender, birthday, anniversary, marital_status, access_permissions)"
          }
        }
      },
      "EditPersonRequest": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "description": "The person's unique identifier" },
          "firstname": { "type": "string" },
          "preferred_name": { "type": "string" },
          "lastname": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "mobile": { "type": "string" },
          "category_id": { "type": "string" },
          "archived": { "type": "string", "enum": ["yes", "no"] },
          "contact": { "type": "string", "enum": ["yes", "no"] },
          "volunteer": { "type": "string", "enum": ["yes", "no"] },
          "status": { "type": "string", "enum": ["active", "suspended"] },
          "username": { "type": "string" },
          "password": { "type": "string" },
          "family_id": { "type": "string" },
          "family_relationship": {
            "type": "string",
            "enum": ["Primary Contact", "Spouse", "Partner", "Child", "Sibling", "Grandfather", "Grandmother", "Other"]
          },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "date_added": { "type": "string", "format": "date-time" },
          "date_modified": { "type": "string", "format": "date-time" },
          "category_id": { "type": "string" },
          "firstname": { "type": "string" },
          "preferred_name": { "type": "string" },
          "middle_name": { "type": "string" },
          "lastname": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "mobile": { "type": "string" },
          "admin": { "type": "integer", "enum": [0, 1] },
          "archived": { "type": "integer", "enum": [0, 1] },
          "contact": { "type": "integer", "enum": [0, 1] },
          "volunteer": { "type": "integer", "enum": [0, 1] },
          "status": { "type": "string" },
          "username": { "type": "string" },
          "last_login": { "type": "string", "format": "date-time" },
          "country": { "type": "string" },
          "timezone": { "type": "string" },
          "picture": { "type": "string", "format": "uri" },
          "family_id": { "type": "integer" },
          "family_relationship": { "type": "string" },
          "birthday": { "type": "string", "format": "date" },
          "gender": { "type": "string" },
          "locations": {
            "type": "object",
            "properties": {
              "location": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "PeopleListResponse": {
        "type": "object",
        "properties": {
          "generated_in": { "type": "string" },
          "status": { "type": "string" },
          "people": {
            "type": "object",
            "properties": {
              "on_this_page": { "type": "integer" },
              "page": { "type": "integer" },
              "per_page": { "type": "integer" },
              "total": { "type": "integer" },
              "person": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          }
        }
      },
      "PersonDetailResponse": {
        "type": "object",
        "properties": {
          "generated_in": { "type": "string" },
          "status": { "type": "string" },
          "person": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          }
        }
      },
      "PersonMutationResponse": {
        "type": "object",
        "properties": {
          "generated_in": { "type": "string" },
          "status": { "type": "string" },
          "person": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "family_id": { "type": "integer" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "generated_in": { "type": "string" },
          "status": { "type": "string" },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "integer" },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  }
}