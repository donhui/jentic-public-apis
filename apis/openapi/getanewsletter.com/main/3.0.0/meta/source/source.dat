{
  "openapi": "3.0.3",
  "info": {
    "title": "Get a Newsletter API",
    "version": "3.0.0",
    "description": "Get a Newsletter allows you to create email newsletters, landing pages, surveys, and more. This API provides access to contacts, lists, subscribers, senders, and reports.",
    "x-jentic-source-url": "https://api.getanewsletter.com/v3/docs"
  },
  "servers": [
    {
      "url": "https://api.getanewsletter.com/v3"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    { "name": "Contacts", "description": "Manage contacts" },
    { "name": "Lists", "description": "Manage mailing lists" },
    { "name": "Subscribers", "description": "Manage list subscribers" },
    { "name": "Senders", "description": "Manage email senders" },
    { "name": "Reports", "description": "View campaign reports" }
  ],
  "paths": {
    "/contacts/": {
      "get": {
        "operationId": "listContacts",
        "summary": "List all contacts",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "ordering", "in": "query", "schema": { "type": "string" } },
          { "name": "search_email", "in": "query", "schema": { "type": "string" } },
          { "name": "search_name", "in": "query", "schema": { "type": "string" } },
          { "name": "lists", "in": "query", "schema": { "type": "string" } },
          { "name": "active", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedContactList"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createContact",
        "summary": "Create a new contact",
        "tags": ["Contacts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contact created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/contacts/{email}/": {
      "put": {
        "operationId": "updateContact",
        "summary": "Update or create a contact (upsert)",
        "tags": ["Contacts"],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "email" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Contact" }
              }
            }
          },
          "201": {
            "description": "Contact created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Contact" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "patch": {
        "operationId": "patchContact",
        "summary": "Partially update a contact",
        "tags": ["Contacts"],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "email" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Contact" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteContact",
        "summary": "Delete a contact",
        "tags": ["Contacts"],
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "email" }
          }
        ],
        "responses": {
          "204": { "description": "Contact deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/lists/": {
      "get": {
        "operationId": "listLists",
        "summary": "List all mailing lists",
        "tags": ["Lists"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of lists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedMailingListList"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createList",
        "summary": "Create a new mailing list",
        "tags": ["Lists"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MailingListInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "List created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailingList" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/lists/{hash}/": {
      "put": {
        "operationId": "updateList",
        "summary": "Update or create a mailing list",
        "tags": ["Lists"],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MailingListInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailingList" }
              }
            }
          },
          "201": {
            "description": "List created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailingList" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "patch": {
        "operationId": "patchList",
        "summary": "Partially update a mailing list",
        "tags": ["Lists"],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MailingListInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MailingList" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteList",
        "summary": "Delete a mailing list",
        "tags": ["Lists"],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "List deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/lists/{hash}/subscribers/": {
      "get": {
        "operationId": "listSubscribers",
        "summary": "List subscribers in a mailing list",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["email", "-email", "name", "-name", "updated", "-updated", "active", "-active"]
            }
          },
          { "name": "cancelled", "in": "query", "schema": { "type": "integer", "enum": [0, 1] } },
          { "name": "active", "in": "query", "schema": { "type": "integer", "enum": [0, 1] } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of subscribers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedSubscriberList"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createSubscriber",
        "summary": "Add a subscriber to a mailing list",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscriberInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscriber created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Subscriber" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/lists/{hash}/subscribers/{email}/": {
      "put": {
        "operationId": "updateSubscriber",
        "summary": "Update or create a subscriber",
        "tags": ["Subscribers"],
        "parameters": [
          { "name": "hash", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "email", "in": "path", "required": true, "schema": { "type": "string", "format": "email" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SubscriberInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscriber updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Subscriber" }
              }
            }
          },
          "201": {
            "description": "Subscriber created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Subscriber" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "patch": {
        "operationId": "patchSubscriber",
        "summary": "Partially update a subscriber",
        "tags": ["Subscribers"],
        "parameters": [
          { "name": "hash", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "email", "in": "path", "required": true, "schema": { "type": "string", "format": "email" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SubscriberInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscriber updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Subscriber" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteSubscriber",
        "summary": "Remove a subscriber from a list",
        "tags": ["Subscribers"],
        "parameters": [
          { "name": "hash", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "email", "in": "path", "required": true, "schema": { "type": "string", "format": "email" } }
        ],
        "responses": {
          "204": { "description": "Subscriber removed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/senders/": {
      "get": {
        "operationId": "listSenders",
        "summary": "List all senders",
        "tags": ["Senders"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "ordering", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of senders",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedSenderList"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createSender",
        "summary": "Create a new sender",
        "tags": ["Senders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SenderInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sender created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sender" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/senders/{id}/": {
      "get": {
        "operationId": "getSender",
        "summary": "Get a sender by ID",
        "tags": ["Senders"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Sender found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sender" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateSender",
        "summary": "Update a sender",
        "tags": ["Senders"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SenderInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sender updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sender" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "patch": {
        "operationId": "patchSender",
        "summary": "Partially update a sender",
        "tags": ["Senders"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SenderInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sender updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sender" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteSender",
        "summary": "Delete a sender",
        "tags": ["Senders"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Sender deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/senders/{id}/request_confirmation/": {
      "post": {
        "operationId": "requestSenderConfirmation",
        "summary": "Request sender email confirmation",
        "tags": ["Senders"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Confirmation requested" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/senders/{id}/confirm/": {
      "post": {
        "operationId": "confirmSender",
        "summary": "Confirm a sender with signature",
        "tags": ["Senders"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "signature": { "type": "string" }
                },
                "required": ["signature"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Sender confirmed" },
          "400": { "description": "Invalid signature" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reports/": {
      "get": {
        "operationId": "listReports",
        "summary": "List all campaign reports",
        "tags": ["Reports"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of reports",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedReportList"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reports/{id}/": {
      "get": {
        "operationId": "getReport",
        "summary": "Get a specific campaign report",
        "tags": ["Reports"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Report found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Report"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based auth. Format: 'Token <your_token_key>'"
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri", "readOnly": true },
          "email": { "type": "string", "format": "email" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "lists": {
            "type": "array",
            "items": { "type": "object" }
          },
          "attributes": { "type": "object" },
          "sms_number": { "type": "string" },
          "created": { "type": "string", "format": "date-time", "readOnly": true },
          "updated": { "type": "string", "format": "date-time", "readOnly": true },
          "active": { "type": "boolean", "readOnly": true }
        }
      },
      "ContactInput": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "lists": {
            "type": "array",
            "items": { "type": "object" }
          },
          "attributes": { "type": "object" },
          "sms_number": { "type": "string" }
        },
        "required": ["email"]
      },
      "PaginatedContactList": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "next": { "type": "string", "format": "uri", "nullable": true },
          "previous": { "type": "string", "format": "uri", "nullable": true },
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Contact" }
          }
        }
      },
      "MailingList": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri", "readOnly": true },
          "hash": { "type": "string", "readOnly": true },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "active_subscribers_count": { "type": "integer", "readOnly": true },
          "subscribers_count": { "type": "integer", "readOnly": true },
          "created": { "type": "string", "format": "date-time", "readOnly": true },
          "subscribers": { "type": "string", "format": "uri", "readOnly": true },
          "responders_count": { "type": "integer", "readOnly": true },
          "responders": { "type": "string", "format": "uri", "readOnly": true }
        }
      },
      "MailingListInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["name"]
      },
      "PaginatedMailingListList": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "next": { "type": "string", "format": "uri", "nullable": true },
          "previous": { "type": "string", "format": "uri", "nullable": true },
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MailingList" }
          }
        }
      },
      "Subscriber": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri", "readOnly": true },
          "contact": { "type": "string", "format": "email" },
          "cancelled": { "type": "boolean" },
          "created": { "type": "string", "format": "date-time", "readOnly": true },
          "updated": { "type": "string", "format": "date-time", "readOnly": true }
        }
      },
      "SubscriberInput": {
        "type": "object",
        "properties": {
          "contact": { "type": "string", "format": "email" },
          "cancelled": { "type": "boolean" }
        },
        "required": ["contact"]
      },
      "PaginatedSubscriberList": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "next": { "type": "string", "format": "uri", "nullable": true },
