{
  "openapi": "3.0.3",
  "info": {
    "title": "Spreadshirt Public Shop API",
    "version": "1.0",
    "description": "Spreadshirt Public Shop API for custom merchandise and print-on-demand. Access product catalogs, manage orders, and integrate custom shop functionality. API follows REST principles with support for both EU and NA regions. All requests require SprdAuth authentication with apiKey and User-Agent headers.",
    "x-jentic-source-url": "https://developer.spreadshirt.net/"
  },
  "servers": [
    {
      "url": "https://api.spreadshirt.net/api/v1",
      "description": "EU Production server"
    },
    {
      "url": "https://api.spreadshirt.com/api/v1",
      "description": "NA Production server"
    }
  ],
  "security": [
    {
      "sprdAuth": []
    }
  ],
  "tags": [
    {
      "name": "Shops",
      "description": "Shop management and information"
    },
    {
      "name": "Products",
      "description": "Product catalog and management"
    },
    {
      "name": "Baskets",
      "description": "Shopping basket operations"
    },
    {
      "name": "Orders",
      "description": "Order processing and management"
    },
    {
      "name": "Users",
      "description": "User account management"
    }
  ],
  "paths": {
    "/shops/{shop_id}": {
      "get": {
        "tags": ["Shops"],
        "summary": "Get shop information",
        "description": "Retrieve shop details and configuration",
        "operationId": "getShopById",
        "parameters": [
          {
            "name": "shop_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Shop identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            },
            "description": "Response media type"
          }
        ],
        "responses": {
          "200": {
            "description": "Shop information retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Shop"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "Shop not found"
          }
        }
      }
    },
    "/shops/{shop_id}/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List shop products",
        "description": "Retrieve products available in a shop",
        "operationId": "listShopProducts",
        "parameters": [
          {
            "name": "shop_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Shop identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product list retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "Shop not found"
          }
        }
      }
    },
    "/shops/{shop_id}/products/{product_id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product details",
        "description": "Retrieve detailed information about a specific product",
        "operationId": "getProductById",
        "parameters": [
          {
            "name": "shop_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Shop identifier"
          },
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Product identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "Product not found"
          }
        }
      }
    },
    "/baskets": {
      "post": {
        "tags": ["Baskets"],
        "summary": "Create basket",
        "description": "Create a new shopping basket",
        "operationId": "createBasket",
        "parameters": [
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BasketInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Basket created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Basket"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          }
        }
      }
    },
    "/baskets/{basket_id}": {
      "get": {
        "tags": ["Baskets"],
        "summary": "Get basket",
        "description": "Retrieve basket contents and totals",
        "operationId": "getBasketById",
        "parameters": [
          {
            "name": "basket_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Basket identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Basket retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Basket"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "Basket not found"
          }
        }
      },
      "put": {
        "tags": ["Baskets"],
        "summary": "Update basket",
        "description": "Update basket contents or properties",
        "operationId": "updateBasket",
        "parameters": [
          {
            "name": "basket_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Basket identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BasketInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Basket updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Basket"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "Basket not found"
          }
        }
      },
      "delete": {
        "tags": ["Baskets"],
        "summary": "Delete basket",
        "description": "Remove a basket",
        "operationId": "deleteBasket",
        "parameters": [
          {
            "name": "basket_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Basket identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Basket deleted successfully"
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "Basket not found"
          }
        }
      }
    },
    "/baskets/{basket_id}/checkout": {
      "post": {
        "tags": ["Orders"],
        "summary": "Checkout basket",
        "description": "Convert basket to order and initiate checkout",
        "operationId": "checkoutBasket",
        "parameters": [
          {
            "name": "basket_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Basket identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckoutRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Checkout initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "Basket not found"
          }
        }
      }
    },
    "/users/{user_id}/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "List user orders",
        "description": "Retrieve orders for a specific user",
        "operationId": "listUserOrders",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order list retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Order"
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/users/{user_id}/orders/{order_id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order details",
        "description": "Retrieve detailed information about a specific order",
        "operationId": "getOrderById",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User identifier"
          },
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Order identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/users/{user_id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get user information",
        "description": "Retrieve user account details",
        "operationId": "getUserById",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User identifier"
          },
          {
            "name": "mediaType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User information retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sprdAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "SprdAuth authentication with format: SprdAuth apiKey=\"<your-api-key>\". Also requires User-Agent header with format: <AppName>/<Version> (domain; email)"
      }
    },
    "schemas": {
      "Shop": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Shop identifier"
          },
          "name": {
            "type": "string",
            "description": "Shop name"
          },
          "description": {
            "type": "string"
          },
          "currency": {
            "type": "string",
            "description": "Shop currency code"
          },
          "locale": {
            "type": "string"
          },
          "platform": {
            "type": "string",
            "enum": ["EU", "NA"]
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "$ref": "#/components/schemas/Price"
          },
          "productType": {
            "type": "string"
          },
          "appearance": {
            "type": "string",
            "description": "Product color/appearance ID"
          },
          "size": {
            "type": "string"
          },
          "resources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "href": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Basket": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "shop": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              }
            }
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BasketItem"
            }
          },
          "price": {
            "$ref": "#/components/schemas/Price"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "BasketInput": {
        "type": "object",
        "properties": {
          "shop": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              }
            }
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "element": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": ["sprd:product", "sprd:article"]
                    }
                  }
                },
                "quantity": {
                  "type": "integer"
                },
                "size": {
                  "type": "string"
                },
                "appearance": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "BasketItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "element": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          },
          "quantity": {
            "type": "integer"
          },
          "price": {
            "$ref": "#/components/schemas/Price"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "processing", "shipped", "delivered", "cancelled"]
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          },
          "price": {
            "$ref": "#/components/schemas/Price"
          },
          "shipping": {
            "$ref": "#/components/schemas/ShippingAddress"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "product": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "quantity": {
            "type": "integer"
          },
          "price": {
            "$ref": "#/components/schemas/Price"
          }
        }
      },
      "CheckoutRequest": {
        "type": "object",
        "required": ["shipping"],
        "properties": {
          "shipping": {
            "$ref": "#/components/schemas/ShippingAddress"
          },
          "payment": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              }
            }
          }
        }
      },
      "ShippingAddress": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "street": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "zipCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "Price": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "format": "float"
          },
          "currency": {
            "type": "string"
          },
          "vatIncluded": {
            "type": "boolean"
          },
          "vat": {
            "type": "number"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
