  "components": {
    "schemas": {
      "ContactBase": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "mobile": { "type": "string" },
          "address": { "type": "string" },
          "branchId": { "type": "integer" }
        }
      },
      "Contact": {
        "allOf": [
          { "$ref": "#/components/schemas/ContactBase" },
          { "type": "object", "properties": { "id": { "type": "integer" }, "createdAt": { "type": "string", "format": "date-time" }, "updatedAt": { "type": "string", "format": "date-time" } } }
        ]
      },
      "CallLogBase": {
        "type": "object",
        "properties": {
          "contactId": { "type": "integer" },
          "userId": { "type": "integer" },
          "direction": { "type": "string" },
          "notes": { "type": "string" },
          "duration": { "type": "integer" },
          "dtsCall": { "type": "string", "format": "date-time" }
        }
      },
      "CallLog": {
        "allOf": [
          { "$ref": "#/components/schemas/CallLogBase" },
          { "type": "object", "properties": { "id": { "type": "integer" }, "createdAt": { "type": "string", "format": "date-time" } } }
        ]
      },
      "Note": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "content": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "NoteRequest": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": { "type": "string" }
        }
      },
      "ContactOrder": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "contactId": { "type": "integer" },
          "listingId": { "type": "integer" },
          "status": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ContactOrderBase": {
        "type": "object",
        "properties": {
