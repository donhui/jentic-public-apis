{
  "openapi": "3.0.3",
  "info": {
    "title": "Apex27 API",
    "version": "1.0.0",
    "description": "Apex27 is a full-featured estate agent CRM platform. The API provides access to contacts, listings, leads, viewings, offers, valuations, inspections, tenancies, tasks, webhooks, and more.",
    "x-jentic-source-url": "https://apex27.docs.apiary.io"
  },
  "servers": [
    {
      "url": "https://api.apex27.co.uk"
    }
  ],
  "paths": {
    "/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "List contacts",
        "tags": ["Contacts"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Page number"
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer", "minimum": 25, "maximum": 250 },
            "description": "Number of results per page (25-250)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of contacts",
            "headers": {
              "X-Page-Count": {
                "schema": { "type": "integer" },
                "description": "Total number of pages"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Contact" }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createContact",
        "summary": "Create a contact",
        "tags": ["Contacts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactBase" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contact created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "operationId": "getContact",
        "summary": "Retrieve a contact",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "Contact ID" }
        ],
        "responses": {
          "200": { "description": "Contact details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateContact",
        "summary": "Update a contact",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "Contact ID" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactBase" } } }
        },
        "responses": {
          "200": { "description": "Contact updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteContact",
        "summary": "Delete a contact",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "Contact ID" }
        ],
        "responses": {
          "200": { "description": "Contact deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/call-logs": {
      "post": {
        "operationId": "createCallLog",
        "summary": "Create a call log",
        "tags": ["Call Logs"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CallLogBase" } } }
        },
        "responses": {
          "201": { "description": "Call log created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CallLog" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{contactId}/call-logs": {
      "get": {
        "operationId": "listContactCallLogs",
        "summary": "List call logs for a contact",
        "tags": ["Call Logs"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "Contact ID" }
        ],
        "responses": {
          "200": { "description": "List of call logs", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CallLog" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createContactCallLog",
        "summary": "Create a call log for a contact",
        "tags": ["Call Logs"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "Contact ID" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CallLogBase" } } }
        },
        "responses": {
          "201": { "description": "Call log created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CallLog" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{contactId}/call-logs/{callLogId}": {
      "put": {
        "operationId": "updateContactCallLog",
        "summary": "Update a call log for a contact",
        "tags": ["Call Logs"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "callLogId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CallLogBase" } } } },
        "responses": {
          "200": { "description": "Call log updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteContactCallLog",
        "summary": "Delete a call log for a contact",
        "tags": ["Call Logs"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "callLogId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Call log deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{contactId}/notes": {
      "get": {
        "operationId": "listContactNotes",
        "summary": "List notes for a contact",
        "tags": ["Notes"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of notes", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Note" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createContactNote",
        "summary": "Create a note for a contact",
        "tags": ["Notes"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NoteRequest" } } } },
        "responses": {
          "201": { "description": "Note created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Note" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{contactId}/notes/{noteId}": {
      "get": {
        "operationId": "getContactNote",
        "summary": "Retrieve a contact note",
        "tags": ["Notes"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "noteId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Note details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Note" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateContactNote",
        "summary": "Update a contact note",
        "tags": ["Notes"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "noteId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NoteRequest" } } } },
        "responses": {
          "200": { "description": "Note updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Note" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteContactNote",
        "summary": "Delete a contact note",
        "tags": ["Notes"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "noteId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Note deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/client-portal/authenticate": {
      "post": {
        "operationId": "authenticateClientPortal",
        "summary": "Authenticate a client portal user",
        "tags": ["Client Portal"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["email", "password"], "properties": { "email": { "type": "string" }, "password": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Authentication successful", "content": { "application/json": { "schema": { "type": "object", "properties": { "contact": { "$ref": "#/components/schemas/Contact" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/client-portal/log-in-url": {
      "get": {
        "operationId": "getClientPortalLoginUrl",
        "summary": "Get client portal login URL",
        "tags": ["Client Portal"],
        "parameters": [
          { "name": "contactId", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Login URL", "content": { "application/json": { "schema": { "type": "object", "properties": { "url": { "type": "string" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/client-portal/sign-in-url": {
      "get": {
        "operationId": "getClientPortalSignInUrl",
        "summary": "Get client portal sign-in URL with expiry",
        "tags": ["Client Portal"],
        "parameters": [
          { "name": "contactId", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Sign-in URL with expiry", "content": { "application/json": { "schema": { "type": "object", "properties": { "url": { "type": "string" }, "dtsExpiry": { "type": "string", "format": "date-time" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contact-orders": {
      "get": {
        "operationId": "listContactOrders",
        "summary": "List contact orders",
        "tags": ["Contact Orders"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "minimum": 25, "maximum": 250 } }
        ],
        "responses": {
          "200": { "description": "List of contact orders", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ContactOrder" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createContactOrder",
        "summary": "Create a contact order",
        "tags": ["Contact Orders"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactOrderBase" } } } },
        "responses": {
          "201": { "description": "Contact order created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactOrder" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contact-orders/{id}": {
      "get": {
        "operationId": "getContactOrder",
        "summary": "Retrieve a contact order",
        "tags": ["Contact Orders"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "Contact order details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactOrder" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateContactOrder",
        "summary": "Update a contact order",
        "tags": ["Contact Orders"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactOrderBase" } } } },
        "responses": {
          "200": { "description": "Contact order updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteContactOrder",
        "summary": "Delete a contact order",
        "tags": ["Contact Orders"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "Contact order deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{contactId}/referrals": {
      "get": {
        "operationId": "listContactReferrals",
        "summary": "List referrals for a contact",
        "tags": ["Contact Referrals"],
        "parameters": [ { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "List of referrals", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ContactReferral" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createContactReferral",
        "summary": "Create a referral for a contact",
        "tags": ["Contact Referrals"],
        "parameters": [ { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactReferralBase" } } } },
        "responses": {
          "201": { "description": "Referral created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactReferral" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{contactId}/referrals/{contactReferralId}": {
      "put": {
        "operationId": "updateContactReferral",
        "summary": "Update a contact referral",
        "tags": ["Contact Referrals"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "contactReferralId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactReferralBase" } } } },
        "responses": {
          "200": { "description": "Referral updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteContactReferral",
        "summary": "Delete a contact referral",
        "tags": ["Contact Referrals"],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "contactReferralId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Referral deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/branches": {
      "get": {
        "operationId": "listBranches",
        "summary": "List branches",
        "tags": ["Branches"],
        "responses": {
          "200": { "description": "List of branches", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Branch" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/listings": {
      "get": {
        "operationId": "listListings",
        "summary": "List property listings",
        "tags": ["Listings"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
