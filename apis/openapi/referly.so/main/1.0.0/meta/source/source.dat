{
  "openapi": "3.0.3",
  "info": {
    "title": "Referly API",
    "description": "Referly is a referral software that helps you create a referral program for your business in minutes. Manage affiliates, referrals, sales, coupons, promotional codes, and affiliate links.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developers.referly.so/api-reference/openapi.json"
  },
  "servers": [
    {
      "url": "https://www.referly.so/api/v1",
      "description": "Referly Production API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Affiliates", "description": "Manage affiliates in your referral program" },
    { "name": "Referrals", "description": "Manage referrals" },
    { "name": "Links", "description": "Manage affiliate links" },
    { "name": "Coupons", "description": "Manage coupons" },
    { "name": "PromotionalCodes", "description": "Manage promotional codes" },
    { "name": "Sales", "description": "Manage sales and commissions" }
  ],
  "paths": {
    "/affiliates": {
      "get": {
        "operationId": "getAffiliates",
        "summary": "Get affiliate(s)",
        "description": "Retrieve affiliates by ID, email, or list all affiliates in the program.",
        "tags": ["Affiliates"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "The ID of the affiliate to retrieve",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "email",
            "in": "query",
            "description": "The email of the affiliate to retrieve",
            "schema": { "type": "string", "format": "email" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved affiliate(s)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Affiliate" }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing bearer token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createAffiliate",
        "summary": "Create an affiliate",
        "description": "Create a new affiliate in your referral program.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewAffiliate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Affiliate created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Affiliate" }
              }
            }
          },
          "400": {
            "description": "Validation or unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateAffiliate",
        "summary": "Update an affiliate",
        "description": "Update an existing affiliate's details.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAffiliate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Affiliate updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Affiliate" }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAffiliate",
        "summary": "Delete an affiliate",
        "description": "Remove an affiliate from the program.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AffiliateDelete" }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Affiliate deleted successfully"
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/referrals": {
      "get": {
        "operationId": "getReferrals",
        "summary": "Get referral(s)",
        "description": "Retrieve referrals by ID, affiliate ID, affiliate email, or external ID.",
        "tags": ["Referrals"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "The ID of the referral to retrieve",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "affiliateId",
            "in": "query",
            "description": "The affiliate ID associated with the referral",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "affiliateEmail",
            "in": "query",
            "description": "The email of the affiliate associated with the referral",
            "schema": { "type": "string", "format": "email" }
          },
          {
            "name": "externalId",
            "in": "query",
            "description": "The external ID of the referred user",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved referral(s)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Referral" }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createReferral",
        "summary": "Create a referral",
        "description": "Create a new referral. Must provide at least one of affiliateId, affiliateEmail, or promoCode.",
        "tags": ["Referrals"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewReferral" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Referral created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Referral" }
              }
            }
          },
          "400": {
            "description": "Validation or unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateReferral",
        "summary": "Update a referral",
        "description": "Update an existing referral.",
        "tags": ["Referrals"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateReferral" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Referral updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Referral" }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteReferral",
        "summary": "Delete a referral",
        "description": "Remove a referral.",
        "tags": ["Referrals"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The ID of the referral to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Referral deleted successfully"
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/links": {
      "get": {
        "operationId": "getAffiliateLinks",
        "summary": "Get affiliate link(s)",
        "description": "Retrieve affiliate links by ID, link string, affiliate ID, or affiliate email.",
        "tags": ["Links"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "The ID of the affiliate link to retrieve",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "link",
            "in": "query",
            "description": "The link string of the affiliate link to retrieve",
            "schema": { "type": "string" }
          },
          {
            "name": "affiliateId",
            "in": "query",
            "description": "The affiliate ID to get links for",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "affiliateEmail",
            "in": "query",
            "description": "The email of the affiliate to get links for",
            "schema": { "type": "string", "format": "email" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved affiliate link(s)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AffiliateLink" }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createAffiliateLink",
        "summary": "Create an affiliate link",
        "description": "Generate a new affiliate link. Must provide either affiliateId or affiliateEmail.",
        "tags": ["Links"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewAffiliateLink" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Affiliate link created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AffiliateLink" }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateAffiliateLink",
        "summary": "Update an affiliate link",
        "description": "Modify an existing affiliate link by ID or link string.",
        "tags": ["Links"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAffiliateLink" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Affiliate link updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AffiliateLink" }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAffiliateLink",
        "summary": "Delete an affiliate link",
        "description": "Remove an affiliate link by ID or link string.",
        "tags": ["Links"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The ID of the affiliate link to delete"
                  },
                  "link": {
                    "type": "string",
                    "description": "The link string to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Affiliate link deleted successfully"
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/coupons": {
      "get": {
        "operationId": "getCoupons",
        "summary": "Get coupon(s)",
        "description": "Retrieve coupons by ID, external ID, or name.",
        "tags": ["Coupons"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "The ID of the coupon to retrieve",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "externalId",
            "in": "query",
            "description": "The external ID of the coupon (e.g., Stripe coupon ID)",
            "schema": { "type": "string" }
          },
          {
            "name": "name",
            "in": "query",
            "description": "The name of the coupon to retrieve",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved coupon(s)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Coupon" }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCoupon",
        "summary": "Create a coupon",
        "description": "Define a new coupon with percentage or flat discount.",
        "tags": ["Coupons"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewCoupon" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Coupon" }
              }
            }
          },
          "400": {
            "description": "Validation or unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateCoupon",
        "summary": "Update a coupon",
        "description": "Modify coupon settings.",
        "tags": ["Coupons"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateCoupon" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Coupon" }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteCoupon",
        "summary": "Delete a coupon",
        "description": "Remove a coupon and its associated promotional codes.",
        "tags": ["Coupons"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The ID of the coupon to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Coupon deleted successfully"
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/promotional-codes": {
      "get": {
        "operationId": "getPromotionalCodes",
        "summary": "Get promotional code(s)",
        "description": "Retrieve promotional codes by various filters.",
        "tags": ["PromotionalCodes"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "The ID of the promotional code",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "code",
            "in": "query",
            "description": "The promotional code string",
            "schema": { "type": "string" }
          },
          {
            "name": "externalId",
            "in": "query",
            "description": "The external ID (e.g., Stripe promotion code ID)",
            "schema": { "type": "string" }
          },
          {
            "name": "couponId",
            "in": "query",
            "description": "The coupon ID to get codes for",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "affiliateId",
            "in": "query",
            "description": "The affiliate ID to get codes for",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "affiliateEmail",
            "in": "query",
            "description": "The affiliate email to get codes for",
            "schema": { "type": "string", "format": "email" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved promotional code(s)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PromotionalCode" }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPromotionalCode",
        "summary": "Create a promotional code",
        "description": "Generate a new promotional code for a coupon, optionally auto-generated.",
        "tags": ["PromotionalCodes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewPromotionalCode" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Promotional code created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PromotionalCode" }
              }
            }
          },
          "400": {
            "description": "Validation or unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updatePromotionalCode",
        "summary": "Update a promotional code",
        "description": "Update promotional code status and constraints.",
        "tags": ["PromotionalCodes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdatePromotionalCode" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Promotional code updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PromotionalCode" }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deletePromotionalCode",
        "summary": "Delete a promotional code",
        "description": "Remove a promotional code.",
        "tags": ["PromotionalCodes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The ID of the promotional code to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Promotional code deleted successfully"
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/sales": {
      "get": {
        "operationId": "getSales",
        "summary": "Get sale(s)",
        "description": "Retrieve sales by various filters including affiliate, referral, or external ID.",
        "tags": ["Sales"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "The ID of the sale to retrieve",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "affiliateId",
            "in": "query",
            "description": "Filter sales by affiliate ID",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "affiliateEmail",
            "in": "query",
            "description": "Filter sales by affiliate email",
            "schema": { "type": "string", "format": "email" }
          },
          {
            "name": "referralId",
            "in": "query",
            "description": "Filter sales by referral ID",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "saleExternalId",
            "in": "query",
            "description": "The external ID of the sale in your system",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved sale(s)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Sale" }
                }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createSale",
        "summary": "Create a sale",
        "description": "Record a new sale. Must provide at least one of referralId, email, or promoCode to identify the affiliate.",
        "tags": ["Sales"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewSale" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sale created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sale" }
              }
            }
          },
          "400": {
            "description": "Validation or unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateSale",
        "summary": "Update a sale",
        "description": "Modify sale details.",
        "tags": ["Sales"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateSale" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sale updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sale" }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "refundSale",
        "summary": "Refund a sale",
        "description": "Mark a sale as refunded.",
        "tags": ["Sales"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SaleRefund" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sale refund processed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SaleRefundResponse" }
              }
            }
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SaleRefundError" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Sale not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SaleRefundError" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteSale",
        "summary": "Delete a sale",
        "description": "Remove a sale record.",
        "tags": ["Sales"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "format": "int64",
                    "description": "The ID of the sale to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Sale deleted successfully"
          },
          "400": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Generate an API key from the Referly dashboard."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "integer",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error description"
          }
        }
      },
      "Affiliate": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid", "description": "The affiliate ID" },
          "firstName": { "type": "string", "description": "First name of the affiliate" },
          "lastName": { "type": "string", "description": "Last name of the affiliate" },
          "name": { "type": "string", "description": "Full name of the affiliate" },
          "email": { "type": "string", "format": "email", "description": "Email of the affiliate" },
          "emailVerified": { "type": "boolean" },
          "image": { "type": "string", "nullable": true },
          "detailsComplete": { "type": "boolean" },
          "programId": { "type": "string", "format": "uuid" },
          "payoutEmail": { "type": "string", "format": "email", "nullable": true },
          "paymentMethod": { "type": "string", "nullable": true },
          "commissionRate": { "type": "number", "format": "float", "description": "Commission rate (0-100)" },
          "link": { "type": "string", "description": "Affiliate's custom referral link" },
          "status": { "type": "string", "description": "Active/inactive status" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "numberOfReferredUsers": { "type": "integer" },
          "numberOfClicks": { "type": "integer" },
          "totalCommissionEarned": { "type": "number", "format": "float" }
        }
      },
      "NewAffiliate": {
        "type": "object",
        "required": ["firstName", "lastName", "email"],
        "properties": {
          "firstName": { "type": "string", "description": "First name of the affiliate" },
          "lastName": { "type": "string", "description": "Last name of the affiliate" },
          "email": { "type": "string", "format": "email", "description": "Email of the affiliate" },
          "commissionRate": { "type": "number", "format": "float", "description": "Commission rate for the affiliate" },
          "affiliateLink": { "type": "string", "description": "Custom affiliate link" }
        }
      },
      "UpdateAffiliate": {
        "type": "object",
        "required": ["affiliateId"],
        "properties": {
          "affiliateId": { "type": "string", "description": "Identifier for the affiliate being updated" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "commissionRate": { "type": "number", "format": "float" },
          "affiliateStatus": { "type": "string", "enum": ["active", "inactive"] },
          "affiliateLink": { "type": "string" }
        }
      },
      "AffiliateDelete": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "description": "The ID of the affiliate to delete" }
        }
      },
      "Referral": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "affiliateId": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "description": "Referred user's name" },
          "email": { "type": "string", "format": "email", "description": "Referred user's email" },
          "referredUserExternalId": { "type": "string", "description": "External identifier for the referred user" },
          "plan": { "type": "string", "description": "Associated plan" },
          "status": { "type": "string", "description": "Referral status" }
        }
      },
      "NewReferral": {
        "type": "object",
        "required": ["name", "email", "referredUserExternalId"],
        "properties": {
          "name": { "type": "string", "description": "Referred user's name" },
          "email": { "type": "string", "format": "email", "description": "Referred user's email" },
          "referredUserExternalId": { "type": "string", "description": "External identifier for the referred user" },
          "affiliateId": { "type": "string", "format": "uuid" },
          "affiliateEmail": { "type": "string", "format": "email" },
          "promoCode": { "type": "string", "description": "Promotional code" },
          "plan": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "inactive"] }
        }
      },
      "UpdateReferral": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "plan": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "inactive"] }
        }
      },
      "AffiliateLink": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "link": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "affiliate": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "name": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            }
          },
          "program": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "name": { "type": "string" },
              "currency": { "type": "string" }
            }
          },
          "clicks": { "type": "integer" },
          "referrals": { "type": "integer" },
          "sales": { "type": "integer" },
          "totalRevenue": { "type": "number", "format": "float" },
          "fullURLs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "baseUrl": { "type": "string" },
                "fullUrl": { "type": "string" }
              }
            }
          }
        }
      },
      "NewAffiliateLink": {
        "type": "object",
        "required": ["link"],
        "properties": {
          "link": { "type": "string", "description": "The affiliate link string (letters, numbers, and hyphens only)" },
          "affiliateId": { "type": "string", "format": "uuid" },
          "affiliateEmail": { "type": "string", "format": "email" }
        }
      },
      "UpdateAffiliateLink": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "link": { "type": "string" },
          "affiliateId": { "type": "string", "format": "uuid" },
          "affiliateEmail": { "type": "string", "format": "email" }
        }
      },
      "Coupon": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "externalId": { "type": "string", "nullable": true },
          "couponType": { "type": "string", "enum": ["PERCENTAGE", "FLAT"] },
          "percentOff": { "type": "number", "format": "float", "nullable": true },
          "amountOff": { "type": "number", "format": "float", "nullable": true },
          "currency": { "type": "string", "nullable": true },
          "duration": { "type": "string", "enum": ["once", "forever", "repeating"] },
          "durationInMonths": { "type": "integer", "nullable": true },
          "maxRedemptions": { "type": "integer", "nullable": true },
          "limitToProducts": { "type": "boolean" },
          "productIds": { "type": "array", "items": { "type": "string" }, "nullable": true },
          "valid": { "type": "boolean" },
          "redeemBy": { "type": "string", "format": "date-time", "nullable": true },
          "integrationType": { "type": "string", "nullable": true },
          "affiliateProgramId": { "type": "string", "format": "uuid" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "promotionalCodes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PromotionalCode" }
          }
        }
      },
      "NewCoupon": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "externalId": { "type": "string" },
          "couponType": { "type": "string", "enum": ["PERCENTAGE", "FLAT"], "default": "PERCENTAGE" },
          "percentOff": { "type": "number", "format": "float", "description": "Discount percentage 1-100 (required for PERCENTAGE type)" },
          "amountOff": { "type": "number", "format": "float", "description": "Fixed discount amount (required for FLAT type)" },
          "currency": { "type": "string", "description": "Currency code (required for FLAT type)" },
          "duration": { "type": "string", "enum": ["once", "forever", "repeating"], "default": "forever" },
          "durationInMonths": { "type": "integer", "description": "Required for repeating duration" },
          "maxRedemptions": { "type": "integer" },
          "limitToProducts": { "type": "boolean", "default": false },
          "productIds": { "type": "array", "items": { "type": "string" } },
          "valid": { "type": "boolean", "default": true },
          "redeemBy": { "type": "string", "format": "date-time" },
          "integrationType": { "type": "string" }
        }
      },
      "UpdateCoupon": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "couponType": { "type": "string", "enum": ["PERCENTAGE", "FLAT"] },
          "percentOff": { "type": "number", "format": "float" },
          "amountOff": { "type": "number", "format": "float" },
          "currency": { "type": "string" },
          "duration": { "type": "string", "enum": ["once", "forever", "repeating"] },
          "durationInMonths": { "type": "integer" },
          "maxRedemptions": { "type": "integer" },
          "valid": { "type": "boolean" },
          "redeemBy": { "type": "string", "format": "date-time" }
        }
      },
      "PromotionalCode": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "couponId": { "type": "string", "format": "uuid" },
          "affiliateId": { "type": "string", "format": "uuid", "nullable": true },
          "externalId": { "type": "string", "nullable": true },
          "active": { "type": "boolean" },
          "expiresAt": { "type": "string", "format": "date-time", "nullable": true },
          "maxRedemptions": { "type": "integer", "nullable": true },
          "timesRedeemed": { "type": "integer" },
          "firstTimeOrder": { "type": "boolean" },
          "minimumAmount": { "type": "number", "format": "float", "nullable": true },
          "minimumAmountCurrency": { "type": "string", "nullable": true },
          "limitToCustomers": { "type": "boolean" },
          "customerId": { "type": "string", "nullable": true },
          "limitToAffiliate": { "type": "boolean" },
          "isAutoGenerated": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "coupon": { "$ref": "#/components/schemas/Coupon" },
          "affiliate": {
            "type": "object",
            "nullable": true,
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "firstName": { "type": "string" },
              "lastName": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            }
          }
        }
      },
      "NewPromotionalCode": {
        "type": "object",
        "required": ["couponId"],
        "properties": {
          "couponId": { "type": "string", "format": "uuid" },
          "code": { "type": "string", "description": "The promotional code string (required if isAutoGenerated is false)" },
          "affiliateId": { "type": "string", "format": "uuid" },
          "affiliateEmail": { "type": "string", "format": "email" },
          "externalId": { "type": "string" },
          "active": { "type": "boolean", "default": true },
          "expiresAt": { "type": "string", "format": "date-time" },
          "maxRedemptions": { "type": "integer" },
          "firstTimeOrder": { "type": "boolean", "default": false },
          "minimumAmount": { "type": "number", "format": "float" },
          "minimumAmountCurrency": { "type": "string" },
          "limitToCustomers": { "type": "boolean", "default": false },
          "customerId": { "type": "string" },
          "limitToAffiliate": { "type": "boolean", "default": false },
          "isAutoGenerated": { "type": "boolean", "default": false },
          "codeStructure": {
            "type": "object",
            "description": "Structure for auto-generated codes (required if isAutoGenerated is true)",
            "properties": {
              "firstName": { "type": "boolean" },
              "lastName": { "type": "boolean" },
              "email": { "type": "boolean" },
              "discountAmount": { "type": "boolean" },
              "couponName": { "type": "boolean" },
              "randomChars": { "type": "boolean" }
            }
          },
          "prefix": { "type": "string" },
          "randomCharsLength": { "type": "integer", "default": 4 },
          "randomCharsCase": { "type": "string", "enum": ["uppercase", "lowercase", "mixed"], "default": "mixed" }
        }
      },
      "UpdatePromotionalCode": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "code": { "type": "string" },
          "active": { "type": "boolean" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "maxRedemptions": { "type": "integer" },
          "firstTimeOrder": { "type": "boolean" },
          "minimumAmount": { "type": "number", "format": "float" },
          "minimumAmountCurrency": { "type": "string" },
          "limitToCustomers": { "type": "boolean" },
          "customerId": { "type": "string" },
          "limitToAffiliate": { "type": "boolean" }
        }
      },
      "Sale": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "affiliateId": { "type": "string", "format": "uuid" },
          "referralId": { "type": "string", "format": "uuid" },
          "externalId": { "type": "string", "nullable": true },
          "externalInvoiceId": { "type": "string", "nullable": true },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "totalEarned": { "type": "number", "format": "float" },
          "commissionRate": { "type": "number", "format": "float" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "NewSale": {
        "type": "object",
        "required": ["totalEarned"],
        "properties": {
          "totalEarned": { "type": "number", "format": "float", "description": "Revenue amount from the transaction" },
          "referralId": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email", "description": "Customer email address" },
          "promoCode": { "type": "string", "description": "Promotional code" },
          "name": { "type": "string", "description": "Customer name" },
          "externalId": { "type": "string", "description": "Sale identifier from external system" },
          "externalInvoiceId": { "type": "string", "description": "Invoice identifier from external system" },
          "commissionRate": { "type": "number", "format": "float", "description": "Override commission rate" },
          "product": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number", "format": "float" },
              "name": { "type": "string" }
            }
          },
          "tax": { "type": "number", "format": "float", "description": "Tax amount excluded from commission" },
          "shipping": { "type": "number", "format": "float", "description": "Shipping amount excluded from commission" }
        }
      },
      "UpdateSale": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "totalEarned": { "type": "number", "format": "float" },
          "commissionRate": { "type": "number", "format": "float" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "externalId": { "type": "string" },
          "externalInvoiceId": { "type": "string" }
        }
      },
      "SaleRefund": {
        "type": "object",
        "required": ["saleId"],
        "properties": {
          "saleId": { "type": "integer", "description": "The sale ID to mark as refunded" }
        }
      },
      "SaleRefundResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "Whether the refund request was handled successfully" },
          "alreadyRefunded": { "type": "boolean", "description": "Indicates prior refund status" },
          "reason": { "type": "string", "description": "Result outcome" }
        }
      },
      "SaleRefundError": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error message" },
          "reason": { "type": "string", "description": "Error classification" }
        }
      }
    }
  }
}