{
  "openapi": "3.0.3",
  "info": {
    "title": "Alltius API",
    "description": "Alltius is an Agentic AI platform for financial services. Provides Chat, Report, and Webhook APIs.",
    "version": "v1",
    "x-jentic-source-url": "https://app.alltius.ai/api/platform/openapi.json"
  },
  "servers": [
    {
      "url": "https://app.alltius.ai/api/platform"
    }
  ],
  "paths": {
    "/v1/chat": {
      "post": {
        "tags": [
          "Chat API"
        ],
        "summary": "Chat",
        "description": "Submit a user query and get a response from the Assistant",
        "operationId": "chat_v1_chat_post",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatApiRequestV1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/chat/rating": {
      "put": {
        "tags": [
          "Chat API"
        ],
        "summary": "Rating",
        "description": "Provide a thumbs up or down feedback to a response given by the Assistant",
        "operationId": "rating_v1_chat_rating_put",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
