{
  "openapi": "3.0.3",
  "info": {
    "title": "Temporal Cloud Ops API",
    "description": "HTTP API for programmatic management of Temporal Cloud control plane resources including namespaces, users, service accounts, API keys, audit logs, and billing.",
    "version": "0.12.0",
    "x-jentic-source-url": "https://docs.temporal.io/"
  },
  "servers": [
    {
      "url": "https://saas-api.tmprl.cloud",
      "description": "Temporal Cloud API"
    }
  ],
  "paths": {
    "/cloud/account": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account details",
        "description": "Retrieve the current account details.",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccountResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "updateAccount",
        "summary": "Update account configuration",
        "tags": ["Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AccountUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/current-identity": {
      "get": {
        "operationId": "getCurrentIdentity",
        "summary": "Get current identity",
        "description": "Get information about the authenticated principal.",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Current identity",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IdentityResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/api-keys": {
      "get": {
        "operationId": "listApiKeys",
        "summary": "List API keys",
        "description": "List all API keys with optional filtering.",
        "tags": ["API Keys"],
        "parameters": [
          {
            "name": "owner_id",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by owner ID"
          },
          {
            "name": "owner_type",
            "in": "query",
            "schema": { "type": "string", "enum": ["user", "service-account"] }
          },
          {
            "name": "page_token",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of API keys",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKeyList" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createApiKey",
        "summary": "Create an API key",
        "tags": ["API Keys"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ApiKeyCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API key created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKeyCreateResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/api-keys/{keyId}": {
      "get": {
        "operationId": "getApiKey",
        "summary": "Get an API key",
        "tags": ["API Keys"],
        "parameters": [
          { "$ref": "#/components/parameters/keyId" }
        ],
        "responses": {
          "200": {
            "description": "API key details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKey" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "updateApiKey",
        "summary": "Update an API key",
        "tags": ["API Keys"],
        "parameters": [
          { "$ref": "#/components/parameters/keyId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ApiKeyUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API key updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteApiKey",
        "summary": "Delete an API key",
        "tags": ["API Keys"],
        "parameters": [
          { "$ref": "#/components/parameters/keyId" }
        ],
        "responses": {
          "200": {
            "description": "API key deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/namespaces": {
      "get": {
        "operationId": "listNamespaces",
        "summary": "List namespaces",
        "tags": ["Namespaces"],
        "parameters": [
          {
            "name": "page_token",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "name",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by namespace name"
          }
        ],
        "responses": {
          "200": {
            "description": "List of namespaces",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NamespaceList" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createNamespace",
        "summary": "Create a namespace",
        "tags": ["Namespaces"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NamespaceCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Namespace creation initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/namespaces/{namespace}": {
      "get": {
        "operationId": "getNamespace",
        "summary": "Get namespace details",
        "tags": ["Namespaces"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" }
        ],
        "responses": {
          "200": {
            "description": "Namespace details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Namespace" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "updateNamespace",
        "summary": "Update namespace configuration",
        "tags": ["Namespaces"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NamespaceUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Namespace update initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteNamespace",
        "summary": "Delete a namespace",
        "tags": ["Namespaces"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" }
        ],
        "responses": {
          "200": {
            "description": "Namespace deletion initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/namespaces/{namespace}/capacity-info": {
      "get": {
        "operationId": "getNamespaceCapacityInfo",
        "summary": "Get namespace capacity info",
        "tags": ["Namespaces"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" }
        ],
        "responses": {
          "200": {
            "description": "Capacity information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CapacityInfo" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/namespaces/{namespace}/update-tags": {
      "post": {
        "operationId": "updateNamespaceTags",
        "summary": "Update namespace tags",
        "tags": ["Namespaces"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tags": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "resource_version": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/namespaces/{namespace}/add-region": {
      "post": {
        "operationId": "addNamespaceRegion",
        "summary": "Add a region to a namespace",
        "description": "Add a namespace replica region for high availability.",
        "tags": ["Namespaces"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "region": { "type": "string" },
                  "resource_version": { "type": "string" }
                },
                "required": ["region"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Region addition initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/namespaces/{namespace}/failover-region": {
      "post": {
        "operationId": "failoverNamespaceRegion",
        "summary": "Initiate regional failover",
        "tags": ["Namespaces"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "region": { "type": "string" },
                  "resource_version": { "type": "string" }
                },
                "required": ["region"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Failover initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cloud/namespaces/{namespace}/users/{userId}/access": {
      "post": {
        "operationId": "setNamespaceUserAccess",
        "summary": "Set user namespace permissions",
        "tags": ["Namespaces"],
        "parameters": [
          { "$ref": "#/components/parameters/namespace" },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NamespaceAccessSpec" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AsyncOperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
