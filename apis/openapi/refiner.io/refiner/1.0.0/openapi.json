{
  "openapi": "3.0.3",
  "info": {
    "title": "Refiner API",
    "version": "1.0.0",
    "description": "Refiner is a customer survey and feedback platform. The API lets you identify users, track events, manage survey responses, contacts, segments, and forms.",
    "x-jentic-source-url": "https://refiner.io/docs/api/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.refiner.io/v1",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
