  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key as Bearer token. Obtain from Refiner dashboard under Integrations > Rest API."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "ok"
          }
        }
      },
      "IdentifyUserRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Your user ID"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "account": {
            "$ref": "#/components/schemas/AccountRef"
          }
        }
      },
      "AccountRef": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "IdentifyUserResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "contact_uuid": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "TrackEventRequest": {
        "type": "object",
        "required": [
          "event"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "event": {
            "type": "string",
            "description": "Event name"
          }
        }
      },
      "StoreResponseRequest": {
        "type": "object",
        "required": [
          "form_uuid"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "form_uuid": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "prevent_duplicates": {
            "type": "boolean"
