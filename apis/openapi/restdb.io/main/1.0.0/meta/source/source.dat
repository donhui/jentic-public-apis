{
  "openapi": "3.0.3",
  "info": {
    "title": "RestDB.io REST API",
    "description": "RestDB.io provides a simple REST API for managing NoSQL cloud database collections, documents, media, and sending emails.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://restdb.io/docs/rest-api"
  },
  "servers": [
    {
      "url": "https://{dburl}.restdb.io",
      "variables": {
        "dburl": {
          "default": "your-database",
          "description": "Your RestDB.io database subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {"name": "Collections", "description": "CRUD operations on collections and documents"},
    {"name": "Media", "description": "Upload, retrieve, and delete media files"},
    {"name": "Metadata", "description": "Database and collection metadata"},
    {"name": "Auth", "description": "Authentication"},
    {"name": "Mail", "description": "Send emails"}
  ],
  "paths": {
    "/rest/{collection}": {
      "get": {
        "operationId": "listDocuments",
        "tags": ["Collections"],
        "summary": "List all documents in a collection",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"name": "q", "in": "query", "description": "JSON query filter", "schema": {"type": "string"}},
          {"name": "h", "in": "query", "description": "JSON query hints (fields, orderby, skip, max)", "schema": {"type": "string"}},
          {"name": "filter", "in": "query", "description": "Simple field filter", "schema": {"type": "string"}},
          {"name": "sort", "in": "query", "description": "Sort field", "schema": {"type": "string"}},
          {"name": "dir", "in": "query", "description": "Sort direction", "schema": {"type": "integer", "enum": [1, -1]}},
          {"name": "skip", "in": "query", "schema": {"type": "integer"}},
          {"name": "max", "in": "query", "schema": {"type": "integer"}},
          {"name": "metafields", "in": "query", "description": "Include meta fields", "schema": {"type": "boolean"}},
          {"name": "fetchchildren", "in": "query", "description": "Include child documents", "schema": {"type": "boolean"}},
          {"name": "groupby", "in": "query", "schema": {"type": "string"}},
          {"name": "aggregate", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "List of documents",
            "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Document"}}}}
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "createDocument",
        "tags": ["Collections"],
        "summary": "Create a new document or bulk insert",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"name": "validate", "in": "query", "description": "Set to false to skip validation", "schema": {"type": "boolean"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {"$ref": "#/components/schemas/Document"},
                  {"type": "array", "items": {"$ref": "#/components/schemas/Document"}}
                ]
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Document created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Document"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/rest/{collection}/{documentId}": {
      "get": {
        "operationId": "getDocument",
        "tags": ["Collections"],
        "summary": "Get a single document by ID",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"$ref": "#/components/parameters/DocumentIdParam"}
        ],
        "responses": {
          "200": {"description": "Document details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Document"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "put": {
        "operationId": "replaceDocument",
        "tags": ["Collections"],
        "summary": "Replace an entire document",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"$ref": "#/components/parameters/DocumentIdParam"}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Document"}}}},
        "responses": {
          "200": {"description": "Document replaced", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Document"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateDocument",
        "tags": ["Collections"],
        "summary": "Update specific properties on a document",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"$ref": "#/components/parameters/DocumentIdParam"}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Document"}}}},
        "responses": {
          "200": {"description": "Document updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Document"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteDocument",
        "tags": ["Collections"],
        "summary": "Delete a single document",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"$ref": "#/components/parameters/DocumentIdParam"}
        ],
        "responses": {
          "200": {"description": "Document deleted"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/rest/{collection}/*": {
      "delete": {
        "operationId": "deleteMultipleDocuments",
        "tags": ["Collections"],
        "summary": "Delete multiple documents by IDs or query",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"name": "q", "in": "query", "description": "JSON query filter for deletion", "schema": {"type": "string"}}
        ],
        "requestBody": {
          "content": {"application/json": {"schema": {"type": "array", "items": {"type": "string"}, "description": "Array of document IDs to delete"}}}
        },
        "responses": {
          "200": {"description": "Documents deleted"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/rest/{collection}/{documentId}/{subcollection}": {
      "get": {
        "operationId": "listSubcollectionDocuments",
        "tags": ["Collections"],
        "summary": "Get subcollection documents",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"$ref": "#/components/parameters/DocumentIdParam"},
          {"name": "subcollection", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Subcollection documents", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Document"}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "createSubcollectionDocument",
        "tags": ["Collections"],
        "summary": "Add child document to subcollection",
        "parameters": [
          {"$ref": "#/components/parameters/CollectionParam"},
          {"$ref": "#/components/parameters/DocumentIdParam"},
          {"name": "subcollection", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Document"}}}},
        "responses": {
          "201": {"description": "Subcollection document created"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/media/{mediaId}": {
      "get": {
        "operationId": "getMedia",
        "tags": ["Media"],
        "summary": "Retrieve media content",
        "parameters": [
          {"name": "mediaId", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "s", "in": "query", "description": "Size: t=thumbnail, w=web, o=original", "schema": {"type": "string", "enum": ["t", "w", "o"]}}
        ],
        "responses": {
          "200": {"description": "Media content", "content": {"application/octet-stream": {"schema": {"type": "string", "format": "binary"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteMedia",
        "tags": ["Media"],
        "summary": "Delete media content",
        "parameters": [
          {"name": "mediaId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Media deleted"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/media": {
      "post": {
        "operationId": "uploadMedia",
        "tags": ["Media"],
        "summary": "Upload media files",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {"type": "string", "format": "binary"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Media uploaded"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/media/{mediaId}/meta": {
      "get": {
        "operationId": "getMediaMeta",
        "tags": ["Media"],
        "summary": "Get metadata for a media item",
        "parameters": [
          {"name": "mediaId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Media metadata", "content": {"application/json": {"schema": {"type": "object", "additionalProperties": true}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/media/*/meta": {
      "get": {
        "operationId": "getMultipleMediaMeta",
        "tags": ["Media"],
        "summary": "Get metadata for multiple media items by IDs",
        "parameters": [
          {"name": "ids", "in": "query", "required": true, "description": "Comma-separated media IDs", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Media metadata list", "content": {"application/json": {"schema": {"type": "array", "items": {"type": "object", "additionalProperties": true}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/rest/_meta": {
      "get": {
        "operationId": "getDatabaseMeta",
        "tags": ["Metadata"],
        "summary": "Get database metadata",
        "responses": {
          "200": {"description": "Database metadata"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/rest/{collection}/_meta": {
      "get": {
        "operationId": "getCollectionMeta",
        "tags": ["Metadata"],
        "summary": "Get collection metadata",
        "parameters": [{"$ref": "#/components/parameters/CollectionParam"}],
        "responses": {
          "200": {"description": "Collection metadata"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/mail": {
      "post": {
        "operationId": "sendEmail",
        "tags": ["Mail"],
        "summary": "Send an email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/EmailRequest"}
            }
          }
        },
        "responses": {
          "200": {"description": "Email sent"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/auth/userinfo": {
      "get": {
        "operationId": "getUserInfo",
        "tags": ["Auth"],
        "summary": "Get authenticated user information",
        "responses": {
          "200": {"description": "User info", "content": {"application/json": {"schema": {"type": "object", "properties": {"email": {"type": "string"}, "displayname": {"type": "string"}, "image": {"type": "string"}}}}}},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "logout",
        "tags": ["Auth"],
        "summary": "Invalidate the current login token",
        "responses": {
          "200": {"description": "Logged out successfully"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/auth/jwt": {
      "post": {
        "operationId": "generateJwt",
        "tags": ["Auth"],
        "summary": "Generate a JWT token",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "properties": {"email": {"type": "string"}, "password": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "JWT token generated", "content": {"application/json": {"schema": {"type": "object", "properties": {"token": {"type": "string"}}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "x-apikey",
        "in": "header"
      }
    },
    "parameters": {
      "CollectionParam": {
        "name": "collection",
        "in": "path",
        "required": true,
        "schema": {"type": "string"}
      },
      "DocumentIdParam": {
        "name": "documentId",
        "in": "path",
        "required": true,
        "schema": {"type": "string"}
      }
    },
    "schemas": {
      "Document": {
        "type": "object",
        "properties": {
          "_id": {"type": "string", "readOnly": true}
        },
        "additionalProperties": true
      },
      "EmailRequest": {
        "type": "object",
        "required": ["to", "subject", "body"],
        "properties": {
          "to": {"type": "string"},
          "subject": {"type": "string"},
          "body": {"type": "string"},
          "company": {"type": "string"},
          "sendername": {"type": "string"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {"type": "string"},
          "error": {"type": "string"}
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key"
      }
    }
  }
}
