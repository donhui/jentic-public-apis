{
  "openapi": "3.0.3",
  "info": {
    "title": "APIVoid Domain Reputation API",
    "description": "APIVoid provides threat intelligence APIs for domain reputation, IP reputation, URL analysis, and more. The Domain Reputation API checks domains against 30+ blocklists for phishing, malware, and fraudulent activity detection.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://www.apivoid.com/api/domain-reputation/"
  },
  "servers": [
    {
      "url": "https://api.apivoid.com",
      "description": "APIVoid Production"
    }
  ],
  "paths": {
    "/v2/domain-reputation": {
      "post": {
        "tags": [
          "Domain Reputation"
        ],
        "summary": "Check domain reputation against 30+ blocklists",
        "operationId": "checkDomainReputation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DomainReputationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Domain reputation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DomainReputationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid domain"
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          },
          "429": {
            "description": "Rate limit or credit limit exceeded"
          }
        },
        "security": [
          {
            "apiKeyHeader": []
          }
        ]
      }
    },
    "/v2/ip-reputation": {
      "post": {
        "tags": [
          "IP Reputation"
        ],
        "summary": "Check IP reputation against blocklists",
        "operationId": "checkIpReputation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IpReputationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "IP reputation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IpReputationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "apiKeyHeader": []
          }
        ]
      }
    },
    "/v2/url-reputation": {
      "post": {
        "tags": [
          "URL Reputation"
        ],
        "summary": "Check URL reputation",
        "operationId": "checkUrlReputation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlReputationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "URL reputation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UrlReputationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "apiKeyHeader": []
          }
        ]
      }
    },
    "/v2/email-verify": {
      "post": {
        "tags": [
          "Email Verification"
        ],
        "summary": "Verify email address",
        "operationId": "verifyEmail",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmailVerifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailVerifyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "apiKeyHeader": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "DomainReputationRequest": {
        "type": "object",
        "required": [
          "host"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "Domain name to check",
            "example": "google.com"
          }
        }
      },
      "DomainReputationResponse": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string"
          },
          "blacklists": {
            "$ref": "#/components/schemas/BlacklistResult"
          },
          "server_details": {
            "$ref": "#/components/schemas/ServerDetails"
          }
        }
      },
      "IpReputationRequest": {
        "type": "object",
        "required": [
          "ip"
        ],
        "properties": {
          "ip": {
            "type": "string",
            "description": "IP address to check"
          }
        }
      },
      "IpReputationResponse": {
        "type": "object",
        "properties": {
          "ip": {
            "type": "string"
          },
          "blacklists": {
            "$ref": "#/components/schemas/BlacklistResult"
          }
        }
      },
      "UrlReputationRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to check"
          }
        }
      },
      "UrlReputationResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "blacklists": {
            "$ref": "#/components/schemas/BlacklistResult"
          }
        }
      },
      "EmailVerifyRequest": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address to verify"
          }
        }
      },
      "EmailVerifyResponse": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "valid": {
            "type": "boolean"
          },
          "disposable": {
            "type": "boolean"
          }
        }
      },
      "BlacklistResult": {
        "type": "object",
        "properties": {
          "engines": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/BlacklistEngine"
            }
          },
          "detections": {
            "type": "integer"
          },
          "engines_count": {
            "type": "integer"
          },
          "detection_rate": {
            "type": "string"
          },
          "scan_time_ms": {
            "type": "integer"
          }
        }
      },
      "BlacklistEngine": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "detected": {
            "type": "boolean"
          },
          "reference": {
            "type": "string"
          },
          "confidence": {
            "type": "string"
          },
          "elapsed_ms": {
            "type": "integer"
          }
        }
      },
      "ServerDetails": {
        "type": "object",
        "properties": {
          "ip": {
            "type": "string"
          },
          "reverse_dns": {
            "type": "string"
          },
          "continent_code": {
            "type": "string"
          },
          "continent_name": {
            "type": "string"
          },
          "country_code": {
            "type": "string"
          },
          "country_name": {
            "type": "string"
          },
          "region_name": {
            "type": "string"
          },
          "city_name": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "isp": {
            "type": "string"
          },
          "asn": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "APIVoid API key"
      }
    }
  },
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Domain Reputation",
      "description": "Domain reputation analysis"
    },
    {
      "name": "IP Reputation",
      "description": "IP reputation analysis"
    },
    {
      "name": "URL Reputation",
      "description": "URL reputation analysis"
    },
    {
      "name": "Email Verification",
      "description": "Email verification"
    }
  ]
}