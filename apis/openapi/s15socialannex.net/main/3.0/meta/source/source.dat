{
  "openapi": "3.0.3",
  "info": {
    "title": "Annex Cloud Loyalty API",
    "description": "Annex Cloud API v3.0 for loyalty program management including users, orders, points, rewards, segments, and campaigns.",
    "version": "3.0",
    "x-jentic-source-url": "https://s15.socialannex.net/help/acapi.html"
  },
  "servers": [
    {
      "url": "https://s15.socialannex.net/api/3.0",
      "description": "Production"
    },
    {
      "url": "https://s15.stage.socialannex.net/api/3.0",
      "description": "Staging"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "siteId": []
    }
  ],
  "tags": [
    { "name": "Users", "description": "User management and loyalty enrollment" },
    { "name": "Orders", "description": "Order creation and status management" },
    { "name": "Points", "description": "Points balance, credits, debits, and redemptions" },
    { "name": "Rewards", "description": "Available rewards for users" },
    { "name": "Segments", "description": "Segment membership details" },
    { "name": "Campaigns", "description": "Campaign configuration" }
  ],
  "paths": {
    "/users": {
      "post": {
        "operationId": "createUser",
        "summary": "Create a user and enroll in loyalty program",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "getUser",
        "summary": "Retrieve user profile details",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unique user identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "User profile retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateUser",
        "summary": "Update user information",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unique user identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}/activity": {
      "get": {
        "operationId": "getUserActivity",
        "summary": "Fetch user activity history with pagination",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unique user identifier"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Page number"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Items per page"
          }
        ],
        "responses": {
          "200": {
            "description": "User activity retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActivityList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}/usedreward": {
      "get": {
        "operationId": "getUserUsedRewards",
        "summary": "Retrieve redeemed rewards list",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unique user identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Redeemed rewards retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsedRewardList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}/tiers": {
      "get": {
        "operationId": "getUserTiers",
        "summary": "Get current and next tier information",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unique user identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Tier information retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TierInfo"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}/reward": {
      "get": {
        "operationId": "getUserRewards",
        "summary": "Retrieve available rewards for user",
        "tags": ["Rewards"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unique user identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Available rewards retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RewardList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/orders": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create a new order",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/orders/{id}": {
      "patch": {
        "operationId": "updateOrder",
        "summary": "Update order status (ship, return, or cancel)",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Order identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/points/{id}": {
      "get": {
        "operationId": "getPointsBalance",
        "summary": "View user's point balance and details",
        "tags": ["Points"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "User identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Points balance retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PointsBalance"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/points": {
      "post": {
        "operationId": "managePoints",
        "summary": "Add, remove points or redeem rewards",
        "tags": ["Points"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManagePointsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Points operation completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PointsTransaction"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/cart": {
      "post": {
        "operationId": "calculateCartPoints",
        "summary": "Calculate potential points for cart items",
        "tags": ["Points"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CartCalculationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cart points calculated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CartCalculationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/segment/{segmentId}": {
      "get": {
        "operationId": "getSegment",
        "summary": "Get segment membership details",
        "tags": ["Segments"],
        "parameters": [
          {
            "name": "segmentId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Segment identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Segment details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Segment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/campaign/{campaignId}": {
      "get": {
        "operationId": "getCampaign",
        "summary": "Retrieve campaign configuration",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "campaignId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Campaign identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Campaign"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT access token with HS256 signing"
      },
      "siteId": {
        "type": "apiKey",
        "in": "header",
        "name": "X-AnnexCloud-Site",
        "description": "Site identifier header"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "errorCode": {
            "type": "string",
            "description": "Error code (AC1001-AC1010)"
          },
          "errorMessage": {
            "type": "string",
            "description": "Description of the error"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "description": "Unique user identifier" },
          "email": { "type": "string", "format": "email" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "phone": { "type": "string" },
          "birthDate": { "type": "string", "format": "date-time" },
          "anniversaryDate": { "type": "string", "format": "date-time" },
          "optInStatus": { "type": "string", "enum": ["YES", "NO"] },
          "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
          "extendedAttribute": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Custom key-value pairs"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "phone": { "type": "string" },
          "birthDate": { "type": "string", "format": "date-time" },
          "anniversaryDate": { "type": "string", "format": "date-time" },
          "optInStatus": { "type": "string", "enum": ["YES", "NO"] },
          "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
          "extendedAttribute": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "phone": { "type": "string" },
          "birthDate": { "type": "string", "format": "date-time" },
          "anniversaryDate": { "type": "string", "format": "date-time" },
          "optInStatus": { "type": "string" },
          "status": { "type": "string" },
          "extendedAttribute": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "ActivityList": {
        "type": "object",
        "properties": {
          "activities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Activity"
            }
          }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "activityId": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "points": { "type": "number" },
          "createdDate": { "type": "string", "format": "date-time" }
        }
      },
      "UsedRewardList": {
        "type": "object",
        "properties": {
          "rewards": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsedReward"
            }
          }
        }
      },
      "UsedReward": {
        "type": "object",
        "properties": {
          "rewardId": { "type": "string" },
          "name": { "type": "string" },
          "redeemedDate": { "type": "string", "format": "date-time" },
          "pointsUsed": { "type": "number" }
        }
      },
      "TierInfo": {
        "type": "object",
        "properties": {
          "currentTier": { "type": "string" },
          "nextTier": { "type": "string" },
          "pointsToNextTier": { "type": "number" },
          "tierExpirationDate": { "type": "string", "format": "date-time" }
        }
      },
      "RewardList": {
        "type": "object",
        "properties": {
          "rewards": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reward"
            }
          }
        }
      },
      "Reward": {
        "type": "object",
        "properties": {
          "rewardId": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "pointsRequired": { "type": "number" }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": ["id", "userId"],
        "properties": {
          "id": { "type": "string", "description": "Order identifier" },
          "userId": { "type": "string", "description": "User identifier" },
          "email": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "eventId": { "type": "string" },
          "storeId": { "type": "string" },
          "source": { "type": "string" },
          "discountAmount": { "type": "number" },
          "coupon": { "type": "string" },
          "shippingAmount": { "type": "number" },
          "orderDetail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderDetailItem"
            }
          }
        }
      },
      "OrderDetailItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "quantity": { "type": "integer" },
          "unitPrice": { "type": "number" },
          "estimatedShipDate": { "type": "string", "format": "date-time" }
        }
      },
      "UpdateOrderRequest": {
        "type": "object",
        "required": ["orderId", "status"],
        "properties": {
          "orderId": { "type": "string" },
          "status": { "type": "string", "enum": ["ship", "return", "cancel"] },
          "orderDetail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderDetailItem"
            },
            "description": "For partial operations only"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "status": { "type": "string" },
          "orderDetail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderDetailItem"
            }
          },
          "createdDate": { "type": "string", "format": "date-time" }
        }
      },
      "PointsBalance": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "totalPoints": { "type": "number" },
          "availablePoints": { "type": "number" },
          "pendingPoints": { "type": "number" }
        }
      },
      "ManagePointsRequest": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "description": "User identifier" },
          "actionId": { "type": "string" },
          "activity": { "type": "string", "enum": ["CREDIT", "DEBIT"] },
          "credit": { "type": "number" },
          "debit": { "type": "number" },
          "reason": { "type": "string" },
          "rewardId": { "type": "string" },
          "customId": { "type": "string" }
        }
      },
      "PointsTransaction": {
        "type": "object",
        "properties": {
          "transactionId": { "type": "string" },
          "userId": { "type": "string" },
          "activity": { "type": "string" },
          "points": { "type": "number" },
          "balance": { "type": "number" },
          "createdDate": { "type": "string", "format": "date-time" }
        }
      },
      "CartCalculationRequest": {
        "type": "object",
        "required": ["userId"],
        "properties": {
          "userId": { "type": "string" },
          "appliedPoints": { "type": "number" },
          "shippingAmount": { "type": "number" },
          "discountAmount": { "type": "number" },
          "productDetail": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "quantity": { "type": "integer" },
                "unitPrice": { "type": "number" },
                "autoDelivery": { "type": "boolean" }
              }
            }
          }
        }
      },
      "CartCalculationResponse": {
        "type": "object",
        "properties": {
          "potentialPoints": { "type": "number" },
          "appliedDiscount": { "type": "number" }
        }
      },
      "Segment": {
        "type": "object",
        "properties": {
          "segmentId": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "memberCount": { "type": "integer" }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "campaignId": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "startDate": { "type": "string", "format": "date-time" },
          "endDate": { "type": "string", "format": "date-time" },
          "status": { "type": "string" }
        }
      }
    }
  }
}