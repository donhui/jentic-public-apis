{
  "openapi": "3.0.0",
  "info": {
    "title": "5centsCDN - Transcoding",
    "description": "API for managing Transcoding in <a href=\"https://www.5centscdn.net\" target=\"_blank\">5centsCDN</a>",
    "version": "2.0.0",
    "contact": {
      "email": "help@5centscdn.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/5centscdnInc/5centsCDN-Transcoding/2.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://api.5centscdn.com/v2",
      "description": "5centsCDN API Server - Production"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Video Encoding Jobs",
      "description": "endpoints related to manage Video Encoding"
    },
    {
      "name": "File Transcoding Profiles",
      "description": "endpoints related to Global Transcode Preset Profiles"
    },
    {
      "name": "Reports -  Video Encoding Minutes",
      "description": "Reports for  Video Transcoding Minutes"
    }
  ],
  "paths": {
    "/transcoding/jobs": {
      "get": {
        "tags": [
          "Video Encoding Jobs"
        ],
        "summary": "List Active Video Encoding Jobs",
        "description": "List all active / pending video encoding job queue for the service",
        "operationId": "getEncodingJobs",
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "jobid": {
                        "type": "integer",
                        "format": "int32",
                        "description": "job id for the Video Encoding Job"
                      },
                      "id": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Zone ID for which the file is in"
                      },
                      "infile": {
                        "type": "string",
                        "description": "input file, relative path"
                      },
                      "outfile": {
                        "type": "string",
                        "description": "output file, relative path"
                      },
                      "percent": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Encoding Process percent"
                      },
                      "log": {
                        "type": "string",
                        "description": "Encoder output log"
                      },
                      "error": {
                        "type": "string",
                        "description": "Encoder Error log"
                      },
                      "profile": {
                        "type": "string",
                        "description": "The profile name to which the file is transcoded into"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transcoding/jobs/{zoneid}": {
      "post": {
        "tags": [
          "Video Encoding Jobs"
        ],
        "summary": "List Active Video Encoding Jobs by ZoneID",
        "description": "List all active / pending video encoding job queue for the zone",
        "operationId": "getEncodingJobsByZone",
        "parameters": [
          {
            "$ref": "#/components/parameters/zoneIdParam"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "\\\"%\\\" to list all files or search text to filter by filename"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "jobid": {
                        "type": "integer",
                        "format": "int32",
                        "description": "job id for the Video Encoding Job"
                      },
                      "id": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Zone ID for which the file is in"
                      },
                      "infile": {
                        "type": "string",
                        "description": "input file, relative path"
                      },
                      "outfile": {
                        "type": "string",
                        "description": "output file, relative path"
                      },
                      "percent": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Encoding Process percent"
                      },
                      "log": {
                        "type": "string",
                        "description": "Encoder output log"
                      },
                      "error": {
                        "type": "string",
                        "description": "Encoder Error log"
                      },
                      "profile": {
                        "type": "string",
                        "description": "The profile name to which the file is transcoded into"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transcoding/jobs/{zoneid}/{profileid}": {
      "post": {
        "tags": [
          "Video Encoding Jobs"
        ],
        "summary": "Add Video Encoding Jobs",
        "description": "Add a file encoding job",
        "operationId": "addEncodingJob",
        "parameters": [
          {
            "$ref": "#/components/parameters/zoneIdParam"
          },
          {
            "$ref": "#/components/parameters/profileIdParam"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "input file relative path"
                  },
                  "priority": {
                    "type": "integer",
                    "description": "encode job priority. 0 - High, 100 - Lowest"
                  },
                  "map": {
                    "description": "Video/Audio/Subtitle selection from input source",
                    "type": "object",
                    "properties": {
                      "video": {
                        "type": "integer",
                        "description": "video track index"
                      },
                      "audio": {
                        "type": "integer",
                        "description": "audio track index"
                      },
                      "subtitle": {
                        "type": "integer",
                        "description": "subtitle track index"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success or error message",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "string",
                      "description": "success/error"
                    },
                    "jobid": {
                      "type": "integer",
                      "description": "video encoding jobid"
                    },
                    "message": {
                      "type": "string",
                      "description": "error message, only if error occurs"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transcoding/jobs/retry/{jobid}": {
      "get": {
        "tags": [
          "Video Encoding Jobs"
        ],
        "summary": "Retry enoding job",
        "description": "Retry an encoding job, after fixing issues",
        "operationId": "retryEncodingJob",
        "parameters": [
          {
            "$ref": "#/components/parameters/jobIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "result": {
                        "type": "string",
                        "description": "success/error"
                      },
                      "message": {
                        "type": "string",
                        "description": "success/error message detail"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transcoding/jobs/cancel/{jobid}": {
      "get": {
        "tags": [
          "Video Encoding Jobs"
        ],
        "summary": "Cancel Enoding Job",
        "description": "Cancel an encoding job. Jobs can be cancelled only before its get processed.",
        "operationId": "cancelEncodingJob",
        "parameters": [
          {
            "$ref": "#/components/parameters/jobIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "result": {
                        "type": "string",
                        "description": "success/error"
                      },
                      "message": {
                        "type": "string",
                        "description": "success/error message detail"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transcoding/file/profiles": {
      "get": {
        "tags": [
          "Video Encoding Profiles"
        ],
        "summary": "List File Transcoding Profiles",
        "description": "List File Transcoding Profiles",
        "operationId": "ProfilesList",
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "string",
                      "example": "success"
                    },
                    "profiles": {
                      "$ref": "#/components/schemas/transcodeProfileList"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transcoding/file/profiles/defaults": {
      "post": {
        "tags": [
          "Video Encoding Profiles"
        ],
        "summary": "Create Global Auto Transcode Preset Profiles",
