    "/transcoding/file/mins/stats": {
      "post": {
        "tags": [
          "Reports -  Video Encoding Minutes"
        ],
        "summary": "Reports by Video Transcoding Minutes",
        "description": "Get reports of Video Transcoding Minutes",
        "operationId": "reportVideoTranscodingMinutes",
        "parameters": [
          {
            "$ref": "#/components/parameters/rParam"
          },
          {
            "$ref": "#/components/parameters/fParam"
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "string",
                      "example": "success"
                    },
                    "zones": {
                      "type": "array",
                      "items": {
                        "type": "integer",
                        "format": "int64"
                      }
                    },
                    "logs": {
                      "type": "array",
                      "items": {
