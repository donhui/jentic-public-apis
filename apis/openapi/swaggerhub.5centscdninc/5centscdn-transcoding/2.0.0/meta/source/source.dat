  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "transcodeProfileList": {
        "properties": {
          "0": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "serviceid": {
                "type": "integer"
              },
              "type": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "filemode": {
                "type": "string"
              },
              "settings": {
                "$ref": "#/components/schemas/settingsList"
              },
              "codec": {
                "type": "string"
              }
            }
          }
        }
      },
      "filtersList": {
        "properties": {
          "0": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "serviceid": {
                "type": "integer"
              },
              "type": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "settings": {
                "$ref": "#/components/schemas/settingFilterList"
              }
            }
          }
        }
      },
      "settingFilterList": {
        "properties": {
          "filter": {
            "type": "string"
          },
          "args": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "fontsize": {
                "type": "integer"
              },
              "fontcolor": {
                "type": "string"
              },
              "position": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "scale": {
                "type": "integer"
              }
            }
          }
        }
      },
      "settingsList": {
        "properties": {
          "name": {
            "type": "string"
          },
          "f": {
            "type": "string"
          },
          "cv": {
            "type": "string"
          },
          "sv": {
            "type": "string"
          },
          "svvalue": {
            "type": "string"
          },
          "crfv": {
            "type": "integer"
          },
          "bv": {
            "type": "integer"
          },
          "bvvalue": {
            "type": "integer"
          },
          "vpass": {
            "type": "integer"
          },
          "vprofile": {
            "type": "string"
          },
          "ca": {
            "type": "string"
          },
          "aca": {
            "type": "integer"
          },
          "ba": {
            "type": "integer"
          },
          "bavalue": {
            "type": "integer"
          },
          "ara": {
            "type": "integer"
          },
          "filemode": {
            "type": "string"
          }
        }
      },
      "logsList": {
        "properties": {
          "serverid": {
            "type": "integer",
            "format": "int64"
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "type": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          }
        }
      },
      "editFileTranscodingFilter": {
        "properties": {
          "args": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "description": "To specify Logo Url eg:http://example.com/logo.png"
              },
              "scale": {
                "type": "integer",
                "format": "int32",
                "description": "To specify scale values can be \tmin: 5, max: 150"
              },
              "position": {
                "type": "string",
                "description": "position of logo should be topleft,tocenter,topright,centerleft,center,centerright,bottomleft,bottomright,bottomcenter"
              },
              "text": {
                "type": "string",
                "description": "Enter watermark text"
              },
              "fontsize": {
                "type": "integer",
                "format": "int32",
                "description": "To specify text fontsize values can be \tmin: 8, max: 64 .eg: 16 ",
                "example": 16
              },
              "fontcolor": {
                "type": "string",
                "description": "To specify text font color for example #42A5F5"
              }
            }
          }
        }
      },
      "createFileTranscodingFilter": {
        "required": [
          "name",
          "_METHOD"
        ],
        "properties": {
          "_METHOD": {
            "type": "string",
            "description": "To cast request method POST to PUT",
            "example": "PUT"
          },
          "name": {
            "type": "string",
            "description": "Enter fliter name"
          },
          "filter": {
            "type": "string",
            "description": "Filter settings values can be overlay or drawtext"
          },
          "args": {
            "type": "object",
            "properties": {
              "overlay": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "To specify Logo Url eg: https://example.com/log.png"
                  },
                  "scale": {
                    "type": "integer",
                    "format": "int32",
                    "description": "To specify scale values can be \tmin: 5, max: 150"
                  },
                  "position": {
                    "type": "string",
                    "description": "position of logo should be topleft,tocenter,topright,centerleft,center,centerright,bottomleft,bottomright,bottomcenter"
                  }
                }
              },
              "drawtext": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "To specify watermark text"
                  },
                  "fontsize": {
                    "type": "integer",
                    "format": "int32",
                    "description": "To specify font size values can be \tmin: 8, max: 64 .eg: 16 ",
                    "example": 16
                  },
                  "fontcolor": {
                    "type": "string",
                    "description": "To specify text font color for example #42A5F5"
                  },
                  "position": {
                    "type": "string",
                    "description": "position of text should be topleft,tocenter,topright,centerleft,center,centerright,bottomleft,bottomright,bottomcenter"
                  }
                }
              }
            }
          }
        }
      },
      "createDefaultProfiles": {
        "properties": {
          "defaultprofiles": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64",
              "description": "defaultprofiles, Should be one of the profiles id from the GET /transcoding/file/profiles call"
            }
          }
        }
      },
      "createProfileCombined": {
        "required": [
          "name",
          "_METHOD"
        ],
        "properties": {
          "_METHOD": {
            "type": "string",
            "description": "To cast request method POST to PUT",
            "example": "PUT"
          },
          "filemode": {
            "type": "string",
            "description": "values can set Single or Combined",
            "example": "Single"
          },
          "name": {
            "type": "string",
            "description": "Enter profile name.<br>Each name should have minimum 3 chars."
          },
          "f": {
            "type": "string",
            "description": "Values can be mp4 or webm.",
            "example": "mp4"
          },
          "cv": {
            "type": "string",
            "description": "Values can be libx264,libx265 set Container Format is mp4. when Container Format is webm set value libvpx-vp9.",
            "example": "libx264"
          },
          "sv": {
            "type": "string",
            "description": "Resolution values can be 0,1,1080p,720p,576p,480p,360p or 240p",
            "example": 0
          },
          "svvalue": {
            "type": "string",
            "description": "value can be this format Width x Height set resolution quality is 0."
          },
          "crfv": {
            "type": "integer",
            "format": "int64",
            "description": "Constrained Quality values can be 18,24, or 28",
            "example": 28
          },
          "bv": {
            "type": "integer",
            "format": "int32",
            "description": "Values can be 0 or 1.<br>Set to 0 if Bitrate should be As Source.<br> Set to 1 if Bitrate should be As Defined."
          },
          "bvvalue": {
            "type": "integer",
            "format": "int64",
            "description": "values can be \tmin: 256, max: 4096"
          },
          "vpass": {
            "type": "integer",
            "format": "int32",
            "description": "Bitrate value should  be set  1 then set no of pass 1 or 2"
          },
          "vprofile": {
            "type": "string",
            "description": "Profile values can be disabled,baseline,main or high",
            "example": "disabled"
          },
          "vlevel": {
            "type": "string",
            "description": "Level. It can be set if  Profile is baseline,main or high. profile value is  set basline  value of level is 3.0 or 3.1. profile value is  set main  value of level is 3.1 or 4.0. profile value is  set high  value of level is 4.0,4.1 or 4.2"
          },
          "upscale": {
            "type": "string",
            "description": "Video upscaling value Y to set allow and N to to set disallow",
            "example": "Y"
          },
          "ca": {
            "type": "string",
            "description": "Codec. value can be set aac, libmp3lame,libvorbis or libopus",
            "example": "libmp3lame"
          },
          "aca": {
            "type": "integer",
            "format": "int32",
            "description": "Channels values can set 0,1 or 2",
            "example": 2
          },
          "ba": {
            "type": "integer",
            "format": "int32",
            "description": "Audio settings bitrate value can be 0 or 1."
          },
          "bavalue": {
            "type": "integer",
            "format": "int64",
            "description": "To specify audio bitrate  value can be \tmin: 48, max: 196",
            "example": 80
          },
          "ara": {
            "type": "integer",
            "format": "int64",
            "description": "Sample Rate can be set 44100 or 48000",
            "example": 44100
          },
          "tm": {
            "type": "string",
            "description": "To specify thumbnail Mode values can be disabled,fixed or interval.",
            "example": "disabled"
          },
          "tv": {
            "type": "string",
            "description": "To specify time in H:i:s format",
            "example": "00:00:00"
          },
          "filters": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32",
              "description": "filters, Should be one of the filter id from the GET /transcoding/file/filters call"
            }
          },
          "sourcevideo": {
            "type": "string",
            "description": "Filemode is Combined set Original Video Stream, Values can be Y or N. <br>Set to Y if Video Stream should be enabled.<br> Set to N if Video Stream should be disabled.",
            "example": "N"
          },
          "sourceaudio": {
            "type": "string",
            "description": "Filemode is Combined set Audio Streams, Values can be Y,O or A.",
            "example": "O"
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64",
              "description": "Filemode is Combined set defaultprofiles, Should be one of the profiles id from the GET /transcoding/file/profiles call"
            }
          }
        }
      },
