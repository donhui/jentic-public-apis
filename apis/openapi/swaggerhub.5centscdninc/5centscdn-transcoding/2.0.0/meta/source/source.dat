                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transcoding/file/profiles/new": {
      "post": {
        "tags": [
          "Video Encoding Profiles"
        ],
        "summary": "Create Transcoding Profiles",
        "description": "Create Transcoding Profiles",
        "operationId": "createTranscodingProfile",
