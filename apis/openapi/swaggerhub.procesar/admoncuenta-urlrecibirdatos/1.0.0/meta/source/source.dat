{
  "openapi": "3.0.1",
  "info": {
    "title": "Recibir Datos Trabajador URL",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para Recibir Datos Trabajador URL",
    "contact": {
      "email": "gerencia_arquitectura_software@inet.procesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar/Admoncuenta-urlRecibirDatos/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/837/registrotrabajadorurl"
    },
    {
      "url": "https://192.168.1.73:443/admoncuenta/v1/837/registrotrabajadorurl"
    }
  ],
  "tags": [
    {
      "name": "Recibir Datos Trabajador URL",
      "description": "Operaci\u00f3n para consular Recibir Datos Trabajador URL"
    }
  ],
  "paths": {
    "/recibirdatos": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Admocuenta - Recibir Datos Trabajador URL",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "datos",
        "tags": [
          "Recibir Datos Trabajador URL"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "Atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "enum": [
                "837"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "Atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "41"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "Atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "2",
                "4",
                "5",
                "6",
                "7",
                "8",
                "10",
                "11",
                "12",
                "14",
                "15"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para la consulta de CURP por datos del trabajador",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/recibirDatosRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/recibirDatosResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/recibirDatosResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "recibirDatosRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "recibirDatosRequest": {
        "required": [
          "curp",
          "nombre",
          "apellidoPaterno",
          "sexo",
          "fechaNacimiento",
          "cveEntidadnacimiento",
          "cveNacionalidad",
          "celular",
          "calle",
          "colonia",
          "ciudad",
          "entidadFederativa",
          "delegacionMunicipio",
          "codigoPostal",
          "pais",
          "cveAfore",
          "aplicacionOrigen",
          "solicitante",
          "latitud",
          "longitud"
        ],
        "type": "object",
        "properties": {
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Trabajador.",
            "example": "XXXX111111XXXXXX11"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguro Social.",
            "example": "12345678901"
          },
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Nombre del Trabajador o Menor de Edad.",
            "example": "Nombre Trabajador"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Apellido paterno del Trabajador o Menor de Edad.",
            "example": "apellidoPaterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Apellido Materno del Trabajador o Menor de Edad.",
            "example": "apellidoMaterno"
          },
          "sexo": {
            "pattern": "^([H,M,X]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo del Trabajador o Menor\n\nH - Hombre\n\nM - Mujer\n\nX - No Binario\n",
            "example": "H"
          },
          "fechaNacimiento": {
            "pattern": "^[0-3]{1}[0-9]{1}[/]{1}[0,1]{1}[0-9]{1}[/][0-2]{1}[0-9]{3}$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Fecha de Nacimiento del Trabajador o Menor de Edad.\n",
            "example": "02/05/2000"
          },
          "cveEntidadnacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "De acuerdo a la Clave letras del Cat\u00e1logo Entidad de Nacimiento.\n\n|DESCRIPCI\u00d3N  |CLAVE LETRAS|\n|:-------------|:----------------:|\n|Aguascalientes  |AS         |\n|Baja california norte  |BC      |\n|Baja california sur  |BS      |\n|Campeche  |CC                  |\n|Coahuila  |CL                  |\n|Colima|CM                       |\n|Chiapas  |CS                  |\n|Chihuahua  |CH                  |\n|Mexico D.F.  |DF              |\n|Durango  |DG                  |\n|Guanajuato  |GT                  |\n|Guerrero  |GR                  |\n|Hidalgo  |HG                  |\n|Jalisco  |JC                  |\n|Estado de M\u00e9xico  |MC          |\n|Michoac\u00e1n  |MN                  |\n|Morelos  |MS                  |\n|Nayarit  |NT                  |\n|Nuevo Le\u00f3n  |NL                  |\n|Oaxaca  |OC                      |\n|Puebla  |PL                      |\n|Quer\u00e9taro  |QT                  |\n|Quintana Roo  |QR              |\n|San Luis Potos\u00ed|  SP           |\n|Sinaloa  |SL                  |\n|Sonora  |SR                      |\n|Tabasco  |TC                  |\n|Tamaulipas  |TS                  |\n|Tlaxcala  |TL                  |\n|Veracruz  |VZ                  |\n|Yucat\u00e1n  |YN                  |\n|Zacatecas  |ZS                  |\n|Extranjeros  |NE|\n",
            "example": "DF"
          },
          "cveNacionalidad": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Nacionalidad de Trabajador o Menor de Edad.",
            "example": "MEX"
          },
          "telefono": {
            "pattern": "^([0-9]{10})$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "example": "5555555555",
            "description": "N\u00famero de tel\u00e9fono del Trabajador o Tutor."
          },
          "email": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "example": "correo@correo.com",
            "description": "Correo electr\u00f3nico del Trabajador o Tutor."
          },
          "celular": {
            "pattern": "^([0-9]{10})$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "example": "5555555555",
            "description": "N\u00famero de celular del Trabajador o Tutor."
          },
          "calle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "example": "calle",
            "description": "Calle del domicilio."
          },
          "numInterior": {
            "pattern": "^([0-9]{15})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "example": "55",
            "description": "N\u00famero interior."
          },
          "numExterior": {
            "pattern": "^([0-9]{15})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "example": "55",
            "description": "N\u00famero Exterior."
          },
          "colonia": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "example": "colonia",
            "description": "Colonia del domicilio."
          },
          "ciudad": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "example": "ciudad",
            "description": "Ciudad del domicilio."
          },
          "entidadFederativa": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "02",
            "description": "De acuerdo a la clave n\u00fameros del Cat\u00e1logo de Entidad Federativa\n\n|CLAVE/INDICADOR  |DESCRIPCI\u00d3N|\n|:-------------|:----------------:|\n|02 |AGUASCALIENTES            |\n|03 |BAJA CALIFORNIA                 |\n|04 |BAJA CALIFORNIA SUR             |\n|05 |CAMPECHE                        |\n|06 |COAHUILA DE ZARAGOZA            |\n|07 |COLIMA                          |\n|08 |CHIAPAS                         |\n|09 |CHIHUAHUA                       |\n|10 |CIUDAD DE MEXICO                |\n|11 |DURANGO                         |\n|12 |GUANAJUATO                      |\n|13 |GUERRERO                        |\n|14 |HIDALGO                         |\n|15 |JALISCO                         |\n|16 |MEXICO                          |\n|17 |MICHOACAN DE OCAMPO             |\n|18 |MORELOS                         |\n|19 |NAYARIT                         |\n|20 |NUEVO LEON                      |\n|21 |OAXACA                          |\n|22 |PUEBLA                          |\n|23 |QUERETARO                       |\n|24 |QUINTANA ROO                    |\n|25 |SAN LUIS POTOSI                 |\n|26 |SINALOA                         |\n|27 |SONORA                          |\n|28 |TABASCO                         |\n|29 |TAMAULIPAS                      |\n|30 |TLAXCALA                        |\n|31 |VERACRUZ DE IGNACIO DE LA LLAVE |\n|32 |YUCATAN                         |\n|33 |ZACATECAS                       |\n|34 |EXTRANJERO                      |\n"
          },
          "delegacionMunicipio": {
            "type": "string",
            "minLength": 5,
            "maxLength": 5,
            "example": "delegacionMunicipio",
            "description": "De acuerdo a la clave del cat\u00e1logo de delegaci\u00f3n o municipio."
          },
          "codigoPostal": {
            "pattern": "^([0-9]{5})$",
            "type": "string",
            "minLength": 5,
            "maxLength": 5,
            "example": "55555",
            "description": "C\u00f3digo postal."
          },
          "pais": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3,
            "example": "MEX",
            "description": "De acuerdo a  clave de pais de hasta 3 posiciones de acuerdo a Cat\u00e1logo de pa\u00eds\n\n|CLAVE  |DESCRIPCI\u00d3N|\n|:-------------|:----------------:|\n|2  |ESTADOS UNIDOS DE AMERICA    |\n|15  |ALEMANIA    |\n|24  |ARGENTINA     |\n|40  |BOLIVIA     |\n|51  |CANAD    |\n|53  |CHILE     |\n|63  |COSTA RICA   |\n|75  |ESPA\u00d1A    |\n|180|REINO UNIDO     |\n|181|PA\u00cdSES BAJOS (HOLANDA)| \n|182|MEXICO                       |\n|183|ITALIA                       |\n|184|AUSTRALIA                    |\n|185|BELICE                       |\n|186|BRASIL                       |\n|187|COLOMBIA                     |\n|188|FRANCIA                      |\n|189|ISRAEL                       |\n|190|PAN\u00c1MA                       |\n|191|PUERTO RICO                  |\n|192|SUIZA                        |\n"
          },
          "curpTutor": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Tutor que solicita el registro del menor. Obligatorio para solicitante 02.",
            "example": "XXXX111111XXXXXX11"
          },
          "cveAfore": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "500",
            "description": "Clave de Afore."
          },
          "idActividadEconomica": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "01",
            "description": "Clave de Afore."
          },
          "aplicacionOrigen": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "06",
            "description": "Identificador de la aplicaci\u00f3n de origen.\n\n06 Registro en l\u00ednea URL.\n"
          },
          "solicitante": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "01",
            "description": "Tipo de Solicitante:\n\n01 - Titular\n\n02 - Menor\n"
          },
          "cveParentesco": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "06",
            "description": "Este campo s\u00f3lo ser\u00e1 obligatorio cuando solicitante = 02. Los valores que se podr\u00e1n enviar son:\n\n04 MADRE\n\n05 PADRE\n"
          },
          "nickname": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "example": "Nickname",
            "description": "Nickname del menor de edad."
          },
          "ocupacion": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "A1",
            "description": "Clave asociada al cat\u00e1logo de ocuapci\u00f3n trabajador."
          },
          "nivelEstudios": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "A2",
            "description": "Clave asociada al cat\u00e1logo de nivel de estudios."
          },
          "latitud": {
            "pattern": "^[+-]?(([1-8]?[0-9])(\\.[0-9]{1,6})?|90(\\.0{1,6})?)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 25,
            "example": "19.219876",
            "description": "Coordenadas de localizaci\u00f3n de la sucursal en grados decimales."
          },
          "longitud": {
            "pattern": "^[+-]?((([1-9]?[0-9]|1[0-7][0-9])(\\.[0-9]{1,6})?)|180(\\.0{1,6})?)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 25,
            "example": "-99.098288",
            "description": "Coordenadas de localizaci\u00f3n de la sucursal en grados decimales."
          },
          "beneficiarios": {
            "type": "array",
            "items": {
              "required": [
                "apellidoPaternoDeBeneficiario",
                "nombreDeBeneficiario",
                "curpDeBeneficiario",
                "porcentajeDeBeneficiario"
              ],
              "type": "object",
              "properties": {
                "apellidoPaternoDeBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "example": "apellidoPaternoDeBeneficiario",
                  "description": "Apellido Paterno de Beneficiario"
                },
                "apellidoMaternoDeBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "example": "apellidoMaternoDeBeneficiario",
                  "description": "Apellido Materno de Beneficiario"
                },
                "nombreDeBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "example": "nombreDeBeneficiario",
                  "description": "Nombre de Beneficiario"
                },
                "curpDeBeneficiario": {
                  "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
                  "type": "string",
                  "minLength": 18,
                  "maxLength": 18,
                  "description": "Curp Beneficiario.",
                  "example": "XXXX111111XXXXXX11"
                },
                "porcentajeDeBeneficiario": {
                  "pattern": "^[0-9]{3}$",
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 3,
                  "description": "Porcentaje Beneficiario",
                  "example": "100"
                }
              }
            }
          }
        }
      },
      "recibirDatosResponse": {
        "required": [
          "resultadoOperacion",
          "diagnosticoOperacion",
          "curp",
          "solicitante"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "C\u00f3digo de la respuesta de la transacci\u00f3n: \n\n01 = Aceptada\n\n02 = Rechazada\n\n60 = Aceptado asignado en la misma Afore\n\n61 = Aceptado asignado en diferente Afore e inicia proceso de Traspaso.\n",
            "example": "01"
          },
          "diagnosticoOperacion": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "J69",
            "description": "Motivo de Rechazo, en caso de que la respuesta del servicio sea 02. Valor de acuerdo con Cat\u00e1logo. \n\n##### Si resultado de la operaci\u00f3n es 01 se enviar\u00e1 000.\n\n\n_001  Parentesco inv\u00e1lido_    \n\n_002  Nickname requerido_    \n\n_003  Clave de aplicaci\u00f3n inv\u00e1lida._    \n\n_03L  La notificaci\u00f3n de Expediente fue rechazada._\n\n_005  NSS Inv\u00e1lido_    \n\n_010  La CURP no existe en RENAPO_    \n\n_013   Captaci\u00f3n de la AFORE sobrepasada._    \n\n_014  Trabajador ya afiliado_    \n\n_015  NSS no se encuentra en PROCANASE_    \n\n_017  La CURP est\u00e1 duplicada en BDNSAR_    \n\n_022  la CURP no est\u00e1 vigente en RENAPO_    \n\n_034  NSS se encuentra con Unificaci\u00f3n concluida_    \n\n_03H  Cuenta en Proceso de Registro M\u00f3vil de IMSS Puro_    \n\n_072  Cuenta en Proceso de Traspasos ISSSTE_    \n\n_297  Cuenta en Proceso de Selecci\u00f3n de SIEFORE_    \n\n_438  Cuenta en Proceso de Transferencia Extempor\u00e1nea_    \n\n_493  CURP diferente en Base de Datos_    \n\n_521  No existe una solicitud de recepci\u00f3n de im\u00e1genes exitosa para CURP enviada._    \n\n_528  Trabajador en proceso de traspasos A-A  _  \n\n_528  Cuenta en Proceso de Traspaso Afore-Afore_    \n\n_529  Cuenta en Proceso de Traspaso SAR 92_    \n\n_530  Cuenta en Proceso de Tranferencia Acreditados_    \n\n_539  Cuenta en Proceso de Tramite Judicial_    \n\n_573  Cuenta en Proceso de Unificaci\u00f3n de Cuentas_    \n\n_574  Cuenta en Proceso de Separaci\u00f3n de Cuentas_    \n\n_584  Tel\u00e9fono Inv\u00e1lido._    \n\n_783  Apellido Paterno PROCANASE y de Solicitud no coinciden._    \n\n_784  Apellido Materno PROCANASE y de Solicitud no coinciden._    \n\n_792  Nombre del trabajador inv\u00e1lido_    \n\n_815  Cuenta en Proceso de Acreditaci\u00f3n de Bono ISSSTE_    \n\n_815  Cuenta en Proceso de Redenci\u00f3n Bono Anual ISSSTE_    \n\n_815  Cuenta en Proceso de Devoluci\u00f3n de Pagos en exceso INFONAVIT_    \n\n_815  Cuenta en Proceso de Devoluci\u00f3n de Excedentes Acreditados_    \n\n_815  Cuenta en Proceso de Devoluci\u00f3n de Excedentes 43 bis&_  \n\n_861  Trabajador asignado en la BDNSAR o registrado en CANASE con diferente NSS y misma CURP_    \n\n_960  Cuenta en Proceso de Fusi\u00f3n_    \n\n_973  Verificaci\u00f3n de CURP no atendida por RENAPO_    \n\n_986  Cuenta en Proceso de Aportaciones subsecuentes 43 bis&_    \n\n_A14  Cuenta en Proceso de Transferencias FOVISSSTE_    \n\n_B44  Datos ra\u00edz CURP notificados por RENAPO no coinciden con lo enviado por la AFORE_    \n\n_B46  La nacionalidad del trabajador enviada por la AFORE no existe dentro del cat\u00e1logo de nacionalidades_\n\n_C47  Cuenta en Proceso de Modificaci\u00f3n de datos No Afiliados_\n\n_C47  Cuenta en Proceso de Actualizaci\u00f3n de Datos del Expediente de Identificaci\u00f3n_\n\n_D01  Cuenta en Proceso de Devoluci\u00f3n de Pagos en exceso IMSS_\n\n_D02  Cuenta en Proceso de Retiros Parciales_\n\n_D03  Cuenta en Proceso de Transferencia de Recursos_\n\n_D04  Cuenta en Proceso de Disposici\u00f3n de Recursos_  \n\n_D05  Cuenta en Proceso de Disposici\u00f3n Retiro Programado_\n\n_D06  Cuenta en Proceso de Retiros Parciales ISSSTE_\n\n_D07  Cuenta en Proceso de Retiros Totales ISSSTE_  \n\n_D08  Cuenta en Proceso de Notificaci\u00f3n de Saldos Previos IMSS_\n\n_D09  Cuenta en Proceso de Notificaci\u00f3n de Saldos Previos ISSSTE_\n\n_D10  Cuenta en Proceso de Transferencia de Recursos ISSSTE_\n\n_D11  Cuenta en Proceso de Solicitud de saldo en garantia 43 bis_\n\n_D12  Cuenta en Proceso de Transferencia Anualidades Garantizadas_    \n\n_D56  Datos de beneficiarios del trabajador incompletos._\n\n_D59  Datos del domicilio particular del trabajador incompletos._\n\n_D60  Ocupaci\u00f3n o Profesi\u00f3n inv\u00e1lida._\n\n_D61  Actividad o Giro del negocio inv\u00e1lido._\n\n_D62  Nivel de Estudio inv\u00e1lido._\n\n_F01  El Tel\u00e9fono Celular recibido pertenece a otro Trabajador._\n\n_F67  Cuenta en Proceso de Registro M\u00f3vil de Ahorradores Asignados_\n\n_F89  La solicitud no corresponde a la edad del menor de edad_\n\n_F90  Tutor no se encuentra afiliado_\n\n_H49  La CURP se encuentra en persona pendiente por posible duplicidad_\n\n_H75  La CURP del tutor es requerida_\n\n_J68   Su cuenta de correo no es v\u00e1lida._    \n\n_J69  La CURP corresponde a un menor de edad_\n\n_D13  Cuenta en Proceso de Devolucion de Saldos Excedentes FOVISSSTE_\n"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Trabajador/Menor de Edad a consultar.",
            "example": "XXXX111111XXXXXX11"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguro Social.",
            "example": "12345678901"
          },
          "solicitante": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "01",
            "description": "Tipo de Solicitante:\n\n01 - Titular\n\n02 - Menor\n"
          },
          "curpTutor": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Tutor que solicita el registro del menor.",
            "example": "XXXX111111XXXXXX11"
          },
          "tipoAfiliacion": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave para tipo de Afiliaci\u00f3n, en donde: \n\n01 - Asignado\n\n02 - No afiliado\n\n03 - Menor de Edad\n\n04 - IMSS Puro.\n",
            "example": "02"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curpTutor\": \"123456789098765\""
          }
        }
      }
    }
  }
}