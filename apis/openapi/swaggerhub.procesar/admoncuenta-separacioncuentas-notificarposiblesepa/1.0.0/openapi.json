  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "notificarPosibleSeparacionRequest": {
        "required": [
          "nssAsegurado",
          "primerApellidoAsegurado",
          "nombreAsegurado",
          "fechaNacimientoAsegurado",
          "sexoAsegurado",
          "entidadNacimientoAsegurado",
          "folioTramite",
          "fechaExpedicion",
          "cadenaOriginal"
        ],
        "type": "object",
        "properties": {
          "nssAsegurado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguridad Social del Asegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS",
            "example": "12345678901"
          },
          "curpAsegurado": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del Asegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS",
            "example": "XXXX111111XXXXXX11"
          },
          "primerApellidoAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno del Asegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS",
            "example": "Perez"
          },
          "segundoApellidoAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno del Asegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS",
            "example": "Perez"
          },
          "nombreAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre(s) del Asegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS",
            "example": "Juan"
          },
          "fechaNacimientoAsegurado": {
            "pattern": "^([1-9][0-9][0-9][0-9](01|02|03|04|05|06|07|08|09|10|11|12)[0-9][0-9])$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de nacimiento del Asegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS, \n\nmayor a 1900 y menor o igual a la fecha del proceso. AAAAAMMDD\n",
            "example": "20201201"
          },
          "sexoAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo del Asegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS:\n\n1=M (masculino)\n\n2=F (femenino)\n",
            "example": "1"
          },
          "entidadNacimientoAsegurado": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Entidad de Nacimiento delAsegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS\n\nSeg\u00fan Catalogo General Clave de las Entidades Federativas\n",
            "example": "01"
          },
          "telefonoAsegurado": {
            "pattern": "^([0-9]{10})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 10,
            "description": "Tel\u00e9fono del Asegurado que solicito una aclaraci\u00f3n de su NSS ante el IMSS",
            "example": "5555555555"
          },
          "correoElectronicoAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Correo electr\u00f3nico del Asegurado",
            "example": "correo@correo.com"
          },
          "folioTramite": {
            "type": "string",
            "minLength": 1,
            "maxLength": 30,
            "description": "Folio \u00fanico de identificaci\u00f3n de la solicitud del tr\u00e1mite de correcci\u00f3n datos.",
            "example": "123456789012345678921324567893"
          },
          "fechaExpedicion": {
            "pattern": "^([0-9]{8})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 8,
            "description": "Fecha de conclusi\u00f3n del tr\u00e1mite de correcci\u00f3n de datos.",
            "example": "20201201"
          },
          "cadenaOriginal": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Cadena original de seguridad \u00fanica de identifiaci\u00f3n \n\nde la solicitud del tr\u00e1mite de correcci\u00f3n de datos. \n",
            "example": "CADENA ORIGINAL"
          },
          "nrpAsegurados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/nrpAsegurado"
            }
          },
          "nssInvolucrados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/nssInvolucrado"
            }
          }
        }
      },
      "notificarPosibleSeparacionResponse": {
        "required": [
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultados de Operaci\u00f3n\n\n01 Solicitud Aceptada                 \n\n02 Solicitud Rechazada\n",
            "example": "01"
          },
          "diagnosticoProceso": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "000",
            "description": "Seg\u00fan Cat\u00e1logo General, Tabla de Motivos de Rechazo de Registro. \n\nEste campo ser\u00e1 notificado en ceros 000 \n\ncuando el resultado de la operaci\u00f3n sea 01 Aceptado\n"
          },
          "folioRespuesta": {
            "type": "string",
            "minLength": 1,
            "maxLength": 25,
            "description": "Folio de respuesta que proporcionar\u00e1 el servicio, y que estar\u00e1 configurado de la siguiente forma:\n\nR o A: si es una solicitud rechazada se notificar\u00e1 R, y cuando sea una solicitud aceptada se notificar\u00e1 A\n\nFecha de env\u00edo de la solicitud en formato: AAAAMMDD\n\nNSS del Asegurado\n\nConsecutivo del d\u00eda a 5 posiciones\n\nEjemplo:\n\nA202306050197777021100001\n\nR202306050197777021100001\n",
            "example": "A202306050197777021100001"
          },
          "nssInvolucrados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/nssInvolucradoResp"
            }
          }
        }
      },
      "nrpAsegurado": {
        "required": [
          "nrpAsegurado"
        ],
        "type": "object",
        "properties": {
          "nrpAsegurado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Registro Patronal asociado al NSS invadido",
            "example": "12345678901"
          },
          "fechaInscripcionPeriodoNrp": {
            "pattern": "^([1-9][0-9][0-9][0-9](01|02|03|04|05|06|07|08|09|10|11|12)[0-9][0-9])$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Inscripci\u00f3n del NRP en formato AAAAAMMDD",
            "example": "20201201"
          },
          "fechaBajaPeriodoNrp": {
            "pattern": "^([1-9][0-9][0-9][0-9](01|02|03|04|05|06|07|08|09|10|11|12)[0-9][0-9])$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Baja del NRP en formato AAAAAMMDD",
            "example": "20201201"
          }
        }
      },
      "nssInvolucrado": {
        "required": [
          "nssInvolucrado",
          "claveTipoRegularizacion"
        ],
        "type": "object",
        "properties": {
          "nssInvolucrado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguridad Social Involucrado en la Separaci\u00f3n de Cuenta que no pertenece al Asegurado",
            "example": "12345678901"
          },
          "claveTipoRegularizacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo de regularizaci\u00f3n del NSS involucrado:\n\n1 Cancelado por duplicidad\n\n2 Corresponde a un hom\u00f3nimo\n\n3 No existe en CANASE\n\n4 Corresponde a otro asegurado\n\n5 Correci\u00f3n de nombre\n\n6 Correcci\u00f3n de datos estad\u00edsticos\n",
            "example": "1"
          }
        }
      },
      "nssInvolucradoResp": {
        "type": "object",
        "properties": {
          "resultadoOperacionNss": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultados de Operaci\u00f3n\n\n01 Solicitud Aceptada                 \n\n02 Solicitud Rechazada\n",
            "example": "02"
          },
          "diagnosticoProcesoNss": {
            "pattern": "^([0-9]{3})?$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Seg\u00fan Cat\u00e1logo General, Tabla de Motivos de Rechazo de Registro. \n\nEste campo ser\u00e1 notificado en ceros 000 cuando el resultado de la operaci\u00f3n sea 01 Aceptado\n",
            "example": "000"
          },
          "nssInvolucrado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguridad Social Involucrado en la Separaci\u00f3n de Cuenta que no pertenece al Asegurado",
            "example": "12345678901"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  }
}