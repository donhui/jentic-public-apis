{
  "openapi": "3.0.1",
  "info": {
    "title": "Separacion Cuentas - Notificar Posible Separacion",
    "description": "Especificación técnica de servicio para Notificar Posible Separacion",
    "contact": {
      "email": "gerencia_arquitectura_software@inet.procesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar/Admoncuenta-SeparacionCuentas-NotificarPosibleSeparacion/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/1019/separacioncuenta/posibleseparacion"
    }
  ],
  "paths": {
    "/notificacion": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Admoncuenta - Separacion Cuentas - Notificar Posible Separacion",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si éstos no llevaran valor, por tanto, no se aceptan campos/etiquetas vacías.",
        "operationId": "datos",
        "tags": [
          "Notificar Posible Separacion"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "Atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "enum": [
                "1019"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "Atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "53"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "Atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "53"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para Notificar Posible Separacion",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/notificarPosibleSeparacionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacción exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/notificarPosibleSeparacionResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/notificarPosibleSeparacionResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petición enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no está de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no válidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje genérico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "notificarPosibleSeparacionRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticación básica, el usuario y contraseña es personalizado por AFORE."
      }
    },
    "schemas": {
      "notificarPosibleSeparacionRequest": {
        "required": [
          "nssAsegurado",
          "primerApellidoAsegurado",
          "nombreAsegurado",
          "fechaNacimientoAsegurado",
          "sexoAsegurado",
          "entidadNacimientoAsegurado",
          "folioTramite",
          "fechaExpedicion",
          "cadenaOriginal"
        ],
        "type": "object",
        "properties": {
          "nssAsegurado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "Número de Seguridad Social del Asegurado que solicito una aclaración de su NSS ante el IMSS",
            "example": "12345678901"
          },
          "curpAsegurado": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del Asegurado que solicito una aclaración de su NSS ante el IMSS",
            "example": "XXXX111111XXXXXX11"
          },
          "primerApellidoAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno del Asegurado que solicito una aclaración de su NSS ante el IMSS",
            "example": "Perez"
          },
          "segundoApellidoAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno del Asegurado que solicito una aclaración de su NSS ante el IMSS",
            "example": "Perez"
          },
          "nombreAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre(s) del Asegurado que solicito una aclaración de su NSS ante el IMSS",
            "example": "Juan"
          },
          "fechaNacimientoAsegurado": {
            "pattern": "^([1-9][0-9][0-9][0-9](01|02|03|04|05|06|07|08|09|10|11|12)[0-9][0-9])$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de nacimiento del Asegurado que solicito una aclaración de su NSS ante el IMSS, \n\nmayor a 1900 y menor o igual a la fecha del proceso. AAAAAMMDD\n",
            "example": "20201201"
          },
          "sexoAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo del Asegurado que solicito una aclaración de su NSS ante el IMSS:\n\n1=M (masculino)\n\n2=F (femenino)\n",
            "example": "1"
          },
          "entidadNacimientoAsegurado": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Entidad de Nacimiento delAsegurado que solicito una aclaración de su NSS ante el IMSS\n\nSegún Catalogo General Clave de las Entidades Federativas\n",
            "example": "01"
          },
          "telefonoAsegurado": {
            "pattern": "^([0-9]{10})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 10,
            "description": "Teléfono del Asegurado que solicito una aclaración de su NSS ante el IMSS",
            "example": "5555555555"
          },
          "correoElectronicoAsegurado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Correo electrónico del Asegurado",
            "example": "correo@correo.com"
          },
          "folioTramite": {
            "type": "string",
            "minLength": 1,
            "maxLength": 30,
            "description": "Folio único de identificación de la solicitud del trámite de corrección datos.",
            "example": "123456789012345678921324567893"
          },
          "fechaExpedicion": {
            "pattern": "^([0-9]{8})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 8,
            "description": "Fecha de conclusión del trámite de corrección de datos.",
            "example": "20201201"
          },
          "cadenaOriginal": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Cadena original de seguridad única de identifiación \n\nde la solicitud del trámite de corrección de datos. \n",
            "example": "CADENA ORIGINAL"
          },
          "nrpAsegurados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/nrpAsegurado"
            }
          },
          "nssInvolucrados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/nssInvolucrado"
            }
          }
        }
      },
      "notificarPosibleSeparacionResponse": {
        "required": [
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultados de Operación\n\n01 Solicitud Aceptada                 \n\n02 Solicitud Rechazada\n",
            "example": "01"
          },
          "diagnosticoProceso": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "000",
            "description": "Según Catálogo General, Tabla de Motivos de Rechazo de Registro. \n\nEste campo será notificado en ceros 000 \n\ncuando el resultado de la operación sea 01 Aceptado\n"
          },
          "folioRespuesta": {
            "type": "string",
            "minLength": 1,
            "maxLength": 25,
            "description": "Folio de respuesta que proporcionará el servicio, y que estará configurado de la siguiente forma:\n\nR o A: si es una solicitud rechazada se notificará R, y cuando sea una solicitud aceptada se notificará A\n\nFecha de envío de la solicitud en formato: AAAAMMDD\n\nNSS del Asegurado\n\nConsecutivo del día a 5 posiciones\n\nEjemplo:\n\nA202306050197777021100001\n\nR202306050197777021100001\n",
            "example": "A202306050197777021100001"
          },
          "nssInvolucrados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/nssInvolucradoResp"
            }
          }
        }
      },
      "nrpAsegurado": {
        "required": [
          "nrpAsegurado"
        ],
        "type": "object",
        "properties": {
          "nrpAsegurado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "Número de Registro Patronal asociado al NSS invadido",
            "example": "12345678901"
          },
          "fechaInscripcionPeriodoNrp": {
            "pattern": "^([1-9][0-9][0-9][0-9](01|02|03|04|05|06|07|08|09|10|11|12)[0-9][0-9])$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Inscripción del NRP en formato AAAAAMMDD",
            "example": "20201201"
          },
          "fechaBajaPeriodoNrp": {
            "pattern": "^([1-9][0-9][0-9][0-9](01|02|03|04|05|06|07|08|09|10|11|12)[0-9][0-9])$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Baja del NRP en formato AAAAAMMDD",
            "example": "20201201"
          }
        }
      },
      "nssInvolucrado": {
        "required": [
          "nssInvolucrado",
          "claveTipoRegularizacion"
        ],
        "type": "object",
        "properties": {
          "nssInvolucrado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "Número de Seguridad Social Involucrado en la Separación de Cuenta que no pertenece al Asegurado",
            "example": "12345678901"
          },
          "claveTipoRegularizacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo de regularización del NSS involucrado:\n\n1 Cancelado por duplicidad\n\n2 Corresponde a un homónimo\n\n3 No existe en CANASE\n\n4 Corresponde a otro asegurado\n\n5 Correción de nombre\n\n6 Corrección de datos estadísticos\n",
            "example": "1"
          }
        }
      },
      "nssInvolucradoResp": {
        "type": "object",
        "properties": {
          "resultadoOperacionNss": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultados de Operación\n\n01 Solicitud Aceptada                 \n\n02 Solicitud Rechazada\n",
            "example": "02"
          },
          "diagnosticoProcesoNss": {
            "pattern": "^([0-9]{3})?$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Según Catálogo General, Tabla de Motivos de Rechazo de Registro. \n\nEste campo será notificado en ceros 000 cuando el resultado de la operación sea 01 Aceptado\n",
            "example": "000"
          },
          "nssInvolucrado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "Número de Seguridad Social Involucrado en la Separación de Cuenta que no pertenece al Asegurado",
            "example": "12345678901"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Separacion Cuentas - Notificar Posible Separacion",
      "description": "Operación para Notificar Posible Separacion"
    }
  ]
}