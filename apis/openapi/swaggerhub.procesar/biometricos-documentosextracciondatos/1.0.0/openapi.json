{
  "openapi": "3.0.1",
  "info": {
    "title": "Documentos Extracci\u00f3n de Datos",
    "description": "Servicio que extrae datos de los documentos. ",
    "contact": {
      "email": "GERENCIA_ARQUITECTURA_SOFTWARE@inet.prcesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar/Biometricos-DocumentosExtraccionDatos/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/procesar-facial"
    }
  ],
  "tags": [
    {
      "name": "Documentos Extracci\u00f3n de Datos",
      "description": "Operaci\u00f3n para extraer informaci\u00f3n de documento."
    }
  ],
  "paths": {
    "/extraedatosdoc": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Biom\u00e9tricos - Documentos Extracci\u00f3n de Datos",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "extraeInformacion",
        "tags": [
          "Documentos Extracci\u00f3n de Datos"
        ],
        "parameters": [
          {
            "name": "BusinessId",
            "in": "header",
            "description": "atributo http-header Token \u00fanico por AFORE, con vigencia de un a\u00f1o.",
            "required": true,
            "schema": {
              "type": "string",
              "example": "5312127WK5T79u5mIzjIXXi2oI9Fglmgivv7RAJ7izyj9tUyQ88DeaEqA2\n"
            }
          },
          {
            "name": "BusinessClient",
            "in": "header",
            "description": "atributo http-header Clave de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "530",
                "534",
                "538",
                "544",
                "550",
                "552",
                "556",
                "562",
                "568",
                "578"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para extrar informaci\u00f3n de Documentos.",
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/extraerInformacionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/extraerInformacionResponse"
                },
                "examples": {
                  "OK": {
                    "summary": "Extracci\u00f3n correcta de documentos.",
                    "value": "{ \"curp\": \"PESP851206HDFRLL01\",\n  \"resultadoOperacion\": \"01\",\n  \"diagnosticoOperacion\": \"000\",\n  \"anioRegistro\": \"2004\",\n  \"claveElector\": \"PRSLPL85120609H200\",\n  \"anioEmision\": \"2020\",\n  \"apellidoPaterno\": \"PEREZ\",\n  \"apellidoMaterno\": \"SILVA\",\n  \"nombre\": \"PLINIO\",\n  \"emisionesPrevias\": \"04\",\n  \"cic\": \"205122693\",\n  \"ocr\": \"1675067762022\"\n  }\n"
                  },
                  "error": {
                    "summary": "Error al extraer documentos.",
                    "value": "{\"resultadoOperacion\":\"02\",\"diagnosticoOperacion\":\"906\", \"error-validacion\": [ \"Formato de clave AFORE incorrecto\", \"Formato de CURP incorrecto\" ] }\n"
                  }
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "extraerInformacionRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "extraerInformacionRequest": {
        "required": [
          "input",
          "files"
        ],
        "type": "object",
        "properties": {
          "input": {
            "$ref": "#/components/schemas/input"
          },
          "files": {
            "type": "string",
            "format": "binary",
            "description": "Atributo file : viaja como part, Arreglo de im\u00e1genes en archivo binario.\n",
            "example": "images.bmp"
          }
        }
      },
      "input": {
        "required": [
          "curp",
          "nombre",
          "apellidoPaterno",
          "cveAfore",
          "cveImagen",
          "enrolar",
          "operacion"
        ],
        "type": "object",
        "description": "Atributo input : viaja como part, cadena en formato tipo JSON\n",
        "properties": {
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del trabajador.\n",
            "example": "AAAA900909XXXXXX09"
          },
          "nombre": {
            "type": "string",
            "minLength": 0,
            "maxLength": 50,
            "example": "Nombre Trabajador",
            "description": "Nombre del trabajador.\n"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 0,
            "maxLength": 50,
            "example": "Apellido Paterno",
            "description": "Apellido paterno del trabajador.\n"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 0,
            "maxLength": 50,
            "example": "Apellido Materno",
            "description": "Apellido materno del trabajador.\n"
          },
          "cveAfore": {
            "pattern": "^[0-9]{3}",
            "type": "string",
            "minLength": 0,
            "maxLength": 3,
            "example": "530",
            "description": "Clave de la afore.\n"
          },
          "cveImagen": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[0-9]{2}",
              "minLength": 2,
              "maxLength": 2,
              "example": [
                "01",
                "02",
                "03"
              ]
            },
            "description": "Elemento de arreglo: clave de la imagen.\n\n_01 Selfie_\n\n_02 INE Anverso_\n\n_03 INE Reverso_\n\n_04 Pasaporte_\n\n_05 Matr\u00edcula Consular Anverso_\n\n_06 FM2 / FM3 Anverso_\n\n_08 Acta Nacimiento_\n\n_09 Matr\u00edcula Consular Reverso_\n\n_10 FM2 / FM3 Reverso_\n\n_11 Comprobante Domicilio Parte 1_\n\n_12 Comprobante Domicilio Parte 2_\n"
          },
          "enrolar": {
            "pattern": "^[0-9]{1}",
            "type": "string",
            "minLength": 0,
            "maxLength": 1,
            "example": "1",
            "description": "Identificador de acci\u00f3n: Enrolar.\n\n_1: enrolamiento activo._\n\n_0: enrolamiento inactivo._\n"
          },
          "operacion": {
            "pattern": "^[0-9]{2}",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "02",
            "description": "Clave de la operaci\u00f3n.\n"
          },
          "folio": {
            "type": "string",
            "minLength": 0,
            "maxLength": 20,
            "example": "ABC 1234567890",
            "description": "Folio de tr\u00e1mite.\n"
          }
        },
        "example": "{ \"curp\":\"XXXX870128HDFLLC08\", \"nombre\": \"NOMBRE\", \"apellidoPaterno\": \"APPELLIDO\", \"apellidoMaterno\": \"APELLIDO\", \"cveAfore\": \"999\", \"cveImagen\": [ \"01\", \"02\", \"03\" ], \"enrolar\":\"1\", \"operacion\":\"06\",\"folio\":\"ABC 1234567890\"}"
      },
      "extraerInformacionResponse": {
        "required": [
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "curp": {
            "type": "string",
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del trabajador.\n",
            "example": "AAAA900909XXXXXX09"
          },
          "resultadoOperacion": {
            "type": "string",
            "description": "Resultado de la operaci\u00f3n.\n",
            "example": "02"
          },
          "diagnosticoOperacion": {
            "type": "string",
            "description": "Diagn\u00f3stico de Negocio de la operaci\u00f3n. Devuelve valor si no hay rechazo por estructura.\n\n_900  La CURP ya cuenta con una validaci\u00f3n previa aceptada para esa AFORE_\n\n_901  Las claves de im\u00e1genes no son validas_\n\n_902  Los nombres de las im\u00e1genes enviadas no coinciden con las claves_\n\n_903  Registro de usuario rechazado_\n\n_904A Selfie rechazada_\n\n_904B Selfie no aprob\u00f3 la prueba de vida est\u00e1tica_\n\n_905  No se han podido procesar alguno de los documentos enviados_\n\n_906  Reglas de evaluaci\u00f3n rechazadas o incompletas_\n\n_907  El tipo de documento obtenido no coincide con la clave de negocio \nenviada_\n\n_908  No existe un usuario activo o bandera interna de enrolamiento es falsa_\n\n_909  Usuario sin fotograf\u00eda enrolada_\n\n_910  La CURP no cuenta con expediente IDE permanente_\n\n_911  La clave AFORE no es valida_\n\n_920  Ocurri\u00f3 un error al invocar/procesar la b\u00fasqueda del expediente_\n\n_921  La CURP no cuenta con fotograf\u00eda del trabajador en el expediente_\n\n_930  La operaci\u00f3n enviada no es valida_\n",
            "example": "930"
          },
          "anioRegistro": {
            "type": "string",
            "description": "A\u00f1o de registro.\n",
            "example": "2004"
          },
          "claveElector": {
            "type": "string",
            "description": "Clave Elector.\n",
            "example": "PRSLPL85120609H200"
          },
          "anioEmision": {
            "type": "string",
            "description": "A\u00f1o de Emisi\u00f3n.\n",
            "example": "2020"
          },
          "apellidoPaterno": {
            "type": "string",
            "description": "Apellido Paterno.\n",
            "example": "PEREZ"
          },
          "apellidoMaterno": {
            "type": "string",
            "description": "Apellido Materno.\n",
            "example": "SILVA"
          },
          "nombre": {
            "type": "string",
            "description": "Nombre.\n",
            "example": "PLINIO"
          },
          "emisionesPrevias": {
            "type": "string",
            "description": "Emisiones Previas.\n",
            "example": "04"
          },
          "cic": {
            "type": "string",
            "description": "CIC\n",
            "example": "205122693"
          },
          "ocr": {
            "type": "string",
            "description": "OCR\n",
            "example": "1675067762022"
          },
          "error-validacion": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Formato de clave AFORE incorrecto",
              "Formato de CURP incorrecto"
            ]
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "example": [
              {
                "validaDoctodRequest": {
                  "curp": "XXXX900909XXXXXX09",
                  "nombre": "5555555555"
                }
              }
            ]
          }
        }
      }
    }
  }
}