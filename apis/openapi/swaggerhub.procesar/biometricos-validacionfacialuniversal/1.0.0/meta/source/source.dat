{
  "openapi": "3.0.1",
  "info": {
    "title": "Validaci\u00f3n Facial Universal",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio validaci\u00f3n facial Universal",
    "contact": {
      "email": "GERENCIA_ARQUITECTURA_SOFTWARE@inet.prcesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar/Biometricos-ValidacionFacialUniversal/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/biometricos-direct/serviciofacial/universal"
    }
  ],
  "tags": [
    {
      "name": "Validacion Facial Universal",
      "description": "Operaci\u00f3n de validaci\u00f3n facial Biometrica"
    }
  ],
  "paths": {
    "/validacionbiometrica": {
      "post": {
        "summary": "Biom\u00e9tricos - Validaci\u00f3n Facial Universal",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "validacionbiometrica",
        "tags": [
          "Validacion Facial Universal"
        ],
        "requestBody": {
          "description": "Request para la solicitud de Validaci\u00f3n Facial Universal",
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/validacionFacialRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/validacionFacialResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/validacionFacialResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "generarSelloRequest"
      }
    }
  },
  "components": {
    "schemas": {
      "validacionFacialRequest": {
        "required": [
          "message",
          "file"
        ],
        "type": "object",
        "properties": {
          "message": {
            "$ref": "#/components/schemas/message"
          },
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Atributo file : viaja como part, cadena en formato tipo JSON (archivoBinario.zip)\n",
            "example": "archivoBinario.zip"
          }
        }
      },
      "message": {
        "required": [
          "origen",
          "cveEntidad",
          "curp",
          "token",
          "cveOperacion",
          "listaImagen"
        ],
        "type": "object",
        "description": "Atributo message : viaja como part, cadena en formato tipo JSON\n",
        "properties": {
          "origen": {
            "type": "string",
            "pattern": "^[A-Za-z0-9]{2}$",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave de origen de la solicitud.\nDe acuerdo con lo definido en el Cat\u00e1logo de Clave de tipo operaci\u00f3n.\n",
            "example": "01"
          },
          "cveEntidad": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la AFORE que realiza la validaci\u00f3n. De acuerdo con lo definido en el Cat\u00e1logo de AFORE",
            "example": "530"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del usuario a validar.\n",
            "example": "AAAA900909XXXXXX09"
          },
          "token": {
            "type": "string",
            "description": "Token obtenido del servicio de validaci\u00f3n de datos.\n",
            "example": "KInio8EOGgdcZWCTQnlxiiP3tDnwp0kBiDE3wTOP8AjshylnpV7lqndrk="
          },
          "cveOperacion": {
            "type": "string",
            "pattern": "^[A-Za-z0-9]{4}$",
            "minLength": 4,
            "maxLength": 4,
            "description": "Clave de la operaci\u00f3n que requiere la validaci\u00f3n.\n",
            "example": "1234"
          },
          "listaImagen": {
            "type": "array",
            "description": "Lista de diagn\u00f3sticos de la operaci\u00f3n.\n",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9]{2}$",
              "minLength": 2,
              "maxLength": 2,
              "description": "Clave de la imagen recibida.\n"
            },
            "example": [
              "01",
              "02"
            ]
          }
        }
      },
      "validacionFacialResponse": {
        "required": [
          "curp",
          "token",
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del usuario a validar.\n",
            "example": "AAAA900909XXXXXX09"
          },
          "token": {
            "type": "string",
            "description": "Token obtenido del servicio de validaci\u00f3n de datos.\n",
            "example": "KInio8EOGgdcZWCTQnlxiiP3tDnwp0kBiDE3wTOP8AjshylnpV7lqndrk="
          },
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operaci\u00f3n.\n\n01-Solicitud procesada.\n\n02-Solicitud rechazada.\n",
            "example": "02"
          },
          "listaDiagnosticosOp": {
            "type": "array",
            "description": "Lista de diagn\u00f3sticos de la operaci\u00f3n.\n\n_A28 - Imagen no v\u00e1lida/Selfie, no se pudo detectar un rostro en la toma._\n\n_A29 - Imagen no v\u00e1lida/Selfie, se detect\u00f3 m\u00e1s de un rostro en la toma._\n\n_A30 - Imagen no valida/Selfie, la posici\u00f3n del rostro dentro de la toma no es correcta._\n\n_A31 - Imagen no v\u00e1lida/Selfie, el rostro no est\u00e1 iluminado de manera uniforme._\n\n_A32 - Imagen no v\u00e1lida/Selfie, la toma se realiz\u00f3 en movimiento o con poca iluminaci\u00f3n._\n\n_A33 - Imagen no v\u00e1lida/Selfie, la toma se realiz\u00f3 con poca iluminaci\u00f3n._\n\n_A34 - Imagen no v\u00e1lida/Selfie, la toma del rostro est\u00e1 muy alejada._\n\n_A35 - Imagen no v\u00e1lida, la toma est\u00e1 difuminada y carece de detalles/Selfie._\n\n_A36 - Imagen no v\u00e1lida/Selfie, se detect\u00f3 el uso de una mascarilla/cubrebocas._\n\n_A37 - Imagen no v\u00e1lida/Selfie, no se detectaron ojos en la toma._\n\n_A38 - Imagen no v\u00e1lida/Selfie, los ojos en la toma parecen estar cerrados._\n\n_A39 - Imagen no v\u00e1lida/Selfie, la imagen no cuenta con la calidad suficiente._\n\n_A40 - Imagen no v\u00e1lida/ Identificaci\u00f3n, la posici\u00f3n del documento dentro de la toma no es correcta._\n\n_A41 - Imagen no v\u00e1lida/ Identificaci\u00f3n, la toma est\u00e1 muy alejada del documento._\n\n_A42 - Imagen no v\u00e1lida/ Identificaci\u00f3n, la toma del documento no es visible por exceso de iluminaci\u00f3n._\n\n_A43 - Imagen no v\u00e1lida/ Identificaci\u00f3n, la toma se realiz\u00f3 en movimiento o con poca iluminaci\u00f3n._\n\n_A44 - Imagen no v\u00e1lida/ Identificaci\u00f3n, la toma del documento se realiz\u00f3 en un fondo no       uniforme._\n\n_A45 - Imagen no v\u00e1lida/ Identificaci\u00f3n, dentro de la toma no se identifica el documento       completo._\n\n_A46 - Imagen no v\u00e1lida/ Identificaci\u00f3n, el documento no cuenta con la calidad suficiente._\n\n_A47 - Imagen no v\u00e1lida/Expediente, no se pudo detectar un rostro en la toma._\n\n_A48 - Imagen no v\u00e1lida/ Expediente, se detect\u00f3 m\u00e1s de un rostro en la toma._\n\n_A49 - Imagen no valida/ Expediente, la posici\u00f3n del rostro dentro de la toma no es correcta._\n\n_A50 - Imagen no v\u00e1lida/ Expediente, el rostro no est\u00e1 iluminado de manera uniforme._\n\n_A51 - Imagen no v\u00e1lida/ Expediente, la toma se realiz\u00f3 en movimiento o con poca iluminaci\u00f3n._\n\n_A52 - Imagen no v\u00e1lida/ Expediente, la toma se realiz\u00f3 con poca iluminaci\u00f3n._\n\n_A53 - Imagen no v\u00e1lida/ Expediente, la toma del rostro est\u00e1 muy alejada._\n\n_A54 - Imagen no v\u00e1lida/ Expediente, la toma est\u00e1 difuminada y carece de detalles._\n\n_A55 - Imagen no v\u00e1lida, se detect\u00f3 el uso de una mascarilla/cubrebocas._\n\n_A56 - Imagen no v\u00e1lida/ Expediente, no se detectaron ojos en la toma._\n\n_A57 - Imagen no v\u00e1lida/ Expediente, los ojos en la toma parecen estar cerrados._\n\n_A58 - Imagen no v\u00e1lida/ Expediente, la imagen no cuenta con la calidad suficiente._\n\n_A22 - La imagen recibida/Selfie no cumple con los requisitos para su validaci\u00f3n._\n\n_A23 - La imagen adicional recibida no corresponde con la clave recibida._\n\n_A24 - La imagen adicional/ Identificaci\u00f3n recibida no cumple con los requisitos para su validaci\u00f3n._\n\n_A25 - No existe una validaci\u00f3n previa y/o vigente asociada al token de la solicitud._\n\n_A27 - La imagen recibida no corresponde con el enrolamiento registrado._\n\n_534 - El archivo excede el tama\u00f1o permitido._\n\n_920 - Error en la recuperaci\u00f3n de la imagen del expediente._\n\n_A01 - La clave de origen de la solicitud no corresponde con lo establecido en el cat\u00e1logo._\n\n_A02 - La clave de la entidad solicitante no corresponde con lo establecido en el cat\u00e1logo._\n\n_A03 - La clave de la operaci\u00f3n no corresponde con lo establecido en el cat\u00e1logo._\n\n_A04 - La clave del tipo de usuario no corresponde con lo establecido en el cat\u00e1logo._\n\n_A05 - La clave de imagen no corresponde con el cat\u00e1logo._\n\n_A08 - La operaci\u00f3n requerida no se encuentra autorizada._\n\n_A09 - El tipo de usuario no se encuentra autorizado._\n\n_A07 - El n\u00famero de im\u00e1genes recibidas en incorrecto._\n\n_A10 - La imagen recibida no permitida para la validaci\u00f3n solicitada._\n\n_A12 - El usuario no se encuentra registrado en la BD._\n\n_A13 - El usuario no se encuentra registrado la AFORE._\n\n_A16 - El solicitante no tiene un Expediente asociado._\n\n_A17 - El solicitante no tiene un Expediente con el estatus requerido._\n\n_A18 - El solicitante no tiene un Expediente asociado a la AFORE._\n\n_A20 - La imagen del Expediente no cumple con los requisitos para su validaci\u00f3n._\n\n_A60 - La clave de origen no est\u00e1 requisitada en la solicitud._\n\n_A61 - La clave de la Entidad no est\u00e1 requisitada en la solicitud._\n\n_A62 - La CURP no est\u00e1 requisitada en la solicitud._\n\n_A63 - La clave operaci\u00f3n no est\u00e1 requisitada en la solicitud._\n\n_A64 - La clave de la imagen no est\u00e1 requisitada en la solicitud._\n\n_A66 - La clave de origen no cumple con la estructura establecida._\n\n_A67 - La clave de la Entidad solicitante no cumple con la estructura establecida._\n\n_A68 - La CURP no cumple con la estructura establecida._\n\n_A69 - La clave de la Operaci\u00f3n no cumple con la estructura establecida._\n\n_A71 - La clave de imagen no cumple con la estructura establecida._\n\n_A74 - El archivo Zip no cuenta con el n\u00famero de archivos requerido._\n\n_A75 - El formato de la imagen recibida es incorrecto._\n\n_A76 - La m\u00e1scara de la imagen recibida es incorrecta._\n\n_A77 - La imagen recibida no puede ser recuperada._\n\n_A73 - El archivo ZIP no fue recibido._\n\n_B01 - El tipo de usuario no est\u00e1 requisitado en la solicitud._\n\n_B02 - El origen requerido no se encuentra autorizado._\n\n_B03 - El token no est\u00e1 requisitado en la solicitud._\n\n_B04 - El nombre del archivo no est\u00e1 requisitado en la solicitud._\n\n_B05 - El token no cumple con la estructura establecida._\n\n_D96 - La persona no se encuentra enrolada._\n",
            "items": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3,
              "description": "Diagn\u00f3stico de rechazo generado en las validaciones realizadas.\n"
            },
            "example": [
              "B05",
              "D96"
            ]
          },
          "resultadoValidacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14,
            "description": "Resultado de la validaci\u00f3n facial:\n\n_MATCH-Cuando existe coincidencia entre las im\u00e1genes validadas._\n\n_NOMATCH-Cuando no existe coincidencia entre las im\u00e1genes validadas._\n",
            "example": "MATCH"
          },
          "calificacion": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Dato notificado solo si el diagn\u00f3stico de la operaci\u00f3n es igual a Match.\nCalificaci\u00f3n otorgada dentro de la escala de coincidencia encontrada en la validaci\u00f3n facial.\n",
            "example": "XXX"
          },
          "enrolado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Dato notificado solo si el diagn\u00f3stico de la operaci\u00f3n es igual a Match.\n\n_00-No existe enrolamiento facial._\n\n_01-Existe enrolamiento facial._\n",
            "example": "01"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Expected element 'message' instead of 'file' here in element validacionFacialRequest@http://www.procesar.com.mx/Biometricos/ValidacionFacial/Usuario/validarDatos/"
            ]
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "example": [
              {
                "validacionFacialRequest": {
                  "message": "534"
                }
              }
            ]
          }
        }
      }
    }
  }
}