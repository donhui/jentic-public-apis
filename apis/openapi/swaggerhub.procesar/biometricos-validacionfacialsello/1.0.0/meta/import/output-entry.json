    {
      "url": "https://172.21.67.22:443/biometricos-direct/serviciofacial/generacion"
    }
  ],
  "paths": {
    "/sello": {
      "post": {
        "summary": "Biométricos - Validación Facial Generación de Sello",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si éstos no llevaran valor, por tanto, no se aceptan campos/etiquetas vacías.",
        "operationId": "sello",
        "tags": [
          "Validacion Facial Sello"
        ],
        "requestBody": {
          "description": "Request para la solicitud de comparación de trámite genérico",
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/generarSelloRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacción exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/generarSelloResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/generarSelloResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petición enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no está de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no válidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje genérico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "generarSelloRequest"
      }
    }
  },
  "components": {
    "schemas": {
      "generarSelloRequest": {
        "required": [
          "message",
          "file"
        ],
        "type": "object",
        "properties": {
          "message": {
            "$ref": "#/components/schemas/message"
          },
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Atributo file : viaja como part, cadena en formato tipo JSON (archivoBinario.zip)\n",
            "example": "archivoBinario.zip"
          }
        }
      },
      "message": {
        "required": [
          "origen",
          "claveAfore",
          "curp",
          "cveOperacion",
          "listaImagen"
        ],
        "type": "object",
        "description": "Atributo message : viaja como part, cadena en formato tipo JSON\n",
        "properties": {
          "origen": {
            "type": "string",
            "pattern": "^[A-Za-z0-9]{2}$",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave de origen de la solicitud.\n\nDe acuerdo con lo definido en el Catálogo de Clave de tipo operación.\n",
            "example": "01"
          },
          "claveAfore": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la AFORE que realiza la validación. \n\nDe acuerdo con lo definido en el Catálogo de AFORE\n",
            "example": "530"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave Única de Registro de Población del usuario a validar.\n",
            "example": "AAAA900909XXXXXX09"
          },
          "cveOperacion": {
            "type": "string",
            "pattern": "^[A-Za-z0-9]{4}$",
            "minLength": 4,
            "maxLength": 4,
            "description": "Tipo de Proceso Operativo al que corresponde la solicitud.\n",
            "example": "1234"
          },
          "listaImagen": {
            "type": "array",
            "description": "Lista de imágenes a recibir.\n",
            "items": {
              "$ref": "#/components/schemas/imagenes"
            }
          },
          "selloPrevio": {
            "type": "string",
            "pattern": "^[0-9]{14}$",
            "minLength": 14,
            "maxLength": 14,
            "description": "Sello de voluntad del Trabajador",
            "example": "12345678900987"
          }
        },
        "example": "{ \"origen\":\"01\",\"claveAfore\":\"534\",\"curp\":\"XXXX111111XXXXXX11\",\"cveOperacion\":\"1111\",\"listaImagen\":[\"01\",\"02\",\"03\",\"04\"],\"selloPrevio\":\"12345678909876\"}"
      },
      "generarSelloResponse": {
        "required": [
          "origen",
          "claveAfore",
          "curp",
          "cveOperacion",
          "listaImagen",
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "origen": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave de origen de la solicitud.\n\nDe acuerdo con lo definido en el Catálogo de Clave de tipo operación.\n",
            "example": "01"
          },
          "claveAfore": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la AFORE que realiza la validación. \n\nDe acuerdo con lo definido en el Catálogo de AFORE\n",
            "example": "530"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "maxLength": 18,
            "description": "Clave Única de Registro de Población del usuario a validar.\n",
            "example": "AAAA900909XXXXXX09"
          },
          "cveOperacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4,
            "description": "Tipo de Proceso Operativo al que corresponde la solicitud.\n",
            "example": "01"
          },
          "selloPrevio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14,
            "description": "Sello de voluntad del Trabajador",
            "example": "12345678900987"
          },
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operación.\n\n_01-Solicitud procesada._\n\n_02-Solicitud rechazada._\n",
            "example": "02"
          },
          "listaDiagnosticosOp": {
            "type": "array",
            "description": "Lista de diagnósticos de la operación.\n",
            "items": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3,
              "description": "Diagnóstico de rechazo generado en las validaciones realizadas.\n"
            },
            "example": [
              "XX1",
              "XX2"
            ]
          },
          "resultadoValidacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14,
            "description": "Resultado de la validación facial:\n\n_MATCH-Cuando existe coincidencia entre las imágenes validadas._\n\n_NOMATCH-Cuando no existe coincidencia entre las imágenes validadas._\n",
            "example": "MATCH"
          },
          "calificacion": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Dato notificado solo si el diagnóstico de la operación es igual a Match.\nCalificación otorgada dentro de la escala de coincidencia encontrada en la validación facial.\n",
            "example": "XXX"
          },
          "enrolado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Dato notificado solo si el diagnóstico de la operación es igual a Match.\n\n_00-No existe enrolamiento facial._\n\n_01-Existe enrolamiento facial._\n",
            "example": "01"
          },
          "sello": {
            "type": "string",
            "minLength": 1,
            "maxLength": 14,
            "description": "Sello de voluntad del Trabajador",
            "example": "12345678900987"
          },
          "datosTrabajador": {
            "$ref": "#/components/schemas/datosTrabajador"
          },
          "telefonos": {
            "type": "array",
            "description": "Lista de teléfonos.\n",
            "items": {
              "$ref": "#/components/schemas/telefono"
            }
          },
          "domicilio": {
            "type": "array",
            "description": "Lista de domicilios.\n",
            "items": {
              "$ref": "#/components/schemas/domicilio"
            }
          },
          "Referencias": {
            "type": "array",
            "description": "Lista de referencias.\n",
            "items": {
              "$ref": "#/components/schemas/referencia"
            }
          },
          "Beneficiarios": {
            "type": "array",
            "description": "Lista de beneficiarios.\n",
            "items": {
              "$ref": "#/components/schemas/beneficiario"
            }
          }
        }
      },
      "datosTrabajador": {
        "type": "object",
        "properties": {
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "maxLength": 18,
            "description": "CURP del Trabajador. Máscara AAAA999999AAAAAAXX; donde A es Alfabético, 9 es Numérico y X es Alfanumérico.\n",
            "example": "CCCC900909XXXXXX09"
          },
          "rfc": {
            "pattern": "^([A-Za-z]{4}\\d{6}([A-Za-z0-9]{3})?)?$",
            "type": "string",
            "maxLength": 13,
            "description": "RFC del Trabajador. Máscara AAAA999999XXX donde A es Alfabético, 9 es Numérico y X es Alfanumérico. Puede ser a 10 ó 13 posiciones",
            "example": "CCCC900909XXX"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno del Trabajador, no blanco.",
            "example": "apellidoPaterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno del Trabajador, blanco en caso de no tener apellido materno.\n",
            "example": "apellidoMaterno"
          },
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre(s) del Trabajador, no blancos.\n",
            "example": "nombre"
          },
          "genero": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Clave de género del trabajador.\n\n_1-Masculino._\n\n_2-Femenino._\n",
            "example": "1"
          },
          "fechaNacimiento": {
            "pattern": "^[0-3]{1}[0-9]{1}[/]{1}[0,1]{1}[0-9]{1}[/][0-2]{1}[0-9]{3}$",
            "type": "string",
            "maxLength": 10,
            "description": "Fecha de nacimiento del Trabajador No Afiliado, mayor a 1900 y menor o igual a la fecha del proceso. DD/MM/AA\n",
            "example": "13/12/1990"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 11,
            "description": "Número de seguridad social que posea el trabajador (en su caso).",
            "example": "12345678901"
          },
          "correoElectronico": {
            "pattern": "^[_A-z0-9\\-]+(\\.[_A-z0-9\\-]+)*@[A-z0-9\\-]+(\\.[A-z0-9\\-]+)*(\\.[A-z]{2,4})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Correo  electrónico del trabajador, con formato de correo electrónico, minúsculas con 1 carácter de @ y sin espacios (en su caso).",
            "example": "correo@Electronico.com"
          },
          "ocupacion": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Ocupación o profesión del trabajador según catálogo INEGI.",
            "example": "02"
          },
          "actividadEconomica": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Actividad o giro del negocio del trabajador según catálogo  INEGI.",
            "example": "02"
          },
          "estudios": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Nivel de estudio del trabajador según catálogo  INEGI.",
            "example": "03"
          },
          "entidadNacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Entidad de Nacimiento conforme al Catálogo de Entidades Federativas.",
            "example": "20"
          },
          "nacionalidad": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Nacionalidad conforme al Catálogo de Nacionalidad.",
            "example": "MEX"
          },
          "indicadorDesignacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Señala si el titular de la cuenta designó o tiene registrados beneficiarios:\n\n_1-Beneficiario designado, si el titular de la cuenta tiene designados o registrados beneficiarios._\n\n_2-Sin beneficiarios designados, si el titular de la cuenta no designó o no tiene registrados beneficiarios._\n",
            "example": "1"
          },
          "indicadorReforma": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador de si el beneficiario fue dado de alta o modificado post implementación de la reforma:\n\n_1-Pre-reforma_\n\n_2-Post-reforma_\n",
            "example": "1"
          },
          "fechaModificacionBeneficiario": {
            "pattern": "^[0-3]{1}[0-9]{1}[/]{1}[0,1]{1}[0-9]{1}[/][0-2]{1}[0-9]{3}$",
            "type": "string",
            "maxLength": 10,
            "description": "Fecha en la que se dio de alta o modificó el beneficiario DD/MM/AA\n",
            "example": "13/12/1990"
          },
          "aforeBeneficiario": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "AFORE que realizó el alta o la modificación del beneficiario",
            "example": "530"
          }
        }
      },
      "telefono": {
        "type": "object",
        "properties": {
          "numero": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "Teléfono del Trabajador. Sin guiones y sin espacios",
            "example": "5555555557"
          },
          "tipo": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo de Teléfono",
            "example": "12345"
          }
        }
      },
      "domicilio": {
        "type": "object",
        "properties": {
          "calle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Calle del domicilio del trabajador",
            "example": "calle"
          },
          "numeroExterior": {
            "type": "string",
            "minLength": 1,
            "maxLength": 9,
            "description": "Número Exterior del domicilio del trabajador",
            "example": "200"
          },
          "numeroInterior": {
            "type": "string",
            "minLength": 1,
            "maxLength": 9,
            "description": "Número Interior del domicilio del trabajador\n",
            "example": "200"
          },
          "colonia": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "colonia del domicilio del trabajador\n",
            "example": "colonia"
          },
          "delegacionMunicipio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "municipio o delegación del domicilio del trabajador",
            "example": "delegacionMunicipio"
          },
          "ciudadPoblacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "ciudad o población del domicilio del trabajador",
            "example": "ciudadPoblacion"
          },
          "codigoPostal": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5,
            "description": "código postal del domicilio del trabajador",
            "example": "12345"
          },
          "entidad": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Entidad Federativa del domicilio del trabajador según catálogo",
            "example": "entidad"
          },
          "pais": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3,
            "description": "País del domicilio del trabajador",
            "example": "MEX"
          },
          "tipo": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo de domicilio Particular/Laboral",
            "example": "2"
          }
        }
      },
      "referencia": {
        "type": "object",
        "properties": {
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido paterno de referencia del trabajador",
            "example": "apellidoPaterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido materno de referencia del trabajador.\n",
            "example": "apellidoMaterno"
          },
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre o nombres de referencia del trabajador\n",
            "example": "nombre"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "maxLength": 18,
            "description": "CURP de la referencia del trabajador\n",
            "example": "CCCC900909XXXXXX09"
          },
          "parentescoRelacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Parentesco o relación de la referencia",
            "example": "01"
          },
          "telefonoReferencia": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "Teléfono de referencia del trabajador (fijo o celular). Sin guiones y sin espacios.",
            "example": "5555555555"
          }
        }
      },
      "beneficiario": {
        "type": "object",
        "properties": {
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "maxLength": 18,
            "description": "CURP del beneficiario\n",
            "example": "AAAA900909XXXXXX09"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido paterno del beneficiario del trabajador.",
            "example": "apellidoPaterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido materno de beneficiario del trabajador.\n",
            "example": "apellidoMaterno"
          },
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre o nombres del beneficiario del trabajador.\n",
            "example": "nombre"
          },
          "porcentajeAsignado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3,
            "description": "Porcentaje asignado al beneficiario (la suma de los porcentajes deberán ser  100%)\n",
            "example": "100"
          }
        }
      },
      "imagenes": {
        "required": [
          "claveImagen"
        ],
        "properties": {
          "claveImagen": {
            "type": "string",
            "pattern": "^[A-Za-z0-9]{2}$",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave de la imagen recibida.\n",
            "example": [
              "01",
              "02"
            ]
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
