          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Expected element 'cveOrigen' instead of 'cveEntSolicitante' here in element validarDatosRequest@http://www.procesar.com.mx/Biometricos/ValidacionFacial/Usuario/validarDatos/",
              "Expected element 'cveOrigen' instead of 'cveEntSolicitante' here in element validarDatosRequest@http://www.procesar.com.mx/Biometricos/ValidacionFacial/Usuario/validarDatos/"
            ]
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "example": [
              {
                "validarDatosRequest": {
                  "cveEntSolicitante": "534",
                  "cveOperacion": "PA01",
                  "curp": "KAEJ821189RDFRMR00",
                  "tipoUsuario": "00"
                }
              }
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Validacion Facial Sello",
