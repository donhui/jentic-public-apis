{
  "openapi": "3.0.1",
  "info": {
    "title": "Enrolamiento Dactilar",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para enrolamiento dactilar",
    "contact": {
      "email": "GERENCIA_ARQUITECTURA_SOFTWARE@inet.prcesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar/Biometricos-EnrolamientoDactilar/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/biometricos/v1/921/enrolamiento/dactilar"
    },
    {
      "url": "https://192.168.1.73:443/biometricos/v1/921/enrolamiento/dactilar"
    }
  ],
  "tags": [
    {
      "name": "Enviar Archivo",
      "description": "Operaci\u00f3n para Enrolamiento Dactilar"
    }
  ],
  "paths": {
    "/archivo": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Biom\u00e9tricos - Enrolamiento Dactilar",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "enviarArchivo",
        "tags": [
          "Enviar Archivo"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "921"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "53"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "2",
                "4",
                "5",
                "6",
                "7",
                "8",
                "10",
                "11",
                "12",
                "14",
                "15"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para enrolamiento dactilar",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/enviarArchivoRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/enviarArchivoResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/enviarArchivoResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "enviarArchivoRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "enviarArchivoRequest": {
        "required": [
          "nombreArchivo",
          "base64"
        ],
        "type": "object",
        "properties": {
          "nombreArchivo": {
            "pattern": "^[A-Za-z0-9]{1,25}[.]{1}[ZzIiPp]{3}$",
            "type": "string",
            "minLength": 0,
            "example": "XXXAAAAMMDDCCCC#######67I.zip",
            "description": "\n``` \n  Archivo ZIP enviado debe ser nombrado de acuerdo a la siguiente Tabla:\n\n  XXXAAAAMMDDCCCC#######67I.zzz\n```\n\n\n  | C\u00f3digo          | Descripci\u00f3n                                                                                                                                 |\n  | -------         | --------------------------------------------------------------------------------------------------------------------------------------------|\n  | XXX             | Clave de Entidad a la que prestar\u00e1 el servicio el agente de servicio y funcionario autorizado seg\u00fan Cat\u00e1logo de Entidades                   |\n  | AAAAMMDD        | Fecha de Operaci\u00f3n                                                                                                                          |\n  | CCCC            | Clave del servicio de enrolamiento que corresponda, como se indica en el documento Cat\u00e1logo de Servicio Biom\u00e9tricos / Cat\u00e1logo de Servicios |\n  | #######         | Folio del archivo ZIP asignado por la Entidad. Debe ser \u00fanico por Fecha de Operaci\u00f3n.                                                       |\n  | 67              | 67 Enrolamiento dactilar en l\u00ednea                                                                                                           |\n  | I               | Num\u00e9rico que indica la cantidad de documentos (1 al 9, para el caso del Expediente de Servicio Biom\u00e9trico, deber\u00e1 considerar 1)             |\n  | ZZZ             | extensi\u00f3n / formato (.zip)                                                                                                                  |\n---\n\n\n  ```\n    NIST (Archivo XML) que se encuentra dentro de zip, debe ser nombrado de acuerdo a la siguiente tabla:\n  \n    XXX67AAAA999999NNNNNN99CAAAAMMDD###.ZZZ \n  ```\n    \n  | C\u00f3digo          | Descripci\u00f3n                                                                                                                                 |\n  | -------         | --------------------------------------------------------------------------------------------------------------------------------------------|\n  | XXX             | Clave de la Entidad Receptora seg\u00fan Cat\u00e1logo de Entidades                                                                                   |\n  | 67              | 67 Enrolamiento dactilar en l\u00ednea                                                                                                           |\n  | AAAA999999NNNNNN99| CURP del Enrolado                                                                                                                         |\n  | C               | Consecutivo del archivo, considerando del 1 al 9, donde al menos deber\u00e1 de venir uno por cada clave de archivo                              |\n  | AAAAMMDD        | Fecha de proceso de la solicitud                                                                                                            |\n  | ###             | Folio del archivo NIST, asignado por la Administradora.                                                                                     |\n  | I               | Num\u00e9rico que indica la cantidad de documentos (1 al 9, para el caso del Expediente de Servicio Biom\u00e9trico, deber\u00e1 considerar 1)             |\n  | ZZZ             | extensi\u00f3n / formato (.xml)                                                                                                                |                             |\n---\n\n---\n\n\n  ```\n    Formato de Enrolamiento con la firma manuscrita digital, debe ser nombrado de acuerdo a la siguiente tabla:\n  \n    5XX67AAAA999999NNNNNN9996CAAAAMMDD###.ZZZ \n  ```\n    \n  | C\u00f3digo          | Descripci\u00f3n                                                                                                                                 |\n  | -------         | --------------------------------------------------------------------------------------------------------------------------------------------|\n  | 5XX             | Clave de la Entidad Receptora seg\u00fan Cat\u00e1logo de Entidades                                                                                   |\n  | 67              | 67 Enrolamiento dactilar en l\u00ednea                                                                                                           |\n  | AAAA999999NNNNNN99| CURP del Enrolado                                                                                                                         |\n  | 96               | Clave de imagen: Formato de enrolamiento datos generales y firma del Enrolado (Empleado o Trabajador) deber\u00e1 de venir uno por cada clave de archivo.                              |\n  | C        | Consecutivo del documento imagen, considerando del 1 al 9, donde al menos deber\u00e1 de venir uno por cada clave de imagen.                                                                                                            |\n  | AAAAMMDD             | Fecha de proceso de la solicitud .                                                                                     |\n  | ###               | Folio del formato de enrolamiento, asignado por la Administradora.             |\n  | ZZZ             | extensi\u00f3n / formato, y que podr\u00e1 ser .tiff o .jpg o .jpeg o .pdf\n\n---\n"
          },
          "base64": {
            "type": "string",
            "format": "byte",
            "description": "archivo en base64",
            "example": "U3dhZ2dlciByb2Nrcw=="
          }
        }
      },
      "enviarArchivoResponse": {
        "required": [
          "nombreArchivo",
          "fechaHoraRecepcion",
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "nombreArchivo": {
            "pattern": "^[A-Za-z0-9]{1,25}[.]{1}[ZzIiPp]{3}$",
            "type": "string",
            "minLength": 0,
            "description": "Nombre del Archivo\n",
            "example": "XXXAAAAMMDDCCCC#######67I.zip"
          },
          "fechaHoraRecepcion": {
            "pattern": "^([1-9]{1}[0-9]{3}[-]{1}[0-9]{2}[-]{1}[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2})?$",
            "type": "string",
            "minLength": 0,
            "description": "fecha y Hora de Recepci\u00f3n\n",
            "example": "2022-01-11T10:00:00"
          },
          "resultadoOperacion": {
            "pattern": "^(01|02)$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operaci\u00f3n\n",
            "example": "02"
          },
          "diagnosticos": {
            "type": "object",
            "properties": {
              "motivo": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "properties": {
                    "clave": {
                      "pattern": "^[A-Z0-9]{3}$",
                      "type": "string",
                      "description": "Clave del motivo de rechazo.\n",
                      "example": "A60"
                    },
                    "descripcion": {
                      "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 200,
                      "example": "La clave de origen no est\u00e1 requisitada en la solicitud",
                      "description": "Descripci\u00f3n de la clave de motivo de rechazo.\n\n  Cat\u00e1logo de diagnosticos:\n  \n  _A60- La clave de origen no est\u00e1 requisitada en la solicitud._\n  \n  _A61- La clave de la Entidad no est\u00e1 requisitada en la solicitud._\n  \n  _A62- La CURP no est\u00e1 requisitada en la solicitud._\n  \n  _A63- La clave operaci\u00f3n no est\u00e1 requisitada en la solicitud._\n  \n  _B01- El tipo de usuario no est\u00e1 requisitado en la solicitud._\n  \n  _B04- El nombre del archivo no est\u00e1 requisitado en la solicitud._\n  \n  _A66- La clave de origen no cumple con la estructura establecida._\n  \n  _A67- La clave de la Entidad solicitante no cumple con la estructura establecida._\n  \n  _A68- La CURP no cumple con la estructura establecida._\n  \n  _A69- La clave de la Operaci\u00f3n no cumple con la estructura establecida._\n  \n  _B07-La clave de tipo de usuario no cumple con la estructura establecida._\n  \n  _E48: Nombre del archivo ZIP incorrecto._\n  \n  _A01- La clave de origen de la solicitud no corresponde con lo establecido en el cat\u00e1logo._\n  \n  _A02- La clave de la entidad solicitante no corresponde con lo establecido en el cat\u00e1logo._\n  \n  _A03- La clave de la operaci\u00f3n no corresponde con lo establecido en el cat\u00e1logo._\n  \n  _A04- La clave del tipo de usuario no corresponde con lo establecido en el cat\u00e1logo._\n  \n  _E71: Duplicidad de archivo ZIP para el enrolamiento._\n  \n  _E59: Archivo ZIP recibido se encuentra vac\u00edo._\n  \n  _E60: Archivo ZIP excede el n\u00famero de archivos contenidos._\n  _\n  _E56: Archivo NIST no recibido._\n  \n  _E58: Archivo Formato Enrolamiento no recibido._\n  \n  _E52: Estructura del Archivo ZIP inv\u00e1lido._\n  \n  _E49: Nombre del Archivo NIST incorrecto._\n  \n  _E53: Estructura del Archivo NIST inv\u00e1lido._\n  \n  _E58: Formato de enrolamiento no recibido._\n  \n  _E51: El nombre del archivo formato de enrolamiento es incorrecto._\n  \n  _E55: Estructura del Archivo Formato de Enrolamiento inv\u00e1lido._\n  \n  _M21: El tipo de persona no corresponde con el servicio._\n  \n  _G67: El n\u00famero de huellas recibidas del trabajador es incorrecto._ \n  \n  _E89: posici\u00f3n de dedo del trabajador duplicada._\n  \n  _M29: La fecha de captura no es vigente._\n  \n  _E27: La huella dactilar del Trabajador no cumple con la calidad requerida._\n  \n  _J09: Al menos una de las im\u00e1genes de las huellas dactilares de la persona a enrolar fue enviada previamente para otro servicio de negocio._\n  \n  _E67: El Identificador del dispositivo es inv\u00e1lido._\n  \n  _M15: El hash de la huella es incorrecto._\n  \n  _M06: Huella del Trabajador duplicada._\n  \n  _M16: Motivo sin huella incorrecto._\n  \n  _M08: Clave de excepci\u00f3n recibida no es v\u00e1lida para posici\u00f3n en mano izquierda/derecha._\n  \n  _B08-Entidad no autorizada para el flujo solicitado._\n  \n  _E54: La CURP ya cuenta con enrolamiento._\n  \n  _E30: Al menos una huella dactilar de la persona a enrolar se encuentra asociada a otro enrolamiento._\n"
                    }
                  }
                },
                "example": [
                  {
                    "clave": "XX1",
                    "descripcion": "descripcion 1"
                  },
                  {
                    "clave": "XX2",
                    "descrpcion": "descripci\u00f3n 2"
                  }
                ]
              }
            }
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Expected element 'nombreArchivo' instead of 'base64' here in element enviarArchivoRequest@http://www.procesar.com.mx/Biometricos/Enrolamiento/Dactilar/enviarArchivo/"
            ]
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "example": [
              {
                "enviarArchivoRequest": {
                  "base64": "ZQ=="
                }
              }
            ]
          }
        }
      }
    }
  }
}