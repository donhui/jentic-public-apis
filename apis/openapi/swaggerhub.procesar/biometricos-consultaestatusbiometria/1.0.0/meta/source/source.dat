{
  "openapi": "3.0.1",
  "info": {
    "title": "Consulta Estatus Biometr\u00eda",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para Consultar el estatus de Biometr\u00eda",
    "contact": {
      "email": "gerencia_arquitectura_software@inet.procesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar/Biometricos-ConsultaEstatusBiometria/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/biometricos/v1/934/afore/consultaestatus"
    },
    {
      "url": "https://192.168.1.73:443/biometricos/v1/934/afore/consultaestatus"
    }
  ],
  "tags": [
    {
      "name": "Consulta Estatus Biometr\u00eda",
      "description": "Operaci\u00f3n para Consultar el estatus de Biometr\u00eda."
    }
  ],
  "paths": {
    "/usuario": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Biom\u00e9tricos - Consulta Estatus Biometr\u00eda",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "consultarEstatus",
        "tags": [
          "Consulta Estatus Biometr\u00eda"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "934"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "53"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "4"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para validaci\u00f3n de datos del usuario",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/consultarEstatusRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/consultarEstatusResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/consultarEstatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "consultarEstatusRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "consultarEstatusRequest": {
        "required": [
          "cveOrigen",
          "cveEntSolicitante",
          "cveOperacion",
          "curp",
          "tipoUsuario"
        ],
        "type": "object",
        "properties": {
          "cveOrigen": {
            "type": "string",
            "minLength": 0,
            "maxLength": 2,
            "example": "05",
            "description": "Clave de origen de la solicitud.\n\n  02-AFORE\n  \n  05-Entidad participante \n"
          },
          "cveEntSolicitante": {
            "pattern": "^[0-9][0-9][0-9]$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "534",
            "description": "Clave de la entidad solicitante.\n\n  534-AFORE Profuturo.\n"
          },
          "cveOperacion": {
            "type": "string",
            "minLength": 0,
            "maxLength": 4,
            "description": "Clave de la operaci\u00f3n.\n",
            "example": "1234"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del usuario a validar.",
            "example": "AAAA900909XXXXXX09"
          },
          "tipoUsuario": {
            "type": "string",
            "minLength": 0,
            "maxLength": 2,
            "example": "01",
            "description": "Clave de tipo de usuario a validar.\n  \n  _00- Cliente de la entidad._\n  \n  _01-Colaborador de la entidad._\n"
          }
        }
      },
      "consultarEstatusResponse": {
        "required": [
          "cveOrigen",
          "cveEntidad",
          "cveOperacion",
          "curp",
          "tipoUsuario",
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "cveOrigen": {
            "type": "string",
            "minLength": 0,
            "maxLength": 2,
            "example": "02",
            "description": "Clave de origen de la solicitud.\n\n02-AFORE\n  \n05-Entidad participante \n"
          },
          "cveEntidad": {
            "pattern": "^[0-9][0-9][0-9]$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "534",
            "description": "Clave de la entidad solicitante.\n\n_534-AFORE Profuturo._\n"
          },
          "cveOperacion": {
            "type": "string",
            "minLength": 0,
            "maxLength": 4,
            "description": "Clave de la operaci\u00f3n.\n",
            "example": "1234"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del usuario a validar.",
            "example": "AAAA900909XXXXXX09"
          },
          "tipoUsuario": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "01",
            "description": "Clave de tipo de usuario a validar.\n\n_00- Cliente de la entidad._\n  \n_01-Colaborador de la entidad._\n"
          },
          "resultadoOperacion": {
            "pattern": "^(01|02)$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operaci\u00f3n.\n\n_01-Solicitud procesada._\n\n_02-Solicitud rechazada._\n",
            "example": "02"
          },
          "listaDiagnosticosOp": {
            "type": "array",
            "items": {
              "pattern": "^[A-Z0-9]{3}$",
              "type": "string",
              "description": "Diagn\u00f3stico de rechazo generado en las validaciones realizadas."
            },
            "example": [
              "T01",
              "T02"
            ]
          },
          "enrolamientoDactilar": {
            "type": "object",
            "properties": {
              "enrolDact": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "_00-No existe enrolamiento dactilar_\n\n_01-Existe erolamiento dactilar_\n",
                "example": "01"
              },
              "fchEnrolDact": {
                "type": "string",
                "minLength": 8,
                "maxLength": 8,
                "description": "Fecha en la que Procesar recibi\u00f3 en enrolamiento dactilar.\n",
                "example": "20220422"
              },
              "excepciones": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "_00-Enrolamiento sin excepciones. En caso que el enrolamiento no tenga expcepcioes._\n\n_01-Enrolamiento con Excepciones-En caso de que el enrolamiento cuente con al menos una clave de excepci\u00f3n._\n",
                "example": "00"
              },
              "huellaCalidad": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1,
                "description": "Posici\u00f3n del dedo que tiene la huella con mayor calidad.\n",
                "example": "1"
              }
            }
          },
          "enrolamientoFacial": {
            "type": "object",
            "properties": {
              "enrolFac": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "_00-No existe enrolamiento facial_\n\n_01-Existe erolamiento facial_\n",
                "example": "01"
              },
              "fchEnrolFac": {
                "type": "string",
                "minLength": 8,
                "maxLength": 8,
                "description": "Fecha en la que Procesar recibi\u00f3 en enrolamiento dactilar.\n",
                "example": "20220422"
              }
            }
          },
          "validacionesDactilares": {
            "required": [
              "resultadoValDact"
            ],
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "object",
              "properties": {
                "fchValDact": {
                  "type": "string",
                  "minLength": 8,
                  "maxLength": 8,
                  "description": "Fecha en la que Procesar recibi\u00f3 la solicitud de valdiaci\u00f3n dactilar\n"
                },
                "resultadoValDact": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 2,
                  "description": "Resultado de la valdaci\u00f3n dactilar:\n\n  _01-Aceptada._\n\n  _02-Rechazada._\n"
                },
                "diagnosticoValDact": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 3,
                  "description": "Diagn\u00f3stico de rechazo recibido en la validaci\u00f3n dactilar.\n"
                }
              }
            },
            "example": [
              {
                "fchValDact": "20220422",
                "resultadoValDact": "02",
                "diagnosticoValDact": "T02"
              },
              {
                "fchValDact": "20220422",
                "resultadoValDact": "02",
                "diagnosticoValDact": "T02"
              }
            ]
          },
          "validacionesFaciales": {
            "required": [
              "resultadoValFac"
            ],
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "object",
              "properties": {
                "fchValFac": {
                  "type": "string",
                  "description": "Fecha en la que Procesar recibi\u00f3 la solicitud de valdiaci\u00f3n facial.\n",
                  "example": "20220422"
                },
                "resultadoValFac": {
                  "type": "string",
                  "description": "Resultado de la valdaci\u00f3n Facial:\n\n_01-Aceptada_\n\n_02-Rechazada_\n",
                  "example": "02"
                },
                "diagnosticoValFac": {
                  "minLength": 3,
                  "maxLength": 3,
                  "type": "string",
                  "description": "Diagn\u00f3stico de rechazo recibido en la validaci\u00f3n facial.\n",
                  "example": "T02"
                }
              }
            }
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string",
              "example": [
                "Expected element 'cveOrigen' instead of 'cveEntSolicitante' here in element consultarEstatusRequest@http://www.procesar.com.mx/Biometricos/Estatus/consultarEstatus/"
              ]
            }
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "example": [
              {
                "consultarEstatusRequest": {
                  "cveEntSolicitante": "534",
                  "cveOperacion": "PA01",
                  "curp": "KAEJ821189RDFRMR00",
                  "tipoUsuario": "00"
                }
              }
            ]
          }
        }
      }
    }
  }
}