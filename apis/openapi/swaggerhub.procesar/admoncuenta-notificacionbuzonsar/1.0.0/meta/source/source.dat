  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "notificarBuzonRequest": {
        "required": [
          "claveAfore",
          "claveTramite",
          "claveEstatus",
          "curp"
        ],
        "type": "object",
        "properties": {
          "claveAfore": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Administradora que env\u00eda la solicitud.\n",
            "example": "530"
          },
          "claveTramite": {
            "type": "string",
            "minLength": 1,
            "maxLength": 6,
            "description": "Clave del tr\u00e1mite.\n",
            "example": "123ABC"
          },
          "claveEstatus": {
            "type": "string",
            "minLength": 1,
            "maxLength": 6,
            "description": "Clave del estatus del tr\u00e1mite.\n",
            "example": "123ABC"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Trabajador.\n",
            "example": "XXXX111111XXXXXX11"
          },
          "folio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20,
            "description": "Folio que asigna a la Administradora al tr\u00e1mite o servicio solicitado por el Trabajador.\n",
            "example": "12345678901324567ABC"
          },
          "claveAccionesSeguir": {
            "type": "string",
            "minLength": 1,
            "maxLength": 6,
            "description": "Clave de las acciones a seguir.\n",
            "example": "123ABC"
          }
        }
      },
      "notificarBuzonResponse": {
        "required": [
          "resultadoOperacion",
          "folioNotificacion"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "C\u00f3digo de la respuesta de la solicitud.\n\nSe notificar\u00e1 01 en caso de que la solicitud sea aceptada, \n\ny 02 en caso de que la solictud sea rechazada.\n",
            "example": "01"
          },
          "motivoRechazo": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave del diagn\u00f3stico asociado al motivo de rechazo de la solicitud.\n\nSolo se presenta en caso de que la solicitud sea rechazada.\n",
            "example": "001"
          },
          "folioNotificacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20,
            "description": "Folio asignado a la notificaci\u00f3n del Buz\u00f3n SAR (para solicitudes aceptadas y rechazadas).\n",
            "example": "12345678901324567ABC"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  }
}