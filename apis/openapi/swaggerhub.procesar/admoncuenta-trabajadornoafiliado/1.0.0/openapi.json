    "schemas": {
      "modificarDatosRequest": {
        "required": [
          "entidadOrigen",
          "idNegocio",
          "identificadorCentroDePago",
          "rfc",
          "curpNueva",
          "apellidoPaterno",
          "nombreTrabajador",
          "fechaDeNacimiento",
          "entidadFederativaDeNacimiento",
          "sexo",
          "selloUnicoVerificacionBiometrica",
          "curpEmpleado",
          "tipoSolicitante",
          "curpSolicitante"
        ],
        "type": "object",
        "properties": {
          "entidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la AFORE que env\u00eda la solicitud.\n",
            "example": "999"
          },
          "idNegocio": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z0-9]{8}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del Trabajador No Afiliado\n",
            "example": "AAAA000000AAAAAAAA"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS IMSS; cuando tipo de trabajador es  \"1\" IMSS\n\nNSS ISSSTE; cuando tipo de trabajador es \"2\" ISSSTE, cuando sea la respuesta de la Op. 54.\n\nBlancos cuando es modificaci\u00f3n por ventanilla\n",
            "example": "12345678901"
          },
          "identificadorCentroDePago": {
            "pattern": "^([0-9]{7})$",
            "type": "string",
            "minLength": 7,
            "maxLength": 7,
            "description": "0000000 Cuando se trate de una modificaci\u00f3n de datos solicitada por el trabajador a tr\u00e1ves de la ventanilla en la  Afore y que el trabajador se encuentre como No Afiliado.\n\nN\u00famerico En caso de que la  modificaci\u00f3n  de datos, haya sido notificada por PROCESAR en la Op. 54.\n",
            "example": "1234567"
          },
          "rfc": {
            "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
            "type": "string",
            "minLength": 10,
            "maxLength": 13,
            "description": "RFC del Trabajador. Formato\n\n04 - primeras posiciones alfab\u00e9ticas\n\n06 - posiciones siguientes num\u00e9ricas.\n\n03 - alfanum\u00e9ricas (opcionales).\n",
            "example": "XXXX900909123"
          },
          "curpNueva": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave Modificada asignada por RENAPO al trabajador.\n",
            "example": "AAAA000000AAAAAAAA"
          },
          "apellidoPaterno": {
            "pattern": "^[A-Z|a-z|\u00c1-\u00da|\u00e1-\u00fa|\u00f1|\u00d1|\u00fc|\u00dc|#|!|?|.|~|\\-|\\\\_|'| ]{1,40}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno Modificado\n",
            "example": "apellidoPaterno"
          },
          "apellidoMaterno": {
            "pattern": "^[A-Z|a-z|\u00c1-\u00da|\u00e1-\u00fa|\u00f1|\u00d1|\u00fc|\u00dc|#|!|?|.|~|\\-|\\\\_|'| ]{1,40}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno\n",
            "example": "apellidoMaterno"
          },
          "nombreTrabajador": {
            "pattern": "^[A-Z|a-z|\u00c1-\u00da|\u00e1-\u00fa|\u00f1|\u00d1|\u00fc|\u00dc|#|!|?|.|~|\\-|\\\\_|'| ]{1,40}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre Trabajador\n",
            "example": "nombreTrabajador"
          },
          "fechaDeNacimiento": {
            "pattern": "((19|2[0-9])[0-9]{2})(0[1-9]|1[012])(0[1-9]|[12][0-9]|3[01])",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Nacimiento del Trabajador modificada con formato AAAAMMDD\n",
            "example": "19901010"
          },
          "entidadFederativaDeNacimiento": {
            "pattern": "^[0-9]{2}",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Seg\u00fan Catalogo General Clave de las Entidades Federativas\n",
            "example": "10"
          },
          "sexo": {
            "pattern": "^(1|2|3)",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo\n",
            "example": "1"
          },
          "estadoCivil": {
            "pattern": "^([0-1]{1})?",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Estado civil modificado del trabajador\n\n0:Soltero\n\n1:Casado\n",
            "example": "1"
          },
          "estatusPorParteDeLaAfore": {
            "pattern": "^(01|02)",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Estatus por parte de la Afore\n\n01 Aceptada la Modificaci\u00f3n notificada por PROCESAR en la Op. 54\n\n02 Rechazada la Modificaci\u00f3n notificada por PROCESAR en la Op. 54\n",
            "example": "01"
          },
          "tipoDeTrabajador": {
            "pattern": "^(1|2)",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "1 - IMSS\n\n2- ISSSTE\n",
            "example": "1"
          },
          "indicadorDeUnificacionAutorizada": {
            "pattern": "^([0-9]{1})?",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador de Unificacion Autorizada\n",
            "example": "1"
