          "curpSolicitante": {
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del Solicitante (Titular, Beneficiario, Apoderado legal, Curador)\n\nCuando sea una solicitud por el proceso de Apertura de Cuentas deber\u00e1 de ser la CURP del Trabajador\n",
            "example": "AAAA000000AAAAAAAA"
