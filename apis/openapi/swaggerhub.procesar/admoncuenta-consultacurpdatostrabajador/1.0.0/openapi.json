{
  "openapi": "3.0.1",
  "info": {
    "title": "Consulta CURP Datos Trabajador",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para consultar la CURP por datos del trabajador",
    "contact": {
      "email": "jcsantia@procesar.com"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar/Admoncuenta-ConsultaCURPDatosTrabajador/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/806/trabajadores/curp/"
    }
  ],
  "tags": [
    {
      "name": "Consulta CURP Datos Trabajador",
      "description": "Operaci\u00f3n para consular la CURP mediante los datos del trabajador"
    }
  ],
  "paths": {
    "/datos": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Admocuenta - Consulta CURP Datos Trabajador",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "datos",
        "tags": [
          "Consulta CURP Datos Trabajador"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "Atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "enum": [
                "806"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "Atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "28"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "Atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "5",
                "6"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para la consulta de CURP por datos del trabajador",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/consultarDatosRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/consultarDatosResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/consultarDatosResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "consultarDatosRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "consultarDatosRequest": {
        "required": [
          "afore",
          "origenConsulta",
          "primerApellido",
          "nombre",
          "sexo",
          "fechaNacimiento",
          "cveAlfaEntFedNac"
        ],
        "type": "object",
        "properties": {
          "afore": {
            "pattern": "^[0-9][0-9][0-9]$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que realiza la consulta.",
            "example": "538"
          },
          "origenConsulta": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "01",
            "description": "Origen de la Consulta\n\n01 - Web\n"
          },
          "primerApellido": {
            "pattern": "^([A-Z|\u00c1-\u00da|\u00d1]{1}[A-Z|\u00c1-\u00da|\u00d1|\u00dc|#|!|\u00a1|\u00bf|?|.|~|\\-|\\\\_|\\\\/|'|\u00b4| ]{0,49})?$",
            "type": "string",
            "minLength": 0,
            "maxLength": 50,
            "description": "Apellido paterno del Trabajador.",
            "example": "apellidoPaternoTrabajador"
          },
          "segundoApellido": {
            "pattern": "^([A-Z|\u00c1-\u00da|\u00d1]{1}[A-Z|\u00c1-\u00da|\u00d1|\u00dc|#|!|\u00a1|\u00bf|?|.|~|\\-|\\\\_|\\\\/|'|\u00b4| ]{0,49})?$",
            "type": "string",
            "minLength": 0,
            "maxLength": 50,
            "description": "Apellido materno del Trabajador.",
            "example": "apellidoMaternoTrabajador"
          },
          "nombre": {
            "pattern": "^([A-Z|\u00c1-\u00da|\u00d1]{1}[A-Z|\u00c1-\u00da|\u00d1|\u00dc|#|!|\u00a1|\u00bf|?|.|~|\\-|\\\\_|\\\\/|'|\u00b4| ]{0,49})?$",
            "type": "string",
            "minLength": 0,
            "maxLength": 50,
            "description": "Nombre(s) del Trabajador.",
            "example": "nombreTrabajador"
          },
          "sexo": {
            "pattern": "^H|M$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Identificador de tipo de sexo.\n\nH: Hombre\n\nM: Mujer\n",
            "example": "H"
          },
          "fechaNacimiento": {
            "pattern": "^[0-3]{1}[0-9]{1}[/]{1}[0,1]{1}[0-9]{1}[/][0-2]{1}[0-9]{3}$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Fecha de Nacimiento en formato\nDD/MM/AAAA Donde D=d\u00eda; M=mes; A=a\u00f1o.\n",
            "example": "20/12/2000"
          },
          "cveAlfaEntFedNac": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave de la Entidad Federativa de Nacimiento\n",
            "example": "01"
          }
        }
      },
      "consultarDatosResponse": {
        "required": [
          "resultadoOperacion",
          "respuesta"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "C\u00f3digo de la respuesta de la consulta:\n\n01 = Aceptada\n\n02 = Rechazada\n",
            "example": "01"
          },
          "motivoRechazo": {
            "pattern": "^([0-9]{3})?$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Diagn\u00f3sticos o motivos de rechazo del proceso de acuerdo al resultado de la operaci\u00f3n \ncuando es  02 y cuando el resultado de la operaci\u00f3n es 01, se enviar\u00e1 vac\u00edo\n",
            "example": "T02"
          },
          "respuesta": {
            "type": "string",
            "description": "Respuesta del servicio de RENAPO.\n\nCuando el resultado de la operaci\u00f3n es 02, se enviar\u00e1 vac\u00edo.\n",
            "example": "<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\\n<CURPCollection statusOper=\\\"EXITOSO\\\" message=\\\"LA OPERACION SE EJECUTO.\\\" TipoError=\\\"\\\" CodigoError=\\\"\\\" SessionID=\\\"PVVcDHdZsOqad3zBgmGQFXvuG1bfwq_SVOVOGeJ8qs65klMUnHdm!-1054687436!1573502351193\\\"><CURPStruct><CURP>AAAA800910HDFRLD02<\\/CURP><apellido1>PEREZ<\\/apellido1><apellido2>HERNANDEZ<\\/apellido2><nombres>EDUARDO<\\/nombres><sexo>H<\\/sexo><fechNac>30/09/1983<\\/fechNac><nacionalidad>MEX<\\/nacionalidad><docProbatorio>1<\\/docProbatorio><anioReg>1983<\\/anioReg><foja><\\/foja><tomo><\\/tomo><libro><\\/libro><numActa>10601<\\/numActa><CRIP><\\/CRIP><numEntidadReg>09<\\/numEntidadReg><cveMunicipioReg>014<\\/cveMunicipioReg><NumRegExtranjeros><\\/NumRegExtranjeros><FolioCarta><\\/FolioCarta><cveEntidadNac>DF<\\/cveEntidadNac><cveEntidadEmisora><\\/cveEntidadEmisora><statusCurp>RCN<\\/statusCurp><\\/CURPStruct><\\/CURPCollection>"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "Expected element 'message' instead of 'file' here in element validacionFacialRequest@http://www.procesar.com.mx/Biometricos/ValidacionFacial/Usuario/validarDatos/"
            ]
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "example": [
              {
                "consultarDatosRequest": {
                  "afore": "534"
                }
              }
            ]
          }
        }
      }
    }
  }
}