{
  "openapi": "3.0.3",
  "info": {
    "title": "Samsara API",
    "version": "1.0.0",
    "description": "Samsara is a fleet management and IoT platform. This API provides access to addresses, contacts, vehicles, drivers, trailers, equipment, routes, safety, compliance (HOS/ELD), DVIRs, alerts, and webhooks.",
    "x-jentic-source-url": "https://developers.samsara.com/reference"
  },
  "servers": [
    {
      "url": "https://api.samsara.com",
      "description": "Samsara Production API"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    { "name": "Addresses", "description": "Address management" },
    { "name": "Alerts", "description": "Alert configuration and incidents" },
    { "name": "Contacts", "description": "Contact management" },
    { "name": "Vehicles", "description": "Vehicle management" },
    { "name": "VehicleLocations", "description": "Vehicle location data" },
    { "name": "VehicleStats", "description": "Vehicle statistics" },
    { "name": "Drivers", "description": "Driver management" },
    { "name": "Trailers", "description": "Trailer asset management" },
    { "name": "Equipment", "description": "Equipment management" },
    { "name": "Routes", "description": "Route management" },
    { "name": "Safety", "description": "Safety scores and events" },
    { "name": "HOS", "description": "Hours of service compliance" },
    { "name": "DVIRs", "description": "Driver vehicle inspection reports" },
    { "name": "Webhooks", "description": "Webhook management" }
  ],
  "paths": {
    "/addresses": {
      "get": {
        "operationId": "listAddresses",
        "tags": ["Addresses"],
        "summary": "List all addresses",
        "responses": {
          "200": { "description": "List of addresses", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddressListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createAddress",
        "tags": ["Addresses"],
        "summary": "Create an address",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddressRequest" } } } },
        "responses": {
          "200": { "description": "Address created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddressResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/addresses/{id}": {
      "get": {
        "operationId": "getAddress",
        "tags": ["Addresses"],
        "summary": "Retrieve an address",
        "parameters": [ { "$ref": "#/components/parameters/ResourceId" } ],
        "responses": {
          "200": { "description": "Address details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddressResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "operationId": "updateAddress",
        "tags": ["Addresses"],
        "summary": "Update an address",
        "parameters": [ { "$ref": "#/components/parameters/ResourceId" } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddressRequest" } } } },
        "responses": {
          "200": { "description": "Address updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddressResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteAddress",
        "tags": ["Addresses"],
        "summary": "Delete an address",
        "parameters": [ { "$ref": "#/components/parameters/ResourceId" } ],
        "responses": {
          "204": { "description": "Address deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/alert-configurations": {
      "get": {
        "operationId": "listAlertConfigurations",
        "tags": ["Alerts"],
