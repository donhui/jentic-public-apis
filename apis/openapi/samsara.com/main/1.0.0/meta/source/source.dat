  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Samsara API token passed as Bearer token"
      }
    },
    "parameters": {
      "ResourceId": { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Resource ID" }
    },
    "responses": {
      "BadRequest": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Unauthorized": { "description": "Unauthorized - invalid or missing bearer token", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
    },
    "schemas": {
      "Error": { "type": "object", "properties": { "message": { "type": "string" }, "requestId": { "type": "string" } } },
      "Pagination": { "type": "object", "properties": { "endCursor": { "type": "string" }, "hasNextPage": { "type": "boolean" } } },
      "Address": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "formattedAddress": { "type": "string" }, "latitude": { "type": "number" }, "longitude": { "type": "number" } } },
      "AddressRequest": { "type": "object", "properties": { "name": { "type": "string" }, "formattedAddress": { "type": "string" }, "latitude": { "type": "number" }, "longitude": { "type": "number" } }, "required": ["name"] },
      "AddressResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Address" } } },
      "AddressListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Address" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "AlertConfigRequest": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "string" } } },
      "AlertConfigResponse": { "type": "object", "properties": { "data": { "type": "object" } } },
      "AlertConfigListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } },
      "AlertIncidentListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } },
      "Contact": { "type": "object", "properties": { "id": { "type": "string" }, "firstName": { "type": "string" }, "lastName": { "type": "string" }, "email": { "type": "string" }, "phone": { "type": "string" } } },
      "ContactRequest": { "type": "object", "properties": { "firstName": { "type": "string" }, "lastName": { "type": "string" }, "email": { "type": "string" }, "phone": { "type": "string" } }, "required": ["firstName", "lastName"] },
      "ContactResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Contact" } } },
      "ContactListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Contact" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "Vehicle": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "vin": { "type": "string" }, "make": { "type": "string" }, "model": { "type": "string" }, "year": { "type": "integer" } } },
      "VehicleRequest": { "type": "object", "properties": { "name": { "type": "string" }, "vin": { "type": "string" } } },
      "VehicleResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Vehicle" } } },
      "VehicleListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Vehicle" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "VehicleLocation": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "latitude": { "type": "number" }, "longitude": { "type": "number" }, "speed": { "type": "number" }, "time": { "type": "string", "format": "date-time" } } },
      "VehicleLocationListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/VehicleLocation" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "VehicleStatsResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "Driver": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "username": { "type": "string" }, "phone": { "type": "string" }, "licenseNumber": { "type": "string" }, "licenseState": { "type": "string" } } },
      "DriverRequest": { "type": "object", "properties": { "name": { "type": "string" }, "username": { "type": "string" }, "password": { "type": "string" }, "phone": { "type": "string" }, "licenseNumber": { "type": "string" }, "licenseState": { "type": "string" } }, "required": ["name", "username", "password"] },
      "DriverResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Driver" } } },
      "DriverListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Driver" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "TrailerRequest": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] },
      "TrailerResponse": { "type": "object", "properties": { "data": { "type": "object" } } },
      "TrailerListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "EquipmentResponse": { "type": "object", "properties": { "data": { "type": "object" } } },
      "EquipmentListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "EquipmentStatsResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } },
      "RouteRequest": { "type": "object", "properties": { "name": { "type": "string" }, "driverId": { "type": "string" }, "vehicleId": { "type": "string" } }, "required": ["name"] },
      "RouteResponse": { "type": "object", "properties": { "data": { "type": "object" } } },
      "RouteListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "SafetyEventListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "SafetyScoreResponse": { "type": "object", "properties": { "data": { "type": "object", "properties": { "safetyScore": { "type": "number" }, "totalMilesDriven": { "type": "number" } } } } },
      "HosClockListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } },
      "HosLogListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } },
      "HosViolationListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } },
      "DvirRequest": { "type": "object", "properties": { "vehicleId": { "type": "string" }, "inspectionType": { "type": "string" } } },
      "DvirResolveRequest": { "type": "object", "properties": { "resolved": { "type": "boolean" }, "mechanicNotes": { "type": "string" } } },
      "DvirResponse": { "type": "object", "properties": { "data": { "type": "object" } } },
      "DvirListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } },
      "WebhookRequest": { "type": "object", "properties": { "url": { "type": "string", "format": "uri" }, "eventTypes": { "type": "array", "items": { "type": "string" } } }, "required": ["url", "eventTypes"] },
      "WebhookResponse": { "type": "object", "properties": { "data": { "type": "object" } } },
      "WebhookListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } }, "pagination": { "$ref": "#/components/schemas/Pagination" } } }
    }
  }
}