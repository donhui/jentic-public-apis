          { "name": "endTime", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": { "description": "Historical locations", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VehicleLocationListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
