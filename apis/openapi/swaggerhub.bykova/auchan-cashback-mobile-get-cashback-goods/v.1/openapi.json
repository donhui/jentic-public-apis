{
  "openapi": "3.0.0",
  "info": {
    "version": "v.1",
    "title": "Auchan cashback api. Mobile.",
    "description": "Middleware api for mobile.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/bykova/auchan_cashback_mobile_get_cashback_goods/v.1/swagger.json"
  },
  "paths": {
    "/cashback/mobile/v.0.1/check_cards": {
      "post": {
        "summary": "Returns token list enriched by cashback flag",
        "tags": [
          "Cashback"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "description": "The payload of tokens",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokensRequest"
              }
            }
          }
        },
        "parameters": [
          {
            "in": "header",
            "name": "access-token",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Personal cabinet Access Token. Level 30"
          },
          {
            "in": "path",
            "name": "muid",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "User's Magento Account Id"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    },
                    "tokens": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "tokenId": {
                            "type": "integer"
                          },
                          "pan": {
                            "type": "string"
                          },
                          "scheme": {
                            "type": "string"
                          },
                          "cashback": {
                            "type": "string"
                          },
                          "cashback_message": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "$ref": "",
            "examples": {
              "noCashback": {
                "code": 0,
                "message": "",
                "tokens": [
                  {
                    "tokenId": 123456,
                    "pan": "123456_1234",
                    "scheme": "VISA",
                    "cashback": "CB0",
                    "cashback_message": ""
                  }
                ]
              },
              "hasCashback": {
                "code": 0,
                "message": "",
                "tokens": [
                  {
                    "tokenId": 123456,
                    "pan": "123456_1234",
                    "scheme": "VISA",
                    "cashback": "CB1",
                    "cashback_message": ""
                  }
                ]
              },
              "error": {
                "code": 1,
                "message": "",
                "tokens": []
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "access_token"
      }
    },
    "schemas": {
      "TokensRequest": {
        "type": "object",
        "properties": {
          "tokens": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tokenId": {
                  "type": "integer"
                },
                "pan": {
                  "type": "string"
                },
                "scheme": {
                  "type": "string"
                }
              }
            }
          }
        },
        "example": {
          "tokens": [
            {
              "tokenId": 123456,
              "pan": "123456_1234",
              "scheme": "VISA"
            }
          ]
        }
      }
    }
  },
  "tags": [
    {
      "name": "Cashback",
      "description": "API's for mobile"
    }
  ]
}