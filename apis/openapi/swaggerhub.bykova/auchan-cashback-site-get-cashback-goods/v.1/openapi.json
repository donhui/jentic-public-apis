{
  "openapi": "3.0.0",
  "info": {
    "version": "v.1",
    "title": "Auchan cashback api. Site.",
    "description": "Middleware api for site.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/bykova/auchan_cashback_site_get_cashback_goods/v.1/swagger.json"
  },
  "paths": {
    "/cashback/site/v.1/getCashbackGoods": {
      "get": {
        "summary": "Returns list of articles that may cause having cashback",
        "security": [
          {
            "BasicAuth": [
              "read"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CashbackGood"
                }
              }
            }
          }
        }
      }
    },
    "/cashback/site/v.1/check_cards": {
      "post": {
        "summary": "Returns token list enriched by cashback flag",
        "security": [
          {
            "BasicAuth": [
              "read"
            ]
          }
        ],
        "requestBody": {
          "description": "The payload of tokens",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokensRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "message": {
                      "type": "string"
                    },
                    "tokens": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "tokenId": {
                            "type": "integer"
                          },
                          "pan": {
                            "type": "string"
                          },
                          "scheme": {
                            "type": "string"
                          },
                          "cashback": {
                            "type": "string"
                          },
                          "cashback_message": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "$ref": "",
            "examples": {
              "noCashback": {
                "code": 0,
                "message": "",
                "tokens": [
                  {
                    "tokenId": 121262,
                    "pan": "427631_7854",
                    "scheme": "VISA",
                    "cashback": "CB0",
                    "cashback_message": ""
                  }
                ]
              },
              "hasCashback": {
                "code": 0,
                "message": "",
                "tokens": [
                  {
                    "tokenId": 121262,
                    "pan": "427631_7854",
                    "scheme": "VISA",
                    "cashback": "CB1",
                    "cashback_message": ""
                  }
                ]
              },
              "error": {
                "code": 1,
                "message": "",
                "tokens": []
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "schemas": {
      "CashbackGood": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "article": {
              "type": "string"
            }
          },
          "example": {
            "article": "123456"
          }
        }
      },
      "TokensRequest": {
        "type": "object",
        "properties": {
          "tokens": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tokenId": {
                  "type": "integer"
                },
                "pan": {
                  "type": "string"
                },
                "scheme": {
                  "type": "string"
                }
              }
            }
          }
        },
        "example": {
          "tokens": [
            {
              "tokenId": 121262,
              "pan": "427631_7854",
              "scheme": "VISA"
            }
          ]
        }
      }
    }
  }
}