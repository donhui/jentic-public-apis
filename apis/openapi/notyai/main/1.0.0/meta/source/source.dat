{
  "openapi": "3.0.3",
  "info": {
    "title": "Noty.ai Public API",
    "description": "Noty.ai is an AI Meeting Assistant that allows you to transcribe, summarize and automate your meetings workflow, organize and keep track of tasks. This API provides access to user profiles, event subscriptions, and OAuth2 authentication.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.noty.ai/openapi"
  },
  "servers": [
    {
      "url": "https://api.noty.ai"
    }
  ],
  "tags": [
    {
      "name": "oauth2",
      "description": "OAuth2 authorization endpoints"
    },
    {
      "name": "events",
      "description": "Event subscription management"
    },
    {
      "name": "users",
      "description": "User profile operations"
    }
  ],
  "paths": {
    "/trpc/users.profile": {
      "get": {
        "operationId": "users-profile",
        "summary": "Gets user profile",
        "tags": ["users"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/error"
          }
        }
      }
    },
    "/trpc/events.subscribe": {
      "post": {
        "operationId": "events-subscribe",
        "summary": "Subscribes a client to an event",
        "tags": ["events"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventSubscribeRequest"
              }
            }
          }
        },
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventSubscription"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/error"
          }
        }
      }
    },
    "/trpc/events.unsubscribe": {
      "post": {
        "operationId": "events-unsubscribe",
        "summary": "Unsubscribes a client from an event",
        "tags": ["events"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subscriptionId": {
                    "type": "number"
                  }
                },
                "required": ["subscriptionId"]
              }
            }
          }
        },
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    }
                  },
                  "required": ["id"]
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/error"
          }
        }
      }
    },
    "/trpc/events.sample": {
      "get": {
        "operationId": "events-sample",
        "summary": "Returns sample data for an event",
        "tags": ["events"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["CONVERSATION_FINISHED", "SUMMARY_CREATED", "TODO_ITEMS_CREATED", "TODO_ITEM_UPDATED"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ConversationFinishedSample"
                    },
                    {
                      "$ref": "#/components/schemas/SummaryCreatedSample"
                    },
                    {
                      "$ref": "#/components/schemas/TodoItemsCreatedSample"
                    }
                  ]
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/error"
          }
        }
      }
    },
    "/oauth2/authorize": {
      "post": {
        "summary": "Creates an authorization code for a client",
        "tags": ["oauth2"],
        "description": "This endpoint is used to initiate the OAuth2 authorizationCode flow with PKCE.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "redirect": {
                      "type": "string",
                      "format": "uri",
                      "description": "The URL to redirect the user to after authorization."
                    }
                  },
                  "required": ["redirect"]
                }
              }
            }
          },
          "default": {
            "description": "Client error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/oauth2/token": {
      "post": {
        "summary": "Exchanges an authorization code or refresh token for an access token",
        "tags": ["oauth2"],
        "description": "This endpoint is used to exchange an authorization code or refresh token for a new pair of access and refresh tokens.",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/AuthorizationCodeGrantRequest"
                  },
                  {
                    "$ref": "#/components/schemas/RefreshTokenGrantRequest"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "default": {
            "description": "Client error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "companyName": {
            "type": "string",
            "nullable": true
          },
          "companyRole": {
            "type": "string",
            "nullable": true
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "required": ["id", "email", "name", "companyName", "companyRole", "avatarUrl"]
      },
      "EventSubscribeRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["CONVERSATION_FINISHED", "SUMMARY_CREATED", "TODO_ITEMS_CREATED", "TODO_ITEM_UPDATED"]
          },
          "resourceId": {
            "type": "string"
          },
          "hookUrl": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": ["type", "resourceId", "hookUrl"]
      },
      "EventSubscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["id", "expiresAt"]
      },
      "ConversationFinishedSample": {
        "type": "object",
        "properties": {
          "conversationName": {
            "type": "string"
          },
          "transcription": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "startTime": {
                  "type": "string",
                  "format": "date-time"
                },
                "endTime": {
                  "type": "string",
                  "format": "date-time"
                },
                "speaker": {
                  "$ref": "#/components/schemas/Speaker"
                }
              },
              "required": ["text", "startTime", "endTime"]
            }
          }
        },
        "required": ["conversationName", "transcription"]
      },
      "SummaryCreatedSample": {
        "type": "object",
        "properties": {
          "conversationName": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "required": ["conversationName", "summary"]
      },
      "TodoItemsCreatedSample": {
        "type": "object",
        "properties": {
          "conversationName": {
            "type": "string"
          },
          "todoItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "title": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "dueAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "assignee": {
                  "$ref": "#/components/schemas/Speaker"
                }
              },
              "required": ["id", "title"]
            }
          }
        },
        "required": ["conversationName", "todoItems"]
      },
      "Speaker": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": ["id", "name"]
      },
      "AuthorizeRequest": {
        "type": "object",
        "properties": {
          "response_type": {
            "type": "string",
            "enum": ["code"]
          },
          "client_id": {
            "type": "string",
            "format": "uuid"
          },
          "redirect_uri": {
            "type": "string",
            "format": "uri"
          },
          "scope": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "code_challenge": {
            "type": "string"
          },
          "code_challenge_method": {
            "type": "string",
            "enum": ["S256"]
          }
        },
        "required": ["response_type", "client_id", "redirect_uri", "scope", "state", "code_challenge", "code_challenge_method"]
      },
      "AuthorizationCodeGrantRequest": {
        "type": "object",
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": ["authorization_code"]
          },
          "client_id": {
            "type": "string",
            "format": "uuid"
          },
          "client_secret": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "code_verifier": {
            "type": "string"
          },
          "redirect_uri": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": ["grant_type", "client_id", "client_secret", "code", "code_verifier", "redirect_uri"]
      },
      "RefreshTokenGrantRequest": {
        "type": "object",
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": ["refresh_token"]
          },
          "client_id": {
            "type": "string",
            "format": "uuid"
          },
          "client_secret": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string"
          }
        },
        "required": ["grant_type", "client_id", "client_secret", "refresh_token"]
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "accessTokenExpiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "refreshToken": {
            "type": "string"
          },
          "refreshTokenExpiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "scope": {
            "type": "string"
          },
          "client": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "grants": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["authorization_code", "refresh_token"]
                }
              }
            },
            "required": ["id", "grants"]
          },
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "name": {
                "type": "string"
              }
            },
            "required": ["id", "email"]
          }
        },
        "required": ["accessToken", "accessTokenExpiresAt", "refreshToken", "refreshTokenExpiresAt", "scope", "client", "user"]
      },
      "ClientErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number"
          },
          "code": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["statusCode", "code", "error", "message"]
      }
    },
    "responses": {
      "error": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                },
                "issues": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "message": {
                        "type": "string"
                      }
                    },
                    "required": ["message"]
                  }
                }
              },
              "required": ["message", "code"]
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "description": "Bearer token authentication.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
