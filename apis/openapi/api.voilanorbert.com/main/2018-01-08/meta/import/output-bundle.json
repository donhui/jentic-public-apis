            "type": "string",
            "description": "Current enrichment status."
          },
          "total": {
            "type": "integer",
            "description": "Total emails to enrich."
          },
          "processed": {
            "type": "integer",
            "description": "Emails enriched so far."
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Success message."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message."
          }
        }
      }
