  "components": {
    "schemas": {
      "SearchByNameRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of the person to search for."
          },
          "domain": {
            "type": "string",
            "description": "Company domain name."
          },
          "company": {
            "type": "string",
            "description": "Company name (alternative to domain)."
          },
          "webhook": {
            "type": "string",
            "description": "Callback URL for async results."
          },
          "list_id": {
            "type": "integer",
            "description": "ID of the list to add the contact to."
          }
        },
        "required": [
          "name"
        ]
      },
      "SearchByDomainRequest": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Company domain name."
          },
          "company": {
            "type": "string",
            "description": "Company name (alternative to domain)."
          },
          "list_id": {
            "type": "integer",
            "description": "ID of the list to add contacts to."
          },
          "page": {
            "type": "integer",
            "description": "Page number for pagination."
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Found email address."
          },
          "score": {
            "type": "number",
            "description": "Confidence score."
          },
          "searching": {
            "type": "boolean",
            "description": "Whether the search is still in progress."
          }
        }
      },
      "BulkSearchRequest": {
        "type": "object",
        "properties": {
          "col_name": {
            "type": "string",
            "description": "Column index for names in CSV."
          },
          "col_company": {
            "type": "string",
            "description": "Column index for company/domain in CSV."
          },
          "content": {
            "type": "string",
            "description": "CSV data content."
          },
          "file_url": {
            "type": "string",
            "description": "URL to a CSV file (alternative to content)."
          },
          "webhook": {
            "type": "string",
            "description": "Callback URL for completion notification."
          },
          "rerun_frequency": {
            "type": "integer",
            "description": "Hours between automatic reruns."
          },
          "webhook_file_retention_time": {
            "type": "integer",
            "description": "Hours to retain webhook file."
          }
        },
        "required": [
          "col_name",
          "col_company",
          "webhook"
        ]
      },
      "BulkSearchStatus": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Bulk search file ID."
          },
          "status": {
            "type": "string",
            "description": "Current status of the bulk search."
          },
          "total": {
            "type": "integer",
            "description": "Total number of records."
          },
          "processed": {
            "type": "integer",
            "description": "Number of records processed."
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Account email."
          },
          "credits": {
            "type": "integer",
            "description": "Remaining search credits."
          }
        }
      },
      "Organization": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Organization name."
          }
        }
      },
      "Credits": {
        "type": "object",
        "properties": {
          "credits": {
            "type": "integer",
            "description": "Remaining credits."
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Contact ID."
          },
          "name": {
            "type": "string",
            "description": "Contact name."
          },
          "email": {
            "type": "string",
            "description": "Contact email address."
          },
          "company": {
            "type": "string",
            "description": "Company name."
          },
          "status": {
            "type": "string",
            "description": "Email verification status."
          }
        }
      },
      "ContactList": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "List ID."
          },
          "name": {
            "type": "string",
            "description": "List name."
          },
          "count": {
            "type": "integer",
            "description": "Number of contacts in the list."
          }
        }
      },
      "VerifyUploadRequest": {
        "type": "object",
        "properties": {
          "data": {
            "type": "string",
            "description": "Comma-separated email addresses to verify."
          },
