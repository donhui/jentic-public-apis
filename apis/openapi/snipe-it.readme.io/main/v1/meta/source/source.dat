        "parameters": [ { "$ref": "#/components/parameters/ResourceId" } ],
        "responses": {
          "200": { "description": "Group deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatusResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/suppliers": {
      "get": {
        "operationId": "listSuppliers",
        "summary": "List all suppliers",
        "tags": ["Suppliers"],
        "parameters": [ { "$ref": "#/components/parameters/Limit" }, { "$ref": "#/components/parameters/Offset" }, { "$ref": "#/components/parameters/Search" } ],
        "responses": {
          "200": { "description": "List of suppliers", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/suppliers/{id}": {
      "get": {
        "operationId": "getSupplier",
        "summary": "Get supplier by ID",
        "tags": ["Suppliers"],
        "parameters": [ { "$ref": "#/components/parameters/ResourceId" } ],
        "responses": {
          "200": { "description": "Supplier details", "content": { "application/json": { "schema": { "type": "object" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/maintenances": {
      "get": {
        "operationId": "listMaintenances",
        "summary": "List all asset maintenances",
        "tags": ["Maintenances"],
        "parameters": [ { "$ref": "#/components/parameters/Limit" }, { "$ref": "#/components/parameters/Offset" }, { "$ref": "#/components/parameters/Search" } ],
        "responses": {
          "200": { "description": "List of maintenances", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createMaintenance",
        "summary": "Create an asset maintenance record",
        "tags": ["Maintenances"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["asset_id", "supplier_id", "asset_maintenance_type", "title", "start_date"], "properties": { "asset_id": { "type": "integer" }, "supplier_id": { "type": "integer" }, "asset_maintenance_type": { "type": "string" }, "title": { "type": "string" }, "start_date": { "type": "string", "format": "date" }, "completion_date": { "type": "string", "format": "date" }, "cost": { "type": "number" }, "notes": { "type": "string" } } } } } },
        "responses": {
          "200": { "description": "Maintenance created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatusResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/maintenances/{id}": {
      "put": {
        "operationId": "updateMaintenance",
        "summary": "Update an asset maintenance",
        "tags": ["Maintenances"],
        "parameters": [ { "$ref": "#/components/parameters/ResourceId" } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "asset_id": { "type": "integer" }, "supplier_id": { "type": "integer" }, "asset_maintenance_type": { "type": "string" }, "title": { "type": "string" }, "start_date": { "type": "string", "format": "date" }, "completion_date": { "type": "string", "format": "date" }, "cost": { "type": "number" }, "notes": { "type": "string" } } } } } },
        "responses": {
          "200": { "description": "Maintenance updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatusResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteMaintenance",
        "summary": "Delete an asset maintenance",
        "tags": ["Maintenances"],
        "parameters": [ { "$ref": "#/components/parameters/ResourceId" } ],
        "responses": {
          "200": { "description": "Maintenance deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatusResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/reports/activity": {
      "get": {
        "operationId": "getActivityReport",
        "summary": "Get activity report",
        "tags": ["Reports"],
        "parameters": [ { "$ref": "#/components/parameters/Limit" }, { "$ref": "#/components/parameters/Offset" } ],
        "responses": {
          "200": { "description": "Activity report", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/version": {
      "get": {
        "operationId": "getVersion",
        "summary": "Get API version",
        "tags": ["Hardware"],
        "responses": {
          "200": { "description": "Version info", "content": { "application/json": { "schema": { "type": "object", "properties": { "version": { "type": "string" } } } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token from Snipe-IT admin panel"
      }
    },
    "parameters": {
      "ResourceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": { "type": "integer", "default": 50 }
      },
      "Offset": {
        "name": "offset",
        "in": "query",
        "schema": { "type": "integer", "default": 0 }
      },
      "Search": {
        "name": "search",
        "in": "query",
        "schema": { "type": "string" }
      },
      "Sort": {
        "name": "sort",
        "in": "query",
        "schema": { "type": "string" }
      },
      "Order": {
        "name": "order",
        "in": "query",
        "schema": { "type": "string", "enum": ["asc", "desc"] }
      }
    },
    "schemas": {
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "rows": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "messages": { "type": "string" },
          "payload": { "type": "object" }
        }
      },
      "Hardware": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "asset_tag": { "type": "string" },
          "serial": { "type": "string" },
          "model": { "type": "object" },
          "status_label": { "type": "object" },
          "category": { "type": "object" },
          "manufacturer": { "type": "object" },
          "location": { "type": "object" },
          "assigned_to": { "type": "object" }
        }
      },
      "HardwareInput": {
        "type": "object",
        "required": ["asset_tag", "status_id", "model_id"],
        "properties": {
          "asset_tag": { "type": "string" },
          "status_id": { "type": "integer" },
          "model_id": { "type": "integer" },
          "name": { "type": "string" },
          "serial": { "type": "string" },
          "purchase_date": { "type": "string", "format": "date" },
          "purchase_cost": { "type": "number" },
          "order_number": { "type": "string" },
          "notes": { "type": "string" },
          "company_id": { "type": "integer" },
          "location_id": { "type": "integer" },
          "supplier_id": { "type": "integer" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "employee_num": { "type": "string" },
          "activated": { "type": "boolean" },
          "company": { "type": "object" },
          "department": { "type": "object" },
          "location": { "type": "object" }
        }
      },
      "UserInput": {
        "type": "object",
        "required": ["first_name", "username"],
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "username": { "type": "string" },
          "password": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "employee_num": { "type": "string" },
          "company_id": { "type": "integer" },
          "department_id": { "type": "integer" },
          "location_id": { "type": "integer" },
          "activated": { "type": "boolean" }
        }
      },
      "License": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "product_key": { "type": "string" },
          "seats": { "type": "integer" },
          "company": { "type": "object" },
          "category": { "type": "object" }
        }
      },
      "LicenseInput": {
        "type": "object",
        "required": ["name", "seats", "category_id"],
        "properties": {
          "name": { "type": "string" },
          "seats": { "type": "integer" },
          "category_id": { "type": "integer" },
          "company_id": { "type": "integer" },
          "product_key": { "type": "string" },
          "order_number": { "type": "string" },
          "purchase_date": { "type": "string", "format": "date" },
          "purchase_cost": { "type": "number" },
          "notes": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "messages": { "type": "string" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  }
}