{
  "openapi": "3.0.3",
  "info": {
    "title": "DISCO Reporting API",
    "description": "API for accessing datasets and metrics from DISCO's ediscovery platform. Provides access to data usage changes, review database size metrics, and related metadata.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.csdisco.com"
  },
  "servers": [
    {
      "url": "https://api.csdisco.com",
      "description": "DISCO API Production Server"
    }
  ],
  "paths": {
    "/datasets": {
      "post": {
        "operationId": "listDatasets",
        "summary": "List available datasets",
        "description": "Returns the list of all available dataset names.",
        "tags": ["Datasets"],
        "responses": {
          "200": {
            "description": "Successful response with list of datasets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/datasets/data-usage-changes": {
      "post": {
        "operationId": "getDataUsageChanges",
        "summary": "Get data usage changes dataset",
        "description": "Returns data usage change events within a specified date range.",
        "tags": ["Datasets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DataUsageChangesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with data usage changes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataUsageChangesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid date format or parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/datasets/data-usage-changes/metadata": {
      "post": {
        "operationId": "getDataUsageChangesMetadata",
        "summary": "Get data usage changes metadata",
        "description": "Returns metadata describing the fields, types, and descriptions for the data-usage-changes dataset.",
        "tags": ["Datasets"],
        "responses": {
          "200": {
            "description": "Successful response with dataset metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetMetadataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "post": {
        "operationId": "listMetrics",
        "summary": "List available metrics",
        "description": "Returns the list of all available metric names.",
        "tags": ["Metrics"],
        "responses": {
          "200": {
            "description": "Successful response with list of metrics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/metrics/metric-reviewdb-size": {
      "post": {
        "operationId": "getReviewDbSizeMetric",
        "summary": "Get review database size metric",
        "description": "Returns aggregated review database size information.",
        "tags": ["Metrics"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReviewDbSizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with review database size data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewDbSizeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/metrics/metric-reviewdb-size/metadata": {
      "post": {
        "operationId": "getReviewDbSizeMetadata",
        "summary": "Get review database size metric metadata",
        "description": "Returns metadata describing available attributes, aggregations, filter parameters, and supported filters for the review database size metric.",
        "tags": ["Metrics"],
        "responses": {
          "200": {
            "description": "Successful response with metric metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricMetadataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "disco-api-key",
        "description": "API key issued by DISCO"
      },
      "organizationId": {
        "type": "apiKey",
        "in": "header",
        "name": "organization-id",
        "description": "Organization identifier"
      }
    },
    "schemas": {
      "DatasetListResponse": {
        "type": "object",
        "properties": {
          "datasets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["data-usage-changes"]
          }
        }
      },
      "DataUsageChangesRequest": {
        "type": "object",
        "required": ["start-date", "end-date"],
        "properties": {
          "start-date": {
            "type": "string",
            "format": "date-time",
            "description": "Start date in ISO-8601 format"
          },
          "end-date": {
            "type": "string",
            "format": "date-time",
            "description": "End date in ISO-8601 format"
          },
          "header-row": {
            "type": "boolean",
            "default": true,
            "description": "Whether to include header row"
          },
          "review-db": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional list of review database IDs to filter by"
          }
        }
      },
      "DataUsageChangesResponse": {
        "type": "object",
        "properties": {
          "data-usage-changes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataUsageChangeRecord"
            }
          }
        }
      },
      "DataUsageChangeRecord": {
        "type": "object",
        "properties": {
          "review_db_name": {
            "type": "string"
          },
          "review_db_id": {
            "type": "string"
          },
          "matter_name": {
            "type": "string"
          },
          "session_operation": {
            "type": "string"
          },
          "input_bytes": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "DatasetMetadataResponse": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldMetadata"
            }
          }
        }
      },
      "FieldMetadata": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "MetricListResponse": {
        "type": "object",
        "properties": {
          "metrics": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["metric-reviewdb-size"]
          }
        }
      },
      "ReviewDbSizeRequest": {
        "type": "object",
        "required": ["end-date"],
        "properties": {
          "end-date": {
            "type": "string",
            "format": "date-time",
            "description": "End date in ISO-8601 format"
          },
          "content-type": {
            "type": "string",
            "description": "Response content type (json or csv)",
            "enum": ["json", "csv"]
          },
          "review-db": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional list of review database IDs to filter by"
          }
        }
      },
      "ReviewDbSizeResponse": {
        "type": "object",
        "properties": {
          "metric-reviewdb-size": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReviewDbSizeRecord"
            }
          }
        }
      },
      "ReviewDbSizeRecord": {
        "type": "object",
        "properties": {
          "review_db_name": {
            "type": "string"
          },
          "matter_name": {
            "type": "string"
          },
          "final_size": {
            "type": "integer",
            "format": "int64"
          },
          "review_state": {
            "type": "string"
          }
        }
      },
      "MetricMetadataResponse": {
        "type": "object",
        "properties": {
          "attributes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldMetadata"
            }
          },
          "aggregations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKey": [],
      "organizationId": []
    }
  ]
}