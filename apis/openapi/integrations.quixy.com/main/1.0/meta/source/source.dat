    },
    "/api/Navis/CheckCompanyExists": {
      "get": {
        "tags": ["Navis"],
        "summary": "Check if trucking company exists",
        "operationId": "checkCompanyExists",
        "responses": {
          "200": {
            "description": "Existence check result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/Navis/CheckTruckExists": {
      "get": {
        "tags": ["Navis"],
        "summary": "Check if truck exists",
        "operationId": "checkTruckExists",
        "responses": {
          "200": {
            "description": "Existence check result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/Navis/CheckDriverExists": {
      "get": {
        "tags": ["Navis"],
        "summary": "Check if driver exists",
        "operationId": "checkDriverExists",
        "responses": {
          "200": {
            "description": "Existence check result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Status": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
