        "responses": {
          "200": {
            "description": "List of trucking companies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Navis/CreateTruckingCompany": {
      "post": {
        "tags": ["Navis"],
        "summary": "Create trucking company",
        "operationId": "createTruckingCompany",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created company",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/Navis/GetTrucks": {
      "get": {
        "tags": ["Navis"],
