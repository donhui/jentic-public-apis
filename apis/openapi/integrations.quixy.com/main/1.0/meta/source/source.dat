        "responses": {
          "200": {
            "description": "List of trucks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Navis/CreateTruck": {
      "post": {
        "tags": ["Navis"],
        "summary": "Create truck record",
        "operationId": "createTruck",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created truck",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/Navis/GetDrivers": {
      "get": {
        "tags": ["Navis"],
        "summary": "Get drivers",
        "operationId": "getDrivers",
        "responses": {
          "200": {
            "description": "List of drivers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Navis/CreateDriver": {
      "post": {
        "tags": ["Navis"],
        "summary": "Create driver record",
        "operationId": "createDriver",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created driver",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
