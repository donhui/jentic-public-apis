{
  "openapi": "3.0.3",
  "info": {
    "title": "Quixy Chat Bot API",
    "description": "API for managing chatbot interactions, tasks, applications, and integrations within the Quixy platform.",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "https://integrations.quixy.com"
    }
  ],
  "paths": {
    "/api/ChatBotApi/GetUserPermission": {
      "get": {
        "tags": ["ChatBot"],
        "summary": "Get user permissions",
        "operationId": "getUserPermission",
        "responses": {
          "200": {
            "description": "User permission data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/ChatBotApi/GetAppsAccess": {
      "get": {
        "tags": ["ChatBot"],
        "summary": "Get app access list",
        "operationId": "getAppsAccess",
        "responses": {
          "200": {
            "description": "List of accessible apps",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/ChatBotApi/ValidateTask": {
      "post": {
        "tags": ["ChatBot"],
        "summary": "Validate a task",
        "operationId": "validateTask",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/ChatBotApi/RejectTask": {
      "post": {
        "tags": ["ChatBot"],
        "summary": "Reject a task",
        "operationId": "rejectTask",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rejection result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/ChatBotApi/CloseTask": {
      "post": {
        "tags": ["ChatBot"],
        "summary": "Close a task",
        "operationId": "closeTask",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Close result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/ChatBotApi/ReassignTask": {
      "post": {
        "tags": ["ChatBot"],
        "summary": "Reassign a task",
        "operationId": "reassignTask",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reassignment result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/ChatBotApi/UpdateTask": {
      "post": {
        "tags": ["ChatBot"],
        "summary": "Update task data",
        "operationId": "updateTask",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/ChatBotApi/GetCacheData": {
      "get": {
        "tags": ["ChatBot"],
        "summary": "Get cached data",
        "operationId": "getCacheData",
        "responses": {
          "200": {
            "description": "Cached data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/Integration/GetAppData": {
      "get": {
        "tags": ["Integration"],
        "summary": "Get app data",
        "operationId": "getAppData",
        "responses": {
          "200": {
            "description": "Application data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/Integration/CheckWebhookStatus": {
      "get": {
        "tags": ["Integration"],
        "summary": "Check webhook status",
        "operationId": "checkWebhookStatus",
        "responses": {
          "200": {
            "description": "Webhook status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/Integration/GetTokenBySecretKey": {
      "post": {
        "tags": ["Integration"],
        "summary": "Get auth token by secret key",
        "operationId": "getTokenBySecretKey",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "secretKey": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Auth token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Integration/GetReportData": {
      "get": {
        "tags": ["Integration"],
        "summary": "Get report data with filtering",
        "operationId": "getReportData",
        "responses": {
          "200": {
            "description": "Report data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/Integration/GetUserAccessApps": {
      "get": {
        "tags": ["Integration"],
        "summary": "List user-accessible apps",
        "operationId": "getUserAccessApps",
        "responses": {
          "200": {
            "description": "List of apps",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
