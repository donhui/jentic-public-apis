{
  "openapi": "3.0.3",
  "info": {
    "title": "TextUs Next API",
    "version": "1.0.0",
    "description": "API for the TextUs business texting platform. Manage contacts, conversations, messages, campaigns, groups, and more.",
    "x-jentic-source-url": "https://apidocs.next.textus.com"
  },
  "servers": [
    {
      "url": "https://next.textus.com"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/{account}/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "List contacts",
        "description": "Retrieves a list of contacts for the specified account.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactCollection"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createContact",
        "summary": "Create contact",
        "description": "Creates a new contact in the specified account.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{account}/contacts/{contact}": {
      "get": {
        "operationId": "getContact",
        "summary": "Get contact",
        "description": "Retrieves all known data about a particular contact.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          { "$ref": "#/components/parameters/ContactParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateContact",
        "summary": "Update contact",
        "description": "Updates an existing contact.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          { "$ref": "#/components/parameters/ContactParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteContact",
        "summary": "Delete contact",
        "description": "Deletes a contact.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          { "$ref": "#/components/parameters/ContactParam" }
        ],
        "responses": {
          "200": { "description": "Contact deleted" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{account}/contacts/{contact}/conversations": {
      "get": {
        "operationId": "getContactConversations",
        "summary": "Get contact conversations",
        "description": "Retrieves conversations associated with a contact.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          { "$ref": "#/components/parameters/ContactParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationCollection"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{account}/contacts/{contact}/tags": {
      "get": {
        "operationId": "getContactTags",
        "summary": "Get contact tags",
        "description": "Retrieves tags associated with a contact.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          { "$ref": "#/components/parameters/ContactParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{account}/contacts/upload": {
      "post": {
        "operationId": "uploadContacts",
        "summary": "Upload contacts",
        "description": "Bulk upload contacts from a file.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Upload accepted" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{account}/messages": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send message",
        "description": "Sends a message to one or more recipients via SMS or WhatsApp.",
        "tags": ["Messages"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message sent (single recipient)",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "202": {
            "description": "Messages accepted (multiple recipients)"
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "422": { "description": "Unprocessable Entity" }
        }
      }
    },
    "/{account}/messages/{message}": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get message",
        "description": "Retrieves a specific message.",
        "tags": ["Messages"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          {
            "name": "message",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateMessage",
        "summary": "Update message",
        "description": "Updates a message.",
        "tags": ["Messages"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          {
            "name": "message",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message updated",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteMessage",
        "summary": "Delete message",
        "description": "Deletes a message.",
        "tags": ["Messages"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          {
            "name": "message",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Message deleted" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{account}/messages/schedule": {
      "post": {
        "operationId": "scheduleMessage",
        "summary": "Schedule message",
        "description": "Schedules a message for future delivery.",
        "tags": ["Messages"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message scheduled",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/conversations/{conversation}": {
      "get": {
        "operationId": "getConversation",
        "summary": "Get conversation",
        "description": "Retrieves details of a conversation including timeline, participants, and status.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conversation"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/conversations/{conversation}/close": {
      "post": {
        "operationId": "closeConversation",
        "summary": "Close conversation",
        "description": "Closes the specified conversation.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Conversation closed" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/conversations/{conversation}/reopen": {
      "post": {
        "operationId": "reopenConversation",
        "summary": "Reopen conversation",
        "description": "Reopens a closed conversation.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Conversation reopened" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/conversations/{conversation}/block": {
      "post": {
        "operationId": "blockConversation",
        "summary": "Block conversation",
        "description": "Blocks the conversation.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Conversation blocked" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/conversations/{conversation}/unblock": {
      "post": {
        "operationId": "unblockConversation",
        "summary": "Unblock conversation",
        "description": "Unblocks a blocked conversation.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Conversation unblocked" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/conversations/{conversation}/timeline": {
      "get": {
        "operationId": "getConversationTimeline",
        "summary": "Get conversation timeline",
        "description": "Retrieves the timeline of messages and events for a conversation.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
