        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contact": { "type": "string", "description": "Contact resource path" }
                },
                "required": ["contact"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Contact added to group" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
