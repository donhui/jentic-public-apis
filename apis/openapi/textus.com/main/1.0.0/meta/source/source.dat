        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/TimelineCollection"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
