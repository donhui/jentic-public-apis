      "put": {
        "operationId": "updateUser",
        "summary": "Update user",
        "description": "Updates a user.",
        "tags": ["Users"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          {
            "name": "user",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user",
        "description": "Deletes a user.",
        "tags": ["Users"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" },
          {
            "name": "user",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "User deleted" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{account}/accounts": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account",
        "description": "Retrieves account details.",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{account}/opt_outs": {
      "get": {
        "operationId": "getOptOuts",
        "summary": "Get opt-outs",
        "description": "Retrieves opt-out settings.",
        "tags": ["Opt Outs"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/vnd.jsonld+json": {
                "schema": {
                  "$ref": "#/components/schemas/OptOut"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateOptOuts",
        "summary": "Update opt-outs",
        "description": "Updates opt-out settings.",
        "tags": ["Opt Outs"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountParam" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OptOut"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Opt-outs updated" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token generated from TextUs Next profile settings under Advanced user settings > API Tokens"
      }
    },
    "parameters": {
      "AccountParam": {
        "name": "account",
        "in": "path",
        "required": true,
        "description": "Account identifier",
        "schema": { "type": "string" }
      },
      "ContactParam": {
        "name": "contact",
        "in": "path",
        "required": true,
        "description": "Contact identifier",
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "@type": { "type": "string", "default": "Contact" },
          "name": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "phones": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContactPhone" }
          },
          "notes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContactNote" }
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "formattedData": {
            "type": "object",
            "additionalProperties": true
          },
          "groups": {
            "type": "array",
            "items": { "type": "string" }
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ContactPhone": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "number": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "ContactNote": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "body": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ContactCollection": {
        "type": "object",
        "properties": {
          "hydra:member": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Contact" }
          },
          "hydra:totalItems": { "type": "integer" }
        }
      },
      "CreateContactRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "phones": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "number": { "type": "string" },
                "type": { "type": "string" }
              },
              "required": ["number"]
            }
          },
          "data": {
            "type": "object",
            "properties": {
              "businessName": { "type": "string" },
              "tags": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "@type": { "type": "string", "default": "Message" },
          "body": { "type": "string" },
          "direction": { "type": "string", "enum": ["inbound", "outbound"] },
          "status": { "type": "string" },
          "channel": { "type": "string", "enum": ["sms", "whatsapp"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "attachments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Attachment" }
          }
        }
      },
      "Attachment": {
        "type": "object",
        "properties": {
          "media_url": { "type": "string", "format": "uri" },
          "content_type": { "type": "string" }
        }
      },
      "SendMessageRequest": {
        "type": "object",
        "properties": {
          "to": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Phone number(s) in E.164 format"
          },
          "body": { "type": "string", "description": "Message content" },
          "channel": { "type": "string", "enum": ["sms", "whatsapp"], "default": "sms" },
          "template": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "variable_values": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          },
          "attachments": {
            "type": "array",
            "maxItems": 1,
            "items": { "$ref": "#/components/schemas/Attachment" }
          }
        },
        "required": ["to"]
      },
      "Conversation": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "slug": { "type": "string" },
          "currentState": { "type": "string" },
          "phoneNumber": { "type": "string" },
          "formattedPhoneNumber": { "type": "string" },
          "blocked": { "type": "boolean" },
          "unsubscribed": { "type": "boolean" },
          "unanswered": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ConversationCollection": {
        "type": "object",
        "properties": {
          "hydra:member": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Conversation" }
          },
          "hydra:totalItems": { "type": "integer" }
        }
      },
      "TimelineCollection": {
        "type": "object",
        "properties": {
          "hydra:member": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Message" }
          },
          "hydra:totalItems": { "type": "integer" }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "messageBody": { "type": "string" },
          "state": { "type": "string" },
          "type": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "scheduledAt": { "type": "string", "format": "date-time" },
          "sendingStartAt": { "type": "string", "format": "date-time" },
          "sendingEndAt": { "type": "string", "format": "date-time" },
          "deliveryStatistics": { "$ref": "#/components/schemas/DeliveryStatistics" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "CampaignCollection": {
        "type": "object",
        "properties": {
          "hydra:member": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Campaign" }
          },
          "hydra:totalItems": { "type": "integer" }
        }
      },
      "CampaignAnalytics": {
        "type": "object",
        "properties": {
          "deliveryStatistics": { "$ref": "#/components/schemas/DeliveryStatistics" }
        }
      },
      "DeliveryStatistics": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "skipped": { "type": "integer" },
          "sent": { "type": "integer" },
          "delivered": { "type": "integer" },
          "replied": { "type": "integer" },
          "unreplied": { "type": "integer" },
          "failed": { "type": "integer" }
        }
      },
      "CreateCampaignRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "message_body": { "type": "string" },
          "scheduled_at": { "type": "string", "format": "date-time" },
          "recipients": {
            "type": "array",
            "items": { "type": "string" }
          },
          "contact_filter": { "type": "string" },
          "contact_collection": { "type": "string" },
          "auto-assign": { "type": "boolean" },
          "exclusion_time": { "type": "integer", "description": "Minutes to look back for recent campaign recipients to exclude" }
        },
        "required": ["title", "message_body", "scheduled_at"]
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "GroupCollection": {
        "type": "object",
        "properties": {
          "hydra:member": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Group" }
          },
          "hydra:totalItems": { "type": "integer" }
        }
      },
      "CreateGroupRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "OptOut": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "message": { "type": "string" }
        }
      }
    }
  }
}