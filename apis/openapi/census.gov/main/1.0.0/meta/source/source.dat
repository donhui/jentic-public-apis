{
  "openapi": "3.0.3",
  "info": {
    "title": "Census Data API",
    "version": "1.0.0",
    "description": "U.S. Census Bureau Data API providing access to census datasets including the American Community Survey (ACS), Decennial Census, County Business Patterns, and more. Query demographic, economic, and housing data by geography.",
    "x-jentic-source-url": "https://api.census.gov/data.html"
  },
  "servers": [
    {
      "url": "https://api.census.gov",
      "description": "Production"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Data",
      "description": "Census data queries"
    },
    {
      "name": "Discovery",
      "description": "Dataset discovery and metadata"
    }
  ],
  "paths": {
    "/data": {
      "get": {
        "operationId": "listDatasets",
        "tags": [
          "Discovery"
        ],
        "summary": "List all available census datasets",
        "responses": {
          "200": {
            "description": "Dataset listing",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dataset": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/data/{vintage}/{dataset}": {
      "get": {
        "operationId": "queryDataset",
        "tags": [
          "Data"
        ],
        "summary": "Query a specific census dataset",
        "parameters": [
          {
            "name": "vintage",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Year of the dataset (e.g. 2023)"
          },
          {
            "name": "dataset",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Dataset path (e.g. acs/acs5)"
          },
          {
            "name": "get",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated variable names (e.g. NAME,B01001_001E)"
          },
          {
            "name": "for",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Geography level and code (e.g. state:06, county:*, us:*)"
          },
          {
            "name": "in",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Parent geography constraint (e.g. state:06)"
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "API key"
          }
        ],
        "responses": {
          "200": {
            "description": "Query results as array of arrays",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/data/{vintage}/{dataset}/variables.json": {
      "get": {
        "operationId": "getDatasetVariables",
        "tags": [
          "Discovery"
        ],
        "summary": "List available variables for a dataset",
        "parameters": [
          {
            "name": "vintage",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Variables list"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/data/{vintage}/{dataset}/geography.json": {
      "get": {
        "operationId": "getDatasetGeography",
        "tags": [
          "Discovery"
        ],
        "summary": "List available geographies for a dataset",
        "parameters": [
          {
            "name": "vintage",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Geography list"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/data/{vintage}/{dataset}/groups.json": {
      "get": {
        "operationId": "getDatasetGroups",
        "tags": [
          "Discovery"
        ],
        "summary": "List available variable groups",
        "parameters": [
          {
            "name": "vintage",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Groups list"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "Census API key"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}