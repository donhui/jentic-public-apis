      "TerminalRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "secret_access_key",
                "organization_id",
                "serial_number",
                "registration_token",
                "sources"
              ],
              "properties": {
                "secret_access_key": {
                  "description": "The access key shared only between TAP and TB that provides authentication for calls coming from TAP.",
                  "type": "string"
                },
                "organization_id": {
                  "description": "The organization's TB ID that the terminal belongs to.",
                  "type": "integer"
                },
                "serial_number": {
                  "description": "The terminal's unique serial number.",
                  "type": "string"
                },
                "registration_token": {
                  "description": "The token that will be used by the terminal to authenticate itself.",
                  "type": "string"
                },
                "name": {
                  "description": "The terminal's name.",
                  "type": "string"
                },
                "device_model": {
                  "description": "The terminal's model.",
                  "type": "string"
                },
                "state": {
                  "description": "The terminal's state. This is used to determine what kind of commands can be handled by the terminal based on the state. Allowed values - `\"deployed\"`, `\"disabled\"`, `\"idle\"`, `\"handling_transaction\"`, `\"lost\"`, `\"paired\"`,\n  `\"pairing\"`, `\"provisioned\"`, `\"returned\"`, `\"shipped\"`\n",
                  "type": "string"
                },
                "validated_p2pe": {
                  "description": "If the terminal allows p2pe transactions or not.",
                  "type": "boolean"
                },
                "carecredit_standalone": {
                  "description": "If the terminal is carecredit standalone or not.",
                  "type": "boolean"
                },
                "sources": {
                  "description": "An array of source IDs that are associated with the terminal.",
                  "type": "array",
                  "items": {
                    "type": "integer"
                  }
                },
                "clients": {
                  "description": "An array of Client IDs that are associated with the terminal.",
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "RefundRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "ref_number",
                "refund_amount",
                "merchant_id"
              ],
              "properties": {
                "ref_number": {
                  "type": "string",
                  "description": "The reference number of the transaction that will be refunded."
                },
                "refund_amount": {
                  "type": "string",
                  "description": "The amount to refund, in USD up to 6 decimals that will be charged, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\")."
                },
                "merchant_id": {
                  "type": "string",
                  "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`"
                },
                "remote_id": {
                  "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..256`.",
                  "type": "string"
                },
                "client_id": {
                  "type": "string",
                  "description": "The client_id of client associated to the terminal.",
                  "example": "string"
                }
              }
            }
          }
        }
      },
