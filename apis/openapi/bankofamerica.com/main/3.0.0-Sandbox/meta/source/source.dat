      "HppResponseFields": {
        "type": "object",
        "properties": {
          "hpp": {
            "description": "The URL pointing to the Hosted Payment Page",
            "type": "string",
            "example": "https://gateway-staging.paymentfusion.com/hpp/start/95?hash=87ec2590b0c2fa3f0c351c5632ac3b678e564cea9b866fd62c2bbdf85b477803&TransactionType=Auth&Amount=1.010000&RemoteId=12abABADELA&InvoiceNumber=001&ForceDuplicate=true&AmountIsEditable=false&NonTaxable=false&TaxAmount=0.010000&ShippingAmount=0.010000&DiscountAmount=0.010000&TipAmount=0.010000&CustomerName=Yummy%20Gummy&PhoneNumber=0724&BillingFirstName=Yummy&BillingLastName=Gummy&BillingAddress1=My%20Address,%20nr%201&BillingAddress2=My%20Second%20Address%20,%20nr%202&BillingCity=MyCity&BillingState=ny&BillingZip=55555&ShippingIsBilling=true&ShippingFirstName=Yummy%20&ShippingLastName=Gummy&ShippingAddress1=My%20Address,%20nr%201&ShippingAddress2=My%20Second%20Address,%20nr%202&ShippingCity=MyCity&ShippingState=ny&ShippingZip=55555&Comment=Some%20Comment&Description=Some%20Description%20&Clerk=Clerk&ShortUrl=false&BalanceDue=10.010000&Patient=John%20Doe&Account=AW098889X9&Guarantor=John%20Doe&SecCode=WEB&ExpirationTime=24&CustomFields[0].Key=tb_id&CustomFields[0].Value=22107&CustomFields[1].Key=tb_transaction_type&CustomFields[1].Value=hpp&CustomFields[2].Key=remote_id&CustomFields[2].Value=12abABADELA&CustomFields[3].Key=client_id&CustomFields[3].Value=client_ididddd"
          }
        }
      },
      "TransactionResponseFields": {
        "type": "object",
        "properties": {
          "id": {
            "description": "The id of the transaction.",
            "type": "integer",
            "example": "integer"
          },
          "amount": {
            "description": "The amount in USD with 2 decimals that will be charged, must be a number greater than 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\").",
            "type": "string",
            "example": "string"
          },
          "serial_number": {
            "description": "The serial number of the terminal that was selected for this transaction. Size range - `256`",
            "type": "string",
            "example": "string"
          },
          "client_id": {
            "description": "The id of the client for wich a transaction was initiated. Size range - `256`",
            "type": "string",
            "example": "string"
          },
          "invoice": {
            "description": "Number of the invoice. If this field is not sent then the invoice will be given a unique identifier. Size range - `1..10`",
            "type": "string",
            "example": "string"
          },
          "ip_address": {
            "description": "IP address of the client requesting the transaction.",
            "type": "string",
            "example": "string"
          },
          "user_name": {
            "description": "The user name of the user that requested the transaction.",
            "type": "string",
            "example": "string"
          },
          "customer_name": {
            "description": "The name of the customer for this transaction.",
            "type": "string",
            "example": "string"
          },
          "software_name": {
            "description": "ISV software identifier.",
            "type": "string",
            "example": "string"
          },
          "clerk_number": {
            "description": "Identifies the clerk or person executing the transaction for reporting purposes.",
            "type": "string",
            "example": "string"
          },
          "transaction_status": {
            "description": "Confirmation from the payment gateway regarding the CC credentials and payment finalization. Allowed values - `\"approved\"`, `\"awaiting_amount\"`, `\"awaiting_confirmation\"`, `\"canceled\"`, `\"declined\"`, `\"emv_needing_reversal\"`, `\"error\"`, `\"in progress\"`, `\"internal error\"`, `\"timeout\"`, `\"verification\"`\n",
            "type": "string",
            "example": "string"
          },
          "credit_card_token": {
            "description": "Token issued by the gateway and that can be used for future transactions. Size range - `19`",
            "type": "string",
            "example": "string"
          },
          "card_type": {
            "description": "The type of the card that was submitted. Allowed values - `\"Discover\"`, `\"DISCOVER\"`, `\"UnionPay\"`, `\"AmEx\"`, `\"AMERICAN EXPRESS\"`, `\"AMEX\"`, `\"American express\"`, `\"Master\"`, `\"MASTERCARD\"`, `\"Mastercard\"`, `\"MASTERCARD/Mastercard\"`, `\"JCB\"`, `\"Jcb\"`, `\"Visa\"`, `\"VISA\"`,`\"Visa Traditional\"`, `\"Visa Classic\"`, `\"Visa Health\"`, `\"Visa Prefered\"`, `\"Mastercard/Eurocard\"`, `\"DINERS\"`, `\"CareCredit\"`, `\"Unknown Code\"`, `\"OTHER\"`, `\"null\"`, `\"N/A\"` The values are subject to change.\n",
            "type": "string",
            "example": "string"
          },
          "card_expiration_date": {
            "description": "The card expiration date. Format 'MMYY' (e.g. '0922').",
            "type": "string",
            "example": "string"
          },
          "masked_card_number": {
            "description": "The masked out card number including the last 4 digits (e.g. ************1234).",
            "type": "string",
            "example": "string"
          },
          "um_command": {
            "description": "The command that will be passed to the gateway.",
            "type": "string",
            "example": "string"
          },
          "created_at": {
            "description": "The time the transaction was created.",
            "type": "string",
            "example": "string"
          },
          "tip_amount": {
            "description": "The tip amount in USD that was added to this transaction.",
            "type": "string",
            "example": "string"
          },
          "tip_method": {
            "description": "The method in which the tip amount is entered in the system. \"specified\" is when it comes from the ISV, \"typed\" is when the customer types the tip amount on the terminal and \"written\" is when the customer writes the tip amount on the receipt and later an employee enters the tip on the ISV. When this param is not present, then it defaults to \"specified\".",
            "type": "string",
            "example": "string"
          },
          "cancel_requested": {
            "description": "If the transaction was canceled or not.",
            "type": "string",
            "example": "string"
          },
          "cancel_requested_at": {
            "description": "The time when the transaciton was canceled.",
            "type": "string",
            "example": "string"
          },
          "gateway_identifier": {
            "description": "The identifier of the gateway. Allowed values - `\"payment_fusion\"`, `\"usaepay\"`",
            "type": "string",
            "example": "string"
          },
          "gateway_reference_number": {
            "description": "Transaction reference number from gateway.",
            "type": "string",
            "example": "string"
          },
          "gateway_response_message": {
            "description": "The message returned from the gateway.",
            "type": "string",
            "example": "string"
          },
          "gateway_result_code": {
            "description": "Result code (or error code) as returned by the gateway.",
            "type": "string",
            "example": "string"
          },
          "gateway_result_text": {
            "description": "The result text as returned by the gateway.",
            "type": "string",
            "example": "string"
          },
          "gateway_auth_code": {
            "description": "The authorization code received from the gateway",
            "type": "string",
            "example": "string"
          },
          "return_card_data": {
            "description": "Flag that specifies if the masked_card_number and the card_type should be extracted by the terminal and returned.",
            "type": "boolean",
            "example": "boolean"
          },
          "save_card": {
            "description": "If the card is saved or not on the gateway",
            "type": "boolean",
            "example": "boolean"
          },
          "merchant_id": {
            "description": "The merchant identifier that will be used to connect to the gateway.",
            "type": "string",
            "example": "string"
          },
          "billing_street": {
            "description": "Billing street address for credit cards.",
            "type": "string",
            "example": "string"
          },
          "billing_city": {
            "description": "Billing city for credit cards.",
            "type": "string",
            "example": "string"
          },
          "billing_zip": {
            "description": "Billing zip code for credit cards.",
            "type": "string",
            "example": "string"
          },
          "billing_state": {
            "description": "Billing state for credit cards.",
            "type": "string",
            "example": "string"
          },
          "comments": {
            "description": "Transaction comments.",
            "type": "string",
            "example": "string"
          },
          "description": {
            "description": "Transaction description.",
            "type": "string",
            "example": "string"
          },
          "recurring": {
            "description": "Specifies if this transaction is recurring or not. If set to false, omitted or filled with wrong data, the recurring billing fields will be ignored - \"schedule\", \"num_left\", \"start_date\", \"bill_amount\". Allowed values - `true`,`false`\n",
            "type": "boolean"
          },
          "schedule": {
            "description": "Frequency of recurring billing schedule. Will be ignored if recurring is not sent as \"true\". Allowed values - `\"disabled\"`,`\"daily\"`,`\"weekly\"`,`\"bi-weekly\"`,`\"monthly\"`,`\"bi-monthly\"`,`\"quarterly\"`,`\"bi-annually\"`,`\"annually\"`.\n",
            "type": "string"
          },
          "num_left": {
            "description": "Number of transactions remaining in recurring billing cycle. Will be ignored if recurring is not sent as \"true\".\n",
            "type": "string"
          },
          "start_date": {
            "description": "Must be entered in YYYYMMDD format. If set to \"next\" the date of the next billing cycle will be used. For example if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. Can also be entered as `\"first of month\"` or `\"last day of month\"` Will be ignored if recurring is not sent as \"true\".\n",
            "type": "string"
          },
          "bill_amount": {
            "type": "string",
            "description": "Sets the monetary amount to charge on each cycle. Specified in USD. If this field is left blank the amount will be used instead. This is NOT the \"initial\" charge or \"setup\" charge, this is only the \"recurring\" charge.\n"
          },
          "customer_id": {
            "description": "Customer identifier associated to the transaction.",
            "type": "string",
            "example": "string"
          },
          "card_holder": {
            "description": "The name on the card.",
            "type": "string",
            "example": "string"
          },
          "gateway_ip": {
            "description": "The IP of the server that processed this transaction.",
            "type": "string",
            "example": "string"
          },
          "signature": {
            "description": "The encoded signature.",
            "type": "string",
            "example": "string"
          },
          "card_hash": {
            "description": "The hashed version of the card number. This can be used to determine if the same card was used for multiple transactions without knowing the actual card number. Size range - `40`",
            "type": "string",
            "example": "string"
          },
          "auth_amount": {
            "description": "The authorized amount in case of a partial authorized transaction.",
            "type": "string",
            "example": "string"
          },
          "remaining_balance": {
            "description": "The remaining balance in case of a partial authorized transaction.",
            "type": "string",
            "example": "string"
          },
          "emv_data": {
            "$ref": "#/components/schemas/EmvDataResponse"
          },
          "remote_id": {
            "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..100`",
            "type": "string",
            "example": "string"
          },
          "street_address": {
            "description": "Optional value indicating the street address of the card holder.",
            "type": "string",
            "example": "string"
          },
          "zip_code": {
            "description": "Optional value indicating the zip code of the card holder.",
            "type": "string",
            "example": "string"
          },
          "input_method": {
            "description": "The input method used for the card associated with the transaction. Allowed values - `\"swipe\"`,`\"keyed\"`,`\"dip\"`,`\"contactless\"`,`\"fallback\"`,`\"chip_read\"`,`\"swiped\"`,`\"tap\"` The values are subject to change.\n",
            "type": "string",
            "example": "string"
          },
          "bin_data": {
            "$ref": "#/components/schemas/BinData"
          },
          "mid": {
            "description": "The merchant ID",
            "type": "string",
            "example": "string"
          },
          "tid": {
            "description": "The terminal ID",
            "type": "string",
            "example": "string"
          },
          "is_healthcare": {
            "description": "Indicates if card's BIN is included in the healthcare BIN table.",
            "type": "boolean",
            "enum": [
              "true",
              "false",
              "null"
            ]
          },
          "healthcare": {
            "$ref": "#/components/schemas/HealthcareRequestFields"
          },
          "card_is_present": {
            "description": "Indicates the presence of the card.",
            "type": "boolean",
            "enum": [
              "true",
              "false",
              "null"
            ]
          },
          "order_method": {
            "type": "string",
            "description": "The type of order.",
            "enum": [
              "mail_order",
              "phone_order",
              "null"
            ]
          },
          "allow_partial_auth": {
            "description": "Indicates that the transaction was created to allow partial payment. `allow_partial_auth` is `null` if it was not set when the transaction was created.",
            "type": "boolean",
            "enum": [
              "true",
              "false",
              "null"
            ]
          },
          "is_partial_auth": {
            "description": "Partial authorization indicator that reflects whether the processor provided a partial authorization, or not. Will be `null` if the gateway didn't return any partial authorization status.",
            "type": "boolean",
            "enum": [
              "true",
              "false",
              "null"
            ]
          },
          "v": {
            "$ref": "#/components/schemas/Version"
          }
        }
      },
      "ProcessResponseFields": {
        "type": "object",
        "properties": {
          "amountData": {
            "$ref": "#/components/schemas/AmountData"
