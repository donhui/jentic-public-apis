      "TransactionInfo": {
        "type": "object",
        "properties": {
          "remote_id": {
            "type": "string",
            "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness.",
            "example": "string"
          },
          "type": {
            "type": "string",
            "description": "The Type of the transaction. Can be one of: `\"process\"`, `\"refund\"`, `\"hpp\"`, `\"transaction_job\"`\n",
            "example": "string"
          },
          "id": {
            "type": "integer",
            "description": "The internal TB ID of the transaction.",
            "example": "integer"
          },
          "created_at": {
            "type": "string",
            "description": "The time when the transaction was created.",
            "example": "string"
          },
          "status": {
            "type": "string",
            "description": "The status of the transaction.\nAllowed values - `\"approved\"`, `\"awaiting_amount\"`, `\"awaiting_confirmation\"`, `\"canceled\"`, `\"declined\"`, `\"emv_needing_reversal\"`, `\"error\"`, `\"in progress\"`, `\"internal error\"`, `\"timeout\"`, `\"verification\"`\n",
            "example": "string"
          },
          "response": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TransactionResponseFields"
              },
              {
                "$ref": "#/components/schemas/HppResponseFields"
              },
              {
                "$ref": "#/components/schemas/ProcessResponseFields"
              },
              {
                "$ref": "#/components/schemas/RefundResponseFields"
              }
            ]
          }
        }
      },
      "EmvData": {
        "type": "object",
        "description": "EMV data for the application.",
        "required": [
          "application_name",
          "application_pan",
          "card_entry_mode",
          "authorization_mode",
          "aid",
          "tvr",
          "iad",
          "tsi",
          "arc",
          "tag_data",
          "customer_verification_method"
        ],
        "properties": {
          "application_name": {
            "type": "string",
            "description": "Value of EMV Tag 50 representing the mnemonic associated with the AID according to ISO/IEC 7816-5",
            "example": "string"
          },
          "application_pan": {
            "type": "string",
            "description": "Identifies and differentiates cards with the same PAN",
            "example": "string"
          },
          "card_entry_mode": {
            "type": "string",
            "description": "Manner of card data reading. Allowed values - `\"chip_read\"`, `\"contactless\"`, `\"fallback\"`, `\"keyed\"`, `\"swiped\"`",
            "example": "string"
          },
          "authorization_mode": {
            "type": "string",
            "description": "The place where the authorization of the transaction has been made. Allowed values - `\"issuer\"`, `\"card\"`",
            "example": "string"
          },
          "aid": {
            "type": "string",
            "description": "Identifies the application as described in ISO/IEC 7816-5",
            "example": "string"
          },
          "tvr": {
            "type": "string",
            "description": "Status of the different functions as seen from the terminal.",
            "example": "string"
          },
          "iad": {
            "type": "string",
            "description": "Contains proprietary application data for transmission to the issuer in an online transaction.",
            "example": "string"
          },
          "tsi": {
            "type": "string",
            "description": "Indicates the functions performed in a transaction",
            "example": "string"
          },
          "arc": {
            "type": "string",
            "description": "Code that defines the disposition of a message.",
            "example": "string"
          },
          "tag_data": {
            "type": "string",
            "description": "List of EMV Tags for Offline Declined transactions",
            "example": "string"
          },
          "customer_verification_method": {
            "type": "string",
            "description": "Customer verification method. Allowed values - `\"online_pin\"`, `\"offline_pin\"`, `\"signature\"`, `\"no_cvm\"`",
            "example": "string"
          }
        }
      },
      "EmvDataResponse": {
        "type": "object",
        "description": "The fields for the emv data. This field is only populated when the card is dipped.",
        "properties": {
          "receipt": {
            "type": "string",
            "example": "string",
            "description": "The receipt information that needs to be printed"
          },
          "customer_verification_method": {
            "type": "string",
            "description": "Specifies if the transaction requires a signature. Allowed values - `\"online_pin\"`, `\"offline_pin\"`, `\"signature\"`, `\"no_cvm\"`",
            "example": "string"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "description": "# All possible errors:\n\n1 - Unauthorized Access - The organization's credentials are invalid.\n\n2 - Invalid Transaction - The specified transaction does not exist for this organization.\n\n3 - Terminal unavailable - The specified terminal does not exist.\n\n4 - Terminal disconnected - The terminal is not connected. Make sure that the terminal is powered on and is not busy with another operation.\n\n5 - Missing Merchant - The merchant_id parameter was not specified.\n\n6 - Invalid Merchant - The merchant_id provided does not belong to this organization.\n\n7 - Invalid Merchant - The merchant_id provided does not belong to this terminal.\n\n8 - Gateway Error - Something went wrong with the gateway. Please try again later.\n\n9 - Missing Reference Number - The ref_number parameter that specifies the transaction was not found.\n\n10 - Invalid Transaction - The transaction specified using ref_number does not exist on the gateway for this organization.\n\n11 - Gateway Login Failed - The credentials for the specified merchant are not valid.\n\n12 - Transaction not refunded - The gateway has refused to refund the transaction.\n\n13 - Transaction not adjusted - The gateway has refused to adjust the transaction.\n\n14 - Transaction not voided - The gateway has refused to void the transaction.\n\n15 - Unauthorized Access - The terminal's credentials are invalid.\n\n16 - Invalid Card Token - The gateway invalidated the token included in the card parameter.\n\n17 - Prompt Job Not Found - The prompt job requested does not exist.\n\n18 - Print Job Not Found - The print job requested does not exist.\n\n19 - Unauthorized Access - Either the organization's credentials are invalid or there are no terminals associated yet.\n\n20 - Invalid Transaction ID - The transaction_id must be specified.\n\n21 - Transaction ID Too Long - The transaction_id must have a length of maximum 50 characters.\n\n22 - Duplicated Transaction ID - The transaction_id already exists for this organization.\n\n23 - Invalid Organization ID - The organization_id must be specified.\n\n24 - Invalid Schedule - The schedule field must be one of the following: disabled, daily, weekly, bi-weekly, monthly, bi-monthly, quarterly, bi-annually, annually.\n\n25 - Invalid Num Left - The num_left field must be numeric or \"*\" for a recurring transaction.\n\n26 - Invalid Start Date - The start_date field must be in YYYYMMDD format or one of the following: `next`, `first of month`, `last day of month`. Value must be in the future.\n\n27 - Invalid Bill Amount - The bill_amount field must be a valid number when specified for a recurring transaction.\n\n28 - Invalid Amount - The amount field must be a positive valid number.\n\n29 - Invalid Tip Amount - The tip amount field must be a positive valid number.\n\n30 - Missing serial_number - The serial_number parameter is missing\n\n31 - Invalid Type - The type field must be one of the following: 'yes/no', 'ok/cancel', 'signature'.\n\n32 - Missing message - The message parameter is missing.\n\n33 - Invalid Message - The message must have a length of maximum 50 characters for the yes/no type.\n\n34 - Missing serial_number - The serial_number parameter is missing\n\n35 - Missing merchant_id - The merchant_id parameter is missing.\n\n36 - Missing template - The template parameter is missing.\n\n37 - Invalid template - Unknown template value provided. Allowed values are: default, approved, declined, void, refund, refunded, credit, installment, error.\n\n38 - Missing fields - The fields must be specified.\n\n39 - Invalid fields content - Missing fields.date.\n\n40 - Invalid fields content - Missing fields.time.\n\n41 - Invalid fields content - Missing fields.batch.\n\n42 - Invalid fields content - Missing fields.gateway_reference_number.\n\n43 - Invalid fields content - Missing fields.masked_card.\n\n44 - Invalid fields content - Missing fields.input_method.\n\n45 - Invalid fields content - Missing fields.card_brand.\n\n46 - Invalid fields content - Missing fields.result.\n\n47 - Invalid fields content - Missing fields.approval_code.\n\n48 - Invalid fields content - Missing fields.transaction_type.\n\n49 - Invalid fields content - Missing fields.amount.\n\n50 - Invalid fields content - Missing fields.card_balance.\n\n51 - Invalid fields content - Missing fields.invoice.\n\n52 - Invalid fields content - Missing fields.invoice.\n\n53 - Invalid Serial Number - The serial_number must be specified.\n\n54 - Invalid Message - The message must have a length of maximum 200 characters for the ok/cancel type.\n\n55 - Missing new_amount parameter - The new_amount parameter was not specified.\n\n56 - Missing new_tip parameter - The new_tip parameter was not specified.\n\n57 - Refund amount exceeds original amount - The gateway has refused the refund since the refund_amount parameter is greater than the original amount on the specified transaction.\n\n58 - Missing refund_amount - The refund_amount parameter was not specified.\n\n59 - Invalid charge amount - The amount parameter is invalid. The gateway has refused the operation.\n\n60 - Negative amount - The amount parameter cannot be negative.\n\n61 - Negative tip amount - The tip_amount parameter cannot be negative.\n\n62 - Negative bill amount - The bill_amount parameter cannot be negative.\n\n63 - Invalid command - The um_command parameter is invalid. Acceptable values are 'sale', 'save', 'credit', 'sale:adjustable' or 'authorize'.\n\n64 - Invalid Command - The command parameter is invalid. Acceptable values are 'sale' or 'authorize'.\n\n65 - Transaction Already Settled - The capture has failed since the transaction has already been settled on the gateway.\n\n66 - Transaction not Captured - The gateway has refused to capture the transaction.\n\n67 - Invalid Total Amount - The total amount to be charged (amount + tip) is 0.\n\n68 - Invalid Status - The prompt job can only have a status with the following values: finalized, error, timed out, canceled.\n\n69 - Unauthorized Access - The credentials provided are invalid.\n\n70 - Maximum amount - The amount parameter cannot be bigger than 99999.99.\n\n71 - Missing amount parameter - The amount parameter was not specified.\n\n72 - Invalid Total Amount - The total amount to be charged (amount + tip) cannot be bigger than 99999.99\n\n73 - Invalid Healthcare Amount - Field healthcare_amount must be a positive valid number.\n\n74 - Invalid Copay Amount - Field copay_amount must be a positive valid number.\n\n75 - Invalid Prescription Amount - Field prescription_amount must be a positive valid number.\n\n76 - Invalid Vision Amount - Field vision_amount must be a positive valid number.\n\n77 - Invalid Clinic/Other Amount - Field clinic_other_amount must be a positive valid number.\n\n78 - Invalid Dental Amount - Field dental_amount must be a positive valid number.\n\n79 - Missing iias_verified parameter - Iias verified parameter must be specified if a detailed amount is sent.\n\n80 - Invalid iias_verified parameter - Iias verified parameter can only be true, false or exempt.\n\n81 - Invalid refund amount - The refund_amount parameter must be a valid positive number.\n\n82 - Invalid detailed amount - Healthcare Amount includes Prescription Amount, Vision Amount, Clinic/Other Amount and Dental Amount and must always be equal or greater to their sum.\n\n83 - Invalid refund amount - Refund amount cannot be 0.\n\n84 - Invalid API Identifier - The api_id must be specified.\n\n85 - Invalid callback URL. - The callback_url parameter that was specified is invalid. Only HTTPS protocol is supported.\n\n86 - organization_id is missing - The organization_id parameter was not specified.\n\n87 - api_id is missing - The api_id parameter was not specified.\n\n88 - api_token is missing - The api_token parameter was not specified.\n\n89 - organization_id is already taken - There is already an organization stored with the provided organization_id.\n\n90 - api_id is already taken - There is already an organization stored with the provided api_id.\n\n91 - Unauthorized access - The access key is invalid.\n\n92 - Organization not found - The requested organization was not found.\n\n93 - serial_number is missing - The serial_number parameter was not specified.\n\n94 - registration_token is missing - The registration_token parameter was not specified.\n\n95 - serial_number is already taken - There is already a terminal stored with the provided serial_number.\n\n96 - Terminal not found - The requested terminal was not found.\n\n97 - source_key is missing - The source_key parameter was not specified.\n\n98 - Source not found - The requested source was not found.\n\n99 - identifier is missing - The identifier parameter was not specified.\n\n100 - Organization not found - The specified organization was not found.\n\n101 - pin is missing - The pin parameter was not specified.\n\n102 - Invalid source(s) - At least one of the specified sources does not exist.\n\n103 - Terminal not found - The specified terminal was not found.\n\n104 - Invalid fields - The specified fields are invalid.\n\n105 - tip_amount too large - The tip_amount parameter cannot be bigger than $99,999.99.\n\n106 - callback_url too large - The callback_url parameter cannot have a length greater than 2000.\n\n107 - terminal_text too large - The terminal_text parameter cannot have a length greater than 200.\n\n108 - Invalid card_hash - The card_hash parameter must be a 40 characters long hexadecimal number (lowercase).\n\n109 - Requested receipt not found. - The requested receipt was not found on the gateway.\n\n110 - Receipt identifier required - No receipt identifier was provided. Reference number or name is required.\n\n111 - receipt_format is invalid. - The allowed values for the receipt format are Text or HTML.\n\n112 - remote_id too long - The remote_id parameter cannot be longer than 100 characters.\n\n113 - (Gateway error message) - An error on the gateway occured. The message will vary depending on the gateway response.\n\n114 - Logs invalid - The provided log information is invalid.\n\n115 - Invalid invoice field - The invoice field must be a positive valid number less than 10 digits long.\n\n116 - Invalid receipt field - The receipt_ref_num should not be blank.\n\n117 - Invalid receipt field - The transaction_ref_num should not be blank.\n\n118 - Invalid type - The receipt_ref_num should be an integer.\n\n119 - Invalid type - The transaction_ref_num should be an integer.\n\n120 - Receipt Job Not Found - The receipt job requested does not exist.\n\n121 - Invalid fields content - Missing fields.header.merchant_dba.\n\n122 - Invalid fields content - Missing fields.header.merchant_address.\n\n123 - Invalid fields content - Missing fields.body.cardholder_name.\n\n124 - Invalid fields content - Missing fields.body.card_last_four.\n\n125 - Invalid fields content - Missing fields.footer.patient_code.\n\n126 - Invalid fields content - Missing fields.footer.description_text.\n\n127 - Invalid fields content - Missing fields.footer.paynow_link.\n\n128 - Invalid template - Missing header, body or footer fields\n\n129 - Invalid fields content - Missing fields.body.transaction_type.\n\n130 - Invalid fields content - Missing fields.body.card_brand.\n\n131 - Invalid fields content - Missing fields.header.merchant_phone.\n\n132 - Invalid fields content - Missing fields.body.date.\n\n133 - Invalid fields content - Missing fields.body.time.\n\n134 - Invalid fields content - Missing fields.body.total_amount.\n\n135 - Invalid fields content - Missing fields.body.amount_paid.\n\n137 - Invalid fields content - Missing fields.body.auth_code.\n\n138 - Invalid fields content - Missing fields.body.decline_reason.\n\n139 - Invalid fields content - Missing fields.body.original_amount.\n\n140 - Invalid fields content - Missing fields.body.amount_voided.\n\n141 - Invalid fields content - Missing fields.body.amount_refunded.\n\n142 - Invalid fields content - Missing fields.body.original_transaction_balance.\n\n143 - Invalid fields content - Missing fields.body.plan_payments.\n\n144 - Invalid receipt field - The receipt object should not be blank.\n\n145 - Missing ids - The ids array is required.\n\n146 - Too many ids - The ids array cannot exceed 50 elements.\n\n147 - gateway_time is invalid - The gateway_time parameter must be an integer between 0 and 600,000 (10 minutes).\n\n148 - Invalid fields content - Missing fields.body.balance_due.\n\n149 - Invalid fields content - Missing fields.footer.provider_name.\n\n150 - Invalid fields content - Missing fields.body.transaction_type.\n\n151 - Invalid fields content - Missing fields.body.error_reason.\n\n152 - Invalid receipt content - Missing receipt.name.\n\n153 - Invalid fields content - Missing fields.footer.appointment_date.\n\n154 - Terminal not functional - This terminal has been disabled.\n\n155 - Terminal not functional - This terminal has been provisioned.\n\n156 - Terminal not functional - This terminal has been returned.\n\n157 - Terminal not functional - This terminal has been lost.\n\n158 - Terminal not functional - This terminal is pairing.\n\n159 - Invalid fields content - Missing fields.body.name.\n\n160 - Invalid fields content - Missing fields.body.account_last_four.\n\n161 - Invalid fields content - Missing fields.body.invoice.\n\n162 - endpoint is missing - The endpoint parameter was not specified.\n\n163 - Invalid zip_code parameter - The zip_code must consist of 5 digits.\n\n164 - Terminal not functional - The terminal is disabled and cannot be used to process any job.\n\n165 - Terminal not functional - The terminal is provisioned and cannot be used to process any job.\n\n166 - Terminal not functional - The terminal is returned and cannot be used to process any job.\n\n167 - Terminal not functional - The terminal is lost and cannot be used to process any job.\n\n168 - Terminal not functional - The terminal is pairing and cannot be used to process any job.\n\n169 - Invalid Test Identifier - The id must be specified.\n\n170 - Invalid Host Parameter - The host must be specified.\n\n171 - Invalid Protocol Parameter - The protocol must be specified.\n\n172 - Invalid Port Parameter - The port must be specified.\n\n173 - Invalid Method Parameter - The method must be specified.\n\n174 - Invalid Path Parameter - The path must be specified.\n\n175 - Invalid Tests Parameter - The provided tests information is invalid.\n\n176 - Invalid Method Parameter - The provided method information is invalid.\n\n177 - Invalid Protocol Parameter - The provided protocol information is invalid.\n\n178 - Invalid Tests Parameter - The tests must be specified.\n\n179 - Invalid Port Parameter - Port must be a valid port between 0 and 65535.\n\n180 - Invalid Timeout Parameter - Timeout must be between 0 and 5000 milliseconds.\n\n181 - Invalid Tests Parameter - Tests performed must be between 0 and 20.\n\n182 - Invalid Test Identifier - The provided id must be unique.\n\n183 - Connectivity Test Job Not Found - The connectivity test job requested does not exist.\n\n184 - Invalid Results Parameter - The results must be specified.\n\n185 - Invalid Results Parameter - The results must have the same number as tests.\n\n186 - Invalid Results Parameter - The provided results information is invalid.\n\n187 - Invalid ID Parameter - The provided id parameter is invalid.\n\n189 - Sorry, something went wrong. Please try again. - We are experiencing some issues at the current time.\n\n190 - Invalid Gateway Parameter - The gateway parameter is invalid. Acceptable values are 'legacy', 'payment_fusion'.\n\n191 - Invalid Type Parameter - The type parameter is invalid. Acceptable values are 'hpp', 'vterm', 'pf'.\n\n192 - Missing new_tip or new_tax parameter - The new_tip or new_tax parameter was not specified.\n\n193 - Missing card or token parameter - The card or token parameters was not specified.\n\n194 - Invalid Gateway Parameter - The gateway parameter must be specified.\n\n195 - Invalid Type Parameter - The type parameter must be specified.\n\n196 - Invalid Message - The message must have a length of maximum 255 characters.\n\n197 - Missing sources array. - The sources array is required.\n\n198 - Invalid check data - The provided data is invalid. Please provide either `'name_on_check' and 'acount_number' and 'routing_number'` or `'ach_token'` or `'micr'`.\n\n199 - Invalid serial number - A terminal with the specified serial number already exists.\n\n200 - Original transaction not an approved sale - The gateway has refused the refund since the original transaction is not an approved sale.\n\n201 - Missing invoice - The invoice parameter was not specified.\n\n202 - Invalid route - Please use /transactions/process/card route for specified merchant.\n\n203 - Invalid route - Please use /transactions/process/(ach|card|cash) route for specified merchant.\n\n204 - Invalid command - The command parameter is invalid. Acceptable values are 'sale', 'authorize' or 'independent_return'.\n\n205 - Missing card parameter - The card parameter is missing.\n\n206 - Invalid command - The command parameter is invalid. Acceptable values are 'sale', 'independent_return' or 'save'.\n\n207 - Invalid command - The command parameter is invalid. Acceptable value is 'sale'.\n\n208 - Invalid route - Please use /transactions/refund/card route for specified merchant.\n\n209 - Invalid route - Please use /transactions/refund/(ach|card|cash) route for specified merchant.\n\n210 - Invalid parameter - The receipt.Target parameter is invalid.\n\n211 - Duplicate identifier - Identifier is already used.\n\n212 - Unauthorized Access - The terminal's credentials are invalid.\n\n213 - Missing gateway_environment parameter - The gateway_environment is missing.\n\n214 - Invalid Gateway Environment Parameter - The gateway_environment parameter is invalid.\n\n215 - Invalid request - Transaction job is not 'in progress'.\n\n216 - Invalid request - confirm_amount flag is not true.\n\n217 - Invalid request - Invalid bin_data (blank or not a valid json).\n\n218 - Invalid request - The amount can not be updated multiple times.\n\n219 - Invalid source - The provided source doesn't have USAePay credentials.\n\n220 - Missing source credentials - Please specify at least one credentials set.\n\n221 - Internal Error - Hosted Payment page does not have correct gateway parameters.\n\n222 - Internal Error - Unable to process Hosted Payment page request.\n\n223 - Invalid Request - No Hosted Payment Page associated with the provided id was found.\n\n224 - Invalid Request - At least one of the mandatory parameters (Amount, TransactionType) is missing.\n\n225 - Invalid Request - transaction_type is missing or invalid.  Allowed values: Sale, Auth, SaveOnly.\n\n226 - Invalid Request - Custom fields format error or reserved key of tb_id or tb_transaction_type used\n\n227 - Invalid source - The provided source doesn't have Payment Fusion Gateway credentials.\n\n228 - Invalid Command - The command parameter is invalid. Acceptable values for legacy gateway are 'sale', 'authorize', 'independent_return'.\n\n229 - Invalid Command - The command parameter is invalid. Acceptable values for Payment Fusion Gateway are 'sale', 'authorize', 'independent_return'.\n\n230 - Requested receipt not found. - The requested receipt was not found on any gateway.\n\n231 - remote_id too long - The remote_id parameter cannot be longer than 256 characters.\n\n232 - Invalid remote_id - The remote_id parameter is invalid. Allowed characters: a-z, A-Z, 0-9, -.\n\n233 - Invalid type - The type parameter is invalid. Acceptable values for type are 'process', 'refund', 'hpp' and 'transaction_job'.\n\n234 - Invalid Request - Please provide only 'serial_number' or 'client_id', not both at once.\n\n235 - Invalid Request - Please provide 'serial_number' or 'client_id'.\n\n236 - Invalid Request - The client_id must not be blank.\n\n237 - Invalid Request - The client_id must not be longer than 255 characters.\n\n238 - Invalid Gateway ID - The Gateway ID must be an integer between 0 and 2147483647.\n\n239 - Invalid Source Identifier - The source identifier can only contain letters, numbers, dashes and underscores.\n\n240 - client_id too long - The client_id parameter cannot be longer than 255 characters.\n\n241 - Both client_id and terminal_text provided - Only one of client_id and terminal_text should be provided.\n\n242 - Missing transaction_status parameter - The transaction_status parameter was not specified.\n\n243 - Invalid gateway_identifier - The gateway_identifier parameter is invalid. Acceptable values are 'payment_fusion', 'usaepay'\n\n244 - Invalid gateway_reference_number - The gateway_reference_number must be numeric.\n\n246 - Invalid Terminal state parameter - The State parameter does not belong to available states (provisioned, shipped, deployed, paired, disabled, returned, lost, pairing, null).\n\n247 - Invalid Job Type - The Job type does not belong to accepted values (log, connectivity_test, print, prompt, receipt, transaction, restart).\n\n248 - Invalid TB Job identifier - The provided TB Job idenfier must be a valid Integer.\n\n249 - Invalid return_card_data value - The return_card_data must be a boolean value (true or false).\n\n250 - Invalid data type - Parameter must be of type string\n\n251 - Invalid parameter value - Parameter value is not supported\n\n252 - Transaction is already finalized - Transactions can only be finalized if current status is one of the following: 'in progress', 'awaiting_confirmation'\n\n253 - Invalid transaction status - Transaction status must be one of the following: 'approved', 'canceled', 'declined', 'error', 'timeout', 'emv_needing_reversal'\n\n254 - Awaiting amount transactions cannot be finalized - A transaction that doesn't have the amount set up cannot be finalized.\n\n255 - Job does not exists in Redis - The Job does not exists in Redis to be deleted.\n\n256 - Incorrect cc_merchant_number length - (If specified) cc_merchant_number's length should be 16\n\n257 - Invalid data type - Parameter must be of type boolean (`true`, `false`)\n\n258 - Job does not exists in Redis - The Job does not exists in Redis to be updated.\n\n259 - Invalid Tax Amount - The tax amount field must be a positive valid number.\n\n260 - Cannot convert to JSON - The Job Data cannot be converted to JSON.\n\n261 - Transaction not processed - The gateway has refused to process the transaction.\n\n262 - Wrong value for confirm_amount - The confirm_amount can't be 'true' if um_command is 'save'.\n\n263 - Missing original_amount parameter - The original_amount parameter was not specified.\n\n264 - Gateway Unavailable - Gateway is currently unavailable, try again later.\n\n265 - Wrong value for is_healthcare - is_healthcare must be of type boolean (true, false) or null.\n\n266 - JobService Instantiate Error - Job Service cannot instantiate the given Job.\n\n267 - JobService add Error - Job Service cannot send the Job to be added.\n\n268 - JobService delete Error - Job Service cannot send the Job to be deleted.\n\n269 - JobService update Error - Job Service cannot send the Job to be updated.\n\n270 - Invalid Transit Amount - Field transit_amount must be a positive valid number.\n\n271 - Invalid Cumulative Amount - Field cumulative_amount must be a positive valid number.\n\n272 - Invalid source credentials - The provided source has invalid gateway credentials.\n\n273 - Wrong value for display_in_progress - Parameters display_in_progress must be of type boolean.\n\n274 - Wrong value for suppress_negative_option - Parameters suppress_negative_option must be of type boolean.\n\n275 - Invalid approved redirect URL. - The approved_redirect parameter that was specified is invalid. Only HTTPS protocol is supported.\n\n276 - Invalid declined redirect URL. - The declined_redirect parameter that was specified is invalid. Only HTTPS protocol is supported.\n\n277 - approved_redirect too large - The approved_redirect parameter cannot have a length greater than 2000.\n\n278 - declined_redirect too large - The declined_redirect parameter cannot have a length greater than 2000.\n\n279 - Invalid markdown syntax - The message_markdown parameters contains invalid markdown syntax.\n\n280 - The message_markdown is too long - The message_markdown parameters is longer than 2000 characters.\n\n281 - Invalid Shipping Amount - The shipping_amount field must be a positive valid number.\n\n282 - Invalid Discount Amount - The discount_amount field must be a positive valid number.\n\n283 - HPP generation failed - Generating the Hosted Payment Page failed\n\n284 - Invalid Request - The ttl field must be a positive integer less or equal to 4464.\n\n285 - Invalid Request - The type field must be qr_code.\n\n286 - Invalid Request - Prompt job is not 'in progress'.\n\n287 - Invalid healthcare amount - Healthcare amount should be equal to sum of prescription_amount, copay_amount, vision_amount, dental_amount, clinic_other_amount, transit_amount\n\n288 - Wrong value for card_is_present - card_is_present must be of type boolean (true, false) or null.\n\n289 - Wrong value for order_method - order_method must be `mail_order`, `phone_order` or null.\n\n290 - Wrong body content - serial_number/client_id should not be sent in the body.\n\n291 - Transaction not processed - Unable to process the transaction on the gateway.\n\n292 - Missing template_identifier field - The template_identifier field is required.\n\n293 - Invalid format for template_identifier field - The field template_identifier must be alphanumeric.\n\n294 - Exceeded length for template_identifier field - The field template_identifier must have max 256 characters.\n\n295 - Missing transaction_ref_number field - The transaction_ref_number field is required.\n\n296 - Invalid format for transaction_ref_number field - The field transaction_ref_number must be alphanumeric.\n\n297 - Exceeded length for transaction_ref_number field - The field transaction_ref_number must have max 256 characters.\n\n298 - Invalid Receipt - The receipt specified using template_identifier does not exist on the gateway for this organization.\n\n299 - Invalid Transaction - The transaction specified using transaction_ref_number does not exist on the gateway for this organization.\n\n300 - Unable to create the job - The terminal you are trying to create the job for is a CareCredit Standalone terminal.\n\n301 - Too many ids - The ids array cannot exceed 100 elements.\n\n302 - Operation is not permitted. - This operation is not permitted for a captured unsettled transaction. Please perform a refund after the transaction has settled.\n\n303 - Invalid Action - The action field must be one of the following: update, enable, disable.\n\n304 - Customer not found - Customer identified by customer_id does not belong to this merchant.\n\n305 - Invalid parameter type - The parameter must be an integer.\n\n307 - Invalid Gateway operation. - This operation is not supported by the gateway.\n\n308 - Invalid Schedule - The schedule field must be one of the following: daily, weekly, bi-weekly, monthly, bi-monthly, quarterly, bi-annually, annually.\n\n309 - Contract not found - Customer identified by customer_id does not have a contract.\n\n310 - The minimum value for page_size is not met - The field page_size must be greater than 0.\n\n311 - Exceeded limit for page_size - The field page_size must not be greater than 50.\n\n312 - The minimum value for page_number is not met - The field page_number must be greater than 0.\n\n313 - Disabled Customer Database - Merchant is not configured for the Customer Database feature.\n\n314 - Invalid status - A loopback_test job can only have a status with one of the following values: in progress, success, fail, canceled.\n\n315 - Invalid final status - A loopback_test job can only be finalized with one of the following statuses: success, fail, canceled.\n\n316 - Job already finalized - This job has already been finalized. You cannot finalize a job that has previously been finalized.\n\n317 - The specified job was not found - The specified job was not found\n\n318 - Invalid type for token - The token parameter must be of type string\n\n319 - Invalid type for enabled - The enabled parameter must be of type boolean\n\n320 - Invalid Payment Token - The gateway invalidated the payment token used.\n\n321 - ACH token not supported for specified merchant. - Creating a contract with ACH token is supported only for the PaymentFusion gateway.\n\n322 - Invalid Routing Number - The gateway invalidated the routing number used.\n\n323 - ACH token not supported for specified merchant. - Creating an ACH token is supported only for the PaymentFusion gateway.\n\n324 - Token creation failed - The token creation call was refused by the gateway.\n\n325 - Invalid check data - The provided data is invalid. Please provide `'name_on_check' and 'acount_number' and 'routing_number'`\n\n2001 - Invalid Jobs data - Failed to parse Job Data\n\n2002 - Redis Terminal delete error - Could not delete the terminal from Redis\n\n2003 - Redis Terminal create error - Could not create the terminal in Redis\n",
        "properties": {
