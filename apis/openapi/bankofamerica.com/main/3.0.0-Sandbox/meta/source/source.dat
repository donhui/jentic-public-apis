      "CallbackUrlInfoTransactions": {
        "{$request.body#/callbackUrl}": {
          "post": {
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "example": 253
                      },
                      "type": {
                        "type": "string",
                        "example": "transaction"
                      },
                      "data": {
                        "type": "object",
                        "properties": {
                          "amount": {
                            "type": "string",
                            "description": "The transaction's amount for which the handshake was created."
                          },
                          "serial_number": {
                            "type": "string",
                            "description": "The serial number of the terminal. Size range - `256`"
                          },
                          "invoice": {
                            "description": "Number of the invoice. If this field is not sent then the invoice will be given a unique identifier. Size range - `1..10`",
                            "type": "string"
                          },
                          "ip_address": {
                            "description": "IP address of the client requesting the transaction.",
                            "type": "string"
                          },
                          "user_name": {
                            "description": "The user name of the user that requested the transaction.",
                            "type": "string"
                          },
                          "customer_name": {
                            "description": "The name of the customer for this transaction.",
                            "type": "string"
                          },
                          "software_name": {
                            "description": "ISV software identifier.",
                            "type": "string"
                          },
                          "clerk_number": {
                            "description": "Identifies the clerk or person executing the transaction for reporting purposes.",
                            "type": "string"
                          },
                          "transaction_status": {
                            "type": "string",
                            "description": "The status of the transaction.\nAllowed values - `\"approved\"`, `\"awaiting_amount\"`, `\"awaiting_confirmation\"`, `\"canceled\"`, `\"declined\"`, `\"emv_needing_reversal\"`, `\"error\"`, `\"in progress\"`, `\"internal error\"`, `\"timeout\"`, `\"verification\"`\n"
                          },
                          "credit_card_token": {
                            "description": "Token issued by the gateway and that can be used for future transactions. Size range - `19`",
                            "type": "string"
                          },
                          "card_type": {
                            "type": "string",
                            "description": "The type of the card that was submitted. Allowed values - `\"Discover\"`, `\"DISCOVER\"`, `\"UnionPay\"`, `\"AmEx\"`, `\"AMERICAN EXPRESS\"`, `\"AMEX\"`, `\"American express\"`, `\"Master\"`, `\"MASTERCARD\"`, `\"Mastercard\"`, `\"MASTERCARD/Mastercard\"`, `\"JCB\"`, `\"Jcb\"`, `\"Visa\"`, `\"VISA\"`,`\"Visa Traditional\"`, `\"Visa Classic\"`, `\"Visa Health\"`, `\"Visa Prefered\"`, `\"Mastercard/Eurocard\"`, `\"DINERS\"`, `\"CareCredit\"`, `\"Unknown Code\"`, `\"OTHER\"`, `\"null\"`, `\"N/A\"` The values are subject to change.\n"
                          },
                          "card_expiration_date": {
                            "type": "string",
                            "description": "The card expiration date. Format 'MMYY' (e.g. '0922')."
                          },
                          "masked_card_number": {
                            "type": "string",
                            "description": "The masked out card number including the last 4 digits (e.g. \"************1234\")."
                          },
                          "um_command": {
                            "description": "The command that will be passed to the gateway. Allowed values - `\"sale\"`,`\"save\"`,`\"authorize\"`,`\"credit\"`,`\"sale:adjustable\"`.",
                            "type": "string"
                          },
                          "created_at": {
                            "type": "string",
                            "description": "The time when the transaction was created."
                          },
                          "tip_amount": {
                            "description": "The tip amount in USD that was added to this transaction. Default value - `0`",
                            "type": "string"
                          },
                          "tip_method": {
                            "description": "The method in which the tip amount is entered in the system. \"specified\" is when it comes from the ISV, \"typed\" is when the customer types the tip amount on the terminal and \"written\" is when the customer writes the tip amount on the receipt and later an employee enters the tip on the ISV. When this param is not present, then it defaults to \"specified\". Allowed values - `\"specified\"`,`\"typed\"`,`\"written\"`.",
                            "type": "string"
                          },
                          "cancel_requested": {
                            "description": "If the transaction was canceled or not.",
                            "type": "string"
                          },
                          "cancel_requested_at": {
                            "description": "The time when the transaciton was canceled.",
                            "type": "string"
                          },
                          "gateway_identifier": {
                            "description": "The identifier of the gateway. Allowed values - `\"payment_fusion\"`, `\"usaepay\"`",
                            "type": "string"
                          },
                          "gateway_reference_number": {
                            "description": "Transaction reference number from gateway.",
                            "type": "string"
                          },
                          "gateway_response_message": {
                            "description": "The message returned from the gateway.",
                            "type": "string"
                          },
                          "gateway_result_code": {
                            "description": "Result code (or error code) as returned by the gateway.",
                            "type": "string"
                          },
                          "gateway_result_text": {
                            "description": "The result text as returned by the gateway.",
                            "type": "string"
                          },
                          "gateway_auth_code": {
                            "description": "The authorization code received from the gateway",
                            "type": "string"
                          },
                          "return_card_data": {
                            "description": "Flag that specifies if the masked_card_number and the card_type should be extracted by the terminal and returned.",
                            "type": "string"
                          },
                          "save_card": {
                            "description": "If the card is saved or not on the gateway",
                            "type": "string"
                          },
                          "merchant_id": {
                            "description": "The merchant identifier that will be used to connect to the gateway.",
                            "type": "string"
                          },
                          "billing_street": {
                            "description": "Billing street address for credit cards.",
                            "type": "string"
                          },
                          "billing_city": {
                            "description": "Billing city for credit cards.",
                            "type": "string"
                          },
                          "billing_zip": {
                            "description": "Billing zip code for credit cards.",
                            "type": "string"
                          },
                          "billing_state": {
                            "description": "Billing state for credit cards.",
                            "type": "string"
                          },
                          "comments": {
                            "description": "Transaction comments.",
                            "type": "string"
                          },
                          "description": {
                            "description": "Transaction description.",
                            "type": "string"
                          },
                          "recurring": {
                            "description": "Specifies if this transaction is recurring or not. If set to false, omitted or filled with wrong data, the recurring billing fields will be ignored - \"schedule\", \"num_left\", \"start_date\", \"bill_amount\". Allowed values - `true`,`false`\n",
                            "type": "boolean"
                          },
                          "schedule": {
                            "description": "Frequency of recurring billing schedule. Will be ignored if recurring is not sent as \"true\". Allowed values - `\"disabled\"`,`\"daily\"`,`\"weekly\"`,`\"bi-weekly\"`,`\"monthly\"`,`\"bi-monthly\"`,`\"quarterly\"`,`\"bi-annually\"`,`\"annually\"`.\n",
                            "type": "string"
                          },
                          "num_left": {
                            "description": "Number of transactions remaining in recurring billing cycle. Will be ignored if recurring is not sent as \"true\".\n",
                            "type": "string"
                          },
                          "start_date": {
                            "description": "Must be entered in YYYYMMDD format. If set to \"next\" the date of the next billing cycle will be used. For example if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. Can also be entered as `\"first of month\"` or `\"last day of month\"` Will be ignored if recurring is not sent as \"true\".\n",
                            "type": "string"
                          },
                          "bill_amount": {
                            "type": "string",
                            "description": "Sets the monetary amount to charge on each cycle. Specified in USD. If this field is left blank the amount will be used instead. This is NOT the \"initial\" charge or \"setup\" charge, this is only the \"recurring\" charge.\n"
                          },
                          "customer_id": {
                            "description": "Customer identifier associated to the transaction.",
                            "type": "string"
                          },
                          "card_holder": {
                            "type": "string",
                            "description": "The name on the card."
                          },
                          "gateway_ip": {
                            "type": "string",
                            "description": "The IP of the server that processed this transaction."
                          },
                          "signature": {
                            "type": "string",
                            "description": "The base64 encoded signature. This param will be empty if the terminal does not support signature capturing."
                          },
                          "card_hash": {
                            "description": "The hashed version of the card number. This can be used to determine if the same card was used for multiple transactions without knowing the actual card number. Size range - `40`",
                            "type": "string"
                          },
                          "auth_amount": {
                            "description": "The authorized amount in case of a partial authorized transaction.",
                            "type": "string"
                          },
                          "remaining_balance": {
                            "description": "The remaining balance in case of a partial authorized transaction.",
                            "type": "string"
                          },
                          "emv_data": {
                            "$ref": "#/components/schemas/EmvDataResponse"
                          },
                          "remote_id": {
                            "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..100`",
                            "type": "string"
                          },
                          "street_address": {
                            "description": "Optional value indicating the street address of the card holder.",
                            "type": "string"
                          },
                          "zip_code": {
                            "description": "Optional value indicating the zip code of the card holder.",
                            "type": "string"
                          },
                          "input_method": {
                            "description": "The input method used for the card associated with the transaction. Allowed values - `\"swipe\"`,`\"keyed\"`,`\"dip\"`,`\"contactless\"`,`\"fallback\"`,`\"chip_read\"`,`\"swiped\"`,`\"tap\"` The values are subject to change.\n",
                            "type": "string"
                          },
                          "bin_data": {
                            "$ref": "#/components/schemas/BinData"
                          },
                          "is_healthcare": {
                            "description": "Indicates if card's BIN is included in the healthcare BIN table.",
                            "type": "boolean",
                            "enum": [
                              "true",
                              "false",
                              "null"
                            ]
                          },
                          "mid": {
                            "description": "The merchant ID",
                            "type": "string"
                          },
                          "tid": {
                            "description": "The terminal ID",
                            "type": "string"
                          },
                          "card_is_present": {
                            "description": "Indicates the presence of the card.",
                            "type": "boolean",
                            "enum": [
                              "true",
                              "false",
                              "null"
                            ]
                          },
                          "order_method": {
                            "type": "string",
                            "description": "The type of order.",
                            "enum": [
                              "mail_order",
                              "phone_order",
                              "null"
                            ]
                          },
                          "allow_partial_auth": {
                            "description": "Indicates that the transaction was created to allow partial payment. The value is `null` if it was not set when the transaction was created.",
                            "type": "boolean",
                            "enum": [
                              "true",
                              "false",
                              "null"
                            ]
                          },
                          "is_partial_auth": {
                            "description": "Partial authorization indicator that reflects whether the processor provided a partial authorization, or not. Will be `null` if the gateway didn't return any partial authorization status.",
                            "type": "boolean",
                            "enum": [
                              "true",
                              "false",
                              "null"
                            ]
                          }
                        }
                      },
                      "version": {
                        "type": "string",
                        "example": "3.0.0"
                      },
                      "hash": {
                        "type": "string",
                        "example": "17c44fbef8925a0f4e69f0168bd7f083594616066bc6e347b49748c46c1cc611"
                      }
                    }
                  }
                }
              }
            },
            "responses": {
              "200": {
                "description": "Succesfully processed the webhook"
              }
            }
          }
        }
      },
      "CallbackInfoCardData": {
        "{$request.body#/callbackUrl}": {
          "post": {
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "example": 253
                      },
                      "type": {
                        "type": "string",
                        "example": "card_data"
                      },
                      "version": {
                        "type": "string",
                        "example": "3.0.0"
                      },
                      "data": {
                        "$ref": "#/components/schemas/CardDataResponse"
                      }
                    }
                  }
                }
              }
            },
            "responses": {
              "200": {
                "description": "Succesfully processed the webhook"
              }
            }
          }
        }
      },
      "CallbackWebhookData": {
        "{$request.body#/callbackUrl}": {
          "post": {
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The id of the webhook.",
                        "example": "integer"
                      },
                      "created_at": {
                        "type": "string",
                        "description": "The time when the webhook was created.",
                        "example": "string"
                      },
                      "gateway_identifier": {
                        "type": "string",
                        "description": "The identifier of the gateway",
                        "example": "string"
                      },
                      "remote_id": {
                        "type": "string",
                        "description": "Used for keeping track of a 3rd party identifier alongside the prompt job object. Size range - `0..100`",
                        "example": "string"
                      },
                      "amount": {
                        "type": "string",
                        "description": "The transaction's amount for which the webhook was created.",
                        "example": "string"
                      },
                      "ip_address": {
                        "type": "string",
                        "description": "IP address of the client requesting the transaction.",
                        "example": "string"
                      },
                      "user_name": {
                        "type": "string",
                        "description": "The user name of the user that requested the transaction.",
                        "example": "string"
                      },
                      "gateway_reference_number": {
                        "type": "string",
                        "description": "Transaction reference number",
                        "example": "string"
                      },
                      "routing_number": {
                        "type": "string",
                        "description": "The check routing number.",
                        "example": "string"
                      },
                      "account_number": {
                        "type": "string",
                        "description": "Identifies the number of account used as a source of funds.",
                        "example": "string"
                      },
                      "account_type": {
                        "type": "string",
                        "description": "Identifies the type of account used as a source of funds.",
                        "example": "string"
                      },
                      "account_entity": {
                        "type": "string",
                        "example": "string"
                      },
                      "sec_code": {
                        "type": "string",
                        "description": "Value indicating the processor SEC Code.",
                        "example": "string"
                      },
                      "host_reference_number": {
                        "type": "string",
                        "example": "string"
                      },
                      "status_update_time": {
                        "type": "string",
                        "example": "status_update_time"
                      },
                      "transaction_status": {
