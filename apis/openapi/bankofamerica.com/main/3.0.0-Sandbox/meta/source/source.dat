                      "$ref": "#/components/schemas/NumericFieldOutOfRange"
                    },
                    {
                      "$ref": "#/components/schemas/InvalidFieldLength"
                    },
                    {
                      "$ref": "#/components/schemas/InvalidAchHppSecCode"
                    }
                  ]
                },
                "examples": {
                  "ApiError": {
                    "value": {
                      "allOf": [
