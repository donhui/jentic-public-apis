      "Contract": {
        "type": "object",
        "properties": {
          "customer_id": {
            "description": "Customer identifier associated to a transaction",
            "type": "string",
            "example": "string"
          },
          "bill_amount": {
            "description": "Sets the monetary amount to charge on each cycle. This is NOT the \"initial\" charge or \"setup\" charge, this is only the \"recurring\" charge. Described in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "type": "string",
            "example": "string"
          },
          "status": {
            "description": "Description of contract status.",
            "type": "string",
            "enum": [
              "enabled",
              "disabled",
              "completed"
            ],
            "example": "string"
          },
          "start_date": {
            "description": "Date formatted as YYYYMMDD.",
            "type": "string",
            "example": "string"
          },
          "end_date": {
            "description": "Date formatted as YYYYMMDD. The end_date is the next day after the last installment. For example if last installment was on 20210305 then the end_date will be 20210306. For a contract with unlimited number of installments the end_date will be `\"none\"`.\n",
            "type": "string",
            "example": "string"
          },
          "schedule": {
            "description": "Frequency of recurring billing schedule. Allowed values - `\"daily\"`,`\"weekly\"`,`\"bi-weekly\"`,`\"monthly\"`,`\"bi-monthly\"`,`\"quarterly\"`,`\"bi-annually\"`,`\"annually\"`.",
            "type": "string",
            "example": "string"
          },
          "num_left": {
            "description": "Number of transactions remaining in recurring billing cycle. When a contract is completed, the num_left will be returned as `0` When the contract is created with unlimited number of installments, the num_left will be returned as `*`\n",
            "type": "string",
            "example": "string"
          }
        }
      },
      "ContractWithToken": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Contract"
          }
        ],
        "type": "object",
        "properties": {
          "token": {
            "description": "The credit card token",
            "type": "string",
            "example": "string"
          }
        }
      },
      "ContractAch": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Contract"
          }
        ],
        "type": "object",
        "properties": {
          "token": {
            "description": "The ACH token. Is null if the contract was created using ACH data",
            "type": "string",
            "example": "string"
          }
        }
      },
      "ContractActionStatusChange": {
        "type": "object",
        "required": [
          "action"
        ],
        "properties": {
          "action": {
            "description": "Action type to be performed on the contract. Allowed vlaues - `\"enable\"` or `\"disable\"`.",
            "type": "string",
            "enum": [
              "enable",
              "disable"
            ],
            "example": "string"
          }
        }
      },
      "ContractActionUpdateData": {
        "type": "object",
        "required": [
          "action"
        ],
        "properties": {
          "action": {
            "description": "Action type to be performed on the contract. Allowed values - `\"update\"`.",
            "type": "string",
            "enum": [
              "update"
            ],
            "example": "update"
          }
        }
      },
      "ContractSchedule": {
        "type": "object",
        "required": [
          "schedule"
        ],
        "properties": {
          "schedule": {
            "description": "Frequency of recurring billing schedule. Allowed values - `\"daily\"`,`\"weekly\"`,`\"bi-weekly\"`,`\"monthly\"`,`\"bi-monthly\"`,`\"quarterly\"`,`\"bi-annually\"`,`\"annually\"`.",
            "type": "string",
            "enum": [
              "daily",
              "weekly",
              "bi-weekly",
              "monthly",
              "bi-monthly",
              "quarterly",
              "bi-annually",
              "annually"
            ],
            "example": "string"
          }
        }
      },
      "ContractNumLeft": {
        "type": "object",
        "required": [
          "num_left"
        ],
        "properties": {
          "num_left": {
            "description": "Number of transactions remaining in recurring billing cycle. Can take the value of *, which is interpreted as recurring payment for unlimited time.",
            "type": "string",
            "example": "string"
          }
        }
      },
      "ContractStartDate": {
        "type": "object",
        "required": [
          "start_date"
        ],
        "properties": {
          "start_date": {
            "description": "Must be entered in YYYYMMDD format. If set to \"next\" the date of the next billing cycle will be used. For example if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. Can also be entered as `\"first of month\"` or `\"last day of month\"`.\n",
            "type": "string",
            "example": "string"
          }
        }
      },
      "ContractBillAmount": {
        "type": "object",
        "required": [
          "bill_amount"
        ],
        "properties": {
          "bill_amount": {
            "description": "Sets the monetary amount to charge on each cycle. This is NOT the \"initial\" charge or \"setup\" charge, this is only the \"recurring\" charge. Described in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "type": "string",
            "example": "string"
          }
        }
      },
      "UpdateContractStatus": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ContractActionStatusChange"
          }
        ]
      },
      "UpdateContractData": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ContractActionUpdateData"
          },
          {
            "$ref": "#/components/schemas/ContractBillAmount"
          }
        ]
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Unique identifier of the transaction.",
            "type": "string",
            "example": "string"
          },
          "amount": {
            "description": "The amount in cents that will be charged.",
            "type": "integer",
            "example": "integer"
          },
          "invoice_number": {
            "description": "Number of the invoice.",
            "type": "string",
            "example": "string"
          },
          "software_name": {
            "description": "ISV software identifier.",
            "type": "string",
            "example": "string"
          },
          "ip_address": {
            "description": "IP address of the client requesting the transaction.",
            "type": "string",
            "example": "string"
          },
          "clerk_number": {
            "description": "Identifies the clerk or person executing the transaction for reporting purposes.",
            "type": "string",
            "example": "string"
          },
          "billing_street": {
            "description": "Billing street address for credit cards.",
            "type": "string",
            "example": "string"
          },
          "billing_city": {
            "description": "Billing city for credit cards.",
            "type": "string",
            "example": "string"
          },
          "billing_state": {
            "description": "Billing state for credit cards.",
            "type": "string",
            "example": "string"
          },
          "billing_zip": {
            "description": "Billing zip code for credit cards.",
            "type": "string",
            "example": "string"
          },
          "comments": {
            "description": "Transaction comments.",
            "type": "string",
            "example": "string"
          },
          "description": {
            "description": "Transaction description.",
            "type": "string",
            "example": "string"
          },
          "recurring": {
            "description": "Specifies if this transaction is recurring or not. If set to false, omitted or filled with wrong data, the recurring billing fields will be ignored - \"schedule\", \"num_left\", \"start_date\", \"bill_amount\". Allowed values - `true`,`false`\n",
            "type": "boolean"
          },
          "schedule": {
            "description": "Frequency of recurring billing schedule. Will be ignored if recurring is not sent as \"true\". Allowed values - `\"disabled\"`,`\"daily\"`,`\"weekly\"`,`\"bi-weekly\"`,`\"monthly\"`,`\"bi-monthly\"`,`\"quarterly\"`,`\"bi-annually\"`,`\"annually\"`.\n",
            "type": "string"
          },
          "num_left": {
            "description": "Number of transactions remaining in recurring billing cycle. Will be ignored if recurring is not sent as \"true\".\n",
            "type": "string"
          },
          "start_date": {
            "description": "Must be entered in YYYYMMDD format. If set to \"next\" the date of the next billing cycle will be used. For example if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. Can also be entered as `\"first of month\"` or `\"last day of month\"` Will be ignored if recurring is not sent as \"true\".\n",
            "type": "string"
          },
          "bill_amount": {
            "description": "Sets the monetary amount to charge on each cycle. Specified in cents. If this field is left blank the amount will be used instead. This is NOT the \"initial\" charge or \"setup\" charge, this is only the \"recurring\" charge.\n",
            "type": "integer",
            "example": "integer"
          },
          "customer_id": {
            "description": "Customer identifier associated to the transaction.",
            "type": "string",
            "example": "string"
          },
          "return_card_data": {
            "description": "Flag that specifies if the masked_card_number and the card_type should be extracted by the terminal and returned. Default value - `false`",
            "type": "boolean",
            "default": false,
            "example": "boolean"
          },
          "save_card": {
            "description": "Flag that specifies if after a given transaction the respective card should be saved for later use or not. Default value - `false`",
            "type": "boolean",
            "default": false,
            "example": "boolean"
          },
          "tip_amount": {
            "description": "The tip amount in USD that was added to this transaction. Default value - `0`",
            "type": "integer",
            "default": 0,
            "example": "integer"
          },
          "tip_method": {
            "description": "The method in which the tip amount is entered in the system. \"specified\" is when it comes from the ISV, \"typed\" is when the customer types the tip amount on the terminal and \"written\" is when the customer writes the tip amount on the receipt and later an employee enters the tip on the ISV. When this param is not present, then it defaults to \"specified\". Allowed values - `\"specified\"`,`\"typed\"`,`\"written\"`.",
            "type": "string",
            "default": "specified",
            "example": "string"
          },
          "terminal_text": {
            "description": "The text that should be displayed on the terminal while waiting for swipe/dip.",
            "type": "string",
            "example": "string"
          },
          "send_zip_code": {
            "description": "Allow or prevent manual key entry of zip code during keyed in transactions.",
            "type": "boolean",
            "example": "boolean"
          },
          "job_type": {
            "description": "The type of the prompt job. Allowed values - `\"yes/no\"`, `\"ok/cancel\"`, `\"signature\"`",
            "type": "string",
            "example": "string"
          },
          "message": {
            "description": "The message that needs to be displayed to the user.",
            "type": "string",
            "example": "string"
          },
          "message_markdown": {
            "description": "The markdown message that will be shown to the user. The terminal will make all the required processing for this.",
            "type": "string",
            "example": "string",
            "maximum": 2000
          },
          "suppress_negative_option": {
            "description": "This will reflect the ability of an ISV to disable a negative input of the user on the terminal (e.g. the user can only agree with the prompt presented on the terminal, he can't press no/cancel if this is set to true)",
            "type": "boolean",
            "example": "boolean"
          },
          "display_in_progress": {
            "description": "The terminal will use this flag to determine if more jobs need to be received from the ISV, after the current one is finalized. If the flag is set to true, after the job is finished, the terminal will stay in a processing screen waiting for the next job.",
            "type": "boolean",
            "example": "boolean"
          },
          "healthcare": {
            "$ref": "#/components/schemas/HealthcareRequestFields"
          },
          "recurring_properties": {
            "$ref": "#/components/schemas/RecurringTransactionFields"
          },
          "allow_partial_auth": {
            "description": "Indicates that the transaction was created to allow partial payment. The value is `null` if it was not set when the transaction was created.",
            "type": "boolean",
            "example": "boolean"
          },
          "is_partial_auth": {
            "description": "Partial authorization indicator that reflects whether the processor provided a partial authorization, or not. Will be `null` if the gateway didn't return any partial authorization status.",
            "type": "boolean",
            "example": "boolean"
          }
        }
      },
      "Log": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "logged_at": {
              "type": "string",
              "description": "The time that the log was created on the terminal, in %Y-%m-%dT%H:%M:%S%z format."
            },
            "type": {
              "type": "string",
              "description": "The type of log."
            },
            "data": {
              "type": "string",
              "description": "The additional data."
            }
          }
        }
      },
      "IsvTransactionInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal TB ID of the transaction.",
            "example": "integer"
          },
          "created_at": {
            "type": "string",
            "description": "The time when the transaction was created by the ISV.",
            "example": "string"
          },
          "total_time": {
            "type": "integer",
            "description": "Returns the time (in milliseconds) spent on the transaction (end-to-end), if the transaction is finalized and \"null\" is returned otherwise.",
            "example": "integer"
          },
          "terminal_time": {
            "type": "integer",
            "description": "Returns the time (in milliseconds) spent on the terminal. If the transaction was not sent or received from the terminal, \"null\" is returned.",
            "example": "integer"
          },
          "gateway_time": {
            "type": "integer",
            "description": "The time (in milliseconds) spent waiting for the gateway to process the transaction, in milliseconds. Returns \"null\" if the transaction was not processed by the gateway.",
            "example": "integer"
          },
          "amount": {
            "type": "integer",
            "description": "The total amount of the transaction, inluding the tip amount, in cents.",
            "example": "integer"
          },
          "organization_id": {
            "type": "integer",
            "description": "The organization's ID for which the transaction was created.",
            "example": "integer"
          },
          "source_id": {
            "type": "integer",
            "description": "The source's ID for transaction.",
            "example": "integer"
          },
          "terminal_id": {
            "type": "integer",
            "description": "The ID of the terminal transaction was created from.",
            "example": "integer"
          },
          "ref_num": {
            "type": "string",
            "description": "Gateway transaction reference for transactions processed by the gateway, \"null\" otherwise.",
            "example": "string"
          }
        }
      },
      "BinData": {
        "type": "object",
        "description": "The card data sent from Gateway or PFTA. Valid JSON or \"null\".",
        "properties": {
          "bin": {
            "type": "integer",
            "description": "The BIN/first 6 digits of the card",
            "example": "integer"
          },
          "card_brand": {
            "type": "string",
            "description": "The card brand (VISA, MasterCard, American Express, etc)",
            "example": "string"
          },
          "issuing_org": {
            "type": "string",
            "description": "The organization/bank that issued the card",
            "example": "string"
          },
          "card_type": {
            "type": "string",
            "description": "The type of the card that was submitted. Allowed values - `\"Discover\"`, `\"DISCOVER\"`, `\"UnionPay\"`, `\"AmEx\"`, `\"AMERICAN EXPRESS\"`, `\"AMEX\"`, `\"American express\"`, `\"Master\"`, `\"MASTERCARD\"`, `\"Mastercard\"`, `\"MASTERCARD/Mastercard\"`, `\"JCB\"`, `\"Jcb\"`, `\"Visa\"`, `\"VISA\"`,`\"Visa Traditional\"`, `\"Visa Classic\"`, `\"Visa Health\"`, `\"Visa Prefered\"`, `\"Mastercard/Eurocard\"`, `\"DINERS\"`, `\"CareCredit\"`, `\"Unknown Code\"`, `\"OTHER\"`, `\"null\"`, `\"N/A\"` The values are subject to change.\n",
            "example": "string"
          },
          "card_category": {
            "type": "string",
            "description": "The category indicating special types of card such as corporate, purchasing, and prepaid",
            "example": "string"
          },
          "issuing_country": {
            "type": "string",
            "description": "The country where the card was issued",
            "example": "string"
          },
          "issuing_country_code_a2": {
            "type": "string",
            "description": "The A2 country code",
            "example": "string"
          },
          "issuing_country_code_a3": {
            "type": "string",
            "description": "The A3 country code",
            "example": "string"
          },
          "issuing_country_number": {
            "type": "integer",
            "description": "The issuing country number",
            "example": "integer"
          },
          "issuing_phone": {
            "type": "string",
            "description": "Phone number, if available, of the issuing organization",
            "example": "string"
          },
          "issuing_website": {
            "type": "string",
            "description": "Web site, if available, of the issuing organization",
            "example": "string"
          },
          "pan_length": {
            "type": "string",
            "description": "The length of credit card number",
            "example": "string"
          },
          "issued_entity": {
            "type": "string",
            "description": "Defines if the BIN is PERSONAL or COMMERCIAL",
            "example": "string"
          },
          "is_regulated": {
            "type": "string",
            "description": "Indicates if the card is regulated",
            "example": "string"
          },
          "is_commercial": {
            "type": "boolean",
            "description": "True if the issued_entity is equal to 'COMMERCIAL'",
            "example": "boolean"
          },
          "is_healthcare": {
            "description": "Indicates if card's BIN is included in the healthcare BIN table.",
            "type": "string",
            "enum": [
              "true",
              "false",
              "null"
            ]
          }
        }
      },
      "Transaction": {
        "required": [
          "amount",
          "merchant_id"
        ],
        "properties": {
          "confirm_amount": {
            "default": true,
            "type": "boolean",
            "description": "The amount needs to be confirmed before the transaction is finalized. Can't be `\"true\"` if um_command is `\"save\"`."
          },
          "amount": {
            "description": "The amount in USD with 2 decimals that will be charged, must be a number greater than 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\").",
            "type": "string"
          },
          "invoice": {
            "description": "Number of the invoice. If this field is not sent then the invoice will be given a unique identifier. Size range - `1..10`",
            "type": "string"
          },
          "um_command": {
            "description": "The command that will be passed to the gateway. Allowed values - `\"sale\"`,`\"save\"`,`\"authorize\"`,`\"credit\"`,`\"sale:adjustable\"`.",
            "type": "string",
            "default": "sale"
          },
          "merchant_id": {
            "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`",
            "type": "string"
          },
          "user_name": {
            "description": "The user name of the user that requested the transaction.",
            "type": "string"
          },
          "customer_name": {
            "description": "The name of the customer for this transaction.",
            "type": "string"
          },
          "software_name": {
            "description": "ISV software identifier.",
            "type": "string"
          },
          "ip_address": {
            "description": "IP address of the client requesting the transaction.",
            "type": "string"
          },
          "clerk_number": {
            "description": "Identifies the clerk or person executing the transaction for reporting purposes.",
            "type": "string"
          },
          "billing_street": {
            "description": "Billing street address for credit cards.",
            "type": "string"
          },
          "billing_city": {
            "description": "Billing city for credit cards.",
            "type": "string"
          },
          "billing_state": {
            "description": "Billing state for credit cards.",
            "type": "string"
          },
          "billing_zip": {
            "description": "Billing zip code for credit cards.",
            "type": "string"
          },
          "comments": {
            "description": "Transaction comments.",
            "type": "string"
          },
          "description": {
            "description": "Transaction description.",
            "type": "string"
          },
          "recurring": {
            "description": "Specifies if this transaction is recurring or not. If set to false, omitted or filled with wrong data, the recurring billing fields will be ignored - \"schedule\", \"num_left\", \"start_date\", \"bill_amount\". Allowed values - `true`,`false`\n",
            "type": "boolean"
          },
          "schedule": {
            "description": "Frequency of recurring billing schedule. Will be ignored if recurring is not sent as \"true\". Allowed values - `\"disabled\"`,`\"daily\"`,`\"weekly\"`,`\"bi-weekly\"`, `\"monthly\"`,`\"bi-monthly\"`,`\"quarterly\"`,`\"bi-annually\"`,`\"annually\"`. If set to `\"disabled\"` the contract will have the schedule set to `\"monthly\"` and status set to `\"disabled\"`.\n",
            "type": "string",
            "default": "monthly"
          },
          "num_left": {
            "description": "Number of transactions remaining in recurring billing cycle. Will be ignored if recurring is not sent as \"true\".\n Can take the value of *, which is interpreted as recurring payment for unlimited time.",
            "type": "string",
            "default": "*"
          },
          "start_date": {
            "description": "Must be entered in YYYYMMDD format. If not set, the default value will be the date of tomorrow. For example if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. If set to \"next\" the date of the next billing cycle will be used. For example if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. Can also be entered as `\"first of month\"` or `\"last day of month\"`. Will be ignored if recurring is not sent as \"true\".\n",
            "type": "string"
          },
          "bill_amount": {
            "type": "string",
            "description": "Sets the monetary amount to charge on each cycle. Specified in USD. If this field is left blank the amount will be used instead. This is NOT the \"initial\" charge or \"setup\" charge, this is only the \"recurring\" charge.\n"
          },
          "return_card_data": {
            "description": "Flag that specifies if the masked_card_number and the card_type should be extracted by the terminal and returned. Default value - `false`",
            "type": "boolean",
            "default": false
          },
          "save_card": {
            "description": "Flag that specifies if after a given transaction the respective card should be saved for later use or not. Default value - `false`",
            "type": "boolean",
            "default": false
          },
          "tip_amount": {
            "description": "The tip amount in USD that was added to this transaction. Default value - `0`",
            "type": "string",
            "default": "0"
          },
          "tip_method": {
            "description": "The method in which the tip amount is entered in the system. \"specified\" is when it comes from the ISV, \"typed\" is when the customer types the tip amount on the terminal and \"written\" is when the customer writes the tip amount on the receipt and later an employee enters the tip on the ISV. When this param is not present, then it defaults to \"specified\". Allowed values - `\"specified\"`,`\"typed\"`,`\"written\"`.",
            "type": "string",
            "default": "specified"
          },
          "allow_partial_auth": {
            "description": "Sets the flag for allowing partial payment",
            "type": "boolean",
            "default": false
          },
          "callback_url_1": {
            "description": "One of the three URLs where Transaction Broker will POST to when a transaction is finalized by the terminal.  Multiple callbacks may occur as new information is updated. This eliminates the need for polling for the transaction's status. Only HTTPS URLs are allowed. The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
            "type": "string"
          },
          "callback_url_2": {
            "description": "One of the three URLs where Transaction Broker will POST to when a transaction is finalized by the terminal.  Multiple callbacks may occur as new information is updated. This eliminates the need for polling for the transaction's status. Only HTTPS URLs are allowed.  The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
            "type": "string"
          },
          "callback_url_3": {
            "description": "One of the three URLs where Transaction Broker will POST to when a transaction is finalized by the terminal.  Multiple callbacks may occur as new information is updated. This eliminates the need for polling for the transaction's status. Only HTTPS URLs are allowed.  The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
            "type": "string"
          },
          "terminal_text": {
            "description": "The text that should be displayed on the terminal. Size range - `0..200`.",
            "type": "string"
          },
          "suppress_signature": {
            "description": "Wheter or not to skip the signature process",
            "type": "boolean"
          },
          "remote_id": {
            "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..100`.",
            "type": "string"
          },
          "receipt_ref_num": {
            "description": "Receipt template ID",
            "type": "integer"
          },
          "receipt_option": {
            "description": "Receipt printing option sent to terminal. By default is set to 'Skip'. Allowed values - `'Skip'`,`'Print'`,`'Prompt'`.",
            "type": "string",
            "default": "Skip"
          },
          "prompt_for_zip_code": {
            "description": "Allow or prevent manual key entry of zip code during keyed in transactions. If zip_code parameter is set, prompt_for_zip_code will be ignored.",
            "type": "boolean",
            "default": false
          },
          "street_address": {
            "description": "Optional value indicating the cardholder's street address.",
            "type": "string"
          },
          "zip_code": {
            "description": "5 digit ZIP code. Optional value indicating the cardholder's zip code.",
            "type": "string"
          },
          "callback_url": {
            "description": "URL where Transaction Broker will POST to when a prompt job is finalized by the terminal. This eliminates the need for polling for the job's status. Only HTTPS URLs are allowed. The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - 0..2000.",
            "type": "string",
            "deprecated": true
          },
          "healthcare": {
            "$ref": "#/components/schemas/HealthcareRequestFields"
          },
          "show_terminal_details": {
            "allOf": [
              {
                "$ref": "#/components/schemas/ShowTerminalDetails"
              }
            ]
          }
        },
        "example": {
          "confirm_amount": true,
          "amount": "string",
          "invoice": "string",
          "um_command": "string",
          "merchant_id": "string",
          "user_name": "string",
          "customer_name": "string",
          "software_name": "string",
          "ip_address": "string",
          "clerk_number": "string",
          "billing_street": "string",
          "billing_city": "string",
          "billing_state": "string",
          "billing_zip": "string",
          "comments": "string",
          "description": "string",
          "recurring": true,
          "schedule": "string",
          "num_left": "string",
          "start_date": "string",
          "bill_amount": "string",
          "return_card_data": false,
          "save_card": false,
          "tip_amount": "string",
          "tip_method": "string",
          "allow_partial_auth": false,
          "callback_url_1": "string",
          "callback_url_2": "string",
          "callback_url_3": "string",
          "terminal_text": "string",
          "suppress_signature": true,
          "remote_id": "string",
          "receipt_ref_num": 0,
          "receipt_option": "string",
          "prompt_for_zip_code": false,
          "street_address": "string",
          "zip_code": "string",
          "healthcare": {
            "iias_verified": "string",
            "healthcare_amount": "string",
            "prescription_amount": "string",
            "copay_amount": "string",
            "vision_amount": "string",
            "clinic_other_amount": "string",
            "dental_amount": "string",
            "transit_amount": "string",
            "cumulative_amount": "string"
          },
          "show_terminal_details": true
        }
      },
      "SingleTransaction": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Transaction"
          },
          {
            "type": "object",
            "properties": {
              "recurring": {
                "description": "Specifies that the transaction is none recurring. The recurring billing fields will be ignored:\n  - schedule\n  - num_left\n  - start_date\n  - bill_amount\n",
                "type": "string",
                "default": "false",
                "enum": [
                  "false"
                ]
              },
              "bill_amount": {
                "description": "Sets the monetary amount to charge on each cycle. Specified in USD. If this field is left blank the amount will be used instead. This is NOT the \"initial\" charge or \"setup\" charge, this is only the \"recurring\" charge.\n",
                "type": "string",
                "example": "12.12"
              }
            }
          }
        ],
        "example": {
          "allOf": [
            {
              "$ref": "#/components/schemas/Transaction/example"
            },
            {
              "recurring": "false"
            },
            {
              "bill_amount": "12.12"
            }
          ]
        }
      },
      "RecurringTransaction": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Transaction"
          },
          {
            "type": "object",
            "required": [
              "bill_amount",
              "recurring"
            ],
            "properties": {
              "recurring": {
                "description": "Specifies that the transaction is recurring.",
                "type": "string",
                "default": "true",
                "enum": [
                  "true"
                ]
              },
              "bill_amount": {
                "description": "Sets the monetary amount to charge on each cycle. Specified in USD. If this field is left blank the amount will be used instead. This is NOT the \"initial\" charge or \"setup\" charge, this is only the \"recurring\" charge.\n",
                "type": "string",
                "example": "12.12"
              }
            }
          }
        ],
        "example": {
          "allOf": [
            {
              "$ref": "#/components/schemas/Transaction/example"
            },
            {
              "recurring": "true"
            },
            {
              "bill_amount": "12.12"
            }
          ]
        }
      },
