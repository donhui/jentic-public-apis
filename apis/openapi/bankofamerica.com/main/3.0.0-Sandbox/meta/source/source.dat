            "properties": {
              "token": {
                "type": "string",
                "description": "The ACH token. Supported only for the Payment Fusion Gateway",
                "example": "string"
              }
            }
          }
        ],
        "example": {
          "allOf": [
            {
              "$ref": "#/components/schemas/AchContract/example"
            },
            {
              "token": "string"
            }
          ]
        }
      },
