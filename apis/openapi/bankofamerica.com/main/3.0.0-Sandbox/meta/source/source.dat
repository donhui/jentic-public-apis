    "/prompt_jobs/{id}/cancel": {
      "put": {
        "tags": [
          "Prompt Job"
        ],
        "summary": "Cancel a prompt job",
        "operationId": "cancelPromptJob",
        "description": "Called by the Independent Software Vendor. Request for a prompt job to be cancelled. The request will be saved but the prompt job may or may not be cancelled based on its current state.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Authorization"
          },
          {
            "$ref": "#/components/parameters/Accept"
          },
          {
            "name": "id",
            "in": "path",
            "description": "ID of the prompt job to cancel.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/VersionResponse"
          },
          "4XX": {
            "description": "Possible errors - 1, 17, 189, 286",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/prompt_jobs": {
      "post": {
        "tags": [
          "Prompt Job"
        ],
        "summary": "Create new prompt job",
        "operationId": "createPromptJob",
        "description": "Called by the Independent Software Vendor. Creates a new prompt job.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Authorization"
          },
          {
            "$ref": "#/components/parameters/Accept"
          },
          {
            "$ref": "#/components/parameters/ContentType"
          }
