                },
                "examples": {
                  "ApiError": {
                    "value": {
                      "allOf": [
                        {
                          "$ref": "#/components/schemas/ApiError/example"
                        }
                      ]
                    }
                  },
                  "OutOfRangeExpirationInDays": {
                    "value": {
                      "allOf": [
                        {
                          "$ref": "#/components/schemas/NumericFieldOutOfRange/example"
