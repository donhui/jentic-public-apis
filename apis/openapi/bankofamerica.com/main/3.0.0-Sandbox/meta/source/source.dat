    "/transactions/receipt/render": {
      "get": {
        "tags": [
          "Transactions"
        ],
        "summary": "Render Receipt",
        "operationId": "renderReceipt",
        "description": "Called by the Independent Software Vendor. Request a receipt by name or by receipt reference number from the gateway for a given transaction reference number. Returns base64 encoded receipt if found.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Authorization"
          },
          {
            "$ref": "#/components/parameters/Accept"
          },
          {
            "name": "ref_number",
            "in": "query",
            "description": "The unique identifier of the transaction on the legacy gateway.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "template_name",
            "in": "query",
            "description": "The unique identifier of the transaction template. Used only for payment fusion gateway.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/ReceiptData"
          },
          {
            "name": "merchant_id",
            "in": "query",
            "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "receipt_format",
            "in": "query",
            "description": "The format of the receipt. Allowed values - `\"Text\"`, `\"HTML\"`",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "text_version",
            "in": "query",
            "description": "Should render receipt as text",
            "schema": {
              "type": "boolean",
              "example": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/RenderReceiptResponse"
          },
          "4XX": {
            "description": "Possible errors - 1, 9, 69, 109, 110, 111, 113, 189, 230",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/receipts": {
      "get": {
        "tags": [
          "Receipts"
        ],
        "summary": "Show Receipts",
        "operationId": "showReceipts",
        "description": "Called by the Independent Software Vendor. Request a receipt by template_identifier from the gateway for a given transaction_ref_number. Returns base64 encoded receipt if found.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Authorization"
          },
          {
            "$ref": "#/components/parameters/Accept"
          },
          {
            "name": "transaction_ref_number",
            "in": "query",
            "description": "The unique identifier of the transaction.",
            "required": true,
            "schema": {
              "type": "string",
              "example": "transaction1",
              "pattern": "^[a-zA-Z0-9]*$",
              "minLength": 1,
              "maxLength": 256
            }
          },
          {
            "name": "template_identifier",
            "in": "query",
            "description": "The unique identifier of the transaction template.",
            "required": true,
            "schema": {
              "type": "string",
              "example": "template1",
              "pattern": "^[a-zA-Z0-9]*$",
              "minLength": 1,
              "maxLength": 256
            }
          },
          {
            "name": "merchant_id",
            "in": "query",
            "description": "The merchant identifier that will be used to connect to the gateway.",
            "required": true,
            "schema": {
              "type": "string",
              "example": "merchant1"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/RenderReceiptResponse"
          },
          "4XX": {
            "description": "Possible errors - 1, 109, 113, 272, 292, 293, 294, 295, 296, 297",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/scan_codes": {
      "post": {
        "tags": [
          "Scan Code"
        ],
        "summary": "Create Scan Code",
        "operationId": "createScanCode",
        "description": "Called by the Independent Software Vendor. Returns a base64 encoded QR code.",
