                "description": "Check owner’s phone number.",
                "type": "string",
                "example": "string"
              },
              "street_1": {
                "description": "Check owner’s address street(1)",
                "type": "string",
                "example": "string"
              },
              "street_2": {
                "description": "Check owner’s address street(2)",
                "type": "string",
                "example": "string"
              },
              "city": {
                "description": "Check owner’s address city.",
                "type": "string"
              },
              "state_or_province_code": {
                "description": "Check owner’s address tate or province code",
                "type": "string",
                "example": "string"
              },
              "postal_code": {
                "description": "Check owner’s address postal code",
                "type": "string",
                "example": "string"
              },
              "country_code": {
                "description": "Check owner’s address country",
                "type": "string",
                "example": "string"
              },
              "account_number": {
                "description": "The check account number.",
                "type": "string",
                "example": "string"
              },
              "routing_number": {
                "description": "The checking routing number",
                "type": "string",
                "example": "string"
              },
              "name_on_check": {
                "description": "The check name on check.",
                "type": "string",
                "example": "string"
              },
              "account_type": {
                "description": "The type of account used as a source of funds.",
                "type": "string",
                "example": "string"
              }
            }
          }
        ],
        "example": {
          "allOf": [
            {
              "$ref": "#/components/schemas/AchContract/example"
            },
            {
              "email_address": "string"
            },
            {
              "phone_number": "string"
            },
            {
              "street_1": "string"
            },
            {
              "street_2": "string"
            },
            {
              "city": "string"
            },
            {
              "state_or_province_code": "string"
            },
            {
              "postal_code": "string"
            },
            {
              "country_code": "string"
            },
            {
              "account_number": "string"
            },
            {
              "routing_number": "string"
            },
            {
              "name_on_check": "string"
            },
            {
              "account_type": "string"
            }
          ]
        }
      }
    }
  }
}