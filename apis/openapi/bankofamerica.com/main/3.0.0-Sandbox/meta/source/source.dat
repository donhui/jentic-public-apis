    "/hpps": {
      "post": {
        "tags": [
          "Hosted Payment Page"
        ],
        "summary": "Generate HPP",
        "operationId": "createHpp",
        "description": "Called by the Independent Software Vendor. Generates a Hosted Payment Page",
        "parameters": [
          {
            "$ref": "#/components/parameters/Authorization"
          },
          {
            "$ref": "#/components/parameters/Accept"
          },
          {
            "$ref": "#/components/parameters/ContentType"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/CreateHostedPaymentPageRequest"
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "hpp": {
                      "type": "string",
                      "description": "Full URL for the retrieved HPP",
                      "example": "string"
                    },
                    "v": {
                      "$ref": "#/components/schemas/Version"
                    }
                  }
                }
              }
            }
          },
          "4XX": {
            "description": "Possible errors - 1, 28, 29, 85, 106, 189, 223, 225, 226, 251, 257, 259, 275, 276, 277, 278, 281, 282, 283",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
