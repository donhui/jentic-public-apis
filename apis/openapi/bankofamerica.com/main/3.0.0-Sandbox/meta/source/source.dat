    "schemas": {
      "Amount": {
        "description": "Passthrough of original transaction request amount",
        "type": "string",
        "example": "string"
      },
      "AuthAmount": {
        "description": "The authorized amount in case of a partial authorized transaction",
        "type": "string",
        "example": "string"
      },
      "GatewayAuthCode": {
        "description": "The authorization code received from the gateway",
        "type": "string",
        "example": "string"
      },
      "CardType": {
        "description": "The type of the card that was submitted. Allowed values - `\"Discover\"`, `\"DISCOVER\"`, `\"UnionPay\"`, `\"AmEx\"`, `\"AMERICAN EXPRESS\"`, `\"AMEX\"`, `\"American express\"`, `\"Master\"`, `\"MASTERCARD\"`, `\"Mastercard\"`, `\"MASTERCARD/Mastercard\"`, `\"JCB\"`, `\"Jcb\"`, `\"Visa\"`, `\"VISA\"`,`\"Visa Traditional\"`, `\"Visa Classic\"`, `\"Visa Health\"`, `\"Visa Prefered\"`, `\"Mastercard/Eurocard\"`, `\"DINERS\"`, `\"CareCredit\"`, `\"Unknown Code\"`, `\"OTHER\"`, `\"null\"`, `\"N/A\"` The values are subject to change.\n",
        "type": "string",
        "example": "string"
      },
      "CreatedAt": {
        "description": "The time the transaction was created.",
        "type": "string",
        "example": "string"
      },
      "GatewayIdentifier": {
        "description": "Identifier of the gateway.",
        "type": "string",
        "enum": [
          "usaepay",
          "payment_fusion"
        ],
        "example": "string"
      },
      "GatewayReferenceNumber": {
        "description": "Transaction reference number from gateway.",
        "type": "string",
        "example": "string"
      },
      "GatewayResponseMessage": {
        "description": "The message returned from the gateway",
        "type": "string",
        "example": "string"
      },
      "GatewayResultCode": {
        "description": "Result code (or error code) as returned by the gateway",
        "type": "string",
        "example": "string"
      },
      "GatewayResultText": {
        "description": "The result text as returned by the gateway.",
        "type": "string",
        "example": "string"
      },
      "MerchantId": {
        "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`\n",
        "type": "string",
        "example": "string"
      },
      "Mid": {
        "description": "The merchant ID",
        "type": "string",
        "example": "string"
      },
      "RemoteId": {
        "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..256`.",
        "type": "string",
        "example": "string"
      },
      "TerminalId": {
        "description": "The terminal ID",
        "type": "string",
        "example": "string"
      },
      "Token": {
        "description": "The check token used when processing the transaction.",
        "type": "string",
        "example": "string"
      },
      "TipAmount": {
        "description": "The tip amount in USD that was added to this transaction. Default value - `0`",
        "type": "string",
        "example": "string"
      },
      "TransactionStatus": {
        "description": "Confirmation from the payment gateway regarding the CC credentials and payment finalization. Allowed values - `\"approved\"`, `\"awaiting_amount\"`, `\"awaiting_confirmation\"`, `\"canceled\"`, `\"declined\"`, `\"emv_needing_reversal\"`, `\"error\"`, `\"in progress\"`, `\"internal error\"`, `\"timeout\"`, `\"verification\"`, `\"Success\"`, `\"Failure\"`\n",
        "type": "string",
        "example": "string"
      },
      "ActionTaken": {
        "description": "The action of the transaction. Allowed values - `\"void\"`, `\"refund\"`, `\"partial_refund\"`, `\"unknown\"`\n",
        "type": "string",
        "example": "string"
      },
      "AchToken": {
        "description": "The check token used when processing the transaction.",
        "type": "string",
        "example": "string"
      },
      "AllowPartialAuth": {
        "description": "Indicates that the transaction was created to allow partial payment. `allow_partial_auth` is `null` if it was not set when the transaction was created.",
        "type": "boolean",
        "example": "boolean"
      },
      "IsPartialAuth": {
        "description": "Partial authorization indicator that reflects whether the processor provided a partial authorization.",
        "type": "boolean",
        "example": "boolean"
      },
      "Version": {
        "type": "string",
        "default": "3.0.0",
        "example": "string",
        "description": "The API version that was used to handle the request."
      },
      "GatewayResponse": {
        "type": "object",
        "description": "The response comming from the gateway."
      },
      "Handshake": {
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal id of the handshake.",
            "example": "integer"
          },
          "category": {
            "type": "string",
            "description": "The category of the handshake.",
            "example": "string"
          },
          "created_at": {
            "type": "string",
            "description": "The time when the handshake was created.",
            "example": "string"
          },
          "job_id": {
            "type": "integer",
            "description": "The job id for which the handshake was created.",
            "example": "integer"
          },
          "organization_id": {
            "type": "integer",
            "description": "The organization's id for which the handshake was created.",
            "example": "integer"
          },
          "terminal_id": {
            "type": "integer",
            "description": "The terminal's id for which the handshake was created.",
            "example": "integer"
          },
          "source_id": {
            "type": "integer",
            "description": "The source's id for which the handshake was created.",
            "example": "integer"
          },
          "amount": {
            "type": "integer",
            "description": "The transaction's amount for which the handshake was created.",
            "example": "integer"
          },
          "ref_num": {
            "type": "string",
            "description": "Reference of the handshake",
            "example": "string"
          },
          "gateway": {
            "type": "string",
            "description": "The gateway. Allowed values - `\"payment_fusion\"`, `\"legacy\"`",
            "example": "string"
          },
          "associated_ref_num": {
            "type": "string",
            "description": "Reference number generated in non terminal financial endpoints",
            "example": "string"
          }
        }
      },
      "PromptJob": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "description": "The type of the prompt job.",
            "type": "string"
          },
          "message": {
            "description": "The message that needs to be displayed on the terminal.",
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "remote_id": {
            "description": "Used for keeping track of a 3rd party identifier alongside the prompt job object. Size range - `0..100`",
            "type": "string"
          },
          "callback_url_1": {
            "description": "One of the three URLs where Transaction Broker will POST to when a prompt job is finalized by the terminal. This eliminates the need for polling for the job's status. Only HTTPS URLs are allowed. The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
            "type": "string"
          },
          "callback_url_2": {
            "description": "One of the three URLs where Transaction Broker will POST to when a prompt job is finalized by the terminal. This eliminates the need for polling for the job's status. Only HTTPS URLs are allowed. The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
            "type": "string"
          },
          "callback_url_3": {
            "description": "One of the three URLs where Transaction Broker will POST to when a prompt job is finalized by the terminal. This eliminates the need for polling for the job's status. Only HTTPS URLs are allowed. The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
            "type": "string"
          },
          "message_markdown": {
            "description": "The markdown message that will be shown to the user. The terminal will make all the required processing for this.",
            "type": "string",
            "example": "string",
            "maximum": 2000
          },
          "suppress_negative_option": {
            "description": "This will reflect the ability of an ISV to disable a negative input of the user on the terminal (e.g. the user can only agree with the prompt presented on the terminal, he can't press no/cancel if this is set to true)",
            "type": "boolean",
            "example": "boolean"
          },
          "display_in_progress": {
            "description": "The terminal will use this flag to determine if more jobs need to be received from the ISV, after the current one is finalized. If the flag is set to true, after the job is finished, the terminal will stay in a processing screen waiting for the next job.",
            "type": "boolean",
            "example": "boolean"
          },
          "show_terminal_details": {
            "allOf": [
              {
                "$ref": "#/components/schemas/ShowTerminalDetails"
              }
            ]
          }
        },
        "example": {
          "type": "some_string",
          "message": "Some valid message for user.",
          "remote_id": "custom124id",
          "callback_url_1": "https://some_domain_here",
          "callback_url_2": "https://some_domain_here",
          "callback_url_3": "https://some_domain_here",
          "message_markdown": "**Some valid message**",
          "supress_negative_option": true,
          "display_in_progress": true,
          "show_terminal_details": true
        }
      },
      "SerialNumberAndSecretAccessKey": {
