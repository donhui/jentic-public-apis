{
  "openapi": "3.0.3",
  "servers": [
    {
      "description": "Transaction Broker URL",
      "url": "https://tb.paymentfusion.com"
    },
    {
      "description": "Transaction Broker staging URL",
      "url": "https://tb-staging.paymentfusion.com"
    },
    {
      "description": "Transaction Broker sandbox URL",
      "url": "https://tb-sandbox.paymentfusion.com"
    }
  ],
  "info": {
    "description": "The transaction broker is the central system for managing ongoing transactions, dispatching them to the terminals, providing results and keeping the mappings for all the terminals. endpoints.",
    "version": "3.0.0-Sandbox",
    "title": "Transaction Broker API",
    "contact": {
      "email": "ConnectPlatformManagement@bofa.com"
    },
    "x-jentic-source-url": "https://developer.merchant-services.bankofamerica.com/healthcareomnichannel/api/swagger/transaction_broker.json"
  },
  "paths": {
    "/merchants/{merchant_id}/contracts/ach": {
      "post": {
        "tags": [
          "Contracts"
        ],
        "summary": "Create a contract with a ach token or ach data for a Merchant's Customer",
        "operationId": "createAchContract",
        "description": "Called by the Independent Software Vendor. Allows creating of contracts with ach tokens or ach data.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Authorization"
          },
          {
            "$ref": "#/components/parameters/Accept"
          },
          {
            "$ref": "#/components/parameters/ContentType"
          },
          {
            "$ref": "#/components/parameters/MerchantId"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/CreateAchContractRequest"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/CreateAchContractResponse"
          },
          "4XX": {
            "description": "Possible errors - 1, 6, 24, 25, 26, 27, 70, 189, 318, 319,",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ApiError"
                    },
                    {
                      "$ref": "#/components/schemas/InvalidFieldApiError"
                    }
                  ]
                },
                "examples": {
                  "ApiError": {
                    "value": {
                      "allOf": [
                        {
                          "$ref": "#/components/schemas/ApiError/example"
                        }
                      ]
                    }
                  },
                  "InvalidFieldApiError": {
                    "value": {
                      "allOf": [
                        {
                          "$ref": "#/components/schemas/InvalidFieldApiError/example"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "5XX": {
            "description": "Possible errors - 8",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiError"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "gateway_identifier": {
                          "$ref": "#/components/schemas/GatewayIdentifier"
                        },
                        "gateway_response": {
                          "$ref": "#/components/schemas/GatewayResponse"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
