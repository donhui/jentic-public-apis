            ],
            "example": "Terminal disconnected"
          },
          "error_description": {
            "type": "string",
            "enum": [
              "The terminal is not connected. Make sure that the terminal is powered on and is not busy with another operation."
            ],
            "example": "The terminal is not connected. Make sure that the terminal is powered on and is not busy with another operation."
          },
          "online": {
            "description": "Indicator specifying if the terminal is online or not.",
            "type": "boolean",
            "example": true
          }
        },
        "example": {
