          "anyOf": [
            {
              "$ref": "#/components/schemas/HTTPSTest"
            },
            {
              "$ref": "#/components/schemas/TCPTest"
            },
            {
              "$ref": "#/components/schemas/ICMPTest"
            }
          ]
        }
      },
      "HTTPSTest": {
        "type": "object",
        "required": [
          "id",
          "host",
          "protocol",
          "method",
          "port",
          "path"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/Connectivity_Test"
          },
          {
            "$ref": "#/components/schemas/HTTPSProtocol"
          }
        ],
        "example": {
          "id": "integer",
          "host": "string",
          "port": "integer",
          "method": "string",
          "path": "string",
          "protocol": "HTTPS"
        }
      },
      "TCPTest": {
        "type": "object",
        "required": [
          "id",
          "host",
          "protocol",
          "method",
          "port",
          "timeout"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/Connectivity_Test"
          },
          {
            "$ref": "#/components/schemas/TCPProtocol"
          }
        ],
        "example": {
          "id": "integer",
          "host": "string",
          "port": "integer",
          "method": "string",
          "timeout": "integer",
          "protocol": "TCP"
        }
      },
      "ICMPTest": {
        "type": "object",
        "required": [
          "id",
          "host",
          "protocol",
          "method"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/Connectivity_Test"
          },
          {
            "$ref": "#/components/schemas/ICMPProtocol"
          }
        ],
        "example": {
          "id": "integer",
          "host": "string",
          "method": "string",
          "protocol": "ICMP"
        }
      },
      "HTTPSProtocol": {
        "properties": {
          "protocol": {
            "type": "string",
            "description": "Protocol of the test. Case insensitive.",
            "example": "string",
            "enum": [
              "HTTPS"
            ]
          }
        }
      },
      "TCPProtocol": {
        "properties": {
          "protocol": {
            "type": "string",
            "description": "Protocol of the test. Case insensitive.",
            "example": "string",
            "enum": [
              "TCP"
            ]
          }
        }
      },
      "ICMPProtocol": {
        "properties": {
          "protocol": {
            "type": "string",
            "description": "Protocol of the test. Case insensitive.",
            "example": "string",
            "enum": [
              "ICMP"
            ]
          }
        }
      },
      "Connectivity_Test": {
        "properties": {
          "id": {
            "type": "integer",
            "description": "ID of the test. Must be unique.",
            "example": "integer"
          },
          "host": {
            "type": "string",
            "description": "Host of the test.",
            "example": "string"
          },
          "port": {
            "type": "integer",
            "minimum": 0,
            "maximum": 65535,
            "description": "Port of the test.",
            "example": "integer"
          },
          "method": {
            "type": "string",
            "description": "Method of the test. Case insensitive.",
            "enum": [
              "GET",
              "POST"
            ],
            "example": "string"
          },
          "path": {
            "type": "string",
            "description": "Path of the test.",
            "example": "string"
          },
          "timeout": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5000,
            "description": "Timeout of the test (in seconds).",
            "example": "integer"
          }
        }
      },
      "CardDataResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/CardDataResponseBasic"
          },
          {
            "type": "object",
            "description": "Card Data Response",
            "properties": {
              "PanLength": {
                "type": "integer",
                "description": "The length of credit card number",
                "example": "integer"
              },
              "remote_id": {
                "type": "string",
                "example": "string"
              }
            }
          }
        ]
      },
      "CardDataResponseBasic": {
        "type": "object",
        "description": "Card Data Response",
        "properties": {
          "Bin": {
            "type": "integer",
            "description": "The BIN/first 6 digits of the card",
            "example": "integer"
          },
          "CardBrand": {
            "type": "string",
            "description": "The card brand (VISA, MasterCard, American Express, etc)",
            "example": "string"
          },
          "CardCategory": {
            "type": "string",
            "description": "The category indicating special types of card such as corporate, purchasing, and prepaid",
            "example": "string"
          },
          "CardType": {
            "type": "string",
            "description": "Typically debit or credit",
            "example": "string"
          },
          "IsCommercial": {
            "type": "boolean",
            "description": "True if the IssuedEntity is equal to 'COMMERCIAL'",
            "example": "boolean"
          },
          "IsHealthcare": {
            "description": "Indicates if card's BIN is included in the healthcare BIN table.",
            "type": "boolean",
            "enum": [
              "true",
              "false",
              "null"
            ]
          },
          "IsRegulated": {
            "type": "boolean",
            "description": "Indicates if the card is regulated",
            "example": "boolean"
          },
          "IssuedEntity": {
            "type": "string",
            "description": "Defines if the BIN is PERSONAL or COMMERCIAL",
            "example": "string"
          },
          "IssuingCountry": {
            "type": "string",
            "description": "The country where the card was issued",
            "example": "string"
          },
          "IssuingCountryCodeA2": {
            "type": "string",
            "description": "The A2 country code",
            "example": "string"
          },
          "IssuingCountryCodeA3": {
            "type": "string",
            "description": "The A3 country code",
            "example": "string"
          },
          "IssuingCountryNumber": {
            "type": "integer",
            "description": "The issuing country number",
            "example": "integer"
          },
          "IssuingOrg": {
            "type": "string",
            "description": "The organization/bank that issued the card",
            "example": "string"
          },
          "IssuingPhone": {
            "type": "string",
            "description": "Phone number, if available, of the issuing organization",
            "example": "string"
          },
          "IssuingWebsite": {
            "type": "string",
            "description": "Web site, if available, of the issuing organization",
            "example": "string"
          }
        }
      },
      "HealthcareRequestFields": {
        "description": "Optional parameters passed to the gateway.",
        "type": "object",
        "properties": {
          "iias_verified": {
            "type": "string",
            "description": "Merchant verified/did not verify the purchased items against an IIAS or Merchant claims exemption from IIAS based on the 90 percent rule.",
            "example": "string",
            "enum": [
              "true",
              "false",
              "exempt"
            ]
          },
          "healthcare_amount": {
            "type": "string",
            "description": "Amount health-care. Field includes the amounts in prescription_amount, vision_amount, clinic_other_amount, dental_amount and should always be equal or greater to their sum. Available for Visa and Mastercard only.\nDescribed in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "example": "string"
          },
          "prescription_amount": {
            "type": "string",
            "description": "Total amount of prescriptions used to gain access to \"Rx Only\" purses. This amount is included in the health-care_amount. Available for Visa and Mastercard only.\nDescribed in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "example": "string"
          },
          "copay_amount": {
            "type": "string",
            "description": "Total amount for co-payments.\nDescribed in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "example": "string"
          },
          "vision_amount": {
            "type": "string",
            "description": "Total amount of vision care purchases. This amount is included in healthcare_amount. Available for Visa only.\nDescribed in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "example": "string"
          },
          "clinic_other_amount": {
            "type": "string",
            "description": "Total amount of clinic or other medical services. This amount is included in healthcare_amount. Available for Visa only.\nDescribed in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "example": "string"
          },
          "dental_amount": {
            "type": "string",
            "description": "Total amount of dental services. This amount is included in healthcare_amount. Available for Visa only.\nDescribed in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "example": "string"
          },
          "transit_amount": {
            "type": "string",
            "description": "Total amount charged to an FSA card for transportation to/from a healthcare provider. Available for Visa only.\nDescribed in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "example": "string"
          },
          "cumulative_amount": {
            "type": "string",
            "description": "Total cumulative authorized amount for a series of incremental authorization transactions.\nDescribed in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
            "example": "string"
          }
        }
      },
      "RecurringTransactionFields": {
        "description": "Parameter list sent only for PaymentFusion recurring transactions.",
        "type": "object",
        "properties": {
          "customer_name": {
            "type": "string",
            "description": "Contains the same value as the transaction job customer_name field. If said field is not populated,\nthe value defaults to the id of the transaction job.\n",
            "example": "string"
          },
          "customer_id": {
            "type": "string",
            "description": "Customer identifier associated to the transaction.",
            "example": "string"
          },
          "activation_status": {
            "type": "string",
            "description": "Default value is 'Active'. Value will be 'Pending' if the value of schedule is 'disabled'.",
            "example": "string"
          },
          "merchant_key": {
            "type": "string",
            "description": "Value consists of the transaction's source access key.",
            "example": "string"
          },
          "bill_amount": {
            "type": "integer",
            "description": "Set in the transaction job. The monetary amount to charge on each cycle. Specified in cents.",
            "example": "integer"
          },
          "start_date": {
            "type": "string",
            "description": "Date formatted as YYYY/MM/DD.",
            "example": "string"
          },
          "end_date": {
            "type": "string",
            "description": "Date formatted as YYYY/MM/DD. Value will not be set when end date cannot be determined from the transaction.",
            "example": "string"
          },
          "billing_interval": {
            "type": "integer",
            "description": "Used in conjuntion with billing_period to determine frequency of payments. Based on the transaction's schedule field.\nIf schedule is not set, defaults to 1 (‘monthly’ value for schedule)\n",
            "example": "integer"
          },
          "billing_period": {
            "type": "string",
            "description": "Used in conjuntion with billing_interval to determine frequency of payments. Based on the transaction's schedule field.\nIf schedule is not set, defaults to \"Month\" (‘monthly’ value for schedule)\n",
            "example": "string"
          }
        }
      },
      "TransactionBrokerHealthResponse": {
        "type": "object",
        "description": "Success",
        "properties": {
          "app_status": {
            "type": "string",
            "default": "UP",
            "example": "UP",
            "description": "This property indicates the status of the App, if any critical dependencies are down, the app_status will be down as well"
          },
          "dependencies": {
            "type": "object",
            "properties": {
              "db_status": {
                "description": "This property indicates the status of the connection with the Database server",
                "type": "string",
                "default": "UP",
                "example": "UP"
              },
              "sqs_status": {
                "description": "This property indicates the status of the connection with the SQS service",
                "type": "string",
                "default": "UP",
                "example": "UP"
              },
              "presence_status": {
                "description": "This property indicates the status of the connection with the Presence service",
                "type": "string",
                "default": "UP",
                "example": "UP"
              }
            }
          }
        },
        "example": {
          "app_status": "UP",
          "dependecies": {
            "db_status": "UP",
            "sqs_status": "UP",
            "presence_status": "UP"
          }
        }
      },
      "AmountData": {
        "description": "Data related to amounts.",
        "type": "object",
