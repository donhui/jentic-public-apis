      "InvoiceData": {
        "description": "Data related to invoice.",
        "type": "object",
        "properties": {
          "totalAmount": {
            "type": "number",
            "description": "Total amount of the transaction.",
            "example": "number"
          },
          "tipAmount": {
            "type": "number",
            "description": "Amount charged for gratuity that is decided by the card holder.",
            "example": "number"
          },
          "taxAmount": {
            "type": "number",
            "description": "Amount charged by a merchant for tax.",
            "example": "number"
          },
          "shippingAmount": {
            "type": "number",
            "description": "Amount charged for shipping.",
            "example": "number"
          },
          "convenienceAmount": {
            "type": "number",
            "description": "Flat fee added by the merchant to the total transaction.",
            "example": "number"
          },
          "surchargeAmount": {
            "type": "number",
            "description": "Amount charged by the merchant in exchange for processing a specific transaction.",
            "example": "number"
          },
          "cashbackAmount": {
            "type": "number",
            "description": "Cashback amount requested by the card holder for an eligible transaction.",
            "example": "number"
          }
        }
      },
      "ValidationData": {
        "description": "Parameter list sent only for PaymentFusion recurring transactions.",
        "type": "object",
        "properties": {
          "avsResponse": {
            "type": "string",
            "description": "Response code for address verification.",
            "example": "string"
          },
          "cvResponse": {
            "type": "string",
            "description": "Response code for card verification.",
            "example": "string"
          },
          "avsResponseText": {
            "type": "string",
            "description": "AVS response in text format.",
            "example": "string"
          },
          "cvResultText": {
            "type": "string",
            "description": "CV response in text format.",
            "example": "string"
          },
          "streetMatchText": {
            "type": "string",
            "description": "AVS street match extra details.",
            "example": "string"
          },
          "zipMatchText": {
            "type": "string",
            "description": "AVS zip match extra details.",
            "example": "string"
          }
        }
      },
      "CustomFields": {
        "description": "Custom field objects collection.",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Custom field name.",
              "example": "string"
            },
            "value": {
              "type": "string",
              "description": "Custom field value.",
              "example": "string"
            }
          }
        }
      },
      "ShowTerminalDetails": {
        "type": "boolean",
        "description": "Set show_terminal_details to true only if displaying extra details about the terminal state is needed.",
        "default": false,
        "example": true,
        "enum": [
          true,
          false
        ]
      },
      "AchContract": {
        "type": "object",
        "required": [
          "bill_amount"
        ],
        "properties": {
          "bill_amount": {
            "description": "Sets the monetary amount to charge on each cycle. Specified in USD.",
            "type": "integer",
            "example": "integer"
          },
          "start_date": {
            "description": "Must be entered in YYYYMMDD format. If not set, the default value will be the date of tomorrow. For example, if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. If set to \"next\" the date of the next billing cycle will be used. For example, if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. Can also be entered as \"first of month\" or \"last day of month\".",
            "type": "string",
            "example": "string"
          },
          "schedule": {
            "description": "Frequency of recurring billing schedule. Will be ignored if recurring is not sent as \"true\". Allowed values - \"disabled\",\"daily\",\"weekly\",\"bi-weekly\", \"monthly\",\"bi-monthly\",\"quarterly\",\"bi-annually\",\"annually\". If set to \"disabled\" the contract will have the schedule set to \"monthly\" and status set to \"disabled\".",
            "type": "string",
            "example": "string"
          },
          "num_left": {
            "description": "Number of transactions remaining in the recurring billing cycle. Will be ignored if recurring is not sent as \"true\". Can take the value of *, which is interpreted as recurring payment for unlimited time.",
            "type": "integer",
            "example": "integer"
          },
          "enabled": {
            "description": "Indicates whether the contract will be enabled or disabled when created.",
            "type": "boolean",
            "example": "boolean",
            "default": true
          }
        },
        "example": {
          "bill_amount": "string",
          "start_date": "string",
          "schedule": "string",
          "num_left": "string",
          "enabled": "boolean"
        }
      },
      "AchContractRequestWithToken": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AchContract"
