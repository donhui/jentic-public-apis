      "SourceRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "secret_access_key",
                "organization_id",
                "identifier",
                "source_key",
                "pin",
                "tid",
                "mid",
                "endpoint",
                "type",
                "gateway",
                "gateway_environment"
              ],
              "properties": {
                "secret_access_key": {
                  "type": "string",
                  "description": "The access key shared only between TAP and TB that provides authentication for calls coming from TAP."
                },
                "organization_id": {
                  "type": "integer",
                  "description": "The organization's TB ID that the source belongs to."
                },
                "identifier": {
                  "type": "string",
                  "description": "The identifier for the source."
                },
                "usaepay_access_key": {
                  "type": "string",
                  "description": "The source_key used for the USAePay payment gateway authentication."
                },
                "usaepay_access_secret": {
                  "type": "string",
                  "description": "The pin used for the USAePay payment gateway authentication."
                },
                "pfg_access_key": {
                  "type": "string",
                  "description": "The source_key used for the Payment Fusion payment gateway authentication."
                },
                "pfg_access_secret": {
                  "type": "string",
                  "description": "The pin used for the Payment Fusion payment gateway authentication."
                },
                "usaepay_tid": {
                  "type": "string",
                  "description": "The Terminal ID for the source's merchant. This is a USAePay gateway specific field set on the merchant."
                },
                "usaepay_mid": {
                  "type": "string",
                  "description": "The Merchant ID for the source's merchant. This is a USAePay gateway specific field set on the merchant."
                },
                "pfg_tid": {
                  "type": "string",
                  "description": "The Terminal ID for the source's merchant. This is a Payment Fusion gateway specific field set on the merchant."
                },
                "pfg_mid": {
                  "type": "string",
                  "description": "The Merchant ID for the source's merchant. This is a Payment Fusion gateway specific field set on the merchant."
                },
                "gateway_environment": {
                  "type": "string",
                  "description": "The Merchant's gateway_environment set name. Values: `\"sandbox\"`, `\"stage\"`, `\"staging\"`, `\"stage_sb\"`, `\"production\"`\n"
                },
                "type": {
                  "type": "string",
                  "description": "The source type. Allowed values - `'hpp'`, `'vterm'`, `'pf'`."
                },
                "usaepay_gateway_id": {
                  "type": "integer",
                  "description": "The gateway identifier for the source's usaepay merchant. This is a gateway specific field set on the merchant."
                },
                "pfg_gateway_id": {
                  "type": "integer",
                  "description": "The gateway identifier for the source's payment fusion merchant. This is a gateway specific field set on the merchant."
                },
                "cc_merchant_number": {
                  "type": "string",
                  "description": "Optional Care Credit merchant number. This is a Payment Fusion Gateway setting specific field set on the merchant. Size range - `16`"
                }
              }
            }
          }
        }
      },
      "RestartJobRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "$ref": "#/components/schemas/SerialNumberAndSecretAccessKey"
            }
          }
        }
      },
