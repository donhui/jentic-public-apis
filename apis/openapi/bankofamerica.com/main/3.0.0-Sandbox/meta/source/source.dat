      "ACHTransactionProcessRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "amount",
                "merchant_id",
                "name_on_check",
                "account_number",
                "routing_number",
                "ach_token",
                "micr"
              ],
              "properties": {
                "merchant_id": {
                  "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`",
                  "type": "string"
                },
                "amount": {
                  "description": "The amount in USD up to 6 decimals that will be charged, must be a number greater than 0 and its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").",
                  "type": "string"
                },
                "invoice": {
                  "description": "Number of the invoice. If this field is not sent then the invoice will be given a unique identifier. Size range - `1..10`",
                  "type": "string"
                },
                "software": {
                  "description": "ISV software identifier.",
                  "type": "string"
                },
                "ip_address": {
                  "description": "IP address of the client requesting the transaction.",
                  "type": "string"
                },
                "clerk": {
                  "description": "Sales Clerk. Optional value indicating the clerk/person processing transaction, for reporting purposes.",
                  "type": "string"
                },
                "billing_street": {
                  "description": "Billing street address for credit cards.",
                  "type": "string"
                },
                "billing_city": {
                  "description": "Billing city for credit cards.",
                  "type": "string"
                },
                "billing_state": {
                  "description": "Billing state for credit cards.",
                  "type": "string"
                },
                "billing_zip": {
                  "description": "Billing zip code for credit cards.",
                  "type": "string"
                },
                "comments": {
                  "description": "Transaction comments.",
                  "type": "string"
                },
                "description": {
                  "description": "Transaction description.",
                  "type": "string"
                },
                "command": {
                  "description": "The operation that will be performed.\n\"sale\" makes the transaction right away while \"independent_return\" makes a refund of the transaction. “save” returns a token for the check data (Payment Fusion Gateway only).\n\nAllowed values - `\"sale\"`,`\"independent_return\"`,`\"save\"`.\n",
                  "type": "string",
                  "default": "sale"
                },
                "force_duplicate": {
                  "description": "Specifies if this transaction can bypass duplicate error. Applies to payment_fusion gateway only. Allowed values - `true`,`false`",
                  "type": "boolean",
                  "default": false
                },
                "allow_partial_auth": {
                  "description": "Sets the flag for allowing partial payment",
                  "type": "boolean",
                  "default": false
                },
                "zip_code": {
                  "description": "5 digit ZIP code. Optional value indicating the cardholder's zip code.",
                  "type": "string"
                },
                "name_on_check": {
                  "description": "The check name on check. Please provide one of `'name_on_check' and 'acount_number' and 'routing_number'` or `'ach_token'` or `'micr'`.",
                  "type": "string"
                },
                "routing_number": {
                  "description": "The check routing number. Please provide one of `'name_on_check' and 'acount_number' and 'routing_number'` or `'ach_token'` or `'micr'`.",
                  "type": "string"
                },
                "account_number": {
                  "description": "The check account number. Please provide one of `'name_on_check' and 'acount_number' and 'routing_number'` or `'ach_token'` or `'micr'`.",
                  "type": "string"
                },
                "check_number": {
                  "description": "Check number.",
                  "type": "string"
                },
                "ach_token": {
                  "description": "The check token. Please provide one of `'name_on_check' and 'acount_number' and 'routing_number'` or `'ach_token'` or `'micr'`.",
                  "type": "string"
                },
                "micr": {
                  "description": "The check MICR. Please provide one of `'name_on_check' and 'acount_number' and 'routing_number'` or `'ach_token'` or `'micr'`.",
                  "type": "string"
                },
                "drivers_license": {
                  "description": "Check owner's driver's license number.",
                  "type": "string"
                },
                "state": {
                  "description": "Check owner's two-character state code.",
                  "type": "string"
                },
                "ssn": {
                  "description": "Check owner's social security number.",
                  "type": "string"
                },
                "check_type": {
                  "description": "Optional parameter that identifies the type of check used in the transaction.",
                  "type": "string"
                },
                "check_account_type": {
                  "description": "Optional parameter that identifies the type of account used as a source of funds.",
                  "type": "string"
                },
                "email_address": {
                  "description": "Check owner's email address.",
                  "type": "string"
                },
                "phone_number": {
                  "description": "Check owner's phone number.",
                  "type": "string"
                },
                "street_1": {
                  "description": "Check owner's address street(1).",
                  "type": "string"
                },
                "street_2": {
                  "description": "Check owner's address street(2).",
                  "type": "string"
                },
                "street_3": {
                  "description": "Check owner's address street(3).",
                  "type": "string"
                },
                "city": {
                  "description": "Check owner's address city.",
                  "type": "string"
                },
                "state_or_province_code": {
                  "description": "Check owner's address state or province code.",
                  "type": "string"
                },
                "postal_code": {
                  "description": "Check owner's address postal code.",
                  "type": "string"
                },
                "country_code": {
                  "description": "Check owner's address country code.",
                  "type": "string"
                },
                "street_address": {
                  "description": "Optional value indicating the cardholder's street address.",
                  "type": "string"
                },
                "remote_id": {
                  "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..256`.",
                  "type": "string"
                },
                "client_id": {
                  "description": "Used to track the workstation associated with the transaction.",
                  "type": "string"
                },
                "sec_code": {
                  "description": "Optional value indicating the processor SEC Code. Allowed values - `\"WEB\"`, `\"PPD\"`, `\"CCD\"`, `\"TEL\"`, `\"ARC\"`",
                  "type": "string"
                },
                "callback_url_1": {
                  "description": "One of the three URLs where Transaction Broker will POST to when a HPP request is completed. This eliminates the need for polling for the request's status. Only HTTPS URLs are allowed. The callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
                  "type": "string"
                },
                "callback_url_2": {
                  "description": "One of the three URLs where Transaction Broker will POST to when a HPP request is completed. This eliminates the need for polling for the request's status. Only HTTPS URLs are allowed. The callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
                  "type": "string"
                },
                "callback_url_3": {
                  "description": "One of the three URLs where Transaction Broker will POST to when a HPP request is completed. This eliminates the need for polling for the request's status. Only HTTPS URLs are allowed. The callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CardTransactionProcessRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "amount",
                "card",
                "merchant_id"
              ],
              "properties": {
                "merchant_id": {
                  "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`",
                  "type": "string"
                },
                "amount": {
                  "description": "The amount in USD up to 6 decimals that will be charged, must be a number greater than 0 and its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").",
                  "type": "string"
                },
                "card": {
                  "description": "The credit card token.",
                  "type": "string"
                },
                "invoice": {
                  "description": "Number of the invoice.",
                  "type": "string"
                },
                "software": {
                  "description": "ISV software identifier.",
                  "type": "string"
                },
                "ip_address": {
                  "description": "IP address of the client requesting the transaction.",
                  "type": "string"
                },
                "clerk": {
                  "description": "Sales Clerk. Optional value indicating the clerk/person processing transaction, for reporting purposes.",
                  "type": "string"
                },
                "billing_street": {
                  "description": "Billing street address for credit cards.",
                  "type": "string"
                },
                "billing_city": {
                  "description": "Billing city for credit cards.",
                  "type": "string"
                },
                "billing_state": {
                  "description": "Billing state for credit cards.",
                  "type": "string"
                },
                "billing_zip": {
                  "description": "Billing zip code for credit cards.",
                  "type": "string"
                },
                "comments": {
                  "description": "Transaction comments.",
                  "type": "string"
                },
                "description": {
                  "description": "Transaction description.",
                  "type": "string"
                },
                "command": {
                  "description": "The operation that will be performed.\n\"sale\" makes the transaction right away while \"authorize\" simply authorizes the maximum amount that can be later captured and \"independent_return\" makes a refund of the transaction.\n\nAllowed values - `\"sale\"`,`\"authorize\"`,`\"independent_return\"`.\n",
                  "type": "string",
                  "default": "sale"
                },
                "tip_amount": {
                  "description": "The tip amount that was added to this transaction, in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\"). Default value - `0`",
                  "type": "string",
                  "default": "0"
                },
                "force_duplicate": {
                  "description": "Specifies if this transaction can bypass duplicate error. Applies to payment_fusion gateway only. Allowed values - `true`,`false`",
                  "type": "boolean",
                  "default": false
                },
                "allow_partial_auth": {
                  "description": "Sets the flag for allowing partial payment",
                  "type": "boolean",
                  "default": false
                },
                "zip_code": {
                  "description": "5 digit ZIP code. Optional value indicating the cardholder's zip code.",
                  "type": "string"
                },
                "street_address": {
                  "description": "Optional value indicating the cardholder's street address.",
                  "type": "string"
                },
                "tax_amount": {
                  "description": "Optional value indicating the tax amount that will be charged, in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").",
                  "type": "string"
                },
                "remote_id": {
                  "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..256`.",
                  "type": "string"
                },
                "client_id": {
                  "description": "Used to track the workstation associated with the transaction.",
                  "type": "string"
                },
                "healthcare": {
                  "$ref": "#/components/schemas/HealthcareRequestFields"
                }
              }
            }
          }
        }
      },
