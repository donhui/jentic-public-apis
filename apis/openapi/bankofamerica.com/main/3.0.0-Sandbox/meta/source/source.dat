    "callbacks": {
      "PromptCallbackUrlInfo": {
        "{$request.body#/callbackUrl}": {
          "post": {
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "example": 253
                      },
                      "type": {
                        "type": "string",
                        "example": "prompt"
                      },
                      "version": {
                        "type": "string",
                        "example": "3.0.0"
                      },
                      "data": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "ID of the returned prompt job."
                          },
                          "type": {
                            "type": "string",
                            "description": "The type of the prompt job. Allowed values - `\"yes/no\"`, `\"ok/cancel\"`, `\"signature\"`"
                          },
                          "result": {
                            "type": "string",
                            "description": "Contains either the action that the user took (\"yes\", \"no\", \"ok\", \"cancel\") or the signature file encoded in base64."
                          },
                          "status": {
                            "type": "string",
                            "description": "Status of the returned prompt job. Allowed values - `\"in progress\"`, `\"finalized\"`, `\"timed out\"`"
                          },
                          "remote_id": {
                            "type": "integer",
                            "description": "Used for keeping track of a 3rd party identifier alongside the prompt job. Size range - `0..100`\n"
                          }
                        }
                      },
                      "hash": {
                        "type": "string",
                        "example": "a39109af119ee4b245b57574d54e5cbce49e01dbd5e39b9c47cba703c5b7d09a"
                      }
                    }
                  }
                }
              }
            },
            "responses": {
              "200": {
                "description": "Succesfully processed the webhook"
              }
            }
          }
        }
      },
      "CallbackUrlInfo": {
        "{$request.body#/callbackUrl}": {
          "post": {
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "example": 227
                      },
                      "type": {
                        "type": "string",
                        "example": "hpp"
                      },
                      "version": {
                        "type": "string",
                        "example": "3.0.0"
                      },
                      "data": {
                        "type": "object",
                        "properties": {
                          "amount": {
                            "description": "The amount in USD, with 2 decimals.",
                            "type": "string"
                          },
                          "invoice_number": {
                            "description": "Number of the invoice.",
                            "type": "string"
                          },
                          "ip_address": {
                            "description": "IP address of the client requesting the transaction.",
                            "type": "string"
                          },
                          "user_name": {
                            "description": "The user name of the user that requested the transaction.",
                            "type": "string"
                          },
                          "transaction_status": {
                            "type": "string",
                            "description": "The status of the transaction.\nAllowed values - `\"approved\"`, `\"awaiting_amount\"`, `\"awaiting_confirmation\"`, `\"canceled\"`, `\"declined\"`, `\"emv_needing_reversal\"`, `\"error\"`, `\"in progress\"`, `\"internal error\"`, `\"timeout\"`, `\"verification\"`\n"
                          },
                          "token": {
                            "type": "string",
                            "description": "Transaction token."
                          },
                          "card_type": {
                            "type": "string",
                            "description": "The type of the card that was submitted. Allowed values - `\"Discover\"`, `\"DISCOVER\"`, `\"UnionPay\"`, `\"AmEx\"`, `\"AMERICAN EXPRESS\"`, `\"AMEX\"`, `\"American express\"`, `\"Master\"`, `\"MASTERCARD\"`, `\"Mastercard\"`, `\"MASTERCARD/Mastercard\"`, `\"JCB\"`, `\"Jcb\"`, `\"Visa\"`, `\"VISA\"`,`\"Visa Traditional\"`, `\"Visa Classic\"`, `\"Visa Health\"`, `\"Visa Prefered\"`, `\"Mastercard/Eurocard\"`, `\"DINERS\"`, `\"CareCredit\"`, `\"Unknown Code\"`, `\"OTHER\"`, `\"null\"`, `\"N/A\"` The values are subject to change.\n"
                          },
                          "card_expiration_date": {
                            "type": "string",
                            "description": "The card expiration date. Format 'MMYY' (e.g. '0922')."
                          },
                          "masked_card_number": {
                            "description": "The masked out card number including the last 4 digits (e.g. ************1234).",
                            "type": "string"
                          },
                          "check_account_type": {
                            "description": "Optional parameter that identifies the type of account used as a source of funds.",
                            "type": "string"
                          },
                          "check_account_number": {
                            "description": "Optional parameter that identifies the number of account used as a source of funds.",
                            "type": "string"
                          },
                          "transaction_type": {
                            "type": "string",
                            "description": "The type of transaction that will be performed. (e.g. transaction_type=Sale)\n\nAllowed Values - `\"Auth\"`, `\"Sale\"`, `\"SaveOnly\"`\n",
                            "example": "Sale"
                          },
                          "created_at": {
                            "description": "The time the transaction was created.",
                            "type": "string"
                          },
                          "tip_amount": {
                            "description": "The tip amount in USD cents that was added to this transaction.",
                            "type": "integer"
                          },
                          "gateway_identifier": {
                            "type": "string",
                            "description": "Identifier of the gateway."
                          },
                          "gateway_reference_number": {
                            "description": "Transaction reference number from gateway.",
                            "type": "string"
                          },
                          "gateway_auth_code": {
                            "type": "string",
                            "description": "Transaction auth code from the gateway."
                          },
                          "merchant_id": {
                            "type": "string",
                            "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`\n"
                          },
                          "billing_address_1": {
                            "type": "string"
                          },
                          "billing_address_2": {
                            "type": "string"
                          },
                          "billing_city": {
                            "description": "Billing city for credit cards.",
                            "type": "string"
                          },
                          "billing_zip": {
                            "description": "Billing zip code for credit cards.",
                            "type": "string"
                          },
                          "billing_state": {
                            "description": "Billing state for credit cards.",
                            "type": "string"
                          },
                          "comment": {
                            "description": "Transaction comment.",
                            "type": "string"
                          },
                          "description": {
                            "description": "Transaction description.",
                            "type": "string"
                          },
                          "card_holder": {
                            "type": "string",
                            "description": "The name on the card."
                          },
                          "auth_amount": {
                            "type": "string",
                            "description": "The authorized amount in case of a partial authorized transaction."
                          },
                          "remote_id": {
                            "type": "integer",
                            "description": "Used for keeping track of a 3rd party identifier alongside the prompt job. Size range - `0..100`\n"
                          },
                          "input_method": {
                            "type": "string",
                            "description": "The input method used for the card associated with the transaction. Allowed values - `\"swipe\"`,`\"keyed\"`,`\"dip\"`,`\"contactless\"`,`\"fallback\"`,`\"chip_read\"`,`\"swiped\"`,`\"tap\"` The values are subject to change.\n"
                          },
                          "bin_data": {
                            "$ref": "#/components/schemas/BinData"
                          },
                          "custom_fields": {
                            "type": "string",
                            "description": "Optional field of comma separated key=value pairs (e.g. custom_fields=key_1=value_1,key_2=value_2,key_3=value_3) reserved keys tb_id, tb_transaction_type"
                          }
                        }
                      },
                      "hash": {
                        "type": "string",
                        "example": "a39109af119ee4b245b57574d54e5cbce49e01dbd5e39b9c47cba703c5b7d09a"
                      }
                    }
                  }
                }
              }
            },
            "responses": {
              "200": {
                "description": "Succesfully processed the webhook"
              }
            }
          }
        }
      },
      "CallbackUrlInfoScanCode": {
        "{$request.body#/callbackUrl}": {
          "post": {
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "example": 227
                      },
                      "type": {
                        "type": "string",
                        "example": "scan_code"
                      },
                      "version": {
                        "type": "string",
                        "example": "3.0.0"
                      },
                      "data": {
                        "type": "object",
                        "properties": {
                          "amount": {
                            "description": "The amount in USD, with 2 decimals.",
                            "type": "string"
                          },
                          "invoice_number": {
                            "description": "Number of the invoice.",
                            "type": "string"
                          },
                          "ip_address": {
                            "description": "IP address of the client requesting the transaction.",
                            "type": "string"
                          },
                          "user_name": {
                            "description": "The user name of the user that requested the transaction.",
                            "type": "string"
                          },
                          "transaction_status": {
                            "type": "string",
                            "description": "The status of the transaction.\nAllowed values - `\"approved\"`, `\"awaiting_amount\"`, `\"awaiting_confirmation\"`, `\"canceled\"`, `\"declined\"`, `\"emv_needing_reversal\"`, `\"error\"`, `\"in progress\"`, `\"internal error\"`, `\"timeout\"`, `\"verification\"`\n"
                          },
                          "token": {
                            "type": "string",
                            "description": "Transaction token."
                          },
                          "card_type": {
                            "type": "string",
                            "description": "The type of the card that was submitted. Allowed values - `\"Discover\"`, `\"DISCOVER\"`, `\"UnionPay\"`, `\"AmEx\"`, `\"AMERICAN EXPRESS\"`, `\"AMEX\"`, `\"American express\"`, `\"Master\"`, `\"MASTERCARD\"`, `\"Mastercard\"`, `\"MASTERCARD/Mastercard\"`, `\"JCB\"`, `\"Jcb\"`, `\"Visa\"`, `\"VISA\"`,`\"Visa Traditional\"`, `\"Visa Classic\"`, `\"Visa Health\"`, `\"Visa Prefered\"`, `\"Mastercard/Eurocard\"`, `\"DINERS\"`, `\"CareCredit\"`, `\"Unknown Code\"`, `\"OTHER\"`, `\"null\"`, `\"N/A\"` The values are subject to change.\n"
                          },
                          "card_expiration_date": {
                            "type": "string",
                            "description": "The card expiration date. Format 'MMYY' (e.g. '0922')."
                          },
                          "masked_card_number": {
                            "description": "The masked out card number including the last 4 digits (e.g. ************1234).",
                            "type": "string"
                          },
                          "check_account_type": {
                            "description": "Optional parameter that identifies the type of account used as a source of funds.",
                            "type": "string"
                          },
                          "check_account_number": {
                            "description": "Optional parameter that identifies the number of account used as a source of funds.",
                            "type": "string"
                          },
                          "transaction_type": {
                            "type": "string",
                            "description": "The type of transaction that will be performed. (e.g. transaction_type=Sale)\n\nAllowed Values - `\"Auth\"`, `\"Sale\"`, `\"SaveOnly\"`\n",
                            "example": "Sale"
                          },
                          "created_at": {
                            "description": "The time the transaction was created.",
                            "type": "string"
                          },
                          "tip_amount": {
                            "description": "The tip amount in USD cents that was added to this transaction.",
                            "type": "integer"
                          },
                          "gateway_identifier": {
                            "type": "string",
                            "description": "Identifier of the gateway."
                          },
                          "gateway_reference_number": {
                            "description": "Transaction reference number from gateway.",
                            "type": "string"
                          },
                          "gateway_auth_code": {
                            "type": "string",
                            "description": "Transaction auth code from the gateway."
                          },
                          "merchant_id": {
                            "type": "string",
                            "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`\n"
                          },
                          "billing_address_1": {
                            "type": "string"
                          },
                          "billing_address_2": {
                            "type": "string"
                          },
                          "billing_city": {
                            "description": "Billing city for credit cards.",
                            "type": "string"
                          },
                          "billing_zip": {
                            "description": "Billing zip code for credit cards.",
                            "type": "string"
                          },
                          "billing_state": {
                            "description": "Billing state for credit cards.",
                            "type": "string"
                          },
                          "comment": {
                            "description": "Transaction comment.",
                            "type": "string"
                          },
                          "description": {
                            "description": "Transaction description.",
                            "type": "string"
                          },
                          "card_holder": {
                            "type": "string",
                            "description": "The name on the card."
                          },
                          "auth_amount": {
                            "type": "string",
                            "description": "The authorized amount in case of a partial authorized transaction."
                          },
                          "remote_id": {
                            "type": "integer",
                            "description": "Used for keeping track of a 3rd party identifier alongside the prompt job. Size range - `0..100`\n"
                          },
                          "input_method": {
                            "type": "string",
                            "description": "The input method used for the card associated with the transaction. Allowed values - `\"swipe\"`,`\"keyed\"`,`\"dip\"`,`\"contactless\"`,`\"fallback\"`,`\"chip_read\"`,`\"swiped\"`,`\"tap\"` The values are subject to change.\n"
                          },
                          "bin_data": {
                            "$ref": "#/components/schemas/BinData"
                          },
                          "custom_fields": {
                            "type": "string",
                            "description": "Optional field of comma separated key=value pairs (e.g. custom_fields=key_1=value_1,key_2=value_2,key_3=value_3) reserved keys tb_id, tb_transaction_type"
                          }
                        }
                      },
                      "hash": {
                        "type": "string",
