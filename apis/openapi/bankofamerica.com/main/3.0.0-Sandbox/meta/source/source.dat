  "components": {
    "securitySchemes": {
      "ISVAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "required: true <br> in: header <br> name: Authorization <br> Needs to include `Basic` word before Base64 encoded `api_id:api_token`. The `api_id` is the identifier of the organization created on TAP; size range - up to 36 characters. The `api_token` is the unique token previously generated by TAP and provided securely to the organization; size range - `32`. <br> Example: `Basic ODA5BVgrNdZkZmbiFlJlTThkYTA2eG00MzA5dHh1bWZnZgfdZDE=`"
      },
      "TerminalAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "required: true <br> in: header <br> name: Authorization <br> description: Needs to include `Basic` word before Base64 encoded `serial_number:registration_token`. The `serial_number` is the identifier of the terminal created on TAP. The `registration_token` is the unique token previously generated by TAP and provided securely to the terminal. <br> Example: `Basic ODA5BVgrNdZkZmbiFlJlTThkYTA2eG00MzA5dHh1bWZnZgfdZDE=` <br>"
      }
    },
    "parameters": {
      "Authorization": {
        "name": "Authorization",
        "in": "header",
        "description": "Needs to include `Basic` word before Base64 encoded `api_id:api_token`. The `api_id` is the identifier of the organization created on TAP; size range - up to 36 characters. The `api_token` is the unique token previously generated by TAP and provided securely to the organization; size range - `32`.\n  Example: `Basic ODA5BVgrNdZkZmbiFlJlTThkYTA2eG00MzA5dHh1bWZnZgfdZDE=`\n",
        "schema": {
          "type": "string",
          "format": "api_id:api_token"
        },
        "required": true
      },
      "Accept": {
        "name": "Accept",
        "in": "header",
        "description": "Specifies the requested API version. If this field is not specified or has an invalid format, the API will return an error. If the specified version does not exist, a 404 page will be displayed. Accepted values - `application/vnd.paymentfusion.v3.0.0+json`\n",
        "schema": {
          "type": "string",
          "example": "application/vnd.paymentfusion.v3.0.0+json"
        },
        "required": true
      },
      "ContentType": {
        "name": "Content-Type",
        "in": "header",
        "description": "The Content-Type entity header is used to indicate the media type of the resource.",
        "schema": {
          "type": "string",
          "example": "application/x-www-form-urlencoded"
        },
        "required": true
      },
      "X-SECRET-KEY": {
        "name": "X-SECRET-KEY",
        "in": "header",
        "description": "The access key shared only between Control Center and TB that provides authentication for calls coming from Control Center.\n",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "MerchantId": {
        "name": "merchant_id",
        "in": "path",
        "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`",
        "schema": {
          "type": "string",
          "example": "string"
        },
        "required": true
      },
      "CustomerId": {
        "name": "customer_id",
        "in": "path",
        "description": "Customer identifier associated to the transaction",
        "required": true,
        "schema": {
          "type": "string",
          "example": "string"
        }
      },
      "ReceiptData": {
        "name": "receipt_data",
        "in": "query",
        "description": "Need to provide at least one of 'receipt_name'(The name of the receipt on the gateway) or 'receipt_ref_num'(The unique identifier of the receipt template on the gateway).",
        "required": true,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "object",
          "properties": {
            "receipt_name": {
              "type": "string",
              "description": "The name of the receipt on the gateway."
            },
            "receipt_ref_num": {
              "type": "integer",
              "description": "The unique identifier of the receipt template on the gateway."
            }
          },
          "oneOf": [
            {
              "required": [
                "receipt_name"
              ]
            },
            {
              "required": [
                "receipt_ref_num"
              ]
            }
          ],
          "additionalProperties": false
        },
        "examples": {
          "RenderReceiptWithReceiptName": {
            "value": {
              "allOf": [
                {
                  "receipt_name": "string"
                }
              ]
            }
          },
          "RenderReceiptWithReceiptRefNum": {
            "value": {
              "allOf": [
                {
                  "receipt_ref_num": 123
                }
              ]
            }
          },
          "RenderReceiptWithReceiptNameAndReceiptRefNum": {
            "value": {
              "allOf": [
                {
                  "receipt_name": "string"
                },
                {
                  "receipt_ref_num": 123
                }
              ]
            }
          }
        }
      },
      "PageSize": {
        "name": "page_size",
        "in": "query",
        "description": "The number of contracts to be returned on a single page. Size range - `1..50`",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 20
        },
        "required": false
      },
      "PageNumber": {
        "name": "page_number",
        "in": "query",
        "description": "The number of the page to be returned. Minimum value - `1`",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "required": false
      }
    },
    "requestBodies": {
      "FinalizeConnectivityTestRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "serial_number",
                "registration_token",
                "results"
              ],
              "properties": {
                "serial_number": {
                  "description": "The serial number of the terminal. Size range - `256`",
                  "type": "string",
                  "example": "string"
                },
                "registration_token": {
                  "type": "string",
                  "description": "The terminal's secret token.",
                  "example": "string"
                },
                "results": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "example": "integer",
                      "description": "Id of the response."
                    },
                    "response_body": {
                      "type": "string",
                      "example": "string",
                      "description": "The body of the response."
                    },
                    "response_header": {
                      "type": "string",
                      "example": "string",
                      "description": "The header of the response."
                    },
                    "ip": {
                      "type": "string",
                      "example": "string",
                      "description": "IP address of the response."
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ConnectivityTestRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "secret_access_key",
                "serial_number",
                "tests"
              ],
              "properties": {
                "secret_access_key": {
                  "type": "string",
                  "example": "string",
                  "description": "The access key shared only between TAP and TB that provides authentication for calls coming from TAP."
                },
                "serial_number": {
                  "type": "string",
                  "example": "string",
                  "description": "The serial number of the terminal. Size range - `256`"
                },
                "tests": {
                  "$ref": "#/components/schemas/Tests"
                },
                "show_terminal_details": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ShowTerminalDetails"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "DiagnosticReportJobRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "serial_number"
              ],
              "properties": {
                "serial_number": {
                  "type": "string",
                  "description": "The serial number of the terminal. Size range - `255`"
                }
              }
            }
          }
        }
      },
      "LogJobRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "secret_access_key",
                "serial_number"
              ],
              "properties": {
                "secret_access_key": {
                  "description": "The access key shared only between TAP and TB that provides authentication for calls coming from TAP.",
                  "type": "string",
                  "example": "string"
                },
                "serial_number": {
                  "description": "The serial number of the terminal. Size range - `256`",
                  "type": "string",
                  "example": "string"
                },
                "show_terminal_details": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ShowTerminalDetails"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "OrganizationRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "secret_access_key",
                "organization_id",
                "api_id",
                "api_token"
              ],
              "properties": {
                "secret_access_key": {
                  "description": "The access key shared only between TAP and TB that provides authentication for calls coming from TAP.",
                  "type": "string"
                },
                "organization_id": {
                  "description": "The old organization_id that is used for authenticating organizations on versions prior to 1.3.1. Not to be confused with TB's internal organization ID.",
                  "type": "string"
                },
                "api_id": {
                  "description": "ID for API credentials",
                  "type": "string"
                },
                "api_token": {
                  "description": "Token for API credentials",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "FinalizePromptJobRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "serial_number",
                "registration_token",
                "result",
                "status"
              ],
              "properties": {
                "serial_number": {
                  "type": "string",
                  "description": "The terminal's serial number. Size range - `256`",
                  "example": "string"
                },
                "registration_token": {
                  "type": "string",
                  "description": "The terminal's secret token.",
                  "example": "string"
                },
                "result": {
                  "type": "string",
                  "description": "The action that the user has made.",
                  "example": "string"
                },
                "status": {
                  "type": "string",
                  "description": "The status of the prompt job. Allowed values - `'in progress'`, `'finalized'`, `'error'`, `'timed out'`, `'canceled'`",
                  "example": "string"
                }
              }
            }
          }
        }
      },
