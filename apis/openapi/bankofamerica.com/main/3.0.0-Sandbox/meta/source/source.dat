                },
                "remote_id": {
                  "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..256`.",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "FinalizeTransactionRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "serial_number",
                "registration_token",
                "transaction_status",
                "cc_token_pfg",
                "cc_token_usaepay",
                "masked_card_number",
                "card_expiration_date",
                "card_type",
                "tip_amount"
              ],
              "properties": {
                "serial_number": {
                  "type": "string",
                  "description": "The terminal's serial number. Size range - `256`",
                  "example": "string"
                },
                "registration_token": {
                  "type": "string",
                  "description": "The terminal's secret token.",
                  "example": "string"
                },
                "transaction_status": {
                  "type": "string",
                  "description": "Confirmation from the payment gateway regarding the CC credentials and payment finalization. Allowed values - `\"approved\"`, `\"canceled\"`, `\"declined\"`, `\"emv_needing_reversal\"`, `\"error\"`, `\"timeout\"`\n",
                  "example": "string"
                },
                "cc_token_pfg": {
                  "type": "string",
                  "description": "If the save_card flag was set to true and the transaction has been approved, the gateway issues a token that can be used for future transactions. Request must include *either* `cc_token_pfg` or `cc_token_usaepay`. It does not need to include both.",
                  "example": "string"
                },
                "cc_token_usaepay": {
                  "type": "string",
                  "description": "If the save_card flag was set to true and the transaction has been approved, the gateway issues a token that can be used for future transactions. Request must include *either* `cc_token_pfg` or `cc_token_usaepay`. It does not need to include both.",
                  "example": "string"
                },
                "masked_card_number": {
                  "type": "string",
                  "description": "The masked out card number including the last 4 digits (e.g. \"************1234\").",
                  "example": "string"
                },
                "card_expiration_date": {
                  "type": "string",
                  "description": "The card expiration date. Format 'MMYY' (e.g. '0922').",
                  "example": "string"
                },
                "card_type": {
                  "type": "string",
                  "description": "The type of the card that was submitted. Allowed values - `\"Discover\"`, `\"DISCOVER\"`, `\"UnionPay\"`, `\"AmEx\"`, `\"AMERICAN EXPRESS\"`, `\"AMEX\"`, `\"American express\"`, `\"Master\"`, `\"MASTERCARD\"`, `\"Mastercard\"`, `\"MASTERCARD/Mastercard\"`, `\"JCB\"`, `\"Jcb\"`, `\"Visa\"`, `\"VISA\"`,`\"Visa Traditional\"`, `\"Visa Classic\"`, `\"Visa Health\"`, `\"Visa Prefered\"`, `\"Mastercard/Eurocard\"`, `\"DINERS\"`, `\"CareCredit\"`, `\"Unknown Code\"`, `\"OTHER\"`, `\"null\"`, `\"N/A\"` The values are subject to change.\n",
                  "example": "string"
                },
                "tip_amount": {
                  "type": "integer",
                  "description": "The tip amount in USD cents that was added to this transaction. This is either the original tip specified by the ISV or the tip typed on the terminal if tip_method was \"typed\".",
                  "example": "integer"
                },
                "gateway_reference_number": {
                  "type": "integer",
                  "description": "Transaction reference number.",
                  "example": "integer"
                },
                "gateway_auth_code": {
                  "type": "string",
                  "description": "Transaction auth code from the gateway.",
                  "example": "string"
                },
                "gateway_identifier": {
                  "type": "string",
                  "description": "Identifier of the gateway. Allowed values - `\"usaepay\"`, `\"payment_fusion\"`.",
                  "example": "string"
                },
                "gateway_response": {
                  "$ref": "#/components/schemas/GatewayResponse"
                },
                "card_holder": {
                  "type": "string",
                  "description": "The name on the card.",
                  "example": "string"
                },
                "gateway_ip": {
                  "type": "string",
                  "description": "The IP of the server that processed this transaction.",
                  "example": "string"
                },
                "signature": {
                  "type": "string",
                  "description": "The base64 encoded signature. This param will be empty if the terminal does not support signature capturing.",
                  "example": "string"
                },
                "auth_amount": {
                  "type": "string",
                  "description": "The authorized amount in case of a partial authorized transaction.",
                  "example": "string"
                },
                "remaining_balance": {
                  "type": "string",
                  "description": "The remaining balance on the card in case of a partial authorized transaction.",
                  "example": "string"
                },
                "emv_data": {
                  "$ref": "#/components/schemas/EmvData"
                },
                "encrypted": {
                  "type": "boolean",
                  "description": "If the transaction is encrypted or not.",
                  "example": "boolean"
                },
                "input_method": {
                  "type": "string",
                  "description": "The input method used for the card associated with the transaction. Allowed values - `\"swipe\"`,`\"keyed\"`,`\"dip\"`,`\"contactless\"`,`\"fallback\"`,`\"chip_read\"`,`\"swiped\"`,`\"tap\"` The values are subject to change.\n",
                  "example": "string"
                },
                "is_card_present": {
                  "type": "boolean",
                  "description": "The presence of the card.",
                  "example": "boolean"
                },
                "order_method": {
                  "type": "string",
                  "description": "The type of order.",
                  "enum": [
                    "mail_order",
                    "phone_order",
                    "null"
                  ]
                }
              }
            }
          }
        }
      },
      "ExistingTransactionRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "ref_number",
                "merchant_id",
                "amount"
              ],
              "properties": {
                "ref_number": {
                  "type": "string",
                  "description": "The reference number of the transaction that will be adjusted.",
                  "example": "string"
                },
                "merchant_id": {
                  "type": "string",
                  "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`",
                  "example": "string"
                },
                "amount": {
                  "type": "string",
                  "description": "The amount in USD up to 6 decimals that will be charged, must be a number greater than 0 and its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").",
                  "example": "string"
                }
              }
            }
          }
        }
      },
      "TransactionAdjustRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "ref_number",
                "merchant_id",
                "original_amount",
                "new_tip"
              ],
              "properties": {
                "ref_number": {
                  "type": "string",
                  "description": "The reference number of the transaction that will be adjusted.",
                  "example": "string"
                },
                "merchant_id": {
                  "type": "string",
                  "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`",
                  "example": "string"
                },
                "original_amount": {
                  "type": "string",
                  "description": "The original amount for this transaction, in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").",
                  "example": "string"
                },
                "new_tip": {
                  "type": "string",
                  "description": "The new tip for this transaction, in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").",
                  "example": "string"
                }
              }
            }
          }
        }
      },
      "TransactionReversalRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "ref_number",
                "merchant_id"
              ],
              "properties": {
                "ref_number": {
                  "type": "string",
                  "description": "The reference number of the transaction that will be refunded.",
                  "example": "string"
                },
                "merchant_id": {
                  "type": "string",
                  "description": "The merchant identifier that will be used to connect to the gateway. Size range - `1..16`",
                  "example": "string"
                },
                "refund_amount": {
                  "type": "string",
                  "description": "The amount to refund, in USD up to 6 decimals that will be charged, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").",
                  "example": "string"
                },
                "force_duplicate": {
                  "type": "boolean",
                  "description": "Specifies whether this transaction can bypass duplicate error.",
                  "example": "string"
                },
                "remote_id": {
                  "description": "Used for keeping track of a 3rd party identifier alongside the transaction object. This is typically used by the ISV to assign its own identifier to the transaction for easy matching in case any network issues appear. This is not validated for uniqueness. Size range - `0..256`.",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "UpdateContractRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/UpdateContractStatus"
                },
                {
                  "$ref": "#/components/schemas/UpdateContractData"
                }
              ]
            },
            "examples": {
              "UpdateContractStatus": {
                "value": {
                  "allOf": [
                    {
                      "action": "string"
                    }
                  ]
                }
              },
              "UpdateContractData": {
                "value": {
                  "allOf": [
                    {
                      "action": "update"
                    },
                    {
                      "bill_amount": "string"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "CreateCardContractRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "bill_amount",
                "token"
              ],
              "properties": {
                "bill_amount": {
                  "description": "Sets the monetary amount to charge on each cycle. Specified in USD.",
                  "type": "integer",
                  "example": "integer"
                },
                "start_date": {
                  "description": "Must be entered in YYYYMMDD format. If not set, the default value will be the date of tomorrow. For example, if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. If set to \"next\" the date of the next billing cycle will be used. For example, if today is 1/10/2009 and schedule=monthly then start_date will be set to 2/10/2009. Can also be entered as \"first of month\" or \"last day of month\".",
                  "type": "string",
                  "example": "string"
                },
                "schedule": {
                  "description": "Frequency of recurring billing schedule. Will be ignored if recurring is not sent as \"true\". Allowed values - \"disabled\",\"daily\",\"weekly\",\"bi-weekly\", \"monthly\",\"bi-monthly\",\"quarterly\",\"bi-annually\",\"annually\". If set to \"disabled\" the contract will have the schedule set to \"monthly\" and status set to \"disabled\".",
                  "type": "string",
                  "example": "string"
                },
                "num_left": {
                  "description": "Number of transactions remaining in the recurring billing cycle. Will be ignored if recurring is not sent as \"true\". Can take the value of *, which is interpreted as recurring payment for unlimited time.",
                  "type": "integer",
                  "example": "integer"
                },
                "token": {
                  "description": "The credit card token.",
                  "type": "string",
                  "example": "string"
                },
                "enabled": {
                  "description": "Indicates whether the contract will be enabled or disabled when created.",
                  "type": "boolean",
                  "example": "boolean",
                  "default": true
                }
              }
            }
          }
        }
      },
      "CreateAchContractRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "allOf": [
                {
                  "type": "object",
                  "required": [
                    "bill_amount"
                  ]
                },
                {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/AchContractRequestWithToken"
                    },
                    {
                      "$ref": "#/components/schemas/AchContractRequestWithData"
                    }
                  ]
                }
              ]
            },
            "examples": {
              "AchContractRequestWithToken": {
                "value": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/AchContractRequestWithToken/example"
                    }
                  ]
                }
              },
              "AchContractRequestWithData": {
                "value": {
                  "allOf": [
                    {
                      "$ref": "#components/schemas/AchContractRequestWithData/example"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "SetAmountFieldsRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "amount"
              ],
              "properties": {
                "amount": {
                  "description": "The amount value used to update the amount field in the database.\nDescribed in USD up to 6 decimals, must be a number greater than 0 and its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").\n",
                  "type": "integer",
                  "example": "integer"
                },
                "healthcare": {
                  "$ref": "#/components/schemas/HealthcareRequestFields"
                }
              }
            }
          }
        }
      }
    },
