      },
      "get": {
        "tags": [
          "Prompt Job"
        ],
        "summary": "Get prompt jobs.",
        "operationId": "getPromptJobs",
        "description": "Called by the Independent Software Vendor. Lists all the prompt jobs in the database for the current organization.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Authorization"
          },
          {
            "$ref": "#/components/parameters/Accept"
          },
          {
            "name": "limit",
            "in": "query",
            "description": "The limit of the returned list. Size range - `1..100`",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "example": 15
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Specifies the offset of the returned list items. Size range - `0..`",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "example": 10
            }
          }
