                "allow_partial_auth": {
                  "description": "Sets the flag for allowing partial payment",
                  "type": "boolean",
                  "default": false
                },
                "zip_code": {
                  "description": "5 digit ZIP code. Optional value indicating the cardholder's zip code.",
                  "type": "string"
                },
                "street_address": {
                  "description": "Optional value indicating the cardholder's street address.",
                  "type": "string"
                },
                "tax_amount": {
                  "description": "Optional value indicating the tax amount that will be charged, in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\").",
                  "type": "string"
                },
                "client_id": {
                  "description": "Used to track the workstation associated with the transaction.",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CreateHostedPaymentPageRequest": {
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "required": [
                "id",
                "transaction_type",
                "amount"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "The HPP identifer for the transaction"
                },
                "transaction_type": {
                  "type": "string",
                  "description": "The type of transaction that will be performed. (e.g. transaction_type=Sale)\n\nAllowed Values - `\"Auth\"`, `\"Sale\"`, `\"SaveOnly\"`\n",
                  "example": "Sale"
                },
                "amount": {
                  "type": "number",
                  "format": "float",
                  "description": "The amount in USD up to 6 decimals that will be charged, must be a number greater than 0 and its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\")."
                },
                "invoice_number": {
                  "type": "string",
                  "description": "The invoice number of the transaction that will be performed. (e.g. invoice_number=INV333)"
                },
                "pn_ref": {
                  "type": "string",
                  "description": "The gateway's transaction reference number (e.g. pn_ref=523222)"
                },
                "echo_fields": {
                  "type": "boolean",
                  "description": "Enable echo_fields"
                },
                "approved_redirect": {
                  "type": "string",
                  "description": "Redirect URL for approval",
                  "maxLength": 2000
                },
                "declined_redirect": {
                  "type": "string",
                  "description": "Redirect URL for declined",
                  "maxLength": 2000
                },
                "send_customer_receipt": {
                  "type": "boolean",
                  "description": "Determines if the receipt should be sent or not"
                },
                "receipt_template": {
                  "type": "string",
                  "description": "Allowed Values - `\"pending\"`, `\"approved\"`, `\"declined\"`, `\"void\"`, `\"error\"`, `\"installment\"`, `\"refund\"`, `\"refunded\"`, `\"credit\"`, `\"default\"`\n"
                },
                "customer_email": {
                  "type": "string",
                  "description": "Specifies the customer email address"
                },
                "test_mode": {
                  "type": "boolean",
                  "description": "Enable test_mode"
                },
                "force_duplicate": {
                  "type": "boolean",
                  "description": "Allows multiple transactions with the same amount to be created on the same merchant"
                },
                "amount_is_editable": {
                  "type": "boolean",
                  "description": "Specifies if the amount is editable or not"
                },
                "non_taxable": {
                  "type": "boolean",
                  "description": "Specifies if the transaction is non taxable"
                },
                "tax_amount": {
                  "type": "number",
                  "format": "float",
                  "description": "Specifies the tax amount value in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\")."
                },
                "shipping_amount": {
                  "type": "number",
                  "format": "float",
                  "description": "Specifies the shipping amount value in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\")."
                },
                "discount_amount": {
                  "type": "number",
                  "format": "float",
                  "description": "Specifies the discount value in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\")."
                },
                "tip_amount": {
                  "type": "number",
                  "format": "float",
                  "description": "Specifies the tip value in USD up to 6 decimals, its last 4 digits must be 0. (e.g. \"1\", \"1.00\", \"1.01\", \"1.2\", \"1.230000\")."
                },
                "customer_name": {
                  "type": "string",
                  "description": "Specifies the customer name"
                },
                "phone_number": {
                  "type": "string",
                  "description": "Specifies the customer phone number"
                },
                "billing_first_name": {
                  "type": "string",
                  "description": "Specifies the billing first name"
                },
                "billing_last_name": {
                  "type": "string",
                  "description": "Specifies the billing last name"
                },
                "billing_address_1": {
                  "type": "string",
                  "description": "Specifies the billing address line 1"
                },
                "billing_address_2": {
                  "type": "string",
                  "description": "Specifies the billing address line 2"
                },
                "billing_city": {
                  "type": "string",
                  "description": "Specifies the billing city"
                },
                "billing_state": {
                  "type": "string",
                  "description": "Specifies the billing state"
                },
                "billing_zip": {
                  "type": "string",
                  "description": "Specifies the billing zip code"
                },
                "shipping_is_billing": {
                  "type": "boolean",
                  "description": "Specifies if the shipping address is the same as the billing address"
                },
                "shipping_first_name": {
                  "type": "string",
                  "description": "Specifies the shipping person first name"
                },
                "shipping_last_name": {
                  "type": "string",
                  "description": "Specifies the shipping person last name"
                },
                "shipping_address_1": {
                  "type": "string",
                  "description": "Specifies the shipping address line 1"
                },
                "shipping_address_2": {
                  "type": "string",
                  "description": "Specifies the shipping address line 2"
                },
                "shipping_city": {
                  "type": "string",
                  "description": "Specifies the shipping city"
                },
                "shipping_state": {
                  "type": "string",
                  "description": "Specifies the shipping state"
                },
                "shipping_zip": {
                  "type": "string",
                  "description": "Specifies the shipping address zip code"
                },
                "comment": {
                  "type": "string",
                  "description": "Specifies a comment for the transaction"
                },
                "description": {
                  "type": "string",
                  "description": "Specifies the description of the transaction"
                },
                "clerk": {
                  "description": "Sales clerk. Optional value indicating the clerk/person processing transaction, for reporting purposes.",
                  "type": "string"
                },
                "remote_id": {
                  "type": "string",
                  "description": "Specifies the remote id"
                },
                "merchant_trans_id": {
                  "type": "string",
                  "description": "Merchant Transaction Id. Must be between 1 and 39 characters in length. When using the Elavon Processor, this field will contain a 3 character Facility ID concatenated with the Patient Account Number which will be passed to the Elavon Processor."
                },
                "expiration_in_days": {
                  "type": "integer",
                  "description": "Sets the expiration in days for the transaction between 1-365. 1 is the default value."
                },
                "sec_code": {
                  "type": "string",
                  "description": "The Standard Entry Class (SEC) value to use with processors that require it. If left empty, the default value will be `\"WEB\"`. Allowed values - `\"WEB\"`, `\"TEL\"`\n"
                },
                "short_url": {
                  "type": "boolean",
                  "description": "Generates a short HPP URL"
                },
                "custom_fields": {
                  "type": "string",
                  "description": "Optional field of comma separated key=value pairs (e.g. custom_fields=key_1=value_1,key_2=value_2,key_3=value_3) reserved keys tb_id, tb_transaction_type"
                },
                "callback_url_1": {
                  "description": "One of the three URLs where Transaction Broker will POST to when a HPP request is completed. This eliminates the need for polling for the request's status. Only HTTPS URLs are allowed. The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
                  "type": "string"
                },
                "callback_url_2": {
                  "description": "One of the three URLs where Transaction Broker will POST to when a HPP request is completed. This eliminates the need for polling for the request's status. Only HTTPS URLs are allowed. The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
                  "type": "string"
                },
                "callback_url_3": {
                  "description": "One of the three URLs where Transaction Broker will POST to when a HPP request is completed. This eliminates the need for polling for the request's status. Only HTTPS URLs are allowed. The callback will the callback will retry if the host is unresponsive. The response received from the callback url must have the response code 2xx. Basic auth credentials may be added in to url ie. 'https://username:password@address.com' or as an url param 'https://address.com?token=secret'. Size range - `0..2000`.",
                  "type": "string"
                },
                "allow_partial_auth": {
                  "description": "Sets the flag for allowing partial payment. If not set then it is not sent in the HPP request.",
                  "type": "boolean"
                },
                "healthcare": {
                  "$ref": "#/components/schemas/HealthcareRequestFields"
                }
              }
            }
          }
        }
      },
