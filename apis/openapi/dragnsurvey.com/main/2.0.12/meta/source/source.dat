              "schema": {
                "type": "object",
                "properties": {
                  "respondents_informations": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "title": "respondent information",
                      "description": "an object of data that should be stored with the respondent answers for example it could be an email address or a CRM id"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/components/{componentId}": {
      "get": {
        "tags": [
          "questions"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get question definition",
        "description": "",
        "parameters": [
          {
            "name": "componentId",
            "in": "path",
            "required": true,
            "description": "the id of the question for which you want to retrieve definition",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Return an object containing question definition",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "question",
                  "properties": {
                    "type": {
                      "$ref": "#/components/schemas/questionTypesEnum"
                    },
                    "title": {
                      "type": "string",
                      "example": "Which color is your favorite?",
                      "description": "The heading of the question"
                    },
                    "items": {
                      "description": "datas to be display as question choice of answers",
                      "type": "object",
                      "title": "question_items",
                      "properties": {
                        "choices": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "label": {
                                "type": "string",
                                "description": "the display label of the item"
                              },
                              "type": {
                                "type": "string",
                                "description": "the item type"
                              },
                              "redirect": {
                                "type": "object",
                                "title": "item redirect settings",
                                "description": "item redirect setting that is present only if a redirection is set for this item. The property will not be returned in case there is no redirection set for a, item",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "enum": [
                                      "page",
                                      "question"
                                    ],
                                    "description": "the element to which the respondent will be redirected after answering the question if he chose this item"
                                  },
                                  "targetId": {
                                    "type": "string",
                                    "description": "the id of the target element",
                                    "example": "5d95b5fdd4c9bd4ad11af070"
                                  }
                                }
                              }
                            }
                          }
                        },
                        "other": {
                          "type": "string",
                          "example": "Une autre couleur",
                          "description": "help text for the \"other\" choice in case of multiple choice answers"
                        }
                      }
                    },
                    "options": {
                      "type": "object",
                      "title": "question_options",
                      "properties": {
                        "sub_type": {
                          "type": "string",
                          "example": null,
                          "description": "optional string that can slightly modify the behaviour or the display of a question (example \"date\" for a free field on which only date answers are accepted)"
                        },
                        "display": {
                          "type": "string",
                          "enum": [
                            "normal",
                            "random",
                            "alpha"
                          ],
                          "description": "indicate how the items are displayed."
                        },
                        "mandatory": {
                          "type": "boolean",
                          "example": true,
                          "description": "indicate if the answer to this question is mandatory to keep progressing in the questionnaire"
                        },
                        "allowed_answer": {
                          "type": "integer",
                          "example": 2,
                          "description": "indicate how many answers it is possible to select for this question"
                        },
                        "characters_limit": {
                          "type": "integer",
                          "example": 500,
                          "description": "indicate how many characters can be entered for a question of type freeField (from 1 to 1000)"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        }
      }
    },
    "/components/{componentId}/responses": {
      "get": {
        "tags": [
          "questions"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Retrieve responses associated to a questions",
        "description": "",
        "parameters": [
          {
            "name": "componentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "reportId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "optional reportId to get question statistics taking into consideration report filters"
          }
        ],
        "responses": {
          "200": {
            "description": "Return an object containing informations about the responses associated to a question",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "responses",
                  "properties": {
                    "choices": {
                      "type": "array",
                      "items": {
                        "type": "number"
                      },
                      "description": "the number of annswer associate dto each question items"
                    },
                    "count": {
                      "type": "integer",
                      "example": 102,
                      "description": "number of respondents that answered this question"
                    },
                    "split": {
                      "type": "array",
                      "items": {
                        "type": "integer",
                        "example": [
                          1,
                          5,
                          0,
                          0,
                          1
                        ],
                        "description": "array representing the spread of the respondents between different labels choice in a rate type question."
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        }
      }
    },
    "/respondents/{respondentId}": {
      "get": {
        "tags": [
          "respondents"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "retrieve responses associated to a respondent",
        "description": "",
        "parameters": [
          {
            "name": "respondentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Return an object containing informations about the responses associated to a respondent",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "respondent",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "5d95b61926530c59e52df232",
                      "description": "the id of the respondent to which the responses are associated"
                    },
                    "ip_address": {
                      "type": "string",
                      "example": "127.0.0.1",
                      "description": "the ip adress of the respondent"
                    },
                    "created_at": {
                      "type": "string",
                      "example": "2019-10-03T08:49:29.000000Z",
                      "description": "the date in ISO format at which the respondent answered"
                    },
                    "questions": {
                      "type": "object",
                      "description": "object containing answers to questions filled by the respondent",
                      "properties": {
                        "questionId": {
                          "type": "object",
                          "description": "uuid of the answered question",
                          "properties": {
                            "choices": {
                              "type": "array",
                              "items": {
                                "type": "string",
                                "description": "the answer for the given question"
                              }
                            }
                          }
                        }
                      }
                    },
                    "complete": {
                      "type": "boolean",
                      "example": true,
                      "description": "boolean that indicated if the respondent completed the survey"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        }
      },
      "delete": {
        "summary": "Delete a respondent by ID",
        "description": "Deletes the specified respondent if the user has the required permissions and the respondent exists.",
        "operationId": "deleteRespondent",
        "tags": [
          "respondents"
        ],
        "parameters": [
          {
            "name": "respondentId",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the respondent",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Respondent deleted successfully"
          },
          "403": {
            "description": "User does not have permission to perform this action",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "permission": {
                      "type": "string",
                      "example": "User role do not authorize this action"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "No respondent could be retrieved with the provided ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "respondent id": {
                      "type": "string",
                      "example": "No respondent could be retrieved with this id"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/respondents/{respondentId}/responses": {
      "get": {
        "tags": [
          "respondents"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "retrieve responses associated to a respondent in a human readable way",
        "description": "",
        "parameters": [
          {
            "name": "respondentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Return an object containing informations about the responses associated to a respondent",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "respondent",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "5d95b61926530c59e52df232",
                      "description": "the id of the respondent to which the responses are associated"
                    },
                    "ip_address": {
                      "type": "string",
                      "example": "127.0.0.1",
                      "description": "the ip adress of the respondent"
                    },
                    "created_at": {
                      "type": "string",
                      "example": "2019-10-03T08:49:29.000000Z",
                      "description": "the date in ISO format at which the respondent answered"
                    },
                    "questions": {
                      "type": "object",
                      "description": "object containing answers to questions filled by the respondent",
                      "properties": {
                        "questionId": {
                          "type": "object",
                          "description": "uuid of the answered question",
                          "properties": {
                            "title": {
                              "type": "string",
                              "description": "The question title",
                              "example": "What do you think about our product ?"
                            },
                            "answers": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "description": "Details of the answer to the question",
                                "properties": {
                                  "type": {
                                    "$ref": "#/components/schemas/questionTypesEnum"
                                  },
                                  "answers": {
                                    "type": "object",
                                    "properties": {
                                      "computed_response": {
                                        "type": "string",
                                        "example": "I love it",
                                        "description": "the computed answer in a human readable way"
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "complete": {
                      "type": "boolean",
                      "example": true,
                      "description": "boolean that indicated if the respondent completed the survey"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          }
        }
      }
    },
    "/reports/{reportId}": {
      "get": {
        "tags": [
          "reports"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "report details",
        "parameters": [
          {
            "name": "reportId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "uuid of the report"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "an object representing the report",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "report",
                  "properties": {
                    "title": {
                      "type": "string",
                      "example": "My awesome report"
                    },
                    "filters": {
                      "description": "array of object representing filters applied to the all survey",
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/filter"
                      }
                    },
                    "questions": {
                      "description": "an object with uuid of questions as properties. Only the questions that are customized in the given report will be present in this object",
                      "properties": {
                        "uuid": {
                          "description": "the uuid of a question",
                          "type": "object",
                          "properties": {
                            "filters": {
                              "type": "array",
                              "description": "array of object representing filters applied to this specific question",
                              "items": {
                                "$ref": "#/components/schemas/filter"
                              }
                            },
                            "chartType": {
                              "type": "string",
                              "enum": [
                                "bar",
                                "doughnut",
                                "line",
                                "pie",
                                "polarArea",
                                "radar"
                              ],
                              "description": "the type of graph used to represent the question. Not used for freeField and spreadsheet_freeField type question"
                            },
                            "hidden": {
                              "type": "boolean",
                              "description": "indicate wether the question will be displayed in shared report or exports"
                            }
                          }
                        }
                      }
                    },
                    "share": {
                      "type": "object",
                      "properties": {
                        "link": {
                          "type": "string",
                          "description": "acces link to the shared report"
                        },
                        "isPasswordProtected": {
                          "type": "boolean"
                        }
                      }
                    },
                    "created_at": {
                      "type": "string",
                      "example": "2019-10-03T08:49:23.000000Z"
                    },
                    "updated_at": {
                      "type": "string",
                      "example": "2019-10-03T08:49:23.000000Z"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          }
        }
      }
    },
    "/webhooks": {
      "get": {
        "tags": [
          "webhooks"
        ],
        "summary": "list all webhooks of a user",
        "responses": {
          "200": {
            "description": "an array of webhooks object",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/webhook"
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/links"
                    },
                    "meta": {
                      "$ref": "#/components/schemas/meta"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "webhooks"
        ],
        "summary": "subscribe to a webhook",
        "responses": {
          "201": {
            "description": "webhook created",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/webhook"
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "a secure url must be provided",
                    "example": "https://wwww.myserver.com/callback"
                  },
                  "event_type": {
                    "type": "string",
                    "enum": [
                      "response_created",
                      "response_completed"
                    ]
                  },
                  "element": {
                    "type": "string",
                    "enum": [
                      "survey",
                      "collector"
                    ]
                  },
                  "element_id": {
                    "type": "string",
                    "description": "uuid of the element"
                  },
                  "authentication": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "basic"
                        ]
                      },
                      "credentials": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "description": "an array containing the username as the first item and the password as the second item"
                        }
                      }
                    }
                  }
                },
                "required": [
                  "url",
                  "event_type",
                  "element",
                  "element_id"
                ]
              }
            }
          }
        },
        "callbacks": {
          "response_created": {
            "https://www.myserver.com/callback": {
              "post": {
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "$ref": "#/components/schemas/webhook_response_event"
                      }
                    }
                  }
                },
                "responses": {
                  "200": {
                    "description": "Ok"
                  }
                }
              }
            }
          },
          "response_completed": {
            "https://www.myserver.com/callback": {
              "post": {
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "$ref": "#/components/schemas/webhook_response_event"
                      }
                    }
                  }
                },
                "responses": {
                  "200": {
                    "description": "Ok"
                  }
                }
              }
            }
          }
        }
      }
    },
