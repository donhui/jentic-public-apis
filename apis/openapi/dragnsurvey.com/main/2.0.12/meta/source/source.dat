              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "respondent access",
                    "properties": {
                      "link": {
                        "type": "string",
                        "description": "a unique link associated to the custom id you provided. Accessing the survey with this link will authentify the respondent with the custom id provided"
                      },
                      "respondentId": {
                        "type": "string",
                        "description": "the Drag'n Survey respondent Id"
                      },
                      "details": {
                        "type": "object",
                        "title": "respondent informations",
                        "description": "the object your provided with your request"
                      }
                    }
