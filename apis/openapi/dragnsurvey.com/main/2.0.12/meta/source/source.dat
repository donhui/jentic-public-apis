        }
      }
    }
  },
  "servers": [
    {
      "url": "https://developer.dragnsurvey.com/api/v2.0.0/"
    }
  ],
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header"
      }
    },
    "headers": {
      "X-RateLimit-Limit": {
        "schema": {
          "type": "integer"
        },
        "description": "The limit of request you can make per minute"
      },
      "X-Ratelimit-Remaining": {
        "schema": {
          "type": "integer"
        },
        "description": "The amount of remaining requests you can perform before reset"
      },
      "Retry-After": {
        "schema": {
          "type": "integer"
        },
        "description": "Amount of time in second you have to wait before performing a new request (will only be present if the limit has been reached)"
      }
    },
    "schemas": {
      "Collector": {
        "type": "object",
        "title": "collector",
        "properties": {
          "type": {
            "type": "string",
            "example": "email",
            "enum": [
              "link",
              "email",
              "qrCode",
              "widget",
              "panel",
              "chat"
            ],
            "description": "a string that describe the collector type"
          },
          "title": {
            "type": "string",
            "example": "Test collector"
          },
          "key": {
            "type": "string",
            "description": "access key to the collector"
          },
          "respondents": {
            "type": "array",
            "items": {
              "type": "string",
              "title": "respondent_id",
              "description": "respondent ids associated to this collector"
            }
          },
          "status": {
            "type": "string",
            "example": "active",
            "description": "Set the questionnaire available to respondent or not"
          },
          "created_at": {
            "type": "string",
            "example": "2019-10-03T08:49:23.000000Z"
          },
          "updated_at": {
            "type": "string",
            "example": "2019-10-03T08:49:23.000000Z"
          }
        }
      },
      "CollectorOptions": {
        "type": "object",
        "title": "collector_options",
        "properties": {
          "limit_responses_per_ip": {
            "type": "boolean",
            "example": false,
            "description": "if set to true, only one answer is accepted by IP address, default to false"
          },
          "anonymous": {
            "type": "boolean",
            "example": false,
            "description": "if set to true, IP address and mail address while not be shown in the result, default to false"
          },
          "redirect": {
            "type": "boolean",
            "example": true,
            "default": false,
            "description": "the status of the redirect options default to false, in which case no redirection will happen If both redirect and loop setting are set to true, it will generate an error  "
          },
          "redirect_url": {
            "type": "string",
            "example": "https://www.google.com",
            "description": "Deprecated property use redirect_content instead. The url to which the respondent will be redirect, only available if options.redirect is set to true",
            "deprecated": true
          },
          "redirect_content": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "url"
                ]
              },
              "value": {
                "type": "string",
                "example": "https://www.google.com",
                "description": "the secure url to which you want to redirect respondents after completion of the survey,"
              },
              "timer": {
                "type": "integer",
                "example": 3,
                "description": "the time in second before the redirection takes place after display of the Thanks page"
              }
            }
          },
          "loop": {
            "type": "boolean",
            "example": true,
            "default": false,
            "description": "If set to true, the survey will automatically restart after a given duration If both redirect and loop setting are set to true, it will generate an error"
          },
          "loop_timer": {
            "type": "integer",
            "example": 10,
            "default": 3,
            "description": "The duration in second before the survey is automatically restarted Only used if loop setting is set to true"
          },
          "custom_thanks_page": {
            "type": "boolean",
            "example": true
          },
          "custom_thanks_page_content": {
            "type": "string",
            "description": "custom thank you text that will be displayed after completion of the survey,if thanks options.thanks_page is set to true in which case, the default thank you message will be displayed instead"
          },
          "answers_print": {
            "type": "boolean",
            "example": true,
            "default": false,
            "description": "If set to true, the respondent will have the option to download his answers in a pdf at the end of the survey"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "type": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "uuid of the webhook"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "example": "https://wwww.myserver.com/callback"
          },
          "event_type": {
            "type": "string",
            "enum": [
              "response_created",
              "response_completed"
            ]
          },
          "element": {
            "type": "string",
            "enum": [
              "survey",
              "collector"
            ]
          },
          "element_id": {
            "type": "string",
            "description": "uuid of the element"
          },
          "authentication": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "basic",
                  "none"
                ]
              }
            }
          }
        }
      },
      "webhook_response_event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "the uuid of the webhook"
          },
          "event_type": {
            "type": "string",
            "enum": [
              "response_created",
              "response_completed"
            ]
          },
          "element": {
            "type": "string",
            "enum": [
              "survey",
              "collector"
            ]
          },
          "element_id": {
            "type": "string",
            "description": "uuid of the element"
          },
          "resources": {
            "type": "object",
            "properties": {
              "survey_id": {
                "type": "string",
                "description": "uuid of the survey on which the respondent answered"
              },
              "collector_id": {
                "type": "string",
                "description": "uuid of the collector through which the respondent answered"
              },
              "respondent_id": {
                "type": "string",
                "description": "the id of the created respondent"
              }
            }
          }
        }
      },
      "filter": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "answer",
                "collector",
                "completion",
                "date"
              ]
            },
            "question": {
              "type": "string",
              "description": "only used for answer type filter. Represent the uuid of the question used to filter"
            },
            "answer": {
              "type": "integer",
              "description": "only used for answer type filter. represent the index of the response in the choice array of the question"
            },
            "collectorId": {
              "type": "string",
              "description": "only used for collector type filter. uuid of the collector that is used to filter"
            },
            "from": {
              "type": "string",
              "description": "only used in date type filter. Date on format Y-m-d representing the start date that is applied to the filter"
            },
            "to": {
              "type": "string",
              "description": "only used in date type filter. Date on format Y-m-d representing the end date that is applied to the filter"
            },
            "chainWith": {
              "type": "string",
              "enum": [
                "and",
                "or"
              ],
              "description": "the connector type with next filter if it exists"
            }
          }
        }
      },
      "questionTypesEnum": {
        "type": "string",
        "example": "multipleChoice",
        "description": "A string whose value indicate question type",
        "enum": [
          "multipleChoice",
          "yesNo",
          "rating",
          "cursor",
          "freeField",
          "ranking",
          "percentage",
          "imageChoice",
          "imageRating",
          "spreadhseet_freeField",
          "spreadsheet_choice",
          "upload",
          "nps"
        ]
      },
      "links": {
        "type": "object",
        "properties": {
          "first": {
            "type": "string"
          },
          "last": {
            "type": "string"
          },
          "prev": {
            "type": "string"
          },
          "next": {
            "type": "string"
          }
        }
      },
      "meta": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer"
          },
          "from": {
            "type": "integer"
          },
          "last_page": {
            "type": "integer"
          },
          "path": {
            "type": "string"
          },
          "per_page": {
            "type": "integer"
          },
          "to": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      }
    }
  },
  "security": [
    {
      "Bearer": []
    }
  ]
}
