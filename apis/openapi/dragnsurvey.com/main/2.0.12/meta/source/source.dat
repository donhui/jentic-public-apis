{
  "openapi": "3.0.3",
  "info": {
    "version": "2.0.12",
    "title": "Drag'n Survey REST API documentation",
    "description": "Drag\u2019n Survey API allow you to collect the datas you retrieved through Drag\u2019n Survey and use them as you wish in your application. You can access your own surveys datas and datas collected by accounts you manage.<br/>\nThe Drag\u2019n Survey API is REST based and use OAuth 2.0 as authorization protocol.\nBearer authentification is used to make request to Drag'n Survey webservices. As a result, webservices are only available over HTTPS (SSL). <br/>\nTo [request an API token](https://developer.dragnsurvey.com/api_token), you must be the owner of a Drag'n Survey account and be authentified.<br/>\nThe token need to be send in the authorization header of your request:  <code>Authorization: Bearer \\<token> </code><br/>\nThe api return json object by default. Models of returned object are provided in the following documentation.<br/> <br/> There is a rate limit of 60 requests per minute.<br/> If you hit the limit, you can retrieve the amount of seconds you need to wait before the next call from the header <code>Retry-After</code> value.\n",
    "contact": {
      "name": "API support",
      "url": "https://developer.dragnsurvey.com",
      "email": "contact@dragnsurvey.com"
    },
    "x-jentic-source-url": "https://developer.dragnsurvey.com"
  },
  "tags": [
    {
      "name": "surveys",
      "description": "survey definition"
    },
    {
      "name": "collectors",
      "description": "collectors definition"
    },
    {
      "name": "questions",
      "description": "questions definition and related answers"
    },
    {
      "name": "respondents",
      "description": "respondents answers"
    }
  ],
  "paths": {
    "/surveys": {
      "get": {
        "tags": [
          "surveys"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "get user surveys",
        "description": "",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "description": "optionnal parameter to get surveys of a sub account",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "title_contains",
            "in": "query",
            "required": false,
            "description": "optionnal parameter to filter returned surveys with a string contained in the survey title",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Return a paginated list of surveys for a given user",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "surveys",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "title": "survey",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "example": "5d95b602f332701a5f33a802"
                          },
                          "title": {
                            "type": "string",
                            "example": "My test survey"
                          },
                          "created_at": {
                            "type": "string",
                            "example": "2019-10-03T08:49:06.000000Z"
                          },
                          "updated_at": {
                            "type": "string",
                            "example": "2019-10-03T08:49:23.000000Z"
                          },
                          "collectors": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "example": [
                                "a4c30e489c7fe8e4da1695abca07d93b",
                                "b2048f33e7d4ee025bca224ad89d9695"
                              ],
                              "description": "array containing collectors id of a given survey"
                            }
                          },
                          "reports": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "example": [
                                "a4c30e489c7fe8e4da1695abca07d93b",
                                "b2048f33e7d4ee025bca224ad89d9695"
                              ],
                              "description": "array containing reports id of a given survey"
                            }
                          },
                          "defaultReportId": {
                            "type": "string",
                            "example": "a4c30e489c7fe8e4da1695abca07d93b",
                            "description": "the id of the default report automatically generated for a survey"
                          },
                          "pages": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "example": [
                                "5d95b602f332701a5f33a803"
                              ],
                              "description": "array containing the pages id of a given survey"
                            }
                          },
                          "options": {
                            "type": "object",
                            "title": "survey_options",
                            "properties": {
                              "display_progress_bar": {
                                "type": "boolean",
                                "example": true,
                                "description": "option to display or hide a progress bar for a given survey"
                              },
                              "display_title": {
                                "type": "boolean",
                                "example": true,
                                "description": "option to display or hide the title of a given survey"
                              },
                              "footer_text": {
                                "type": "string",
                                "example": "Powered by Drag'n Survey",
                                "description": "Text displayed in the survey footer"
                              },
                              "language": {
                                "type": "string",
                                "example": "fr",
                                "description": "language in which the various help text and buttons of the survey will be displayed to the user. Currently accepted strings are \"en\" and \"fr\""
                              },
                              "display_logo": {
                                "type": "boolean",
                                "example": true,
                                "description": "option to display or hide the logo of the survey. It works both for the Drag'n Survey logo or custom user logo"
                              },
                              "display_pages_numbering": {
                                "type": "boolean",
                                "example": false,
                                "description": "option to display or hide the page numbering and remaining pages at the top of a survey page"
                              },
                              "display_questions_numbering": {
                                "type": "boolean",
                                "example": true,
                                "description": "option to display or hide questions numbering"
                              },
                              "correction_type": {
                                "type": "boolean",
                                "example": true,
                                "description": "option that enable the correction mode at the end of a quiz."
                              },
                              "timer": {
                                "type": "object",
                                "title": "timer_configuration",
                                "description": "time allowed to complete a survey",
                                "properties": {
                                  "hours": {
                                    "type": "integer",
                                    "example": 0
                                  },
                                  "minutes": {
                                    "type": "integer",
                                    "example": 10
                                  },
                                  "seconds": {
                                    "type": "integer",
                                    "example": 0
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/links"
                    },
                    "meta": {
                      "$ref": "#/components/schemas/meta"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          }
        }
      }
    },
    "/surveys/{surveyId}/respondents": {
      "get": {
        "tags": [
          "surveys"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "get all respondents ids associated to a survey",
        "description": "",
        "parameters": [
          {
            "name": "surveyId",
            "in": "path",
            "required": true,
            "description": "survey Id",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "optionnal parameter to return only ids of respondents that fully completed the survey or respondents that didn't answer the survey at all depending on the parameter passed",
            "schema": {
              "type": "string",
              "enum": [
                "complete",
                "unanswered"
              ]
            }
          },
          {
            "name": "reportId",
            "in": "query",
            "required": false,
            "description": "optionnal, pass the id of a report to return the ids of respondents matching the filters set on the report",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "list of respondentsIds for a given survey",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "60dac8a75381e915c017434c"
                    },
                    "respondents": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "title": "respondent_id",
                        "description": "the id of a respondent",
                        "example": "60dac8e262958e224238f532"
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          }
        }
      }
    },
    "/surveys/{surveyId}/respondents/paginated": {
      "get": {
        "tags": [
          "surveys"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "get respondents ids associated to a survey (paginated)",
        "description": "",
        "parameters": [
          {
            "name": "surveyId",
            "in": "path",
            "required": true,
            "description": "survey Id",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "optionnal parameter to return only ids of respondents that fully completed the survey or respondents that didn't answer the survey at all depending on the parameter passed",
            "schema": {
              "type": "string",
              "enum": [
                "complete",
                "unanswered"
              ]
            }
          },
          {
            "name": "reportId",
            "in": "query",
            "required": false,
            "description": "optionnal, pass the id of a report to return the ids of respondents matching the filters set on the report",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "paginated list of respondentsIds for a given survey",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "title": "respondent_id",
                        "description": "the id of a respondent",
                        "example": "60dac8e262958e224238f532"
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/links"
                    },
                    "meta": {
                      "$ref": "#/components/schemas/meta"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          }
        }
      }
    },
    "/surveys/{surveyId}/collectors": {
      "post": {
        "tags": [
          "collectors"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Create a collector for a given survey",
        "description": "",
        "parameters": [
          {
            "name": "surveyId",
            "in": "path",
            "required": true,
            "description": "survey Id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "list of respondentsIds for a given survey",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Collector"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "options": {
                          "type": "object",
                          "$ref": "#/components/schemas/CollectorOptions"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "type"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "example": "My awesome collector title"
                  },
                  "type": {
                    "enum": [
                      "link"
                    ],
                    "example": "link",
                    "description": "At the moment only link is a supported type for collector creation with the API"
                  },
                  "user_id": {
                    "type": "number",
                    "example": 777,
                    "description": "optionnal user id of a sub account"
                  },
                  "options": {
                    "$ref": "#/components/schemas/CollectorOptions"
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "collectors"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "fetch the collectors of a survey",
        "description": "",
        "parameters": [
          {
            "name": "surveyId",
            "in": "path",
            "required": true,
            "description": "Survey Id",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "title_contains",
            "in": "query",
            "required": false,
            "description": "optionnal parameter to filter returned surveys with a string contained in the collector title",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Return a paginated list of collectors for a given survey",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "allOf": [
                          {
                            "$ref": "#/components/schemas/Collector"
                          },
                          {
                            "type": "object",
                            "properties": {
                              "emails_campaign_id": {
                                "type": "string",
                                "description": "the id of the email campaign associated for \"email\" type collector                   "
                              }
                            }
                          },
                          {
                            "type": "object",
                            "properties": {
                              "options": {
                                "type": "object",
                                "$ref": "#/components/schemas/CollectorOptions"
                              }
                            }
                          }
                        ]
                      }
                    },
                    "links": {
                      "$ref": "#/components/schemas/links"
                    },
                    "meta": {
                      "$ref": "#/components/schemas/meta"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        }
      }
    },
    "/pages/{pageId}": {
      "get": {
        "tags": [
          "pages"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "retrieve informations about a page",
        "description": "",
        "parameters": [
          {
            "name": "pageId",
            "in": "path",
            "required": true,
            "description": "page Id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "pages data",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "page",
                  "properties": {
                    "components": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "title": "component_id",
                        "description": "the id of the component in the page",
                        "example": "5da987cf8ed0e108e200bcb2"
                      }
                    },
                    "options": {
                      "type": "object",
                      "title": "page options",
                      "properties": {
                        "timer": {
                          "type": "object",
                          "title": "page timer settings",
                          "properties": {
                            "hours": {
                              "type": "integer",
                              "description": "number of hours allowed to complete the page",
                              "example": 0
                            },
                            "minutes": {
                              "type": "integer",
                              "description": "number of minutes allowed to complete the page",
                              "example": 10
                            },
                            "seconds": {
                              "type": "integer",
                              "description": "number of minutes allowed to complete the page",
                              "example": 30
                            }
                          }
                        },
                        "redirect": {
                          "type": "object",
                          "title": "page redirect settings",
                          "description": "the page redirect setting that will be returned only of a redirection is defined for the page. If no redirection is defined, the property will not be returned",
                          "properties": {
                            "type": {
                              "type": "string",
                              "enum": [
                                "page",
                                "question"
                              ],
                              "description": "the element to which the respondent will be redirected after completing the page"
                            },
                            "targetId": {
                              "type": "string",
                              "description": "the id of the target element",
                              "example": "5d95b5fdd4c9bd4ad11af070"
                            }
                          }
                        }
                      }
                    },
                    "created_at": {
                      "type": "string",
                      "example": "2019-10-03T08:49:23.000000Z"
                    },
                    "updated_at": {
                      "type": "string",
                      "example": "2019-10-03T08:49:23.000000Z"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        }
      }
    },
    "/collectors/{collectorId}": {
      "get": {
        "tags": [
          "collectors"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "retrieve informations about a collector",
        "description": "",
        "parameters": [
          {
            "name": "collectorId",
            "in": "path",
            "required": true,
            "description": "collector Id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "collector data",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Collector"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "emails_campaign_id": {
                          "type": "string",
                          "description": "the id of the email campaign associated for \"email\" type collector                   "
                        }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "options": {
                          "type": "object",
                          "$ref": "#/components/schemas/CollectorOptions"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "unauthorized"
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        }
      },
      "patch": {
        "tags": [
          "collectors"
        ],
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Update collector settings",
        "description": "",
        "parameters": [
          {
            "name": "collectorId",
            "in": "path",
            "required": true,
            "description": "collector Id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return update collector data",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Collector"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "options": {
                          "allOf": [
                            {
                              "$ref": "#/components/schemas/CollectorOptions"
                            },
                            {
                              "type": "object",
                              "properties": {
                                "emails_campaign_id": {
                                  "type": "string",
                                  "description": "the id of the email campaign associated for \"email\" type collector               "
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "example": "My awesome collector title"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "active",
                      "inactive"
                    ],
                    "description": "If set to inactive the access to the survey will be close"
                  },
                  "options": {
                    "$ref": "#/components/schemas/CollectorOptions"
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "parameters": [
          {
            "name": "collectorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "tags": [
          "collectors"
        ],
        "summary": "Delete a collector",
        "responses": {
          "204": {
            "description": "collector deleted",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-RateLimit-Limit"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "Retry-After": {
                "$ref": "#/components/headers/Retry-After"
              }
            }
          },
          "403": {
            "description": "unauthorized"
          },
          "422": {
            "description": "Resource couldn't be found"
          }
        }
      }
    },
