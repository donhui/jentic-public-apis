    "/buckets/{bucketSlug}/media": {
      "get": {
        "operationId": "getMedia",
        "summary": "Get media list",
        "description": "Retrieve a list of media files from the bucket.",
        "tags": [
          "Media"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "description": "JSON query for filtering",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "props",
            "in": "query",
            "description": "Properties to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "created_at",
                "-created_at",
                "modified_at",
                "-modified_at",
                "random"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          },
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "useCache",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "pretty",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "read_key",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Media list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "readKey": []
          }
        ]
      },
      "post": {
        "operationId": "createMedia",
        "summary": "Upload media",
        "description": "Upload a new media file to the bucket.",
        "tags": [
          "Media"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "media"
                ],
                "properties": {
                  "media": {
                    "type": "string",
                    "format": "binary",
                    "description": "Media file to upload"
                  },
                  "folder": {
                    "type": "string",
                    "description": "Media folder path"
                  },
                  "alt_text": {
                    "type": "string",
                    "description": "Image alt text"
                  },
                  "metadata": {
                    "type": "string",
                    "description": "JSON metadata object"
                  },
                  "trigger_webhook": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Media uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "media": {
                      "$ref": "#/components/schemas/MediaObject"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "writeKey": []
          }
        ]
      }
    },
    "/buckets/{bucketSlug}/media/{mediaId}": {
      "patch": {
        "operationId": "updateMedia",
        "summary": "Update media",
        "description": "Update media file metadata.",
        "tags": [
          "Media"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "folder": {
                    "type": "string"
                  },
                  "alt_text": {
                    "type": "string"
                  },
                  "metadata": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "trigger_webhook": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Media updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "media": {
                      "$ref": "#/components/schemas/MediaObject"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "writeKey": []
          }
        ]
      },
      "delete": {
        "operationId": "deleteMedia",
        "summary": "Delete media",
        "description": "Delete a media file from the bucket.",
        "tags": [
          "Media"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trigger_webhook",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
