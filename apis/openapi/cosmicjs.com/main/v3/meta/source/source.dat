{
  "openapi": "3.0.3",
  "info": {
    "title": "Cosmic API",
    "version": "v3",
    "description": "Cosmic is a headless CMS and API toolkit providing content management capabilities including objects, object types, media, and more.",
    "x-jentic-source-url": "https://www.cosmicjs.com/docs/api"
  },
  "servers": [
    {
      "url": "https://api.cosmicjs.com/v3",
      "description": "Cosmic API production server"
    }
  ],
  "paths": {
    "/status": {
      "get": {
        "operationId": "getApiStatus",
        "summary": "Check API status",
        "description": "Check the operational status of the Cosmic API.",
        "tags": [
          "Status"
        ],
        "responses": {
          "200": {
            "description": "API status information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/buckets/{bucketSlug}/objects": {
      "get": {
        "operationId": "getObjects",
        "summary": "Get objects",
        "description": "Retrieve a list of objects from a bucket with optional filtering, sorting, and pagination.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "description": "Bucket slug identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "description": "JSON query for search/filtering",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "props",
            "in": "query",
            "description": "Specific properties to return (comma-separated)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by publish status",
            "schema": {
              "type": "string",
              "enum": [
                "published",
                "draft",
                "any"
              ]
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort field and direction",
            "schema": {
              "type": "string",
              "enum": [
                "created_at",
                "-created_at",
                "modified_at",
                "-modified_at",
                "random"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of objects to return",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of objects to skip for pagination",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "depth",
            "in": "query",
            "description": "Object reference depth to resolve",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "after",
            "in": "query",
            "description": "Pagination cursor",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "useCache",
            "in": "query",
            "description": "Use cached results",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "pretty",
            "in": "query",
            "description": "Format JSON response",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "read_key",
            "in": "query",
            "description": "Bucket read key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of objects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectsListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing read key"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "readKey": []
          }
        ]
      },
      "post": {
        "operationId": "createObject",
        "summary": "Create an object",
        "description": "Create a new object in the bucket.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "description": "Bucket slug identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateObjectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Object created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing write key"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "writeKey": []
          }
        ]
      }
    },
    "/buckets/{bucketSlug}/objects/{objectId}": {
      "get": {
        "operationId": "getObjectById",
        "summary": "Get a single object by ID",
        "description": "Retrieve a single object by its unique identifier.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "description": "Bucket slug identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "description": "Object unique identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "props",
            "in": "query",
            "description": "Specific properties to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by publish status",
            "schema": {
              "type": "string",
              "enum": [
                "published",
                "draft",
                "any"
              ]
            }
          },
          {
            "name": "depth",
            "in": "query",
            "description": "Object reference depth",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "read_key",
            "in": "query",
            "description": "Bucket read key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "readKey": []
          }
        ]
      },
      "patch": {
        "operationId": "updateObject",
        "summary": "Update an object",
        "description": "Update an existing object's properties.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "description": "Bucket slug identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "description": "Object unique identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateObjectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Object updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "writeKey": []
          }
        ]
      },
      "delete": {
        "operationId": "deleteObject",
        "summary": "Delete an object",
        "description": "Delete an object from the bucket.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "description": "Bucket slug identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "description": "Object unique identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trigger_webhook",
            "in": "query",
            "description": "Trigger associated webhooks",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "writeKey": []
          }
        ]
      }
    },
    "/buckets/{bucketSlug}/objects/{objectId}/revisions": {
      "post": {
        "operationId": "addObjectRevision",
        "summary": "Add an object revision",
        "description": "Create a new revision for an object. Status defaults to draft.",
        "tags": [
          "Objects"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "objectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateObjectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Revision created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "revision": {
                      "$ref": "#/components/schemas/CosmicObject"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "writeKey": []
          }
        ]
      }
    },
    "/buckets/{bucketSlug}/object-types": {
      "get": {
        "operationId": "getObjectTypes",
        "summary": "Get object types",
        "description": "Retrieve all object types in the bucket.",
        "tags": [
          "Object Types"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of object types",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "object_types": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ObjectType"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "readKey": []
          }
        ]
      },
      "post": {
        "operationId": "createObjectType",
        "summary": "Create an object type",
        "description": "Create a new object type in the bucket.",
        "tags": [
          "Object Types"
        ],
        "parameters": [
          {
            "name": "bucketSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateObjectTypeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Object type created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "object_type": {
                      "$ref": "#/components/schemas/ObjectType"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "writeKey": []
          }
        ]
      }
    },
