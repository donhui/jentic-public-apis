    "/user.json": {
      "get": {
        "operationId": "getUser",
        "tags": [
          "Account"
        ],
        "summary": "Get the current user account info",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Get the current user account info"
      }
    },
    "/info/output_file_endings.json": {
      "get": {
        "operationId": "listOutputFileEndings",
        "tags": [
          "Info"
        ],
        "summary": "List available output file endings",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfoListResponse"
                }
              }
            }
          }
        },
        "description": "List available output file endings"
      }
    },
    "/info/production_status.json": {
      "get": {
        "operationId": "listProductionStatuses",
        "tags": [
          "Info"
        ],
        "summary": "List production status codes",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfoListResponse"
                }
              }
            }
          }
        },
        "description": "List production status codes"
      }
    },
    "/info/service_types.json": {
      "get": {
        "operationId": "listServiceTypes",
        "tags": [
          "Info"
        ],
        "summary": "List supported service types (e.g. SFTPs, storage, publishing platforms)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfoListResponse"
                }
              }
            }
          }
        },
        "description": "List supported service types (e.g. SFTPs, storage, publishing platforms)"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication with Auphonic username and password"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth2 Bearer token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error_code": {
            "type": "integer"
          },
          "error_message": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "status_string": {
            "type": "string"
          }
        }
      },
      "OutputFile": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string"
          },
          "bitrate": {
            "type": "string"
          },
          "mono": {
            "type": "boolean"
          },
          "suffix": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "download_url": {
            "type": "string"
          }
        }
      },
      "ProductionRequest": {
        "type": "object",
        "properties": {
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "preset": {
            "type": "string",
            "description": "Preset UUID"
          },
          "input_file": {
            "type": "string",
            "description": "URL to input audio file"
          },
          "output_files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OutputFile"
            }
          },
          "algorithms": {
            "$ref": "#/components/schemas/Algorithms"
          },
          "is_multitrack": {
            "type": "boolean"
          },
          "tracks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Track"
            }
          }
        }
      },
      "Metadata": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "artist": {
            "type": "string"
          },
          "album": {
            "type": "string"
          },
          "track": {
            "type": "string"
          },
          "genre": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "Algorithms": {
        "type": "object",
        "properties": {
          "normloudness": {
            "type": "boolean"
          },
          "denoise": {
            "type": "boolean"
          },
          "denoiseamount": {
            "type": "number"
          },
          "dehum": {
            "type": "boolean"
          },
          "hipfilter": {
            "type": "boolean"
          },
          "gate": {
            "type": "boolean"
          }
        }
      },
      "Track": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "input_file": {
            "type": "string"
          },
          "algorithms": {
            "$ref": "#/components/schemas/Algorithms"
          }
        }
      },
      "Production": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "status_string": {
            "type": "string"
          },
          "creation_time": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "output_files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OutputFile"
            }
          },
          "error_message": {
            "type": "string"
          }
        }
      },
      "ProductionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "status_string": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/Production"
          }
        }
      },
      "ProductionsList": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Production"
            }
          }
        }
      },
      "PresetRequest": {
        "type": "object",
        "properties": {
          "preset_name": {
            "type": "string"
          },
          "output_files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OutputFile"
            }
          },
          "algorithms": {
            "$ref": "#/components/schemas/Algorithms"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        }
      },
      "Preset": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string"
          },
          "preset_name": {
            "type": "string"
          },
          "creation_time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PresetResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "$ref": "#/components/schemas/Preset"
          }
        }
      },
      "PresetsList": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Preset"
            }
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "object",
            "properties": {
              "username": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "credits": {
                "type": "number"
              },
              "purchase_credits": {
                "type": "number"
              }
            }
          }
        }
      },
      "InfoListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Account",
      "description": "Operations related to Account"
    },
    {
      "name": "Info",
      "description": "Operations related to Info"
    },
    {
      "name": "Presets",
      "description": "Operations related to Presets"
    },
    {
      "name": "Productions",
      "description": "Operations related to Productions"
    }
  ]
}
