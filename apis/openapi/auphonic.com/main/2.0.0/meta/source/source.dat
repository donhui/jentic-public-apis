    },
    "/production/{uuid}/reset.json": {
      "post": {
        "operationId": "resetProduction",
        "tags": [
          "Productions"
        ],
        "summary": "Reset a production status",
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
