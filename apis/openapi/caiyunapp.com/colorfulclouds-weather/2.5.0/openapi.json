{
  "openapi": "3.0.3",
  "info": {
    "title": "ColorfulClouds Weather API",
    "description": "Weather API by Caiyun (ColorfulClouds) providing real-time weather data, minutely precipitation nowcasting, hourly and daily forecasts. Covers global weather data with specialized precipitation nowcasting for China and other regions. Supports multiple languages and unit systems.",
    "version": "2.5.0",
    "contact": {
      "name": "Caiyun Weather API",
      "url": "https://open.caiyunapp.com",
      "email": "api@caiyunapp.com"
    },
    "x-jentic-source-url": "https://open.caiyunapp.com/ColorfulClouds_Weather_API"
  },
  "servers": [
    {
      "url": "https://api.caiyunapp.com/v2.5",
      "description": "ColorfulClouds API v2.5 Production Server"
    }
  ],
  "security": [
    {
      "apiKeyPath": []
    }
  ],
  "tags": [
    {
      "name": "Weather",
      "description": "Comprehensive weather data including realtime, minutely, hourly, and daily forecasts"
    },
    {
      "name": "Realtime",
      "description": "Current weather conditions"
    },
    {
      "name": "Minutely",
      "description": "Minute-by-minute precipitation data"
    },
    {
      "name": "Hourly",
      "description": "Hourly weather forecast"
    },
    {
      "name": "Daily",
      "description": "Daily weather forecast"
    }
  ],
  "paths": {
    "/{token}/{longitude},{latitude}/weather.json": {
      "get": {
        "operationId": "getWeather",
        "summary": "Get comprehensive weather data",
        "description": "Returns comprehensive weather data including realtime conditions, minutely precipitation, hourly forecast, and daily forecast for the specified coordinates.",
        "tags": ["Weather"],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "description": "API token for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "longitude",
            "in": "path",
            "required": true,
            "description": "Longitude of the location",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "latitude",
            "in": "path",
            "required": true,
            "description": "Latitude of the location",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "Language for response text",
            "schema": {
              "type": "string",
              "enum": ["zh_CN", "en_US", "ja"],
              "default": "zh_CN"
            }
          },
          {
            "name": "unit",
            "in": "query",
            "required": false,
            "description": "Unit system for measurements",
            "schema": {
              "type": "string",
              "enum": ["metric", "imperial", "SI"],
              "default": "metric"
            }
          },
          {
            "name": "hourlysteps",
            "in": "query",
            "required": false,
            "description": "Number of hourly forecast steps (1-24)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 24,
              "default": 24
            }
          },
          {
            "name": "dailysteps",
            "in": "query",
            "required": false,
            "description": "Number of daily forecast steps (1-10)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 5
            }
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "description": "Optional additional data fields (e.g., 'astro' for sunrise/sunset)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with comprehensive weather data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeatherResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid coordinates or parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
