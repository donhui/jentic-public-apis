  "components": {
    "securitySchemes": {
      "apiKeyPath": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API token passed as a path segment. Note: the token is actually part of the URL path, but represented here as a path parameter for OpenAPI compatibility."
      }
    },
    "schemas": {
