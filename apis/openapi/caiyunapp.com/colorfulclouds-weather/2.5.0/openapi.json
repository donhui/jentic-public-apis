        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status"
          },
          "api_version": {
            "type": "string",
            "description": "API version"
          },
          "api_status": {
            "type": "string",
            "description": "API status"
          },
          "lang": {
            "type": "string",
