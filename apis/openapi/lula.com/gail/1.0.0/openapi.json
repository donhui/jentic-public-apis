{
  "openapi": "3.0.3",
  "info": {
    "title": "GAIL API",
    "version": "1.0.0",
    "description": "Gail's AI-powered calling platform API. Manage calls, conversations, contacts, campaigns, sequences, and more.",
    "x-jentic-source-url": "https://api.lula.com/swagger/v1/swagger.json"
  },
  "servers": [
    { "url": "https://api.lula.com/v1", "description": "Production" }
  ],
  "security": [{ "apiKey": [] }],
  "paths": {
    "/calls": {
      "post": {
        "operationId": "startCall",
        "tags": ["Calls"],
        "summary": "Start a single outbound call",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StartCallRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StartCallResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/calls/bulk": {
      "post": {
        "operationId": "bulkStartCall",
        "tags": ["Calls"],
        "summary": "Start multiple outbound calls in bulk",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkStartCallRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BulkStartCallResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/calls/{callId}/recording-url": {
      "get": {
        "operationId": "getCallRecordingUrl",
        "tags": ["Call Recordings"],
        "summary": "Get a pre-signed URL for a call recording",
        "parameters": [
          { "name": "callId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "string" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/calls/{callId}/recording": {
      "get": {
        "operationId": "downloadCallRecording",
        "tags": ["Call Recordings"],
        "summary": "Download a call recording as an audio file",
        "parameters": [
          { "name": "callId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Audio file", "content": { "audio/mpeg": { "schema": { "type": "string", "format": "binary" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/campaigns": {
      "get": {
        "operationId": "listCampaigns",
        "tags": ["Campaigns"],
        "summary": "List all campaigns",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Campaign" } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createCampaign",
        "tags": ["Campaigns"],
        "summary": "Create a new campaign",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CampaignRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/campaigns/{id}": {
      "get": {
        "operationId": "getCampaign",
        "tags": ["Campaigns"],
        "summary": "Get a campaign by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateCampaign",
        "tags": ["Campaigns"],
        "summary": "Update an existing campaign",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CampaignRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/campaigns/{id}/start": {
      "post": {
        "operationId": "startCampaign",
        "tags": ["Campaigns"],
        "summary": "Start a campaign",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/campaigns/{id}/stop": {
      "post": {
        "operationId": "stopCampaign",
        "tags": ["Campaigns"],
        "summary": "Stop a running campaign",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/campaigns/{id}/contacts": {
      "post": {
        "operationId": "addContactToCampaign",
        "tags": ["Campaigns"],
        "summary": "Add a single contact to a campaign",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddContactRequest" }
            }
          }
        },
        "responses": {
          "202": { "description": "Accepted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddContactResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/campaigns/{id}/contacts/bulk_add": {
      "post": {
        "operationId": "bulkAddContactsToCampaign",
        "tags": ["Campaigns"],
        "summary": "Add multiple contacts to a campaign in bulk",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AddContactRequest" } }
            }
          }
        },
        "responses": {
          "207": { "description": "Multi-Status" },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/campaigns/{id}/touchpoints": {
      "get": {
        "operationId": "getCampaignTouchpoints",
        "tags": ["Campaigns"],
        "summary": "Get touchpoints for a campaign",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "includeTranscripts", "in": "query", "schema": { "type": "boolean", "default": false } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedTouchpoints" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/campaigns/{id}/report": {
      "get": {
        "operationId": "getCampaignReport",
        "tags": ["Campaigns"],
        "summary": "Download a CSV report of campaign results",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "CSV report" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/audio_files": {
      "get": {
        "operationId": "listAudioFiles",
        "tags": ["Audio Files"],
        "summary": "List available audio files",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AudioFile" } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key obtained from Gail Portal under General > Integrations > API Keys"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "StartCallRequest": {
        "type": "object",
        "required": ["destination"],
        "properties": {
          "destination": { "type": "string", "description": "Phone number or contact ID" },
          "script_id": { "type": "string", "format": "uuid" },
          "extra": { "type": "object", "additionalProperties": true }
        }
      },
      "StartCallResponse": {
        "type": "object",
        "properties": {
          "callId": { "type": "string", "format": "uuid" },
          "status": { "type": "string" }
        }
      },
      "BulkStartCallRequest": {
        "type": "object",
        "properties": {
          "calls": { "type": "array", "items": { "$ref": "#/components/schemas/StartCallRequest" } }
        }
      },
      "BulkStartCallResponse": {
        "type": "object",
        "properties": {
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/StartCallResponse" } }
        }
      },
      "CampaignRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "sequences": { "type": "array", "items": { "type": "string", "format": "uuid" } },
          "contact_list_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "AddContactRequest": {
        "type": "object",
        "required": ["phone"],
        "properties": {
          "phone": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "external_id": { "type": "string" },
          "extra": { "type": "object", "additionalProperties": true }
        }
      },
      "AddContactResponse": {
        "type": "object",
        "properties": {
          "assignment_id": { "type": "string", "format": "uuid" },
          "status": { "type": "string" }
        }
      },
      "Touchpoint": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "call_id": { "type": "string", "format": "uuid" },
          "status": { "type": "string" },
          "duration": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "PaginatedTouchpoints": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/Touchpoint" } },
          "next_cursor": { "type": "string", "nullable": true },
          "total": { "type": "integer" }
        }
      },
      "AudioFile": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "url": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    }
  }
}
