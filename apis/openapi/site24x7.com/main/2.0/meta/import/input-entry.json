{
  "openapi": "3.0.3",
  "info": {
    "title": "Site24x7 API",
    "version": "2.0",
    "description": "REST API for Site24x7 website and infrastructure monitoring platform. Manage monitors, monitor groups, MSP customers, and retrieve monitoring data.",
