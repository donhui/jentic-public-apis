  "components": {
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "MonitorRequest": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string",
            "description": "Display name for the monitor"
          },
          "type": {
            "type": "string",
            "description": "Monitor type (e.g., URL, PING, etc.)"
          },
          "website": {
            "type": "string",
            "description": "URL or hostname to monitor"
          },
          "check_frequency": {
            "type": "string",
            "description": "Monitoring frequency in minutes"
          },
          "timeout": {
            "type": "integer",
            "description": "Timeout in seconds"
          },
          "location_profile_id": {
            "type": "string",
            "description": "Location profile ID"
          },
          "notification_profile_id": {
            "type": "string",
            "description": "Notification profile ID"
          },
          "threshold_profile_id": {
            "type": "string",
            "description": "Threshold profile ID"
          },
          "monitor_groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of monitor group IDs"
          }
        }
      },
      "Monitor": {
        "type": "object",
        "properties": {
          "monitor_id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "website": {
            "type": "string"
          },
          "check_frequency": {
            "type": "string"
          },
          "state": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "created_time": {
            "type": "string"
          },
          "last_polled_time": {
            "type": "string"
          }
        }
      },
      "MonitorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/Monitor"
          }
        }
      },
      "MonitorListResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Monitor"
            }
          }
        }
      },
      "MonitorGroupRequest": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string",
            "description": "Monitor group name"
          },
          "description": {
            "type": "string"
          },
          "monitors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Monitor IDs to include"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "error_code": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "zohoOAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Zoho OAuth 2.0 access token. Use the header format: Authorization: Zoho-oauthtoken {access_token}"
      }
    }
  },
  "security": [
