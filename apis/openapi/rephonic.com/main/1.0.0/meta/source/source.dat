  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Rephonic-Api-Key",
        "description": "API key obtained from your Rephonic account page"
      }
    },
    "schemas": {
      "PodcastSearchResults": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PodcastSummary"
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          }
        }
      },
      "EpisodeSearchResults": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EpisodeSummary"
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          }
        }
      },
      "AutocompleteResults": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "podcasts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PodcastSummary"
            }
          }
        }
      },
      "PodcastSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "downloads_per_episode": {
            "type": "integer"
          },
          "est_weekly_downloads": {
            "type": "integer"
          }
        }
      },
      "Podcast": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "rankings": {
            "type": "object"
          },
          "latest_episodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EpisodeSummary"
            }
          }
        }
      },
      "PodcastPeople": {
        "type": "object",
        "properties": {
          "hosts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          },
          "guests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "affiliations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "social_accounts": {
            "type": "object"
          }
        }
      },
      "PodcastDemographics": {
        "type": "object",
        "properties": {
          "age_groups": {
            "type": "object"
          },
          "gender": {
            "type": "object"
          },
          "education": {
            "type": "object"
          },
          "professions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "interests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "income": {
            "type": "object"
          },
          "geography": {
            "type": "object"
          }
        }
      },
      "PodcastPromotions": {
        "type": "object",
        "properties": {
          "sponsors": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "cross_promotions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "EpisodeList": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EpisodeSummary"
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          }
        }
      },
      "EpisodeSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "audio_url": {
            "type": "string",
            "format": "uri"
          },
          "itunes_id": {
            "type": "string"
          }
        }
      },
      "Episode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "guests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          },
          "moments": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Transcript": {
        "type": "object",
        "properties": {
          "speakers": {
            "type": "object",
            "description": "Mapping of speaker IDs to speaker names"
          },
          "segments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "speaker_id": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "Contacts": {
        "type": "object",
        "properties": {
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "format": "email"
                },
                "concierge": {
                  "type": "boolean"
                },
                "warning": {
                  "type": "boolean"
                },
                "upvotes": {
                  "type": "integer"
                },
                "downvotes": {
                  "type": "integer"
                }
              }
            }
          },
          "contact_pages": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      },
      "SocialAccounts": {
        "type": "object",
        "properties": {
          "instagram": {
            "$ref": "#/components/schemas/SocialAccount"
          },
          "facebook": {
            "$ref": "#/components/schemas/SocialAccount"
          },
          "twitter": {
            "$ref": "#/components/schemas/SocialAccount"
          },
          "patreon": {
            "$ref": "#/components/schemas/SocialAccount"
          },
          "tiktok": {
            "$ref": "#/components/schemas/SocialAccount"
          },
          "linkedin_profile": {
            "$ref": "#/components/schemas/SocialAccount"
          }
        }
      },
      "SocialAccount": {
        "type": "object",
        "properties": {
          "followers": {
            "type": "integer"
          },
          "engagement": {
            "type": "number"
          },
          "posts": {
            "type": "integer"
          },
          "likes": {
            "type": "integer"
          }
        }
      },
      "Feedback": {
        "type": "object",
        "properties": {
          "ratings": {
            "type": "object"
          },
          "review_count": {
            "type": "integer"
          },
          "review_summary": {
            "type": "string"
          }
        }
      },
      "Reviews": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "author": {
                  "type": "string"
                },
                "rating": {
                  "type": "number"
                },
                "text": {
                  "type": "string"
                },
                "date": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      },
      "Trends": {
        "type": "object",
        "description": "Historical metric trends data"
      },
      "SimilarGraph": {
        "type": "object",
        "description": "Shared audience analysis graph"
      },
      "ChartCategories": {
        "type": "object",
        "properties": {
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ChartRankings": {
        "type": "object",
        "properties": {
          "rankings": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rank": {
                  "type": "integer"
                },
                "podcast_id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CategoryList": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          }
        }
      },
      "CountryList": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          }
        }
      },
      "LanguageList": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          }
