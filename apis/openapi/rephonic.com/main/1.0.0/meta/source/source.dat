    "/api/podcasts/{id}/promotions/": {
      "get": {
        "operationId": "getPodcastPromotions",
        "summary": "Get podcast promotions",
        "description": "Returns sponsor and cross-promotion data extracted from transcripts.",
        "tags": ["Podcasts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Podcast ID",
            "required": true,
