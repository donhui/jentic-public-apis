{
  "openapi": "3.0.3",
  "info": {
    "title": "Rephonic Podcast API",
    "description": "API for discovering podcast data including metadata, audience demographics, analytics, contacts, reviews, and chart rankings.",
    "version": "1.0.0",
    "contact": {
      "name": "Rephonic",
      "url": "https://rephonic.com/developers"
    }
  },
  "servers": [
    {
      "url": "https://api.rephonic.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    { "name": "Search", "description": "Search podcasts, episodes, and autocomplete" },
    { "name": "Podcasts", "description": "Podcast metadata, people, demographics, and promotions" },
    { "name": "Episodes", "description": "Episode listing, metadata, and transcripts" },
    { "name": "Contacts", "description": "Email and social contact information" },
    { "name": "Feedback", "description": "Ratings, reviews, and feedback" },
    { "name": "Analytics", "description": "Historical trends and audience graphs" },
    { "name": "Charts", "description": "Platform chart categories and rankings" },
    { "name": "Reference", "description": "Common reference data (categories, countries, languages, etc.)" },
    { "name": "Account", "description": "API account usage and quota" }
  ],
  "paths": {
    "/api/search/podcasts/": {
      "get": {
        "operationId": "searchPodcasts",
        "summary": "Search podcasts",
        "description": "Search for podcasts by keyword query with optional filters.",
        "tags": ["Search"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query string" },
          { "name": "filters", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Filter criteria" },
          { "name": "mode", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Search mode" },
          { "$ref": "#/components/parameters/PerPage" },
          { "$ref": "#/components/parameters/Page" }
        ],
        "responses": {
          "200": {
            "description": "Successful podcast search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PodcastSearchResults"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/search/episodes/": {
      "get": {
        "operationId": "searchEpisodes",
        "summary": "Search episodes",
        "description": "Search for podcast episodes by keyword query with optional filters.",
        "tags": ["Search"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query string" },
          { "name": "filters", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Filter criteria" },
          { "$ref": "#/components/parameters/PerPage" },
          { "$ref": "#/components/parameters/Page" },
          { "name": "highlight", "in": "query", "required": false, "schema": { "type": "boolean" }, "description": "Whether to highlight matching terms in results" }
        ],
        "responses": {
          "200": {
            "description": "Successful episode search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeSearchResults"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/search/autocomplete/": {
      "get": {
        "operationId": "searchAutocomplete",
        "summary": "Keyword suggestions",
        "description": "Get autocomplete keyword suggestions for a search query.",
        "tags": ["Search"],
        "parameters": [
          { "name": "mode", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Autocomplete mode" },
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Partial query string" }
        ],
        "responses": {
          "200": {
            "description": "Autocomplete suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutocompleteResults"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/podcasts/{id}/": {
      "get": {
        "operationId": "getPodcast",
        "summary": "Get podcast metadata",
        "description": "Retrieve detailed metadata for a specific podcast by its slug ID.",
        "tags": ["Podcasts"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastId" }
        ],
        "responses": {
          "200": {
            "description": "Podcast metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Podcast"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/podcasts/{id}/people/": {
      "get": {
        "operationId": "getPodcastPeople",
        "summary": "Get hosts and guests",
        "description": "Retrieve hosts and guests associated with a podcast.",
        "tags": ["Podcasts"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastId" }
        ],
        "responses": {
          "200": {
            "description": "List of hosts and guests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PodcastPeople"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/podcasts/{id}/demographics/": {
      "get": {
        "operationId": "getPodcastDemographics",
        "summary": "Get listener demographics",
        "description": "Retrieve listener demographic data for a podcast.",
        "tags": ["Podcasts"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastId" }
        ],
        "responses": {
          "200": {
            "description": "Listener demographics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Demographics"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/podcasts/{id}/promotions/": {
      "get": {
        "operationId": "getPodcastPromotions",
        "summary": "Get sponsors and cross-promotions",
        "description": "Retrieve sponsors and cross-promotion data for a podcast.",
        "tags": ["Podcasts"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastId" }
        ],
        "responses": {
          "200": {
            "description": "Sponsors and cross-promotions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Promotions"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/episodes/": {
      "get": {
        "operationId": "listEpisodes",
        "summary": "List episodes",
        "description": "List episodes for a podcast with optional search and pagination.",
        "tags": ["Episodes"],
        "parameters": [
          { "name": "podcast_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Podcast ID to list episodes for" },
          { "name": "query", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Optional search query within episodes" },
          { "$ref": "#/components/parameters/PerPage" },
          { "$ref": "#/components/parameters/Page" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of episodes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeList"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/episodes/{id}/": {
      "get": {
        "operationId": "getEpisode",
        "summary": "Get episode metadata",
        "description": "Retrieve detailed metadata for a specific episode.",
        "tags": ["Episodes"],
        "parameters": [
          { "$ref": "#/components/parameters/EpisodeId" }
        ],
        "responses": {
          "200": {
            "description": "Episode metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Episode"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/episodes/{id}/transcript/": {
      "get": {
        "operationId": "getEpisodeTranscript",
        "summary": "Get episode transcript",
        "description": "Retrieve the transcript for an episode, including speaker identification.",
        "tags": ["Episodes"],
        "parameters": [
          { "$ref": "#/components/parameters/EpisodeId" }
        ],
        "responses": {
          "200": {
            "description": "Episode transcript with speaker IDs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transcript"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/contacts/": {
      "get": {
        "operationId": "getContacts",
        "summary": "Get email and social contacts",
        "description": "Retrieve email and social contact information for a podcast.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastIdQuery" }
        ],
        "responses": {
          "200": {
            "description": "Contact information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contacts"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/social/accounts/": {
      "get": {
        "operationId": "getSocialAccounts",
        "summary": "Get linked social accounts",
        "description": "Retrieve social media accounts linked to a podcast.",
        "tags": ["Contacts"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastIdQuery" }
        ],
        "responses": {
          "200": {
            "description": "Linked social accounts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SocialAccounts"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/feedback/": {
      "get": {
        "operationId": "getFeedback",
        "summary": "Get ratings and reviews summary",
        "description": "Retrieve a summary of ratings and reviews for a podcast.",
        "tags": ["Feedback"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastIdQuery" }
        ],
        "responses": {
          "200": {
            "description": "Ratings and reviews summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedbackSummary"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/reviews/": {
      "get": {
        "operationId": "getReviews",
        "summary": "Get chronological reviews",
        "description": "Retrieve chronological reviews for a podcast, optionally filtered by platform.",
        "tags": ["Feedback"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastIdQuery" },
          { "name": "platform", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Filter reviews by platform" }
        ],
        "responses": {
          "200": {
            "description": "List of reviews",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewList"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/trends/": {
      "get": {
        "operationId": "getTrends",
        "summary": "Get historical metrics trends",
        "description": "Retrieve historical trend data for one or more podcasts across specified metrics.",
        "tags": ["Analytics"],
        "parameters": [
          { "name": "podcast_ids", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Comma-separated list of podcast IDs" },
          { "name": "metrics", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Comma-separated list of metric names" }
        ],
        "responses": {
          "200": {
            "description": "Historical trend data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Trends"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/similar/graph/": {
      "get": {
        "operationId": "getSimilarGraph",
        "summary": "Get shared audience graph",
        "description": "Retrieve a graph of podcasts with shared audiences.",
        "tags": ["Analytics"],
        "parameters": [
          { "$ref": "#/components/parameters/PodcastIdQuery" }
        ],
        "responses": {
          "200": {
            "description": "Shared audience graph data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AudienceGraph"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/charts/{platform}/": {
      "get": {
        "operationId": "getChartCategories",
        "summary": "Get chart categories and countries",
        "description": "Retrieve available chart categories and countries for a given platform.",
        "tags": ["Charts"],
        "parameters": [
          { "$ref": "#/components/parameters/Platform" }
        ],
        "responses": {
          "200": {
            "description": "Chart categories and countries for the platform",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChartMeta"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/charts/{platform}/{country}/{category}/": {
      "get": {
        "operationId": "getChartRankings",
        "summary": "Get chart rankings",
        "description": "Retrieve podcast chart rankings for a specific platform, country, and category.",
        "tags": ["Charts"],
        "parameters": [
          { "$ref": "#/components/parameters/Platform" },
          { "name": "country", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Country code" },
          { "name": "category", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Chart category identifier" }
        ],
        "responses": {
          "200": {
            "description": "Chart rankings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChartRankings"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/common/categories/": {
      "get": {
        "operationId": "getCategories",
        "summary": "Get podcast categories",
        "description": "Retrieve the list of available podcast categories.",
        "tags": ["Reference"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of categories",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReferenceList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/common/countries/": {
      "get": {
        "operationId": "getCountries",
        "summary": "Get countries",
        "description": "Retrieve the list of available countries.",
        "tags": ["Reference"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of countries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReferenceList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/common/languages/": {
      "get": {
        "operationId": "getLanguages",
        "summary": "Get languages",
        "description": "Retrieve the list of available languages.",
        "tags": ["Reference"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of languages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReferenceList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/common/sponsors/": {
      "get": {
        "operationId": "getSponsors",
        "summary": "Get common sponsors",
        "description": "Retrieve a list of common podcast sponsors, optionally filtered by query.",
        "tags": ["Reference"],
        "parameters": [
          { "$ref": "#/components/parameters/OptionalQuery" }
        ],
        "responses": {
          "200": {
            "description": "List of sponsors",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReferenceList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/common/professions/": {
      "get": {
        "operationId": "getProfessions",
        "summary": "Get listener professions",
        "description": "Retrieve a list of listener professions, optionally filtered by query.",
        "tags": ["Reference"],
        "parameters": [
          { "$ref": "#/components/parameters/OptionalQuery" }
        ],
        "responses": {
          "200": {
            "description": "List of professions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReferenceList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/common/interests/": {
      "get": {
        "operationId": "getInterests",
        "summary": "Get listener interests",
        "description": "Retrieve a list of listener interests, optionally filtered by query.",
        "tags": ["Reference"],
        "parameters": [
          { "$ref": "#/components/parameters/OptionalQuery" }
        ],
        "responses": {
          "200": {
            "description": "List of interests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReferenceList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/accounts/quota/": {
      "get": {
        "operationId": "getQuota",
        "summary": "Get API usage and quota",
        "description": "Retrieve current API usage statistics and remaining quota.",
        "tags": ["Account"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "API usage and quota information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quota"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Rephonic-Api-Key",
        "description": "API key for authenticating requests to the Rephonic API."
      }
    },
    "parameters": {
      "PodcastId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Podcast slug identifier"
      },
      "EpisodeId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Episode identifier"
      },
      "PodcastIdQuery": {
        "name": "podcast_id",
        "in": "query",
        "required": true,
        "schema": { "type": "string" },
        "description": "Podcast identifier"
      },
      "Platform": {
        "name": "platform",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "enum": ["apple", "spotify", "youtube"]
        },
        "description": "Chart platform"
      },
      "PerPage": {
        "name": "per_page",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "default": 20 },
        "description": "Number of results per page"
      },
      "Page": {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "default": 1 },
        "description": "Page number"
      },
      "OptionalQuery": {
        "name": "query",
        "in": "query",
        "required": false,
        "schema": { "type": "string" },
        "description": "Optional search query to filter results"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid or missing parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing or invalid API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "Human-readable error message"
          }
        },
        "required": ["detail"]
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "description": "Current page number" },
          "per_page": { "type": "integer", "description": "Results per page" },
          "total": { "type": "integer", "description": "Total number of results" }
        }
      },
      "PodcastSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Podcast slug identifier" },
          "title": { "type": "string", "description": "Podcast title" },
          "description": { "type": "string", "description": "Short description" },
          "image_url": { "type": "string", "format": "uri", "description": "Podcast artwork URL" },
          "language": { "type": "string", "description": "Primary language" },
          "categories": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Category names"
          }
        }
      },
      "Podcast": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Podcast slug identifier" },
          "title": { "type": "string", "description": "Podcast title" },
          "description": { "type": "string", "description": "Full description" },
          "image_url": { "type": "string", "format": "uri", "description": "Podcast artwork URL" },
          "website_url": { "type": "string", "format": "uri", "description": "Podcast website" },
          "language": { "type": "string", "description": "Primary language" },
          "categories": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Category names"
          },
          "total_episodes": { "type": "integer", "description": "Total episode count" },
          "frequency": { "type": "string", "description": "Publishing frequency" },
          "latest_episode_date": { "type": "string", "format": "date", "description": "Date of most recent episode" },
          "average_duration_seconds": { "type": "integer", "description": "Average episode duration in seconds" },
          "global_rank": { "type": "integer", "nullable": true, "description": "Global popularity rank" }
        }
      },
      "PodcastSearchResults": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PodcastSummary" }
          },
          "pagination": { "$ref": "#/components/schemas/Pagination" }
        }
      },
      "EpisodeSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Episode identifier" },
          "title": { "type": "string", "description": "Episode title" },
          "description": { "type": "string", "description": "Episode description" },
          "published_at": { "type": "string", "format": "date-time", "description": "Publication date" },
          "duration_seconds": { "type": "integer", "description": "Duration in seconds" },
          "podcast_id": { "type": "string", "description": "Parent podcast ID" }
        }
      },
      "Episode": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Episode identifier" },
          "title": { "type": "string", "description": "Episode title" },
          "description": { "type": "string", "description": "Full episode description" },
          "published_at": { "type": "string", "format": "date-time", "description": "Publication date" },
          "duration_seconds": { "type": "integer", "description": "Duration in seconds" },
          "audio_url": { "type": "string", "format": "uri", "description": "Audio file URL" },
          "podcast_id": { "type": "string", "description": "Parent podcast ID" },
          "podcast_title": { "type": "string", "description": "Parent podcast title" },
          "season": { "type": "integer", "nullable": true, "description": "Season number" },
          "episode_number": { "type": "integer", "nullable": true, "description": "Episode number" }
        }
      },
      "EpisodeSearchResults": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EpisodeSummary" }
          },
          "pagination": { "$ref": "#/components/schemas/Pagination" }
        }
      },
      "EpisodeList": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EpisodeSummary" }
          },
          "pagination": { "$ref": "#/components/schemas/Pagination" }
        }
      },
      "AutocompleteResults": {
        "type": "object",
        "properties": {
          "suggestions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": { "type": "string", "description": "Suggested keyword" },
                "type": { "type": "string", "description": "Suggestion type" }
              }
            }
          }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Person name" },
          "role": { "type": "string", "description": "Role (host or guest)" },
          "episode_count": { "type": "integer", "description": "Number of episodes appeared in" },
          "image_url": { "type": "string", "format": "uri", "nullable": true, "description": "Profile image URL" }
        }
      },
      "PodcastPeople": {
        "type": "object",
        "properties": {
          "hosts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Person" }
          },
          "guests": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Person" }
          }
        }
      },
      "Demographics": {
        "type": "object",
        "properties": {
          "age_ranges": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "range": { "type": "string", "description": "Age range label" },
                "percentage": { "type": "number", "format": "float", "description": "Percentage of listeners" }
              }
            }
          },
          "gender": {
            "type": "object",
            "properties": {
              "male": { "type": "number", "format": "float" },
              "female": { "type": "number", "format": "float" },
              "other": { "type": "number", "format": "float" }
            }
          },
          "top_countries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "country": { "type": "string" },
                "percentage": { "type": "number", "format": "float" }
              }
            }
          },
          "interests": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Top listener interests"
          },
          "professions": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Top listener professions"
          }
        }
      },
      "Promotions": {
        "type": "object",
        "properties": {
          "sponsors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "description": "Sponsor name" },
                "url": { "type": "string", "format": "uri", "nullable": true, "description": "Sponsor website" },
                "episode_count": { "type": "integer", "description": "Number of sponsored episodes" }
              }
            }
          },
          "cross_promotions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "podcast_id": { "type": "string", "description": "Cross-promoted podcast ID" },
                "podcast_title": { "type": "string", "description": "Cross-promoted podcast title" },
                "direction": { "type": "string", "description": "Promotion direction (inbound or outbound)" }
              }
            }
          }
        }
      },
      "TranscriptSegment": {
        "type": "object",
        "properties": {
          "speaker_id": { "type": "string", "description": "Speaker identifier" },
          "speaker_name": { "type": "string", "nullable": true, "description": "Speaker name if identified" },
          "start_time": { "type": "number", "format": "float", "description": "Start time in seconds" },
          "end_time": { "type": "number", "format": "float", "description": "End time in seconds" },
          "text": { "type": "string", "description": "Transcript text" }
        }
      },
      "Transcript": {
        "type": "object",
        "properties": {
          "episode_id": { "type": "string", "description": "Episode identifier" },
          "segments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TranscriptSegment" }
          }
        }
      },
      "Contacts": {
        "type": "object",
        "properties": {
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "address": { "type": "string", "format": "email", "description": "Email address" },
                "type": { "type": "string", "description": "Contact type (e.g., general, booking)" }
              }
            }
          },
          "social_links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "platform": { "type": "string", "description": "Social platform name" },
                "url": { "type": "string", "format": "uri", "description": "Profile URL" }
              }
            }
          }
        }
      },
      "SocialAccounts": {
        "type": "object",
        "properties": {
          "accounts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "platform": { "type": "string", "description": "Platform name" },
                "username": { "type": "string", "description": "Account username" },
                "url": { "type": "string", "format": "uri", "description": "Account URL" },
                "followers": { "type": "integer", "nullable": true, "description": "Follower count" }
              }
            }
          }
        }
      },
      "FeedbackSummary": {
        "type": "object",
        "properties": {
          "average_rating": { "type": "number", "format": "float", "description": "Average rating across platforms" },
          "total_ratings": { "type": "integer", "description": "Total number of ratings" },
          "total_reviews": { "type": "integer", "description": "Total number of text reviews" },
          "platforms": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "platform": { "type": "string" },
                "average_rating": { "type": "number", "format": "float" },
                "rating_count": { "type": "integer" }
              }
            }
          }
        }
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Review identifier" },
          "platform": { "type": "string", "description": "Source platform" },
          "author": { "type": "string", "description": "Reviewer name" },
          "rating": { "type": "integer", "description": "Rating value" },
          "title": { "type": "string", "nullable": true, "description": "Review title" },
          "body": { "type": "string", "description": "Review text" },
          "date": { "type": "string", "format": "date", "description": "Review date" }
        }
      },
      "ReviewList": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Review" }
          }
        }
      },
      "Trends": {
        "type": "object",
        "properties": {
          "podcast_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "metrics": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "date": { "type": "string", "format": "date" },
                  "value": { "type": "number" }
                }
              }
            },
            "description": "Metric name mapped to time-series data points"
          }
        }
      },
      "AudienceGraph": {
        "type": "object",
        "properties": {
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string", "description": "Podcast ID" },
                "title": { "type": "string", "description": "Podcast title" },
                "score": { "type": "number", "format": "float", "description": "Similarity score" }
              }
            }
          },
          "edges": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source": { "type": "string", "description": "Source podcast ID" },
                "target": { "type": "string", "description": "Target podcast ID" },
                "weight": { "type": "number", "format": "float", "description": "Edge weight (audience overlap)" }
              }
            }
          }
        }
      },
      "ChartMeta": {
        "type": "object",
        "properties": {
          "platform": { "type": "string", "description": "Platform name" },
          "countries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "name": { "type": "string" }
              }
            }
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" }
              }
            }
          }
        }
      },
      "ChartRankings": {
        "type": "object",
        "properties": {
          "platform": { "type": "string" },
          "country": { "type": "string" },
          "category": { "type": "string" },
          "updated_at": { "type": "string", "format": "date-time" },
          "rankings": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rank": { "type": "integer" },
                "podcast_id": { "type": "string" },
                "title": { "type": "string" },
                "movement": { "type": "integer", "description": "Rank change since last update" }
              }
            }
          }
        }
      },
      "ReferenceItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Item identifier" },
          "name": { "type": "string", "description": "Display name" }
        }
      },
      "ReferenceList": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ReferenceItem" }
          }
        }
      },
      "Quota": {
        "type": "object",
        "properties": {
          "plan": { "type": "string", "description": "Current plan name" },
          "requests_used": { "type": "integer", "description": "Requests used in current period" },
          "requests_limit": { "type": "integer", "description": "Total requests allowed in current period" },
          "requests_remaining": { "type": "integer", "description": "Remaining requests" },
          "period_start": { "type": "string", "format": "date-time", "description": "Current billing period start" },
          "period_end": { "type": "string", "format": "date-time", "description": "Current billing period end" }
        }
      }
    }
  }
}