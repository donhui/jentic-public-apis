{
  "openapi": "3.0.3",
  "info": {
    "title": "Rephonic Podcast API",
    "description": "Rephonic's Podcast API provides comprehensive podcast data including search, demographics, social metrics, episode transcripts, charts, and audience analytics.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://rephonic.com/developers"
  },
  "servers": [
    {
      "url": "https://api.rephonic.com"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Search",
      "description": "Search for podcasts and episodes"
    },
    {
      "name": "Podcasts",
      "description": "Podcast metadata and analytics"
    },
    {
      "name": "Episodes",
      "description": "Episode data and transcripts"
    },
    {
      "name": "Social",
      "description": "Social media and engagement data"
    },
    {
      "name": "Charts",
      "description": "Podcast chart rankings"
    },
    {
      "name": "Reference",
      "description": "Reference data (categories, countries, languages)"
    },
    {
      "name": "Account",
      "description": "Account and quota management"
    }
  ],
  "paths": {
    "/api/search/podcasts/": {
      "get": {
        "operationId": "searchPodcasts",
        "summary": "Search for podcasts",
        "description": "Search for podcasts with listener estimates. Supports topic-based and keyword-based search modes with filtering.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search query string",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "description": "Search mode",
            "required": false,
            "schema": {
              "type": "string",
              "default": "topics"
            }
          },
          {
            "name": "topics",
            "in": "query",
            "description": "Topic filter",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "filters",
            "in": "query",
            "description": "Additional filters",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results with podcast data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PodcastSearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/search/episodes/": {
      "get": {
        "operationId": "searchEpisodes",
        "summary": "Search for episodes",
        "description": "Search for episodes by content with optional filtering and highlighting.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search query string",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "filters",
            "in": "query",
            "description": "Additional filters",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "highlight",
            "in": "query",
            "description": "Enable search term highlighting",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "podcast_id",
            "in": "query",
            "description": "Filter by podcast ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "threshold",
            "in": "query",
            "description": "Relevance threshold",
            "required": false,
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results with episode data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeSearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/search/autocomplete/": {
      "get": {
        "operationId": "searchAutocomplete",
        "summary": "Autocomplete search",
        "description": "Returns suggested keywords and matching podcasts for autocomplete.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Partial search query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "description": "Search mode",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Autocomplete suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutocompleteResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/podcasts/{id}/": {
      "get": {
        "operationId": "getPodcast",
        "summary": "Get podcast details",
        "description": "Returns individual podcast metadata, rankings, and latest episodes.",
        "tags": ["Podcasts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Podcast ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Podcast details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Podcast"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/podcasts/{id}/people/": {
      "get": {
        "operationId": "getPodcastPeople",
        "summary": "Get podcast people",
        "description": "Returns hosts, guests with names, descriptions, affiliations, contact info, and social accounts.",
