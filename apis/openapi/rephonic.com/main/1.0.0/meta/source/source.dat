    "/api/similar/graph/": {
      "get": {
        "operationId": "getSimilarGraph",
        "summary": "Get shared audience graph",
        "description": "Returns shared audience analysis for a podcast.",
        "tags": ["Podcasts"],
        "parameters": [
          {
            "name": "podcast_id",
            "in": "query",
            "description": "Podcast ID",
