    "/api/trends/": {
      "get": {
        "operationId": "getTrends",
        "summary": "Get podcast trends",
        "description": "Returns historical metric trends over time for specified podcasts.",
        "tags": ["Podcasts"],
        "parameters": [
          {
            "name": "podcast_ids",
            "in": "query",
