      }
    },
    "/api/episodes/": {
      "get": {
        "operationId": "listEpisodes",
        "summary": "List episodes",
        "description": "Returns episodes for a podcast in chronological order.",
        "tags": ["Episodes"],
        "parameters": [
          {
            "name": "podcast_id",
            "in": "query",
            "description": "Podcast ID to filter episodes",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "description": "Search within episodes",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of episodes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/episodes/{id}/": {
      "get": {
        "operationId": "getEpisode",
        "summary": "Get episode details",
        "description": "Returns individual episode metadata including topics, locations, guests, and moments.",
        "tags": ["Episodes"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Episode ID",
            "required": true,
