    "/api/charts/{platform}/": {
      "get": {
        "operationId": "getChartCategories",
        "summary": "Get chart categories",
        "description": "Returns available chart categories and countries for a platform.",
        "tags": ["Charts"],
        "parameters": [
          {
            "name": "platform",
            "in": "path",
            "description": "Platform (apple, spotify, or youtube)",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["apple", "spotify", "youtube"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chart categories and countries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChartCategories"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/charts/{platform}/{country}/{category}/": {
      "get": {
        "operationId": "getChartRankings",
        "summary": "Get chart rankings",
        "description": "Returns latest 24-hour updated chart rankings.",
        "tags": ["Charts"],
        "parameters": [
          {
            "name": "platform",
            "in": "path",
            "description": "Platform (apple, spotify, or youtube)",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["apple", "spotify", "youtube"]
            }
          },
          {
            "name": "country",
            "in": "path",
            "description": "Country code",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "path",
            "description": "Chart category",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chart rankings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChartRankings"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
