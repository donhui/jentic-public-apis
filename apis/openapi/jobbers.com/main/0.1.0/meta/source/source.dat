{
  "openapi": "3.0.3",
  "info": {
    "title": "Jobbers OneAPI",
    "description": "Jobbers OneAPI provides REST endpoints for managing clients, passes, conversations, messages, webhooks, tags, and box-client locations for the Jobbers platform.",
    "version": "0.1.0",
    "x-jentic-source-url": "https://www.jobbers.com/restoneapi/docs/index.html"
  },
  "servers": [
    {
      "url": "https://www.jobbers.com",
      "description": "Jobbers Production API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "Authentication", "description": "Token-based authentication"},
    {"name": "Echo", "description": "Testing endpoints"},
    {"name": "Enterprise", "description": "Enterprise and statistics management"},
    {"name": "Passes", "description": "Pass stock management"},
    {"name": "Clients", "description": "Client management"},
    {"name": "Conversations", "description": "Conversation management"},
    {"name": "Messages", "description": "Message and attachment management"},
    {"name": "Webhooks", "description": "Webhook management for notifications"},
    {"name": "Tags", "description": "Tag management for boxes"},
    {"name": "Box Client Location", "description": "Client-location relationship management"}
  ],
  "paths": {
    "/oneapi/authentication/token": {
      "post": {
        "operationId": "getAccessToken",
        "tags": ["Authentication"],
        "summary": "Get access token",
        "description": "Authenticate using API credentials to obtain a bearer token.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["apiKey", "apiSecret"],
                "properties": {
                  "apiKey": {
                    "type": "string",
                    "description": "API key"
                  },
                  "apiSecret": {
                    "type": "string",
                    "description": "API secret"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/oneapi/v0/current": {
      "get": {
        "operationId": "getCurrentEntity",
        "tags": ["Authentication"],
        "summary": "Get current authenticated entity",
        "description": "Retrieve information about the currently authenticated entity.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/echo/{text}": {
      "get": {
        "operationId": "echoGet",
        "tags": ["Echo"],
        "summary": "Echo text (GET)",
        "description": "Echo back the text parameter for testing purposes.",
        "parameters": [
          {
            "name": "text",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Text to echo back"
          }
        ],
        "responses": {
          "200": {
            "description": "Echoed text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "echo": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/echo": {
      "post": {
        "operationId": "echoPost",
        "tags": ["Echo"],
        "summary": "Echo text (POST)",
        "description": "Echo back the JSON payload text field for testing purposes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Echoed text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "echo": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/groupsofenterprises": {
      "get": {
        "operationId": "getGroupsOfEnterprises",
        "tags": ["Enterprise"],
        "summary": "Get enterprise groups",
        "description": "Retrieve enterprise groups.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/stats": {
      "get": {
        "operationId": "getStats",
        "tags": ["Enterprise"],
        "summary": "Get usage statistics",
        "description": "Get usage statistics for a specified period.",
        "parameters": [
          {
            "name": "month",
            "in": "query",
            "required": true,
            "schema": {"type": "integer", "minimum": 1, "maximum": 12},
            "description": "Month number (1-12)"
          },
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": {"type": "integer"},
            "description": "Year (e.g., 2024)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/stockofpasses": {
      "get": {
        "operationId": "getStockOfPasses",
        "tags": ["Passes"],
        "summary": "List available pass stocks",
        "description": "List all available pass stocks.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/stockofpasses/assign": {
      "post": {
        "operationId": "assignPass",
        "tags": ["Passes"],
        "summary": "Assign pass to client",
        "description": "Assign a pass from stock to a client.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "clientId": {"type": "string"},
                  "passId": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pass assigned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/stockofpasses/invoice": {
      "post": {
        "operationId": "generatePassInvoice",
        "tags": ["Passes"],
        "summary": "Generate pass assignment invoice",
        "description": "Generate an invoice for a pass assignment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "clientId": {"type": "string", "description": "Client identifier"},
                  "passId": {"type": "string", "description": "Pass identifier"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invoice generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/oneapi/v0/clients/{clientIdOrClientEmail}/exists": {
      "get": {
        "operationId": "checkClientExists",
        "tags": ["Clients"],
        "summary": "Check if client exists",
        "description": "Check if a client exists by ID or email.",
        "parameters": [
          {"$ref": "#/components/parameters/clientIdOrClientEmail"}
        ],
        "responses": {
          "200": {
            "description": "Client existence check result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "exists": {"type": "boolean"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/clients/{clientIdOrClientEmail}": {
      "get": {
        "operationId": "getClient",
        "tags": ["Clients"],
        "summary": "Get client details",
        "description": "Retrieve client details by ID or email.",
        "parameters": [
          {"$ref": "#/components/parameters/clientIdOrClientEmail"}
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "updateClient",
        "tags": ["Clients"],
        "summary": "Update client",
        "description": "Update an existing client by ID or email.",
        "parameters": [
          {"$ref": "#/components/parameters/clientIdOrClientEmail"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Client updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteClient",
        "tags": ["Clients"],
        "summary": "Delete client",
        "description": "Delete a client by ID or email.",
        "parameters": [
          {"$ref": "#/components/parameters/clientIdOrClientEmail"}
        ],
        "responses": {
          "200": {
            "description": "Client deleted"
          }
        }
      }
    },
    "/oneapi/v0/clients": {
      "post": {
        "operationId": "createClient",
        "tags": ["Clients"],
        "summary": "Create client",
        "description": "Create a new client.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Client created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          }
        }
      }
    },
    "/oneapi/v0/clients/{clientIdOrClientEmail}/login": {
      "get": {
        "operationId": "getClientAutoLoginToken",
        "tags": ["Clients"],
        "summary": "Generate autologin token",
        "description": "Generate an autologin token for a client.",
        "parameters": [
          {"$ref": "#/components/parameters/clientIdOrClientEmail"}
        ],
        "responses": {
          "200": {
            "description": "Autologin token generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/conversations": {
      "post": {
        "operationId": "createConversation",
        "tags": ["Conversations"],
        "summary": "Create conversation",
        "description": "Create a new conversation.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConversationInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Conversation created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conversation"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "getConversations",
        "tags": ["Conversations"],
        "summary": "Get conversations",
        "description": "Retrieve conversations filtered by client and status.",
        "parameters": [
          {
            "name": "clientId",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Client identifier"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Conversation status filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Conversation"
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateConversation",
        "tags": ["Conversations"],
        "summary": "Update conversation",
        "description": "Update a conversation's subject, status, or rating.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {"type": "string"},
                  "subject": {"type": "string"},
                  "status": {"type": "string"},
                  "rating": {"type": "integer"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversation updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conversation"
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/conversations/{id_conversation}/messages": {
      "post": {
        "operationId": "createMessage",
        "tags": ["Messages"],
        "summary": "Create message",
        "description": "Create a new message in a conversation.",
        "parameters": [
          {"$ref": "#/components/parameters/conversationId"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {"type": "string"},
                  "author": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "getMessages",
        "tags": ["Messages"],
        "summary": "Get messages",
        "description": "Retrieve messages in a conversation.",
        "parameters": [
          {"$ref": "#/components/parameters/conversationId"},
          {
            "name": "size",
            "in": "query",
            "schema": {"type": "integer"},
            "description": "Number of messages to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Message"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/conversations/{id_conversation}/attachments": {
      "post": {
        "operationId": "uploadAttachment",
        "tags": ["Messages"],
        "summary": "Upload file attachment",
        "description": "Upload a file attachment to a conversation.",
        "parameters": [
          {"$ref": "#/components/parameters/conversationId"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attachment uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/webhooks": {
      "post": {
        "operationId": "createWebhook",
        "tags": ["Webhooks"],
        "summary": "Create message webhook",
        "description": "Create a message notification webhook.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "getWebhooks",
        "tags": ["Webhooks"],
        "summary": "List webhooks",
        "description": "List all message notification webhooks.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Webhook"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/webhooks/{id_webhook}": {
      "delete": {
        "operationId": "deleteWebhook",
        "tags": ["Webhooks"],
        "summary": "Delete webhook",
        "description": "Delete a message notification webhook.",
        "parameters": [
          {"$ref": "#/components/parameters/webhookId"}
        ],
        "responses": {
          "200": {
            "description": "Webhook deleted"
          }
        }
      }
    },
    "/api/v0/boxes_webhook": {
      "post": {
        "operationId": "createBoxWebhook",
        "tags": ["Webhooks"],
        "summary": "Create box webhook",
        "description": "Create a box notification webhook.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Box webhook created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "getBoxWebhooks",
        "tags": ["Webhooks"],
        "summary": "List box webhooks",
        "description": "List all box notification webhooks.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Webhook"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/boxes_webhook/{id_webhook}": {
      "delete": {
        "operationId": "deleteBoxWebhook",
        "tags": ["Webhooks"],
        "summary": "Delete box webhook",
        "description": "Delete a box notification webhook.",
        "parameters": [
          {"$ref": "#/components/parameters/webhookId"}
        ],
        "responses": {
          "200": {
            "description": "Box webhook deleted"
          }
        }
      }
    },
    "/api/v0/boxes_tags": {
      "post": {
        "operationId": "createTags",
        "tags": ["Tags"],
        "summary": "Create tags",
        "description": "Create tags for boxes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tags": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tags created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteTags",
        "tags": ["Tags"],
        "summary": "Delete tags",
        "description": "Delete tags from boxes.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tags": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags deleted"
          }
        }
      }
    },
    "/api/v0/boxes_disconnect_tags": {
      "post": {
        "operationId": "disconnectTags",
        "tags": ["Tags"],
        "summary": "Disconnect tags",
        "description": "Disconnect tags from boxes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tags": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags disconnected"
          }
        }
      }
    },
    "/api/v0/boxes_client_location": {
      "post": {
        "operationId": "createClientLocation",
        "tags": ["Box Client Location"],
        "summary": "Create client-location relationship",
        "description": "Create a client-location relationship for a box.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "clientId": {"type": "string"},
                  "locationId": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Client-location relationship created"
          }
        }
      },
      "delete": {
        "operationId": "deleteClientLocation",
        "tags": ["Box Client Location"],
        "summary": "Delete client-location relationship",
        "description": "Delete a client-location relationship.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "clientId": {"type": "string"},
                  "locationId": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Client-location relationship deleted"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained from /oneapi/authentication/token"
      }
    },
    "parameters": {
      "clientIdOrClientEmail": {
        "name": "clientIdOrClientEmail",
        "in": "path",
        "required": true,
        "schema": {"type": "string"},
        "description": "Client ID or client email address"
      },
      "conversationId": {
        "name": "id_conversation",
        "in": "path",
        "required": true,
        "schema": {"type": "string"},
        "description": "Conversation identifier"
      },
      "webhookId": {
        "name": "id_webhook",
        "in": "path",
        "required": true,
        "schema": {"type": "string"},
        "description": "Webhook identifier"
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {"type": "string", "description": "Bearer access token"},
          "token_type": {"type": "string"},
          "expires_in": {"type": "integer"}
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "email": {"type": "string", "format": "email"},
          "firstName": {"type": "string"},
          "lastName": {"type": "string"},
          "phone": {"type": "string"},
          "address": {"type": "string"},
          "city": {"type": "string"},
          "zipCode": {"type": "string"},
          "country": {"type": "string"}
        }
