{
    "openapi": "3.0.0",
    "info": {
        "version": "1.0.0",
        "title": "Accounts API",
        "description": "To gather and provide information relating to customer accounts",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/Hackney/accountsApi/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "Accounts API",
            "description": "Retrieve account details"
        },
        {
            "name": "Production",
            "description": "This API is available in the Production environment"
        },
        {
            "name": "Staging",
            "description": "This API is available in the Staging environment"
        },
        {
            "name": "Development",
            "description": "This API is available in the Development environment"
        }
    ],
    "paths": {
        "/accounts": {
            "get": {
                "description": "Gets a collection of accounts for a person or organisation",
                "parameters": [
                    {
                        "in": "query",
                        "name": "targetId",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "type",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully retrieved a collection of accounts",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/getAccounts"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid query parameters supplied"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            },
            "post": {
                "description": "Creates a new account for a person",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/createAccountDetails"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Successfully created account"
                    },
                    "400": {
                        "description": "Invalid account object provided"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
        "/accounts/arrears": {
            "get": {
                "description": "Gets a collection of accounts that are in arrears",
                "parameters": [
                    {
                        "in": "query",
                        "name": "type",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "sort",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "direction",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "resultsCount",
                        "schema": {
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully retrieved a collection of accounts",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/getAccounts"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid query parameters supplied"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
        "/accounts/{id}": {
            "get": {
                "description": "Gets a single account record from the supplied id",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successfully retrieved details for a particular account",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/getAccountDetails"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid account id provided"
                    },
                    "404": {
                        "description": "Account not found for id requested"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            },
            "put": {
                "description": "Creates a new account for a person",
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/updateAccountDetails"
                            }
                        }
                    }
                },
                "responses": {
                    "204": {
                        "description": "Account has been updated"
                    },
                    "400": {
                        "description": "Invalid account object provided"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/Hackney/accountsApi/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "createAccountDetails": {
                "type": "object",
                "properties": {
                    "targetType": {
                        "type": "string"
                    },
                    "targetId": {
                        "type": "string",
                        "description": "id for an account"
                    },
                    "accountType": {
                        "type": "string",
                        "description": "Recharge, Master, etc"
                    },
                    "rentGroupType": {
                        "type": "string",
                        "description": "Major Works, etc"
                    },
                    "agreementType": {
                        "type": "string"
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "accountStatus": {
                        "type": "string",
                        "enum": [
                            "active",
                            "suspended",
                            "ended"
                        ]
                    }
                }
            },
            "updateAccountDetails": {
                "type": "object",
                "properties": {
                    "accountBalance": {
                        "type": "number",
                        "format": "double",
                        "multipleOf": 0.01
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "endDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "accountStatus": {
                        "type": "string",
                        "enum": [
                            "active",
                            "suspended",
                            "ended"
                        ]
                    },
                    "accountType": {
                        "type": "string",
                        "description": "Recharge, Master, etc"
                    },
                    "rentGroupType": {
                        "type": "string",
                        "description": "Major Works, etc"
                    },
                    "agreementType": {
                        "type": "string"
                    },
                    "consolidatedCharges": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/consolidatedCharge"
                        }
                    },
                    "tenure": {
                        "type": "object",
                        "description": "basic information on the tenure associated with this account",
                        "properties": {
                            "tenancyId": {
                                "type": "string",
                                "format": "GUID",
                                "description": "the id of the tenancy"
                            },
                            "tenancyType": {
                                "type": "string",
                                "description": "the type of tenancy"
                            },
                            "primaryTenants": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/primaryTenant"
                                }
                            },
                            "fullAddress": {
                                "type": "string",
                                "description": "the full address of the tenancy",
                                "example": "1 Hillman Street, Hackney, E8 1DY"
                            }
                        }
                    }
                }
            },
            "getAccountDetails": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "GUID",
                        "example": "6506743f-a137-4e49-a4fa-0e6ed6957393",
                        "description": "id for an account"
                    },
                    "paymentReference": {
                        "type": "string",
                        "description": "the payment reference for the account"
                    },
                    "parentAccount": {
                        "type": "string",
                        "format": "GUID",
                        "example": "21d89cab-96ce-48f3-a9ad-d0dad64c2208",
                        "description": "the id of the master account"
                    },
                    "targetType": {
                        "type": "string",
                        "description": "the type of account"
                    },
                    "targetId": {
                        "type": "string",
                        "description": "the id of the source object"
                    },
                    "accountType": {
                        "type": "string",
                        "description": "Recharge, Sundry, Master, etc"
                    },
                    "rentGroupType": {
                        "type": "string",
                        "description": "Major Works, etc"
                    },
                    "agreementType": {
                        "type": "string",
                        "description": "M, R, S, X"
                    },
                    "accountBalance": {
                        "type": "number",
                        "format": "double",
                        "multipleOf": 0.01,
                        "description": "the current balance on the account"
                    },
                    "lastUpdated": {
                        "type": "string",
                        "format": "date-time",
                        "description": "the last time the account was updated"
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "the start date of the account"
                    },
                    "endDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "the date the account was closed"
                    },
                    "accountStatus": {
                        "type": "string",
                        "description": "the current account status (active, suspended or ended)"
                    },
                    "consolidatedCharges": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/consolidatedCharge"
                        }
                    },
                    "tenure": {
                        "type": "object",
                        "description": "basic information on the tenure associated with this account",
                        "properties": {
                            "tenancyId": {
                                "type": "string",
                                "format": "GUID",
                                "description": "the id of the tenancy"
                            },
                            "tenancyType": {
                                "type": "string",
                                "description": "the type of tenancy"
                            },
                            "primaryTenants": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/primaryTenant"
                                }
                            },
                            "fullAddress": {
                                "type": "string",
                                "description": "the full address of the tenancy",
                                "example": "1 Hillman Street, Hackney, E8 1DY"
                            }
                        }
                    }
                }
            },
            "getAccounts": {
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/getAccountDetails"
                }
            },
            "consolidatedCharge": {
                "type": "object",
                "description": "an aggregated view of a collection of charges for an account",
                "properties": {
                    "type": {
                        "type": "string",
                        "description": "the type of consolidated charge"
                    },
                    "frequency": {
                        "type": "string",
                        "description": "the frequency that the charge is applied"
                    },
                    "amount": {
                        "type": "number",
                        "format": "double",
                        "multipleOf": 0.01,
                        "description": "the amount charged"
                    }
                }
            },
            "primaryTenant": {
                "type": "object",
                "description": "a primary tenant object",
                "properties": {
                    "fullName": {
                        "type": "string",
                        "description": "the name of the tenant"
                    }
                }
            }
        }
    }
}