  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Use your Paystack secret key as the bearer token. Authorization: Bearer SECRET_KEY"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - Invalid or missing API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {}
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {
            "type": "array",
            "items": {}
          },
          "meta": { "$ref": "#/components/schemas/PaginationMeta" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": false },
          "message": { "type": "string" }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "skipped": { "type": "integer" },
          "perPage": { "type": "integer" },
          "page": { "type": "integer" },
          "pageCount": { "type": "integer" }
        }
      },
      "InitializeTransactionRequest": {
        "type": "object",
        "required": ["amount", "email"],
        "properties": {
          "amount": { "type": "integer", "description": "Amount in kobo (NGN) or pesewas (GHS)" },
          "email": { "type": "string", "format": "email" },
          "currency": { "type": "string", "enum": ["NGN", "GHS", "ZAR", "USD"] },
          "reference": { "type": "string" },
          "callback_url": { "type": "string", "format": "uri" },
          "plan": { "type": "string" },
          "invoice_limit": { "type": "integer" },
          "metadata": { "type": "object" },
          "channels": {
            "type": "array",
            "items": { "type": "string", "enum": ["card", "bank", "ussd", "qr", "mobile_money", "bank_transfer", "eft"] }
          },
          "split_code": { "type": "string" },
          "subaccount": { "type": "string" },
          "transaction_charge": { "type": "integer" },
          "bearer": { "type": "string", "enum": ["account", "subaccount"] }
        }
      },
      "ChargeAuthorizationRequest": {
        "type": "object",
        "required": ["authorization_code", "email", "amount"],
        "properties": {
          "authorization_code": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "amount": { "type": "integer", "description": "Amount in kobo" },
          "reference": { "type": "string" },
          "currency": { "type": "string" },
          "metadata": { "type": "object" },
          "channels": {
            "type": "array",
            "items": { "type": "string" }
          },
          "subaccount": { "type": "string" },
          "transaction_charge": { "type": "integer" },
          "bearer": { "type": "string", "enum": ["account", "subaccount"] }
        }
      },
      "PartialDebitRequest": {
        "type": "object",
        "required": ["authorization_code", "currency", "amount", "email"],
        "properties": {
          "authorization_code": { "type": "string" },
          "currency": { "type": "string" },
          "amount": { "type": "integer" },
          "email": { "type": "string", "format": "email" },
          "reference": { "type": "string" },
          "at_least": { "type": "integer", "description": "Minimum amount to charge" }
        }
      },
      "CreateCustomerRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "phone": { "type": "string" },
          "metadata": { "type": "object" }
        }
      },
      "UpdateCustomerRequest": {
        "type": "object",
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "phone": { "type": "string" },
          "metadata": { "type": "object" }
        }
      },
      "SetRiskActionRequest": {
        "type": "object",
        "required": ["customer"],
        "properties": {
          "customer": { "type": "string", "description": "Customer code or email" },
          "risk_action": { "type": "string", "enum": ["default", "allow", "deny"] }
        }
      },
      "CreatePlanRequest": {
        "type": "object",
        "required": ["name", "amount", "interval"],
        "properties": {
          "name": { "type": "string" },
          "amount": { "type": "integer", "description": "Amount in kobo" },
          "interval": { "type": "string", "enum": ["hourly", "daily", "weekly", "monthly", "quarterly", "biannually", "annually"] },
          "description": { "type": "string" },
          "send_invoices": { "type": "boolean" },
          "send_sms": { "type": "boolean" },
          "currency": { "type": "string" },
          "invoice_limit": { "type": "integer" }
        }
      },
      "CreateSubscriptionRequest": {
        "type": "object",
        "required": ["customer", "plan"],
        "properties": {
          "customer": { "type": "string" },
          "plan": { "type": "string" },
          "authorization": { "type": "string" },
          "start_date": { "type": "string", "format": "date-time" }
        }
      },
      "ToggleSubscriptionRequest": {
        "type": "object",
        "required": ["code", "token"],
        "properties": {
          "code": { "type": "string" },
          "token": { "type": "string" }
        }
      },
      "CreateProductRequest": {
        "type": "object",
        "required": ["name", "description", "price", "currency"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "integer" },
          "currency": { "type": "string" },
          "unlimited": { "type": "boolean" },
          "quantity": { "type": "integer" }
        }
      },
      "CreatePaymentPageRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "amount": { "type": "integer" },
          "split_code": { "type": "string" },
          "slug": { "type": "string" },
          "metadata": { "type": "object" },
          "redirect_url": { "type": "string", "format": "uri" },
          "custom_fields": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "InitiateTransferRequest": {
        "type": "object",
        "required": ["source", "amount", "recipient"],
        "properties": {
          "source": { "type": "string", "example": "balance" },
          "amount": { "type": "integer" },
          "recipient": { "type": "string", "description": "Recipient code" },
          "reason": { "type": "string" },
          "currency": { "type": "string" },
          "reference": { "type": "string" }
        }
      },
      "BulkTransferRequest": {
        "type": "object",
        "required": ["source", "transfers"],
        "properties": {
          "source": { "type": "string", "example": "balance" },
          "transfers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["amount", "recipient"],
              "properties": {
                "amount": { "type": "integer" },
                "recipient": { "type": "string" },
                "reason": { "type": "string" },
                "reference": { "type": "string" }
              }
            }
          }
        }
      },
      "CreateTransferRecipientRequest": {
        "type": "object",
        "required": ["type", "name", "account_number", "bank_code"],
        "properties": {
          "type": { "type": "string", "enum": ["nuban", "ghipss", "mobile_money", "basa"] },
          "name": { "type": "string" },
          "account_number": { "type": "string" },
          "bank_code": { "type": "string" },
          "description": { "type": "string" },
          "currency": { "type": "string" },
          "authorization_code": { "type": "string" },
          "metadata": { "type": "object" }
        }
      },
      "CreateSubaccountRequest": {
        "type": "object",
        "required": ["business_name", "settlement_bank", "account_number", "percentage_charge"],
        "properties": {
          "business_name": { "type": "string" },
          "settlement_bank": { "type": "string" },
          "account_number": { "type": "string" },
          "percentage_charge": { "type": "number" },
          "description": { "type": "string" },
          "primary_contact_email": { "type": "string", "format": "email" },
          "primary_contact_name": { "type": "string" },
          "primary_contact_phone": { "type": "string" },
          "metadata": { "type": "object" }
        }
      },
      "CreateRefundRequest": {
        "type": "object",
        "required": ["transaction"],
        "properties": {
          "transaction": { "type": "string", "description": "Transaction reference or ID" },
          "amount": { "type": "integer" },
          "currency": { "type": "string" },
          "customer_note": { "type": "string" },
          "merchant_note": { "type": "string" }
        }
      },
      "CreateSplitRequest": {
        "type": "object",
        "required": ["name", "type", "currency", "subaccounts"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["percentage", "flat"] },
          "currency": { "type": "string" },
          "subaccounts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["subaccount", "share"],
              "properties": {
                "subaccount": { "type": "string" },
                "share": { "type": "integer" }
              }
            }
          },
          "bearer_type": { "type": "string", "enum": ["subaccount", "account", "all-proportional", "all"] },
          "bearer_subaccount": { "type": "string" }
        }
      }
    }
  }
}