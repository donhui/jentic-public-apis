        }
      },
      "put": {
        "operationId": "updatePlan",
        "summary": "Update Plan",
        "tags": ["Plans"],
        "parameters": [
          {
            "name": "id_or_code",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
