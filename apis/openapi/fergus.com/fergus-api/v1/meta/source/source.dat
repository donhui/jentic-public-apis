            "required": false,
            "description": "Searchable fields:\n- `user`\n- `employee's username`\n- `jobPhaseTitle`,\n- `jobPhaseDetails`"
          },
          {
            "schema": {
              "errorMessage": "The filterLockedOnly must be a boolean",
              "type": "boolean"
