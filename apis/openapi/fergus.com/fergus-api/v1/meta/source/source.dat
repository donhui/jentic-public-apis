          {
            "schema": {
              "format": "date-time",
              "errorMessage": "dueAfter must be a valid ISO 8601 date-time",
              "type": "string"
            },
            "in": "query",
            "name": "dueAfter",
            "required": false,
            "description": "Filter invoices due after this datetime"
          }
        ],
