          {
            "type": "object",
            "properties": {
              "sortField": {
                "default": "dateEntered",
                "enum": [
                  "dateEntered",
                  "lastModified"
                ],
                "errorMessage": "The sortField must be `dateEntered` (default) or `lastModified`",
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "dateEntered"
                    ]
                  },
                  {
                    "type": "string",
                    "enum": [
                      "lastModified"
                    ]
                  }
                ]
              },
              "filterSearchText": {
                "description": "Searchable fields:\n- `itemDescription`",
                "type": "string"
              },
              "lastModified": {
                "format": "date-time",
                "type": "string"
              },
              "dateEntered": {
                "format": "date-time",
                "type": "string"
              }
            }
          }
        ]
      },
