            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "filterAddressPostalCode",
            "required": false
          },
          {
            "schema": {
              "default": "createdAt",
              "enum": [
                "name",
                "createdAt"
              ],
              "errorMessage": "The sortField must be either `name` or `createdAt`, defaults to `name`",
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "name"
                  ]
                },
                {
                  "type": "string",
                  "enum": [
                    "createdAt"
                  ]
                }
