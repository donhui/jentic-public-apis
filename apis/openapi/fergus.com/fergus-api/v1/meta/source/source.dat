              "type": "string"
            },
            "in": "query",
            "name": "pageCursor",
            "required": false
          },
          {
            "schema": {
              "default": "createdAt",
              "enum": [
                "firstName",
                "lastName",
                "createdAt"
              ],
              "errorMessage": "The sortField must be either `firstName`, `lastName` or `createdAt`, defaults to `createdAt`",
              "type": "string"
            },
            "in": "query",
