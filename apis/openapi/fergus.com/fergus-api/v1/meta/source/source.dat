      "post": {
        "tags": [
          "Jobs"
        ],
        "description": "Create a new job",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "if": {
                  "type": "object",
                  "required": [
                    "isDraft"
                  ],
                  "properties": {
                    "isDraft": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    }
                  }
                },
                "then": {
                  "$ref": "#/components/schemas/CreateDraftJob"
                },
                "else": {
                  "$ref": "#/components/schemas/CreateNonDraftJob"
                },
                "type": "object",
                "required": [
                  "jobType",
                  "title"
                ],
                "properties": {
                  "isDraft": {
                    "type": "boolean"
                  },
                  "jobType": {
                    "enum": [
                      "Quote",
                      "Estimate",
                      "Charge Up"
                    ],
                    "errorMessage": "The jobType must be one of `Quote`, `Estimate`, or `Charge Up`",
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "customerId": {
                    "type": "number"
                  },
                  "customerReference": {
                    "type": "string"
                  },
                  "siteId": {
                    "type": "number"
                  }
                }
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "oauth2": []
          },
          {
            "PersonalAccessToken": []
          }
        ],
        "responses": {
          "201": {
            "description": "Resource created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client Request Errors",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Server Errors",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
