      "get": {
        "tags": [
          "Jobs - Quotes"
        ],
        "description": "Returns a list of all quotes from across all jobs, sorted by created date and last modified date.",
        "parameters": [
          {
            "schema": {
              "default": 10,
              "errorMessage": "The pageSize must be an integer between 1 and 100",
              "minimum": 1,
              "maximum": 100,
