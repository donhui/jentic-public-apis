{
  "openapi": "3.0.3",
  "info": {
    "title": "Showdigs API",
    "description": "API for Showdigs property showing and listing management platform.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.showdigs.com/docs"
  },
  "servers": [
    {
      "url": "https://api.showdigs.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    { "name": "Coverage", "description": "Location coverage operations" },
    { "name": "Units", "description": "Unit management operations" },
    { "name": "Listings", "description": "Listing management operations" },
    { "name": "Inquiries", "description": "Inquiry operations" },
    { "name": "Bot", "description": "Bot conversation operations" },
    { "name": "Webhooks", "description": "Webhook management operations" },
    { "name": "Properties", "description": "Property management operations" }
  ],
  "paths": {
    "/api/v1/coverage": {
      "get": {
        "operationId": "checkCoverage",
        "summary": "Check location coverage",
        "description": "Check whether a given location is within the Showdigs coverage area.",
        "tags": ["Coverage"],
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": { "type": "number" },
            "description": "Latitude of the location"
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": { "type": "number" },
            "description": "Longitude of the location"
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Street address of the location"
          }
        ],
        "responses": {
          "200": {
            "description": "Coverage status with network tier",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CoverageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/units": {
      "get": {
        "operationId": "listUnits",
        "summary": "List all units",
        "description": "Retrieve a paginated list of all units.",
        "tags": ["Units"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1 },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 100 },
            "description": "Number of results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of unit objects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedUnitsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/units/{uuid}": {
      "get": {
        "operationId": "getUnit",
        "summary": "Get specific unit",
        "description": "Retrieve details of a specific unit by UUID.",
        "tags": ["Units"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unit UUID"
          }
        ],
        "responses": {
          "200": {
            "description": "Unit object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Unit"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/units/{uuid}/listing": {
      "post": {
        "operationId": "createListing",
        "summary": "Create listing for unit",
        "description": "Create a new listing for the specified unit.",
        "tags": ["Listings"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unit UUID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateListingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Listing UUID and scheduling URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateListingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateListing",
        "summary": "Update listing",
        "description": "Update an existing listing for the specified unit.",
        "tags": ["Listings"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unit UUID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateListingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update confirmation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/listings": {
      "get": {
        "operationId": "listActiveListings",
        "summary": "Get all active listings",
        "description": "Retrieve all currently active listings.",
        "tags": ["Listings"],
        "responses": {
          "200": {
            "description": "Array of listing objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Listing"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/listings/{uuid}": {
      "get": {
        "operationId": "getListing",
        "summary": "Get specific listing",
        "description": "Retrieve details of a specific listing by UUID.",
        "tags": ["Listings"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Listing UUID"
          }
        ],
        "responses": {
          "200": {
            "description": "Listing object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Listing"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deactivateListing",
        "summary": "Deactivate listing",
        "description": "Deactivate a specific listing by UUID.",
        "tags": ["Listings"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Listing UUID"
          }
        ],
        "responses": {
          "200": {
            "description": "Deactivation confirmation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/inquiries": {
      "post": {
        "operationId": "createInquiry",
        "summary": "Create inquiry",
        "description": "Create a new inquiry from a prospective tenant.",
        "tags": ["Inquiries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInquiryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inquiry ID and scheduling URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateInquiryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/bots/business-info/{businessId}": {
      "get": {
        "operationId": "getBusinessInfo",
        "summary": "Get business info for bot",
        "description": "Retrieve business details for a bot by business ID.",
        "tags": ["Bot"],
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Business ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Business details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessInfoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/bots/conversation/message": {
      "post": {
        "operationId": "sendBotMessage",
        "summary": "Send bot message",
        "description": "Send a message in a bot conversation.",
        "tags": ["Bot"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BotMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BotMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/webhooks/subscribe": {
      "post": {
        "operationId": "subscribeWebhook",
        "summary": "Register webhook",
        "description": "Register a webhook URL to receive event notifications. URL must use HTTPS.",
        "tags": ["Webhooks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription confirmation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/webhooks/unsubscribe": {
      "delete": {
        "operationId": "unsubscribeWebhook",
        "summary": "Remove webhook",
        "description": "Remove the registered webhook subscription.",
        "tags": ["Webhooks"],
        "responses": {
          "200": {
            "description": "Unsubscription confirmation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/webhooks/sample": {
      "get": {
        "operationId": "getWebhookSample",
        "summary": "Get sample webhook payload",
        "description": "Retrieve an example webhook payload structure.",
        "tags": ["Webhooks"],
        "responses": {
          "200": {
            "description": "Example webhook payload structure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookSampleResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/properties": {
      "post": {
        "operationId": "createProperty",
        "summary": "Create property with units",
        "description": "Create a new property along with its units.",
        "tags": ["Properties"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePropertyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created property object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Property"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/properties/{origin_id}": {
      "put": {
        "operationId": "updateProperty",
        "summary": "Update property",
        "description": "Update an existing property and its units by origin ID.",
        "tags": ["Properties"],
        "parameters": [
          {
            "name": "origin_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Origin ID of the property"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePropertyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated property object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Property"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token passed via Authorization header"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "CoverageResponse": {
        "type": "object",
        "properties": {
          "covered": {
            "type": "boolean",
            "description": "Whether the location is covered"
          },
          "network_tier": {
            "type": "string",
            "description": "Network tier for the location"
          }
        }
      },
      "Unit": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Unique identifier for the unit"
          },
          "name": {
            "type": "string",
            "description": "Unit name"
          },
          "bedrooms": {
            "type": "number",
            "description": "Number of bedrooms"
          },
          "bathrooms": {
            "type": "number",
            "description": "Number of bathrooms"
          },
          "size": {
            "type": "number",
            "description": "Size of the unit in square feet"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of image URLs"
          }
        }
      },
      "PaginatedUnitsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Unit"
            }
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "per_page": {
            "type": "integer",
            "description": "Number of results per page"
          },
          "total": {
            "type": "integer",
            "description": "Total number of units"
          }
        }
      },
      "Tenant": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          }
        }
      },
      "CreateListingRequest": {
        "type": "object",
        "required": [
          "type",
          "property_link",
          "application_link",
          "manager_email",
          "access_hardware",
          "notes",
          "tours_limit",
          "rent"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "high_availability",
              "publish_listing",
              "self_showing",
              "restricted"
            ],
            "description": "Listing type"
          },
          "property_link": {
            "type": "string",
            "description": "URL to the property listing page"
          },
          "application_link": {
            "type": "string",
            "description": "URL to the rental application"
          },
          "manager_email": {
            "type": "string",
            "description": "Property manager email address"
          },
          "access_hardware": {
            "type": "string",
            "description": "Type of access hardware at the property"
          },
          "access_code": {
            "type": "string",
            "description": "Access code for the property"
          },
          "serial_number": {
            "type": "string",
            "description": "Serial number of access hardware"
          },
          "notes": {
            "type": "string",
            "description": "Additional notes for the listing"
          },
          "tours_limit": {
            "type": "integer",
            "description": "Maximum number of tours allowed"
          },
          "rent": {
            "type": "integer",
            "description": "Monthly rent amount"
          },
          "security_deposit": {
            "type": "integer",
            "description": "Security deposit amount"
          },
          "screening_template_uuid": {
            "type": "string",
            "description": "UUID of the screening template to use"
          },
          "schedule_template_uuid": {
            "type": "string",
            "description": "UUID of the schedule template to use"
          },
          "ai_identity_verification": {
            "type": "boolean",
            "description": "Whether to enable AI identity verification"
          },
          "tenants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tenant"
            },
            "description": "List of existing tenants"
          },
          "report_emails": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Email addresses to receive reports"
          },
          "availability_date": {
            "type": "string",
            "format": "date",
            "description": "Date the unit becomes available"
          },
          "showing_start_date": {
            "type": "string",
            "format": "date",
            "description": "Date showings can begin"
          }
        }
      },
      "CreateListingResponse": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "UUID of the created listing"
          },
          "scheduling_url": {
            "type": "string",
            "description": "URL for scheduling showings"
          }
        }
      },
      "UpdateListingRequest": {
        "type": "object",
        "properties": {
          "rent": {
            "type": "integer",
            "description": "Updated monthly rent amount"
          },
          "security_deposit": {
            "type": "integer",
            "description": "Updated security deposit amount"
          },
          "application_url": {
            "type": "string",
            "description": "Updated application URL"
          },
          "notes": {
            "type": "string",
            "description": "Updated notes"
          }
        }
      },
      "Listing": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Listing UUID"
          },
          "type": {
            "type": "string",
            "description": "Listing type"
          },
          "status": {
            "type": "string",
            "description": "Current listing status"
          },
          "rent": {
            "type": "integer",
            "description": "Monthly rent amount"
          },
          "security_deposit": {
            "type": "integer",
            "description": "Security deposit amount"
          },
          "scheduling_url": {
            "type": "string",
            "description": "URL for scheduling showings"
          },
          "unit": {
            "$ref": "#/components/schemas/Unit"
          }
        }
      },
      "CreateInquiryRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "email",
          "phone_number"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "description": "Inquirer's first name"
          },
          "last_name": {
            "type": "string",
            "description": "Inquirer's last name"
          },
          "email": {
            "type": "string",
            "description": "Inquirer's email address"
          },
          "phone_number": {
            "type": "string",
            "description": "Inquirer's phone number"
          },
          "property_interest": {
            "type": "string",
            "description": "Property of interest (conditional)"
          },
          "listing_id": {
            "type": "string",
            "description": "Listing ID of interest (conditional)"
          }
        }
      },
      "CreateInquiryResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Inquiry ID"
          },
          "scheduling_url": {
            "type": "string",
            "description": "URL for scheduling a showing"
          }
        }
      },
      "BusinessInfoResponse": {
        "type": "object",
        "properties": {
          "businessId": {
            "type": "string",
            "description": "Business identifier"
          },
          "name": {
            "type": "string",
            "description": "Business name"
          },
          "details": {
            "type": "object",
            "description": "Additional business details"
          }
        }
      },
      "BotMessageRequest": {
        "type": "object",
        "required": [
          "businessDetails",
          "conversationDetails",
          "messageDetails"
        ],
        "properties": {
          "businessDetails": {
            "type": "object",
            "required": ["businessId"],
            "properties": {
              "businessId": {
                "type": "string",
                "description": "Business identifier"
              }
            }
          },
          "conversationDetails": {
            "type": "object",
            "required": ["conversationId"],
            "properties": {
              "conversationId": {
                "type": "string",
                "description": "Conversation identifier"
              }
            }
          },
          "messageDetails": {
            "type": "object",
            "required": ["messageId", "direction", "content", "createdOn"],
            "properties": {
              "messageId": {
                "type": "string",
                "description": "Message identifier"
              },
              "direction": {
                "type": "string",
                "description": "Message direction (inbound/outbound)"
              },
              "content": {
                "type": "string",
                "description": "Message content"
              },
              "createdOn": {
                "type": "string",
                "format": "date-time",
                "description": "Message creation timestamp"
              }
            }
          },
          "overridePrompts": {
            "type": "object",
            "description": "Optional prompt overrides"
          }
        }
      },
      "BotMessageResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "string",
            "description": "Bot response message"
          },
          "conversationId": {
            "type": "string",
            "description": "Conversation identifier"
          }
        }
      },
      "WebhookSubscribeRequest": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "description": "HTTPS webhook URL to receive events",
            "pattern": "^https://"
          }
        }
      },
      "WebhookSampleResponse": {
        "type": "object",
        "properties": {
          "event": {
            "type": "string",
            "description": "Event type"
          },
          "data": {
            "type": "object",
            "description": "Event payload data"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp"
          }
        }
      },
      "PropertyUnit": {
        "type": "object",
        "required": ["name", "bedrooms", "bathrooms", "size", "images"],
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Unit UUID (used for updates)"
          },
          "name": {
            "type": "string",
            "description": "Unit name or number"
          },
          "bedrooms": {
            "type": "number",
            "description": "Number of bedrooms"
          },
          "bathrooms": {
            "type": "number",
            "description": "Number of bathrooms"
          },
          "size": {
            "type": "number",
            "description": "Unit size in square feet"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of image URLs"
          }
        }
      },
      "CreatePropertyRequest": {
        "type": "object",
        "required": [
          "street",
          "city",
          "state",
          "zip",
          "latitude",
          "longitude",
          "units"
        ],
        "properties": {
          "origin_id": {
            "type": "string",
            "description": "External origin identifier"
          },
          "property_type": {
            "type": "string",
            "description": "Type of property"
          },
          "street": {
            "type": "string",
            "description": "Street address"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "state": {
            "type": "string",
            "description": "State"
          },
          "zip": {
            "type": "string",
            "description": "ZIP code"
          },
          "latitude": {
            "type": "number",
            "description": "Latitude coordinate"
          },
          "longitude": {
            "type": "number",
            "description": "Longitude coordinate"
          },
          "units": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PropertyUnit"
            },
            "description": "Units within the property"
          }
        }
      },
      "UpdatePropertyRequest": {
        "type": "object",
        "properties": {
          "origin_id": {
            "type": "string",
            "description": "External origin identifier"
          },
          "property_type": {
            "type": "string",
            "description": "Type of property"
          },
          "street": {
            "type": "string",
            "description": "Street address"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "state": {
            "type": "string",
            "description": "State"
          },
          "zip": {
            "type": "string",
            "description": "ZIP code"
          },
          "latitude": {
            "type": "number",
            "description": "Latitude coordinate"
          },
          "longitude": {
            "type": "number",
            "description": "Longitude coordinate"
          },
          "units": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PropertyUnit"
            },
            "description": "Units within the property (include uuid for updates)"
          }
        }
      },
      "Property": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Property UUID"
          },
          "origin_id": {
            "type": "string",
            "description": "External origin identifier"
          },
          "property_type": {
            "type": "string",
            "description": "Type of property"
          },
