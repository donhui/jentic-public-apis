  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "company_id": {
            "type": "integer",
            "description": "Associated company ID"
          },
          "valid": {
            "type": "boolean",
            "description": "Whether the token is valid"
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Webhook identifier"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook callback URL"
          },
          "method": {
            "type": "string",
            "description": "HTTP method for the webhook"
          },
          "model": {
            "type": "string",
            "description": "Model the webhook listens to"
          },
          "events": {
            "type": "string",
            "description": "Events that trigger the webhook"
          },
          "filter_key": {
            "type": "string",
            "description": "Optional filter key"
          }
        }
      },
      "WebhookCreateRequest": {
        "type": "object",
        "required": [
          "url",
          "method",
          "model",
          "events"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook callback URL"
          },
          "method": {
            "type": "string",
            "description": "HTTP method for the webhook"
          },
          "model": {
            "type": "string",
            "description": "Model the webhook listens to"
          },
          "events": {
            "type": "string",
            "description": "Events that trigger the webhook"
          },
          "filter_key": {
            "type": "string",
            "description": "Optional filter key"
          }
        }
      },
      "WebhookList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Webhook"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "Contact": {
        "type": "object",
