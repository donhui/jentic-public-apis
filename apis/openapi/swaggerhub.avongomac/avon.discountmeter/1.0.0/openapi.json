{
    "openapi": "3.0.0",
    "info": {
        "description": "\"This API is to invoke subystems of discount meter for a given representatifve\"",
        "version": "1.0.0",
        "title": "GOMAC Discount Meter API",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/avonGomac/Avon.DiscountMeter/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "DiscountMeter",
            "description": "Discount meter"
        }
    ],
    "paths": {
        "/{dataAreaId}/DiscountMeter": {
            "get": {
                "tags": [
                    "DiscountMeter"
                ],
                "summary": "Get discount meter for a given rep without considering any order",
                "description": "Get discount meter for a rep",
                "operationId": "GetDiscountMeter",
                "parameters": [
                    {
                        "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/components/parameters/dataAreaId"
                    },
                    {
                        "name": "acctNr",
                        "in": "query",
                        "description": "representative account number as is in LINX",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "cmpgNr",
                        "in": "query",
                        "description": "campaign of discount meter",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "retrieved discount meter with some header",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/outDiscountMeter"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/definitions/Error"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "rep is not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/definitions/Error"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "/api/v1"
        }
    ],
    "components": {
        "schemas": {
            "outDiscountMeter": {
                "properties": {
                    "cmpgNr": {
                        "description": "order campaign id (CAMPORD) Capture,Preview,Customer",
                        "type": "integer",
                        "format": "int64",
                        "example": 201801
                    },
                    "acctNr": {
                        "description": "Representative account number (CUSTACCT)",
                        "type": "integer",
                        "format": "int64",
                        "example": 123
                    },
                    "bckndAcctNr": {
                        "description": "Backend account number (BACKENDACCT) TBD, for Russia",
                        "type": "string"
                    },
                    "discnt": {
                        "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/definitions/discnt"
                    }
                }
            }
        }
    }
}