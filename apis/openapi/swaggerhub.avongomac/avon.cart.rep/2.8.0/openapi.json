{
    "openapi": "3.0.0",
    "info": {
        "description": "\"This API is proxying input (json) to subystems via MQ to get rep carts priced.\"",
        "version": "2.8.0",
        "title": "GOMAC Rep Cart API",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/avonGomac/Avon.Cart.Rep/2.8.0/swagger.json"
    },
    "tags": [
        {
            "name": "CartRep",
            "description": "Cart"
        }
    ],
    "paths": {
        "/{dataAreaId}/{langCd}/gomac/cart/rep": {
            "post": {
                "tags": [
                    "CartRep"
                ],
                "summary": "Get cart priced preview for rep",
                "description": "Get cart priced preview for rep",
                "operationId": "GetCartPricedForRep",
                "parameters": [
                    {
                        "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/components/parameters/dataAreaId"
                    },
                    {
                        "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/components/parameters/langCd"
                    },
                    {
                        "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/components/parameters/timeout"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/definitions/inRepOrdEntry"
                            }
                        }
                    },
                    "description": "Rep cart to be priced",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Priced rep cart",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/definitions/outRepOrdEntry"
                                }
                            }
                        }
                    },
                    "202": {
                        "description": "Message id to retrieve response if Timeout happens",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Server side error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "https://api.swaggerhub.com/domains/csibat/LinxOMS/1.2#/definitions/Error"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "/api/v1"
        }
    ]
