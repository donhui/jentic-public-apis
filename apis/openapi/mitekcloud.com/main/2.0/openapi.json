  },
  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "description": "Token validity in seconds",
            "example": 300
          }
        }
      },
      "CreateDossierRequest": {
        "type": "object",
        "required": [
          "evidence"
        ],
        "properties": {
          "dossierMetadata": {
            "type": "object",
            "properties": {
              "customerReferenceId": {
                "type": "string"
              }
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Evidence"
            }
          },
          "configuration": {
            "$ref": "#/components/schemas/DossierConfiguration"
          }
        }
      },
      "Evidence": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "IdDocument",
              "Biometric"
            ]
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EvidenceImage"
            },
            "maxItems": 2
          },
          "data": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded image data"
          },
          "encryptedPayload": {
            "type": "string",
            "description": "Encrypted payload for injection attack detection"
          },
          "customerReferenceId": {
            "type": "string"
          },
          "encodedData": {
            "type": "string",
            "description": "PDF417 or QR code data"
          },
          "nfc": {
            "$ref": "#/components/schemas/NfcData"
          }
        }
      },
      "EvidenceImage": {
        "type": "object",
        "properties": {
          "data": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded image"
          },
          "customerReferenceId": {
            "type": "string"
          }
        }
      },
      "NfcData": {
        "type": "object",
        "properties": {
          "sod": {
            "type": "string"
          },
          "com": {
            "type": "string"
          },
          "dataGroups": {
            "type": "object"
          },
          "activeAuthInput": {
            "type": "string"
          },
          "portrait": {
            "type": "string"
          }
        }
      },
      "DossierConfiguration": {
        "type": "object",
        "properties": {
          "verifications": {
            "type": "object",
            "properties": {
              "faceComparison": {
                "type": "boolean"
              },
              "faceLiveness": {
                "type": "boolean"
              },
              "faceBlocklist": {
                "type": "boolean"
              },
              "faceVelocity": {
                "type": "boolean"
              },
              "dataSignalAAMVA": {
                "type": "boolean"
              },
              "injectionAttackDetection": {
                "type": "boolean"
              },
              "injectionAttackDetectionAI": {
                "type": "boolean"
              },
              "templateAttackDetection": {
                "type": "boolean"
              }
            }
          },
          "responseImages": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "CroppedPortrait",
                "CroppedSignature",
                "CroppedDocument",
                "Selfies"
              ]
            }
          }
        }
      },
      "DossierResponse": {
        "type": "object",
        "properties": {
          "dossierMetadata": {
            "type": "object",
            "properties": {
              "dossierId": {
                "type": "string"
              },
              "processingStatus": {
                "type": "string"
              },
              "createdDateTime": {
                "type": "string",
                "format": "date-time"
              },
              "version": {
                "type": "string"
              }
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProcessedEvidence"
            }
          }
        }
      },
      "ProcessedEvidence": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "extractedData": {
            "$ref": "#/components/schemas/ExtractedData"
          },
          "findings": {
            "$ref": "#/components/schemas/Findings"
          }
        }
      },
      "ExtractedData": {
        "type": "object",
        "properties": {
          "name": {
            "type": "object",
            "properties": {
              "fullName": {
                "type": "string"
              },
              "firstName": {
                "type": "string"
              },
              "lastName": {
                "type": "string"
              }
            }
          },
          "address": {
            "type": "object",
            "properties": {
              "fullAddress": {
                "type": "string"
              }
            }
          },
          "documentNumber": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string"
          },
          "expirationDate": {
            "type": "string"
          },
          "issueDate": {
            "type": "string"
          }
        }
      },
      "Findings": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean"
          },
          "probability": {
            "type": "number"
          },
          "verifications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Verification"
            }
          }
        }
      },
      "Verification": {
        "type": "object",
        "properties": {
          "verificationType": {
            "type": "string"
          },
          "judgement": {
            "type": "string",
            "enum": [
              "Authentic",
              "Fraudulent",
              "Undetermined"
            ]
          },
          "probability": {
            "type": "number"
          },
          "notifications": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "version": {
            "type": "string"
          }
        }
      },
      "FillDocumentRequest": {
        "type": "object",
        "required": [
          "images"
        ],
        "properties": {
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EvidenceImage"
            }
          },
          "configuration": {
            "type": "object"
          }
        }
      },
      "FillDocumentResponse": {
        "type": "object",
        "properties": {
          "extractedData": {
            "$ref": "#/components/schemas/ExtractedData"
          },
          "processingStatus": {
            "type": "string"
          }
        }
      },
      "CreateBlocklistItemRequest": {
        "type": "object",
        "required": [
          "biometricData"
        ],
        "properties": {
          "biometricData": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded biometric data"
          },
          "customerReferenceId": {
            "type": "string"
          }
        }
      },
      "BlocklistItem": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "string"
          },
          "transactionId": {
            "type": "string"
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateEnrollmentRequest": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded audio recording"
          },
          "customerReferenceId": {
            "type": "string"
          }
        }
      },
      "EnrollmentResponse": {
        "type": "object",
        "properties": {
          "enrollmentId": {
            "type": "string"
          },
          "processingStatus": {
            "type": "string"
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BiometricVerifyRequest": {
        "type": "object",
