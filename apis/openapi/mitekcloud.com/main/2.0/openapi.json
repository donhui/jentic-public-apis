{
  "openapi": "3.0.3",
  "info": {
    "title": "Mitek Identity Cloud API",
    "version": "2.0",
    "description": "Mitek Identity Cloud API provides identity verification services including document verification (Mobile Verify), data extraction (Mobile Fill), face blocklist management, biometric enrollment and verification (MiPass), and AAMVA driver license verification.",
    "x-jentic-source-url": "https://docs.us.mitekcloud.com/"
  },
  "servers": [
    {
      "url": "https://api.us.mitekcloud.com",
      "description": "US Production"
    }
  ],
  "paths": {
    "/connect/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Obtain an OAuth 2.0 access token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret",
                  "scope"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "example": "client_credentials"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Mitek-provided client identifier"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Mitek-provided client secret"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Space-delimited scope list",
                    "example": "global.identity.api dossier.creator"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/verify/v2/dossier": {
      "post": {
        "operationId": "createVerificationDossier",
        "summary": "Create a verification dossier (Mobile Verify)",
        "tags": [
          "Mobile Verify"
