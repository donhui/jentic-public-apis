  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained from F5 identity OAuth2 endpoint (https://identity.account.f5.com/oauth2/ausp95ykc80HOU7SQ357/v1/token). Token valid for 30 minutes."
      }
    },
    "schemas": {
      "DeletedQkviewsResponse": {
        "type": "object",
        "properties": {
          "deleted_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of deleted QKViews"
          }
        }
      },
      "DiagnosticOutput": {
        "type": "object",
        "description": "XML diagnostic output",
        "properties": {
          "diagnostics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Diagnostic"
            }
          },
          "system_information": {
            "type": "object",
            "properties": {
              "serial_number": {
                "type": "string"
              },
              "hostname": {
                "type": "string"
              },
              "platform": {
                "type": "string"
              }
            }
          },
          "version": {
            "type": "object",
            "properties": {
              "product": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "build": {
                "type": "string"
              }
            }
          }
        }
      },
      "Diagnostic": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "output": {
            "type": "string"
          },
          "importance": {
            "type": "string"
          },
          "match": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "header": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "solutions": {
            "type": "string"
          }
        }
      },
      "FileListResponse": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "File hash identifier"
                },
                "file_path": {
                  "type": "string",
                  "description": "File path within QKView"
                }
              }
            }
          }
        }
      },
      "CommandListResponse": {
        "type": "object",
        "properties": {
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Command hash identifier"
                },
                "commandline": {
                  "type": "string",
                  "description": "The command text"
                }
              }
            }
          }
