{
  "openapi": "3.0.3",
  "info": {
    "title": "F5 iHealth API",
    "description": "The F5 iHealth API provides programmatic access to F5 iHealth diagnostic services, allowing users to upload QKView files, retrieve diagnostic results, access files, and run commands.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://clouddocs.f5.com/api/ihealth/"
  },
  "servers": [
    {
      "url": "https://ihealth2-api.f5.com/qkview-analyzer/api",
      "description": "F5 iHealth API server"
    }
  ],
  "paths": {
    "/qkviews": {
      "get": {
        "operationId": "listQkviews",
        "summary": "List all QKViews",
        "tags": [
          "QKViews"
        ],
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "application/vnd.f5.ihealth.api"
            }
          }
        ],
        "responses": {
          "303": {
            "description": "Redirect to QKView list",
            "headers": {
              "Location": {
                "schema": {
                  "type": "string"
                },
                "description": "URI to the QKView list"
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "uploadQkview",
        "summary": "Upload a new QKView file",
        "tags": [
          "QKViews"
        ],
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "application/vnd.f5.ihealth.api"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "qkview"
                ],
                "properties": {
                  "qkview": {
                    "type": "string",
                    "format": "binary",
                    "description": "QKView tarball file"
                  },
                  "visible_in_gui": {
                    "type": "boolean",
                    "description": "Make the QKView visible in the iHealth GUI"
                  },
                  "description": {
                    "type": "string",
                    "description": "Description for the uploaded QKView"
                  },
                  "f5_support_case": {
                    "type": "string",
                    "description": "Associated F5 support case number"
                  },
                  "share_with_case_owner": {
                    "type": "boolean",
                    "description": "Share the QKView with the support case owner"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "303": {
            "description": "QKView uploaded successfully",
            "headers": {
              "Location": {
                "schema": {
                  "type": "string"
                },
                "description": "URI to the uploaded QKView resource"
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAllQkviews",
        "summary": "Delete all QKViews",
        "tags": [
          "QKViews"
        ],
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "application/vnd.f5.ihealth.api"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All QKViews deleted",
            "content": {
              "application/vnd.f5.ihealth.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/DeletedQkviewsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No QKViews found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
