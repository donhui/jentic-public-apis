              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "QKView not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/qkviews/{qkviewId}/diagnostics": {
      "get": {
        "operationId": "getQkviewDiagnostics",
        "summary": "Retrieve diagnostics for a QKView",
        "tags": [
          "Diagnostics"
        ],
        "parameters": [
          {
            "name": "qkviewId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "QKView identifier"
          },
          {
            "name": "set",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "hit",
                "miss"
              ]
            },
            "description": "Filter diagnostics by match status (hit or miss)"
          },
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "application/vnd.f5.ihealth.api"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Diagnostic output",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/DiagnosticOutput"
                }
              }
            }
          },
          "202": {
            "description": "Processing not yet complete, retry after 10+ seconds"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "QKView not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
