    "/outbound-ips": {
      "get": {
        "operationId": "getOutboundIps",
        "summary": "Get ReadMe's outbound IP addresses",
        "tags": ["outbound-ips"],
        "responses": {
          "200": {
            "description": "List of outbound IP addresses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ips": {
                      "type": "array",
                      "items": {"type": "string"}
                    }
                  }
                }
              }
            }
          },
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/owlbot/ask": {
      "post": {
        "operationId": "askOwlbot",
        "summary": "Ask Owlbot AI about documentation",
        "description": "Query the Owlbot AI assistant about your project documentation.",
        "tags": ["owlbot"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["question"],
                "properties": {
                  "question": {"type": "string", "description": "The question to ask Owlbot"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Owlbot response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "answer": {"type": "string", "description": "The AI-generated answer"}
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "429": {"description": "Rate limited"}
        }
      }
    },
    "/schema": {
      "get": {
        "operationId": "getSchema",
        "summary": "Get the ReadMe OpenAPI definition",
        "tags": ["schema"],
        "responses": {
          "200": {
