      "get": {
        "operationId": "getProductionDoc",
        "summary": "Get production doc",
        "tags": ["docs"],
        "parameters": [
          {"name": "slug", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
