    "/docs": {
      "post": {
        "operationId": "createDoc",
        "summary": "Create a doc",
        "tags": ["docs"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Doc created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Doc"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/docs/search": {
      "post": {
        "operationId": "searchDocs",
        "summary": "Search docs",
        "tags": ["docs"],
        "parameters": [
          {"name": "search", "in": "query", "required": true, "description": "Search query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Doc"}
                    }
                  }
                }
              }
            }
          },
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/docs/{slug}": {
      "get": {
        "operationId": "getDoc",
        "summary": "Get a doc",
        "tags": ["docs"],
        "parameters": [
          {"name": "slug", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Doc details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Doc"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"}
        }
      },
      "put": {
        "operationId": "updateDoc",
        "summary": "Update a doc",
        "tags": ["docs"],
        "parameters": [
          {"name": "slug", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Doc updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Doc"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"}
        }
      },
      "delete": {
        "operationId": "deleteDoc",
        "summary": "Delete a doc",
        "tags": ["docs"],
        "parameters": [
          {"name": "slug", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Doc deleted"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"}
        }
      }
    },
