{
  "openapi": "3.0.3",
  "info": {
    "title": "RooR SMS API",
    "version": "2.0.0",
    "description": "RooR SMS API for sending automated campaign SMS messages with recipient management.",
    "x-jentic-source-url": "https://portal.roor.app/v2.0/api/documentation/get/page/autoresponder"
  },
  "servers": [
    {
      "url": "https://portal.roor.app",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/v2.0/api/post/autoCampaignSend/key/{api_key}/response/json/campaign/{campaign_id}": {
      "post": {
        "operationId": "sendautocampaignsms",
        "summary": "Send automated SMS campaign message",
        "description": "Sends automated SMS messages through a specified campaign by submitting recipient and message details.",
        "tags": [
          "SMS Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "campaign_id",
            "in": "path",
            "required": true,
            "description": "Campaign identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AutoCampaignSendRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS send result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutoCampaignSendResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "path",
        "name": "api_key",
        "description": "API key passed as a path parameter"
      }
    },
    "schemas": {
      "AutoCampaignSendRequest": {
        "type": "object",
        "required": [
          "phone"
        ],
        "properties": {
          "phone": {
            "type": "string",
            "description": "The phone number to send to"
          },
          "first_name": {
            "type": "string",
            "description": "Recipient's first name"
          },
          "last_name": {
            "type": "string",
            "description": "Recipient's last name"
          },
          "phone2": {
            "type": "string",
            "description": "Additional phone number"
          },
          "phone3": {
            "type": "string",
            "description": "Additional phone number"
          },
          "phone4": {
            "type": "string",
            "description": "Additional phone number"
          },
          "address1": {
            "type": "string",
            "description": "Street address line 1"
          },
          "address2": {
            "type": "string",
            "description": "Street address line 2"
          },
          "city": {
            "type": "string",
            "description": "City name"
          },
          "state": {
            "type": "string",
            "description": "State abbreviation"
          },
          "zip": {
            "type": "string",
            "description": "Postal code"
          },
          "email": {
            "type": "string",
            "description": "Email address"
          },
          "notes": {
            "type": "string",
            "description": "Additional notes"
          },
          "suppress": {
            "type": "string",
            "description": "Used by SMS system to flag STOP requests"
          },
          "call_status": {
            "type": "string",
            "description": "Call status tracking"
          },
          "message_content": {
            "type": "string",
            "description": "Complete message for the auto responder to send"
          }
        }
      },
      "AutoCampaignSendResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failed"
            ],
            "description": "Operation status"
          },
          "message": {
            "type": "string",
            "description": "Result message"
          },
          "mid": {
            "type": "string",
            "description": "Message ID (present on success)"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "failed"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "SMS Campaigns",
      "description": "Operations related to SMS Campaigns"
    }
  ]
}