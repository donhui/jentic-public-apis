{
  "openapi": "3.0.3",
  "info": {
    "title": "Localize API",
    "description": "API for managing localization projects, phrases, and labels on the Localize platform.",
    "version": "2.0",
    "contact": {
      "name": "Localize",
      "url": "https://developers.localizejs.com/docs/introduction-to-localize"
    }
  },
  "servers": [
    {
      "url": "https://api.localizejs.com/v2.0",
      "description": "Production"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Projects",
      "description": "Manage localization projects"
    },
    {
      "name": "Phrases",
      "description": "Manage phrases within projects"
    },
    {
      "name": "Labels",
      "description": "Manage labels within projects"
    }
  ],
  "paths": {
    "/projects": {
      "post": {
        "tags": ["Projects"],
        "summary": "Create project",
        "operationId": "createProject",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProjectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "tags": ["Projects"],
        "summary": "List all projects",
        "operationId": "listProjects",
        "responses": {
          "200": {
            "description": "List of projects retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/projects/{projectKey}": {
      "get": {
        "tags": ["Projects"],
        "summary": "Get project details",
        "operationId": "getProject",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Project details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/projects/{projectKey}/phrases": {
      "post": {
        "tags": ["Phrases"],
        "summary": "Create phrases",
        "description": "Create new phrases in a project. Maximum 500 phrases per call.",
        "operationId": "createPhrases",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePhrasesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phrases created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhrasesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "tags": ["Phrases"],
        "summary": "Get phrases with filters",
        "operationId": "getPhrases",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKey"
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of phrases to return.",
            "schema": {
              "type": "integer",
              "default": 1000,
              "maximum": 5000
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of phrases to skip for pagination.",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Filter by phrase state.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by phrase type.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "languageCode",
            "in": "query",
            "description": "Filter by language code.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ids",
            "in": "query",
            "description": "Comma-separated list of phrase IDs.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phraseKeys",
            "in": "query",
            "description": "Comma-separated list of phrase keys.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "labels",
            "in": "query",
            "description": "Comma-separated list of labels.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "context",
            "in": "query",
            "description": "Filter by context.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "phraseHistory",
            "in": "query",
            "description": "Include phrase history.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "translationState",
            "in": "query",
            "description": "Filter by translation state.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search term to filter phrases.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exactMatch",
            "in": "query",
            "description": "Whether to use exact matching for search.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Phrases retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhrasesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "put": {
        "tags": ["Phrases"],
        "summary": "Edit phrases",
        "description": "Edit existing phrases in a project. Maximum 500 phrases per call.",
        "operationId": "editPhrases",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditPhrasesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phrases updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhrasesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/projects/{projectKey}/phrases/{phraseId}/add-screenshots": {
      "put": {
        "tags": ["Phrases"],
        "summary": "Add screenshots to a phrase",
        "operationId": "addScreenshots",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKey"
          },
          {
            "name": "phraseId",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the phrase.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddScreenshotsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Screenshots added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/projects/{projectKey}/phrases/{id}": {
      "delete": {
        "tags": ["Phrases"],
        "summary": "Delete a phrase",
        "operationId": "deletePhrase",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKey"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the phrase to delete.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeletePhraseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phrase deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/projects/{projectKey}/labels": {
      "post": {
        "tags": ["Labels"],
        "summary": "Create a label",
        "operationId": "createLabel",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLabelRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Label created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LabelResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "tags": ["Labels"],
        "summary": "Get labels",
        "operationId": "getLabels",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKey"
          },
          {
            "name": "names",
            "in": "query",
            "description": "Comma-separated list of label names to filter by.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Labels retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LabelListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Provide your API token as a Bearer token in the Authorization header."
      }
    },
    "parameters": {
      "ProjectKey": {
        "name": "projectKey",
        "in": "path",
        "required": true,
        "description": "The unique key identifying the project.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Meta": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "example": 200
          },
          "success": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "ErrorMeta": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "CreateProjectRequest": {
        "type": "object",
        "required": ["name", "sourceLanguage", "type", "activeLanguages"],
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the project."
          },
          "sourceLanguage": {
            "type": "string",
            "description": "The source language code for the project."
          },
          "type": {
            "type": "string",
            "enum": ["web", "file", "document"],
            "description": "The project type."
          },
          "activeLanguages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of active target language codes."
          },
          "description": {
            "type": "string",
            "description": "A description of the project."
          },
          "url": {
            "type": "string",
            "description": "The URL associated with the project."
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sourceLanguage": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["web", "file", "document"]
          },
          "activeLanguages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "projectKey": {
            "type": "string"
          }
        }
      },
      "ProjectResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "$ref": "#/components/schemas/Project"
          }
        }
      },
      "ProjectListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Project"
            }
          }
        }
      },
      "CreatePhraseItem": {
        "type": "object",
        "required": ["phrase", "type", "state"],
        "properties": {
          "phrase": {
            "type": "string",
            "description": "The phrase text."
          },
          "phraseKey": {
            "type": "string",
            "description": "An optional unique key for the phrase."
          },
          "type": {
            "type": "string",
            "enum": ["phrase", "glossary"],
            "description": "The type of the phrase."
          },
          "state": {
            "type": "string",
            "enum": ["active", "pending"],
            "description": "The state of the phrase."
          },
          "context": {
            "type": "string",
            "description": "Contextual information for the phrase."
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels associated with the phrase."
          }
        }
      },
      "CreatePhrasesRequest": {
        "type": "object",
        "required": ["phrases"],
        "properties": {
          "phrases": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreatePhraseItem"
            },
            "maxItems": 500,
            "description": "Array of phrases to create. Maximum 500 per call."
          }
        }
      },
      "EditPhraseItem": {
        "type": "object",
        "properties": {
          "phrase": {
            "type": "string",
            "description": "The updated phrase text."
          },
          "id": {
            "type": "string",
            "description": "The phrase ID. Either id or phraseKey is required."
          },
          "phraseKey": {
            "type": "string",
            "description": "The phrase key. Either id or phraseKey is required."
          },
          "state": {
            "type": "string",
            "description": "The updated state of the phrase."
          },
          "context": {
            "type": "string",
            "description": "Updated contextual information."
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Updated labels."
          }
        }
      },
      "EditPhrasesRequest": {
        "type": "object",
        "required": ["phrases"],
        "properties": {
          "phrases": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EditPhraseItem"
            },
            "maxItems": 500,
            "description": "Array of phrases to edit. Maximum 500 per call."
          }
        }
      },
      "Phrase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "phrase": {
            "type": "string"
          },
          "phraseKey": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["phrase", "glossary"]
          },
          "state": {
            "type": "string",
            "enum": ["active", "pending"]
          },
          "context": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PhrasesResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Phrase"
            }
          }
        }
      },
      "AddScreenshotsRequest": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of screenshot file URLs or paths."
          }
        }
      },
      "DeletePhraseRequest": {
        "type": "object",
        "properties": {
          "bypassTrash": {
            "type": "boolean",
            "default": false,
            "description": "If true, permanently deletes the phrase instead of moving it to trash."
          }
        }
      },
      "CreateLabelRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the label."
          },
          "description": {
            "type": "string",
            "description": "A description of the label."
          },
          "rules": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "autoapprove",
                "neverdeprecate",
                "excludeOrderTranslation",
                "excludeMachineTranslation"
              ]
            },
            "description": "Rules to apply to the label."
          }
        }
      },
      "Label": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "rules": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "autoapprove",
                "neverdeprecate",
                "excludeOrderTranslation",
                "excludeMachineTranslation"
              ]
            }
          }
        }
      },
      "LabelResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "$ref": "#/components/schemas/Label"
          }
        }
      },
      "LabelListResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Label"
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/ErrorMeta"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request. The request was malformed or missing required parameters.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized. The API token is missing or invalid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
