{
  "openapi": "3.0.3",
  "info": {
    "title": "Phare API",
    "description": "Interact programmatically with the Phare platform for uptime monitoring, incident management, and status pages. Supports project-scoped and organization-scoped API keys. Rate limited to 100 calls per minute across the organization.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.phare.io/api-reference/introduction"
  },
  "servers": [
    {
      "url": "https://api.phare.io"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getApiInfo",
        "summary": "Get API info",
        "description": "Get basic API information including version and documentation links.",
        "tags": ["Platform"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key"
          },
          "403": {
            "description": "Forbidden - insufficient permissions"
          }
        }
      }
    },
    "/uptime/monitors": {
      "get": {
        "operationId": "listMonitors",
        "summary": "List monitors",
        "description": "Get a paginated list of uptime monitors. Organization-scoped API keys require a project selection header.",
        "tags": ["Uptime Monitors"],
        "parameters": [
          {
            "name": "X-Phare-Project-Id",
            "in": "header",
            "description": "Project ID (required for organization-scoped API keys).",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "X-Phare-Project-Slug",
            "in": "header",
            "description": "Project slug (alternative to project ID).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (max 100).",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MonitorListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "429": {
            "description": "Rate limit exceeded (100 calls per minute)"
          }
        }
      },
      "post": {
        "operationId": "createMonitor",
        "summary": "Create a monitor",
        "description": "Create a new uptime monitor.",
        "tags": ["Uptime Monitors"],
        "parameters": [
          {
            "name": "X-Phare-Project-Id",
            "in": "header",
            "description": "Project ID (required for organization-scoped API keys).",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MonitorCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Monitor created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Monitor"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation errors"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/uptime/monitors/{id}": {
      "get": {
        "operationId": "getMonitor",
        "summary": "Get a monitor",
        "description": "Retrieve details of a specific uptime monitor.",
        "tags": ["Uptime Monitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Monitor ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "X-Phare-Project-Id",
            "in": "header",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Monitor"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      },
      "post": {
        "operationId": "updateMonitor",
        "summary": "Update a monitor",
        "description": "Update an existing uptime monitor.",
        "tags": ["Uptime Monitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Monitor ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "X-Phare-Project-Id",
            "in": "header",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MonitorCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Monitor updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Monitor"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      },
      "delete": {
        "operationId": "deleteMonitor",
        "summary": "Delete a monitor",
        "description": "Delete an uptime monitor.",
        "tags": ["Uptime Monitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Monitor ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "X-Phare-Project-Id",
            "in": "header",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Monitor deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/uptime/monitors/{id}/pause": {
      "post": {
        "operationId": "pauseMonitor",
        "summary": "Pause a monitor",
        "description": "Pause an active uptime monitor. It will stop being checked until resumed.",
        "tags": ["Uptime Monitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Monitor ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "X-Phare-Project-Id",
            "in": "header",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Monitor paused"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/uptime/monitors/{id}/resume": {
      "post": {
        "operationId": "resumeMonitor",
        "summary": "Resume a monitor",
        "description": "Resume a previously paused uptime monitor.",
        "tags": ["Uptime Monitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Monitor ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "X-Phare-Project-Id",
            "in": "header",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Monitor resumed"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "description": "Get a list of projects in the organization. Only available with organization-scoped API keys.",
        "tags": ["Projects"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Project"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/uptime/incidents": {
      "get": {
        "operationId": "listIncidents",
        "summary": "List incidents",
        "description": "Get a paginated list of uptime incidents.",
        "tags": ["Incidents"],
        "parameters": [
          {
            "name": "X-Phare-Project-Id",
            "in": "header",
            "description": "Project ID (required for organization-scoped API keys).",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key from the Phare control panel. Can be project-scoped (acts on its scoped project) or organization-scoped (requires project selection headers)."
      }
    },
    "schemas": {
      "ApiInfo": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "API title."
          },
          "version": {
            "type": "string",
            "description": "API version."
          },
          "support": {
            "type": "string",
            "description": "Support contact URL."
          },
          "website": {
            "type": "string",
            "description": "Website URL."
          },
          "documentation": {
            "type": "string",
            "description": "Documentation URL."
          }
        }
      },
      "Monitor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Monitor ID."
          },
          "project_id": {
            "type": "integer",
            "description": "Project this monitor belongs to."
          },
          "name": {
            "type": "string",
            "description": "Monitor display name."
          },
          "protocol": {
            "type": "string",
            "enum": ["http", "tcp", "ping"],
            "description": "Monitoring protocol."
          },
          "request": {
            "$ref": "#/components/schemas/MonitorRequest"
          },
          "interval": {
            "type": "integer",
            "description": "Check interval in seconds."
          },
          "timeout": {
            "type": "integer",
            "description": "Timeout in milliseconds."
          },
          "incident_confirmations": {
            "type": "integer",
            "description": "Number of consecutive failures before creating an incident."
          },
          "recovery_confirmations": {
            "type": "integer",
            "description": "Number of consecutive successes before resolving an incident."
          },
          "regions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Monitoring regions."
          },
          "status": {
            "type": "string",
            "enum": ["fetching", "up", "down", "paused"],
            "description": "Current monitor status."
          },
          "paused": {
            "type": "boolean",
            "description": "Whether the monitor is paused."
          },
          "response_time": {
            "type": "integer",
            "description": "Latest response time in milliseconds."
          },
          "success_assertions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SuccessAssertion"
            },
            "description": "Conditions that must be met for a check to be considered successful."
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MonitorRequest": {
        "type": "object",
        "description": "Request configuration for the monitor.",
        "properties": {
          "method": {
            "type": "string",
            "enum": ["HEAD", "GET", "POST", "PUT", "PATCH", "DELETE"],
            "description": "HTTP method to use."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to monitor."
          },
          "tls_skip_verify": {
            "type": "boolean",
            "description": "Skip TLS certificate verification."
          },
          "body": {
            "type": "string",
            "description": "Request body content."
          },
          "follow_redirects": {
            "type": "boolean",
            "description": "Whether to follow HTTP redirects."
          },
          "user_agent_secret": {
            "type": "string",
            "description": "Secret string sent in the User-Agent header for verification."
          },
          "headers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            },
            "description": "Custom HTTP headers."
          }
        }
      },
      "MonitorCreateRequest": {
        "type": "object",
        "required": ["name", "protocol", "request"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Monitor display name."
          },
          "protocol": {
            "type": "string",
            "enum": ["http", "tcp", "ping"],
            "description": "Monitoring protocol."
          },
          "request": {
            "$ref": "#/components/schemas/MonitorRequest"
          },
          "interval": {
            "type": "integer",
            "description": "Check interval in seconds."
          },
          "timeout": {
            "type": "integer",
            "description": "Timeout in milliseconds."
          },
          "incident_confirmations": {
            "type": "integer",
            "description": "Failures before incident."
          },
          "recovery_confirmations": {
            "type": "integer",
            "description": "Successes before recovery."
          },
          "regions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "success_assertions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SuccessAssertion"
            }
          }
        }
      },
      "SuccessAssertion": {
        "type": "object",
        "description": "Condition that must be met for a check to be successful.",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["status_code", "response_time", "body"],
            "description": "Type of assertion."
          },
          "operator": {
            "type": "string",
            "enum": ["in", "not_in", "eq", "ne", "gt", "lt", "contains", "not_contains"],
            "description": "Comparison operator."
          },
          "value": {
            "type": "string",
            "description": "Expected value for the assertion."
          }
        }
      },
      "MonitorListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Monitor"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          },
          "links": {
            "$ref": "#/components/schemas/PaginationLinks"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer"
          },
          "from": {
            "type": "integer"
          },
          "to": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "path": {
            "type": "string"
          }
        }
      },
      "PaginationLinks": {
        "type": "object",
        "properties": {
          "first": {
            "type": "string"
          },
          "last": {
            "type": "string"
          },
          "prev": {
            "type": "string",
            "nullable": true
          },
          "next": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
