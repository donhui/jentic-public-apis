{
  "openapi": "3.0.3",
  "info": {
    "title": "Wompi Payments API",
    "version": "1.0.0",
    "description": "Wompi payment processing API for Colombia. Supports credit/debit cards, Nequi, PSE, Bancolombia transfers, Bancolombia QR, Daviplata, and other local payment methods.",
    "x-jentic-source-url": "https://docs.wompi.co/en/docs/colombia/metodos-de-pago/"
  },
  "servers": [
    {
      "url": "https://production.wompi.co",
      "description": "Production server"
    },
    {
      "url": "https://sandbox.wompi.co",
      "description": "Sandbox server"
    }
  ],
  "paths": {
    "/v1/tokens/cards": {
      "post": {
        "operationId": "tokenizecard",
        "summary": "Tokenize a credit or debit card",
        "description": "Creates a token for a credit or debit card. Use the public key for authentication. Never store card data directly.",
        "tags": [
          "Tokenization"
        ],
        "security": [
          {
            "publicKey": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CardTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card tokenized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CardTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/transactions": {
      "post": {
        "operationId": "createtransaction",
        "summary": "Create a payment transaction",
        "description": "Creates a new payment transaction. Supports multiple payment method types including CARD, NEQUI, PSE, BANCOLOMBIA_TRANSFER, BANCOLOMBIA_QR, BANCOLOMBIA_COLLECT, PCOL, BANCOLOMBIA_BNPL, DAVIPLATA, and SU_PLUS.",
        "tags": [
          "Transactions"
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTransactionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/transactions/{transaction_id}": {
      "get": {
        "operationId": "gettransaction",
        "summary": "Get transaction status",
        "description": "Retrieves the current status and details of a transaction.",
        "tags": [
          "Transactions"
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "name": "transaction_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique transaction identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/pse/financial_institutions": {
      "get": {
        "operationId": "listpsefinancialinstitutions",
        "summary": "List PSE financial institutions",
        "description": "Returns a list of Colombian financial institutions (banks) available for PSE transactions.",
        "tags": [
          "PSE"
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of financial institutions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FinancialInstitutionsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CardTokenRequest": {
        "type": "object",
        "required": [
          "number",
          "cvc",
          "exp_month",
          "exp_year",
          "card_holder"
        ],
        "properties": {
          "number": {
            "type": "string",
            "description": "Card number (13-19 digits)",
            "minLength": 13,
            "maxLength": 19
          },
          "cvc": {
            "type": "string",
            "description": "Card verification code (3-4 digits)",
            "minLength": 3,
            "maxLength": 4
          },
          "exp_month": {
            "type": "string",
            "description": "Card expiration month (2 digits)",
            "minLength": 2,
            "maxLength": 2
          },
          "exp_year": {
            "type": "string",
            "description": "Card expiration year (2 digits)",
            "minLength": 2,
            "maxLength": 2
          },
          "card_holder": {
            "type": "string",
            "description": "Cardholder name"
          }
        }
      },
      "CardTokenResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "CREATED"
            ],
            "description": "Token creation status"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Generated token identifier"
              },
              "created_at": {
                "type": "string",
                "format": "date-time",
                "description": "Token creation timestamp"
              },
              "brand": {
                "type": "string",
                "enum": [
                  "VISA",
                  "MASTERCARD",
                  "AMEX"
                ],
                "description": "Card brand"
              },
              "name": {
                "type": "string",
                "description": "Cardholder name"
              },
              "last_four": {
                "type": "string",
                "description": "Last four digits of the card"
              },
              "bin": {
                "type": "string",
                "description": "Card BIN number"
              },
              "exp_year": {
                "type": "string",
                "description": "Expiration year"
              },
              "exp_month": {
                "type": "string",
                "description": "Expiration month"
              },
              "card_holder": {
                "type": "string",
                "description": "Cardholder name"
              },
              "expires_at": {
                "type": "string",
                "format": "date-time",
                "description": "Token expiration timestamp"
              }
            }
          }
        }
      },
      "CreateTransactionRequest": {
        "type": "object",
        "required": [
          "amount_in_cents",
          "currency",
          "reference",
          "payment_method_type",
          "payment_method",
          "customer_email",
          "acceptance_token"
        ],
        "properties": {
          "amount_in_cents": {
            "type": "integer",
            "description": "Transaction amount in cents (COP)"
          },
          "currency": {
            "type": "string",
            "enum": [
              "COP"
            ],
            "description": "Currency code"
          },
          "reference": {
            "type": "string",
            "description": "Unique transaction reference"
          },
          "payment_method_type": {
            "type": "string",
            "enum": [
              "CARD",
              "NEQUI",
              "PSE",
              "BANCOLOMBIA_TRANSFER",
              "BANCOLOMBIA_QR",
              "BANCOLOMBIA_COLLECT",
              "PCOL",
              "BANCOLOMBIA_BNPL",
              "DAVIPLATA",
              "SU_PLUS"
            ],
            "description": "Payment method type"
          },
          "payment_method": {
            "$ref": "#/components/schemas/PaymentMethod"
          },
          "customer_email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address"
          },
          "customer_data": {
            "$ref": "#/components/schemas/CustomerData"
          },
          "acceptance_token": {
            "type": "string",
            "description": "Acceptance token (mandatory)"
          },
          "payment_source_id": {
            "type": "string",
            "description": "Payment source ID for recurring payments"
          },
          "parent_transaction_id": {
            "type": "string",
            "description": "Parent transaction ID for PCOL second payment"
          },
          "redirect_url": {
            "type": "string",
            "description": "URL to redirect after payment"
          }
        }
      },
      "PaymentMethod": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Payment method type"
          },
          "installments": {
            "type": "integer",
            "description": "Number of installments (for CARD)"
          },
          "token": {
            "type": "string",
            "description": "Card token (for CARD)"
          },
          "phone_number": {
            "type": "string",
            "description": "Phone number (for NEQUI, DAVIPLATA)"
          },
          "user_type": {
            "type": "string",
            "description": "User type (for BANCOLOMBIA_TRANSFER)"
          },
          "payment_description": {
            "type": "string",
            "description": "Payment description (max 64 chars)",
            "maxLength": 64
          },
          "user_legal_id_type": {
            "type": "string",
            "enum": [
              "CC",
              "CE",
              "NIT"
            ],
            "description": "Legal ID type"
          },
          "user_legal_id": {
            "type": "string",
            "description": "Legal ID number"
          },
          "financial_institution_code": {
            "type": "string",
            "description": "Financial institution code (for PSE)"
          },
          "reference_one": {
            "type": "string",
            "description": "IP address for PSE fraud mitigation"
          },
          "reference_two": {
            "type": "string",
            "description": "Product open date for PSE"
          },
          "reference_three": {
            "type": "string",
            "description": "Beneficiary ID for PSE"
          }
        }
      },
      "CustomerData": {
        "type": "object",
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Customer phone number"
          },
          "full_name": {
            "type": "string",
            "description": "Customer full name"
          }
        }
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Transaction ID"
              },
              "status": {
                "type": "string",
                "enum": [
                  "PENDING",
                  "APPROVED",
                  "DECLINED",
                  "VOIDED",
                  "ERROR"
                ],
                "description": "Transaction status"
              },
              "reference": {
                "type": "string",
                "description": "Transaction reference"
              },
              "amount_in_cents": {
                "type": "integer",
                "description": "Amount in cents"
              },
              "currency": {
                "type": "string",
                "description": "Currency code"
              },
              "payment_method_type": {
                "type": "string",
                "description": "Payment method type used"
              },
              "payment_method": {
                "type": "object",
                "description": "Payment method details"
              },
              "processor_response_code": {
                "type": "string",
                "description": "Card processor response code"
              },
              "async_payment_url": {
                "type": "string",
                "description": "URL for async payment completion (when applicable)"
              },
              "redirect_url": {
                "type": "string",
                "description": "Redirect URL after payment"
              }
            }
          }
        }
      },
      "FinancialInstitutionsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "financial_institution_code": {
                  "type": "string",
                  "description": "Institution code"
                },
                "financial_institution_name": {
                  "type": "string",
                  "description": "Institution name"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "publicKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Public key for tokenization endpoints (Bearer pub_...)"
      },
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Private API key for transaction endpoints (Bearer prv_...)"
      }
    }
  },
  "tags": [
    {
      "name": "Tokenization",
      "description": "Card tokenization endpoints"
    },
    {
      "name": "Transactions",
      "description": "Payment transaction management"
    },
    {
      "name": "PSE",
      "description": "PSE bank transfer related endpoints"
    }
  ],
  "security": [
    {
      "publicKey": []
    }
  ]
}