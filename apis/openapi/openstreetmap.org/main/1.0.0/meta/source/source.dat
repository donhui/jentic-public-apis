{
  "openapi": "3.0.3",
  "info": {
    "title": "Nominatim Geocoding API",
    "description": "Nominatim is a geocoding API for OpenStreetMap data. It provides search (forward geocoding), reverse geocoding, and address lookup services.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://nominatim.org/release-docs/develop/api/Overview/"
  },
  "servers": [
    {
      "url": "https://nominatim.openstreetmap.org",
      "description": "Nominatim public API server"
    }
  ],
  "security": [],
  "tags": [
    {"name": "Geocoding", "description": "Forward and reverse geocoding operations"},
    {"name": "Lookup", "description": "Address lookup by OSM ID"},
    {"name": "Status", "description": "Server status"}
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchPlaces",
        "summary": "Search places",
        "description": "Search OSM objects by name, address, or type. Supports free-form and structured queries.",
        "tags": ["Geocoding"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Free-form query string to search for"
          },
          {
            "name": "amenity",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Name or type of POI (structured query)"
          },
          {
            "name": "street",
            "in": "query",
            "schema": {"type": "string"},
            "description": "House number and street name (structured query)"
          },
          {
            "name": "city",
            "in": "query",
            "schema": {"type": "string"},
            "description": "City name (structured query)"
          },
          {
            "name": "county",
            "in": "query",
            "schema": {"type": "string"},
            "description": "County name (structured query)"
          },
          {
            "name": "state",
            "in": "query",
            "schema": {"type": "string"},
            "description": "State name (structured query)"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Country name (structured query)"
          },
          {
            "name": "postalcode",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Postal code (structured query)"
          },
          {"$ref": "#/components/parameters/FormatParam"},
          {"$ref": "#/components/parameters/AddressDetailsParam"},
          {"$ref": "#/components/parameters/ExtraTagsParam"},
          {"$ref": "#/components/parameters/NameDetailsParam"},
          {"$ref": "#/components/parameters/AcceptLanguageParam"},
          {
            "name": "limit",
            "in": "query",
            "schema": {"type": "integer", "default": 10, "maximum": 40},
            "description": "Maximum number of results to return"
          },
          {
            "name": "countrycodes",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Comma-separated list of ISO 3166-1 alpha-2 country codes"
          },
          {
            "name": "layer",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["address", "poi", "railway", "natural", "manmade"]
            },
            "description": "Layer to search in"
          },
          {
            "name": "featureType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["country", "state", "city", "settlement"]
            },
            "description": "Restrict results to a specific feature type"
          },
          {
            "name": "viewbox",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Preferred area for results in format: x1,y1,x2,y2"
          },
          {
            "name": "bounded",
            "in": "query",
            "schema": {"type": "integer", "enum": [0, 1], "default": 0},
            "description": "Restrict results to viewbox area"
          },
          {
            "name": "exclude_place_ids",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Comma-separated list of place IDs to exclude"
          },
          {
            "name": "dedupe",
            "in": "query",
            "schema": {"type": "integer", "enum": [0, 1], "default": 1},
            "description": "Remove duplicate results"
          },
          {"$ref": "#/components/parameters/PolygonGeoJsonParam"},
          {"$ref": "#/components/parameters/PolygonThresholdParam"},
          {"$ref": "#/components/parameters/EmailParam"}
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Place"}
                }
              }
            }
          },
          "400": {"description": "Bad request"}
        }
      }
    },
    "/reverse": {
      "get": {
        "operationId": "reverseGeocode",
        "summary": "Reverse geocode",
        "description": "Search OSM objects by their location (coordinates to address).",
        "tags": ["Geocoding"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": {"type": "number", "format": "double"},
            "description": "Latitude in WGS84 projection"
          },
          {
            "name": "lon",
            "in": "query",
            "required": true,
            "schema": {"type": "number", "format": "double"},
            "description": "Longitude in WGS84 projection"
          },
          {"$ref": "#/components/parameters/FormatParam"},
          {"$ref": "#/components/parameters/AddressDetailsParam"},
          {"$ref": "#/components/parameters/ExtraTagsParam"},
          {"$ref": "#/components/parameters/NameDetailsParam"},
          {"$ref": "#/components/parameters/AcceptLanguageParam"},
          {
            "name": "zoom",
            "in": "query",
            "schema": {"type": "integer", "minimum": 0, "maximum": 18, "default": 18},
            "description": "Level of detail for the address (0=country, 18=building)"
          },
          {
            "name": "layer",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Comma-separated layers: address, poi, railway, natural, manmade"
          },
          {"$ref": "#/components/parameters/PolygonGeoJsonParam"},
          {"$ref": "#/components/parameters/PolygonThresholdParam"},
          {"$ref": "#/components/parameters/EmailParam"}
        ],
        "responses": {
          "200": {
            "description": "Reverse geocoding result",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Place"}
              }
            }
          },
          "400": {"description": "Bad request"}
        }
      }
    },
    "/lookup": {
      "get": {
        "operationId": "lookupAddress",
        "summary": "Address lookup",
        "description": "Look up address details for OSM objects by their ID. Maximum 50 IDs per request.",
        "tags": ["Lookup"],
        "parameters": [
          {
            "name": "osm_ids",
            "in": "query",
            "required": true,
            "schema": {"type": "string"},
            "description": "Comma-separated list of OSM IDs with type prefix (N=node, W=way, R=relation), e.g. N123,W456,R789"
          },
          {"$ref": "#/components/parameters/FormatParam"},
          {"$ref": "#/components/parameters/AddressDetailsParam"},
          {"$ref": "#/components/parameters/ExtraTagsParam"},
          {"$ref": "#/components/parameters/NameDetailsParam"},
          {"$ref": "#/components/parameters/AcceptLanguageParam"},
          {"$ref": "#/components/parameters/PolygonGeoJsonParam"},
          {"$ref": "#/components/parameters/PolygonThresholdParam"},
          {"$ref": "#/components/parameters/EmailParam"}
        ],
        "responses": {
          "200": {
            "description": "Lookup results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Place"}
                }
              }
            }
          },
          "400": {"description": "Bad request"}
        }
      }
    },
    "/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get server status",
        "description": "Query the status of the Nominatim server.",
        "tags": ["Status"],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["text", "json"],
              "default": "text"
            },
            "description": "Output format"
          }
        ],
        "responses": {
          "200": {
            "description": "Server status",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Status"}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {},
    "parameters": {
      "FormatParam": {
        "name": "format",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": ["xml", "json", "jsonv2", "geojson", "geocodejson"],
          "default": "jsonv2"
        },
        "description": "Output format"
      },
      "AddressDetailsParam": {
        "name": "addressdetails",
        "in": "query",
        "schema": {"type": "integer", "enum": [0, 1], "default": 0},
        "description": "Include a breakdown of the address into elements"
      },
      "ExtraTagsParam": {
        "name": "extratags",
        "in": "query",
        "schema": {"type": "integer", "enum": [0, 1], "default": 0},
        "description": "Include additional information in the result if available"
      },
      "NameDetailsParam": {
        "name": "namedetails",
        "in": "query",
        "schema": {"type": "integer", "enum": [0, 1], "default": 0},
        "description": "Include a list of alternative names in the results"
      },
      "AcceptLanguageParam": {
        "name": "accept-language",
        "in": "query",
        "schema": {"type": "string"},
        "description": "Preferred language order for showing search results as a browser Accept-Language string"
      },
      "PolygonGeoJsonParam": {
        "name": "polygon_geojson",
        "in": "query",
        "schema": {"type": "integer", "enum": [0, 1], "default": 0},
        "description": "Output geometry as GeoJSON"
      },
      "PolygonThresholdParam": {
        "name": "polygon_threshold",
        "in": "query",
        "schema": {"type": "number", "format": "float", "default": 0.0},
        "description": "Simplification threshold for polygon output"
      },
      "EmailParam": {
        "name": "email",
        "in": "query",
        "schema": {"type": "string", "format": "email"},
        "description": "Contact email for the API user (for heavy usage)"
      }
    },
    "schemas": {
      "Place": {
        "type": "object",
        "properties": {
          "place_id": {"type": "integer"},
          "licence": {"type": "string"},
          "osm_type": {"type": "string", "enum": ["node", "way", "relation"]},
          "osm_id": {"type": "integer"},
          "lat": {"type": "string"},
          "lon": {"type": "string"},
          "display_name": {"type": "string"},
          "category": {"type": "string"},
          "type": {"type": "string"},
          "importance": {"type": "number"},
          "place_rank": {"type": "integer"},
          "addresstype": {"type": "string"},
          "name": {"type": "string"},
          "boundingbox": {
            "type": "array",
            "items": {"type": "string"}
          },
          "address": {"$ref": "#/components/schemas/Address"}
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "house_number": {"type": "string"},
          "road": {"type": "string"},
          "suburb": {"type": "string"},
          "city": {"type": "string"},
          "county": {"type": "string"},
          "state": {"type": "string"},
          "postcode": {"type": "string"},
          "country": {"type": "string"},
          "country_code": {"type": "string"}
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "status": {"type": "integer"},
          "message": {"type": "string"},
          "data_updated": {"type": "string", "format": "date-time"},
          "software_version": {"type": "string"},
          "database_version": {"type": "string"}
        }
      }
    }
  }
}