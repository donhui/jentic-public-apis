  "info": {
    "title": "Connect",
    "version": "0.01-beta",
    "x-jentic-source-url": "https://app.pdq.com/v1/openapi"
  },
  "openapi": "3.0.3",
  "paths": {
    "/v1/api/deployments": {
      "post": {
        "callbacks": {},
        "operationId": "HoustonWeb.DeploymentsApiController.create",
        "parameters": [
          {
            "description": "Package ID or Package Version ID",
            "example": "pkg_123abc",
            "in": "query",
            "name": "package",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Comma-delimited Device IDs or Group IDs",
            "example": "grp_123abc,dvc_123abc",
            "in": "query",
            "name": "targets",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No content response when deployments are successfully created"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Forbidden"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Not found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Invalid or missing IDs"
          }
        },
        "summary": "Deploy a package version to target devices or groups",
        "tags": []
      }
    },
    "/v1/api/devices": {
      "get": {
        "callbacks": {},
        "operationId": "HoustonWeb.DevicesApiController.list",
        "parameters": [
          {
            "description": "Comma-separated list of related objects to include in the response.\n\n**Available includes:**\n\n- disks\n- drivers\n- features\n- networking\n- processors\n- updates\n- software\n- activeDirectory\n- activeDirectoryGroups\n- customFields\n",
            "example": "networking,processors",
            "in": "query",
            "name": "includes",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter by group ID",
            "in": "query",
            "name": "group",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Page size returned per request (max: 250, default: 100)",
            "example": 50,
            "in": "query",
            "name": "pageSize",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Page count per size (default: 1)",
            "example": "1",
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Sort by a field in camelCase.\n\nBy default, a field name sorts ascending. Append `Asc` or `Desc` to explicitly set the direction.\n\n**Examples:**\n\n| Value              | Direction  |\n|--------------------|------------|\n| `insertedAt`       | Ascending  |\n| `insertedAtAsc`    | Ascending  |\n| `insertedAtDesc`   | Descending |\n",
            "example": "insertedAt",
            "in": "query",
            "name": "sort",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/DeviceSort"
            }
          },
          {
            "description": "Filter devices by one or more fields. Each field type supports different operators.\n\n---\n\n### String Filters\n\nString filter values match exactly unless a supported operator is provided.\n\n| Operator | Syntax | Example | Matches |\n|----------|--------|---------|---------|\n| Exact | `value` | `LAB01` | Equals \"LAB01\" |\n| Starts with | `^value` | `^LAB` | Starts with \"LAB\" |\n| Contains | `~value` | `~server` | Contains \"server\" |\n| Ends with | `value$` | `01$` | Ends with \"01\" |\n\n\n**Applicable fields:** `architecture`, `biosAssetTag`, `biosManufacturer`, `biosVersion`, `chassis`, `currentUser`, `dotNetVersions`, `family`, `hostname`, `lastUser`, `lastUserShortName`, `macAddress`, `manufacturer`, `model`, `name`, `os`, `osFullName`, `osProductType`, `osVersion`, `powershellVersion`, `publicIpAddress`, `serialNumber`, `servicePack`, `sku`, `systemVersion`, `timezone`\n\n---\n\n### Datetime Filters\n\nDatetime filter values accept UTC ISO 8601 datetimes (e.g. `2024-01-01T00:00:00.000000Z`).\n\n| Operator | Syntax | Description |\n|----------|--------|-------------|\n| Exact | `value` | Matches the exact datetime |\n| Before | `<value` | Everything before the given datetime |\n| After | `>value` | Everything after the given datetime |\n\n\n**Applicable fields:** `insertedAt`, `lastBootUpTime`, `lastSeenAt`, `osInstallDate`, `updatedAt`\n\n---\n\n### Integer Filters\n\nInteger filter values match exactly unless a supported operator is provided.\n\n| Operator | Syntax | Description |\n|----------|--------|-------------|\n| Exact | `value` | Matches the exact value |\n| Less than | `<value` | Values less than given |\n| Greater than | `>value` | Values greater than given |\n| Less than or equal | `<=value` | Values less than or equal to |\n| Greater than or equal | `>=value` | Values greater than or equal to |\n\n\n**Applicable fields:** `freePercent`, `memory`\n\n---\n\n### Boolean Filters\n\nBoolean filter values accept `true` or `false` strings for exact matching.\n\n\n**Applicable fields:** `requireReboot`, `smbVersionOne`\n",
            "in": "query",
            "name": "filter",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/DeviceFilter"
            },
            "style": "deepObject"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DevicesResponse"
                }
              }
            },
            "description": "Devices response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Forbidden"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Invalid params"
          }
        },
        "summary": "List devices",
        "tags": []
      }
    },
    "/v1/api/devices/{device_id}": {
      "get": {
        "callbacks": {},
        "operationId": "HoustonWeb.DevicesApiController.get",
        "parameters": [
          {
            "description": "Device ID",
            "example": "dvc_123abc",
            "in": "path",
            "name": "device_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceResponse"
                }
              }
            },
            "description": "Device response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Forbidden"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Not found"
          }
        },
        "summary": "Get a device",
        "tags": []
      }
    },
    "/v1/api/groups": {
      "get": {
        "callbacks": {},
        "operationId": "HoustonWeb.GroupsApiController.list",
        "parameters": [
          {
            "description": "Page size returned per request (max: 100, default: 100)",
            "example": "50",
            "in": "query",
            "name": "pageSize",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Page count per size (default: 1)",
            "example": "1",
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Sort by a field in camel case. By default a field name sorts with \"Asc\". Add the suffix \"Desc\" to sort by that field in descending order.\n\nFor example:\n\n- `insertedAt` and `insertedAtAsc` sort by ascending\n- `insertedAtDesc` sorts by descending\n",
            "example": "insertedAt",
            "in": "query",
            "name": "sort",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/GroupSort"
            }
          },
          {
            "description": "String filter values match exactly unless a supported operator is provided.\n\n| Operator | Syntax | Example | Matches |\n|----------|--------|---------|---------|\n| Exact | `value` | `LAB01` | Equals \"LAB01\" |\n| Starts with | `^value` | `^LAB` | Starts with \"LAB\" |\n| Contains | `~value` | `~server` | Contains \"server\" |\n| Ends with | `value$` | `01$` | Ends with \"01\" |\n\n\nValid string filter keys: id, name, source, type\n\nDatetime filter values accept UTC ISO 8601 datetimes (e.g. `2024-01-01T00:00:00.000000Z`).\n\n| Operator | Syntax | Description |\n|----------|--------|-------------|\n| Exact | `value` | Matches the exact datetime |\n| Before | `<value` | Everything before the given datetime |\n| After | `>value` | Everything after the given datetime |\n\n\nValid filter keys: insertedAt\n",
            "in": "query",
            "name": "filter",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/GroupFilter"
            },
            "style": "deepObject"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupsResponse"
                }
              }
            },
            "description": "Groups response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Forbidden"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsResponse"
                }
              }
            },
            "description": "Invalid params"
          }
        },
        "summary": "List groups",
        "tags": []
      }
    },
    "/v1/api/packages": {
      "get": {
        "callbacks": {},
        "operationId": "HoustonWeb.PackagesApiController.list",
        "parameters": [
          {
            "description": "Page size returned per request (max: 100, default: 100)",
            "example": "50",
            "in": "query",
            "name": "pageSize",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Page count per size (default: 1)",
            "example": "1",
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Sort by a field in camel case. By default a field name sorts with \"Asc\". Add the suffix \"Desc\" to sort by that field in descending order.\n\nFor example:\n\n- `name` and `nameAsc` sort by ascending\n- `nameDesc` sorts by descending\n",
