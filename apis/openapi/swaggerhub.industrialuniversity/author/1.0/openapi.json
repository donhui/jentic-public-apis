                  "biography": {
                    "type": "string",
                    "example": "Nh\u00e0 v\u0103n n\u1ed5i ti\u1ebfng - Updated"
                  },
                  "birthYear": {
                    "type": "integer",
                    "example": 1980
                  },
                  "nationality": {
                    "type": "string",
                    "example": "Vi\u1ec7t Nam"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
