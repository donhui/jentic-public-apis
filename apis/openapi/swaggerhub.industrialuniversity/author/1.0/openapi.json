  "paths": {
    "/api/authors": {
      "get": {
        "summary": "L\u1ea5y t\u1ea5t c\u1ea3 t\u00e1c gi\u1ea3 (c\u00f3 ph\u00e2n trang)",
        "description": "L\u1ea5y danh s\u00e1ch t\u1ea5t c\u1ea3 t\u00e1c gi\u1ea3 v\u1edbi ph\u00e2n trang v\u00e0 s\u1eafp x\u1ebfp",
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "in": "query",
            "name": "size",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "in": "query",
            "name": "sortByName",
            "schema": {
              "type": "string",
              "default": "asc"
            }
          },
          {
            "in": "query",
            "name": "sortByBirthYear",
            "schema": {
              "type": "string",
              "default": "desc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Danh s\u00e1ch t\u00e1c gi\u1ea3 tr\u1ea3 v\u1ec1"
          }
        }
      },
      "post": {
        "summary": "ADMIN - T\u1ea1o t\u00e1c gi\u1ea3 m\u1edbi",
        "description": "ADMIN: T\u1ea1o t\u00e1c gi\u1ea3 m\u1edbi",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Nguy\u1ec5n V\u0103n A"
                  },
                  "biography": {
                    "type": "string",
                    "example": "Nh\u00e0 v\u0103n n\u1ed5i ti\u1ebfng"
                  },
                  "birthYear": {
                    "type": "integer",
                    "example": 1980
                  },
                  "nationality": {
                    "type": "string",
                    "example": "Vi\u1ec7t Nam"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "T\u00e1c gi\u1ea3 \u0111\u01b0\u1ee3c t\u1ea1o th\u00e0nh c\u00f4ng"
          }
        }
      }
    },
