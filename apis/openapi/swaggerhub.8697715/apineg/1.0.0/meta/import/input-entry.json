{
  "openapi": "3.0.0",
  "info": {
    "title": "Credit APIneg",
    "description": "API for managing credit applications",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/8697715/APIneg/1.0.0/swagger.json",
