{
  "openapi": "3.0.0",
  "info": {
    "title": "Credit API",
    "description": "API for managing credit applications",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/8697715/API/1.0.0/swagger.json",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://example.com/credit-api"
    }
  ],
  "paths": {
    "/credit-application": {
      "post": {
        "summary": "Создание новой заявки на кредит",
        "description": "Создает новую заявку на получение кредита",
        "operationId": "createCreditApplication",
        "tags": [
          "Credit Application"
        ],
        "requestBody": {
          "description": "Данные заявки на кредит",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreditApplication"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Заявка создана успешно",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditApplicationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/credit-application/{id}": {
      "get": {
        "summary": "Получение информации о заявке на кредит",
        "description": "Возвращает информацию о заявке по ее идентификатору",
        "operationId": "getCreditApplication",
        "tags": [
          "Credit Application"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Идентификатор заявки"
          }
        ],
        "responses": {
          "200": {
            "description": "Информация о заявке",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditApplicationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/credit-offer": {
      "post": {
        "summary": "Создание кредитного предложения",
        "description": "Создает кредитное предложение для клиента",
        "operationId": "createCreditOffer",
        "tags": [
          "Credit Offer"
        ],
        "requestBody": {
          "description": "Данные кредитного предложения",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreditOffer"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Предложение создано успешно",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditOfferResponse"
                }
              }
            }
          }
        }
      }
    },
    "/credit-signature": {
      "post": {
        "summary": "Подписание кредитного договора",
        "description": "Подписывает кредитный договор",
        "operationId": "signCreditAgreement",
        "tags": [
          "Credit Agreement"
        ],
        "requestBody": {
          "description": "Данные для подписания договора",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreditSignature"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Договор подписан успешно",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditSignatureResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreditApplication": {
        "type": "object",
        "properties": {
          "client_id": {
            "type": "integer",
            "description": "Идентификатор клиента"
          },
          "amount": {
            "type": "integer",
            "description": "Сумма кредита"
          },
          "credit_term": {
            "type": "integer",
            "description": "Срок кредита"
          },
          "interest_rate": {
            "type": "number",
            "description": "Процентная ставка"
          }
        }
      },
      "CreditApplicationResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Идентификатор заявки"
          },
          "client_id": {
            "type": "integer",
            "description": "Идентификатор клиента"
          },
          "amount": {
            "type": "integer",
            "description": "Сумма кредита"
          },
          "status": {
            "type": "string",
            "description": "Статус заявки"
          }
        }
      },
      "CreditOffer": {
        "type": "object",
        "properties": {
          "client_id": {
            "type": "integer",
            "description": "Идентификатор клиента"
          },
          "offer_details": {
            "type": "object",
            "properties": {
              "product_code": {
                "type": "string",
                "description": "Код кредитного продукта"
              },
              "loan_product": {
                "type": "string",
                "description": "Название кредитного продукта"
              }
            }
          }
        }
      },
      "CreditOfferResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Идентификатор предложения"
          },
          "client_id": {
            "type": "integer",
            "description": "Идентификатор клиента"
          },
          "offer_details": {
            "type": "object",
            "properties": {
              "product_code": {
                "type": "string",
                "description": "Код кредитного продукта"
              }
            }
          }
        }
      },
      "CreditSignature": {
        "type": "object",
        "properties": {
          "offer_id": {
            "type": "integer",
            "description": "Идентификатор кредитного предложения"
          },
          "client_signature": {
            "type": "string",
            "description": "Подпись клиента"
          }
        }
      },
      "CreditSignatureResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Успешность подписания договора"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Credit Agreement"
    },
    {
      "name": "Credit Application"
    },
    {
      "name": "Credit Offer"
    }
  ]
}