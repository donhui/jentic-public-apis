  "tags": [
    {
      "name": "Caller Details",
      "description": "Caller details collected via telephony system"
    }
  ],
  "paths": {
    "/caller-details": {
      "post": {
        "tags": [
          "Caller Details"
        ],
        "summary": "Post caller details",
        "description": "Post collected caller details along with the destination call handlers phone identifier at the point of transferring the phone call. This will pre-populate the Case Entry screen for the call handler, either with a single patient match or with search criteria. Returns an appropriate response.",
        "operationId": "postCallerDetails",
        "requestBody": {
          "$ref": "#/components/requestBodies/CallerDetailsRequestModel"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/CallerDetailsResponseModel"
          },
          "400": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem400Response"
          },
          "401": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem401Response"
          },
          "403": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem403Response"
          },
          "415": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem415Response"
          },
          "500": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem500Response"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CallerDetailsRequestModel": {
        "type": "object",
        "required": [
          "requestId",
          "callerPhoneNumber"
        ],
        "additionalProperties": false,
        "properties": {
          "requestId": {
            "type": "string",
            "description": "Request Identifier",
            "example": "12345"
          },
          "destinationPhoneId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 30,
            "description": "Identifier for the destination call handlers phone (i.e. DN, Agent ID)",
            "example": "123"
          },
          "callerPhoneNumber": {
            "type": "string",
            "description": "Callers phone number",
            "minLength": 8,
            "maxLength": 15,
            "example": "07824777777"
          },
          "vectorDirectoryNumber": {
            "type": "string",
            "description": "Vector Directory Number (VDN) of the call",
            "minLength": 1,
            "maxLength": 20,
            "example": "8547055"
          },
          "isCallerPatient": {
            "type": "boolean",
            "description": "Is the caller the patient or are they calling on behalf of someone else",
            "example": true,
            "default": false
          },
          "patientDemographics": {
            "type": "object",
            "description": "Patient demographics",
            "properties": {
              "forename": {
                "type": "string",
                "description": "Patient forename",
                "minLength": 1,
                "maxLength": 50,
                "example": "John"
              },
              "surname": {
                "type": "string",
                "description": "Patient surname",
                "minLength": 1,
                "maxLength": 50,
                "example": "Smith"
              },
              "dateOfBirth": {
                "type": "string",
                "format": "date",
                "description": "Patient date of birth in yyyy-mm-dd format",
                "example": "1957-06-15"
              },
              "mobileNumber": {
                "type": "string",
                "description": "Patients mobile number",
                "minLength": 8,
                "maxLength": 15,
                "example": "07824777777"
              },
              "sex": {
                "type": "string",
                "enum": [
                  "Female",
                  "Male",
                  "NotKnown",
                  "NotSpecified"
                ],
                "description": "Patient sex",
                "example": "Male",
                "default": "NotKnown"
              },
              "nationalNumber": {
                "type": "string",
                "description": "Patients national number (NHS, CHI, etc)",
                "minLength": 10,
                "maxLength": 12,
                "example": "4857773456"
              }
            }
          },
          "homeAddress": {
            "type": "object",
            "description": "Patient home address",
            "properties": {
              "line1": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "description": "First line of address",
                "example": "First line"
              },
              "line2": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "description": "Second line of address",
                "example": "Second line"
              },
              "line3": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "description": "Third line of address",
                "example": "Third line"
              },
              "town": {
                "type": "string",
                "minLength": 1,
                "maxLength": 60,
                "description": "Town",
                "example": "Town"
              },
              "county": {
                "type": "string",
                "minLength": 1,
                "maxLength": 60,
                "description": "County",
                "example": "County"
              },
              "postcode": {
                "type": "string",
                "minLength": 5,
                "maxLength": 10,
                "description": "Postcode",
                "example": "Postcode"
              }
            }
          }
        }
      },
      "CallerDetailsResponseModel": {
        "type": "object",
        "required": [
          "requestId"
        ],
        "properties": {
          "requestId": {
            "type": "string",
            "description": "Same requestId passed into the initial request",
            "example": "12345"
          }
        }
      }
    },
    "requestBodies": {
      "CallerDetailsRequestModel": {
        "description": "Schema for caller request",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CallerDetailsRequestModel"
            }
          }
        }
      }
    },
    "responses": {
      "CallerDetailsResponseModel": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CallerDetailsResponseModel"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "oAuth": {
        "type": "oauth2",
        "description": "Endpoints using OAuth 2 with the Client Credentials flow.",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://identity.oneadvanced.com/auth/realm/protocol/openid-connect/token",
            "scopes": {}
          }
        }
      }
    }
  }
}