{
  "openapi": "3.0.0",
  "info": {
    "x-api-id": "cd6635a3-f9b0-4160-b0a1-62b594182637",
    "x-audience": "external-partner",
    "description": "# Introduction\nThe API provides option to search for a patient based on the phone number and the date of birth and create a case if the details match.\n",
    "version": "1.0.2",
    "title": "Adastra IVR API",
    "termsOfService": "http://oneadvanced.com",
    "contact": {
      "name": "Advanced",
      "email": "api@oneadvanced.com",
      "url": "https://oneadvanced.com/contact-us"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/AdvancedComputerSoft/Adastra-IVR-API/1.0.2/swagger.json"
  },
  "security": [
    {
      "token": []
    }
  ],
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/AdvancedComputerSoft/Adastra-IVR-API/1.0.2"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Operations related to authentication"
    },
    {
      "name": "Patient",
      "description": "Operations related to lookup of patient based on phone number and date of birth"
    },
    {
      "name": "Case",
      "description": "Operations related to creation of case based on the patient details"
    }
  ],
  "paths": {
    "/authenticate": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "operationId": "authentication",
        "summary": "Obtain JWT token",
        "description": "Obtain authentication token (JWT) on behalf of an API user. JWT returned on successful authentication.",
        "requestBody": {
          "$ref": "#/components/requestBodies/AuthenticationRequestModel"
        },
        "responses": {
          "200": {
            "description": "Authentication successful, JWT returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationResponseModel"
                }
              }
            }
          },
          "400": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem400Response"
          },
          "401": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem401Response"
          },
          "403": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem403Response"
          },
          "415": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem415Response"
          },
          "500": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem500Response"
          }
        }
      }
    },
    "/patient-search": {
      "post": {
        "tags": [
          "Patient"
        ],
        "summary": "Get patient details",
        "description": "Gets patient details based on phone number and date of birth",
        "operationId": "getPatientDetails",
        "requestBody": {
          "$ref": "#/components/requestBodies/PatientRequestModel"
        },
        "responses": {
          "200": {
            "description": "Provides patient details and request id to create case if a single matching patient was found. No match or multiple matches results in success field being false and appropriate message is returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientResponseModel"
                },
                "examples": {
                  "single-match": {
                    "value": {
                      "success": true,
                      "message": "",
                      "requestId": "884c0363-bbbe-4a5e-8d4f-1d34910803fc",
                      "data": [
                        {
                          "patientId": "5D82CA16-930F-4C30-FCF0-9B6A1FE37D2A",
                          "forename": "Jane",
                          "surname": "Smith",
                          "dob": "1990-12-23",
                          "gender": "Female",
                          "postcode": "B338TH"
                        }
                      ]
                    }
                  },
                  "no-match": {
                    "value": {
                      "success": false,
                      "message": "No matching patient record for the search criteria found",
                      "requestId": "00000000-0000-0000-0000-000000000000",
                      "data": [
                        {}
                      ]
                    }
                  },
                  "multiple-match": {
                    "value": {
                      "success": false,
                      "message": "Multiple patient records found for the search criteria",
                      "requestId": "00000000-0000-0000-0000-000000000000",
                      "data": [
                        {}
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem400Response"
          },
          "401": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem401Response"
          },
          "403": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem403Response"
          },
          "415": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem415Response"
          },
          "500": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem500Response"
          }
        }
      }
    },
    "/cases": {
      "post": {
        "operationId": "createCase",
        "tags": [
          "Case"
        ],
        "summary": "Create case",
        "description": "Create case for existing patient once the demographic details are verified",
        "requestBody": {
          "$ref": "#/components/requestBodies/CreateCaseRequestModel"
        },
        "responses": {
          "201": {
            "description": "Case number",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/CreateCaseResponseModel"
                    }
                  ]
                }
              }
            },
            "headers": {
              "Location": {
                "schema": {
                  "type": "string",
                  "format": "url",
                  "example": "https://virtserver.swaggerhub.com/AdvancedComputerSoft/Adastra-IVR-API/1.0.2/cases/CFB587E9-AE72-F90D-96B7-C729FA73F08F"
                },
                "description": "Location URI of the newly created case"
              }
            }
          },
          "400": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem400Response"
          },
          "401": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem401Response"
          },
          "403": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem403Response"
          },
          "415": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem415Response"
          },
          "500": {
            "$ref": "https://api.swaggerhub.com/domains/AdvancedComputerSoft/advanced-common-oas3/1.5.0#/components/responses/Problem500Response"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "token": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "AuthenticationRequestModel": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "additionalProperties": false,
        "properties": {
          "username": {
            "type": "string",
            "minimum": 3,
            "maximum": 20,
            "description": "Username of the API user",
            "example": "smith"
          },
          "password": {
            "type": "string",
            "minimum": 5,
            "maximum": 20,
            "description": "Password",
            "example": "sm1t@h"
          }
        }
      },
      "AuthenticationResponseModel": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "accessToken": {
            "type": "string",
            "readOnly": true,
            "description": "JWT token for further API access",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6InNtaXRoIn0.FIPOOkyOTayGgVQ8SjhuUDvlbSHwlTTL_aR-Cr5nV6Y"
          }
        }
      },
      "PatientRequestModel": {
        "type": "object",
        "required": [
          "phoneNumber",
          "dob"
        ],
        "additionalProperties": false,
        "properties": {
          "phoneNumber": {
            "type": "string",
            "minimum": 8,
            "maximum": 15,
            "description": "Patient's phone number in E.164 format",
            "example": "+447911123456"
          },
          "dob": {
            "type": "string",
            "format": "date",
            "description": "Patient's date of birth in yyyy-mm-dd format",
            "example": "1990-12-23"
          }
        }
      },
      "PatientResponseModel": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "success": {
            "type": "boolean",
            "description": "true/ false based on the search",
            "example": true
          },
          "message": {
            "type": "string",
            "description": "Appropriate message based on the success field",
            "example": ""
          },
          "requestId": {
            "type": "string",
            "format": "uuid",
            "readOnly": true,
            "description": "Request id to create case for the patient",
            "example": "884c0363-bbbe-4a5e-8d4f-1d34910803fc"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PatientModel"
            }
          }
        }
      },
      "PatientModel": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "patientId": {
            "type": "string",
            "format": "uuid",
            "readOnly": true,
            "description": "Patient ref",
            "example": "884c0363-bbbe-4a5e-8d4f-1d34910803fc"
          },
          "forename": {
            "type": "string",
            "description": "Patient's forename",
            "minimum": 3,
            "maximum": 50,
            "example": "Jane"
          },
          "surname": {
            "type": "string",
            "minimum": 3,
            "maximum": 50,
            "description": "Patient's surname",
            "example": "Smith"
          },
          "dob": {
            "type": "string",
            "format": "date",
            "description": "Patient's date of birth in yyyy-mm-dd format",
            "example": "1990-12-23"
          },
          "gender": {
            "type": "string",
            "minimum": 4,
            "maximum": 10,
            "enum": [
              "Male",
              "Female",
              "Unknown"
            ],
            "description": "Patient's gender",
            "example": "Female"
          },
          "postcode": {
            "type": "string",
            "minimum": 5,
            "maximum": 10,
            "description": "Patient's home postcode",
            "example": "B338TH"
          }
        }
      },
      "CreateCaseRequestModel": {
        "type": "object",
        "required": [
          "requestId",
          "returnPhoneNumber",
          "outcomeMappingCode"
        ],
        "additionalProperties": false,
        "properties": {
          "requestId": {
            "type": "string",
            "format": "uuid",
            "description": "Request id to create case for the patient",
            "example": "884c0363-bbbe-4a5e-8d4f-1d34910803fc"
          },
          "patientId": {
            "type": "string",
            "format": "uuid",
            "description": "Patient ref",
            "example": "5D82CA16-930F-4C30-FCF0-9B6A1FE37D2A"
          },
          "returnPhoneNumber": {
            "type": "string",
            "minimum": 8,
            "maximum": 15,
            "description": "Patient's return phone number in E.164 format",
            "example": "+447911567899"
          },
          "outcomeMappingCode": {
            "type": "string",
            "minimum": 1,
            "maximum": 20,
            "description": "Outcome mapping code",
            "example": "DX100"
          }
        }
      },
      "CreateCaseResponseModel": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "caseNo": {
            "type": "integer",
            "readOnly": true,
            "description": "Case number of newly created case",
            "example": 41992
          },
          "caseDateStamp": {
            "type": "string",
            "format": "dateTime",
            "description": "Case creation date stamp in 'yyyy-mm-dd hh:mm:ss' format",
            "example": "2018-04-15 19:15:24"
          }
        }
      }
    },
    "requestBodies": {
      "AuthenticationRequestModel": {
        "description": "Schema for authentication request",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/AuthenticationRequestModel"
            }
          }
        }
      },
      "PatientRequestModel": {
        "description": "Schema for patient request",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/PatientRequestModel"
            }
          }
        }
      },
      "CreateCaseRequestModel": {
        "description": "Schema for creation of case",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CreateCaseRequestModel"
            }
          }
        }
      }
    }
  }
}