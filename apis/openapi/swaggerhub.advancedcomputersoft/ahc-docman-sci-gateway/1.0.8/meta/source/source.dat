  "paths": {
    "/{tenantId}/Patient": {
      "get": {
        "operationId": "getPatientQuery",
        "description": "Retrieve Patient resource(s) from the service",
        "tags": [
          "Patient"
        ],
        "summary": "Get Patients",
        "parameters": [
          {
            "in": "path",
            "name": "tenantId",
            "required": true,
            "description": "Tenant ODS Code",
            "explode": false,
            "style": "simple",
            "example": "A12345",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "identifier",
            "schema": {
              "type": "string",
              "minLength": 0,
              "maxLength": 1000
            },
            "description": "Retrieve Patient resource(s) for a single CHI/NHS Number/National Id",
            "explode": true,
            "style": "form",
            "example": "https://fhir.nhs.uk/Id/chi-number|1234567890"
          },
          {
            "in": "query",
            "name": "given",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "description": "Retrieve Patient resource(s) for a Given Name",
            "explode": true,
            "style": "form",
            "example": "John"
          },
          {
            "name": "family",
            "in": "query",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "description": "Retrieve Patient resource(s) for a Family Name",
            "explode": true,
            "style": "form",
            "example": "Smith"
          },
          {
            "name": "_summary",
            "in": "query",
            "required": false,
            "description": "If the value is count this returns a count of Patients.",
            "explode": true,
            "style": "form",
            "example": "count",
            "schema": {
              "type": "string",
              "enum": [
                "count"
              ]
            }
          },
          {
            "name": "active",
            "in": "query",
            "required": false,
            "description": "If the value is true - returns Active Patients, false - Inactive Patients",
            "explode": true,
            "style": "form",
            "example": true,
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "_count",
            "in": "query",
            "required": false,
            "description": "Number of resources to return per page",
            "explode": true,
            "style": "form",
            "example": 1,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 30
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Current page to return when _count is specified",
            "explode": true,
            "style": "form",
            "example": 1,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000000,
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientBundle"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "value"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorised",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "login"
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "forbidden"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "not-found"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/{tenantId}/Patient/{patientId}": {
      "get": {
