    "/{tenantId}": {
      "post": {
        "operationId": "fhirBundle",
        "description": "Accepts multiple GET requests and returns a FHIR Bundler set of responses",
        "tags": [
          "Bundles"
        ],
        "summary": "Get Many Responses for SCI Gateway",
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "description": "Tenant ODS Code",
            "explode": false,
            "style": "simple",
            "example": "A12345",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Bundles of Fhir Requests",
          "content": {
            "application/fhir+json": {
              "schema": {
                "$ref": "#/components/schemas/FhirBundleRequests"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/FhirBundleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "structure",
                      "diagnostics": ""
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
