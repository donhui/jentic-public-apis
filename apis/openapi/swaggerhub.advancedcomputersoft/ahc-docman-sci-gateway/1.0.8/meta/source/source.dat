    "/{tenantId}/DocumentReference": {
      "get": {
        "operationId": "getDocumentReferenceQuery",
        "summary": "Get Document References",
        "tags": [
          "DocumentReference"
        ],
        "description": "Retrieve DocumentReference resources for a given patient, using either their national identifier or service identifier",
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "description": "Tenant ODS Code",
            "explode": false,
            "style": "simple",
            "example": "A12345",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subject:Patient.identifier",
            "in": "query",
            "required": false,
            "description": "National identifier or service identifier",
            "explode": true,
            "style": "form",
            "example": "https://fhir.nhs.uk/Id/chi-number|1234567890",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            }
          },
          {
            "name": "subject",
            "in": "query",
            "required": false,
            "description": "Clinical Reference Identifier",
            "explode": true,
            "style": "form",
            "example": "1234",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "Folder identifier",
            "example": "fd0d9107-7952-4a78-af1e-aa5af26e2758",
            "schema": {
              "type": "string",
              "minLength": 36,
              "maxLength": 36
            }
          },
          {
            "name": "type:missing",
            "in": "query",
            "required": false,
            "description": "Documents in or not in a Folder",
            "explode": true,
            "style": "form",
            "example": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "_summary",
            "in": "query",
            "required": false,
            "description": "If the value is true this returns a list of DocumentReferences excluding any data property within the DocumentReference attachment.  If the value is count this returns a count of DocumentReferences",
            "explode": true,
            "style": "form",
            "example": true,
            "schema": {
              "type": "string",
              "default": "true",
              "enum": [
                "true",
                "false",
                "count"
              ]
            }
          },
          {
            "name": "_count",
            "in": "query",
            "required": false,
            "description": "Number of resources to return per page",
            "example": 10,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 30
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Current page to return when _count is specified",
            "example": 1,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000000,
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentReferenceBundle"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "structure",
                      "diagnostics": ""
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "login",
                      "diagnostics": ""
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "forbidden"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                },
                "example": {
                  "resourceType": "OperationOutcome",
                  "issue": [
                    {
                      "severity": "error",
                      "code": "not-found"
                    }
                  ]
                }
              }
            }
          }
        }
      },
