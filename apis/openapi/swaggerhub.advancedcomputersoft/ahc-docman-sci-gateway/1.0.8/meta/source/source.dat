    "/{tenantId}/DocumentReference/{documentId}": {
      "get": {
        "operationId": "getDocumentReference",
        "description": "Retrieve a DocumentReference that includes all data related to it, including attachment binary data",
        "tags": [
          "DocumentReference"
        ],
        "summary": "Get Document Reference",
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "description": "Tenant ODS Code",
            "explode": false,
            "style": "simple",
            "example": "A12345",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "description": "Retrieve a DocumentReference using its system identifier",
            "explode": false,
            "style": "simple",
            "example": "00000000-0000-0000-0000-000000000000",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_summary",
            "in": "query",
            "required": false,
            "description": "If the value is true this returns a DocumentReference excluding the file content.",
            "explode": true,
            "style": "form",
            "example": true,
            "schema": {
              "type": "string",
              "default": "true",
              "enum": [
                "true",
                "false"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
