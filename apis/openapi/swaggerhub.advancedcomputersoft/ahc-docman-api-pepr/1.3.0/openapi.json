          }
        },
        "example": {
          "data": [
            {
              "comment": "No action required",
              "completedDateTime": "2020-05-07T09:00:00",
              "username": "SaltM",
              "taskType": "Review",
              "taskName": "Consultant Review"
            },
            {
              "comment": "Accepted at allocations meeting",
              "completedDateTime": "2020-05-07T12:00:00",
              "username": "AinsworthK",
              "taskType": "Review",
              "taskName": "Triage"
            },
            {
              "comment": "Amendments needed to redact information from referral letter",
              "completedDateTime": "2020-05-09T15:00:00",
              "username": "StanwayS",
              "taskType": "Discussion",
              "taskName": null
            }
          ],
          "pagination": [
            {
              "offset": 0,
              "limit": 3,
              "totalResultCount": 3
            }
          ]
        }
      },
      "TaskCommentModel": {
        "type": "object",
        "properties": {
          "comment": {
            "type": "string",
            "description": "Free text Comment made in Docman as part of a Task."
          },
          "completedDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the Task was completed in Docman."
          },
          "username": {
            "type": "string",
            "description": "The Docman username of the person who added the comment."
          },
          "taskType": {
            "type": "boolean",
            "description": "The type of Docman Task which the Comment relates to. Can be 'Review', 'Review Action', 'Discussion' or 'Clinical Coding'."
          },
          "taskName": {
            "type": "string",
            "description": "The name of the Task in Docman. Usually refers to the name of the Task Template used to create it."
          }
        }
      },
      "Pagination": {
        "required": [
          "limit",
          "offset",
          "totalResultCount"
        ],
        "type": "object",
        "properties": {
