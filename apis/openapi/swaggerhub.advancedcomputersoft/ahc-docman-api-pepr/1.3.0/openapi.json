        "example": {
          "data": [
            {
              "documentGuid": "437205f2-d200-4aac-8268-015cb672a322",
              "patientRef": "L900784",
              "taskType": "Review",
              "taskName": "Triage",
              "completedDateTime": "2021-02-24T11:03:56Z"
            },
            {
              "documentGuid": "3eb27672-524c-4556-b358-18d2421ad264",
              "patientRef": "F78812",
              "taskType": "Discussion",
              "taskName": "",
              "completedDateTime": "2021-02-23T11:02:34Z"
            },
            {
              "documentGuid": "0f4e3f36-b369-46f0-8f1c-07eeb3347cf6",
              "patientRef": "AB22093",
              "taskType": "Review",
              "taskName": "Appt Book",
              "completedDateTime": "2021-02-23T11:00:21Z"
            }
          ],
          "pagination": {
            "offset": 0,
            "limit": 3,
            "totalResultCount": 3
          }
        }
      },
      "DocumentTaskUpdate": {
        "type": "object",
        "properties": {
          "documentGuid": {
            "type": "string",
            "description": "The globally unique identifier representing a Docman document."
          },
          "patientRef": {
            "type": "string",
            "description": "The local reference for the patient this document belongs to. Typically a PAS identifier."
          },
          "taskType": {
            "type": "string",
            "description": "The type of Docman Task which has been completed. Can be 'Review', 'Review Action', 'Discussion' or 'Clinical Coding'."
          },
          "taskName": {
            "type": "string",
            "description": "The name of the Task in Docman. Usually refers to the name of the Task Template used to create it."
          },
          "completedDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time the Task was completed in Docman."
          }
        }
      },
      "TaskCommentsPagedResponse": {
        "required": [
          "data",
          "pagination"
