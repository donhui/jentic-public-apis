    "/api/tenants/{odsCode}/discussions/task-count": {
      "get": {
        "tags": [
          "Discussions"
        ],
        "summary": "Get task count for a user",
        "description": "Returns a count of tasks for the user requested. Can be either a Docman 10 username or a Windows username. Using the userType parameter will force the function to search for either the Windows or Docman username, with 1 being for Docman and 2 being for Windows.",
        "operationId": "getTaskCountForUser",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "odsCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Organisation Data Service code for the Docman tenant.",
            "example": "RWN"
          },
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "A Docman 10 or Windows username.",
            "example": "WallaceJ"
          },
          {
            "name": "userType",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User type to utilise in the query. '1' represents a Docman user, whereas 2 represents a Windows User.",
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation, returns count of tasks for user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "format": "integer32",
                  "example": 123
                }
              }
            }
          },
          "400": {
            "description": "Data input is invalid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Message": {
                      "type": "string"
                    }
                  }
                },
                "examples": {
                  "invalidTenant": {
                    "value": {
                      "Message": "DC01"
                    }
                  },
                  "noUsernameProvided": {
                    "value": {
                      "Message": "Username is required"
                    }
                  },
                  "invalidUserType": {
                    "value": {
                      "Message": "Invalid user type"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Unable to locate user by Docman or Windows username"
          }
        }
      }
    }
