  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "BearerTokenRequest": {
        "type": "string",
        "description": "String including username and password in order to retrieve a bearer token.",
        "example": "grant_type=password&username={ConsumerUsername}&password={ConsumerPassword}"
      },
      "BearerTokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Bearer token to use to authenticate with the API.",
            "example": "FFMlYRgjf_YBPf0ItcqRCxwofX0bYs5PPaps6ensPTj-EeJcPmWucg1jUbYOXoKZaltOwq2317DGQ6kUjUIINMVBVMcRbw2weLsedANzwIXw7Nrs4pX2PPtm2JSYEXeqNATEQbSPxmKyUt5smdra_lxt2udN2i7XXWhw_vnKIny5FVOntWfXvQ_p7hKCU-DPmw1EjUvnf6J3ITZbziUY_CNZw0gfc5rHOXd0A-UeARSIJYFvpfbO2qx_Dr7QdiuNgvHXbCvnqAzpckxA-XmAjjUnwknXfkWnGaYpWAWT0W8-EPy6EheYI6cZf8l-KJ6-e0DYS3z5QOZlJLLLd3uliL"
          },
          "token_type": {
            "type": "string",
            "description": "The type of token provided. Will always be 'bearer' in this instance.",
            "example": "bearer"
          },
          "expires_in": {
            "type": "integer",
            "format": "integer32",
            "description": "The number of seconds available until this bearer token expires.",
            "example": 25919999
          }
        }
      },
      "PatientDocumentOutbound": {
        "type": "object",
        "properties": {
          "document": {
            "type": "object",
            "properties": {
              "guid": {
                "type": "string",
                "description": "The globally unique identifier representing a Docman document.",
                "example": "de2e1a28-bc3f-4e75-b131-3cc84b96b38e"
              },
              "eventDate": {
                "type": "string",
                "format": "date-time",
                "description": "The date assigned to the document. Usually the date the document was written, or the date on which an appointment or event took place.",
                "example": "2021-07-23T00:00:00"
              },
              "description": {
                "type": "string",
                "description": "Summary of the document.",
                "example": "Clinic Letter"
              },
              "organisation": {
                "type": "string",
                "description": "Name of the organisation who sent the document.",
                "example": "Leeds General Infirmary"
              },
              "department": {
                "type": "string",
                "description": "Name of the department who sent the document.",
                "example": "Oncology"
              },
              "folderId": {
                "type": "integer",
                "description": "Unique identifier of the folder the document is stored in, within the patient record in Docman.",
                "example": 8
              },
              "folderName": {
                "type": "string",
                "description": "Name of the folder the document is stored in, within the patient record in Docman.",
                "example": "Cancer"
              },
              "fileExtension": {
                "type": "string",
                "description": "The file extension of the document stored in Docman.",
                "example": "TIF"
              },
              "ubrn": {
                "type": "string",
                "description": "The 12-character Unique Booking Reference Number for the e-Referral Service referral this document relates to, if relevant.",
                "example": "120308929091"
              }
            }
          },
          "file": {
            "type": "object",
            "properties": {
              "fileExtension": {
                "type": "string",
                "description": "The file extension of the document stored in Docman.",
                "example": "TIF"
              },
              "fileContent": {
                "type": "string",
                "format": "byte",
                "description": "The document represented as a file in a byte array.",
                "example": "[BYTE_ARRAY]"
              },
              "fileHash": {
                "type": "string",
                "format": "byte",
                "description": "Hashed representation of the file in bytes.",
                "example": "XzLvWOO8CQ+pgkpZ3cN8+5GABaM="
              },
              "fileSize": {
                "type": "integer",
                "description": "The size of the file in bytes.",
                "example": 88020
              }
            }
          }
        }
      },
      "DocumentTaskUpdatesPagedResponse": {
        "required": [
          "data",
          "pagination"
        ],
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
