  "paths": {
    "/token": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Request bearer token",
        "description": "The bearer token is used to authenticate you as a valid Docman customer. <p> Using your Organisation Consumer Username and Password, you can request a token from the API, which can then be used for all operations within it, based on the claims you have available. One claim covers all Share API operations. <p> Your Consumer Username and Password are configured by Advanced. Please contact your Account Manager to arrange this.",
        "operationId": "TokenRequest",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BearerTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BearerTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Explains the nature of the issue with the bearer token request.",
                      "example": "invalid_grant"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/tenants/{odsCode}/patients/reference/{patientRef}/Documents/{documentGuid}": {
      "get": {
        "tags": [
          "Documents"
        ],
        "summary": "Document with metadata by reference",
        "description": "Returns the metadata and physical document for a specific document (specified by GUID) with a correctly matched patient reference.",
        "operationId": "GetPatientDocumentByReference",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "odsCode",
            "in": "path",
            "required": true,
            "x-nullable": false,
            "schema": {
              "type": "string"
            },
            "description": "The Organisation Data Service code for the Docman tenant.",
            "example": "RWN"
          },
          {
            "name": "patientRef",
            "in": "path",
            "required": true,
            "x-nullable": false,
            "schema": {
              "type": "string"
            },
            "description": "The local reference for the patient this document belongs to. Typically a PAS identifier.",
            "example": "F78812"
          },
          {
            "name": "documentGuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The globally unique identifier representing a Docman document.",
            "example": "de2e1a28-bc3f-4e75-b131-3cc84b96b38e"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientDocumentOutbound"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "examples": {
                  "invalidTenant": {
                    "value": "DC01",
                    "summary": "Tenant ODS format is not valid"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/api/tenants/{odsCode}/documents/task-updates": {
      "get": {
        "tags": [
          "Documents"
        ],
        "summary": "Documents with completed tasks",
        "description": "Returns a list of documents for which a Docman Task has been completed in a given time frame. Can be filtered by the name of the Task used. Maximum date/time range to check for updates is 72 hours.",
        "operationId": "getDocumentTaskUpdates",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "odsCode",
            "in": "path",
            "required": true,
            "x-nullable": false,
            "schema": {
              "type": "string"
            },
            "description": "The Organisation Data Service code for the Docman tenant.",
            "example": "RWN"
          },
          {
            "name": "startDateTIme",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "The start date/time in the range being queried for Task updates.",
            "example": "2021-02-24T12:00:00Z"
          },
          {
            "name": "endDateTime",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "The end date/time in the range being queried for Task updates.",
            "example": "2021-02-25T00:00:00Z"
          },
          {
            "name": "taskName",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "The name of the Task Template used to complete the Task.",
            "example": "Triage"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "minimum": 0,
              "type": "integer",
              "format": "int32"
            },
            "description": "Number of records to skip for pagination.",
            "example": 10
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "type": "integer",
              "format": "int32"
            },
            "description": "Maximum number of records for pagination.",
            "example": 20
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentTaskUpdatesPagedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                },
                "examples": {
                  "invalidTenant": {
                    "value": "DC01",
                    "summary": "Tenant ODS format is not valid"
                  },
                  "dateTimeBreach": {
                    "value": "A StartDate can only be a maximum of 3 days before the current DateTime",
                    "summary": "DateTime breach"
                  },
                  "invalidPaginationParams": {
                    "value": "Invalid parameters in the pagination request",
                    "summary": "Invalid pagination parameters"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
