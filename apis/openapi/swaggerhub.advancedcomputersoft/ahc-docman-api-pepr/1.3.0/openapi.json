            "type": "integer",
            "description": "Number of results that were skipped in the dataset before the current page."
          },
          "limit": {
            "type": "integer",
            "description": "The maximum number of results per page."
          },
          "totalResultCount": {
            "type": "integer",
            "description": "The total number of results in the returned data set based on the search criteria."
          }
        },
        "example": {
