  "info": {
    "x-api-id": "34f34cdf-5b5c-4615-89dc-d147cbf0b398",
    "x-audience": "external-partner",
    "description": "API to allow third parties to send a Case Request to Adastra",
    "version": "1.0.0",
    "title": "Case Request Adastra Integration API",
    "contact": {
      "name": "Advanced",
      "email": "api@oneadvanced.com",
      "url": "https://oneadvanced.com/contact-us"
    },
    "license": {
      "name": "Apache 2.0",
