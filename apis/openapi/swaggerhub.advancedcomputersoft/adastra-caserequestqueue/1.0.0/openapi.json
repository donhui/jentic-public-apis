      "token": []
    }
  ],
  "tags": [
    {
      "name": "CaseRequests",
      "description": "Operations for Case Request records"
    }
  ],
  "paths": {
    "/case-requests": {
      "post": {
        "tags": [
          "CaseRequests"
        ],
        "summary": "Adds a CaseRequest Record",
        "operationId": "addCaseRequest",
        "description": "Adds a CaseRequest Record to Adastra",
        "responses": {
          "201": {
            "description": "Item created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "caseId": {
                      "type": "string",
                      "description": "Adastra Case ID (Non Unique - Human identifiable reference)",
                      "example": "12345"
                    },
                    "caseReference": {
                      "type": "string",
                      "description": "Adastra Case Reference (GUID)",
                      "example": "453e3a44-21a9-4571-bbd5-e3dccb89b712"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "type": "https://example.net/problem/400",
                  "title": "Bad Request",
                  "status": 400,
                  "detail": "The request is invalid.",
                  "issues": [
                    {
                      "fieldName": "priority",
                      "error": "The max length of 50 has been exceeded"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "type": "https://example.net/problem/401",
                  "title": "Unauthorized",
                  "status": 401
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "type": "https://example.net/problem/403",
                  "title": "Forbidden",
                  "status": 403
                }
              }
            }
          },
          "415": {
            "description": "Unsupported Media Type",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "type": "https://example.net/problem/415",
                  "title": "Unsupported Media Type",
                  "status": 415,
                  "detail": "The request could not be completed due to the request body being formed of an unsupported media type. Only application/json is accepted by this API."
                }
              }
            }
          },
          "500": {
            "description": "Server Error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "type": "https://example.net/problem/500",
                  "title": "An internal error occurred.",
                  "status": 500,
                  "detail": "The server is unable to process the request."
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaseRequest"
              }
            }
          },
          "description": "CaseRequest Record to add"
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "token": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CaseRequest": {
        "type": "object",
        "required": [
          "outcomeCode",
          "referrer",
          "patient"
        ],
        "properties": {
          "outcomeCode": {
            "type": "string",
            "maxLength": 20,
            "description": "This field is intended to drive the workflow within Adastra. e.g. Urgency based.",
            "example": "EMER"
          },
          "relativeUrgency": {
            "type": "integer",
            "description": "An indicator of urgency relative to other Cases. (0 being the highest priority, then 1, then 2 etc). Field is used purely for sorting Cases in a queue.",
            "example": 1
          },
          "returnPhone": {
            "type": "string",
            "maxLength": 15,
            "example": "0141 123123",
            "description": "Phone number to use to contact the patient for this episode of care"
          },
          "symptoms": {
            "type": "string",
            "example": "Fell over - hurt leg badly",
            "description": "Patient's reported Symptoms for this episode of care"
          },
          "currentLocationAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "patient": {
            "$ref": "#/components/schemas/Patient"
          },
          "referrer": {
            "$ref": "#/components/schemas/Referrer"
          },
          "questionSets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionSet"
            }
          },
          "odysseyTriage": {
            "$ref": "#/components/schemas/OdysseyTriage"
          }
        }
      },
      "Patient": {
        "type": "object",
        "description": "The Patient object contains properties that are not necessarily specific to the Case. They apply at Patient level and are likely to be the same should the same patient call back and generate a new Case record.",
        "properties": {
          "nationalNumber": {
            "type": "string",
            "description": "NHS Number / Community Health Index Number",
            "example": "010119901230"
          },
          "forename": {
            "type": "string",
            "maxLength": 45,
            "example": "John"
          },
          "surname": {
            "type": "string",
            "maxLength": 45,
            "example": "Smith"
          },
          "surnamePrefix": {
            "type": "string",
            "maxLength": 10,
            "example": "Van"
          },
          "maidenName": {
            "type": "string",
            "maxLength": 45,
            "example": "Jones"
          },
          "maidenNamePrefix": {
            "type": "string",
            "maxLength": 10,
            "example": "Van"
          },
          "sex": {
            "type": "string",
            "enum": [
              "Female",
              "Male",
              "NotKnown",
              "NotSpecified"
            ],
            "example": "Male"
          },
          "dateOfBirth": {
            "required": [
              "date",
              "approximate"
            ],
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "format": "date",
                "example": "1990-07-21",
                "description": "Date only - no time element"
              },
              "approximate": {
                "type": "boolean",
                "description": "If the DOB is an estimate / not accurate then dateOfBirthApproximate is set to true"
              }
            }
          },
          "mobilePhone": {
            "type": "string",
            "maxLength": 15,
            "example": "07777 111111"
          },
          "homePhone": {
            "type": "string",
            "maxLength": 15,
            "example": "0141 123123"
          },
          "otherPhone": {
            "type": "string",
            "maxLength": 15,
            "example": "0141 555555",
            "description": "Another contact phone for the patient other than their home and mobile numbers."
          },
          "ethnicity": {
            "type": "string",
            "maxLength": 20,
            "example": "92431000000100",
            "description": "SNOMED CT Concept code representing ethnicity"
          },
          "homeAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "providerDetails": {
            "$ref": "#/components/schemas/ProviderDetails"
          }
        }
      },
      "ProviderDetails": {
        "type": "object",
        "properties": {
          "gp": {
            "properties": {
              "code": {
                "type": "string",
                "maxLength": 20,
                "example": "1353235",
                "description": "Identifier for the the patient's registered GP. It is expected to be the doctor's GMC number"
              },
              "name": {
                "type": "string",
                "maxLength": 50,
                "example": "Smith, John",
                "description": "Patient's registered GP"
              }
            }
          },
          "surgery": {
            "properties": {
              "code": {
                "type": "string",
                "maxLength": 20,
                "example": "F21825",
                "description": "Identifier for the the patient's registered GP Practice. It is expected to be the Practice Code (with letter prefix)"
              },
              "name": {
                "type": "string",
                "maxLength": 50,
                "example": "Blackfriars Medical Centre",
                "description": "Name of the patient's registered GP Practice"
              }
            }
          }
        }
      },
      "Referrer": {
        "type": "object",
        "required": [
          "service"
        ],
        "properties": {
          "service": {
            "type": "string",
            "maxLength": 50,
            "example": "Weymouth Emergency Department"
          },
          "name": {
            "type": "string",
            "maxLength": 50,
            "example": "Bob Smith"
          },
          "phone": {
            "type": "object",
            "description": "This is the primary contact number for reaching the Referring Service should a query be raised about the Case.",
            "properties": {
              "number": {
                "type": "string",
                "maxLength": 15,
                "example": "0141 123123",
                "description": "Contact for the referring service."
              },
              "extension": {
                "type": "string",
                "maxLength": 6,
                "example": "x123",
                "description": "Extension number, if applicable."
              }
            }
          },
          "reference": {
            "type": "object",
            "properties": {
              "caseId": {
                "type": "string",
                "maxLength": 15,
                "description": "Referrer Case ID (Non Unique - Human identifiable reference). Would be understood by the referrer if questioned about the Case.",
                "example": "12345"
              },
              "caseReference": {
                "type": "string",
                "maxLength": 50,
                "description": "Unique Case Reference (GUID)",
                "example": "453e3a44-21a9-4571-bbd5-e3dccb89b712"
              }
            }
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "lines": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 0,
            "maxItems": 5,
            "maxLength": 55,
            "example": [
              "43 Park View",
              "Glasgow"
            ]
          },
          "postcode": {
            "type": "string",
            "maxLength": 15,
            "example": "TN25 4AZ"
          },
          "directions": {
            "type": "string",
            "example": "First turning after big oak tree"
          }
        }
      },
      "QuestionSet": {
        "description": "A group of questions and the answers given by the Patient. These can map to Case Questions within Adastra if the codes match",
        "type": "object",
        "required": [
          "title",
          "answers"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Title/Name of the Question Set",
            "maxLength": 50,
            "example": "Pre Assessment Questions"
          },
          "code": {
            "type": "string",
            "description": "Code to identify the question set when mapping to the Adastra Case Question Set. Can be omitted if no mapping available.",
            "maxLength": 10,
            "example": "TRIAGE"
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Answer"
            },
            "minItems": 1
          }
        }
      },
      "Answer": {
        "description": "Question and Answer details",
        "type": "object",
        "required": [
          "questionText",
          "answerText"
        ],
        "properties": {
          "questionText": {
            "type": "string",
            "description": "Question asked to the patient",
            "maxLength": 100,
            "example": "Are you currently taking any medications?"
          },
          "questionCode": {
            "type": "string",
            "description": "Unique code (unique within the question set) to identify this question. This can map to a Case Question within Adastra if the codes match.",
            "maxLength": 10,
            "example": "MEDICATION"
          },
          "answerText": {
            "type": "string",
            "description": "Answer given by the patient",
            "maxLength": 2000,
            "example": true
          },
          "answerCode": {
            "type": "string",
            "description": "Unique code (unique within the possible list of answers for this question) to identify this answer. This would not be expected to be present if it is a free text answer, but if the question has a list of answers to choose from then this code would identify that pre-defined answer. Thus this could map to a Case Question Answer within Adastra if the codes match.",
            "maxLength": 10,
            "example": "MEDS-YES"
          }
        }
      },
      "OdysseyTriage": {
        "description": "If the referring system is using Odyssey then the Odyssey Triage data can be sent with the Case",
        "type": "object",
        "required": [
          "odysseyClientVersion",
          "odysseyContentVersion",
          "urgency",
          "fullTriageData"
        ],
        "properties": {
          "sessionId": {
            "type": "string",
            "description": "Odyssey TriageId GUID",
            "example": "5490d54d-7af4-4847-940b-9aea8ffbef97"
          },
          "odysseyClientVersion": {
            "type": "string",
            "description": "Odyssey Client Version",
            "maxLength": 15,
            "example": "3.10.5"
          },
          "odysseyContentVersion": {
            "type": "string",
            "description": "Odyssey Content Version",
            "maxLength": 15,
            "example": "7.354"
          },
          "urgency": {
            "type": "string",
            "maxLength": 10,
            "example": "URG1"
          },
          "fullTriageData": {
            "type": "string",
            "description": "Full Triage XML (Base64 encoded)"
          }
        }
      },
      "ProblemDetails": {
        "description": "Implementation of [RFC7807](https://tools.ietf.org/html/rfc7807) Problem Details object.  Content type should always be ```application/problem+json```.  Problem type definitions MAY extend the problem details object with additional members",
        "type": "object",
        "required": [
          "type",
          "title",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "format": "uri",
            "description": "A type URI"
          },
          "title": {
            "type": "string",
            "description": "A short, human-readable summary of the problem type"
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "The HTTP status code for this occurrence of the problem"
          },
          "detail": {
            "type": "string",
            "description": "A human-readable explanation specific to this occurrence of the problem"
          },
          "issues": {
            "type": "array",
            "description": "A list of issues that exist with the request. Note this is an extension that is supported by the RFC but specific to this API.",
            "items": {
              "type": "object",
              "properties": {
                "fieldName": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                }
              }
            }
          },
          "instance": {
            "type": "string",
            "description": "A URI reference that identifies the specific occurrence of the problem.  It may or may not yield further information if dereferenced",
            "example": "https://example.net/support/problem/74837463"
          }
        }
      }
    }
  }
}