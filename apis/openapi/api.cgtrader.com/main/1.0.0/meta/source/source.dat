{
  "openapi": "3.0.3",
  "info": {
    "title": "CGTrader API",
    "version": "1.0.0",
    "description": "API for accessing and managing 3D models on CGTrader marketplace.",
    "x-jentic-source-url": "https://api.cgtrader.com/docs/index.html"
  },
  "servers": [
    {
      "url": "https://api.cgtrader.com",
      "description": "CGTrader API server"
    }
  ],
  "paths": {
    "/v1/file_types": {
      "get": {
        "operationId": "listFileTypes",
        "summary": "Fetch all file types",
        "description": "Fetch all file types with their renderer applications.",
        "tags": ["File Types"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of file types",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/FileType" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/file_types/{id}": {
      "get": {
        "operationId": "getFileType",
        "summary": "Get a file type",
        "description": "Get file type with renderer application.",
        "tags": ["File Types"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "File type details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FileType" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/models": {
      "get": {
        "operationId": "listModels",
        "summary": "Get page of models",
        "tags": ["Models"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Paginated list of models",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Model" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      },
      "post": {
        "operationId": "createModel",
        "summary": "Create a new model draft",
        "tags": ["Models"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ModelInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Model created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Model" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/models/{id}": {
      "get": {
        "operationId": "getModel",
        "summary": "Fetch model details",
        "tags": ["Models"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Model details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Model" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "operationId": "updateModel",
        "summary": "Update model information",
        "tags": ["Models"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ModelInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Model updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Model" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "operationId": "deleteModel",
        "summary": "Delete model",
        "tags": ["Models"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Model deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/categories": {
      "get": {
        "operationId": "listCategories",
        "summary": "Fetch all categories",
        "tags": ["Categories"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of categories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Category" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/categories/{id}": {
      "get": {
        "operationId": "getCategory",
        "summary": "Get category details",
        "tags": ["Categories"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Category details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Category" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "List all orders",
        "description": "Lists all orders initiated by the authorized user.",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Order" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      },
      "post": {
        "operationId": "createOrder",
        "summary": "Create a new order",
        "description": "Creates a new unpaid order and returns checkout_url.",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Order" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/orders/{id}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get order details",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Order" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/models/{model_id}/files": {
      "get": {
        "operationId": "listModelFiles",
        "summary": "List all files of a model",
        "tags": ["Model Files"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "model_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of model files",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ModelFile" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      },
      "post": {
        "operationId": "uploadModelFile",
        "summary": "Upload model file",
        "tags": ["Model Files"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "model_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "File uploaded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelFile" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/models/{model_id}/files/{id}": {
      "get": {
        "operationId": "downloadModelFile",
        "summary": "Download model file",
        "description": "Redirects to S3 storage if file can be downloaded.",
        "tags": ["Model Files"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "model_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "302": { "description": "Redirect to file download" },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "operationId": "deleteModelFile",
        "summary": "Remove model file",
        "tags": ["Model Files"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "model_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "File deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/models/{model_id}/license": {
      "get": {
        "operationId": "getModelLicense",
        "summary": "Get model license information",
        "tags": ["Models"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "model_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "License information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/License" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/models/{model_id}/images": {
      "get": {
        "operationId": "listModelImages",
        "summary": "List all images of a model",
        "tags": ["Model Images"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "model_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of model images",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ModelImage" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      },
      "post": {
        "operationId": "uploadModelImage",
        "summary": "Upload model image",
        "tags": ["Model Images"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "model_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Image uploaded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelImage" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/models/{model_id}/images/{id}": {
      "delete": {
        "operationId": "deleteModelImage",
        "summary": "Remove model image",
        "tags": ["Model Images"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "model_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Image deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/v1/users": {
      "post": {
        "operationId": "createUser",
        "summary": "Create new user",
        "description": "Create new user and returns access_token.",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" },
                  "username": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/v1/users/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user",
        "description": "Returns the user associated with the passed access_token.",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": { "description": "Authentication required" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Access token authentication"
      }
    },
    "schemas": {
      "FileType": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "renderer_app": { "type": "string" }
        }
      },
      "Model": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "category_id": { "type": "integer" },
          "price": { "type": "number" }
        }
      },
      "ModelInput": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "category_id": { "type": "integer" },
          "price": { "type": "number" }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "checkout_url": { "type": "string", "format": "uri" },
          "status": { "type": "string" }
        }
      },
      "OrderInput": {
        "type": "object",
        "properties": {
          "model_id": { "type": "integer" }
        }
      },
      "ModelFile": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "filename": { "type": "string" },
          "file_type_id": { "type": "integer" }
        }
      },
      "License": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "ModelImage": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "url": { "type": "string", "format": "uri" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }]
}