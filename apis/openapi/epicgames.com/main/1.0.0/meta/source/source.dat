          },
          "action": {
            "type": "string"
          },
          "expirationTimestamp": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          }
        }
      },
      "SanctionEventsResponse": {
        "type": "object",
        "properties": {
          "elements": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SanctionEvent"
            }
          }
        }
      },
      "SanctionEvent": {
        "type": "object",
        "properties": {
          "productUserId": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "justification": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "eventType": {
            "type": "integer",
            "description": "1=created, 2=updated, 3=deleted"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "logId": {
            "type": "string"
          },
          "referenceId": {
            "type": "string"
          }
        }
      },
      "BulkSanctionsResponse": {
        "type": "object",
        "properties": {
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "productUserId": {
                  "type": "string"
                },
                "referenceId": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                },
                "action": {
                  "type": "string"
                },
                "expirationTimestamp": {
                  "type": "string",
                  "format": "date-time",
                  "nullable": true
                }
              }
            }
          }
        }
      },
      "PaginatedSanctionsResponse": {
        "type": "object",
        "properties": {
          "elements": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sanction"
            }
          },
          "paging": {
            "$ref": "#/components/schemas/Paging"
          }
        }
      },
      "Sanction": {
        "type": "object",
        "properties": {
          "referenceId": {
            "type": "string"
          },
          "productUserId": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "justification": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string"
          },
          "pending": {
            "type": "boolean"
          },
          "automated": {
            "type": "boolean"
          },
          "deploymentId": {
            "type": "string"
          },
          "batchUuid": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "expirationTimestamp": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "removedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "displayName": {
            "type": "string"
          },
          "identityProvider": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "SanctionCreatePayload": {
        "type": "object",
        "required": ["productUserId", "action", "justification", "source"],
        "properties": {
          "productUserId": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]+$",
            "maxLength": 64
          },
          "justification": {
            "type": "string",
            "maxLength": 2048
          },
          "source": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]+$",
            "minLength": 2,
            "maxLength": 64
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 16
            }
          },
          "pending": {
            "type": "boolean"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "maxProperties": 25
          },
          "displayName": {
            "type": "string",
            "maxLength": 64
          },
          "identityProvider": {
            "type": "string",
            "maxLength": 64
          },
          "accountId": {
            "type": "string",
            "maxLength": 64
          },
          "duration": {
            "type": "integer",
            "description": "Sanction length in seconds"
          }
        }
      },
      "SanctionUpdatePayload": {
        "type": "object",
        "required": ["referenceId", "updates"],
        "properties": {
          "referenceId": {
            "type": "string"
          },
          "updates": {
            "type": "object",
            "properties": {
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "metadata": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "justification": {
                "type": "string",
                "maxLength": 2048
              }
            }
          }
        }
      },
      "PlayerReportRequest": {
        "type": "object",
        "required": ["reportingPlayerId", "reportedPlayerId", "time", "reasonId"],
        "properties": {
          "reportingPlayerId": {
            "type": "string",
            "description": "EOS Product User ID of reporter"
          },
          "reportedPlayerId": {
            "type": "string",
            "description": "EOS Product User ID being reported"
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "description": "Report timestamp (ISO 8601)"
          },
          "reasonId": {
            "type": "integer",
            "description": "Report reason ID"
          },
          "message": {
            "type": "string",
            "maxLength": 1024,
            "description": "Report message"
          },
          "context": {
            "type": "string",
            "maxLength": 4096,
            "description": "Additional context as valid JSON"
          }
        }
      },
      "PlayerReportsResponse": {
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/Paging"
          },
          "elements": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PlayerReport"
            }
          }
        }
      },
      "PlayerReport": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "sandboxId": {
            "type": "string"
          },
          "deploymentId": {
            "type": "string"
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "reportingPlayerId": {
            "type": "string"
          },
          "reportedPlayerId": {
            "type": "string"
          },
          "reasonId": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "context": {
            "type": "string"
          }
        }
      },
      "ReportReasonsResponse": {
        "type": "object",
        "properties": {
          "elements": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reasonId": {
                  "type": "integer"
                },
                "reasonString": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CreateRoomTokensRequest": {
        "type": "object",
        "required": ["participants"],
        "properties": {
          "participants": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["puid", "hardMuted"],
              "properties": {
                "puid": {
                  "type": "string",
                  "description": "EOS Product User ID"
                },
                "clientIp": {
                  "type": "string",
                  "description": "Player's IP for server selection"
                },
                "hardMuted": {
                  "type": "boolean",
                  "description": "Initial mute status"
                }
              }
            }
          }
        }
      },
      "RoomTokensResponse": {
        "type": "object",
        "properties": {
          "roomId": {
            "type": "string"
          },
          "clientBaseUrl": {
            "type": "string"
          },
          "deploymentId": {
            "type": "string"
          },
          "participants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "puid": {
                  "type": "string"
                },
                "token": {
                  "type": "string"
                },
                "hardMuted": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "Paging": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "EOS access token obtained via Auth or Connect endpoints"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Base64-encoded ClientId:ClientSecret"
      }
    }
  },
  "security": [
    {"bearerAuth": []}
  ]
}