                }
              }
            }
          }
        }
      }
    },
    "/rtc/v1/{deploymentId}/room/{roomId}/participants/{productUserId}": {
      "post": {
        "operationId": "modifyRoomParticipant",
        "summary": "Modify Room Participant",
        "description": "Modify a participant's settings in a voice room (e.g. mute/unmute).",
        "tags": ["Voice"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "deploymentId",
            "in": "path",
            "required": true,
            "description": "EOS Deployment ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "description": "Voice room ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "productUserId",
            "in": "path",
            "required": true,
            "description": "Product User ID of participant",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["hardMuted"],
                "properties": {
                  "hardMuted": {
                    "type": "boolean",
                    "description": "Mute status"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Participant modified"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "removeRoomParticipant",
        "summary": "Remove Room Participant",
        "description": "Remove a participant from a voice room.",
        "tags": ["Voice"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "deploymentId",
            "in": "path",
            "required": true,
            "description": "EOS Deployment ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "description": "Voice room ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "productUserId",
            "in": "path",
            "required": true,
            "description": "Product User ID of participant to remove",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Participant removed"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
