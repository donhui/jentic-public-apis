                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/rtc/v1/{deploymentId}/room/{roomId}": {
      "post": {
        "operationId": "createRoomTokens",
        "summary": "Create Voice Room Tokens",
        "description": "Create a voice room and generate tokens for participants.",
        "tags": ["Voice"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "deploymentId",
            "in": "path",
            "required": true,
            "description": "EOS Deployment ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "roomId",
            "in": "path",
            "required": true,
            "description": "Voice room ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoomTokensRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Room created with participant tokens",
