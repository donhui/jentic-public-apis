{
  "openapi": "3.0.3",
  "info": {
    "title": "Epic Online Services Web API",
    "version": "1.0.0",
    "description": "RESTful Web APIs for Epic Online Services (EOS) including authentication, connect, friends, ecommerce, anti-cheat, sanctions, player reports, and voice chat.",
    "x-jentic-source-url": "https://dev.epicgames.com/docs/web-api-ref"
  },
  "servers": [
    {
      "url": "https://api.epicgames.dev",
      "description": "EOS Production API"
    }
  ],
  "paths": {
    "/epic/oauth/v2/token": {
      "post": {
        "operationId": "requestEpicAuthToken",
        "summary": "Request Epic Account OAuth Token",
        "description": "Obtain an access token via various OAuth 2.0 grant types for Epic Account Services.",
        "tags": ["Auth"],
        "security": [{"basicAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["authorization_code", "client_credentials", "exchange_code", "password", "refresh_token"],
                    "description": "OAuth 2.0 grant type"
                  },
                  "deployment_id": {
                    "type": "string",
                    "description": "Deployment identifier for service interactions"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Space-delimited permissions (e.g. basic_profile friends_list presence)"
                  },
                  "code": {
                    "type": "string",
                    "description": "Authorization code (for authorization_code grant)"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "OAuth Client ID (for client_credentials grant)"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "OAuth Client Secret (for client_credentials grant)"
                  },
                  "exchange_code": {
                    "type": "string",
                    "description": "One-time use code from Epic Launcher (for exchange_code grant)"
                  },
                  "username": {
                    "type": "string",
                    "description": "User email address (for password grant)"
                  },
                  "password": {
                    "type": "string",
                    "description": "User account password (for password grant)"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token for session extension (for refresh_token grant)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token granted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpicAuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/oauth/v2/revoke": {
      "post": {
        "operationId": "revokeEpicAuthToken",
        "summary": "Revoke Token",
        "description": "Revoke an access or refresh token per RFC 7009.",
        "tags": ["Auth"],
        "security": [{"basicAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["token"],
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "Access or refresh token to revoke"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token revoked successfully"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/oauth/v2/.well-known/jwks.json": {
      "get": {
        "operationId": "getEpicPublicKeys",
        "summary": "Get Public Keys (JWKS)",
        "description": "Retrieve JWK Set for offline JWT verification of Epic Account tokens.",
        "tags": ["Auth"],
        "security": [],
        "responses": {
          "200": {
            "description": "JWK Set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JwksResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/oauth/v2/tokenInfo": {
      "post": {
        "operationId": "introspectEpicToken",
        "summary": "Token Introspection",
        "description": "Verify and introspect an access or refresh token per RFC 7662.",
        "tags": ["Auth"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["token"],
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "Access or refresh token to verify"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenInfoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/id/v2/accounts": {
      "get": {
        "operationId": "getEpicAccounts",
        "summary": "Get Account Information",
        "description": "Retrieve account information for up to 50 Epic accounts.",
        "tags": ["Auth"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "description": "Account identifiers to resolve (up to 50, repeatable)",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 50
            },
            "style": "form",
            "explode": true
          }
        ],
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EpicAccount"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/v1/oauth/token": {
      "post": {
        "operationId": "requestEosConnectToken",
        "summary": "Request EOS Connect Access Token",
        "description": "Obtain an EOS access token for Game Services using client credentials or external authentication.",
        "tags": ["Connect"],
        "security": [{"basicAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["client_credentials", "external_auth"],
                    "description": "client_credentials for client access, external_auth for user access"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "OAuth Client ID (if not using Basic auth header)"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "OAuth Client Secret (if not using Basic auth header)"
                  },
                  "nonce": {
                    "type": "string",
                    "description": "Arbitrary string for security verification (for user access)"
                  },
                  "deployment_id": {
                    "type": "string",
                    "description": "Target EOS deployment identifier (for user access)"
                  },
                  "external_auth_token": {
                    "type": "string",
                    "description": "External authentication token (for user access)"
                  },
                  "external_auth_type": {
                    "type": "string",
                    "enum": [
                      "amazon_access_token", "apple_id_token", "discord_access_token",
                      "epicgames_access_token", "epicgames_id_token", "gog_encrypted_sessionticket",
                      "google_id_token", "itchio_jwt", "itchio_key", "nintendo_id_token",
                      "oculus_userid_nonce", "openid_access_token", "psn_id_token",
                      "steam_access_token", "steam_encrypted_appticket", "steam_session_ticket",
                      "xbl_xsts_token"
                    ],
                    "description": "External auth token type"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "EOS access token granted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EosConnectTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/v1/accounts": {
      "get": {
        "operationId": "queryExternalAccounts",
        "summary": "Query External Accounts",
        "description": "Map external platform account IDs to EOS Product User IDs.",
        "tags": ["Connect"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "required": true,
            "description": "External account IDs (max 16, repeatable)",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 16
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "identityProviderId",
            "in": "query",
            "required": true,
            "description": "Identity provider",
            "schema": {
              "type": "string",
              "enum": ["amazon", "apple", "discord", "epicgames", "gog", "google", "itchio", "nintendo", "oculus", "openid", "psn", "steam", "xbl"]
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": false,
            "description": "Platform-specific environment (e.g. xbl_retail for Xbox)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account mapping",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExternalAccountsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/v1/product-users": {
      "get": {
        "operationId": "queryProductUsers",
        "summary": "Query Product Users",
        "description": "Get linked external accounts for EOS Product User IDs.",
        "tags": ["Connect"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "productUserId",
            "in": "query",
            "required": true,
            "description": "Product User IDs to query (max 16, repeatable)",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 16
            },
            "style": "form",
            "explode": true
          }
        ],
        "responses": {
          "200": {
            "description": "Product user data with linked accounts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductUsersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/friends/v1/{accountId}": {
      "get": {
        "operationId": "getFriendsAndBlockList",
        "summary": "Get Friends and Block List",
        "description": "Retrieve both a player's friends list and block list in a single request.",
        "tags": ["Friends"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "description": "Epic Account ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Friends and block list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FriendsAndBlockListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token verification failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - insufficient scopes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/friends/v1/{accountId}/friends": {
      "get": {
        "operationId": "getFriendsList",
        "summary": "Get Friends List",
        "description": "Retrieve only a player's friends list.",
        "tags": ["Friends"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "description": "Epic Account ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Friends list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Friend"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token verification failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/friends/v1/{accountId}/blocklist": {
      "get": {
        "operationId": "getBlockList",
        "summary": "Get Block List",
        "description": "Retrieve only a player's block list.",
        "tags": ["Friends"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "description": "Epic Account ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Block list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BlockedUser"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Token verification failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/ecom/v3/platforms/{platform}/identities/{accountId}/ownership": {
      "get": {
        "operationId": "verifyOwnership",
        "summary": "Verify Ownership",
        "description": "Verify ownership of catalog items for an Epic Games account.",
        "tags": ["Ecom"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "platform",
            "in": "path",
            "required": true,
            "description": "Platform identifier",
            "schema": {
              "type": "string",
              "default": "EPIC"
            }
          },
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "description": "Epic Games Account ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nsCatalogItemId",
            "in": "query",
            "required": false,
            "description": "Format sandboxId:catalogItemId (repeatable)",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "sandboxId",
            "in": "query",
            "required": false,
            "description": "Retrieve full list of owned catalog items in sandbox",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ownership verification results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OwnershipItem"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/ecom/v3/platforms/{platform}/identities/{accountId}/ownershipToken": {
      "post": {
        "operationId": "requestOwnershipToken",
        "summary": "Request Ownership Verification Token",
        "description": "Request a JWT for offline ownership verification.",
        "tags": ["Ecom"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "platform",
            "in": "path",
            "required": true,
            "description": "Platform identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "description": "Epic Games Account ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["nsCatalogItemId"],
                "properties": {
                  "nsCatalogItemId": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Format sandboxId:catalogItemId (repeatable)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ownership verification JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OwnershipTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/ecom/v4/identities/{accountId}/entitlements": {
      "get": {
        "operationId": "getEntitlements",
        "summary": "Get Entitlements",
        "description": "Enumerate entitlements for an Epic Games account.",
        "tags": ["Ecom"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "description": "Epic Games Account ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sandboxId",
            "in": "query",
            "required": true,
            "description": "Game namespace/sandbox",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entitlementName",
            "in": "query",
            "required": false,
            "description": "Filter by entitlement name (repeatable)",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "includeRedeemed",
            "in": "query",
            "required": false,
            "description": "Include redeemed entitlements",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of entitlements",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Entitlement"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/epic/ecom/v4/platforms/{platform}/identities/{accountId}/entitlementToken": {
      "post": {
        "operationId": "requestEntitlementToken",
        "summary": "Request Entitlement Verification Token",
        "description": "Request a JWT for offline entitlement verification.",
        "tags": ["Ecom"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "platform",
            "in": "path",
            "required": true,
            "description": "Platform identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "accountId",
            "in": "path",
            "required": true,
