{
  "openapi": "3.0.3",
  "info": {
    "title": "Sirv REST API",
    "description": "Sirv is an image management and CDN platform. The REST API provides programmatic access to account management, file operations, image processing, statistics, and more. Authentication uses JWT bearer tokens obtained via client credentials.",
    "version": "2.0.0",
    "contact": {
      "name": "Sirv",
      "url": "https://sirv.com"
    },
    "x-jentic-source-url": "https://apidocs.sirv.com/"
  },
  "servers": [
    {
      "url": "https://api.sirv.com/v2",
      "description": "Sirv API v2 production server"
    }
  ],
  "paths": {
    "/token": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Get API token",
        "description": "Obtain a JWT bearer token using client credentials. Tokens expire after 1200 seconds (20 minutes).",
        "operationId": "getToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "clientId": {
                    "type": "string",
                    "description": "API client ID"
                  },
                  "clientSecret": {
                    "type": "string",
                    "description": "API client secret"
                  }
                },
                "required": [
                  "clientId",
                  "clientSecret"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token issued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "description": "JWT bearer token"
                    },
                    "expiresIn": {
                      "type": "integer",
                      "description": "Token lifetime in seconds",
                      "example": 1200
                    },
                    "scope": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Granted scopes"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/account": {
      "get": {
        "tags": [
          "Account"
        ],
        "summary": "Get account information",
        "description": "Get information about the account, including its CDN URL.",
        "operationId": "getAccount",
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
      "post": {
        "tags": [
          "Account"
        ],
        "summary": "Update account settings",
        "description": "Modify account settings such as minify and fetching options.",
        "operationId": "updateAccount",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "minify": {
                    "type": "object",
                    "properties": {
                      "enabled": {
                        "type": "boolean"
                      }
                    }
                  },
                  "fetching": {
                    "type": "object",
                    "properties": {
                      "enabled": {
                        "type": "boolean"
                      },
                      "type": {
                        "type": "string"
                      },
                      "http": {
                        "type": "object",
                        "properties": {
                          "url": {
                            "type": "string",
                            "format": "uri"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/account/limits": {
      "get": {
