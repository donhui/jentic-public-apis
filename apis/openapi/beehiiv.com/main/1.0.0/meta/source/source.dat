          "recommendation",
          "magic_link",
          "boost",
          "boost_send",
          "boost_direct_link",
          "integration",
          "product"
        ],
        "description": "The acquisition channel",
        "title": "SubscriptionExpandedUtmChannel"
      },
      "type_ids:TierId": {
