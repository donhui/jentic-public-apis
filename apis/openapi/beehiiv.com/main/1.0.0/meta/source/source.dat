            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "description": "The direction that the results are sorted in. Defaults to asc<br> `asc` - Ascending, sorts from smallest to largest.<br> `desc` - Descending, sorts from largest to smallest.",
