{
  "openapi": "3.0.3",
  "info": {
    "title": "Crunchbase API",
    "description": "Crunchbase's REST API provides access to firmographic, financial, and relationship data on companies, people, funding rounds, acquisitions, investments, events, and funds. The API supports entity lookups, search queries, autocomplete, and deleted entity tracking.",
    "version": "4.0",
    "contact": {
      "name": "Crunchbase API Support",
      "email": "api@crunchbase.com",
      "url": "https://data.crunchbase.com/docs"
    },
    "termsOfService": "https://about.crunchbase.com/terms-of-service/"
  },
  "servers": [
    {
      "url": "https://api.crunchbase.com/v4",
      "description": "Crunchbase API v4 Production"
    }
  ],
  "security": [
    {
      "ApiKeyHeader": []
    },
    {
      "ApiKeyQuery": []
    }
  ],
  "paths": {
    "/data/entities/organizations/{entity_id}": {
      "get": {
        "operationId": "getOrganization",
        "summary": "Lookup an Organization",
        "description": "Retrieve detailed information about a specific organization by its UUID or permalink.",
        "tags": ["Entity Lookup"],
        "parameters": [
          { "$ref": "#/components/parameters/EntityId" },
          { "$ref": "#/components/parameters/FieldIds" },
          { "$ref": "#/components/parameters/CardIds" }
        ],
        "responses": {
          "200": {
            "description": "Successful response with organization entity data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SingleEntityResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/data/entities/people/{entity_id}": {
      "get": {
        "operationId": "getPerson",
        "summary": "Lookup a Person",
