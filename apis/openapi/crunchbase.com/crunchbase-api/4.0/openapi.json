    "/data/searches/organizations": {
      "post": {
        "operationId": "searchOrganizations",
        "summary": "Search Organization Entities",
        "description": "Search for organizations matching specified criteria using field-based filtering with operators.",
        "tags": ["Search"],
        "requestBody": {
          "$ref": "#/components/requestBodies/SearchRequest"
        },
        "responses": {
          "200": {
            "description": "Successful response with matching organization entities.",
            "content": {
              "application/json": {
