    "/data/autocompletes": {
      "get": {
        "operationId": "autocomplete",
        "summary": "Autocomplete Entities",
        "description": "Suggests matching Identifier entities based on the query and entity_def_ids provided. Useful for finding UUIDs or permalinks for use with other API endpoints.",
        "tags": ["Autocomplete"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search term to match against entity identifiers.",
            "schema": {
              "type": "string"
            },
            "example": "crunchbase"
          },
          {
            "name": "collection_ids",
            "in": "query",
            "required": false,
            "description": "Comma-separated entity definition IDs to filter results. Valid values include: organization, person, funding_round, acquisition, investment, event, fund, category, category_group, location, and others.",
            "schema": {
              "type": "string"
            },
            "example": "organization.companies,organization.investors"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of results to return per page. Maximum value is 25.",
            "schema": {
              "type": "integer",
              "maximum": 25,
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with autocomplete suggestions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutocompleteResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/data/deleted_entities": {
      "get": {
        "operationId": "getDeletedEntities",
        "summary": "Retrieve Deleted Entities",
        "description": "Retrieve a list of entities that have been deleted from the Crunchbase database. Useful for keeping local data synchronized.",
        "tags": ["Deleted Entities"],
        "parameters": [
          {
            "name": "collection_ids",
            "in": "query",
            "required": false,
            "description": "Filter by entity collection type (e.g., organizations, people).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "before_id",
            "in": "query",
            "required": false,
            "description": "Cursor for pagination; return results before this entity UUID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "after_id",
            "in": "query",
            "required": false,
            "description": "Cursor for pagination; return results after this entity UUID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of results to return.",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "deleted_at_order",
            "in": "query",
            "required": false,
            "description": "Sort order for deleted_at timestamp.",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"],
              "default": "asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with deleted entity records.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeletedEntitiesResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-cb-user-key",
        "description": "Crunchbase API key passed via request header."
      },
      "ApiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "user_key",
        "description": "Crunchbase API key passed as a query parameter."
      }
    },
    "parameters": {
      "EntityId": {
        "name": "entity_id",
        "in": "path",
        "required": true,
        "description": "UUID or permalink of the desired entity.",
        "schema": {
          "type": "string"
        }
      },
      "FieldIds": {
        "name": "field_ids",
        "in": "query",
        "required": false,
        "description": "Fields to include on the resulting entity. Accepts an array of field_id strings in JSON or a comma-separated list.",
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "style": "form",
        "explode": false
      },
      "CardIds": {
        "name": "card_ids",
        "in": "query",
        "required": false,
        "description": "Cards to include on the resulting entity. Each card returns a set of related entities or additional detail.",
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "style": "form",
        "explode": false
      }
    },
    "requestBodies": {
      "SearchRequest": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/SearchRequestBody"
            }
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Authentication failed. Invalid or missing API key.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "The requested entity was not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded. Maximum 200 calls per minute.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Request body validation failed.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message."
          }
        }
      },
      "EntityIdentifier": {
        "type": "object",
        "description": "A reference to a Crunchbase entity.",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the entity."
          },
          "value": {
            "type": "string",
            "maxLength": 255,
            "description": "Display name or label of the entity."
          },
          "image_id": {
            "type": "string",
            "maxLength": 255,
            "description": "Identifier for the entity image."
          },
          "permalink": {
            "type": "string",
            "maxLength": 255,
            "description": "URL-friendly unique identifier."
          },
          "entity_def_id": {
            "type": "string",
            "description": "Type of entity.",
            "enum": [
              "address",
              "category",
              "category_group",
              "degree",
              "diversity_spotlight",
              "event",
              "event_appearance",
              "fund",
              "funding_round",
              "investment",
              "ipo",
              "job",
              "location",
              "organization",
              "ownership",
              "person"
            ]
          }
        }
      },
      "SingleEntityResponse": {
        "type": "object",
        "description": "Response containing a single entity with its fields and optional cards.",
        "properties": {
          "properties": {
            "type": "object",
            "description": "Core fields of the entity. Varies by entity type.",
            "properties": {
              "identifier": {
                "$ref": "#/components/schemas/EntityIdentifier"
              },
              "uuid": {
                "type": "string",
                "format": "uuid"
              },
              "permalink": {
                "type": "string"
              },
              "entity_def_id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "short_description": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time"
              },
              "image_id": {
                "type": "string"
              },
              "image_url": {
                "type": "string",
                "format": "uri"
              },
              "rank": {
                "type": "integer",
                "description": "Crunchbase rank value."
              }
            },
            "additionalProperties": true
          },
          "cards": {
            "type": "object",
            "description": "Optional card data containing related entities.",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      },
      "SearchRequestBody": {
        "type": "object",
        "description": "Request body for search endpoints supporting field-based filtering, sorting, and pagination.",
        "properties": {
          "field_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Fields to include in each entity result."
          },
          "order": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortOrder"
            },
            "description": "Sort order for results."
          },
          "query": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Predicate"
            },
            "description": "Array of filter predicates. All predicates are combined with AND logic."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of results to return.",
            "default": 100,
            "maximum": 1000
          },
          "after_id": {
            "type": "string",
            "description": "Cursor for pagination; return results after this entity UUID."
          },
          "before_id": {
            "type": "string",
            "description": "Cursor for pagination; return results before this entity UUID."
          }
        },
        "required": ["field_ids", "query"]
      },
      "Predicate": {
        "type": "object",
        "description": "A filter condition for a search query.",
        "properties": {
          "field_id": {
            "type": "string",
            "description": "The field to filter on."
          },
          "operator_id": {
            "type": "string",
            "description": "The comparison operator.",
            "enum": [
              "blank",
              "between",
              "contains",
              "eq",
              "gt",
              "gte",
              "includes",
              "includes_all",
              "lt",
              "lte",
              "not_contains",
              "not_eq",
              "not_includes",
              "not_includes_all",
              "starts"
            ]
          },
          "values": {
            "type": "array",
            "items": {},
            "description": "Values to compare against. Type depends on the field being filtered."
          },
          "type": {
            "type": "string",
            "description": "Predicate type.",
            "enum": ["predicate"]
          }
        },
        "required": ["field_id", "operator_id", "type"]
      },
      "SortOrder": {
        "type": "object",
        "description": "Defines sort order for search results.",
        "properties": {
          "field_id": {
            "type": "string",
            "description": "Field to sort by."
          },
          "sort": {
            "type": "string",
            "description": "Sort direction.",
            "enum": ["asc", "desc"]
          },
          "nulls": {
            "type": "string",
            "description": "Where to place null values in sort order.",
            "enum": ["first", "last"]
          }
        },
        "required": ["field_id", "sort"]
      },
      "SearchResponse": {
        "type": "object",
        "description": "Response from a search endpoint containing matching entities.",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Total number of entities matching the query."
          },
          "entities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SingleEntityResponse"
            },
            "description": "Array of matching entity results."
          }
        }
      },
      "AutocompleteResponse": {
        "type": "object",
        "description": "Response from the autocomplete endpoint.",
        "properties": {
