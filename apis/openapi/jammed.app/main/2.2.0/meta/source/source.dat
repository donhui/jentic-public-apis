{
  "openapi": "3.0.3",
  "info": {
    "title": "Jammed Bookings API",
    "description": "Jammed Bookings API powers scheduling and bookings for independent creative spaces like rehearsal rooms, recording studios, dance studios, and more. Manage bookings, customers, rooms, coupons, and notifications.",
    "version": "2.2.0",
    "x-jentic-source-url": "https://api.jammedapp.com/v2/jammed.yaml"
  },
  "servers": [
    {
      "url": "https://api.jammed.app/api/v2",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Bookings",
      "description": "Booking management operations"
    },
    {
      "name": "Customers",
      "description": "Customer management operations"
    },
    {
      "name": "Rooms",
      "description": "Room information"
    },
    {
      "name": "Groups",
      "description": "Group/band management"
    },
    {
      "name": "Coupons",
      "description": "Coupon and promocode management"
    },
    {
      "name": "Extras",
      "description": "Add-on/extras management"
    },
    {
      "name": "Blocked Times",
      "description": "Blocked time management"
    },
    {
      "name": "Notifications",
      "description": "Notification management"
    },
    {
      "name": "Studio",
      "description": "Studio configuration"
    },
    {
      "name": "Reporting",
      "description": "Reporting and pricing"
    }
  ],
  "paths": {
    "/bookings.json": {
      "get": {
        "operationId": "getBookings",
        "summary": "List bookings",
        "description": "Retrieve a list of bookings",
        "tags": [
          "Bookings"
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "422": {
            "description": "Validation error"
          }
        }
      },
      "post": {
        "operationId": "createBooking",
        "summary": "Create a booking",
        "description": "Create a new booking",
        "tags": [
          "Bookings"
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "422": {
            "description": "Validation error"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
