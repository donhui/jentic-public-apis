      "PostBeneficiariosRequest": {
        "type": "object",
        "required": [
          "cabecalho",
          "dadosBeneficiario",
          "dadosPessoa"
        ],
        "properties": {
          "cabecalho": {
            "type": "object",
            "required": [
              "codigoControleTransacao",
              "codigoVersaoPTU",
              "unimed",
              "dataGeracao"
            ],
            "properties": {
              "codigoControleTransacao": {
                "type": "integer",
                "description": "C\u00f3digo de transa\u00e7\u00e3o do PTU",
                "format": "int64",
                "minimum": 0,
                "maximum": 99999999999999999999,
                "example": "01234567890123456789"
              },
              "codigoVersaoPTU": {
                "type": "string",
                "description": "C\u00f3digo da Vers\u00e3o do PTU trafegando",
                "minimum": 0,
                "maximum": 999,
                "example": "011"
              },
              "unimed": {
                "type": "object",
                "required": [
                  "codigoUnimedOrigem",
                  "codigoUnimedDestino"
                ],
                "properties": {
                  "codigoUnimedOrigem": {
                    "type": "integer",
                    "description": "C\u00f3digo da Unimed origem do envio de arquivo",
                    "format": "int32",
                    "minimum": 1,
                    "maximum": 9999,
                    "example": 865
                  },
                  "codigoUnimedDestino": {
                    "type": "integer",
                    "description": "C\u00f3digo da Unimed destino para envio de arquivo",
                    "format": "int32",
                    "minimum": 1,
                    "maximum": 9999,
                    "example": 999
                  }
                }
              },
              "dataGeracao": {
                "type": "string",
                "description": "Data de gera\u00e7\u00e3o do arquivo de envio",
                "format": "date-time",
                "example": "2023-04-02T09:06:05-03:00"
              },
              "protocoloProspeccao": {
                "type": "integer",
                "description": "Protocolo VCOM - tipo prospec\u00e7\u00e3o",
                "format": "int64",
                "minimum": 0,
                "maximum": 99999999999999999999,
                "example": "12345678901234567890"
              },
              "protocoloContrato": {
                "type": "integer",
                "description": "Protocolo VCOM - tipo contrato",
                "format": "int64",
                "minimum": 0,
                "maximum": 99999999999999999999,
                "example": "12345678901234567890"
              }
            }
          },
          "dadosBeneficiario": {
            "type": "object",
            "required": [
              "carteirinhaBeneficiario",
              "indicadorSib",
              "indicadorRemido",
              "indicadorAutoGestao",
              "indicadorBeneficiarioCooperado",
              "dataInclusaoUnimed",
              "indicadorExcRN561",
              "indicadorNato"
            ],
            "properties": {
              "carteirinhaBeneficiario": {
                "type": "string",
                "description": "Carteirinha do benefici\u00e1rio",
                "minimum": 17,
                "maximum": 17,
                "example": "01234567890123456"
              },
              "codigoFamiliaBenef": {
                "type": "integer",
                "description": "C\u00f3digo da Fam\u00edlia do Benefici\u00e1rio.",
                "format": "int32",
                "minimum": 1,
                "maximum": 999999,
                "example": 5349
              },
              "codigoDependenciaBeneficiario": {
                "type": "string",
                "description": "C\u00f3digo da Depend\u00eancia do Benefici\u00e1rio",
                "minLength": 2,
                "maxLength": 2,
                "enum": [
                  "00",
                  "01",
                  "02",
                  "10",
                  "50",
                  "52",
                  "60",
                  "70",
                  "75",
                  "80",
                  "90"
                ],
                "example": "00"
              },
              "carteirinhaBeneficiarioTitular": {
                "type": "string",
                "description": "Carteirinha do benefici\u00e1rio titular",
                "minimum": 17,
                "maximum": 17,
                "example": "01234567890123456"
              },
              "numeroPlanoPortabilidade": {
                "type": "string",
                "description": "N\u00famero do C\u00f3digo do Plano de Origem (portabilidade)",
                "minimum": 1,
                "maximum": 20,
                "example": "01234567890123456789"
              },
              "indicadorSib": {
                "type": "boolean",
                "description": "C\u00f3digo Sib (C\u00f3digo do beneficiario no Sistema de Informa\u00e7\u00f5es de Benefici\u00e1rios da ANS)",
                "example": true
              },
              "indicadorRemido": {
                "type": "boolean",
                "description": "Indica se o benefici\u00e1rio \u00e9 remido: usu\u00e1rio dependente de plano de sa\u00fade com continuidade do atendimento assistencial ap\u00f3s a morte do titular com isen\u00e7\u00e3o de mensalidade",
                "example": false
              },
              "indicadorAutoGestao": {
                "type": "boolean",
                "description": "Indica se o benefici\u00e1rio \u00e9 de auto gest\u00e3o.",
                "example": false
              },
              "codigoAutoGestaoAns": {
                "type": "integer",
                "description": "C\u00f3digo da Autogest\u00e3o junto a ANS",
                "format": "int64",
                "minimum": 1,
                "maximum": 9999999999,
                "example": "0123456789"
              },
              "indicadorBeneficiarioCooperado": {
                "type": "boolean",
                "description": "Indicador se o benefici\u00e1rio \u00e9 um cooperado",
                "example": false
              },
              "dadosCooperado": {
                "type": "object",
                "required": [
                  "codigoCrm",
                  "codigoUfConselho"
                ],
                "properties": {
                  "codigoCrm": {
                    "type": "string",
                    "description": "N\u00famero do CRM do m\u00e9dico cooperado",
                    "minLength": 0,
                    "maxLength": 15,
                    "example": "012345678901234"
                  },
                  "codigoUfConselho": {
                    "type": "string",
                    "description": "C\u00f3digo da Unidade Federativa do m\u00e9dico coopera codifica\u00e7\u00e3o do IBGE",
                    "minLength": 2,
                    "maxLength": 2,
                    "example": "35"
                  }
                }
              },
              "dataInclusaoUnimed": {
                "type": "string",
                "description": "Data de inclus\u00e3o do benefici\u00e1rio na Unimed",
                "format": "date",
                "example": "2024-04-02"
              },
              "dataExclusaoBeneficiario": {
                "type": "string",
                "description": "Data de exclus\u00e3o do benefici\u00e1rio na Unimed",
                "format": "date",
                "example": "2024-04-02"
              },
              "motivoExclusaoBeneficiario": {
                "type": "string",
                "description": "Motivo de exclus\u00e3o",
                "minLength": 2,
                "maxLength": 2,
                "enum": [
                  "01",
                  "02",
                  "03",
                  "04",
                  "05",
                  "06",
                  "07",
                  "08"
                ],
                "example": "06"
              },
              "codigoPlanoInter": {
                "type": "string",
                "description": "C\u00f3digo do Plano de Interc\u00e2mbio do Benefici\u00e1rio",
                "minLength": 1,
                "maxLength": 3,
                "example": "123"
              },
              "numeroMatricula": {
                "type": "string",
                "description": "N\u00famero da matr\u00edcula/funcional na empresa.",
                "minLength": 1,
                "maxLength": 20,
                "example": "01234567890123456789"
              },
              "codigoLotacao": {
                "type": "string",
                "description": "C\u00f3digo da lota\u00e7\u00e3o do benefici\u00e1rio",
                "minLength": 1,
                "maxLength": 8,
                "example": "01234567"
              },
              "descricaoLotacao": {
                "type": "string",
                "description": "Descri\u00e7\u00e3o da lota\u00e7\u00e3o do benefici\u00e1rio",
                "minLength": 3,
                "maxLength": 30,
                "example": "Lorem ipsum aliquet eget litor"
              },
              "dataInclusaoPlanoDestino": {
                "type": "string",
                "description": "Data de Inclus\u00e3o no Plano Destino (Interc\u00e2mbio).",
                "format": "date",
                "example": "2024-04-02"
              },
              "indicadorExcRN561": {
                "type": "boolean",
                "description": "Indicador de exclus\u00e3o proveniente da RN561",
                "example": true
              },
              "indicadorNato": {
                "type": "boolean",
                "description": "Identificador de Rec\u00e9m-Nato",
                "example": true
              },
              "valorMensalidade": {
                "type": "integer",
                "format": "decimal",
                "description": "Valor mensalidade",
                "example": 1650.25
              },
              "rendaMensal": {
                "type": "integer",
                "format": "decimal",
                "description": "Renda mensal",
                "example": 10050.1
              },
              "carteirinhaAnterior": {
                "type": "string",
                "description": "Carteirinha anterior do benefici\u00e1rio",
                "minimum": 17,
                "maximum": 17,
                "example": "01234567890123456"
              },
              "idFilho": {
                "type": "string",
                "description": "Codigo do tipo de filho",
                "minLength": 2,
                "maxLength": 2,
                "enum": [
                  "01",
                  "02",
                  "99"
                ],
                "example": "01"
              },
              "produtoAgregado": {
                "type": "array",
                "items": {
                  "required": [
                    "tipoProduto"
                  ],
                  "type": "object",
                  "properties": {
                    "tipoProduto": {
                      "type": "string",
                      "description": "Tipo do Produto",
