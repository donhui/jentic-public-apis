      "PatchBeneficiariosRequest": {
        "type": "object",
        "required": [
          "cabecalho",
          "dadosBeneficiario"
        ],
        "properties": {
          "cabecalho": {
            "type": "object",
            "required": [
              "codigoControleTransacao",
              "codigoVersaoPTU",
              "unimed",
              "dataGeracao"
            ],
            "properties": {
              "codigoControleTransacao": {
                "type": "integer",
                "description": "C\u00f3digo de transa\u00e7\u00e3o do PTU",
