                      "maxLength": 20,
                      "example": "Lorem ipsum aliquet "
                    },
                    "codigoUnimedDestino": {
                      "type": "integer",
                      "description": "C\u00f3digo da Unimed destino para envio de arquivo",
                      "format": "int32",
                      "minimum": 1,
                      "maximum": 9999,
                      "example": 865
                    },
                    "codigoPlanoDestino": {
                      "type": "integer",
                      "description": "C\u00f3digo do plano da Unimed Destino",
                      "format": "int32",
                      "minimum": 1,
                      "maximum": 999999,
                      "example": 975543
