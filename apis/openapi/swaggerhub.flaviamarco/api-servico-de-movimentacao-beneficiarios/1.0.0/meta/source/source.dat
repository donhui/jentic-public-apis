              "unimed": {
                "type": "object",
                "required": [
                  "codigoUnimedOrigem",
                  "codigoUnimedDestino"
                ],
                "properties": {
                  "codigoUnimedOrigem": {
                    "type": "integer",
                    "description": "C\u00f3digo da Unimed origem do envio de arquivo",
                    "format": "int32",
                    "minimum": 1,
                    "maximum": 9999,
