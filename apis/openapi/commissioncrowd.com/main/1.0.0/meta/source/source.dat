    "/wall_post_replies/": {
      "get": {
        "summary": "List wall post replies",
        "operationId": "listWallPostReplies",
        "tags": ["Wall Posts"],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/companies/": {
      "get": {
        "summary": "List companies",
        "operationId": "listCompanies",
        "tags": ["Companies"],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/opportunities/": {
      "get": {
        "summary": "List opportunities",
        "operationId": "listOpportunities",
        "tags": ["Opportunities"],
        "responses": {
          "200": { "description": "Successful response" }
