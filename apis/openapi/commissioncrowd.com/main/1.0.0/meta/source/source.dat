          "200": { "description": "Successful response" }
        }
      }
    },
    "/leads/": {
      "get": {
        "summary": "List leads",
        "operationId": "listLeads",
        "tags": ["Leads"],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/agents/": {
      "get": {
        "summary": "List agents",
        "operationId": "listAgents",
        "tags": ["Agents"],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/phone_numbers/": {
      "get": {
        "summary": "List phone numbers",
        "operationId": "listPhoneNumbers",
