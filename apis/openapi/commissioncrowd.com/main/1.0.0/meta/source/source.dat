{
  "openapi": "3.0.3",
  "info": {
    "title": "CommissionCrowd API",
    "description": "CommissionCrowd API for managing activities, tasks, wall posts, users, leads, contacts, companies, opportunities, organizations, agents, events, and more.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://www.commissioncrowd.com/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/activities/": {
      "get": {
        "summary": "List activities",
        "operationId": "listActivities",
        "tags": ["Activities"],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/tasks/": {
      "get": {
        "summary": "List tasks",
        "operationId": "listTasks",
        "tags": ["Tasks"],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/wall_posts/": {
      "get": {
        "summary": "List wall posts",
        "operationId": "listWallPosts",
        "tags": ["Wall Posts"],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/users/": {
      "get": {
        "summary": "List users",
        "operationId": "listUsers",
