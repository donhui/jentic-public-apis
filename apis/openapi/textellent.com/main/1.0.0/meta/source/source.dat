              }
            }
          }
        }
      }
    },
    "/event/unsubscribe/{clientId}.json": {
      "delete": {
        "operationId": "unsubscribeFromEvent",
        "summary": "Unsubscribe from Webhook Event",
        "description": "Unsubscribe from a webhook event.",
        "tags": ["Webhooks"],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "description": "Client ID for the subscription.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "event",
            "in": "header",
            "description": "Event type to unsubscribe from.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "targetUrl",
            "in": "header",
            "description": "Target URL of the webhook.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unsubscribed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
