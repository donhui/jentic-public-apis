  "components": {
    "schemas": {
      "SendMessageRequest": {
        "type": "object",
        "required": ["text", "from", "to"],
        "properties": {
          "text": {
            "type": "string",
            "description": "Message text content."
          },
          "from": {
            "type": "string",
            "description": "Sender phone number."
          },
          "to": {
            "type": "string",
            "description": "Recipient phone number."
          },
          "mediaFileIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of media file IDs to attach."
          },
          "mediaFileURLs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of media file URLs to attach."
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "description": "Status code of the operation."
          },
          "message": {
            "type": "string",
            "description": "Status message."
          },
          "messageId": {
            "type": "string",
            "description": "Unique message identifier."
          },
          "errorCode": {
            "type": "string",
            "description": "Error code if applicable."
          }
        }
      },
      "ContactInput": {
        "type": "object",
        "properties": {
          "contactFirstName": {
            "type": "string",
            "description": "Contact first name."
          },
          "contactLastName": {
            "type": "string",
            "description": "Contact last name."
          },
          "phoneNumber": {
            "type": "string",
            "description": "Primary phone number."
          },
          "email": {
            "type": "string",
            "description": "Email address."
          },
          "customFields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Custom field key-value pairs."
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "contactId": {
            "type": "string",
            "description": "Unique contact identifier."
          },
          "contactFirstName": {
            "type": "string",
            "description": "Contact first name."
          },
          "contactLastName": {
            "type": "string",
            "description": "Contact last name."
          },
          "phoneNumber": {
            "type": "string",
            "description": "Primary phone number."
          },
          "email": {
            "type": "string",
            "description": "Email address."
          },
          "customFields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Custom field key-value pairs."
          }
        }
      },
      "TagInput": {
        "type": "object",
        "required": ["tagName"],
        "properties": {
          "tagName": {
            "type": "string",
            "description": "Name of the tag."
          },
          "signUpKeyword": {
            "type": "string",
            "description": "Keyword for sign-up."
          },
          "shortCodeKeyword": {
            "type": "string",
            "description": "Short code keyword."
          },
          "confirmationText": {
            "type": "string",
            "description": "Confirmation text sent on tag assignment."
          },
          "sendFrom": {
            "type": "string",
            "description": "Phone number to send from."
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "tagId": {
            "type": "string",
            "description": "Unique tag identifier."
          },
          "tagName": {
            "type": "string",
            "description": "Name of the tag."
          },
          "signUpKeyword": {
            "type": "string"
          },
          "shortCodeKeyword": {
            "type": "string"
          },
          "confirmationText": {
            "type": "string"
          },
          "sendFrom": {
            "type": "string"
          }
        }
      },
      "TagContactAssignment": {
        "type": "object",
        "properties": {
          "customerName": {
            "type": "string",
            "description": "Customer name."
          },
          "phoneNumber": {
            "type": "string",
            "description": "Phone number to assign."
          },
          "assignmentDate": {
            "type": "string",
            "description": "Date of assignment."
          }
        }
      },
      "AppointmentInput": {
        "type": "object",
        "required": ["startDateTime", "endDateTime"],
        "properties": {
          "startDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "Start date and time of the appointment."
          },
          "endDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "End date and time of the appointment."
          },
          "serviceName": {
            "type": "string",
            "description": "Name of the service."
          },
          "customerName": {
            "type": "string",
            "description": "Customer name."
          },
          "customerPhone": {
            "type": "string",
            "description": "Customer phone number."
          },
          "customerEmail": {
            "type": "string",
            "description": "Customer email address."
          },
          "timeZone": {
            "type": "string",
            "description": "Timezone for the appointment."
          },
          "status": {
            "type": "string",
            "description": "Appointment status."
          }
        }
      },
      "WebhookSubscription": {
        "type": "object",
        "properties": {
          "target_url": {
            "type": "string",
            "description": "URL to receive webhook notifications."
          },
          "event": {
            "type": "string",
            "description": "Event type to subscribe to."
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "description": "Unique event identifier."
          },
          "eventType": {
            "type": "string",
            "description": "Type of the event."
          },
          "data": {
            "type": "object",
            "description": "Event data payload."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp."
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "errorCode": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "authCode": {
        "type": "apiKey",
        "in": "header",
        "name": "authCode",
        "description": "Authentication code for API access. Does not expire."
      },
      "partnerClientCode": {
        "type": "apiKey",
        "in": "header",
        "name": "partnerClientCode",
        "description": "Partner client code for multi-level organization access."
      }
    }
  },
  "security": [
    {
      "authCode": []
    }
  ]
}