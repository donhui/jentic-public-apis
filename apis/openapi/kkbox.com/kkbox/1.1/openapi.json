          "images": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Image" },
            "description": "Album cover images in various sizes"
          },
          "artist": { "$ref": "#/components/schemas/Artist" }
        }
      },
      "Artist": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Artist ID" },
