          { "name": "territory", "in": "query", "description": "Content territory", "schema": { "type": "string", "enum": ["TW", "HK", "SG", "MY", "JP"], "default": "TW" } }
        ],
        "responses": {
          "200": {
            "description": "Successful response with track metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Track" }
              }
