{
  "openapi": "3.0.3",
  "info": {
    "title": "KKBOX Open API",
    "description": "The KKBOX Open API provides access to KKBOX's music catalog, including tracks, albums, artists, playlists, charts, stations, and search functionality. Available territories include TW, HK, SG, MY, and JP.",
    "version": "1.1",
    "contact": {
      "name": "KKBOX Developer Support",
      "url": "https://developer.kkbox.com"
    },
    "x-jentic-source-url": "https://developer.kkbox.com"
  },
  "servers": [
    {
      "url": "https://api.kkbox.com/v1.1",
      "description": "KKBOX Open API v1.1 Production Server"
    }
  ],
  "tags": [
    { "name": "Search", "description": "Search for tracks, albums, artists, and playlists" },
    { "name": "Tracks", "description": "Track metadata" },
    { "name": "Albums", "description": "Album metadata and tracks" },
    { "name": "Artists", "description": "Artist metadata, albums, and top tracks" },
    { "name": "Shared Playlists", "description": "User-shared playlists" },
    { "name": "Featured Playlists", "description": "Editorially curated featured playlists" },
    { "name": "Featured Playlist Categories", "description": "Categories of featured playlists" },
    { "name": "New Hits Playlists", "description": "New hits playlists" },
    { "name": "New Release Categories", "description": "Categories for new album releases" },
    { "name": "Charts", "description": "Music chart playlists" },
    { "name": "Mood Stations", "description": "Mood-based radio stations" },
    { "name": "Genre Stations", "description": "Genre-based radio stations" }
  ],
  "security": [
    { "oauth2ClientCredentials": [] }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "search",
        "summary": "Search",
        "description": "Search for tracks, albums, artists, and playlists by keyword.",
        "tags": ["Search"],
        "parameters": [
          { "name": "q", "in": "query", "required": true, "description": "The search keyword", "schema": { "type": "string" } },
          { "name": "type", "in": "query", "description": "Type of search results to return. Multiple types can be comma-separated.", "schema": { "type": "string", "enum": ["artist", "album", "track", "playlist"] } },
          { "name": "territory", "in": "query", "description": "Content territory", "schema": { "type": "string", "enum": ["TW", "HK", "SG", "MY", "JP"], "default": "TW" } },
          { "name": "limit", "in": "query", "description": "Number of results per page", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "description": "Offset for pagination", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/tracks/{track_id}": {
