    "schemas": {
      "Image": {
        "type": "object",
        "properties": {
          "height": { "type": "integer", "description": "Image height in pixels" },
          "width": { "type": "integer", "description": "Image width in pixels" },
          "url": { "type": "string", "format": "uri", "description": "Image URL" }
        }
      },
      "Track": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Track ID" },
