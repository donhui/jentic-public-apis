          "track_number": { "type": "integer", "description": "Track number within the album" },
          "explicitness": { "type": "boolean", "description": "Whether the track has explicit content" },
          "available_territories": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of territories where the track is available"
          },
          "album": { "$ref": "#/components/schemas/Album" }
        }
      },
      "Album": {
        "type": "object",
        "properties": {
