{
  "openapi": "3.0.3",
  "info": {
    "title": "Twilio Programmable Video API",
    "description": "The Twilio Programmable Video REST API lets you create and manage Rooms for real-time video and audio communication. Use this API to create rooms, list rooms, manage participants, and access recordings and compositions. All resources use the base URL https://video.twilio.com.",
    "version": "1.0.0",
    "contact": {
      "name": "Twilio",
      "url": "https://www.twilio.com"
    },
    "x-jentic-source-url": "https://www.twilio.com/docs/video"
  },
  "servers": [
    {
      "url": "https://video.twilio.com/v1",
      "description": "Twilio Video API v1"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Rooms",
      "description": "Create and manage video rooms"
    },
    {
      "name": "Participants",
      "description": "Manage room participants"
    },
    {
      "name": "Recordings",
      "description": "Manage room recordings"
    },
    {
      "name": "Compositions",
      "description": "Manage video compositions"
    }
  ],
  "paths": {
    "/Rooms": {
      "post": {
        "operationId": "createRoom",
        "summary": "Create a Room",
        "description": "Create a new Programmable Video Room. Rooms created via REST API exist for five minutes to allow the first Participant to connect.",
        "tags": ["Rooms"],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoomRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Room created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Room"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "operationId": "listRooms",
        "summary": "List Rooms",
        "description": "List all Rooms.",
        "tags": ["Rooms"],
        "parameters": [
          {
            "name": "Status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["in-progress", "completed", "failed"]
            }
          },
          {
            "name": "UniqueName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "DateCreatedAfter",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "DateCreatedBefore",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of rooms",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoomListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/Rooms/{RoomNameOrSid}": {
      "get": {
        "operationId": "getRoom",
        "summary": "Fetch a Room",
        "description": "Retrieve a Room by its SID or UniqueName.",
        "tags": ["Rooms"],
        "parameters": [
          {
            "name": "RoomNameOrSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Room SID or UniqueName."
          }
        ],
        "responses": {
          "200": {
            "description": "Room details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Room"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "Room not found"
          }
        }
      },
      "post": {
        "operationId": "updateRoom",
        "summary": "Update a Room",
        "description": "Update a Room (e.g., set status to 'completed' to end the room).",
        "tags": ["Rooms"],
        "parameters": [
          {
            "name": "RoomNameOrSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["Status"],
                "properties": {
                  "Status": {
                    "type": "string",
                    "enum": ["completed"],
                    "description": "Set to 'completed' to end the room."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Room updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Room"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/Rooms/{RoomSid}/Participants": {
      "get": {
        "operationId": "listRoomParticipants",
        "summary": "List Room Participants",
        "description": "List all Participants in a Room.",
        "tags": ["Participants"],
        "parameters": [
          {
            "name": "RoomSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["connected", "disconnected"]
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of participants",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParticipantListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/Rooms/{RoomSid}/Participants/{ParticipantSid}": {
      "get": {
        "operationId": "getRoomParticipant",
        "summary": "Fetch a Participant",
        "description": "Retrieve a specific Participant in a Room.",
        "tags": ["Participants"],
        "parameters": [
          {
            "name": "RoomSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ParticipantSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Participant details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Participant"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/Rooms/{RoomSid}/Recordings": {
      "get": {
        "operationId": "listRoomRecordings",
        "summary": "List Room Recordings",
        "description": "List all Recordings for a Room.",
        "tags": ["Recordings"],
        "parameters": [
          {
            "name": "RoomSid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of recordings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordingListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/Compositions": {
      "post": {
        "operationId": "createComposition",
        "summary": "Create a Composition",
        "description": "Create a new Composition from Room recordings.",
        "tags": ["Compositions"],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CreateCompositionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Composition created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Composition"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "operationId": "listCompositions",
        "summary": "List Compositions",
        "description": "List Compositions.",
        "tags": ["Compositions"],
        "parameters": [
          {
            "name": "RoomSid",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["enqueued", "processing", "completed", "deleted", "failed"]
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of compositions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompositionListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your Twilio Account SID as the username and Auth Token as the password."
      }
    },
    "schemas": {
      "CreateRoomRequest": {
        "type": "object",
        "properties": {
          "UniqueName": {
            "type": "string",
            "description": "A unique name for the room."
          },
          "Type": {
            "type": "string",
            "enum": ["go", "peer-to-peer", "group", "group-small"]
          },
          "MaxParticipants": {
            "type": "integer",
            "description": "Maximum number of concurrent participants (max 50)."
          },
          "MaxParticipantDuration": {
            "type": "integer",
            "description": "Max seconds a participant can be connected (max 86400)."
          },
          "StatusCallback": {
            "type": "string",
            "format": "uri"
          },
          "StatusCallbackMethod": {
            "type": "string",
            "enum": ["GET", "POST"]
          },
          "RecordParticipantsOnConnect": {
            "type": "boolean"
          },
          "VideoCodecs": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["VP8", "H264"]
            }
          },
          "AudioOnly": {
            "type": "boolean"
          },
          "EmptyRoomTimeout": {
            "type": "integer",
            "description": "Minutes room stays active after last participant leaves (1-60)."
          },
          "UnusedRoomTimeout": {
            "type": "integer",
            "description": "Minutes room stays active if no one joins (1-60)."
          },
          "LargeRoom": {
            "type": "boolean"
          }
        }
      },
      "Room": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string",
            "pattern": "^RM[0-9a-fA-F]{32}$"
          },
          "account_sid": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["in-progress", "completed", "failed"]
          },
          "type": {
            "type": "string",
            "enum": ["go", "peer-to-peer", "group", "group-small"]
          },
          "unique_name": {
            "type": "string"
          },
          "max_participants": {
            "type": "integer"
          },
          "max_participant_duration": {
            "type": "integer"
          },
          "max_concurrent_published_tracks": {
            "type": "integer"
          },
          "duration": {
            "type": "integer"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "date_updated": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "status_callback": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "status_callback_method": {
            "type": "string"
          },
          "record_participants_on_connect": {
            "type": "boolean"
          },
          "video_codecs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "media_region": {
            "type": "string"
          },
          "audio_only": {
            "type": "boolean"
          },
          "empty_room_timeout": {
            "type": "integer"
          },
          "unused_room_timeout": {
            "type": "integer"
          },
          "large_room": {
            "type": "boolean"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "links": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      },
      "RoomListResponse": {
        "type": "object",
        "properties": {
          "rooms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Room"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "Participant": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string"
          },
          "room_sid": {
            "type": "string"
          },
          "account_sid": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["connected", "disconnected"]
          },
          "identity": {
            "type": "string"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "date_updated": {
            "type": "string",
            "format": "date-time"
          },
          "duration": {
            "type": "integer"
          }
        }
      },
      "ParticipantListResponse": {
        "type": "object",
        "properties": {
          "participants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Participant"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "Recording": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string"
          },
          "room_sid": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "duration": {
            "type": "integer"
          },
          "size": {
            "type": "integer"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RecordingListResponse": {
        "type": "object",
        "properties": {
          "recordings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Recording"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "CreateCompositionRequest": {
        "type": "object",
        "required": ["RoomSid"],
        "properties": {
          "RoomSid": {
            "type": "string"
          },
          "VideoLayout": {
            "type": "object"
          },
          "AudioSources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "Resolution": {
            "type": "string"
          },
          "Format": {
            "type": "string",
            "enum": ["mp4", "webm"]
          },
          "StatusCallback": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Composition": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string"
          },
          "room_sid": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["enqueued", "processing", "completed", "deleted", "failed"]
          },
          "duration": {
            "type": "integer"
          },
          "resolution": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CompositionListResponse": {
        "type": "object",
        "properties": {
          "compositions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Composition"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "first_page_url": {
            "type": "string",
            "format": "uri"
          },
          "previous_page_url": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "next_page_url": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "key": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "more_info": {
            "type": "string",
            "format": "uri"
          },
          "status": {
            "type": "integer"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid credentials",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
