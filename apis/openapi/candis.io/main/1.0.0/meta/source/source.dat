{
  "openapi": "3.0.3",
  "info": {
    "title": "Candis API",
    "version": "1.0.0",
    "description": "Candis API provides endpoints for exporting accounting data, managing core data (general ledger accounts, contacts, cost dimensions, tax codes, payment conditions), and downloading related documents.",
    "x-jentic-source-url": "https://developer.candis.io"
  },
  "servers": [
    {
      "url": "https://api.candis.io/v1",
      "description": "Candis Production API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Organizations",
      "description": "Organization information"
    },
    {
      "name": "Exports",
      "description": "Export management"
    },
    {
      "name": "General Ledger Accounts",
      "description": "GL account imports"
    },
    {
      "name": "Cost Dimensions",
      "description": "Cost center and cost object imports"
    },
    {
      "name": "Tax Codes",
      "description": "Tax code imports"
    },
    {
      "name": "Contacts",
      "description": "Contact imports"
    },
    {
      "name": "Payment Conditions",
      "description": "Payment condition imports"
    },
    {
      "name": "Additional Delivery Costs",
      "description": "Delivery cost imports"
    },
    {
      "name": "Import Logs",
      "description": "Import process logs"
    },
    {
      "name": "Files",
      "description": "File downloads"
    }
  ],
  "paths": {
    "/organizations/info": {
      "get": {
        "operationId": "getorganizationinfo",
        "summary": "Get organization information",
        "tags": [
          "Organizations"
        ],
        "responses": {
          "200": {
            "description": "Organization info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Organization"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{organizationId}/exports": {
      "post": {
        "operationId": "createexport",
        "summary": "Create an export of approved invoices",
        "tags": [
          "Exports"
        ],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "entityType": {
                    "type": "string",
                    "enum": [
                      "DOCUMENT",
                      "REIMBURSEMENT_ITEM",
                      "CARD_TRANSACTION"
                    ],
                    "default": "DOCUMENT"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Export created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Export"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listexports",
        "summary": "Get list of all exports",
        "tags": [
          "Exports"
        ],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of exports",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExportList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{organizationId}/exports/{exportId}": {
      "get": {
        "operationId": "getexport",
        "summary": "Get a specific export",
        "tags": [
          "Exports"
        ],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exportId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
