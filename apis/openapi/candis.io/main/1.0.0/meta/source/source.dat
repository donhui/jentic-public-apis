    "/organizations/{organizationId}/imports/additional-delivery-costs": {
      "post": {
        "operationId": "createadditionaldeliverycosts",
        "summary": "Import additional delivery costs",
        "tags": [
          "Additional Delivery Costs"
        ],
        "parameters": [
          {
            "name": "organizationId",
