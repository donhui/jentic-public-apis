{
  "openapi": "3.0.3",
  "info": {
    "title": "Bible API",
    "version": "1.0.0",
    "description": "Free Bible verse API providing reference lookup, translations, random verses, and chapter/book browsing. Default translation is WEB (World English Bible).",
    "x-jentic-source-url": "https://bible-api.com"
  },
  "servers": [
    {
      "url": "https://bible-api.com"
    }
  ],
  "paths": {
    "/{reference}": {
      "get": {
        "operationId": "getVersesByReference",
        "summary": "Get verses by reference",
        "description": "Retrieve specific verse(s) using a natural language reference format like 'John 3:16' or 'Romans 8:28-30'.",
        "tags": ["Verses"],
        "parameters": [
          {
            "name": "reference",
            "in": "path",
            "required": true,
            "description": "Bible verse reference (e.g., 'John 3:16', 'Genesis 1:1-5').",
            "schema": { "type": "string" }
          },
          {
            "name": "translation",
            "in": "query",
            "description": "Translation identifier. Defaults to 'web'.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerseResponse" }
              }
            }
          },
          "400": { "description": "Bad request - invalid reference format" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/data": {
      "get": {
        "operationId": "listTranslations",
        "summary": "List available translations",
        "description": "Returns a list of all available Bible translations.",
        "tags": ["Data"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Translation" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/data/{translationId}": {
      "get": {
        "operationId": "listBooks",
        "summary": "List books in a translation",
        "description": "Returns all books available in a specific translation.",
        "tags": ["Data"],
        "parameters": [
          {
            "name": "translationId",
            "in": "path",
            "required": true,
            "description": "The translation identifier.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Book" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/data/{translationId}/{bookId}": {
      "get": {
        "operationId": "listChapters",
        "summary": "List chapters in a book",
        "description": "Returns all chapters available in a specific book and translation.",
        "tags": ["Data"],
        "parameters": [
          {
            "name": "translationId",
            "in": "path",
            "required": true,
            "description": "The translation identifier.",
            "schema": { "type": "string" }
          },
          {
            "name": "bookId",
            "in": "path",
            "required": true,
            "description": "The book identifier.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Chapter" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/data/{translationId}/{bookId}/{chapter}": {
      "get": {
        "operationId": "getChapterVerses",
        "summary": "Get all verses in a chapter",
        "description": "Returns all verses in a specific chapter of a book.",
        "tags": ["Data"],
        "parameters": [
          {
            "name": "translationId",
            "in": "path",
            "required": true,
            "description": "The translation identifier.",
            "schema": { "type": "string" }
          },
          {
            "name": "bookId",
            "in": "path",
            "required": true,
            "description": "The book identifier.",
            "schema": { "type": "string" }
          },
          {
            "name": "chapter",
            "in": "path",
            "required": true,
            "description": "The chapter number.",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerseResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/data/{translationId}/random": {
      "get": {
        "operationId": "getRandomVerse",
        "summary": "Get a random verse",
        "description": "Returns a random verse from the specified translation.",
        "tags": ["Data"],
        "parameters": [
          {
            "name": "translationId",
            "in": "path",
            "required": true,
            "description": "The translation identifier.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerseResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VerseResponse": {
        "type": "object",
        "properties": {
          "reference": { "type": "string", "description": "The verse reference." },
          "verses": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Verse" }
          },
          "text": { "type": "string", "description": "Combined text of all verses." },
          "translation_id": { "type": "string" },
          "translation_name": { "type": "string" },
          "translation_note": { "type": "string" }
        }
      },
      "Verse": {
        "type": "object",
        "properties": {
          "book_id": { "type": "string" },
          "book_name": { "type": "string" },
          "chapter": { "type": "integer" },
          "verse": { "type": "integer" },
          "text": { "type": "string" }
        }
      },
      "Translation": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "language": { "type": "string" },
          "note": { "type": "string" }
        }
      },
      "Book": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Chapter": {
        "type": "object",
        "properties": {
          "chapter": { "type": "integer" },
          "verse_count": { "type": "integer" }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}