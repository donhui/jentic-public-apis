  "components": {
    "schemas": {
      "Record": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "object"
          },
          "status": {
            "type": "object"
          },
          "description": {
            "type": "string"
          },
          "openedDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Inspection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "object"
          },
          "status": {
            "type": "object"
          },
          "scheduledDate": {
            "type": "string",
            "format": "date-time"
          },
          "resultDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
