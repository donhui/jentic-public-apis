{
  "openapi": "3.0.3",
  "info": {
    "title": "Accela Civic Platform API",
    "version": "4.0.0",
    "description": "Accela Civic Platform V4 API for government agencies. Provides access to records, inspections, contacts, addresses, parcels, documents, workflows, payments, and more for civic engagement applications.",
    "x-jentic-source-url": "https://developer.accela.com/docs/api_reference/api-index.html"
  },
  "servers": [
    {
      "url": "https://apis.accela.com",
      "description": "API server"
    },
    {
      "url": "https://auth.accela.com",
      "description": "Authentication server"
    }
  ],
  "paths": {
    "/oauth2/authorize": {
      "get": {
        "operationId": "getAuthorizationCode",
        "summary": "Get authorization code",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "code"
              ]
            }
          },
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "agency_name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect with authorization code"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/oauth2/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Get access token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "code": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "redirect_uri": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/oauth2/tokeninfo": {
      "get": {
        "operationId": "getTokenInfo",
        "summary": "Get token information",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token info"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
