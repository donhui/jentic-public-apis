{
  "openapi": "3.0.3",
  "info": {
    "title": "TasteDive API",
    "version": "1.0.0",
    "description": "TasteDive provides taste-based recommendations for music, movies, TV shows, podcasts, books, games, people, places, and brands. Single endpoint API that returns similar items based on input queries.",
    "x-jentic-source-url": "https://tastedive.com/read/api"
  },
  "servers": [
    { "url": "https://tastedive.com/api" }
  ],
  "paths": {
    "/similar": {
      "get": {
        "operationId": "getSimilarItems",
        "summary": "Get similar recommendations",
        "description": "Returns recommendations based on one or more search queries. Supports multiple content types.",
        "tags": ["Recommendations"],
        "parameters": [
          { "name": "q", "in": "query", "required": true, "description": "Comma-separated search items. Prefix with type (e.g., 'music:radiohead, movie:inception')", "schema": { "type": "string" } },
          { "name": "type", "in": "query", "required": true, "description": "Result type filter", "schema": { "type": "string", "enum": ["music", "movie", "show", "podcast", "book", "game", "person", "place", "brand"] } },
          { "name": "info", "in": "query", "description": "Set to 1 for additional data (descriptions, YouTube clips)", "schema": { "type": "integer", "enum": [0, 1], "default": 0 } },
          { "name": "limit", "in": "query", "description": "Maximum recommendations returned", "schema": { "type": "integer", "default": 20 } },
          { "name": "slimit", "in": "query", "description": "Max search results per query item (1-3)", "schema": { "type": "integer" } },
          { "name": "k", "in": "query", "description": "API access key", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Recommendations",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SimilarResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SimilarResponse": {
        "type": "object",
        "properties": {
          "similar": {
            "type": "object",
            "properties": {
              "info": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/ItemInfo" }
              },
              "results": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/ItemInfo" }
              }
            }
          }
        }
      },
      "ItemInfo": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "wTeaser": { "type": "string", "description": "Wikipedia teaser text (when info=1)" },
          "wUrl": { "type": "string", "description": "Wikipedia URL (when info=1)" },
          "yUrl": { "type": "string", "description": "YouTube URL (when info=1)" },
          "yID": { "type": "string", "description": "YouTube video ID (when info=1)" }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "k",
        "description": "TasteDive API access key"
      }
    }
  },
  "security": [
    { "apiKey": [] }
  ]
}
