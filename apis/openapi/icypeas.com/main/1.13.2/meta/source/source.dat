{
  "openapi": "3.0.3",
  "info": {
    "title": "Icypeas API",
    "version": "1.13.2",
    "description": "Icypeas is an email finder leveraging data from open sources. The API allows email discovery, email verification, bulk search, domain scanning, reverse email lookup, profile/company scraping, lead database search, and subscription management.",
    "x-jentic-source-url": "https://api-doc.icypeas.com/getting-started"
  },
  "servers": [
    {
      "url": "https://app.icypeas.com/api",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {"name": "Email Discovery", "description": "Find email addresses"},
    {"name": "Email Verification", "description": "Verify email addresses"},
    {"name": "Bulk Search", "description": "Launch and manage bulk searches"},
    {"name": "Domain Scan", "description": "Scan domains for role-based addresses"},
    {"name": "Reverse Email Lookup", "description": "Find profile URLs from email addresses"},
    {"name": "Results", "description": "Fetch search results and bulk search files"},
    {"name": "Lead Database", "description": "Search people and companies database"},
    {"name": "Scraping", "description": "Scrape profiles and companies"},
    {"name": "URL Search", "description": "Find profile and company URLs"},
    {"name": "Subscription", "description": "Manage subscription information"}
  ],
  "paths": {
    "/email-search": {
      "post": {
        "operationId": "emailDiscovery",
        "summary": "Find a Single Email Address",
        "description": "Find an email address from a firstname, lastname, and company domain name. Use bulk search for many searches.",
        "tags": ["Email Discovery"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmailSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SingleSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/email-verification": {
      "post": {
        "operationId": "emailVerification",
        "summary": "Verify a Single Email Address",
        "description": "Verify if a specific email address exists. Use bulk search for many verifications.",
        "tags": ["Email Verification"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmailVerificationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SingleSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/domain-search": {
      "post": {
        "operationId": "domainScan",
        "summary": "Scan a Single Domain",
        "description": "Scan a domain to discover all role-based email addresses (e.g., contact@, admin@). Use bulk search for many scans.",
        "tags": ["Domain Scan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DomainSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Domain scan initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SingleSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/reverse-email-lookup": {
      "post": {
        "operationId": "reverseEmailLookup",
        "summary": "Reverse Email Lookup",
        "description": "Find the profile URL behind a single professional email address.",
        "tags": ["Reverse Email Lookup"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReverseEmailLookupRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lookup result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReverseEmailLookupResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/bulk-search": {
      "post": {
        "operationId": "bulkSearch",
        "summary": "Launch Bulk Search",
        "description": "Launch a bulk search. Each bulk search can contain up to 5000 items. Supported tasks: email-search, email-verification, domain-search.",
        "tags": ["Bulk Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk search launched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/bulk-single-searchs/read": {
      "post": {
        "operationId": "readSearchItem",
        "summary": "Retrieve Search Item Results",
        "description": "Retrieve your search results. Each result is stored as a search item containing found emails, status, person info, and verification level.",
        "tags": ["Results"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReadSearchItemRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search items retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchItemResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/search-files/read": {
      "post": {
        "operationId": "readBulkSearchFiles",
        "summary": "Fetch Bulk Search Files",
        "description": "Fetch information and stats about your bulk searches. The route is paginated.",
        "tags": ["Results"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReadBulkSearchFilesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk search files retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkSearchFilesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/leads/people": {
      "post": {
        "operationId": "findPeople",
        "summary": "Find People",
        "description": "Search the people dataset using various filters such as firstname, lastname, job title, company, location, industry, and more.",
        "tags": ["Lead Database"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindPeopleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "People search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeadSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/leads/companies": {
      "post": {
        "operationId": "findCompanies",
        "summary": "Find Companies",
        "description": "Search the companies dataset using various filters such as company name, industry, size, location, and more.",
        "tags": ["Lead Database"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindCompaniesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Companies search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeadSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/scrape/profile": {
      "get": {
        "operationId": "scrapeProfile",
        "summary": "Scrape a Single Profile",
        "description": "Scrape a single user profile from the provided URL.",
        "tags": ["Scraping"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The profile URL to scrape"
          }
        ],
        "responses": {
          "200": {
            "description": "Profile data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeProfileResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/scrape/company": {
      "get": {
        "operationId": "scrapeCompany",
        "summary": "Scrape a Single Company",
        "description": "Scrape a single company from the provided URL.",
        "tags": ["Scraping"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The company URL to scrape"
          }
        ],
        "responses": {
          "200": {
            "description": "Company data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeCompanyResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/url-search/profile": {
      "post": {
        "operationId": "searchProfileUrl",
        "summary": "Find Profile URL",
        "description": "Find a single profile URL from firstname, lastname, and company or job title.",
        "tags": ["URL Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileUrlSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile URL found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UrlSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/url-search/company": {
      "post": {
        "operationId": "searchCompanyUrl",
        "summary": "Find Company URL",
        "description": "Find a single company URL from company name or domain.",
        "tags": ["URL Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompanyUrlSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Company URL found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UrlSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/a/actions/subscription-information": {
      "post": {
        "operationId": "getSubscriptionInfo",
        "summary": "Get Subscription Information",
        "description": "Retrieve information about your subscription including credits and user ID.",
        "tags": ["Subscription"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscriptionInfoRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionInfoResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key obtained from the API section in your Icypeas profile"
      }
    },
    "schemas": {
      "EmailSearchRequest": {
        "type": "object",
        "required": ["firstname", "lastname", "domainOrCompany"],
        "properties": {
          "firstname": {
            "type": "string",
            "description": "First name of the person"
          },
          "lastname": {
            "type": "string",
            "description": "Last name of the person"
          },
          "domainOrCompany": {
            "type": "string",
            "description": "Company domain or company name"
          },
          "custom": {
            "type": "object",
            "description": "Custom data to attach to the search"
          },
          "webhookUrl": {
            "type": "string",
            "description": "Custom webhook URL for this specific search"
          }
        }
      },
      "EmailVerificationRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "description": "The email address to verify"
          },
          "custom": {
            "type": "object",
            "description": "Custom data to attach to the search"
          },
          "webhookUrl": {
            "type": "string",
            "description": "Custom webhook URL for this specific search"
          }
        }
      },
      "DomainSearchRequest": {
        "type": "object",
        "required": ["domainOrCompany"],
        "properties": {
          "domainOrCompany": {
            "type": "string",
            "description": "Domain or company name to scan"
          },
          "custom": {
            "type": "object",
            "description": "Custom data to attach to the search"
          },
          "webhookUrl": {
            "type": "string",
            "description": "Custom webhook URL for this specific search"
          }
        }
      },
      "ReverseEmailLookupRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "description": "A professional email address"
          }
        }
      },
      "ReverseEmailLookupResponse": {
        "type": "object",
        "properties": {
          "profileUrl": {
            "type": "string",
            "description": "The profile URL found for the email"
          },
          "status": {
            "type": "string",
            "description": "Search status"
          }
        }
      },
      "BulkSearchRequest": {
        "type": "object",
        "required": ["name", "task", "data"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the bulk search"
          },
          "task": {
            "type": "string",
            "enum": ["email-search", "email-verification", "domain-search"],
            "description": "The task to execute"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Array of data rows. For email-search: [firstname, lastname, domain]. For email-verification: [email]. For domain-search: [domain]. Max 5000 items."
          }
        }
      },
      "BulkSearchResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Bulk search file ID"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "SingleSearchResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The search item ID"
          },
          "status": {
            "type": "string",
            "description": "Search status"
          }
        }
      },
      "ReadSearchItemRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Search item ID to retrieve"
          },
          "searchFileId": {
            "type": "string",
            "description": "Bulk search file ID to retrieve items from"
          },
          "page": {
            "type": "integer",
            "description": "Page number for pagination"
          },
          "limit": {
            "type": "integer",
            "description": "Number of items per page"
          }
        }
      },
      "SearchItemResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchItem"
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          }
        }
      },
      "SearchItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string"
          },
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "certainty": {
            "type": "string"
          }
        }
      },
      "ReadBulkSearchFilesRequest": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Filter by status (e.g., 'in_progress', 'done')"
          },
          "id": {
            "type": "string",
            "description": "Specific file ID"
          },
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "BulkSearchFilesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BulkSearchFile"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "BulkSearchFile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "task": {
            "type": "string"
          },
          "total_items": {
            "type": "integer"
          },
          "completed_items": {
            "type": "integer"
          }
        }
      },
      "FindPeopleRequest": {
        "type": "object",
        "properties": {
          "firstname": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "lastname": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "jobTitle": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "companyName": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "location": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "industry": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "FindCompaniesRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "industry": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "location": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "size": {
            "type": "object",
            "properties": {
              "include": {"type": "array", "items": {"type": "string"}},
              "exclude": {"type": "array", "items": {"type": "string"}}
            }
          },
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "LeadSearchResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          }
        }
      },
      "ScrapeProfileResponse": {
        "type": "object",
        "properties": {
          "found": {
            "type": "boolean"
          },
          "profile": {
            "type": "object",
            "description": "Profile data when found"
          }
        }
      },
      "ScrapeCompanyResponse": {
        "type": "object",
        "properties": {
          "found": {
            "type": "boolean"
          },
          "company": {
            "type": "object",
            "description": "Company data when found"
          }
        }
      },
      "ProfileUrlSearchRequest": {
        "type": "object",
        "required": ["firstname", "lastname"],
        "properties": {
          "firstname": {
            "type": "string",
            "description": "First name of the prospect"
          },
          "lastname": {
            "type": "string",
            "description": "Last name of the prospect"
          },
          "companyOrDomain": {
            "type": "string",
            "description": "Company name or domain (required if jobTitle is empty)"
          },
          "jobTitle": {
            "type": "string",
            "description": "Job title (required if companyOrDomain is empty)"
          }
        }
      },
      "CompanyUrlSearchRequest": {
        "type": "object",
        "required": ["companyOrDomain"],
        "properties": {
          "companyOrDomain": {
            "type": "string",
            "description": "Company name or domain"
          }
        }
      },
      "UrlSearchResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "The found URL"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "SubscriptionInfoRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
