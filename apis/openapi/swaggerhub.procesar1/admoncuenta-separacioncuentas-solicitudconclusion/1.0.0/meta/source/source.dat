      "solicitudConclusionResponse": {
        "required": [
          "origenSolicitud",
          "claveEntidadOrigen",
          "nssInvadido",
          "resultadoOperacion",
          "diagnosticoProceso"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud",
            "example": "01"
          },
          "claveEntidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que env\u00eda la solicitud",
            "example": "300"
          },
          "nssInvadido": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 11,
            "description": "Numero de Seguridad Social del Invadido",
            "example": "12345678901"
          },
          "marcaRegimenPensionarioNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4,
            "description": "Indica la marca de r\u00e9gimen pensionario que corresponde al NSS invadido, en donde:\n\n9F00 Bono\n\n9G02 No bono afirmativo\n\n9G04 No bono por reingreso\n\n9E01 Reingreso Nueva Ley\n\n9E00 Trabajador nuevo 31/03/2007 Nueva ley\n\n9G03 No bono Negativa\n\n9G06 Vieja Ley\n\n9G05 Voluntario para cotizar en el ISSSTE    \n",
            "example": "9F00"
          },
          "claveAforeSaldosAdicionales71NssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "Solo se notificar\u00e1 este campo cuando la solicitud sea rechazada por 123, y otras Afores hayan reportado saldos de vivienda",
            "example": "clave123456789"
          },
          "nssAsociado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 11,
            "description": "Numero de Seguridad Social del Asociado",
            "example": "12345678901"
          },
          "marcaRegimenPensionarioNssAsociado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4,
            "description": "Indica la marca de r\u00e9gimen pensionario que corresponde al NSS asociado, en donde:\n\n9F00 Bono\n\n9G02 No bono afirmativo\n\n9G04 No bono por reingreso\n\n9E01 Reingreso Nueva Ley\n\n9E00 Trabajador nuevo 31/03/2007 Nueva ley\n\n9G03 No bono Negativa\n\n9G06 Vieja Ley\n\n9G05 Voluntario para cotizar en el ISSSTE    \n",
            "example": "9F00"
          },
          "claveAforeSaldosAdicionales71NssAsociado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "Solo se notificar\u00e1 este campo cuando la solicitud sea rechazada por 123, y otras Afores hayan reportado saldos de vivienda",
            "example": "clave123456789"
          },
          "resultadoOperacion": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operaci\u00f3n, en donde:\n\n01 Solicitud Aceptada.\n\n02 Solicitud Rechazada por Procesar.\n\n03 Solicitud Pendiente por Marca Operativa.\n\n04 Solicitud Rechazada por Infonavit.\n\n05 Solicitud sin respuesta del servicio del Infonavit.      \n",
            "example": "02"
          },
          "diagnosticoProceso": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "Diagn\u00f3stico del proceso, cuando el resultado de la operaci\u00f3n en rechazo (02).\n\n000 Solicitud aceptada\n\n068 Tipo de registro inv\u00e1lido\n\n022 Afore no existente\n\n026 Fecha de Nacimiento inv\u00e1lida      \n\n027 Entidad Federativa de Nacimiento inv\u00e1lida\n\nB46 La nacionalidad del trabajador enviada por la AFORE no existe dentro del cat\u00e1logo de nacionalidades      \n\n011 Indicador de marcaje invalido\n\n816 Cuenta con operaci\u00f3n fuera de secuencia\n\n489 Trabajador afiliado en otra AFORE\n\nC04 Datos base CURP diferentes a los registrados en la BDNSAR\n\n938 El trabajador no se encuentra en proceso de Separaci\u00f3n de Cuentas\n\nD21 CURP debe de venir requisitada, ya que existen saldos FOVISSSTE\n\n123 Diferencias en saldos de vivienda\n\n010 NSS invadido marcado con otra pareja previamente\n\n020 NSS asociado marcado con otra pareja previamente\n\n030 Campo \"___(indicar campo)\" no cumple con longitud\n\n040 Campo \"___(indicar campo)\" no cumple con tipo de dato\n\n060 NSS en proceso de disposicion de recursos por retiro\n\n080 NSS en conciliacion de saldos con otra pareja\n\n090 Saldo insuficiente de los NSS\u00b4s para concluir separaci\u00f3n\n\n03L La notificaci\u00f3n no fue exitosa\n",
            "example": "816"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  }
}