    "schemas": {
      "solicitudConclusionRequest": {
        "required": [
          "origenSolicitud",
          "claveEntidadOrigen",
          "nssInvadido",
          "apellidoPaternoNssInvadido",
          "nombretrabajadorsNssInvadido",
