            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Saldo en AIVS FOVISSSTE vivienda 92 invadido, en caso de no tener saldo se deben enviar cero",
            "example": "1123456"
          },
          "saldoAivsFovisssteVivienda08Invadido": {
            "pattern": "^[0-9]{1,9}|[0-9]{0,9}[.]{1}[0-9]{1,6}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Saldo en AIVS INFONAVIT vivienda 08 invadido, en caso de no tener saldo se deben enviar cero",
            "example": "1123456"
          },
          "nrpInvadido": {
            "type": "array",
            "items": {
