          "saldoAivsFovisssteVivienda92Asociado",
          "saldoAivsFovisssteVivienda08Asociado"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n",
            "example": "01"
          },
          "claveEntidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que env\u00eda la solicitud",
            "example": "300"
          },
          "nssInvadido": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 11,
            "description": "Numero de Seguridad Social Invadido, obligatorio si no se env\u00eda el NSS Asociado",
            "example": "12345678901"
          },
          "curpTrabajadorInvadido": {
            "pattern": "^([A-Z][AEIOUX][A-Z]{2}\\d{2}(?:0[1-9]|1[0-2])(?:0[1-9]|[12]\\d|3[01])[HM](?:AS|B[CS]|C[CLMSH]|D[FG]|G[TR]|HG|JC|M[CNS]|N[ETL]|OC|PL|Q[TR]|S[PLR]|T[CSL]|VZ|YN|ZS)[B-DF-HJ-NP-TV-Z]{3}[A-Z\\d])(\\d)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 18,
            "description": "CURP que le corresponde al NSS invadido",
            "example": "CAHF620818HMNLNL09"
          },
          "apellidoPaternoNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno del NSS invadido",
            "example": "lopez"
          },
          "apellidoMaternoNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno del NSS invadido",
            "example": "lopez"
          },
          "nombretrabajadorsNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre Trabajador(s) del NSS invadido",
            "example": "hugo"
          },
          "fechaNacimientoNssInvadido": {
            "pattern": "^(19|20)(((([02468][048])|([13579][26]))-02-29)|(\\d{2})((02-((0[1-9])|1\\d|2[0-8]))|((((0[13456789])|1[012]))((0[1-9])|((1|2)\\d)|30))|(((0[13578])|(1[02]))-31)))$",
            "type": "string",
            "minLength": 1,
            "maxLength": 8,
            "description": "Fecha de nacimiento del NSS invadido",
            "example": "20620818"
          },
          "sexoNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo. Donde:1=M (masculino); 2=F(femenino); 3=X(no binario)",
            "example": "1"
          },
          "entidadNacimientoNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Seg\u00fan Catalogo General Clave de las Entidades Federativas",
            "example": "01"
          },
          "nacionalidadNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3,
            "description": "Seg\u00fan Cat\u00e1logo de pa\u00edses",
            "example": "001"
          },
          "rfcNssInvadido": {
            "pattern": "^([A-Z\u00d1&]{3,4}) ?(?:- ?)?(\\d{2}(?:0[1-9]|1[0-2])(?:0[1-9]|[12]\\d|3[01])) ?(?:- ?)?([A-Z\\d]{2})([A\\d])$",
            "type": "string",
            "minLength": 1,
            "maxLength": 13,
            "description": "RFC del NSS",
            "example": "CAHF6208182S2"
          },
          "indicadorMarcajeCuenta": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Marcaje de la Cuenta. Donde:0 = Continua Marcado 1 = Desmarcar 3 = Desmarca cuenta y pone marca informativa Separaci\u00f3n Concluida con Disposici\u00f3n de Recursos",
            "example": "0"
          },
          "saldoAivsInfonavitVivienda92Invadido": {
            "pattern": "^[0-9]{1,9}|[0-9]{0,9}[.]{1}[0-9]{1,6}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Saldo en AIVS INFONAVIT vivienda 92 invadido, en caso de no tener saldo se deben enviar cero",
            "example": "1123456"
          },
          "saldoAivsInfonavitVivienda97Invadido": {
            "pattern": "^[0-9]{1,9}|[0-9]{0,9}[.]{1}[0-9]{1,6}$",
