  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "prevalidadarRegistroRequest": {
        "required": [
          "origenEnvio",
          "tipoSolicitud",
          "entidadOrigen",
          "curp",
          "solicitante"
        ],
        "type": "object",
        "properties": {
          "origenEnvio": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "example": "1",
            "description": "Origen env\u00edo."
          },
          "tipoSolicitud": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "example": "1",
            "description": "Tipo de solicitud."
          },
          "origenPrevalidacion": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "example": "1",
            "description": "Origen de solicitud de Prevalidaci\u00f3n."
          },
          "entidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "500",
            "description": "Entidad Origen."
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n",
            "example": "XXXX111111XXXXXX11"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguro Social.",
            "example": "12345678901"
          },
          "solicitante": {
            "pattern": "^([0-9])$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Solicitante",
            "example": "01"
          },
          "curpTutor": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del tutor",
            "example": "XXXX111111XXXXXX11"
          },
          "curpEmpleado": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del tutor",
            "example": "XXXX111111XXXXXX11"
          },
          "selloVerificacionBiometrica": {
            "type": "string",
            "minLength": 14,
            "maxLength": 14,
            "example": "12345678901234",
            "description": "Sello de Verificacion Biometrica"
          }
        }
      },
      "prevalidadarRegistroResponse": {
        "required": [
          "resultadoOperacion",
          "entidadOrigen",
          "curp"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la Operaci\u00f3n\n\n01 = Aceptada\n\n02 = Rechazada\n",
            "example": "01"
          },
          "diagnosticoOperacion": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "022",
            "description": "Diagn\u00f3stico de la operaci\u00f3n. \n\nD11 Cuenta en Proceso de Solicitud de saldo en garant\u00eda 43 bis \n\n815 Cuenta en Proceso de Devoluci\u00f3n de Excedentes 43 bis& \n\n072 Cuenta en Proceso de Traspasos ISSSTE \n\nA14 Cuenta en Proceso de Transferencias FOVISSSTE \n\nD13 Cuenta en Proceso de Devoluci\u00f3n de Saldos Excedentes FOVISSSTE \n\nF68 Cuenta en Proceso de Registro M\u00f3vil de Ahorradores Independientes \n\nC33 Cuenta en Proceso de Asignaci\u00f3n de Cuentas (Prestadora de Servicios) \n\nD14 Cuenta en Proceso de Aportaciones Subsecuentes FOVISSSTE \n"
          },
          "origenEnvio": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "example": "1",
            "description": "Origen env\u00edo."
          },
          "tipoSolicitud": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "example": "1",
            "description": "Tipo de solicitud."
          },
          "origenPrevalidacion": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "example": "1",
            "description": "Origen env\u00edo."
          },
          "entidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "500",
            "description": "Entidad Origen."
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n",
            "example": "XXXX111111XXXXXX11"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguro Social.",
            "example": "12345678901"
          },
          "solicitante": {
            "pattern": "^([0-9])$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Solicitante",
            "example": "01"
          },
          "curpTutor": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del tutor",
            "example": "XXXX111111XXXXXX11"
          },
          "nombre": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "example": "nombre",
            "description": "Nombre"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "example": "apellidoPaterno",
            "description": "Apellido Paterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "example": "apellidoMaterno",
            "description": "Apellido Materno"
          },
          "sexo": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo\n\n H : Hombre\n \n M : Mujer\n",
            "example": "H"
          },
          "cveAfiliacion": {
            "pattern": "^([0-9])$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave de Afiliaci\u00f3n",
            "example": "01"
          },
          "cveNacionalidad": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave Nacionalidad",
            "example": "MEX"
          },
          "cveEntidadnacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave Entidad de Nacimiento",
            "example": "PU"
          },
          "fechaNacimiento": {
            "pattern": "^[0-3]{1}[0-9]{1}[/]{1}[0,1]{1}[0-9]{1}[/][0-2]{1}[0-9]{3}$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Fecha de nacimiento.",
            "example": "02/05/2022"
          },
          "tipoDuplicidad": {
            "pattern": "^([0-9])$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Tipo de Duplicidad",
            "example": "01"
          },
          "nssAsociado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS de Asociado.",
            "example": "12345678901"
          },
          "nombreEnProcanase": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Nombre Trabajador.",
            "example": "nombreEnProcanase"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  }
}