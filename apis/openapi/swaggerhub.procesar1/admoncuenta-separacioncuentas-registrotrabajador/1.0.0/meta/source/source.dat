  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "registroTrabajadorRequest": {
        "required": [
          "origenSolicitud",
          "claveEntidadOrigen",
          "idNegocio",
          "rfc",
          "apellidoPaterno",
          "nombreTrabajador",
          "fechaNacimiento",
          "sexo",
          "entidadFederativaNacimiento",
          "nacionalidad"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n",
            "example": "01"
          },
          "claveEntidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que env\u00eda la solicitud",
            "example": "300"
          },
          "idNegocio": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "ID Negocio (NSS del trabajador)",
            "example": "11111111111"
          },
          "rfc": {
            "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
            "type": "string",
            "minLength": 13,
            "maxLength": 13,
            "description": "RFC del trabajador (formato de persona f\u00edsica o moral). Homoclave opcional.",
            "example": "XXXX900909XXX"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno de Trabajador",
            "example": "Apellido Paterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno de Trabajador",
            "example": "Apellido Paterno"
          },
          "nombreTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre Trabajador",
            "example": "Apellido Paterno"
          },
          "fechaNacimiento": {
            "pattern": "^[1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2}$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Nacimiento del trabajador.",
            "example": "20220510"
          },
          "sexo": {
            "pattern": "^(1|2|3)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo",
            "example": "1"
          },
          "entidadFederativaNacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Entidad Federativa de Nacimiento",
            "example": "02"
          },
          "nacionalidad": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de Pa\u00eds",
            "example": "MEX"
          },
          "claveTipoDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Clave del tipo de documento. Seg\u00fan tabla de documentos",
            "example": "A"
          },
          "folioDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10,
            "description": "Folio de documento probatorio",
            "example": "Folio12345"
          },
          "documentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Informaci\u00f3n detallada del documento probatorio",
            "example": "docto12345678901"
          }
        }
      },
      "registroTrabajadorResponse": {
        "required": [
          "origenSolicitud",
          "claveEntidadOrigen",
          "idNegocio",
          "resultadoOperacion",
          "diagnosticoProceso"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud",
            "example": "01"
          },
          "claveEntidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que env\u00eda la solicitud",
            "example": "300"
          },
          "idNegocio": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "ID Negocio (NSS del trabajador)",
            "example": "11111111111"
          },
          "rfc": {
            "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
            "type": "string",
            "minLength": 13,
            "maxLength": 13,
            "description": "RFC del trabajador (formato de persona f\u00edsica o moral). Homoclave opcional.",
            "example": "XXXX900909XXX"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno de Trabajador",
            "example": "Apellido Paterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno de Trabajador",
            "example": "Apellido Paterno"
          },
          "nombreTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre Trabajador",
            "example": "Apellido Paterno"
          },
          "fechaNacimiento": {
            "pattern": "^[1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2}$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Nacimiento del trabajador.",
            "example": "20220510"
          },
          "sexo": {
            "pattern": "^(1|2|3)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo",
            "example": "1"
          },
          "entidadFederativaNacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Entidad Federativa de Nacimiento",
            "example": "02"
          },
          "nombreTrabajadorIMSS": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Nombre Trabajador IMSS",
            "example": "nombreTrabajadorIMSS"
          },
          "nacionalidad": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de Pa\u00eds",
            "example": "MEX"
          },
          "claveTipoDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Clave del tipo de documento. Seg\u00fan tabla de documentos",
            "example": "A"
          },
          "folioDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10,
            "description": "Folio de documento probatorio",
            "example": "Folio12345"
          },
          "documentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Informaci\u00f3n detallada del documento probatorio",
            "example": "docto12345678901"
          },
          "fechaAltaAfore": {
            "pattern": "^[1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2}$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha del d\u00eda en que se procesa la solicitud",
            "example": "20220510"
          },
          "indicadorSieforeBasicaPension": {
            "pattern": "^([0-9]{})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Siefore B\u00e1sica pensi\u00f3n",
            "example": "1"
          },
          "indicadorPortabilidad": {
            "pattern": "^([0-9]{})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Siefore B\u00e1sica pensi\u00f3n",
            "example": "1"
          },
          "resultadoOperacion": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operaci\u00f3n, en donde:\n\n01 Solicitud Aceptada.\n\n60 Aceptado y asignado en misma Afore.\n\n61 Aceptado y en proceso de traspaso A-A por asignaci\u00f3n.\n\n02 Solicitud Rechazada por Procesar.\n",
            "example": "02"
          },
          "diagnosticoProceso": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "Diagn\u00f3stico del proceso, cuando el resultado de la operaci\u00f3n en rechazo (02).\n\n000 Solicitud de certificaci\u00f3n aceptada\n\n000 Solicitud aceptada y asignada misma AFORE\n\n000 Solicitud aceptada y en proceso de traspaso A-A por asignaci\u00f3n\n\n026 Fecha de Nacimiento inv\u00e1lida\n\n027 Entidad Federativa de Nacimiento inv\u00e1lida\n\nB46 La nacionalidad del trabajador enviada por la AFORE no existe dentro del cat\u00e1logo de nacionalidades\n\n785 Tipo de Documento Probatorio inv\u00e1lido\n\nB43 La estructura de la informaci\u00f3n del documento probatorio no corresponde al TDP enviado por la AFORE\n\n014 Trabajador ya afiliado\n\n005 NSS Inv\u00e1lido\n\n015 NSS no se encuentra en PROCANASE\n\n528 Trabajador en proceso de Traspaso AFORE \u2013 AFORE\n\n783 Apellido Paterno PROCANASE y de Solicitud no coinciden\n\n784 Apellido Materno PROCANASE y de Solicitud no coinciden\n\n792 Nombre del trabajador inv\u00e1lido\n\n938 El trabajador no se encuentra en proceso de Separaci\u00f3n de Cuentas\n\n816 Cuenta con operaci\u00f3n fuera de secuencia\n\n937 Afore que responde no es la Afore Solicitante\n",
            "example": "816"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  }
