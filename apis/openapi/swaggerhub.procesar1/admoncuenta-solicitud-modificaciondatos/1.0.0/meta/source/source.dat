      "datosBaseCurpTrabajadorResp": {
        "required": [
          "apellidoPaterno",
          "nombreTrabajador",
          "nombreEnFormatoImss",
          "nombreEnProcanase",
          "fechaDeNacimiento",
          "sexo",
          "entidadFederativaDeNacimiento",
          "folioDeLaSolicitud",
          "ocupacionOProfesionTrabajador",
          "actividadOGiroNegocioTrabajador",
          "nivelDeEstudioTrabajador",
          "flujoDeValidacion",
          "selloVerificacionBiometrica",
          "indicadorDeServicioBiometrico",
          "curpSolicitante",
          "tipoSolicitante",
          "movimientoBeneficiario",
          "fechaDePrimerRegistro",
          "fechaAltaEnAforeActual",
          "claveDeAforeDeRegistro",
          "indicadorDeCreditoInfonavit",
          "expedienteCompleto",
          "resultadoDeLaOperacion",
          "diagnosticoDeRecepcion"
        ],
        "type": "object",
        "properties": {
          "curpOficial": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP Oficial, en caso de rechazo por diferencias con RENAPO se requisita CURP notificada por RENAPO, en caso de duplicidad; se requisita la CURP del trabajador duplicado.\n\nEn cualquier otro caso CURP BDNSAR\n",
            "example": "XXXX111111XXXXXX11"
          },
          "curpNueva": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Se notifica para trabajadores No afiliados o ISSSTE cuando se va a modificar la CURP, as\u00ed como trabajadores IMSS\n",
            "example": "XXXX111111XXXXXX11"
          },
          "rfc": {
            "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
            "type": "string",
            "maxLength": 13,
            "description": "RFC",
            "example": "CCCC900909XXX"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno del Trabajador",
            "example": "paterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno del Trabajador",
            "example": "materno"
          },
          "nombreTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Nombre(s) del Trabajador en BDNSAR",
            "example": "nombre"
          },
          "nombreEnFormatoImss": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "En caso de diferencias con RENAPO se requisita el Apellido paterno, materno y nombre en formato desdoblado que devuelve RENAPO en caso de duplicidad y que existan diferencias en datos base CURP, el apellido paterno, materno y nombre en formato desdoblado del duplicado.\n\nEn otro caso el apellido paterno, materno y nombre en formato desdoblado de la BDNSAR\n",
            "example": "nombreEnFormatoImss"
          },
          "nombreEnProcanase": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Nombre de trabajador que corresponde al NSS seg\u00fan IMSS",
            "example": "nombreEnProcanase"
          },
          "fechaDeNacimiento": {
            "pattern": "^(([1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2}))$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Nacimiento, en caso de diferencias con RENAPO se requisita la fecha de nacimiento que devuelve RENAPO.\n\nEn caso de duplicidad y que existan diferencias en datos base CURP, la fecha de nacimiento del trabajador duplicado.\n\nEn otro caso la fecha de nacimiento en BDNSAR\n",
            "example": "20000101"
          },
          "sexo": {
            "pattern": "^([1,2,3]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "1 - M\n\n2 - F\n\n3 - X\n",
            "example": "1"
          },
          "entidadFederativaDeNacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Seg\u00fan Catalogo General Clave de las Entidades Federativas",
            "example": "01"
          },
          "nacionalidad": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3,
            "description": "Nacionalidad del Trabajador",
            "example": "MEX"
          },
          "folioDeLaSolicitud": {
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Folio de la solicitud",
            "example": "1234567890"
          },
          "claveDeTipoDeDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Clave del Documento Probatorio",
            "example": "1"
          },
          "documentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Documento Probatorio",
            "example": "Docto1A"
          },
          "folioDeDocumentoProbatorio": {
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Folio Documento Probatorio\n",
            "example": "0000000001"
          },
          "ocupacionOProfesionTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Ocupaci\u00f3n o profesi\u00f3n del trabajador",
            "example": "01"
          },
          "actividadOGiroNegocioTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Actividad o giro del negocio del trabajador",
            "example": "01"
          },
          "nivelDeEstudioTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Nivel de estudio del trabajador",
            "example": "01"
          },
          "flujoDeValidacion": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Conforme al flujo de validaciones (1B,2A,3B,4B,5A,6A,7A, 8A, 9A, 9B)\n",
            "example": "1B"
          },
          "selloVerificacionBiometrica": {
            "type": "string",
            "minLength": 14,
            "maxLength": 14,
            "description": "sello Verificacion Biometrica\n",
            "example": "00000000000014"
          },
          "selloVoluntadTramite": {
            "type": "string",
            "minLength": 14,
            "maxLength": 14,
            "description": "Cuando el tipo de solicitante es 01 Titular y tipo de movimiento 1: Folio  de la Voluntad del Tramite de Actualizaci\u00f3n (Trabajador). \n\nCuando el tipo de solicitante es 02, 03 o 04 y tipo de movimiento 1: Folio de Autentificaci\u00f3n.\n\nPara los tipos de movimiento 2, 3, 4 y 5 es opcional.\n",
            "example": "00000000000014"
          },
          "indicadorDeDuplicidad": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "0= Modificaci\u00f3n realizada por error de captura\n\n1= Modificaci\u00f3n realizada por un rechazo 861 o 972\n\nEl indicador ser\u00e1 obligatorio cuando se envie un movimiento 3 \n",
            "example": "1"
          },
          "indicadorEnrolamiento": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "El campo sera obligatorio cuando se env\u00ede el flujo 9B: \n\n1 -  No existe enrolamiento para el trabajador de la solicitud\n\n2 -  Existe un enrolamiento, y pertenece al trabajador de la solicitud\n",
            "example": "1"
          },
          "indicadorDeServicioBiometrico": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4,
            "description": "Clave del servicio conforme a Cat\u00e1logo.",
            "example": "1234"
          },
          "curpSolicitante": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del solicitante.",
            "example": "XXXX111111XXXXXX11"
          },
          "tipoSolicitante": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "01 - Titular\n\n02 - Beneficiario\n\n03 - Apoderado Legal \n\n04 - Curador\n\nSe enviaran de acuerdo al flujo enviado\n",
            "example": "01"
          },
          "movimientoBeneficiario": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "El campo sera obligatorio para todos los movimientos, de acuedo a la matriz especificada:   \n\n1: Eliminar todos los beneficiarios asociados a la Cuenta Individual del Trabajador.\n\n2: Modificar beneficiarios.\n\n3: No se deber\u00e1 de realizar ninguna eliminaci\u00f3n o modificaci\u00f3n de beneficiarios, \n\nLa informaci\u00f3n de beneficiarios se conserva como esta actualmente.\n",
            "example": "1"
          },
          "claveDeAgentePromotor": {
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Clave del Agente Promotor en Base de Datos\n\n2 primeras posiciones a\u00f1o.\n\n2 siguientes mes.\n\n5 siguientes, consecutivo\n\n1 D\u00edgito verificador, asignado por CONSAR\n",
            "example": "1234567890"
          },
          "fechaDePrimerRegistro": {
            "pattern": "^([1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2})$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Es la fecha en que el trabajador se dio de alta en la BDNSAR. Formato  AAAAMMDD",
            "example": "20000101"
          },
          "fechaAltaEnAforeActual": {
            "pattern": "^([1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2})$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de alta en AFORE actual. Formato  AAAAMMDD",
            "example": "20000101"
          },
          "claveDeAforeDeRegistro": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Es la clave de la AFORE a la que el trabajador qued\u00f3 registrado",
            "example": "123"
          },
          "claveDeAforeConNssAsociado": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Se requisitar\u00e1 s\u00f3lo en caso de rechazo cuando exista una CURP duplicada en BDNSAR/BDNSAR NO AFILIADOS",
            "example": "123"
          },
          "identificadorDeTipoDeTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Identificador De Tipo De Trabajador:\n\n1 - Trabajador registrado en BDNSAR\n\n2 - Trabajador registrado en BDNSAR-NO-AFILIADOS\n\nSe requisitar\u00e1 s\u00f3lo en caso de rechazo cuando exista una CURP duplicada en BDNSAR/BDNSAR NO AFILIADOS\n",
            "example": "1"
          },
          "nssAsociado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS asociado al trabajador de la solicitud. \nSe requisitar\u00e1 s\u00f3lo en caso de rechazo cuando exista una CURP duplicada en BDNSAR\n",
            "example": "12345678901"
          },
          "indicadorDeCreditoInfonavit": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador de cr\u00e9dito del trabajador.\n\nPara trabajadores asignados seg\u00fan lo registrado en BDNSAR. Para trabajadores normales, conforme lo enviado por la AFORE\n\n0 - Sin cr\u00e9dito    \n\n1 - Con cr\u00e9dito\n\n2 - Con cr\u00e9dito 43 bis\n",
            "example": "1"
          },
          "periodoDePago": {
            "pattern": "^([0-9]{6})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 6,
            "description": "\u00daltimo periodo de pago",
            "example": "123456"
          },
          "salarioDiarioIntegrado": {
            "pattern": "^([0-9]{7})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 7,
            "description": "Salario diario integrado",
            "example": "1234567"
          },
          "numeroFolioEdoCta": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8,
            "description": "N\u00famero de folio de Estado de Cuenta",
            "example": "12345678"
          },
          "expedienteCompleto": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "00 - No cuenta con Expediente Electr\u00f3nico\n\n01 - Cuenta s\u00f3lo con Expediente de Identificaci\u00f3n permanente\n\n02 - Cuenta con Expediente de Identificaci\u00f3n y Enrolamiento, ambos permanentes\n\n03 - Cuenta solo con datos complementarios. No cuenta con Expediente de Id. no cuenta con Enrolamiento.\n",
            "example": "01"
          },
          "resultadoDeLaOperacion": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "resultado de operaci\u00f2n de acuerdo a la gu\u00eca operativa\n",
            "example": "01"
          },
          "diagnosticoDeRecepcion": {
            "type": "string",
            "minLength": 15,
            "maxLength": 15,
            "description": "Diagn\u00f3stico del proceso de acuerdo al resultado de la operaci\u00f3n. Este campo deber\u00e1 llenarse con ceros\n",
            "example": "000000000000015"
          },
          "indicadorHomologacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador de Homologaci\u00f3n.\n\nLa Administradora deber\u00e1 de enviar este campo cuando se detecto que es parte del proceso de homologaci\u00f3n\n\n1 Modificaci\u00f3n no presencial por homologaci\u00f3n (actualizaci\u00f3n de BDNSAR)\n\n2 Modificaci\u00f3n no presencial por homologaci\u00f3n (actualizaci\u00f3n de BDAFORE)\n\n3 Modificaci\u00f3n presencial por homologaci\u00f3n (actualizaci\u00f3n de BDAFORE y BDNSAR)\n",
            "example": "1"
          }
        }
      },
      "datosDomicilioParticularTrabajadorResp": {
        "required": [
          "calle",
          "numeroExterior",
          "colonia",
          "delegacionOMunicipio",
          "codigoPostal",
          "entidadFederativa",
          "pais",
          "indicadorDeTelefono1",
          "telefono1",
          "indicadorTelefono2",
          "telefono2",
          "resultadoDeLaOperacion",
          "diagnosticoDeRecepcion"
        ],
        "type": "object",
        "properties": {
          "calle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "description": "calle",
            "example": "calle"
          },
          "numeroExterior": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "N\u00famero exterior",
            "example": "1"
          },
          "numeroInterior": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "N\u00famero interior",
            "example": "1"
          },
          "colonia": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "description": "Colonia",
            "example": "Colonia"
          },
          "delegacionOMunicipio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5,
            "description": "Clave de Delegaci\u00f3n o Municipio. De acuerdo a Cat\u00e1logo de Municipio",
            "example": "12345"
          },
          "codigoPostal": {
            "pattern": "^([0-9]{5})$",
            "type": "string",
            "minLength": 5,
            "maxLength": 5,
            "description": "C\u00f3digo Postal",
            "example": "12345"
          },
          "entidadFederativa": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Clave de Entidad Federativa. De acuerdo a Cat\u00e1logo de Entidad Federativa",
            "example": "02"
          },
          "pais": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3,
            "description": "De acuerdo a Cat\u00e1logo de Pa\u00edses",
            "example": "MEX"
          },
          "indicadorDeTelefono1": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "El prefijo de:\n\n044 - Tel\u00e9fono  celular DF y \u00e1rea metropolitana\n\n045 - Tel\u00e9fono celular interior de la republica\n",
            "example": "044"
          },
          "telefono1": {
            "pattern": "^([0-9]{10})$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Corresponde al tel\u00e9fono de Casa. En caso de no contar con este dato, el campo se deber\u00e1 requisitar con ceros'\n",
            "example": "1234567890"
          },
