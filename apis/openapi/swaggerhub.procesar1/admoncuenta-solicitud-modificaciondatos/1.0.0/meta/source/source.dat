{
  "openapi": "3.0.1",
  "info": {
    "title": "Actualizaci\u00f3n Expediente 13+",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para Actualizaci\u00f3n Expediente 13+",
    "contact": {
      "email": "GERENCIA_ARQUITECTURA_SOFTWARE@inet.prcesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar1/Admoncuenta-Solicitud-ModificacionDatos/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/355/expedienteidentificacion"
    }
  ],
  "tags": [
    {
      "name": "Actualizaci\u00f3n Expediente 13+",
      "description": "Operaci\u00f3n para actualizaci\u00f3n de expediente de 13+"
    }
  ],
  "paths": {
    "/actualizar": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Admoncuenta - Actualizaci\u00f3n Expediente 13+",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "actualiza",
        "tags": [
          "Actualizaci\u00f3n Expediente 13+"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "enum": [
                "355"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "28"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "2",
                "4",
                "5",
                "6",
                "7",
                "8",
                "10",
                "11",
                "12",
                "14",
                "15"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para la Actualizaci\u00f3n Expediente 13+",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/actualizaDatosExpedienteIdentificacionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/actualizaDatosExpedienteIdentificacionResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/actualizaDatosExpedienteIdentificacionResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "actualizaDatosExpedienteIdentificacionRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "actualizaDatosExpedienteIdentificacionRequest": {
        "required": [
          "entidadOrigen",
          "tipoDeMovimiento"
        ],
        "type": "object",
        "properties": {
          "entidadOrigen": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de AFORE.\n",
            "example": "001"
          },
          "tipoDeMovimiento": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "1 - si el tr\u00e1mite se solicita de manera presencial\n\n2 - si el tr\u00e1mite se solicita de manera no presencial.\n\n3 - si el tr\u00e1mite se solicita por error de captura.\n\n4 - si el tr\u00e1mite se solicita por separaci\u00f3n de manera Presencial.\n\n5 - si el tr\u00e1mite se solicita por separaci\u00f3n de manera No presencial.\n",
            "example": "1"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS del Trabajador, requisitado en caso de que se trate de un trabajador IMSS.\n\nSi no es requisitado se considera la modificaci\u00f3n de un No afiliado.\n",
            "example": "12345678901"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Si el tipo de documento probatorio es 5, se valida la estructura y d\u00edgito verificador, el tipo de documento en la BDNSAR debe ser \"5\"\n",
            "example": "XXXX111111XXXXXX11"
          },
          "baseCurpTrabajador": {
            "$ref": "#/components/schemas/datosBaseCurpTrabajador"
          },
          "domicilioParticularTrabajador": {
            "$ref": "#/components/schemas/datosDomicilioParticularTrabajador"
          },
          "domicilioLaboralTrabajador": {
            "$ref": "#/components/schemas/datosDomicilioLaboralTrabajador"
          },
          "referenciasTrabajador": {
            "$ref": "#/components/schemas/datosReferenciasTrabajador"
          },
          "listaBeneficiariosTrabajador": {
            "$ref": "#/components/schemas/datosBeneficiarioTrabajador"
          }
        }
      },
      "actualizaDatosExpedienteIdentificacionResponse": {
        "required": [
          "entidadOrigen"
        ],
        "type": "object",
        "properties": {
          "entidadOrigen": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de AFORE",
            "example": "123"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS proporcionado por el trabajador",
            "example": "12345678901"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP a 18 posiciones",
            "example": "XXXX111111XXXXXX11"
          },
          "baseCurpTrabajador": {
            "$ref": "#/components/schemas/datosBaseCurpTrabajadorResp"
          },
          "domicilioParticularTrabajador": {
            "$ref": "#/components/schemas/datosDomicilioParticularTrabajadorResp"
          },
          "domicilioLaboralTrabajador": {
            "$ref": "#/components/schemas/datosDomicilioLaboralTrabajadorResp"
          },
          "referenciasTrabajador": {
            "$ref": "#/components/schemas/datosReferenciasTrabajadorResp"
          },
          "listaBeneficiariosTrabajador": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/datosBeneficiariosTrabajadorResp"
            }
          }
        }
      },
      "datosBaseCurpTrabajador": {
        "required": [
          "apellidoPaterno",
          "nombreTrabajador",
          "fechaDeNacimiento",
          "sexo",
          "entidadFederativaDeNacimiento",
          "flujoDeValidacion",
          "selloVerificacionBiometrica",
          "indicadorDeServicioBiometrico",
          "curpSolicitante",
          "tipoSolicitante",
          "movimientoBeneficiario"
        ],
        "type": "object",
        "properties": {
          "curpNueva": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Se notifica para trabajadores No afiliados o ISSSTE cuando se va a modificar la CURP, as\u00ed como trabajadores IMSS\n",
            "example": "XXXX111111XXXXXX11"
          },
          "rfc": {
            "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
            "type": "string",
            "maxLength": 13,
            "description": "Caundo se reciba la informaci\u00f3n se valida la estructura, \n\n04 Primeras posiciones alfab\u00e9ticas,  \n\n06 Posiciones siguientes num\u00e9ricas, \n\n03 Alfanum\u00e9ricas.\n",
            "example": "CCCC900909XXX"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno del Trabajador",
            "example": "paterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno del Trabajador",
            "example": "materno"
          },
          "nombreTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre(s) del Trabajador",
            "example": "nombre"
          },
          "fechaDeNacimiento": {
            "pattern": "^([1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2})$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de nacimiento del Trabajador, mayor a 1900 y menor o igual a la fecha del proceso. \nFormato AAAAMMDD\n",
            "example": "20000101"
          },
          "sexo": {
            "pattern": "^([1,2,3]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "1 - M\n\n2 - F\n\n3 - X\n",
            "example": "1"
          },
          "entidadFederativaDeNacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Seg\u00fan Catalogo General Clave de las Entidades Federativas",
            "example": "01"
          },
          "nacionalidad": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3,
            "description": "Nacionalidad del Trabajador",
            "example": "MEX"
          },
          "claveDeTipoDeDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Clave del Documento Probatorio",
            "example": "1"
          },
          "folioDeLaSolicitud": {
            "pattern": "^([0-9]{10})$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Folio de la solicitud",
            "example": "1234567890"
          },
          "documentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Documento Probatorio",
            "example": "1A"
          },
          "folioDeDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10,
            "description": "Carta de Naturalizaci\u00f3n, folio de Certificado de Nacionalidad Mexicana  Num\u00e9rico, requerido si el TDP =  4 \u00f3 7, se rellena con 0 a la izquierda.\n",
            "example": "0000000001"
          },
          "ocupacionOProfesionTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Ocupaci\u00f3n o profesi\u00f3n del trabajador",
            "example": "1"
          },
          "actividadOGiroNegocioTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Actividad o giro del negocio del trabajador",
            "example": "1"
          },
          "nivelDeEstudioTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Nivel de estudio del trabajador",
            "example": "1"
          },
          "flujoDeValidacion": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Conforme al flujo de validaciones (1B,2A,3B,4B,5A,6A,7A, 8A, 9A, 9B)\n",
            "example": "1B"
          },
          "selloVerificacionBiometrica": {
            "type": "string",
            "minLength": 14,
            "maxLength": 14,
            "description": "Dato num\u00e9rico a 14 posiciones,se aceptan ceros.\n",
            "example": "00000000000014"
          },
          "selloVoluntadTramite": {
            "type": "string",
            "minLength": 14,
            "maxLength": 14,
            "description": "Cuando el tipo de solicitante es 01 Titular y tipo de movimiento 1: Folio  de la Voluntad del Tramite de Actualizaci\u00f3n (Trabajador). \n\nCuando el tipo de solicitante es 02, 03 o 04 y tipo de movimiento 1: Folio de Autentificaci\u00f3n.\n\nPara los tipos de movimiento 2, 3, 4 y 5 es opcional.\n",
            "example": "00000000000014"
          },
          "indicadorDeDuplicidad": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "0= Modificaci\u00f3n realizada por error de captura\n\n1= Modificaci\u00f3n realizada por un rechazo 861 o 972\n\nEl indicador ser\u00e1 obligatorio cuando se envie un movimiento 3 \n",
            "example": "1"
          },
          "indicadorEnrolamiento": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Enrolamiento.\n\nEl campo sera obligatorio cuando se env\u00ede el flujo 9B: \n\n1: No existe enrolamiento para el trabajador de la solicitud\n\n2: Existe un enrolamiento, y pertenece al trabajador de la solicitud\n",
            "example": "1"
          },
          "indicadorDeServicioBiometrico": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4,
            "description": "Clave del servicio conforme a Cat\u00e1logo.",
            "example": "1234"
          },
          "curpSolicitante": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del solicitante.",
            "example": "XXXX111111XXXXXX11"
          },
          "tipoSolicitante": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "01 - Titular\n\n02 - Beneficiario\n\n03 - Apoderado Legal \n\n04 - Curador\n\nSe enviaran de acuerdo al flujo enviado\n",
            "example": "01"
          },
          "movimientoBeneficiario": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "El campo sera obligatorio para todos los movimientos, de acuedo a la matriz especificada:   \n\n1: Eliminar todos los beneficiarios asociados a la Cuenta Individual del Trabajador.\n\n2: Modificar beneficiarios.\n\n3: No se deber\u00e1 de realizar ninguna eliminaci\u00f3n o modificaci\u00f3n de beneficiarios. \n\nla informaci\u00f3n de beneficiarios se conserva como esta actualmente.\n",
            "example": "01"
          },
          "indicadorHomologacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador de Homologaci\u00f3n.\n\nLa Administradora deber\u00e1 de enviar este campo cuando se detecto que es parte del proceso de homologaci\u00f3n\n\n1 Modificaci\u00f3n no presencial por homologaci\u00f3n (actualizaci\u00f3n de BDNSAR)\n\n2 Modificaci\u00f3n no presencial por homologaci\u00f3n (actualizaci\u00f3n de BDAFORE)\n\n3 Modificaci\u00f3n presencial por homologaci\u00f3n (actualizaci\u00f3n de BDAFORE y BDNSAR)\n",
            "example": "1"
          }
        }
      },
      "datosDomicilioParticularTrabajador": {
        "required": [
          "calle",
          "colonia",
          "delegacionOMunicipio",
          "codigoPostal",
          "entidadFederativa",
          "pais",
          "indicadorDeTelefono1",
          "telefono1",
          "indicadorTelefono2",
          "telefono2"
        ],
        "type": "object",
        "properties": {
          "calle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "description": "calle",
            "example": "calle"
          },
          "numeroExterior": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "N\u00famero exterior",
            "example": "1"
          },
          "numeroInterior": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "N\u00famero interior",
            "example": "1"
          },
          "colonia": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "description": "Colonia",
            "example": "Colonia"
          },
          "delegacionOMunicipio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5,
            "description": "Clave de Delegaci\u00f3n o Municipio. De acuerdo a Cat\u00e1logo de Municipio",
            "example": "12345"
          },
          "codigoPostal": {
            "pattern": "^[0-9A-Z]{5}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 5,
            "description": "C\u00f3digo Postal",
            "example": "12345"
          },
          "entidadFederativa": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Clave de Entidad Federativa. De acuerdo a Cat\u00e1logo de Entidad Federativa",
            "example": "02"
          },
          "pais": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3,
            "description": "De acuerdo a Cat\u00e1logo de Pa\u00edses",
            "example": "023"
          },
          "indicadorDeTelefono1": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "El prefijo de:\n\n044  tel\u00e9fono  celular DF y \u00e1rea metropolitana\n\n045 tel\u00e9fono celular interior de la republica\n",
            "example": "044"
          },
          "telefono1": {
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Corresponde al tel\u00e9fono de Casa.    \n\nEn caso de no contar con este dato, el campo se deber\u00e1 requisitar con ceros'\n",
            "example": "1234567890"
          },
          "extension1": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5,
            "description": "Extensi\u00f3n",
            "example": "02345"
          },
          "indicadorTelefono2": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "El prefijo de:\n\n044  tel\u00e9fono  celular DF y \u00e1rea metropolitana\n\n045 tel\u00e9fono celular interior de la republica\n",
            "example": "044"
          },
          "telefono2": {
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Corresponde al tel\u00e9fono de Casa.    \n\nEn caso de no contar con este dato, el campo se deber\u00e1 requisitar con ceros'\n",
            "example": "1234567890"
          },
          "extension2": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5,
            "description": "Extensi\u00f3n",
            "example": "02345"
          },
          "correoElectronicoDelTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "El registrado por el Trabajador",
            "example": "correo@correo.com"
          }
        }
      },
      "datosDomicilioLaboralTrabajador": {
        "required": [
          "calle",
          "colonia",
          "delegacionOMunicipio",
          "codigoPostal",
          "entidadFederativa",
          "pais"
        ],
        "type": "object",
        "properties": {
          "calle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "description": "calle",
            "example": "calle"
          },
          "numeroExterior": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "N\u00famero exterior",
            "example": "1"
          },
          "numeroInterior": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "N\u00famero interior",
            "example": "1"
          },
          "colonia": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65,
            "description": "Colonia",
            "example": "Colonia"
          },
          "delegacionOMunicipio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5,
            "description": "Clave de Delegaci\u00f3n o Municipio. De acuerdo a Cat\u00e1logo de Municipio",
            "example": "12345"
          },
          "codigoPostal": {
            "pattern": "^[0-9A-Z]{5}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 5,
            "description": "C\u00f3digo Postal",
            "example": "12345"
          },
          "entidadFederativa": {
            "type": "string",
            "minLength": 1,
