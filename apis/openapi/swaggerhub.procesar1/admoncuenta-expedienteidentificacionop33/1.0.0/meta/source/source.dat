{
  "openapi": "3.0.1",
  "info": {
    "title": "Expediente Identificacion Op 33",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para Expediente Identificaci\u00f3n Op33",
    "contact": {
      "email": "gerencia_arquitectura_software@inet.procesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar1/Admoncuenta-ExpedienteIdentificacionOp33/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/1012/expedienteidentidad"
    }
  ],
  "tags": [
    {
      "name": "Expediente Identificaci\u00f3n Op33",
      "description": "Operaci\u00f3n para dar Expediente Identificaci\u00f3n Op33."
    }
  ],
  "paths": {
    "/registro": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Admoncuenta - Expediente Identificaci\u00f3n Op33",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "solicitud",
        "tags": [
          "Expediente Identificaci\u00f3n Op33"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "Atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "enum": [
                "1012"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "Atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "53"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "Atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "2",
                "4",
                "5",
                "6",
                "7",
                "8",
                "10",
                "11",
                "12",
                "14",
                "15"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para dar Expediente Identificaci\u00f3n Op33.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/registrarExpedienteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/registrarExpedienteResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/registrarExpedienteResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "respuestaConfrontaRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "registrarExpedienteRequest": {
        "required": [
          "entidadOrigen",
          "procesoEnvio",
          "tipoIdentificadorTrabajador",
          "curp"
        ],
        "type": "object",
        "properties": {
          "entidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de Administradora.\n",
            "example": "999"
          },
          "procesoEnvio": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Proceso Env\u00edo:\n\n01 - Registro\n\n02 - Traspasos\n",
            "example": "01"
          },
          "tipoIdentificadorTrabajador": {
            "pattern": "^[0-9]{1}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo Identificador Trabajador\n\n1 - Trabajador IMSS / Mixto\n\n2 - Trabajador No Afiliado (Independientes o ISSSTE)\n",
            "example": "1"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguro Social del trabajador.",
            "example": "12345678901"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Trabajador.\n",
            "example": "AAAA000000AAAAAAAA"
          },
          "datosParticularesTrabajador": {
            "required": [
              "rfc",
              "fechaNacimiento",
              "generoTrabajador",
              "ocupacionProfesionTrabajador",
              "actividadGiroNegocioTrabajador",
              "nivelEstudioTrabajador",
              "curpPromotorFuncionario",
              "calle",
              "colonia",
              "delegacionMunicipio",
              "codigoPostal",
              "entidadFederativa",
              "pais",
              "telefono1",
              "telefono2"
            ],
            "type": "object",
            "properties": {
              "rfc": {
                "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
                "type": "string",
                "minLength": 13,
                "maxLength": 13,
                "description": "RFC del Trabajador. Formato\n\n04 - primeras posiciones alfab\u00e9ticas\n\n06 - posiciones siguientes num\u00e9ricas.\n\n03 - alfanum\u00e9ricas (opcionales).\n",
                "example": "XXXX900909123"
              },
              "fechaNacimiento": {
                "pattern": "^([1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2})$",
                "type": "string",
                "minLength": 8,
                "maxLength": 8,
                "description": "Fecha de nacimiento del trabajador. Formato: AAAAMMDD\n",
                "example": "20001031"
              },
              "generoTrabajador": {
                "pattern": "^(1|2|3)$",
                "type": "string",
                "minLength": 1,
                "maxLength": 1,
                "description": "De acuerdo al  Cat\u00e1logo Genero del Trabajador\n\n1=M\n\n2=F\n\n3=X\n",
                "example": "1"
              },
              "ocupacionProfesionTrabajador": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al Cat\u00e1logo Ocupaci\u00f3n/Profesi\u00f3n del Trabajador\n",
                "example": "01"
              },
              "actividadGiroNegocioTrabajador": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al  Cat\u00e1logo Actividad/Giro del negocio del Trabajador\n",
                "example": "01"
              },
              "nivelEstudioTrabajador": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "'De acuerdo al  Cat\u00e1logo Nivel de estudios\n",
                "example": "01"
              },
              "curpPromotorFuncionario": {
                "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                "type": "string",
                "minLength": 18,
                "maxLength": 18,
                "description": "Curp promotor funcionario\n",
                "example": "AAAA900909XXXXXX09"
              },
              "calle": {
                "type": "string",
                "minLength": 1,
                "maxLength": 65,
                "description": "Calle\n",
                "example": "Calle"
              },
              "numeroExterior": {
                "type": "string",
                "minLength": 1,
                "maxLength": 15,
                "description": "Calle\n",
                "example": "NumeroExt"
              },
              "numeroInterior": {
                "type": "string",
                "minLength": 1,
                "maxLength": 15,
                "description": "Numero Interior\n",
                "example": "NumeroINT"
              },
              "colonia": {
                "type": "string",
                "minLength": 1,
                "maxLength": 65,
                "description": "Colonia\n",
                "example": "Colonia"
              },
              "delegacionMunicipio": {
                "type": "string",
                "minLength": 1,
                "maxLength": 5,
                "description": "Delegacion o Municipio\n",
                "example": "Del01"
              },
              "codigoPostal": {
                "pattern": "^([0-9]{5})$",
                "type": "string",
                "minLength": 5,
                "maxLength": 5,
                "description": "C\u00f3digo Postal\n",
                "example": "12345"
              },
              "entidadFederativa": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "Entidad Federativa\n",
                "example": "20"
              },
              "pais": {
                "type": "string",
                "minLength": 3,
                "maxLength": 3,
                "description": "De acuerdo a Cat\u00e1logo de Pa\u00edses \n",
                "example": "MEX"
              },
              "indicadorTelefono1": {
                "pattern": "^([0-9]{3})$",
                "type": "string",
                "minLength": 3,
                "maxLength": 3,
                "description": "Se debe requisitar solo si el telefono1 es un celular con el prefijo de:\n \n 044 - tel\u00e9fono  celular DF y \u00e1rea metropolitana\n \n 045 - tel\u00e9fono celular interior de la republica\n",
                "example": "045"
              },
              "telefono1": {
                "pattern": "^([0-9]{10})$",
                "type": "string",
                "minLength": 10,
                "maxLength": 10,
                "description": "Corresponde al tel\u00e9fono de Casa.    \n \n En caso de no contar con este dato, el campo se deber\u00e1 requisitar con ceros\n",
                "example": "5555555555"
              },
              "extension1": {
                "pattern": "^([0-9]{1,5}})$",
                "type": "string",
                "minLength": 1,
                "maxLength": 5,
                "description": "Extensi\u00f3n\n",
                "example": "12345"
              },
              "indicadorTelefono2": {
                "pattern": "^([0-9]{3})$",
                "type": "string",
                "minLength": 3,
                "maxLength": 3,
                "description": "El prefijo de:\n \n 044  tel\u00e9fono  celular DF y \u00e1rea metropolitana\n \n 045 tel\u00e9fono celular interior de la republica\n",
                "example": "045"
              },
              "telefono2": {
                "pattern": "^([0-9]{10})$",
                "type": "string",
                "minLength": 10,
                "maxLength": 10,
                "description": "Corresponde al tel\u00e9fono de Oficina. \n \nEn caso de no contar con este dato, el campo se deber\u00e1 requisitar con ceros\n",
                "example": "5555555555"
              },
              "extension2": {
                "pattern": "^([0-9]{1,5}})$",
                "type": "string",
                "minLength": 1,
                "maxLength": 5,
                "description": "Extensi\u00f3n\n",
                "example": "12345"
              },
              "correoElectronicoTrabajador": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50,
                "description": "Correo Electronico registrado por el Trabajador\n",
                "example": "correo@correo.com"
              }
            }
          },
          "datosDomicilioLaboralTrabajador": {
            "required": [
              "calle",
              "colonia",
              "delegacionMunicipio",
              "codigoPostal",
              "entidadFederativa",
              "pais"
            ],
            "type": "object",
            "properties": {
              "calle": {
                "type": "string",
                "minLength": 1,
                "maxLength": 65,
                "description": "Calle\n",
                "example": "Calle"
              },
              "numeroExterior": {
                "type": "string",
                "minLength": 1,
                "maxLength": 15,
                "description": "Calle\n",
                "example": "NumeroExt"
              },
              "numeroInterior": {
                "type": "string",
                "minLength": 1,
                "maxLength": 15,
                "description": "Numero Interior\n",
                "example": "NumeroINT"
              },
              "colonia": {
                "type": "string",
                "minLength": 1,
                "maxLength": 65,
                "description": "Colonia\n",
                "example": "Colonia"
              },
              "delegacionMunicipio": {
                "type": "string",
                "minLength": 1,
                "maxLength": 5,
                "description": "Clave de la Delegaci\u00f3n o Municipio, de acuerdo al Cat\u00e1logo de Delegaci\u00f3n o Municipio\n",
                "example": "Del01"
              },
              "codigoPostal": {
                "pattern": "^([0-9]{5})$",
                "type": "string",
                "minLength": 5,
                "maxLength": 5,
                "description": "C\u00f3digo Postal\n",
                "example": "12345"
              },
              "entidadFederativa": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "Clave de Entidad Federativa, de acuerdo al Cat\u00e1logo de Entidades Federativas.\n",
                "example": "20"
              },
              "pais": {
                "type": "string",
                "minLength": 3,
                "maxLength": 3,
                "description": "De acuerdo a Cat\u00e1logo de Pa\u00edses \n",
                "example": "MEX"
              }
            }
          },
          "datosReferenciasTrabajador": {
            "required": [
              "folioRegistro",
              "selloVerificacionBiometrica",
              "selloVoluntadRegistro",
              "tipoSolicitante",
              "curpSolicitante"
            ],
            "type": "object",
            "properties": {
              "apellidoPaternoReferencia1": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Apellido Paterno de la Referencia 1\n",
                "example": "Apellido Paterno"
              },
              "apellidoMaternoReferencia1": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Apellido Materno de la Referencia 1\n",
                "example": "Apellido Materno"
              },
              "nombreReferencia1": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Nombre(s) de la Referencia 1\n",
                "example": "Nombre"
              },
              "curpReferencia1": {
                "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                "type": "string",
                "minLength": 18,
                "maxLength": 18,
                "description": "CURP de la Referencia 1\n",
                "example": "AAAA900909XXXXXX09"
              },
              "telefonoReferencia1": {
                "pattern": "^([0-9]{10})$",
                "type": "string",
                "minLength": 10,
                "maxLength": 10,
                "description": "Tel\u00e9fono de la Referencia 1\n",
                "example": "5555555555"
              },
              "parentescoRelacionReferencia1": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al Cat\u00e1logo Parentesco\n",
                "example": "01"
              },
              "apellidoPaternoReferencia2": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Apellido Paterno de la Referencia 2\n",
                "example": "Apellido Paterno"
              },
              "apellidoMaternoReferencia2": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Apellido Maternode la Referencia 2\n",
                "example": "Apellido Paterno"
              },
              "nombreReferencia2": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Nombre(s) de la Referencia 2\n",
                "example": "Nombre"
              },
              "curpReferencia2": {
                "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                "type": "string",
                "minLength": 18,
                "maxLength": 18,
                "description": "CURP de la Referencia 2\n",
                "example": "AAAA900909XXXXXX09"
              },
              "telefonoReferencia2": {
                "pattern": "^([0-9]{10})$",
                "type": "string",
                "minLength": 10,
                "maxLength": 10,
                "description": "Tel\u00e9fono de la Referencia 2\n",
                "example": "5555555555"
              },
              "parentescoRelacionReferencia2": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al Cat\u00e1logo Parentesco\n",
                "example": "01"
              },
              "folioRegistro": {
                "type": "string",
                "minLength": 1,
                "maxLength": 6,
                "description": "Folio para registro\n",
                "example": "Folio1"
              },
              "selloVerificacionBiometrica": {
                "pattern": "^([0-9]{14})$",
                "type": "string",
                "minLength": 14,
                "maxLength": 14,
                "description": "Dato a 14 posiciones \n",
                "example": "12345678901234"
              },
              "selloVoluntadRegistro": {
                "pattern": "^([0-9]{14})$",
                "type": "string",
                "minLength": 14,
                "maxLength": 14,
                "description": "Folio  de la Voluntad del Tramite de Registro (Trabajador).\nEnviar en ceros cuando el tipo de solicitante es diferente a titular.\n",
                "example": "12345678901234"
              },
              "tipoSolicitante": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al Cat\u00e1logo de Tipo de Solicitante.\n",
                "example": "01"
              },
              "curpSolicitante": {
                "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                "type": "string",
                "minLength": 18,
                "maxLength": 18,
                "description": "CURP del Solicitante\n",
                "example": "AAAA900909XXXXXX09"
              }
            }
          },
          "datosBeneficiariosTrabajador": {
            "type": "array",
            "items": {
              "required": [
                "apellidoPaternoBeneficiario",
                "nombreBeneficiario",
                "curpBeneficiario",
                "porcentajeBeneficiario"
              ],
              "type": "object",
              "properties": {
                "apellidoPaternoBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "description": "Apellido Paterno de Beneficiario\n",
                  "example": "Apellido Paterno"
                },
                "apellidoMaternoBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "description": "Apellido Materno de Beneficiario\n",
                  "example": "Apellido Materno"
                },
                "nombreBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "description": "Nombre(s) de Beneficiario\n",
                  "example": "Nombre"
                },
                "curpBeneficiario": {
                  "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                  "type": "string",
                  "minLength": 18,
                  "maxLength": 18,
                  "description": "CURP de Beneficiario\n",
                  "example": "AAAA900909XXXXXX09"
                },
                "parentescoRelacion": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 2,
                  "description": "De acuerdo al Cat\u00e1logo Parentesco\n",
                  "example": "01"
                },
                "porcentajeBeneficiario": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 3,
                  "description": "Porcentaje de Beneficiario.\n\n La suma del porcentaje de los N beneficiarios deber\u00e1 ser del 100%\n",
                  "example": "100"
                }
              }
            }
          }
        }
      },
      "registrarExpedienteResponse": {
        "required": [
          "entidadOrigen",
          "procesoEnvio",
          "tipoIdentificadorTrabajador",
          "curp"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de Operaci\u00f3n:\n\n01 Aceptado\n\n02 Rechazado \n",
            "example": "02"
          },
          "diagnosticoRecepcion": {
            "pattern": "^[A-Z0-9]$",
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "Seg\u00fan cat\u00e1logo Motivos de rechazo de Detalle. \n\n025 - Folio para Registro inv\u00e1lido\n\n102 - NSS o CURP obligatorios\n\n446 - CURP del Solicitante diferente a la CURP del Trabajador\n\n584 - Tel\u00e9fono inv\u00e1lido\n\n973 - Verificaci\u00f3n de CURP no atendida por RENAPO\n\nD52 - Datos particulares del trabajador incompletos\n\nD53 - Datos de referencia del trabajador incompletos\n\nD54 - Datos del domicilio laboral del trabajador incompletos\n\nD55 - Trabajador no cuenta con las im\u00e1genes del Expediente de Identidad\n\nD56 - Datos de beneficiarios del trabajador incompletos\n\nE75 - Sello de Voluntad no corresponde\n\nE76 - Sello de Voluntad no vigente\n\nE77 - Sello de Voluntad utilizado previamente\n\nF01 - El Tel\u00e9fono Celular recibido pertence a otro Trabajador\n\nG41 - CURP del Solicitante igual a la CURP del Trabajador\n\nH22 - El Correo electr\u00f3nico recibido pertenece a otro Trabajador\n\nJ68 - Su cuenta de correo no es v\u00e1lida\n",
            "example": "D52D53D54D55D56"
          },
          "entidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de Administradora.\n",
            "example": "999"
          },
          "procesoEnvio": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Proceso Env\u00edo:\n\n01 - Registro\n\n02 - Traspasos\n",
            "example": "01"
          },
          "tipoIdentificadorTrabajador": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo Identificador Trabajador\n\n1 - Trabajador IMSS / Mixto\n\n2 - Trabajador No Afiliado (Independientes o ISSSTE)\n",
            "example": "1"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguro Social del trabajador.",
            "example": "12345678901"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Trabajador.\n",
            "example": "AAAA000000AAAAAAAA"
          },
          "datosParticularesTrabajador": {
            "required": [
              "rfc",
              "fechaNacimiento",
              "generoTrabajador",
              "ocupacionProfesionTrabajador",
              "actividadGiroNegocioTrabajador",
              "nivelEstudioTrabajador",
              "curpPromotorFuncionario",
              "calle",
              "colonia",
              "delegacionMunicipio",
              "codigoPostal",
              "entidadFederativa",
              "pais",
              "telefono1",
              "telefono2"
            ],
            "type": "object",
            "properties": {
              "rfc": {
                "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
                "type": "string",
                "minLength": 13,
                "maxLength": 13,
                "description": "RFC del Trabajador. Formato.\n\n04 - primeras posiciones alfab\u00e9ticas.\n\n06 - posiciones siguientes num\u00e9ricas.\n\n03 - alfanum\u00e9ricas (opcionales).\n",
                "example": "XXXX900909123"
              },
              "fechaNacimiento": {
                "pattern": "^([1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2})$",
                "type": "string",
                "minLength": 8,
                "maxLength": 8,
                "description": "Fecha de nacimiento del trabajador. Formato: AAAAMMDD\n",
                "example": "20001031"
              },
              "generoTrabajador": {
                "pattern": "^(1|2|3)$",
                "type": "string",
                "minLength": 1,
                "maxLength": 1,
                "description": "De acuerdo al  Cat\u00e1logo Genero del Trabajador\n\n1=M\n\n2=F\n\n3=X\n",
                "example": "1"
              },
              "ocupacionProfesionTrabajador": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al Cat\u00e1logo Ocupaci\u00f3n/Profesi\u00f3n del Trabajador\n",
                "example": "01"
              },
              "actividadGiroNegocioTrabajador": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al  Cat\u00e1logo Actividad/Giro del negocio del Trabajador\n",
                "example": "01"
              },
              "nivelEstudioTrabajador": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "'De acuerdo al  Cat\u00e1logo Nivel de estudios\n",
                "example": "01"
              },
              "curpPromotorFuncionario": {
                "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                "type": "string",
                "minLength": 18,
                "maxLength": 18,
                "description": "Curp promotor funcionario\n",
                "example": "AAAA900909XXXXXX09"
              },
              "calle": {
                "type": "string",
                "minLength": 1,
                "maxLength": 65,
                "description": "Calle\n",
                "example": "Calle"
              },
              "numeroExterior": {
                "type": "string",
                "minLength": 1,
                "maxLength": 15,
                "description": "Calle\n",
                "example": "NumeroExt"
              },
              "numeroInterior": {
                "type": "string",
                "minLength": 1,
                "maxLength": 15,
                "description": "Numero Interior\n",
                "example": "NumeroINT"
              },
              "colonia": {
                "type": "string",
                "minLength": 1,
                "maxLength": 65,
                "description": "Colonia\n",
                "example": "Colonia"
              },
              "delegacionMunicipio": {
                "type": "string",
                "minLength": 1,
                "maxLength": 5,
                "description": "Clave de la Delegaci\u00f3n o Municipio, de acuerdo al Cat\u00e1logo de Delegaci\u00f3n o Municipio.\n",
                "example": "Del01"
              },
              "codigoPostal": {
                "pattern": "^([0-9]{5})$",
                "type": "string",
                "minLength": 5,
                "maxLength": 5,
                "description": "C\u00f3digo Postal\n",
                "example": "12345"
              },
              "entidadFederativa": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "Clave de Entidad Federativa, de acuerdo al Cat\u00e1logo de Entidades Federativas.\n",
                "example": "20"
              },
              "pais": {
                "type": "string",
                "minLength": 3,
                "maxLength": 3,
                "description": "De acuerdo a Cat\u00e1logo de Pa\u00edses \n",
                "example": "MEX"
              },
              "indicadorTelefono1": {
                "pattern": "^([0-9]{3})$",
                "type": "string",
                "minLength": 3,
                "maxLength": 3,
                "description": "Se debe requisitar solo si el telefono1 es un celular con el prefijo de:\n \n 044 - tel\u00e9fono  celular DF y \u00e1rea metropolitana\n \n 045 - tel\u00e9fono celular interior de la republica\n",
                "example": "045"
              },
              "telefono1": {
                "pattern": "^([0-9]{10})$",
                "type": "string",
                "minLength": 10,
                "maxLength": 10,
                "description": "Corresponde al tel\u00e9fono de Casa.    \n \n En caso de no contar con este dato, el campo se deber\u00e1 requisitar con ceros\n",
                "example": "5555555555"
              },
              "extension1": {
                "pattern": "^([0-9]{5})$",
                "type": "string",
                "minLength": 1,
                "maxLength": 5,
                "description": "Extensi\u00f3n\n",
                "example": "12345"
              },
              "indicadorTelefono2": {
                "pattern": "^([0-9]{3})$",
                "type": "string",
                "minLength": 3,
                "maxLength": 3,
                "description": "Se debe requisitar solo si el telefono1 es un celular con el prefijo de:\n \n 044 - tel\u00e9fono  celular DF y \u00e1rea metropolitana\n \n 045 - tel\u00e9fono celular interior de la republica\n",
                "example": "045"
              },
              "telefono2": {
                "pattern": "^([0-9]{10})$",
                "type": "string",
                "minLength": 10,
                "maxLength": 10,
                "description": "Corresponde al tel\u00e9fono de Casa.    \n \n En caso de no contar con este dato, el campo se deber\u00e1 requisitar con ceros\n",
                "example": "5555555555"
              },
              "extension2": {
                "pattern": "^([0-9]{5})$",
                "type": "string",
                "minLength": 1,
                "maxLength": 5,
                "description": "Extensi\u00f3n\n",
                "example": "12345"
              },
              "correoElectronicoTrabajador": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50,
                "description": "Correo Electronico del Trabajador\n",
                "example": "correo@correo.com"
              }
            }
          },
          "datosDomicilioLaboralTrabajador": {
            "required": [
              "calle",
              "colonia",
              "delegacionMunicipio",
              "codigoPostal",
              "entidadFederativa",
              "pais"
            ],
            "type": "object",
            "properties": {
              "calle": {
                "type": "string",
                "minLength": 1,
                "maxLength": 65,
                "description": "Calle\n",
                "example": "Calle"
              },
              "numeroExterior": {
                "type": "string",
                "minLength": 1,
                "maxLength": 15,
                "description": "Calle\n",
                "example": "NumeroExt"
              },
              "numeroInterior": {
                "type": "string",
                "minLength": 1,
                "maxLength": 15,
                "description": "Numero Interior\n",
                "example": "NumeroINT"
              },
              "colonia": {
                "type": "string",
                "minLength": 1,
                "maxLength": 65,
                "description": "Colonia\n",
                "example": "Colonia"
              },
              "delegacionMunicipio": {
                "type": "string",
                "minLength": 1,
                "maxLength": 5,
                "description": "Clave de Delegaci\u00f3n o Municipio, de acuerdo al Cat\u00e1logo de Delegaci\u00f3n o Municipio.\n",
                "example": "Del01"
              },
              "codigoPostal": {
                "pattern": "^([0-9]{5})$",
                "type": "string",
                "minLength": 5,
                "maxLength": 5,
                "description": "C\u00f3digo Postal\n",
                "example": "12345"
              },
              "entidadFederativa": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "Entidad Federativa\n",
                "example": "20"
              },
              "pais": {
                "type": "string",
                "minLength": 3,
                "maxLength": 3,
                "description": "De acuerdo a Cat\u00e1logo de Pa\u00edses \n",
                "example": "MEX"
              }
            }
          },
          "datosReferenciasTrabajador": {
            "required": [
              "folioRegistro",
              "selloVerificacionBiometrica",
              "selloVoluntadRegistro",
              "tipoSolicitante",
              "curpSolicitante"
            ],
            "type": "object",
            "properties": {
              "apellidoPaternoReferencia1": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Apellido Paterno de la Referencia 1\n",
                "example": "Apellido Paterno"
              },
              "apellidoMaternoReferencia1": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Apellido Materno de la Referencia 1\n",
                "example": "Apellido Materno"
              },
              "nombreReferencia1": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Nombre(s) de la Referencia 1\n",
                "example": "Nombre"
              },
              "curpReferencia1": {
                "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                "type": "string",
                "minLength": 18,
                "maxLength": 18,
                "description": "CURP de la Referencia 1\n",
                "example": "AAAA900909XXXXXX09"
              },
              "telefonoReferencia1": {
                "pattern": "^([0-9]{10})$",
                "type": "string",
                "minLength": 10,
                "maxLength": 10,
                "description": "Tel\u00e9fono de la Referencia 1\n",
                "example": "5555555555"
              },
              "parentescoRelacionReferencia1": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al Cat\u00e1logo Parentesco\n",
                "example": "01"
              },
              "apellidoPaternoReferencia2": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Apellido Paterno de la Referencia 2\n",
                "example": "Apellido Paterno"
              },
              "apellidoMaternoReferencia2": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Apellido Maternode la Referencia 2\n",
                "example": "Apellido Paterno"
              },
              "nombreReferencia2": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "Nombre(s) de la Referencia 2\n",
                "example": "Nombre"
              },
              "curpReferencia2": {
                "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                "type": "string",
                "minLength": 18,
                "maxLength": 18,
                "description": "CURP de la Referencia 2\n",
                "example": "AAAA900909XXXXXX09"
              },
              "telefonoReferencia2": {
                "pattern": "^([0-9]{10})$",
                "type": "string",
                "minLength": 10,
                "maxLength": 10,
                "description": "Tel\u00e9fono de la Referencia 2\n",
                "example": "5555555555"
              },
              "parentescoRelacionReferencia2": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al Cat\u00e1logo Parentesco\n",
                "example": "01"
              },
              "folioRegistro": {
                "type": "string",
                "minLength": 1,
                "maxLength": 6,
                "description": "Folio para registro\n",
                "example": "Folio1"
              },
              "selloVerificacionBiometrica": {
                "pattern": "^([0-9]{14})$",
                "type": "string",
                "minLength": 14,
                "maxLength": 14,
                "description": "Dato a 14 posiciones \n",
                "example": "12345678901234"
              },
              "selloVoluntadRegistro": {
                "pattern": "^([0-9]{14})$",
                "type": "string",
                "minLength": 14,
                "maxLength": 14,
                "description": "Folio  de la Voluntad del Tramite de Registro (Trabajador).\nEnviar en ceros cuando el tipo de solicitante es diferente a titular.\n",
                "example": "12345678901234"
              },
              "tipoSolicitante": {
                "type": "string",
                "minLength": 2,
                "maxLength": 2,
                "description": "De acuerdo al Cat\u00e1logo de Tipo de Solicitante.\n",
                "example": "01"
              },
              "curpSolicitante": {
                "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                "type": "string",
                "minLength": 18,
                "maxLength": 18,
                "description": "CURP del Solicitante\n",
                "example": "AAAA900909XXXXXX09"
              }
            }
          },
          "datosBeneficiariosTrabajador": {
            "type": "array",
            "items": {
              "required": [
                "apellidoPaternoBeneficiario",
                "nombreBeneficiario",
                "curpBeneficiario",
                "porcentajeBeneficiario"
              ],
              "type": "object",
              "properties": {
                "apellidoPaternoBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "description": "Apellido Paterno de la Referencia 1\n",
                  "example": "Apellido Paterno"
                },
                "apellidoMaternoBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "description": "Apellido Materno de la Referencia 1\n",
                  "example": "Apellido Materno"
                },
                "nombreBeneficiario": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40,
                  "description": "Nombre(s) de la Referencia 1\n",
                  "example": "Nombre"
                },
                "curpBeneficiario": {
                  "pattern": "^([A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2})$",
                  "type": "string",
                  "minLength": 18,
                  "maxLength": 18,
                  "description": "CURP de Beneficiario\n",
                  "example": "AAAA900909XXXXXX09"
                },
                "parentescoRelacion": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 2,
                  "description": "De acuerdo al Cat\u00e1logo Parentesco\n",
                  "example": "01"
                },
                "porcentajeBeneficiario": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 3,
                  "description": "Porcentaje de Beneficiario.\n La suma del porcentaje de los N beneficiarios deber\u00e1 ser del 100%\n",
                  "example": "100"
                }
              }
            }
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for nss in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"nss\": \"12345678909\""
          }
        }
      }
    }
  }
}