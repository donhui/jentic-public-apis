{
  "openapi": "3.0.1",
  "info": {
    "title": "Separacion Cuentas - Solicitud Traspaso Op34",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para Separacion Cuentas - Solicitud Traspaso Op34",
    "contact": {
      "email": "gerencia_arquitectura_software@inet.procesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar1/Admoncuenta-SeparacionCuentas-SolicitudTraspasoOp34/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/920/separacioncuenta/traspasoafore"
    }
  ],
  "tags": [
    {
      "name": "Separacion Cuentas - Solicitud Traspaso Op34",
      "description": "Operaci\u00f3n para consular Separacion Cuentas - Solicitud Traspaso Op34"
    }
  ],
  "paths": {
    "/solicitud": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Admoncuenta - Separacion Cuentas - Solicitud Traspaso Op34",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "solicitud",
        "tags": [
          "Separacion Cuentas - Solicitud Traspaso Op34"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "Atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "enum": [
                "920"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "Atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "53"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "Atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "2",
                "4",
                "5",
                "6",
                "7",
                "8",
                "10",
                "11",
                "12",
                "14",
                "15"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para la solicitud de traspaso Op34 por datos del trabajador",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/solicitudTraspasoRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/solicitudTraspasoResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/solicitudTraspasoResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "solicitudTraspasoRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "solicitudTraspasoRequest": {
        "required": [
          "origenSolicitud",
          "nssTrabajador",
          "rfcTrabajador",
          "apellidoPaterno",
          "nombreTrabajador",
          "claveAforeTransferente",
          "claveAforeReceptora",
          "fechaNacimientoTrabajador",
          "sexo",
          "entidadFederativaNacimiento",
          "nacionalidad"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n",
            "example": "01"
          },
          "nssTrabajador": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 11,
            "description": "N\u00famero de Seguridad Social",
            "example": "12345678901"
          },
          "curp": {
            "pattern": "^([A-Z][AEIOUX][A-Z]{2}\\d{2}(?:0[1-9]|1[0-2])(?:0[1-9]|[12]\\d|3[01])[HM](?:AS|B[CS]|C[CLMSH]|D[FG]|G[TR]|HG|JC|M[CNS]|N[ETL]|OC|PL|Q[TR]|S[PLR]|T[CSL]|VZ|YN|ZS)[B-DF-HJ-NP-TV-Z]{3}[A-Z\\d])(\\d)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 18,
            "description": "CURP que tiene registrada el trabajador en la BDNSAR ",
            "example": "CAHF620818HMNLNL09"
          },
          "rfcTrabajador": {
            "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
            "type": "string",
            "minLength": 13,
            "maxLength": 13,
            "description": "RFC del trabajador (formato de persona f\u00edsica o moral). Homoclave opcional",
            "example": "XXXX900909XXX"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido paterno del trabajador, debe ser igual al registrado en la BDNSAR",
            "example": "Apellido Paterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido materno del trabajador, debe ser igual al registrado en la BDNSAR",
            "example": "Apellido Paterno"
          },
          "nombreTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre del trabajador, debe ser igual al registrado en la BDNSAR",
            "example": "Apellido Paterno"
          },
          "claveAforeTransferente": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de administradora transferente",
            "example": "300"
          },
          "claveAforeReceptora": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la entidad receptora",
            "example": "300"
          },
          "fechaNacimientoTrabajador": {
            "pattern": "^[1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2}$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Nacimiento del trabajador.",
            "example": "20220510"
          },
          "folioSolicitud": {
            "pattern": "^([0-9]{10})$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Folio asignado por la Administradora al tr\u00e1mite",
            "example": "11111111111"
          },
          "sexo": {
            "pattern": "^(1|2|3)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo",
            "example": "1"
          },
          "entidadFederativaNacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Entidad Federativa de Nacimiento",
            "example": "02"
          },
          "nacionalidad": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de Pa\u00eds",
            "example": "MEX"
          },
          "claveTipoDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Clave del tipo de documento. Seg\u00fan tabla de documentos",
            "example": "A"
          },
          "folioDocumentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 10,
            "description": "Folio de documento probatorio",
            "example": "Folio12345"
          },
          "documentoProbatorio": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Informaci\u00f3n detallada del documento probatorio",
            "example": "docto12345678901"
          }
        }
      },
      "solicitudTraspasoResponse": {
        "required": [
          "resultadoOperacion",
          "origenSolicitud",
          "nssTrabajador",
          "apellidoPaterno",
          "nombre",
          "rfcTrabajador",
          "fechaNacimientoTrabajador",
          "sexo",
          "entidadFederativaNacimiento",
          "nombreTrabajadorIMSS"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operaci\u00f3n, en donde:\n\n01 Solicitud Aceptada.\n\n60 Aceptado y asignado en misma Afore.\n\n61 Aceptado y en proceso de traspaso A-A por asignaci\u00f3n.\n\n02 Solicitud Rechazada por Procesar.\n",
            "example": "02"
          },
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud",
            "example": "01"
          },
          "nssTrabajador": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 11,
            "description": "N\u00famero de Seguridad Social",
            "example": "12345678901"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Paterno de Trabajador",
            "example": "Apellido Paterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido Materno de Trabajador",
            "example": "Apellido Paterno"
          },
          "nombreTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre Trabajador",
            "example": "Apellido Paterno"
          },
          "curp": {
            "pattern": "^([A-Z][AEIOUX][A-Z]{2}\\d{2}(?:0[1-9]|1[0-2])(?:0[1-9]|[12]\\d|3[01])[HM](?:AS|B[CS]|C[CLMSH]|D[FG]|G[TR]|HG|JC|M[CNS]|N[ETL]|OC|PL|Q[TR]|S[PLR]|T[CSL]|VZ|YN|ZS)[B-DF-HJ-NP-TV-Z]{3}[A-Z\\d])(\\d)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 18,
            "description": "CURP que tiene registrada el trabajador en la BDNSAR ",
            "example": "CAHF620818HMNLNL09"
          },
          "rfcTrabajador": {
            "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
            "type": "string",
            "minLength": 13,
            "maxLength": 13,
            "description": "RFC del trabajador (formato de persona f\u00edsica o moral). Homoclave opcional.",
            "example": "XXXX900909XXX"
          },
          "fechaNacimientoTrabajador": {
            "pattern": "^[1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2}$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Nacimiento del trabajador.",
            "example": "20220510"
          },
          "sexo": {
            "pattern": "^(1|2|3)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Sexo",
            "example": "1"
          },
          "entidadFederativaNacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Entidad Federativa de Nacimiento",
            "example": "02"
          },
          "nombreTrabajadorIMSS": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Nombre Trabajador IMSS",
            "example": "nombreTrabajadorIMSS"
          },
          "fechaAltaAforeActual": {
            "pattern": "^[1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2}$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha del d\u00eda en que se procesa la solicitud",
            "example": "20220510"
          },
          "indicadorSieforeBasicaPension": {
            "pattern": "^([0-9]{})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Siefore B\u00e1sica pensi\u00f3n",
            "example": "1"
          },
          "indicadorPortabilidad": {
            "pattern": "^([0-9]{})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Siefore B\u00e1sica pensi\u00f3n",
            "example": "1"
          },
          "motivoRechazo": {
            "type": "string",
            "minLength": 1,
            "maxLength": 15,
            "description": "Motivo de rechazo cuando la operaci\u00f3n es rechazada.\n\n000 Solicitud de certificaci\u00f3n aceptada\n\n068 Tipo de registro inv\u00e1lido\n\n049 Trabajador no se encuentra Afiliado\n\n785 Tipo de Documento Probatorio inv\u00e1lido\n\n439 CURP con datos de documento probatorio requeridos para So1 Traspaso\n\n028 CURP trabajador inv\u00e1lido\n\n037 RFC del trabajador inv\u00e1lido\n\n305 Apellido Paterno del trabajador en Entidad Receptora del Traspaso es inv\u00e1lido\n\n306 Apellido Materno en Receptora del Traspaso inv\u00e1lido\n\n307 Nombre del trabajador en Receptora del Traspaso es inv\u00e1lido\n\n937 Afore que responde no es la Afore Solicitante\n\nC28 Afore receptora es igual a la cedente\n\n026 Fecha de Nacimiento inv\u00e1lida\n\n009 Sexo inv\u00e1lido\n\n027 Entidad Federativa de Nacimiento inv\u00e1lida\n\nB46 La nacionalidad del trabajador enviada por la AFORE no existe dentro del cat\u00e1logo de nacionalidades\n\n938 El trabajador no se encuentra en proceso de Separaci\u00f3n de Cuentas \n\n816 Cuenta con operaci\u00f3n fuera de secuencia\n",
            "example": "816"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  }
}