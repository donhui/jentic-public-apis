  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "enviarRespuestaRequest": {
        "required": [
          "origenSolicitud",
          "claveAforeResponsable",
          "curp",
          "tipoConfronta",
          "identificadorUniverso",
          "indicadorProcedencia"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 2,
            "description": "Origen de la Solicitud\n\n  01 Afore\n",
            "example": "01"
          },
          "claveAforeResponsable": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "500",
            "description": "Clave de la Afore que env\u00eda la solicitud."
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguro Social a unificar.",
            "example": "12345678901"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n a unificar",
            "example": "XXXX111111XXXXXX11"
          },
          "tipoConfronta": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo Confronta\n\n1 Unificaci\u00f3n de Cuentas Mixtas\n",
            "example": "1"
          },
          "identificadorUniverso": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Identificador Universo\n\n2 Intra-Afore, las dos cuentas se encuentran registradas en la misma Administradora.\n\n3 Extra-Afore, las dos cuentas se encuentran registradas en diferentes Administradoras\n",
            "example": "2"
          },
          "indicadorProcedencia": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Indicador Procedencia\n\n01 Unificaci\u00f3n de Cuentas Mixta Procedente\n\n02 Unificaci\u00f3n de Cuentas Mixta No Procedente\n",
            "example": "01"
          }
        }
      },
      "enviarRespuestaResponse": {
        "required": [
          "resultadoOperacion",
          "diagnosticoProceso",
          "origenSolicitud",
          "claveAforeResponsable"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de Operaci\u00f3n:\n\n01 SolicitusAceptado                 \n\n02 Rechazado\n",
            "example": "01"
          },
          "diagnosticoProceso": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "000",
            "description": "Diagn\u00f3stico del proceso de acuerdo al resultado de la operaci\u00f3n y Cat\u00e1logo de Diagn\u00f3stico. \n\n003  Clave de operaci\u00f3n inv\u00e1lida\n\n821  AFORE solicitante no corresponde a la responsable\n\n005  NSS incorrecto\n\n028  CURP trabajador inv\u00e1lido\n\n065  Tipo de Transacci\u00f3n inv\u00e1lido \n\n068  Tipo de registro inv\u00e1lido\n\n788  Cuenta sin marca de unificaci\u00f3n\n\n020  Solicitud pendiente vencida\n\n654  El resultado de operaci\u00f3n inv\u00e1lido\n\n**Este campo deber\u00e1 llenarse con ceros cuando el resultado de operaci\u00f3n sea 01 Solicitud Aceptada.**\n"
          },
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "01",
            "description": "Origen de la Solicitud:\n\n01 Afore\n"
          },
          "claveAforeResponsable": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "example": "500",
            "description": "Clave de la Afore que env\u00eda la solicitud."
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  }
}