{
  "openapi": "3.0.1",
  "info": {
    "title": "Separacion Cuentas - Resultado Confronta",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para Separacion Cuentas - Resultado Confronta",
    "contact": {
      "email": "gerencia_arquitectura_software@inet.procesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar1/Admoncuenta-SeparacionCuentasResultadoConfronta/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/891/separacioncuenta/resultadoconfronta"
    }
  ],
  "tags": [
    {
      "name": "Separacion Cuentas - Resultado Confronta",
      "description": "Operaci\u00f3n para consular Separacion Cuentas - Resultado Confronta"
    }
  ],
  "paths": {
    "/registrar": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Admoncuenta - Separacion Cuentas - Resultado Confronta",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "solicitud",
        "tags": [
          "Separacion Cuentas - Resultado Confronta"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "Atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "enum": [
                "891"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "Atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "53"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "Atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "2",
                "4",
                "5",
                "6",
                "7",
                "8",
                "10",
                "11",
                "12",
                "14",
                "15"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para la consulta de CURP por datos del trabajador",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/resultadoConfrontaRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/resultadoConfrontaResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/resultadoConfrontaResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "resultadoConfrontaRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "resultadoConfrontaRequest": {
        "required": [
          "origenSolicitud",
          "claveAfore",
          "nssInvadido",
          "diagnosticoConfronta"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n\n01 Afore\n",
            "example": "01"
          },
          "claveAfore": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore",
            "example": "300"
          },
          "nssInvadido": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS del invadido.",
            "example": "11111111111"
          },
          "rfc": {
            "pattern": "^([A-Z]{4}[0-9]{6})|([A-Z]{4}[0-9]{6}[A-Z0-9]{3})$",
            "type": "string",
            "minLength": 13,
            "maxLength": 13,
            "description": "RFC del trabajador.",
            "example": "XXXX900909XXX"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del trabajador.",
            "example": "XXXX111111XXXXXX11"
          },
          "apellidoPaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido paterno del trabajador invadido.",
            "example": "Apellido Paterno"
          },
          "apellidoMaterno": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido materno del trabajador invadido.",
            "example": "Apellido Paterno"
          },
          "nombreTrabajador": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre del trabajador invadido.",
            "example": "Apellido Paterno"
          },
          "fechaNacimiento": {
            "pattern": "^[1,2]{1}[0-9]{1}[0-9]{2}[0-1]{1}[0-9]{1}[0-9]{2}$",
            "type": "string",
            "minLength": 8,
            "maxLength": 8,
            "description": "Fecha de Nacimiento del trabajador.",
            "example": "20220510"
          },
          "entidadFederativaNacimiento": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Entidad Federativa de Nacimiento",
            "example": "02"
          },
          "sexo": {
            "pattern": "^(1|2|3)$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Genero\n\n1 - M\n\n2 - F\n\n3 - X\n",
            "example": "1"
          },
          "indicadorUnificacionPrevia": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Unificaci\u00f3n Previa",
            "example": "1"
          },
          "diagnosticoConfronta": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Indicador Unificaci\u00f3n Previa",
            "example": "01"
          },
          "clasificacionSeparacion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Unificaci\u00f3n Previa",
            "example": "A"
          },
          "indicadorCambioClasificacion": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Unificaci\u00f3n Previa",
            "example": "1"
          },
          "idNegocioAsociado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS del asociado.",
            "example": "12345678901"
          },
          "indicadorCambioNssAsociado": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador Cambio de Nss de Asociado",
            "example": "1"
          },
          "idNegocioAsociadoNuevo": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "Id de Negocio Asociado Nuevo",
            "example": "11111111111"
          }
        }
      },
      "resultadoConfrontaResponse": {
        "required": [
          "origenSolicitud",
          "claveAfore",
          "nssInvadido",
          "resultadoOperacion",
          "diagnosticoProceso"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud: \n\n01 Afore\n",
            "example": "01"
          },
          "claveAfore": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de AFORE",
            "example": "530"
          },
          "nssInvadido": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS del invadido.",
            "example": "12345678901"
          },
          "tipoEntidadNssInvadido": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "NSS del invadido.",
            "example": "01"
          },
          "nssAsociado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS del Asociado.",
            "example": "12345678901"
          },
          "tipoEntidadNssAsociado": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "NSS del Asociado.",
            "example": "01"
          },
          "claveEntidadNssAsociado": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de entidad de NSS Asociado",
            "example": "530"
          },
          "resultadoOperacion": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operaci\u00f3n, en donde:\n\n01 Solicitud Aceptada.\n\n02 Solicitud Rechazada por Procesar.\n\n03 Solicitud Pendiente por Marca Operativa.\n\n04 Solicitud Rechazada por Infonavit.\n\n05 Solicitud sin respuesta del servicio del Infonavit.\n",
            "example": "02"
          },
          "diagnosticoProceso": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Diagn\u00f3stico del proceso, cuando el resultado de la operaci\u00f3n en rechazo (02).\n\n000 Solicitud aceptada \n\n068 Tipo de registro inv\u00e1lido \n\n022 Afore no existente \n\n049 Trabajador no se encuentra afiliado \n\n489 Trabajador afiliado en otra AFORE \n\n938 El trabajador no se encuentra en proceso de Separaci\u00f3n de Cuentas \n\n816 Cuenta con operaci\u00f3n fuera de secuencia \n\n065 Tipo de Transacci\u00f3n inv\u00e1lido \n\n745 Diagn\u00f3stico de la aclaraci\u00f3n de la AFORE inv\u00e1lido \n\n802 Clasificaci\u00f3n requerida \n\n494 Trabajador asociado requerido \n\n862 NSS asociado no coincide con la informaci\u00f3n enviada \n\n042 NSS no se encuentra activo en PROCANASE \n\nC47 En Proceso de Modificaci\u00f3n de datos No Afiliados \n\n960 En Proceso de Fusi\u00f3n \n\n03H En Proceso de Registro M\u00f3vil de IMSS Puro \n\nF67 En Proceso de Registro M\u00f3vil de Ahorradores Asignados \n\n573 En Proceso de Unificaci\u00f3n de Cuentas \n\n573 En Proceso de Unificaci\u00f3n de Cuentas \n\n573 En Proceso de Unificaci\u00f3n de Cuentas \n\n986 En Proceso de Aportaciones subsecuentes 43 bis& \n\nD01 En Proceso de Devoluci\u00f3n de Pagos en exceso IMSS \n\nF72 En Proceso de Acreditaci\u00f3n de Bono ISSSTE \n\nF71 En Proceso de Redenci\u00f3n Bono Anual ISSSTE \n\n297 En Proceso de Selecci\u00f3n de SIEFORE \n\n815 En Proceso de Registro Subcuentas Marop \n\n815 En Proceso de Devoluci\u00f3n de Pagos en exceso INFONAVIT \n\nD14 En Proceso de Aportaciones Subsecuentes FOVISSSTE \n\n438 En Proceso de Transferencia Extempor\u00e1nea \n\nD02 En Proceso de Retiros Parciales \n\nD03 En Proceso de Transferencia de Recursos \n\nD04 En Proceso de Disposici\u00f3n de Recursos \n\nD05 En Proceso de Disposici\u00f3n de Recursos por Ventanilla Infonavit \n\nD04 En Proceso de Retiros Disposici\u00f3n por Recursos Ventanilla AFORE \n\n539 En Proceso de Tr\u00e1mite Judicial (IMSS) \n\n539 En Proceso de Tr\u00e1mite Judicial \n\nD05 En Proceso de Disposici\u00f3n Retiro Programado \n\nD06 En Proceso de Retiros Parciales ISSSTE \n\nD07 En Proceso de Retiros Totales ISSSTE \n\nD08 En Proceso de Notificaci\u00f3n de Saldos Previos IMSS \n\nD09 En Proceso de Notificaci\u00f3n de Saldos Previos ISSSTE \n\nD03 En Proceso de Transferencia de Recursos ISSSTE \n\n530 En Proceso de Transferencia Acreditados Infonavit\n",
            "example": "284"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"curp\": \"123456789098765\""
          }
        }
      }
    }
  }
}