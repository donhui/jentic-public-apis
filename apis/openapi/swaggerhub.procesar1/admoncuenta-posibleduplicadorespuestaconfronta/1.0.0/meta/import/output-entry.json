  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticación básica, el usuario y contraseña es personalizado por AFORE."
      }
    },
    "schemas": {
      "respuestaConfrontaRequest": {
        "required": [
          "origenSolicitud",
          "claveAforeResponsable",
          "curp",
          "tipoConfronta",
          "identificadorUniverso",
          "indicadorProcedencia"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n\n01 Afore\n",
            "example": "01"
          },
          "claveAforeResponsable": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que envía la solicitud",
            "example": "123"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "Número de Seguro Social de la solicitud.",
            "example": "12345678901"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave Única de Registro de Población",
            "example": "XXXX111111XXXXXX11"
          },
          "tipoConfronta": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo de confronta",
            "example": "2"
          },
          "identificadorUniverso": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Identificador Universo\n\n11 Aclaración por posible raíz CURP  duplicada en procesos de registro\n\n12 Aclaración por CURP duplicada en procesos de registro\n\n13 Aclaración por CURP duplicada en procesos de modificación de datos\n\n14 Aclaración por CURP duplicada en procesos de unificación de cuentas mixtas\n\n15 Aclaración por CURP duplicada en procesos de permanencia de expediente electrónico\n",
            "example": "15"
          },
          "indicadorProcedencia": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Indicador Procedencia\n\n03 - Es diferente Trabajador.\n\n04 - Es el mismo Trabajador\n",
            "example": "03"
          }
        }
      },
      "respuestaConfrontaResponse": {
        "required": [
          "resultadoOperacion",
          "diagnosticoProceso",
          "origenSolicitud",
          "claveAforeResponsable"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de Operación:\n\n01 Solicitud Aceptada                 \n\n02 Solicitud Rechazada\n",
            "example": "02"
          },
          "diagnosticoProceso": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Diagnóstico del proceso de acuerdo al resultado de la operación y Catálogo de Diagnóstico. \n\n003 Clave de operación inválida\n\n821 AFORE solicitante no corresponde a la responsable\n\n005 NSS incorrecto\n\n028 CURP trabajador inválido\n\n065 Tipo de Transacción inválido \n\n068 Tipo de registro inválido\n\n865 Cuenta no se encuentra pendiente por CURP Duplicada\n\n860 Solicitud de aclaración de CURP duplicada vencida\n\n654 El resultado de operación inválido\n\n_Este campo deberá llenarse con ceros cuando el resultado de operación sea 01 Solicitud Aceptada._\n",
            "example": "003"
          },
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n\n01 Afore\n",
            "example": "01"
          },
          "claveAforeResponsable": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que envía la solicitud",
            "example": "123"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for nss in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"nss\": \"12345678909\""
          }
        }
      }
    }
  },
