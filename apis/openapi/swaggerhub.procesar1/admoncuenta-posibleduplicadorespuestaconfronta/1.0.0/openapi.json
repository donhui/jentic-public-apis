  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "respuestaConfrontaRequest": {
        "required": [
          "origenSolicitud",
          "claveAforeResponsable",
          "curp",
          "tipoConfronta",
          "identificadorUniverso",
          "indicadorProcedencia"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n\n01 Afore\n",
            "example": "01"
          },
          "claveAforeResponsable": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que env\u00eda la solicitud",
            "example": "123"
          },
          "nss": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "N\u00famero de Seguro Social de la solicitud.",
            "example": "12345678901"
          },
          "curp": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n",
            "example": "XXXX111111XXXXXX11"
          },
          "tipoConfronta": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Tipo de confronta",
            "example": "2"
          },
          "identificadorUniverso": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Identificador Universo\n\n11 Aclaraci\u00f3n por posible ra\u00edz CURP  duplicada en procesos de registro\n\n12 Aclaraci\u00f3n por CURP duplicada en procesos de registro\n\n13 Aclaraci\u00f3n por CURP duplicada en procesos de modificaci\u00f3n de datos\n\n14 Aclaraci\u00f3n por CURP duplicada en procesos de unificaci\u00f3n de cuentas mixtas\n\n15 Aclaraci\u00f3n por CURP duplicada en procesos de permanencia de expediente electr\u00f3nico\n",
            "example": "15"
          },
          "indicadorProcedencia": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Indicador Procedencia\n\n03 - Es diferente Trabajador.\n\n04 - Es el mismo Trabajador\n",
            "example": "03"
          }
        }
      },
      "respuestaConfrontaResponse": {
        "required": [
          "resultadoOperacion",
          "diagnosticoProceso",
          "origenSolicitud",
          "claveAforeResponsable"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de Operaci\u00f3n:\n\n01 Solicitud Aceptada                 \n\n02 Solicitud Rechazada\n",
            "example": "02"
          },
          "diagnosticoProceso": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Diagn\u00f3stico del proceso de acuerdo al resultado de la operaci\u00f3n y Cat\u00e1logo de Diagn\u00f3stico. \n\n003 Clave de operaci\u00f3n inv\u00e1lida\n\n821 AFORE solicitante no corresponde a la responsable\n\n005 NSS incorrecto\n\n028 CURP trabajador inv\u00e1lido\n\n065 Tipo de Transacci\u00f3n inv\u00e1lido \n\n068 Tipo de registro inv\u00e1lido\n\n865 Cuenta no se encuentra pendiente por CURP Duplicada\n\n860 Solicitud de aclaraci\u00f3n de CURP duplicada vencida\n\n654 El resultado de operaci\u00f3n inv\u00e1lido\n\n_Este campo deber\u00e1 llenarse con ceros cuando el resultado de operaci\u00f3n sea 01 Solicitud Aceptada._\n",
            "example": "003"
          },
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n\n01 Afore\n",
            "example": "01"
          },
          "claveAforeResponsable": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore que env\u00eda la solicitud",
            "example": "123"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for nss in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"nss\": \"12345678909\""
          }
        }
      }
    }
  }
}