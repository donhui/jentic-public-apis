{
  "openapi": "3.0.1",
  "info": {
    "title": "Consulta Estatus CURP Trabajador",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para consultar el estatus de la curp de un trabajador",
    "contact": {
      "email": "GERENCIA_ARQUITECTURA_SOFTWARE@inet.procesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar1/Admoncuenta-Trabajador-ConsultaCurp/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/807/trabajadores"
    }
  ],
  "tags": [
    {
      "name": "Consultar Estatus CURP Trabajador",
      "description": "Operaciones para consultar el estatus de la curp de un trabajador"
    }
  ],
  "paths": {
    "/{curp}/estatus": {
      "get": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Traspasos - Consulta Estatus CURP Trabajador por NSS, CURP y AFORE",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "consultarTrabajadorNss",
        "tags": [
          "Consultar Estatus CURP Trabajador"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "Atributo http-header identificador de servicio.",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "807"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "Atributo http-header identificador de negocio.",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "28"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "Atributo http-header identificador de AFORE.",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "6",
                "4"
              ]
            }
          },
          {
            "name": "curp",
            "in": "path",
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Trabajador.\n```\npattern: ^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$\ntype: string\nminLength: 18\nmaxLength: 18\n```\n",
            "required": true,
            "schema": {
              "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
              "type": "string",
              "minLength": 18,
              "maxLength": 18,
              "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Trabajador.",
              "example": "XXXX111111XXXXXX11"
            }
          },
          {
            "name": "afore",
            "in": "query",
            "description": "Clave de Administradora.\n```\npattern: ^[0-9][0-9][0-9]$\ntype: string\nminLength: 3\nmaxLength: 3           \n```\n",
            "required": true,
            "schema": {
              "pattern": "^[0-9][0-9][0-9]$",
              "type": "string",
              "minLength": 3,
              "maxLength": 3,
              "description": "Clave de Administradora.",
              "example": "999"
            }
          },
          {
            "name": "origenSolicitud",
            "in": "query",
            "description": "Origen de la solicitud.\n```\ntype: string\nminLength: 2\nmaxLength: 2            \n```\n",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2,
              "description": "Origen de la solicitud.",
              "example": "01"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/consultarCurpResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "consultarCurpResponse": {
        "required": [
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^01|02$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de la operaci\u00f3n. Valores:\n\n01 = aceptado; 02 = rechazado.\n",
            "example": "02"
          },
          "motivoRechazo": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Motivo de Rechazo de acuerdo al cat\u00e1logo.\n",
            "example": "100"
          },
          "estatus": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Estatus de la operacion.\n",
            "example": "XX"
          }
        }
      },
      "error": {
        "required": [
          "error"
        ],
        "type": "object",
        "properties": {
          "error": {
            "$ref": "#/components/schemas/errorDetail"
          }
        }
      },
      "errorDetail": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string",
            "example": "HTTP - 400"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string",
            "example": "Validar Estructura Entrada"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for numericoString_11 in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"nssTrabajador\": \"123456789098765\""
          }
        }
      }
    }
  }
}