  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticación básica, el usuario y contraseña es personalizado por AFORE."
      }
    },
    "schemas": {
      "enviarRespuestaRequest": {
        "required": [
          "afore",
          "tipoProceso",
          "tipoProcesoReclasificacion",
          "curpAhorrador",
          "respuestaAfore",
          "folioAclaracionQueja",
          "fechaRespuestaAfore",
          "reclasificacion",
          "accion"
        ],
        "type": "object",
        "properties": {
          "afore": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de Administradora.\n",
            "example": "999"
          },
          "tipoProceso": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Opciones de Tipo de Notificación:\n\n01 Ahorro en Línea\n\n02 Consulta de saldos y movimientos\n\n03 Modificación de Datos\n\n04 Registro y Consulta de Menores\n\n05 Retiro de Aportaciones Voluntarias\n\n06 Retiro por Desempleo\n\n07 Retiro por Matrimonio\n\n08 Solicitud de Documento\n",
            "example": "01"
          },
          "tipoProcesoReclasificacion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Opciones de Tipo de Notificación:\n\n01 Ahorro en Línea\n\n02 Consulta de saldos y movimientos\n\n03 Modificación de Datos\n\n04 Registro y Consulta de Menores\n\n05 Retiro de Aportaciones Voluntarias\n\n06 Retiro por Desempleo\n\n07 Retiro por Matrimonio\n\n08 Solicitud de Documento\n",
            "example": "01"
          },
          "curpAhorrador": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave Única de Registro de Población del Ahorrador.\n",
            "example": "AAAA000000AAAAAAAA"
          },
          "respuestaAfore": {
            "type": "string",
            "minLength": 50,
            "maxLength": 500,
            "description": "Texto de respuesta, no deberá ser nulo y mayor a 50 caracteres.\n",
            "example": "descripcionQuejadescripcionQuejadescripcionQuejas1"
          },
          "folioAclaracionQueja": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20,
            "description": "Identificador único del trámite asignado por la app para la solicitud de la Queja\n",
            "example": "AAAAA99999AAAAA99999"
          },
          "fechaRespuestaAfore": {
            "pattern": "^[0-3]{1}[0-9]{1}[/]{1}[0,1]{1}[0-9]{1}[/][0-2]{1}[0-9]{3}$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Fecha de respuesta de la Afore, Formato  DD/MM/AAAA\n Donde:\n \n DD = día\n \n MM = mes\n \n AAAA = año\n \n",
            "example": "30/11/2023"
          },
          "reclasificacion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Tipo de Clasificación:\n\n01 Aclaración\n\n02 Queja\n",
            "example": "01"
          },
          "accion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "03 - Atendida\n",
            "example": "03"
          }
        }
      },
      "enviarRespuestaResponse": {
        "required": [
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de Operación:\n\n01 Solicitud Aceptada            \n     \n02 Solicitud Rechazada\n",
            "example": "02"
          },
          "motivoRechazo": {
            "pattern": "^[A-Z0-9]{3}$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Diagnósticos o motivos de rechazo del proceso. Campo obligatorio, de acuerdo al resultado de la operación = 02. \n\n999  Time Out.                \n     \nL84  El folio no existe.          \n     \nL85  Folio y CURP diferentes a los notificados.            \n     \nL86  Reclasificación no válida.            \n     \nL87  Servicio no válido.            \n     \n02R  Acción no válida.\n",
            "example": "999"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for nss in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"nss\": \"12345678909\""
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Respuesta Aclaración y Quejas",
      "description": "Operación para dar Respuesta Aclaración y Quejas."
    }
  ]
