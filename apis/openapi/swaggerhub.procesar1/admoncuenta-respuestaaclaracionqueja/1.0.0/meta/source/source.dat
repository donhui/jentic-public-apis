{
  "openapi": "3.0.1",
  "info": {
    "title": "Respuesta Aclaraci\u00f3n y Quejas",
    "description": "Especificaci\u00f3n t\u00e9cnica de servicio para Respuesta Aclaraci\u00f3n y Quejas",
    "contact": {
      "email": "gerencia_arquitectura_software@inet.procesar.com.mx"
    },
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Procesar1/Admoncuenta-RespuestaAclaracionQueja/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://172.21.67.22:443/admoncuenta/v1/1005/aclaracionqueja"
    }
  ],
  "tags": [
    {
      "name": "Respuesta Aclaraci\u00f3n y Quejas",
      "description": "Operaci\u00f3n para dar Respuesta Aclaraci\u00f3n y Quejas."
    }
  ],
  "paths": {
    "/respuesta": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Admoncuenta - Respuesta Aclaraci\u00f3n y Quejas",
        "description": "**NOTA:** Los campos marcados como opcional no deben enviarse si \u00e9stos no llevaran valor, por tanto, no se aceptan campos/etiquetas vac\u00edas.",
        "operationId": "solicitud",
        "tags": [
          "Respuesta Aclaraci\u00f3n y Quejas"
        ],
        "parameters": [
          {
            "name": "idServicio",
            "in": "header",
            "description": "Atributo http-header identificador de servicio",
            "required": true,
            "schema": {
              "enum": [
                "1005"
              ]
            }
          },
          {
            "name": "idEbusiness",
            "in": "header",
            "description": "Atributo http-header identificador de negocio",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "53"
              ]
            }
          },
          {
            "name": "idCliente",
            "in": "header",
            "description": "Atributo http-header identificador de AFORE",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "2",
                "4",
                "5",
                "6",
                "7",
                "8",
                "10",
                "11",
                "12",
                "14",
                "15"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Request para dar Respuesta Aclaraci\u00f3n y Quejas.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/enviarRespuestaRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "# OK \n\nTransacci\u00f3n exitosa.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/enviarRespuestaResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/enviarRespuestaResponse"
                }
              }
            }
          },
          "400": {
            "description": "# Bad Request  \n\nLa petici\u00f3n enviada es incorrecta. \n\n1.- El payload (campos y valores) no son correctos. \n\n2.- Mensaje de error cuando los valores del header no son correctos, tanto en atributos como en valor. \n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "# Unauthorized \n\n1.- El usuario de las credenciales enviadas no est\u00e1 de acuerdo con el atributo idCliente correspondiente. \n\n2.- Credenciales\nde Basic Auth no v\u00e1lidas o no enviadas.\n",
            "content": {
              "text/html": {
                "example": "<html>\n  <head>\n      <meta content=\"HTML Tidy for Java (vers. 26 Sep 2004), see www.w3.org\" name=\"generator\"/>\n      <title/>\n  </head>\n  <body>Unauthorized</body>\n</html>\n"
              }
            }
          },
          "404": {
            "description": "# Not Found\n\nEndpoint incorrecto\n",
            "content": {
              "application/json": {
                "example": "Not Found"
              }
            }
          },
          "500": {
            "description": "# Internal Server Error \n\nMensaje gen\u00e9rico de error de servidor.\n",
            "content": {
              "application/json": {
                "example": "Internal Server Error"
              }
            }
          },
          "503": {
            "description": "# Service Unavailable \n\nServicio no disponible temporalmente .\n",
            "content": {
              "application/json": {
                "example": "Service Unavailable"
              }
            }
          }
        },
        "x-codegen-request-body-name": "respuestaConfrontaRequest"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Servicio con autenticaci\u00f3n b\u00e1sica, el usuario y contrase\u00f1a es personalizado por AFORE."
      }
    },
    "schemas": {
      "enviarRespuestaRequest": {
        "required": [
          "afore",
          "tipoProceso",
          "tipoProcesoReclasificacion",
          "curpAhorrador",
          "respuestaAfore",
          "folioAclaracionQueja",
          "fechaRespuestaAfore",
          "reclasificacion",
          "accion"
        ],
        "type": "object",
        "properties": {
          "afore": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de Administradora.\n",
            "example": "999"
          },
          "tipoProceso": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Opciones de Tipo de Notificaci\u00f3n:\n\n01 Ahorro en L\u00ednea\n\n02 Consulta de saldos y movimientos\n\n03 Modificaci\u00f3n de Datos\n\n04 Registro y Consulta de Menores\n\n05 Retiro de Aportaciones Voluntarias\n\n06 Retiro por Desempleo\n\n07 Retiro por Matrimonio\n\n08 Solicitud de Documento\n",
            "example": "01"
          },
          "tipoProcesoReclasificacion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Opciones de Tipo de Notificaci\u00f3n:\n\n01 Ahorro en L\u00ednea\n\n02 Consulta de saldos y movimientos\n\n03 Modificaci\u00f3n de Datos\n\n04 Registro y Consulta de Menores\n\n05 Retiro de Aportaciones Voluntarias\n\n06 Retiro por Desempleo\n\n07 Retiro por Matrimonio\n\n08 Solicitud de Documento\n",
            "example": "01"
          },
          "curpAhorrador": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Clave \u00danica de Registro de Poblaci\u00f3n del Ahorrador.\n",
            "example": "AAAA000000AAAAAAAA"
          },
          "respuestaAfore": {
            "type": "string",
            "minLength": 50,
            "maxLength": 500,
            "description": "Texto de respuesta, no deber\u00e1 ser nulo y mayor a 50 caracteres.\n",
            "example": "descripcionQuejadescripcionQuejadescripcionQuejas1"
          },
          "folioAclaracionQueja": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20,
            "description": "Identificador \u00fanico del tr\u00e1mite asignado por la app para la solicitud de la Queja\n",
            "example": "AAAAA99999AAAAA99999"
          },
          "fechaRespuestaAfore": {
            "pattern": "^[0-3]{1}[0-9]{1}[/]{1}[0,1]{1}[0-9]{1}[/][0-2]{1}[0-9]{3}$",
            "type": "string",
            "minLength": 10,
            "maxLength": 10,
            "description": "Fecha de respuesta de la Afore, Formato  DD/MM/AAAA\n Donde:\n \n DD = d\u00eda\n \n MM = mes\n \n AAAA = a\u00f1o\n \n",
            "example": "30/11/2023"
          },
          "reclasificacion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Tipo de Clasificaci\u00f3n:\n\n01 Aclaraci\u00f3n\n\n02 Queja\n",
            "example": "01"
          },
          "accion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "03 - Atendida\n",
            "example": "03"
          }
        }
      },
      "enviarRespuestaResponse": {
        "required": [
          "resultadoOperacion"
        ],
        "type": "object",
        "properties": {
          "resultadoOperacion": {
            "pattern": "^[0-9]{2}$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Resultado de Operaci\u00f3n:\n\n01 Solicitud Aceptada            \n     \n02 Solicitud Rechazada\n",
            "example": "02"
          },
          "motivoRechazo": {
            "pattern": "^[A-Z0-9]{3}$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Diagn\u00f3sticos o motivos de rechazo del proceso. Campo obligatorio, de acuerdo al resultado de la operaci\u00f3n = 02. \n\n999  Time Out.                \n     \nL84  El folio no existe.          \n     \nL85  Folio y CURP diferentes a los notificados.            \n     \nL86  Reclasificaci\u00f3n no v\u00e1lida.            \n     \nL87  Servicio no v\u00e1lido.            \n     \n02R  Acci\u00f3n no v\u00e1lida.\n",
            "example": "999"
          }
        }
      },
      "error": {
        "required": [
          "codigo",
          "descripcion",
          "locacion"
        ],
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string"
          },
          "descripcion": {
            "$ref": "#/components/schemas/ValidationFailure"
          },
          "locacion": {
            "type": "string"
          }
        }
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "ValidationFailureDetail": {
            "$ref": "#/components/schemas/ValidationFailureDetail"
          }
        }
      },
      "ValidationFailureDetail": {
        "type": "object",
        "properties": {
          "message": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "string value '123456789098765' does not match pattern for nss in namespace http://www.procesar.com.mx/ArquitecturaSW/DataTypes/tiposComunesProcesar/\n"
          },
          "xmlLocation": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "\"nss\": \"12345678909\""
          }
        }
      }
    }
  }
}