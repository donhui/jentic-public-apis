    "schemas": {
      "solicitarBajaCurpRequest": {
        "required": [
          "origenSolicitud",
          "cveEntidadOrigen",
          "idNegocioInvadido",
          "bajaCurp"
        ],
        "type": "object",
        "properties": {
          "origenSolicitud": {
            "pattern": "^([0-9]{2})$",
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "Origen de la Solicitud:\n\n01 Afore\n",
            "example": "01"
          },
          "cveEntidadOrigen": {
            "pattern": "^([0-9]{3})$",
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "description": "Clave de la Afore",
            "example": "300"
          },
          "idNegocioInvadido": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS del invadido.",
            "example": "11111111111"
          },
          "curpTrabajadorInvadido": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del trabajador invadido.",
            "example": "XXXX111111XXXXXX11"
          },
          "apPaternoNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido paterno del trabajador invadido.",
            "example": "Apellido Paterno"
          },
          "apMaternoNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido materno del trabajador invadido.",
            "example": "Apellido Paterno"
          },
          "nombreTrabNssInvadido": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre del trabajador invadido.",
            "example": "Apellido Paterno"
          },
          "menoresNssInvadido": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Este indicador solo ser\u00e1 enviado cuando la CURP a dar de baja tiene asociados menores de edad:\n\n1: Menores de Edad pertenecen al due\u00f1o de la CURP.\n\n2: Menores de Edad no pertenecen al due\u00f1o de la CURP.N\u00famero de Seguro Social proporcionado por el trabajador.\n",
            "example": "1"
          },
          "idNegocioAsociado": {
            "pattern": "^([0-9]{11})$",
            "type": "string",
            "minLength": 11,
            "maxLength": 11,
            "description": "NSS del asociado.",
            "example": "12345678901"
          },
          "curpTrabajadorAsociado": {
            "pattern": "^[A-Z]{4}\\d{6}[A-Z]{6}[A-Z0-9]{2}$",
            "type": "string",
            "minLength": 18,
            "maxLength": 18,
            "description": "CURP del trabajador asociado.\n\nSer\u00e1 obligatorio cuando se dar\u00e1 de baja una CURP con Saldos ISSSTE\n",
            "example": "XXXX111111XXXXXX11"
          },
          "apPaternoNssAsociado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido paterno del trabajador asociado.",
            "example": "Apellido Paterno"
          },
          "apMaternoNssAsociado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Apellido materno del trabajador asociado.",
            "example": "Apellido Paterno"
          },
          "nombreTrabNssAsociado": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "Nombre del trabajador asociado.",
            "example": "Apellido Paterno"
          },
          "menoresNssAsociado": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Este indicador solo ser\u00e1 enviado cuando la CURP a dar de baja tiene asociados menores de edad:\n\n1: Menores de Edad pertenecen al due\u00f1o de la CURP.\n\n2: Menores de Edad no pertenecen al due\u00f1o de la CURP.\n",
            "example": "1"
          },
          "bajaCurp": {
            "pattern": "^([0-9]{1})$",
            "type": "string",
            "minLength": 1,
            "maxLength": 1,
            "description": "Indicador de baja de CURP:\n\n1: Baja de CURP en el NSS invadido\n\n2: Baja de CURP en el NSS asociado\n\n3: Transferencia de CURP\n",
            "example": "1"
          }
        }
      },
