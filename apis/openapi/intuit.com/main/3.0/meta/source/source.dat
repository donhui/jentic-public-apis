    "/cdc": {
      "get": {
        "tags": [
          "ChangeDataCapture"
        ],
        "summary": "Get changed entities since a given time",
        "description": "Returns entities that have changed since the specified timestamp. Useful for syncing data. Supports multiple entity types in a single request.",
        "operationId": "getChangedEntities",
        "parameters": [
          {
            "name": "entities",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of entity names to check for changes (e.g. Invoice,Customer,Payment)",
            "schema": {
              "type": "string"
            },
            "example": "Invoice,Customer,Payment"
          },
          {
            "name": "changedSince",
            "in": "query",
            "required": true,
            "description": "ISO 8601 timestamp. Returns entities changed since this time.",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "example": "2024-01-01T00:00:00-07:00"
          },
          {
            "$ref": "#/components/parameters/minorversion"
          }
        ],
        "responses": {
          "200": {
            "description": "Changed entities retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CDCResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input or business validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or expired OAuth 2.0 token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Entity does not exist",
