{
  "openapi": "3.0.3",
  "info": {
    "title": "QuickBooks Online Accounting API",
    "version": "3.0",
    "description": "The QuickBooks Online Accounting API provides programmatic access to QuickBooks Online company data including customers, invoices, payments, bills, items, accounts, reports, and more. It uses a REST architecture with JSON payloads and OAuth 2.0 for authentication.",
    "contact": {
      "name": "Intuit Developer",
      "url": "https://developer.intuit.com"
    },
    "x-jentic-source-url": "https://developer.intuit.com/app/developer/qbo/docs/api/accounting/all-entities/account"
  },
  "servers": [
    {
      "url": "https://quickbooks.api.intuit.com/v3/company/{realmId}",
      "description": "Production",
      "variables": {
        "realmId": {
          "description": "The QuickBooks Online company ID (realm ID)",
          "default": "1234567890"
        }
      }
    },
    {
      "url": "https://sandbox-quickbooks.api.intuit.com/v3/company/{realmId}",
      "description": "Sandbox",
      "variables": {
        "realmId": {
          "description": "The QuickBooks Online company ID (realm ID)",
          "default": "1234567890"
        }
      }
    }
  ],
  "paths": {
    "/account": {
      "post": {
        "tags": [
          "Account"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/minorversion"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Account"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Financial account created or updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Account": {
                      "$ref": "#/components/schemas/Account"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input or business validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or expired OAuth 2.0 token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Entity does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "summary": "Create or update a financial account",
        "description": "Creates a new financial account if no Id is provided in the request body, or performs a full update if Id and SyncToken are included. For sparse updates, set sparse=true in the request body.",
        "operationId": "createOrUpdateAccount"
      }
    },
    "/account/{accountId}": {
      "get": {
        "tags": [
          "Account"
        ],
        "summary": "Read a financial account by ID",
        "description": "Retrieves the details of a financial account that has been previously created.",
        "operationId": "readAccount",
        "parameters": [
