                "$ref": "#/components/schemas/VendorCredit"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Vendor credit created or updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "VendorCredit": {
                      "$ref": "#/components/schemas/VendorCredit"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input or business validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or expired OAuth 2.0 token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Entity does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "summary": "Create or update a vendor credit",
        "description": "Creates a new vendor credit if no Id is provided in the request body, or performs a full update if Id and SyncToken are included. For sparse updates, set sparse=true in the request body. To delete, include the Id and SyncToken in the body and add ?operation=delete as a query parameter.",
        "operationId": "createOrUpdateVendorCredit"
      }
    },
    "/vendorcredit/{vendorcreditId}": {
      "get": {
        "tags": [
          "VendorCredit"
        ],
        "summary": "Read a vendor credit by ID",
        "description": "Retrieves the details of a vendor credit that has been previously created.",
        "operationId": "readVendorCredit",
        "parameters": [
          {
            "name": "vendorcreditId",
            "in": "path",
            "required": true,
            "description": "The ID of the vendor credit to retrieve",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/minorversion"
          }
        ],
        "responses": {
          "200": {
            "description": "Vendor credit retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "VendorCredit": {
                      "$ref": "#/components/schemas/VendorCredit"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input or business validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or expired OAuth 2.0 token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Entity does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ReferenceType": {
        "type": "object",
        "description": "Reference to a QuickBooks entity",
        "properties": {
          "value": {
            "type": "string",
            "description": "The ID of the referenced entity"
          },
          "name": {
            "type": "string",
            "description": "The display name of the referenced entity"
          }
        },
        "required": [
          "value"
        ]
      },
      "CurrencyRef": {
        "type": "object",
        "description": "Reference to a currency",
        "properties": {
          "value": {
            "type": "string",
            "description": "ISO 4217 currency code (e.g. USD)"
          },
          "name": {
            "type": "string",
            "description": "Currency name"
          }
        },
        "required": [
          "value"
        ]
      },
      "MetaData": {
        "type": "object",
        "description": "Metadata about the entity creation and last update",
        "properties": {
          "CreateTime": {
            "type": "string",
            "format": "date-time",
            "description": "Time the entity was created"
          },
          "LastUpdatedTime": {
            "type": "string",
            "format": "date-time",
            "description": "Time the entity was last updated"
          }
        }
      },
      "PhysicalAddress": {
        "type": "object",
        "description": "Physical (postal) address",
        "properties": {
          "Id": {
            "type": "string",
            "description": "Unique identifier for the address"
          },
          "Line1": {
            "type": "string",
            "description": "First line of the street address"
          },
          "Line2": {
            "type": "string",
            "description": "Second line of the street address"
          },
          "Line3": {
            "type": "string",
            "description": "Third line of the street address"
          },
          "Line4": {
            "type": "string",
            "description": "Fourth line of the street address"
          },
          "Line5": {
            "type": "string",
            "description": "Fifth line of the street address"
          },
          "City": {
            "type": "string",
            "description": "City name"
          },
          "Country": {
            "type": "string",
            "description": "Country name or abbreviation"
          },
          "CountrySubDivisionCode": {
            "type": "string",
            "description": "Region within a country (e.g. state, province)"
          },
          "PostalCode": {
            "type": "string",
            "description": "Postal code"
          },
          "Lat": {
            "type": "string",
            "description": "Latitude coordinate"
          },
          "Long": {
            "type": "string",
            "description": "Longitude coordinate"
          }
        }
      },
      "EmailAddress": {
        "type": "object",
        "description": "Email address",
        "properties": {
          "Address": {
            "type": "string",
            "format": "email",
            "description": "Email address"
          }
        }
      },
      "TelephoneNumber": {
        "type": "object",
        "description": "Telephone number",
        "properties": {
          "FreeFormNumber": {
            "type": "string",
            "description": "Phone number in free-form text"
          }
        }
      },
      "WebSiteAddress": {
        "type": "object",
        "description": "Website URL",
        "properties": {
          "URI": {
            "type": "string",
            "format": "uri",
            "description": "Website URL"
          }
        }
      },
      "MemoRef": {
        "type": "object",
        "description": "User-entered message or memo",
        "properties": {
          "value": {
            "type": "string",
            "description": "The memo text"
          }
        }
      },
      "LinkedTxn": {
        "type": "object",
        "description": "Reference to a linked transaction",
        "properties": {
          "TxnId": {
            "type": "string",
            "description": "Transaction ID of the linked transaction"
          },
          "TxnType": {
            "type": "string",
            "description": "Transaction type of the linked transaction"
          }
        },
        "required": [
          "TxnId",
          "TxnType"
        ]
      },
      "CustomField": {
        "type": "object",
        "description": "Custom field value",
        "properties": {
          "DefinitionId": {
            "type": "string",
            "description": "Unique identifier of the custom field definition"
          },
          "Name": {
            "type": "string",
            "description": "Name of the custom field"
          },
          "Type": {
            "type": "string",
            "description": "Data type of the custom field",
            "enum": [
              "StringType",
              "BooleanType",
              "NumberType",
              "DateType"
            ]
          },
          "StringValue": {
            "type": "string",
            "description": "Value if the custom field type is StringType"
          }
        }
      },
      "MarkupInfo": {
        "type": "object",
        "description": "Markup information for billable expenses",
        "properties": {
          "PriceLevelRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "Percent": {
            "type": "number",
            "description": "Markup percentage"
          },
          "MarkUpIncomeAccountRef": {
            "$ref": "#/components/schemas/ReferenceType"
          }
        }
      },
      "TxnTaxDetail": {
        "type": "object",
        "description": "Tax details for a transaction",
        "properties": {
          "TxnTaxCodeRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "TotalTax": {
            "type": "number",
            "description": "Total tax amount"
          },
          "TaxLine": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Amount": {
                  "type": "number"
                },
                "DetailType": {
                  "type": "string",
                  "enum": [
                    "TaxLineDetail"
                  ]
                },
                "TaxLineDetail": {
                  "type": "object",
                  "properties": {
                    "TaxRateRef": {
                      "$ref": "#/components/schemas/ReferenceType"
                    },
                    "PercentBased": {
                      "type": "boolean"
                    },
                    "TaxPercent": {
                      "type": "number"
                    },
                    "NetAmountTaxable": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "SalesItemLineDetail": {
        "type": "object",
        "description": "Line detail for a sales item",
        "properties": {
          "ItemRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "ClassRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "UnitPrice": {
            "type": "number",
            "description": "Unit price of the item"
          },
          "Qty": {
            "type": "number",
            "description": "Quantity"
          },
          "TaxCodeRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "ServiceDate": {
            "type": "string",
            "format": "date"
          },
          "DiscountRate": {
            "type": "number"
          },
          "DiscountAmt": {
            "type": "number"
          },
          "MarkupInfo": {
            "$ref": "#/components/schemas/MarkupInfo"
          }
        }
      },
      "AccountBasedExpenseLineDetail": {
        "type": "object",
        "description": "Line detail for an account-based expense",
        "properties": {
          "AccountRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "ClassRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "TaxCodeRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "BillableStatus": {
            "type": "string",
            "enum": [
              "Billable",
              "NotBillable",
              "HasBeenBilled"
            ]
          },
          "CustomerRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "MarkupInfo": {
            "$ref": "#/components/schemas/MarkupInfo"
          }
        },
        "required": [
          "AccountRef"
        ]
      },
      "ItemBasedExpenseLineDetail": {
        "type": "object",
        "description": "Line detail for an item-based expense",
        "properties": {
          "ItemRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "ClassRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "UnitPrice": {
            "type": "number"
          },
          "Qty": {
            "type": "number"
          },
          "TaxCodeRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "BillableStatus": {
            "type": "string",
            "enum": [
              "Billable",
              "NotBillable",
              "HasBeenBilled"
            ]
          },
          "CustomerRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "MarkupInfo": {
            "$ref": "#/components/schemas/MarkupInfo"
          }
        }
      },
      "GroupLineDetail": {
        "type": "object",
        "description": "Line detail for a group of items",
        "properties": {
          "GroupItemRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "Quantity": {
            "type": "number"
          },
          "Line": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Line"
            }
          }
        }
      },
      "DescriptionOnlyLineDetail": {
        "type": "object",
        "description": "Line with description only (no amount)",
        "properties": {
          "ServiceDate": {
            "type": "string",
            "format": "date"
          },
          "TaxCodeRef": {
            "$ref": "#/components/schemas/ReferenceType"
          }
        }
      },
      "DiscountLineDetail": {
        "type": "object",
        "description": "Line detail for a discount",
        "properties": {
          "DiscountRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "PercentBased": {
            "type": "boolean"
          },
          "DiscountPercent": {
            "type": "number"
          },
          "DiscountAccountRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "ClassRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "TaxCodeRef": {
            "$ref": "#/components/schemas/ReferenceType"
          }
        }
      },
      "SubTotalLineDetail": {
        "type": "object",
        "description": "Subtotal line detail",
        "properties": {
          "ItemRef": {
            "$ref": "#/components/schemas/ReferenceType"
          }
        }
      },
      "DepositLineDetail": {
        "type": "object",
        "description": "Line detail for a deposit",
        "properties": {
          "Entity": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "ClassRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "AccountRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "PaymentMethodRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "CheckNum": {
            "type": "string"
          },
          "TxnType": {
            "type": "string"
          }
        }
      },
      "JournalEntryLineDetail": {
        "type": "object",
        "description": "Line detail for a journal entry",
        "properties": {
          "PostingType": {
            "type": "string",
            "enum": [
              "Debit",
              "Credit"
            ]
          },
          "AccountRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "ClassRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "DepartmentRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "Entity": {
            "type": "object",
            "properties": {
              "Type": {
                "type": "string",
                "enum": [
                  "Customer",
                  "Employee",
                  "Vendor"
                ]
              },
              "EntityRef": {
                "$ref": "#/components/schemas/ReferenceType"
              }
            }
          },
          "TaxCodeRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "TaxApplicableOn": {
            "type": "string"
          },
          "TaxAmount": {
            "type": "number"
          },
          "BillableStatus": {
            "type": "string",
            "enum": [
              "Billable",
              "NotBillable",
              "HasBeenBilled"
            ]
          }
        },
        "required": [
          "PostingType",
          "AccountRef"
        ]
      },
      "Line": {
        "type": "object",
        "description": "A line item in a transaction",
        "properties": {
          "Id": {
            "type": "string",
            "description": "Line item ID"
          },
          "LineNum": {
            "type": "integer",
            "description": "Line number"
          },
          "Description": {
            "type": "string",
            "description": "Line description"
          },
          "Amount": {
            "type": "number",
            "description": "Line amount"
          },
          "DetailType": {
            "type": "string",
            "description": "Type of line detail",
            "enum": [
              "SalesItemLineDetail",
              "AccountBasedExpenseLineDetail",
              "ItemBasedExpenseLineDetail",
              "GroupLineDetail",
              "DescriptionOnly",
              "DiscountLineDetail",
              "SubTotalLineDetail",
              "DepositLineDetail",
              "JournalEntryLineDetail"
            ]
          },
          "SalesItemLineDetail": {
            "$ref": "#/components/schemas/SalesItemLineDetail"
          },
          "AccountBasedExpenseLineDetail": {
            "$ref": "#/components/schemas/AccountBasedExpenseLineDetail"
          },
          "ItemBasedExpenseLineDetail": {
            "$ref": "#/components/schemas/ItemBasedExpenseLineDetail"
          },
          "GroupLineDetail": {
            "$ref": "#/components/schemas/GroupLineDetail"
          },
          "DescriptionLineDetail": {
            "$ref": "#/components/schemas/DescriptionOnlyLineDetail"
          },
          "DiscountLineDetail": {
            "$ref": "#/components/schemas/DiscountLineDetail"
          },
          "SubTotalLineDetail": {
            "$ref": "#/components/schemas/SubTotalLineDetail"
          },
          "DepositLineDetail": {
            "$ref": "#/components/schemas/DepositLineDetail"
          },
          "JournalEntryLineDetail": {
            "$ref": "#/components/schemas/JournalEntryLineDetail"
          },
          "LinkedTxn": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LinkedTxn"
            }
          }
        },
        "required": [
          "Amount",
          "DetailType"
        ]
      },
      "AttachableRef": {
        "type": "object",
        "description": "Reference to an entity that an attachable is linked to",
        "properties": {
          "EntityRef": {
            "$ref": "#/components/schemas/ReferenceType"
          },
          "IncludeOnSend": {
            "type": "boolean"
          },
          "LineInfo": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Error response from the API",
        "properties": {
          "Fault": {
            "type": "object",
            "properties": {
              "Error": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "Message": {
                      "type": "string"
                    },
                    "Detail": {
                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
                    "element": {
                      "type": "string"
                    }
                  }
                }
              },
              "type": {
                "type": "string",
                "enum": [
                  "ValidationFault",
                  "AuthenticationFault",
                  "AuthorizationFault",
                  "SystemFault"
                ]
              }
            }
          },
          "time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "QueryResponse": {
        "type": "object",
        "description": "Response from a query request",
        "properties": {
          "startPosition": {
            "type": "integer"
          },
          "maxResults": {
            "type": "integer"
          },
          "totalCount": {
            "type": "integer"
          }
        },
        "additionalProperties": true
      },
      "ReportResponse": {
        "type": "object",
        "description": "Response from a report request",
        "properties": {
          "Header": {
            "type": "object",
            "properties": {
              "Time": {
                "type": "string",
                "format": "date-time"
              },
              "ReportName": {
                "type": "string"
              },
              "ReportBasis": {
                "type": "string",
                "enum": [
                  "Accrual",
                  "Cash"
                ]
              },
              "StartPeriod": {
                "type": "string"
              },
              "EndPeriod": {
                "type": "string"
              },
              "Currency": {
                "type": "string"
              },
              "Option": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "Name": {
                      "type": "string"
                    },
                    "Value": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "Columns": {
            "type": "object",
            "properties": {
              "Column": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "ColTitle": {
                      "type": "string"
                    },
                    "ColType": {
                      "type": "string"
                    },
                    "MetaData": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Name": {
                            "type": "string"
                          },
                          "Value": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "Rows": {
            "type": "object",
            "properties": {
              "Row": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "CDCResponse": {
        "type": "object",
        "description": "Response from a Change Data Capture request",
        "properties": {
          "CDCResponse": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "QueryResponse": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QueryResponse"
                  }
                }
              }
            }
          },
          "time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BatchItemRequest": {
        "type": "object",
        "description": "A single item in a batch request",
        "properties": {
          "bId": {
            "type": "string",
            "description": "Unique identifier for the batch item"
          },
          "operation": {
            "type": "string",
            "description": "Operation to perform",
            "enum": [
              "create",
              "update",
              "delete",
              "query"
            ]
          },
          "Query": {
            "type": "string",
            "description": "SQL-like query string (for query operation)"
          }
        },
        "additionalProperties": true,
        "required": [
          "bId"
        ]
      },
      "BatchRequest": {
        "type": "object",
        "properties": {
          "BatchItemRequest": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BatchItemRequest"
            },
            "maxItems": 30,
            "description": "Array of batch request items (max 30)"
          }
        },
        "required": [
          "BatchItemRequest"
        ]
      },
      "BatchResponse": {
        "type": "object",
        "properties": {
          "BatchItemResponse": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "bId": {
                  "type": "string"
                },
                "Fault": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          },
          "time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Account": {
        "type": "object",
        "description": "A financial account in QuickBooks (bank, credit card, income, expense, etc.)",
        "properties": {
          "Id": {
            "type": "string",
            "description": "Unique identifier for the entity",
            "readOnly": true
          },
          "SyncToken": {
            "type": "string",
