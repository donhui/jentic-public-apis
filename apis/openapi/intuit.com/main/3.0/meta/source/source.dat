    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authorization code flow for QuickBooks Online",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://appcenter.intuit.com/connect/oauth2",
            "tokenUrl": "https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer",
            "refreshUrl": "https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer",
            "scopes": {
              "com.intuit.quickbooks.accounting": "Access QuickBooks Online Accounting data",
              "com.intuit.quickbooks.payment": "Access QuickBooks Online Payments data"
            }
          }
        }
      }
    },
    "parameters": {
      "minorversion": {
        "name": "minorversion",
        "in": "query",
        "description": "Minor version of the API. Use this to access new features or fields. Current minor version is 73.",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 73
        }
      }
    }
  },
