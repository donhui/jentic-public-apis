    "/query": {
      "get": {
        "tags": [
          "Query"
        ],
        "summary": "Query entities using SQL-like syntax",
        "description": "Executes a SQL-like query against QuickBooks Online entities. Supports SELECT, WHERE, ORDER BY, STARTPOSITION, and MAXRESULTS clauses. Example: SELECT * FROM Invoice WHERE TotalAmt > '100.00' ORDERBY TxnDate STARTPOSITION 1 MAXRESULTS 10. Queryable entities include: Account, Attachable, Bill, BillPayment, Budget, Class, CompanyInfo, CreditMemo, Customer, Department, Deposit, Employee, Estimate, ExchangeRate, Invoice, Item, JournalEntry, Payment, PaymentMethod, Preferences, Purchase, PurchaseOrder, RefundReceipt, SalesReceipt, TaxAgency, TaxCode, TaxRate, Term, TimeActivity, Transfer, Vendor, VendorCredit.",
        "operationId": "queryEntities",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "SQL-like query string. Example: SELECT * FROM Customer WHERE DisplayName LIKE '%Smith%'",
            "schema": {
              "type": "string"
            },
            "example": "SELECT * FROM Invoice WHERE TotalAmt > '100.00'"
          },
          {
            "$ref": "#/components/parameters/minorversion"
          }
        ],
        "responses": {
          "200": {
            "description": "Query executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "QueryResponse": {
                      "$ref": "#/components/schemas/QueryResponse"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input or business validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or expired OAuth 2.0 token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Entity does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
