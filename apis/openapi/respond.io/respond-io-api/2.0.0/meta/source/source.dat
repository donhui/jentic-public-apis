    "/space/user": {
      "get": {
        "summary": "List users",
        "operationId": "listSpaces",
        "description": "Get a list of users in your workspace.\n\nUsers with pending invitations are not included in the response.",
        "tags": [
          "Space"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Number of items to return i.e. page size.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "exclusiveMaximum": 100,
              "default": 10
            }
          },
          {
            "name": "cursorId",
            "in": "query",
            "description": "Pointer to the contact `id` from where the next batch of records should start from.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "User ID.",
                            "examples": [
                              123
                            ]
                          },
                          "firstName": {
                            "type": "string",
                            "examples": [
                              "John"
                            ]
                          },
                          "lastName": {
                            "type": "string",
                            "examples": [
                              "Wick"
                            ]
                          },
                          "email": {
                            "type": "string",
                            "examples": [
                              "test@example.com"
                            ]
                          },
                          "role": {
                            "type": "string",
                            "enum": [
                              "agent",
                              "manager",
                              "owner"
                            ],
                            "description": "User **role** in the workspace.",
                            "examples": [
                              "owner"
                            ]
                          },
                          "team": {
                            "type": [
                              "object",
                              "null"
                            ],
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "ID of the team.",
                                "examples": [
                                  123
                                ]
                              },
                              "name": {
                                "type": "string",
                                "description": "Name of the team.",
                                "examples": [
                                  "Customer Support"
                                ]
                              }
                            }
                          },
                          "restrictions": {
                            "type": "array",
                            "description": "Constants representing the user restrictions at the workspace-level.",
                            "anyOf": [
                              {
                                "type": "array",
                                "uniqueItems": true,
                                "items": {
                                  "type": "string",
                                  "enum": [
                                    "restrict_data_export",
                                    "restrict_contact_deletion",
                                    "restrict_space_setting",
                                    "show_team_contacts",
                                    "show_only_mine",
                                    "restrict_space_integration",
                                    "restrict_shortcuts"
                                  ],
                                  "examples": [
                                    "show_only_mine"
                                  ]
                                }
                              }
                            ]
                          }
                        },
                        "required": [
                          "id",
                          "firstName",
                          "lastName",
                          "email",
                          "role",
                          "team",
                          "restrictions"
                        ]
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "next": {
                          "type": "string",
                          "examples": [
                            "https://api.respond.io/space/user?limit=10&cursorId=10"
                          ]
                        },
                        "previous": {
                          "type": "string",
                          "examples": [
                            "https://api.respond.io/space/user?limit=10&cursorId=-10"
                          ]
                        }
                      },
                      "required": [
                        "next",
                        "previous"
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        400
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "Validation error."
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        401
                      ]
                    },
