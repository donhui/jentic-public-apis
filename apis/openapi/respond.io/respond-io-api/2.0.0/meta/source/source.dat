    "/space/user/{id}": {
      "get": {
        "summary": "Get a user",
        "operationId": "getUser",
        "description": "Retrieve information about a user.",
        "tags": [
          "Space"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "User ID.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "User ID.",
                      "examples": [
                        123
                      ]
                    },
                    "firstName": {
                      "type": "string",
                      "examples": [
                        "John"
                      ]
                    },
                    "lastName": {
                      "type": "string",
                      "examples": [
                        "Wick"
                      ]
                    },
                    "email": {
                      "type": "string",
                      "examples": [
                        "test@example.com"
                      ]
                    },
                    "role": {
                      "type": "string",
                      "enum": [
                        "agent",
                        "manager",
                        "owner"
                      ],
                      "description": "User **role** in the workspace.",
                      "examples": [
                        "owner"
                      ]
                    },
                    "team": {
                      "type": [
                        "object",
                        "null"
                      ],
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "ID of the team.",
                          "examples": [
                            123
                          ]
                        },
                        "name": {
                          "type": "string",
                          "description": "Name of the team.",
                          "examples": [
                            "Customer Support"
                          ]
                        }
                      }
                    },
                    "restrictions": {
                      "type": "array",
                      "description": "Constants representing the user restrictions at the workspace-level.",
                      "anyOf": [
                        {
                          "type": "array",
                          "uniqueItems": true,
                          "items": {
                            "type": "string",
                            "enum": [
                              "restrict_data_export",
                              "restrict_contact_deletion",
                              "restrict_space_setting",
                              "show_team_contacts",
                              "show_only_mine",
                              "restrict_space_integration",
                              "restrict_shortcuts"
                            ],
                            "examples": [
                              "show_only_mine"
                            ]
                          }
                        }
                      ]
                    }
                  },
                  "required": [
                    "id",
                    "firstName",
                    "lastName",
                    "email",
                    "role",
                    "team",
                    "restrictions"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
