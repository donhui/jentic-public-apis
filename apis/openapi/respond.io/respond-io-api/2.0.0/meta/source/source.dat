                                                    ]
                                                  }
                                                },
                                                "required": [
                                                  "link",
                                                  "caption",
                                                  "filename"
                                                ]
                                              }
                                            },
                                            "required": [
                                              "type",
                                              "image"
                                            ]
                                          }
                                        }
                                      },
                                      "required": [
                                        "parameters"
                                      ],
                                      "x-examples": {
                                        "Example 1": {
                                          "type": "header",
                                          "format": "image",
                                          "parameters": [
                                            {
                                              "type": "image",
                                              "image": {
                                                "link": "https://cdn.chatapi.net",
