        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "messageId": {
                      "type": "integer",
                      "description": "The id of the message so that you can track it later"
                    }
                  },
                  "required": [
                    "messageId"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        400
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "Validation error."
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        401
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "UN_AUTHORIZED"
                      ]
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "headers": {
              "Retry-After": {
                "description": "Number of seconds until you can retry the request",
                "schema": {
                  "type": "number",
                  "examples": [
                    1
                  ]
                }
              },
              "X-RateLimit-Limit": {
                "description": "Number of request allowed for this end point",
                "schema": {
                  "type": "number",
                  "examples": [
                    10
                  ]
                }
              },
              "X-RateLimit-Remaining": {
                "description": "Number of request remaining for this end point",
                "schema": {
                  "type": "number",
                  "examples": [
                    5
                  ]
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        429
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "Too Many Requests"
                      ]
                    }
                  }
                }
              }
            }
          },
          "449": {
            "description": "Request queued, try again later",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        449
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "Your request cannot be processed at the moment as it is currently in queue. Please try again in a few minutes."
                      ]
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        500
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "Unexpected error occurred"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/contact/{identifier}/message/list": {
      "get": {
        "summary": "List Messages",
        "operationId": "listMessages",
        "description": "List all messages of a specific contact.",
        "tags": [
          "Messaging"
        ],
        "parameters": [
          {
            "name": "identifier",
            "in": "path",
            "description": "Identifier of the contact that can either be a phone number, email or contact ID. Examples: ``id:123`` , ``email:abdc@gmail.com`` , ``phone:+60121233112``",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of messages to return i.e. page size.",
            "schema": {
              "type": "integer",
              "maximum": 50
            }
          },
          {
            "name": "cursorId",
            "in": "query",
            "description": "Pointer to the message `id` from where the next batch of records should start from.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "messageId": {
                            "type": "integer",
                            "description": "Unique ID of the message",
                            "examples": [
                              1262965213
                            ]
                          },
                          "channelMessageId": {
                            "examples": [
                              123
                            ],
                            "oneOf": [
                              {
                                "type": "string"
                              },
                              {
                                "type": "integer"
                              }
                            ]
                          },
                          "contactId": {
                            "type": "integer",
                            "description": "ID of the contact to which the message was sent.",
                            "examples": [
                              123
                            ]
                          },
                          "channelId": {
                            "type": "integer",
                            "examples": [
                              123
                            ]
                          },
                          "traffic": {
                            "type": "string",
                            "enum": [
