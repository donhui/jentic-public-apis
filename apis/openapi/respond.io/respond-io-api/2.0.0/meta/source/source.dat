            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of items to return i.e. page size.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "exclusiveMaximum": 100,
              "default": 10
            }
          },
          {
            "name": "cursorId",
            "in": "query",
            "description": "Pointer to the template `id` from where the next batch of records should start from.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "title": "MessageTemplate",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "examples": [
                              12345
                            ]
                          },
                          "name": {
                            "type": "string",
                            "examples": [
                              "conversation_follow_up"
                            ]
                          },
                          "components": {
                            "type": "array",
                            "items": {
                              "anyOf": [
                                {
                                  "type": "object",
                                  "anyOf": [
                                    {
                                      "type": "object",
                                      "properties": {
                                        "type": {
                                          "const": "header",
                                          "examples": [
                                            "header"
                                          ]
                                        },
                                        "format": {
                                          "const": "text",
                                          "examples": [
                                            "text"
                                          ]
                                        },
                                        "text": {
                                          "type": "string",
                                          "examples": [
                                            "Header text"
                                          ]
                                        },
                                        "parameters": {
                                          "type": "array",
                                          "items": {
                                            "type": "object",
                                            "properties": {
                                              "type": {
                                                "type": "string",
                                                "examples": [
                                                  "text"
                                                ]
                                              },
                                              "text": {
                                                "type": "string",
                                                "examples": [
                                                  "respond.io"
                                                ]
                                              }
                                            },
                                            "required": [
                                              "type",
                                              "text"
                                            ]
                                          }
                                        }
                                      },
                                      "required": [
                                        "type",
                                        "text",
                                        "parameters"
                                      ]
                                    },
                                    {
                                      "type": "object",
                                      "properties": {
                                        "type": {
                                          "const": "header",
                                          "examples": [
                                            "header"
                                          ]
                                        },
                                        "format": {
                                          "const": "image",
                                          "examples": [
                                            "image"
                                          ]
                                        },
                                        "parameters": {
                                          "type": "array",
                                          "items": {
                                            "type": "object",
                                            "properties": {
                                              "type": {
                                                "const": "image",
                                                "examples": [
                                                  "image"
                                                ]
                                              },
                                              "image": {
                                                "type": "object",
                                                "properties": {
                                                  "link": {
                                                    "type": "string",
                                                    "examples": [
                                                      "https://picsum.photos"
                                                    ]
                                                  },
                                                  "caption": {
                                                    "type": "string",
                                                    "examples": [
                                                      "image caption"
                                                    ]
                                                  },
                                                  "filename": {
                                                    "type": "string",
                                                    "examples": [
