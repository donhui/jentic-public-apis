    "/contact/{identifier}/channels": {
      "get": {
        "summary": "List contact channels",
        "operationId": "listChannels",
        "description": "List all connected channel of a specific contact.",
        "tags": [
          "Contact"
        ],
        "parameters": [
          {
            "name": "identifier",
            "in": "path",
            "description": "Identifier of the contact that can either be a phone number, email or contact ID. Examples: ``id:123`` , ``email:abdc@gmail.com`` , ``phone:+60121233112``",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "identifier",
            "in": "path",
            "description": "Identifier of the contact that can either be a phone number, email or contact ID. Examples: ``id:123`` , ``email:abdc@gmail.com`` , ``phone:+60121233112``",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of contacts to return i.e. page size.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "exclusiveMaximum": 100,
              "default": 10
            }
          },
          {
            "name": "cursorId",
            "in": "query",
            "description": "Pointer to the contact `id` from where the next batch of records should start from.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "Channel ID.",
                            "minimum": 1,
                            "examples": [
                              12345
                            ]
                          },
                          "name": {
                            "type": "string",
                            "description": "Channel name."
                          },
                          "source": {
                            "type": "string",
                            "enum": [
                              "facebook",
                              "instagram",
                              "line",
                              "telegram",
                              "viber",
                              "twitter",
                              "wechat",
                              "custom_channel",
                              "gmail",
                              "other_email",
                              "twillio",
                              "message_bird",
                              "nexmo",
                              "360dialog_whatsapp",
                              "twilio_whatsapp",
                              "message_bird_whatsapp",
                              "whatsapp",
                              "nexmo_whatsapp",
                              "whatsapp_cloud"
                            ],
                            "description": "Type of the channel"
                          },
                          "meta": {
                            "type": "object",
                            "description": "Additional details of the contact as provided by the channel. This will vary across channels."
                          },
                          "lastMessageTime": {
                            "type": "integer",
                            "description": "Unix timestamp of the last messag received/sent (in seconds)."
                          },
                          "lastIncomingMessageTime": {
                            "type": "integer",
                            "description": "Unix timestamp of the last incoming message (in seconds)."
                          },
                          "created_at": {
                            "type": "integer",
                            "description": "Unix timestamp of the channel creation (in seconds)."
                          }
                        }
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "next": {
                          "type": "string",
                          "examples": [
                            "https://api.respond.io/contact/{identifier}/channels?limit=10&cursorId=10"
                          ]
                        },
                        "previous": {
                          "type": "string",
                          "examples": [
                            "https://api.respond.io/contact/{identifier}/channels?limit=10&cursorId=-10"
                          ]
                        }
                      },
                      "required": [
                        "next",
                        "previous"
                      ]
                    }
                  },
                  "required": [
                    "items",
                    "pagination"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
