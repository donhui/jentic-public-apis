            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "open",
                      "close"
                    ],
                    "description": "Status of the conversation which can either be `open` or `close`"
                  },
                  "category": {
                    "type": "string",
                    "description": "Optionally provide the **closing note** name.",
                    "maxLength": 128
                  },
                  "summary": {
                    "type": "string",
                    "description": "Optionally provide a **summary**. Only used if the `category` is specified.",
                    "maxLength": 512
                  }
                },
                "required": [
                  "status"
                ]
              },
              "example": {
                "status": "open"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contactId": {
                      "type": "integer",
                      "description": "ID of the contact on which the action was performed."
