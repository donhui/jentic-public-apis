      "post": {
        "summary": "Create a contact",
        "operationId": "createContact",
        "description": "Creates a new contact. It is highly recommended to add a delay before executing a new action after creating a new contact, as processing time is required.",
        "tags": [
          "Contact"
        ],
        "parameters": [
          {
            "name": "identifier",
            "in": "path",
            "description": "Identifier of the contact that can either be a phone number, email or contact ID. Examples: ``email:abdc@gmail.com`` , ``phone:+60121233112``",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "allOf": [
                  {
                    "type": "object",
                    "anyOf": [
                      {
                        "type": "object",
                        "properties": {
                          "firstName": {
                            "type": "string",
                            "examples": [
                              "Muhammad "
                            ]
                          },
                          "lastName": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "examples": [
                              "Mahin"
                            ]
                          },
                          "phone": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "examples": [
                              "+60123456789"
                            ]
                          },
                          "email": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "examples": [
                              "test@example.com"
                            ]
                          },
                          "language": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Following the [ISO 639-1](https://en.wikipedia.org/wiki/List_of_ISO_639-1_codes) standard.",
                            "examples": [
                              "ms"
                            ]
                          },
                          "profilePic": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "examples": [
                              "https://cdn.respond.io/profile_avatar.png"
                            ]
                          },
                          "countryCode": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "Following the [ISO 3166-1 alpha-2](https://www.wikiwand.com/en/ISO_3166-1_alpha-2) standard.",
                            "examples": [
                              "MY"
                            ]
                          },
                          "custom_fields": {
                            "type": [
                              "array",
                              "null"
                            ],
                            "items": {
                              "type": "object",
                              "properties": {
                                "name": {
                                  "type": "string",
                                  "examples": [
                                    "Company Website"
                                  ]
                                },
                                "value": {
                                  "type": [
                                    "string",
                                    "null"
                                  ],
                                  "description": "Formatting rules\n\n- Text: \"string\" (use quotation marks for the string value)\n- Number: Number (without any quotation marks)\n- Email: \"email\" (format: user@domain.com)\n- URL: \"url\" (format: www.website.com, https://www.website.com, website.com, http://website.com)\n- List: \"string\" (the string value must match one of the list options)\n- Date: \"yyyy-mm-dd\" (must follow this format)\n- Time: \"HH:MM\" (must follow 24H format, 1PM => 13:00)\n- Checkbox: \"true/false\" (must be true for checked, false for unchecked)",
                                  "examples": [
                                    "https://example.com"
                                  ]
                                }
                              },
                              "required": [
                                "name"
                              ]
                            }
                          }
                        },
                        "required": [
                          "firstName"
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "examples": [
                        "200"
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "Contact added successfully!"
                      ]
                    }
                  },
                  "required": [
                    "code",
                    "message"
                  ]
                }
              }
            }
          },
          "400": {
