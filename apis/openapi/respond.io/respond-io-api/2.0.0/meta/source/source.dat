    "/space/custom_field": {
      "get": {
        "summary": "List custom fields",
        "operationId": "listContactFields",
        "description": "Get a list of all the custom fields in the workspace.",
        "tags": [
          "Space"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Number of items to return i.e. page size.",
