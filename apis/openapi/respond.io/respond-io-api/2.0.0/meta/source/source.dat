    "/space/channel": {
      "get": {
        "summary": "List channels",
        "operationId": "listChannels",
        "description": "Get all the messaging channels connected in the workspace.",
        "tags": [
          "Space"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Number of items to return i.e. page size.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "exclusiveMaximum": 100,
              "default": 10
            }
          },
          {
            "name": "cursorId",
            "in": "query",
            "description": "Pointer to the contact `id` from where the next batch of records should start from.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "examples": [
                              12345
                            ]
                          },
                          "name": {
                            "type": "string",
                            "description": "Channel name"
                          },
                          "source": {
                            "type": "string",
                            "enum": [
                              "facebook",
                              "instagram",
                              "line",
                              "telegram",
                              "viber",
                              "twitter",
                              "wechat",
                              "custom_channel",
                              "gmail",
                              "other_email",
                              "twilio",
                              "message_bird",
                              "nexmo",
                              "360dialog_whatsapp",
                              "twilio_whatsapp",
                              "message_bird_whatsapp",
                              "whatsapp",
                              "nexmo_whatsapp",
                              "whatsapp_cloud"
                            ],
                            "description": "Type of the channel"
                          },
                          "created_at": {
                            "type": "integer",
                            "description": "Unix timestamp of the channel creation time (in seconds)."
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "source",
                          "created_at"
                        ]
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "next": {
                          "type": "string",
                          "examples": [
                            "https://api.respond.io/space/channel?limit=10&cursorId=10"
                          ]
                        },
                        "previous": {
                          "type": "string",
                          "examples": [
                            "https://api.respond.io/space/channellimit=10&cursorId=-10"
                          ]
                        }
                      },
                      "required": [
                        "next",
                        "previous"
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        400
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "Validation error."
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "examples": [
                        401
                      ]
                    },
                    "message": {
                      "type": "string",
                      "examples": [
                        "UN_AUTHORIZED"
                      ]
                    }
                  }
                }
