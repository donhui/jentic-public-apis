      "post": {
        "summary": "Create custom field",
        "operationId": "createCustomField",
        "description": "Create a new custom field",
        "tags": [
          "Space"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "maxLength": 50,
                    "examples": [
                      "customer id"
                    ]
                  },
                  "slug": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "The unique identifier for API and integrations. Field ID cannot be edited once added. Only letters, numbers, and underscores are allowed for this field.",
                    "maxLength": 50,
                    "examples": [
                      "customer_id"
                    ]
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 255,
                    "examples": [
                      "This is for storing customer ID"
                    ]
                  },
                  "dataType": {
                    "type": "string",
                    "enum": [
                      "text",
                      "list",
                      "checkbox",
                      "email",
                      "number",
                      "url",
                      "date",
                      "time"
                    ],
                    "examples": [
                      "number"
                    ]
                  },
                  "allowedValues": {
                    "type": [
                      "array",
                      "null"
                    ],
                    "description": "Only to be provided when the value of `dataType` is `list`",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "name",
                  "dataType"
                ]
              },
              "example": {
                "name": "notes",
                "description": "The internal notes about this customer",
                "dataType": "text"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Custom field ID.",
                      "examples": [
                        123
                      ]
                    },
                    "name": {
                      "type": "string",
                      "description": "Name of the custom field.",
                      "examples": [
                        "customer_id"
                      ]
                    },
                    "description": {
                      "type": "string",
                      "examples": [
                        "Customer ID"
                      ]
                    },
                    "dataType": {
                      "type": "string",
                      "enum": [
                        "text",
                        "list",
                        "checkbox",
