    "/space/closing_notes": {
      "get": {
        "summary": "List Closing Notes",
        "operationId": "listClosingNotes",
        "description": "Get a list of all the closing notes in the workspace.\n\nThe response is sorted by category.",
        "tags": [
          "Space"
