                        "type": "object",
                        "properties": {
                          "category": {
                            "type": "string",
                            "description": "The name of category you have created.",
                            "examples": [
                              "Order Issue"
                            ]
                          },
                          "description": {
                            "type": "string",
                            "examples": [
