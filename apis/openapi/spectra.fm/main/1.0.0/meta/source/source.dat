{
  "openapi": "3.0.3",
  "info": {
    "title": "spectra.fm API",
    "description": "Async export API for spectra.fm. spectra.fm is an AI-powered visual system that turns intent into consistent, production-ready visuals. All endpoints are under /v1. Use objectKey + downloadUrl to retrieve export artifacts.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.spectra.fm/docs"
  },
  "servers": [
    {
      "url": "https://api.spectra.fm",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication and API key validation"
    },
    {
      "name": "Projects",
      "description": "Project management"
    },
    {
      "name": "Project Details",
      "description": "Project layout, templates, assets, locales, themes, and content variables"
    },
    {
      "name": "History",
      "description": "Project version history and snapshots"
    },
    {
      "name": "Exports",
      "description": "Export jobs and artifact management"
    }
  ],
  "paths": {
    "/v1/whoami": {
      "get": {
        "operationId": "getWhoami",
        "summary": "Validate API key",
        "description": "Validate API key and return key metadata including user, service, and rate limit information.",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "API key is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WhoamiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "API key disabled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "description": "List projects, optionally filtered by team ID.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "teamId",
            "in": "query",
            "description": "Filter projects by team ID",
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{projectId}": {
      "get": {
        "operationId": "getProject",
        "summary": "Get a project",
        "description": "Retrieve a specific project by ID.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Project not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{projectId}/layout": {
      "get": {
        "operationId": "getProjectLayout",
        "summary": "Get project layout",
        "description": "Get project layout including canvas dimensions and frames.",
        "tags": ["Project Details"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project layout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Layout"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Project not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{projectId}/template": {
      "get": {
        "operationId": "getProjectTemplate",
        "summary": "Get project HTML template",
        "description": "Get project HTML template with optional CSS variables, locales, themes, and content overrides.",
        "tags": ["Project Details"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeCssVariables",
            "in": "query",
            "description": "Include CSS variables in the response",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeLocales",
            "in": "query",
            "description": "Include locale data in the response",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeThemes",
            "in": "query",
            "description": "Include theme data in the response",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeContentOverrides",
            "in": "query",
            "description": "Include content overrides in the response",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project template",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Template"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Project not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{projectId}/assets": {
      "get": {
        "operationId": "listProjectAssets",
        "summary": "List project assets",
        "description": "List assets for a project with optional filtering.",
        "tags": ["Project Details"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mimeTypeFilter",
            "in": "query",
            "description": "Filter by MIME type",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filenameSearch",
            "in": "query",
            "description": "Search by filename",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of assets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Asset"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Project not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{projectId}/assets/{assetId}/content": {
      "get": {
        "operationId": "getAssetContent",
        "summary": "Get asset content",
        "description": "Fetch text content of a specific asset.",
        "tags": ["Project Details"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "assetId",
            "in": "path",
            "required": true,
            "description": "Asset ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Asset content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetContent"
                }
              }
            }
          },
          "400": {
            "description": "Asset content not readable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Asset not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
