    "/v1/projects/{projectId}/history": {
      "get": {
        "operationId": "listProjectHistory",
        "summary": "List project snapshots",
        "description": "List version history snapshots for a project.",
        "tags": ["History"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of snapshots to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeAutoSnapshots",
            "in": "query",
            "description": "Include auto-generated snapshots",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of snapshots",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Snapshot"
                  }
                }
              }
