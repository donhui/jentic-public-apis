    "/v1/projects/{projectId}/exports/download": {
      "get": {
        "operationId": "downloadExportArtifact",
        "summary": "Download export artifact",
        "description": "Download a specific export artifact by object key.",
        "tags": ["Exports"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "objectKey",
            "in": "query",
            "required": true,
            "description": "R2 object key for the artifact",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filename",
            "in": "query",
            "description": "Optional filename for the download",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Binary download of the artifact",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid object key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Export artifact not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Fetch failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{projectId}/exports/{exportId}": {
      "get": {
        "operationId": "getExportStatus",
        "summary": "Get export status",
        "description": "Get the status of an export job.",
        "tags": ["Exports"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exportId",
            "in": "path",
            "required": true,
            "description": "Export ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Export details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Export"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Export not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/projects/{projectId}/exports/{exportId}/artifacts": {
      "get": {
        "operationId": "listExportArtifacts",
        "summary": "List export artifacts",
        "description": "List artifacts generated by an export job.",
        "tags": ["Exports"],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "description": "Project ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exportId",
            "in": "path",
            "required": true,
            "description": "Export ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Export artifacts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Export not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication. Use X-API-Key header or Authorization: Bearer <key>. Get yours at app.spectra.fm/settings/api-keys"
      }
    },
    "schemas": {
      "WhoamiResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          },
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              }
            }
          },
          "key": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "enabled": {
                "type": "boolean"
              },
              "permissions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time",
                "nullable": true
              },
              "rateLimit": {
                "type": "object",
                "properties": {
                  "limit": {
                    "type": "integer"
                  },
                  "remaining": {
                    "type": "integer"
                  },
                  "reset": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "organizationId": {
            "type": "string"
          },
          "teamId": {
            "type": "string"
          },
          "ownerId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Layout": {
        "type": "object",
        "properties": {
          "sourcePresetId": {
            "type": "string"
          },
          "layoutType": {
            "type": "string",
            "enum": ["horizontal", "vertical", "grid", "custom"]
          },
          "gridColumns": {
            "type": "integer"
          },
          "canvas": {
            "type": "object",
            "properties": {
              "width": {
                "type": "integer"
              },
              "height": {
                "type": "integer"
              }
            }
          },
          "frames": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "html": {
            "type": "string"
          },
          "cssVariables": {
            "type": "object"
          },
          "locales": {
            "type": "object",
            "properties": {
              "defaultLocale": {
                "type": "string"
              },
              "entries": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          },
          "themes": {
            "type": "object",
            "properties": {
              "defaultTheme": {
                "type": "string"
              },
              "entries": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          },
          "contentOverrides": {
            "type": "object"
          }
        }
      },
      "Asset": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          },
          "byteSize": {
            "type": "integer"
          },
          "checksum": {
            "type": "string"
          },
          "uploadedById": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object"
          },
          "contentPath": {
            "type": "string"
          },
          "contentUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "AssetContent": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          }
        }
      },
      "LocalesResponse": {
        "type": "object",
        "properties": {
          "locales": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Locale"
            }
          },
          "primaryLocale": {
            "type": "string"
          }
        }
      },
      "Locale": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "isDefault": {
            "type": "boolean"
          }
        }
      },
      "ThemesResponse": {
        "type": "object",
        "properties": {
          "themes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Theme"
            }
          },
          "primaryTheme": {
            "type": "string"
          }
        }
      },
      "Theme": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "isDefault": {
            "type": "boolean"
          }
        }
      },
      "ContentVariablesResponse": {
        "type": "object",
        "properties": {
          "contentVariables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "defaultValue": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Snapshot": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "createdById": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object"
          }
        }
      },
      "CreateExportRequest": {
        "type": "object",
        "properties": {
          "combinations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "locale": {
                  "type": "string"
                },
                "theme": {
                  "type": "string"
                }
              }
            }
          },
          "contentVariations": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "version": {
            "oneOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "enum": ["latest"]
              }
            ],
            "description": "Project version to export, or 'latest'"
          }
        }
      },
      "ExportJob": {
        "type": "object",
        "properties": {
          "exportId": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "processing", "completed", "failed"]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "statusUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Export": {
        "type": "object",
        "properties": {
          "exportId": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "processing", "completed", "failed"]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "completedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "variantCount": {
            "type": "integer"
          },
          "zip": {
            "type": "object",
            "nullable": true
          },
          "locales": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "themes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hasContentVariations": {
            "type": "boolean"
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ExportOptions": {
        "type": "object",
        "properties": {
          "locales": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Locale"
            }
          },
          "themes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Theme"
            }
          },
          "contentVariables": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "defaultValue": {
                  "type": "string"
                }
              }
            }
          },
          "primaryLocale": {
            "type": "string"
          },
          "primaryTheme": {
            "type": "string"
          }
        }
      },
      "ArtifactsResponse": {
        "type": "object",
        "properties": {
          "exportId": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Artifact"
            }
          }
        }
      },
      "Artifact": {
        "type": "object",
        "properties": {
          "objectKey": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "uploaded": {
            "type": "boolean"
          },
          "filename": {
            "type": "string"
          },
          "downloadUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}