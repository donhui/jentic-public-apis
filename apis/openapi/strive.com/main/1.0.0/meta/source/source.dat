{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "Strive.asia",
      "url": "https://virtserver.swaggerhub.com/2432/strive.asia/1.0.0"
    }
  ],
  "info": {
    "description": "This is the list of API for Strive",
    "version": "1.0.0",
    "title": "Strive APIs",
    "contact": {
      "email": "brandon@strive.asia"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://app.swaggerhub.com/apis-docs/2432/strive.asia/1.0.0"
  },
  "tags": [
    {
      "name": "admins",
      "description": "Secured Admin-only calls"
    },
    {
      "name": "developers",
      "description": "Operations available to regular developers"
    }
  ],
  "paths": {
    "/zapier_addContact": {
      "post": {
        "tags": [
          "developers"
        ],
        "summary": "Add a new contact using Zapier automation",
        "operationId": "create_contact",
        "description": "Creating a contact using Zapier action",
        "parameters": [
          {
            "in": "query",
            "name": "first_name",
            "description": "The contact's first name",
            "required": true,
            "schema": {
              "type": "string",
              "format": "first_name"
            }
          },
          {
            "in": "query",
            "name": "last_name",
            "description": "The contact's first name",
            "schema": {
              "type": "string",
              "format": "last_name"
            }
          },
          {
            "in": "query",
            "name": "email",
            "description": "The contact's email address",
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "in": "query",
            "name": "contact",
            "description": "The contact's phone number",
            "schema": {
              "type": "string",
              "format": "contact"
            }
          },
          {
            "in": "query",
            "name": "country_code",
            "description": "The contact's phone country code",
            "schema": {
              "type": "string",
              "format": "country_code"
            }
          },
          {
            "in": "query",
            "name": "dob",
            "description": "The contact's date of birth",
            "schema": {
              "type": "string",
              "format": "dob"
            }
          },
          {
            "in": "query",
            "name": "email2",
            "description": "The Strive user's email address",
            "schema": {
              "type": "string",
              "format": "email2"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Contact added successfully"
          },
          "400": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/zapier_getContact": {
      "post": {
        "tags": [
          "developers"
        ],
        "summary": "Retrieve newly added contact from Strive platform",
        "operationId": "get_contact",
        "description": "Retrieve a contact using Zapier action",
        "parameters": [
          {
            "in": "query",
            "name": "email2",
            "description": "The Strive user's email address",
            "schema": {
              "type": "string",
              "format": "email2"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Contact fetched successfully"
          },
          "400": {
            "description": "Not authorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Contact"
              }
            }
          },
          "description": "Inventory item to add"
        }
      }
    },
    "/zapier_addProduct": {
      "post": {
        "tags": [
          "developers"
        ],
        "summary": "Add a new contact using Zapier automation",
        "operationId": "add_product",
        "description": "Creating a product using Zapier action",
        "parameters": [
          {
            "in": "query",
            "name": "title",
            "description": "The product's title",
            "required": true,
            "schema": {
              "type": "string",
              "format": "title"
            }
          },
          {
            "in": "query",
            "name": "short_description",
            "description": "The product's short description",
            "schema": {
              "type": "string",
              "format": "short_description"
            }
          },
          {
            "in": "query",
            "name": "detail_description",
            "description": "The product's detailed description",
            "schema": {
              "type": "string",
              "format": "detail_description"
            }
          },
          {
            "in": "query",
            "name": "usage_duration",
            "description": "The product's usage duration",
            "schema": {
              "type": "integer",
              "format": "usage_duration"
            }
          },
          {
            "in": "query",
            "name": "price",
            "description": "The product's price",
            "schema": {
              "type": "integer",
              "format": "price"
            }
          },
          {
            "in": "query",
            "name": "commission",
            "description": "The product's commission",
            "schema": {
              "type": "string",
              "format": "commission"
            }
          },
          {
            "in": "query",
            "name": "email2",
            "description": "The Strive user's email address",
            "schema": {
              "type": "string",
              "format": "email2"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Product added successfully"
          },
          "400": {
            "description": "Not authorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Contact"
              }
            }
          },
          "description": "Inventory item to add"
        }
      }
    },
    "/zapier_getProduct": {
      "post": {
        "tags": [
          "developers"
        ],
        "summary": "Retrieve newly added product from Strive platform",
        "operationId": "get_product",
        "description": "Retrieve a product using Zapier action",
        "parameters": [
          {
            "in": "query",
            "name": "email2",
            "description": "The Strive user's email address",
            "schema": {
              "type": "string",
              "format": "email2"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Product fetched successfully"
          },
          "400": {
            "description": "Not authorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Product"
              }
            }
          },
          "description": "Inventory item to add"
        }
      }
    },
    "/zapier_addDeal": {
      "post": {
        "tags": [
          "developers"
        ],
        "summary": "Add a new deal using Zapier automation",
        "operationId": "add_deal",
        "description": "Creating a deal using Zapier action",
        "parameters": [
          {
            "in": "query",
            "name": "deal_name",
            "description": "The deal's name",
            "required": true,
            "schema": {
              "type": "string",
              "format": "deal_name"
            }
          },
          {
            "in": "query",
            "name": "board_name",
            "description": "The deal's board id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "board_name"
            }
          },
          {
            "in": "query",
            "name": "stage_id",
            "description": "The deal's stage id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "stage_id"
            }
          },
          {
            "in": "query",
            "name": "deal_cost",
            "description": "The deal's cost/value",
            "schema": {
              "type": "integer",
              "format": "deal_cost"
            }
          },
          {
            "in": "query",
            "name": "email2",
            "description": "The Strive user's email address",
            "schema": {
              "type": "string",
              "format": "email2"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Deal added successfully"
          },
          "400": {
            "description": "Not authorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Deal"
              }
            }
          },
          "description": "Inventory item to add"
        }
      }
    },
    "/zapier_getDeal": {
      "post": {
        "tags": [
          "developers"
        ],
        "summary": "Retrieve newly added product from Strive platform",
        "operationId": "get_deal",
        "description": "Retrieve a deal using Zapier action",
        "parameters": [
          {
            "in": "query",
            "name": "email2",
            "description": "The Strive user's email address",
            "schema": {
              "type": "string",
              "format": "email2"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Deal fetched successfully"
          },
          "400": {
            "description": "Not authorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Deal"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Contact": {
        "type": "object",
        "required": [
          "first_name"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "format": "first_name",
            "example": "Brandon"
          },
          "last_name": {
            "type": "string",
            "format": "last_name",
            "example": "Oh"
          },
          "email_name": {
            "type": "string",
            "format": "email",
            "example": "brandon@strive.asia"
          },
          "contact": {
            "type": "string",
            "format": "contact",
            "example": "0104244829"
          },
          "country_code": {
            "type": "integer",
            "format": "country_code",
            "example": 60
          },
          "dob": {
            "type": "string",
            "format": "dob",
            "example": "2020-10-10"
          }
        }
      },
      "Product": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "format": "title",
            "example": "Product A"
          },
          "short_description": {
            "type": "string",
            "format": "short_description",
            "example": "This is a food product by McDonalds"
          },
          "detail_description": {
            "type": "string",
            "format": "detail_description",
            "example": "This is a good burger with juicy patty"
          },
          "usage_duration": {
            "type": "integer",
            "format": "usage_duration",
            "example": 1
          },
          "price": {
            "type": "integer",
            "format": "price",
            "example": 30
          },
          "commission": {
            "type": "integer",
            "format": "commission",
            "example": 0
          }
        }
      },
      "Deal": {
        "type": "object",
        "required": [
          "deal_name",
          "board_name",
          "stage_id"
        ],
        "properties": {
          "deal_name": {
            "type": "string",
            "format": "deal_name",
            "example": "Deal A"
          },
          "board_name": {
            "type": "integer",
            "format": "board_name",
            "example": 150
          },
          "stage_id": {
            "type": "integer",
            "format": "stage_id",
            "example": 100
          },
          "deal_cost": {
            "type": "integer",
            "format": "deal_cost",
            "example": 50
          }
        }
      }
    }
  }
}