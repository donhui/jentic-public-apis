{
  "openapi": "3.0.3",
  "info": {
    "title": "Nexi XPay Payment Gateway API",
    "description": "Nexi XPay payment gateway API providing hosted payment page integration, pay-by-link, server-to-server payments, back office operations, and disputeless (hospitality) features.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.nexi.it/en"
  },
  "servers": [
    {
      "url": "https://xpay.nexigroup.com/api/phoenix-0.0/psp/api/v1",
      "description": "Production"
    },
    {
      "url": "https://xpaysandbox.nexigroup.com/api/phoenix-0.0/psp/api/v1",
      "description": "Sandbox"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    { "name": "Payments", "description": "Payment initiation endpoints" },
    { "name": "BackOffice", "description": "Order and operation management" },
    { "name": "PayByLink", "description": "Pay-by-link management" }
  ],
  "paths": {
    "/orders/hpp": {
      "post": {
        "operationId": "createHostedPaymentPageOrder",
        "summary": "Create Hosted Payment Page order",
        "description": "Initiate a payment via Hosted Payment Page redirect.",
        "tags": ["Payments"],
        "parameters": [
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" }, "description": "API key" },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" }, "description": "Request correlation ID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/HppOrderRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hosted payment page URL returned",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HppOrderResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/orders/paybylink": {
      "post": {
        "operationId": "createPayByLinkV2",
        "summary": "Create Pay-by-Link (v2)",
        "description": "Generate a payment link that can be sent to customers.",
        "tags": ["PayByLink"],
        "parameters": [
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PayByLinkRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment link created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PayByLinkResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/paybylink/{linkId}/cancels": {
      "post": {
        "operationId": "cancelPayByLink",
        "summary": "Cancel a Pay-by-Link",
        "description": "Cancel an active payment link.",
        "tags": ["PayByLink"],
        "parameters": [
          { "name": "linkId", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Payment link ID" },
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Link cancelled" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/orders/3steps/init": {
      "post": {
        "operationId": "initThreeStepPayment",
        "summary": "Initialize 3-step payment",
        "description": "Initialize a server-to-server 3-step payment flow.",
        "tags": ["Payments"],
        "parameters": [
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ThreeStepInitRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Payment initialized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ThreeStepInitResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/orders/mit": {
      "post": {
        "operationId": "createMerchantInitiatedTransaction",
        "summary": "Create merchant-initiated transaction",
        "description": "Process a merchant-initiated transaction using stored credentials.",
        "tags": ["Payments"],
        "parameters": [
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MitRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Transaction processed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/orders/googlepay": {
      "post": {
        "operationId": "createGooglePayOrder",
        "summary": "Create Google Pay order",
        "description": "Process a payment via Google Pay.",
        "tags": ["Payments"],
        "parameters": [
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GooglePayRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Payment processed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "List orders",
        "description": "Retrieve a filtered list of orders.",
        "tags": ["BackOffice"],
        "parameters": [
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "orderId", "in": "query", "schema": { "type": "string" }, "description": "Merchant order identifier" },
          { "name": "amountType", "in": "query", "schema": { "type": "string", "enum": ["ORDER_AMOUNT", "AUTHORIZED_AMOUNT", "CAPTURED_AMOUNT"] } },
          { "name": "minAmount", "in": "query", "schema": { "type": "string" }, "description": "Minimum order amount" },
          { "name": "maxAmount", "in": "query", "schema": { "type": "string" }, "description": "Maximum order amount" },
          { "name": "fromTime", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Start time (ISO 8601)" },
          { "name": "toTime", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "End time (ISO 8601, max 1-month interval)" },
          { "name": "orderState", "in": "query", "schema": { "type": "string", "enum": ["TO_CAPTURE", "CAPTURED"] } },
          { "name": "maxRecords", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 500 } },
          { "name": "customField", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of orders",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OrderListResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/orders/{orderId}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get order details",
        "description": "Retrieve details for a specific order.",
        "tags": ["BackOffice"],
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Order details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/operations/{operationId}": {
      "get": {
        "operationId": "getOperation",
        "summary": "Get operation details",
        "description": "Retrieve details for a specific operation.",
        "tags": ["BackOffice"],
        "parameters": [
          { "name": "operationId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Operation details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Operation" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/operations/{operationId}/refunds": {
      "post": {
        "operationId": "createRefund",
        "summary": "Refund an operation",
        "description": "Process a full or partial refund for an operation.",
        "tags": ["BackOffice"],
        "parameters": [
          { "name": "operationId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Idempotency-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefundCaptureRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund processed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/operations/{operationId}/captures": {
      "post": {
        "operationId": "captureOperation",
        "summary": "Capture an authorized payment",
        "description": "Capture a previously authorized payment.",
        "tags": ["BackOffice"],
        "parameters": [
          { "name": "operationId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Idempotency-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefundCaptureRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment captured",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/operations/{operationId}/cancels": {
      "post": {
        "operationId": "cancelOperation",
        "summary": "Cancel an operation",
        "description": "Cancel a previously authorized payment.",
        "tags": ["BackOffice"],
        "parameters": [
          { "name": "operationId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Idempotency-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefundCaptureRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/payment_methods": {
      "get": {
        "operationId": "listPaymentMethods",
        "summary": "List payment methods",
        "description": "Retrieve available payment methods.",
        "tags": ["BackOffice"],
        "parameters": [
          { "name": "X-Api-Key", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "Correlation-Id", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Available payment methods",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaymentMethodsResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key",
        "description": "API key in UUID format"
      }
    },
    "schemas": {
      "HppOrderRequest": {
        "type": "object",
        "required": ["order", "paymentSession"],
        "properties": {
          "order": { "$ref": "#/components/schemas/OrderInput" },
          "paymentSession": { "$ref": "#/components/schemas/PaymentSession" }
        }
      },
      "OrderInput": {
        "type": "object",
        "required": ["orderId", "amount", "currency"],
        "properties": {
          "orderId": { "type": "string", "maxLength": 18, "description": "Unique merchant order ID" },
          "amount": { "type": "string", "description": "Amount in smallest currency unit (e.g., 5000 = 50.00 EUR)" },
          "currency": { "type": "string", "description": "ISO 4217 code" },
          "customerId": { "type": "string", "maxLength": 27 },
          "description": { "type": "string", "maxLength": 255 },
          "customField": { "type": "string", "maxLength": 255 },
          "customerInfo": { "$ref": "#/components/schemas/CustomerInfo" },
          "transactionSummary": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TransactionSummaryItem" }
          }
        }
      },
      "PaymentSession": {
        "type": "object",
        "required": ["actionType", "amount", "language", "resultUrl", "cancelUrl"],
        "properties": {
          "actionType": { "type": "string", "enum": ["PAY", "VERIFY", "PREAUTH"] },
          "amount": { "type": "string", "description": "First payment amount (less than or equal to order amount)" },
          "recurrence": { "type": "object" },
          "captureType": { "type": "string", "enum": ["IMPLICIT", "EXPLICIT"] },
          "exemptions": { "type": "string", "default": "NO_PREFERENCE" },
          "language": { "type": "string", "description": "ISO 639-2 language code", "default": "ita" },
          "paymentService": { "type": "string", "description": "Restricts payment methods" },
          "resultUrl": { "type": "string", "maxLength": 2048, "description": "Redirect URL after completion" },
          "cancelUrl": { "type": "string", "maxLength": 2048, "description": "Redirect URL if abandoned" },
          "notificationUrl": { "type": "string", "maxLength": 2048, "description": "Server-to-server webhook URL" }
        }
      },
      "CustomerInfo": {
        "type": "object",
        "properties": {
          "cardHolderName": { "type": "string" },
          "cardHolderEmail": { "type": "string" },
          "billingAddress": { "$ref": "#/components/schemas/Address" },
          "shippingAddress": { "$ref": "#/components/schemas/Address" }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "street": { "type": "string" },
          "additionalInfo": { "type": "string" },
          "city": { "type": "string" },
          "postCode": { "type": "string" },
          "province": { "type": "string" },
          "country": { "type": "string", "description": "ISO 3166-1 alpha-3 code" }
        }
      },
      "TransactionSummaryItem": {
        "type": "object",
        "properties": {
          "language": { "type": "string" },
          "summaryList": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          }
        }
      },
      "HppOrderResponse": {
        "type": "object",
        "properties": {
          "hostedPage": { "type": "string", "description": "URL to redirect customer to" },
          "securityToken": { "type": "string" }
        }
      },
      "PayByLinkRequest": {
        "type": "object",
        "required": ["order"],
        "properties": {
          "order": { "$ref": "#/components/schemas/OrderInput" },
          "paymentSession": { "$ref": "#/components/schemas/PaymentSession" }
        }
      },
      "PayByLinkResponse": {
        "type": "object",
        "properties": {
          "linkId": { "type": "string" },
          "paymentLink": { "type": "string" },
          "expirationDate": { "type": "string", "format": "date-time" }
        }
      },
      "ThreeStepInitRequest": {
        "type": "object",
        "required": ["order", "paymentSession"],
        "properties": {
          "order": { "$ref": "#/components/schemas/OrderInput" },
          "paymentSession": { "$ref": "#/components/schemas/PaymentSession" }
        }
      },
      "ThreeStepInitResponse": {
        "type": "object",
        "properties": {
          "operationId": { "type": "string" },
          "operationTime": { "type": "string", "format": "date-time" }
        }
      },
      "MitRequest": {
        "type": "object",
        "required": ["order"],
        "properties": {
          "order": { "$ref": "#/components/schemas/OrderInput" },
          "contractId": { "type": "string" },
          "captureType": { "type": "string", "enum": ["IMPLICIT", "EXPLICIT"] }
        }
      },
      "GooglePayRequest": {
        "type": "object",
        "required": ["order"],
        "properties": {
          "order": { "$ref": "#/components/schemas/OrderInput" },
          "paymentData": { "type": "object", "description": "Google Pay payment data token" }
        }
      },
      "RefundCaptureRequest": {
        "type": "object",
        "required": ["amount", "currency"],
        "properties": {
          "amount": { "type": "string", "description": "Amount in smallest currency unit" },
          "currency": { "type": "string", "description": "ISO 4217 code" },
          "description": { "type": "string", "maxLength": 255 }
        }
      },
      "OperationResponse": {
        "type": "object",
        "properties": {
          "operationId": { "type": "string" },
          "operationTime": { "type": "string", "format": "date-time" }
        }
      },
      "Operation": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string" },
          "operationId": { "type": "string" },
          "channel": { "type": "string", "enum": ["ECOMMERCE", "POS", "BACKOFFICE"] },
          "channelDetail": { "type": "string" },
          "operationType": { "type": "string", "enum": ["AUTHORIZATION", "CAPTURE", "VOID", "REFUND", "CANCEL", "CARD_VERIFICATION"] },
          "operationResult": { "type": "string", "enum": ["AUTHORIZED", "EXECUTED", "DECLINED", "THREEDS_VALIDATED", "PENDING", "VOIDED", "REFUNDED"] },
          "operationTime": { "type": "string", "format": "date-time" },
          "paymentMethod": { "type": "string", "enum": ["CARD", "APM"] },
          "paymentCircuit": { "type": "string" },
          "paymentInstrumentInfo": { "type": "string" },
          "operationAmount": { "type": "string" },
          "operationCurrency": { "type": "string" },
          "customerInfo": { "$ref": "#/components/schemas/CustomerInfo" },
          "additionalData": { "type": "object" },
          "warnings": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          },
          "paymentLinkId": { "type": "string" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string" },
          "amount": { "type": "string" },
          "currency": { "type": "string" },
          "customerId": { "type": "string" },
          "description": { "type": "string" },
          "customField": { "type": "string" },
          "customerInfo": { "$ref": "#/components/schemas/CustomerInfo" },
          "authorizedAmount": { "type": "string" },
          "capturedAmount": { "type": "string" },
          "lastOperationType": { "type": "string" },
          "lastOperationTime": { "type": "string", "format": "date-time" }
        }
      },
      "OrderListResponse": {
        "type": "object",
        "properties": {
          "orders": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Order" }
          }
        }
      },
      "PaymentMethodsResponse": {
        "type": "object",
        "properties": {
          "paymentMethods": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "circuit": { "type": "string" },
                "paymentMethod": { "type": "string" }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}