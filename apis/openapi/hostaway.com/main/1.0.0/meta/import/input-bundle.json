  "components": {
    "schemas": {
      "AccessTokenRequest": {
        "type": "object",
        "required": [
          "grant_type",
          "client_id",
          "client_secret",
          "scope"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": [
              "client_credentials"
            ]
          },
          "client_id": {
            "type": "integer",
            "description": "Hostaway account ID"
          },
          "client_secret": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "general"
            ]
          }
        }
      },
      "AccessTokenResponse": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer"
          },
          "access_token": {
            "type": "string"
          }
        }
      },
      "Listing": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "propertyTypeId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "externalListingName": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "zipcode": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "price": {
            "type": "number"
          },
          "currencyCode": {
            "type": "string"
          },
          "personCapacity": {
            "type": "integer"
          },
          "bedroomsNumber": {
            "type": "integer"
          },
          "bedsNumber": {
            "type": "integer"
          },
          "bathroomsNumber": {
            "type": "integer"
          },
          "minNights": {
            "type": "integer"
          },
          "maxNights": {
            "type": "integer"
          },
          "guestsIncluded": {
            "type": "integer"
          },
          "priceForExtraPerson": {
            "type": "number"
          },
          "cleaningFee": {
            "type": "number"
          },
          "cancellationPolicy": {
            "type": "string",
            "enum": [
              "flexible",
              "moderate",
              "strict"
            ]
          },
          "roomType": {
            "type": "string",
            "enum": [
              "entire_home",
              "private_room",
              "shared_room"
            ]
          },
          "bathroomType": {
            "type": "string",
            "enum": [
              "private",
              "shared"
            ]
          },
          "description": {
            "type": "string"
          },
          "checkInTimeStart": {
            "type": "integer"
          },
          "checkInTimeEnd": {
            "type": "integer"
          },
          "checkOutTime": {
            "type": "integer"
          },
          "contactName": {
            "type": "string"
          },
          "contactEmail": {
            "type": "string"
          }
        }
      },
      "ListingCreateRequest": {
        "type": "object",
        "required": [
          "name",
          "externalListingName",
          "address",
          "price",
          "guestsIncluded",
          "priceForExtraPerson",
          "currencyCode"
        ],
