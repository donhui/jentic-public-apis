{
  "openapi": "3.0.3",
  "info": {
    "title": "Hostaway API",
    "description": "Hostaway Public API for vacation rental management. Provides endpoints for managing listings, reservations, calendar, cancellation policies, and webhooks. Rate limited to 15 requests per 10 seconds per IP and 20 requests per 10 seconds per account.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.hostaway.com/documentation"
  },
  "servers": [
    {
      "url": "https://api.hostaway.com/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/accessTokens": {
      "post": {
        "operationId": "generateaccesstoken",
        "summary": "Generate access token",
        "description": "Generate a new OAuth 2.0 access token using client credentials",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccessTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid credentials"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "revokeaccesstoken",
        "summary": "Revoke access token",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "Token to revoke",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token revoked successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/listings": {
      "get": {
        "operationId": "listlistings",
        "summary": "Retrieve listings list",
        "tags": [
          "Listings"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max items per page"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Items to skip"
          },
          {
            "name": "sortOrder",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "nameReversed",
                "order",
                "orderReversed",
                "contactName",
                "contactNameReversed",
                "latestActivity",
                "latestActivityDesc"
              ]
            },
            "description": "Sort order"
          },
          {
            "name": "city",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by city"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by country"
          },
          {
            "name": "contactName",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by contact name"
          },
          {
            "name": "propertyTypeId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by property type"
          },
          {
            "name": "match",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by listing name"
          },
          {
            "name": "includeResources",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "Include resources"
          },
          {
            "name": "availabilityDateStart",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Availability start date (Y-m-d)"
          },
          {
            "name": "availabilityDateEnd",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Availability end date (Y-m-d)"
          },
          {
            "name": "availabilityGuestNumber",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of guests"
          },
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by user ID"
          },
          {
            "name": "isBookingEngineActive",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by booking engine status"
          }
        ],
        "responses": {
          "200": {
            "description": "List of listings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListingsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createlisting",
        "summary": "Create a new listing",
        "tags": [
          "Listings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListingCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Listing created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Listing"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
