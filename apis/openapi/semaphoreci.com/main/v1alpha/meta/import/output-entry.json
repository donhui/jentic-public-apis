{
  "openapi": "3.0.3",
  "info": {
    "title": "Semaphore CI",
    "version": "v1alpha",
    "description": "Semaphore CI/CD API for managing workflows, pipelines, jobs, promotions, deployment targets, self-hosted agents, and artifact retention policies.",
    "x-jentic-source-url": "https://docs.semaphore.io/reference/api"
  },
  "servers": [
    {
      "url": "https://{organization}.semaphoreci.com/api/v1alpha",
      "variables": {
        "organization": {
          "default": "myorg",
          "description": "Your Semaphore organization name"
        }
      }
    }
  ],
  "paths": {
    "/plumber-workflows": {
      "get": {
        "operationId": "listWorkflows",
        "summary": "List workflows",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "branch_name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "schema": {
              "type": "integer",
              "description": "Unix timestamp"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "schema": {
              "type": "integer",
              "description": "Unix timestamp"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of workflows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Workflow"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "runWorkflow",
        "summary": "Run a new workflow",
        "tags": [
          "Workflows"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "project_id",
                  "reference"
                ],
                "properties": {
                  "project_id": {
                    "type": "string"
                  },
                  "reference": {
                    "type": "string"
                  },
                  "commit_sha": {
                    "type": "string"
                  },
                  "pipeline_file": {
                    "type": "string"
                  },
                  "parameters": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "workflow_id": {
                      "type": "string"
                    },
                    "pipeline_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/plumber-workflows/{workflow_id}": {
      "get": {
        "operationId": "describeWorkflow",
        "summary": "Describe a workflow",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "workflow_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
