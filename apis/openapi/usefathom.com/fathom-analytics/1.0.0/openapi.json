  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Fathom API token. Generate from your Fathom dashboard under Settings > API."
      }
    },
    "schemas": {
      "Site": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique site identifier."
          },
          "object": {
            "type": "string",
            "enum": [
              "site"
            ],
            "description": "Object type."
          },
          "name": {
            "type": "string",
            "description": "The name of the site."
          },
          "sharing": {
            "type": "string",
            "enum": [
              "none",
              "private",
              "public"
            ],
            "description": "Sharing level for the site dashboard."
          },
          "share_password": {
            "type": "string",
            "description": "Password for private sharing."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp."
          }
        }
      },
      "SiteList": {
        "type": "object",
        "properties": {
          "object": {
            "type": "string",
            "enum": [
              "list"
            ]
          },
          "url": {
            "type": "string"
          },
          "has_more": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Site"
            }
          }
        }
      },
      "CreateSiteRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the site."
          },
          "sharing": {
            "type": "string",
            "enum": [
              "none",
              "private",
              "public"
            ],
            "description": "Dashboard sharing level."
          },
          "share_password": {
            "type": "string",
            "description": "Password if sharing is private."
          }
        }
      },
      "UpdateSiteRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the site."
          },
          "sharing": {
            "type": "string",
            "enum": [
              "none",
              "private",
              "public"
            ],
            "description": "Dashboard sharing level."
          },
          "share_password": {
            "type": "string",
            "description": "Password if sharing is private."
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
