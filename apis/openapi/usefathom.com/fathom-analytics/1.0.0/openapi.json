{
  "openapi": "3.0.3",
  "info": {
    "title": "Fathom Analytics API",
    "version": "1.0.0",
    "description": "Fathom Analytics provides simple, privacy-focused website analytics. The API allows you to manage sites, events, aggregations, and account data programmatically.",
    "x-jentic-source-url": "https://usefathom.com/api",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.usefathom.com/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Sites",
      "description": "Manage sites"
    },
    {
      "name": "Events",
      "description": "Manage events"
    },
    {
      "name": "Aggregations",
      "description": "Query analytics data"
    },
    {
      "name": "Current Visitors",
      "description": "Real-time visitor data"
    },
    {
      "name": "Account",
      "description": "Account management"
