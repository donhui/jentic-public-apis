    "/aggregations": {
      "get": {
        "operationId": "getAggregations",
        "summary": "Get aggregations",
        "description": "Query analytics data with various grouping and filtering options. Returns pageview and visit data aggregated by the specified entity.",
        "tags": [
          "Aggregations"
        ],
        "parameters": [
          {
            "name": "entity_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The site ID or event ID to query."
          },
          {
            "name": "entity",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "pageview",
                "event"
              ]
            },
            "description": "The entity type to aggregate."
          },
          {
            "name": "aggregates",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of aggregation functions: visits, uniques, pageviews, avg_duration, bounce_rate."
          },
          {
            "name": "date_from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start date for the aggregation period (ISO 8601)."
          },
          {
            "name": "date_to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End date for the aggregation period (ISO 8601)."
          },
          {
            "name": "date_grouping",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "hour",
                "day",
                "month",
                "year"
              ]
            },
            "description": "Group results by time period."
          },
          {
            "name": "field_grouping",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Group results by a field such as hostname, pathname, referrer_hostname, referrer_pathname, utm_source, utm_medium, utm_campaign, utm_content, utm_term, country_code, device_type, browser, os."
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Field to sort results by."
          },
          {
            "name": "timezone",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Timezone for date grouping (e.g., America/New_York)."
          },
          {
            "name": "filters",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSON-encoded array of filter objects to narrow results."
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 200
            },
            "description": "Maximum number of results."
          }
        ],
        "responses": {
          "200": {
            "description": "Aggregation results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Aggregation"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/current_visitors": {
      "get": {
        "operationId": "getCurrentVisitors",
        "summary": "Get current visitors",
        "description": "Returns the number of visitors currently on a site in real-time.",
