{
  "openapi": "3.0.3",
  "info": {
    "title": "Scalr IACP API",
    "version": "v3",
    "description": "Scalr Infrastructure Automation and Collaboration Platform (IACP) API following JSON:API specification. Provides management of access policies, roles, and infrastructure automation resources.",
    "x-jentic-source-url": "https://docs.scalr.io/reference/get_access_policies"
  },
  "servers": [
    {
      "url": "https://{domain}/api/iacp/v3",
      "description": "Scalr IACP API",
      "variables": {
        "domain": {
          "default": "scalr.example.com",
          "description": "Your Scalr account domain"
        }
      }
    }
  ],
  "paths": {
    "/access-policies": {
      "get": {
        "operationId": "listAccessPolicies",
        "summary": "List access policies",
        "description": "Returns a list of IAM access policies.",
        "tags": ["Access Policies"],
        "responses": {
          "200": {
            "description": "List of access policies",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessPolicyListingDocument"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createAccessPolicy",
        "summary": "Create an access policy",
        "description": "Grant access for a member identity to a scope identity. Access comprises a collection of roles.",
        "tags": ["Access Policies"],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.api+json": {
              "schema": {
                "$ref": "#/components/schemas/AccessPolicyDocument"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Access policy created",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessPolicyDocument"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          }
        }
      }
    },
    "/access-policies/{policyId}": {
      "get": {
        "operationId": "getAccessPolicy",
        "summary": "Get an access policy",
        "description": "Retrieves a specific access policy by ID.",
        "tags": ["Access Policies"],
        "parameters": [
          {
            "name": "policyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The access policy identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Access policy details",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessPolicyDocument"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateAccessPolicy",
        "summary": "Update an access policy",
        "description": "Updates an existing access policy.",
        "tags": ["Access Policies"],
        "parameters": [
          {
            "name": "policyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The access policy identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.api+json": {
              "schema": {
                "$ref": "#/components/schemas/AccessPolicyDocument"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access policy updated",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessPolicyDocument"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAccessPolicy",
        "summary": "Delete an access policy",
        "description": "Removes an access policy.",
        "tags": ["Access Policies"],
        "parameters": [
          {
            "name": "policyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The access policy identifier"
          }
        ],
        "responses": {
          "204": {
            "description": "Access policy deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDocument"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccessPolicyListingDocument": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccessPolicy"
            }
          },
          "included": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "links": {
            "$ref": "#/components/schemas/PaginationLinks"
          },
          "meta": {
            "type": "object"
          }
        }
      },
      "AccessPolicyDocument": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AccessPolicy"
          }
        }
      },
      "AccessPolicy": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "readOnly": true
          },
          "type": {
            "type": "string",
            "enum": ["access-policies"]
          },
          "attributes": {
            "type": "object",
            "properties": {
              "is-system": {
                "type": "boolean",
                "readOnly": true,
                "description": "Indicates a built-in read-only policy that cannot be updated or deleted"
              }
            }
          },
          "relationships": {
            "type": "object",
            "properties": {
              "account": {
                "$ref": "#/components/schemas/RelationshipObject"
              },
              "environment": {
                "$ref": "#/components/schemas/RelationshipObject"
              },
              "workspace": {
                "$ref": "#/components/schemas/RelationshipObject"
              },
              "roles": {
                "$ref": "#/components/schemas/RelationshipArrayObject"
              },
              "user": {
                "$ref": "#/components/schemas/RelationshipObject"
              },
              "team": {
                "$ref": "#/components/schemas/RelationshipObject"
              },
              "service-account": {
                "$ref": "#/components/schemas/RelationshipObject"
              }
            }
          }
        }
      },
      "RelationshipObject": {
        "type": "object",
        "nullable": true,
        "properties": {
          "data": {
            "type": "object",
            "nullable": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        }
      },
      "RelationshipArrayObject": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "PaginationLinks": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string"
          },
          "first": {
            "type": "string"
          },
          "last": {
            "type": "string"
          },
          "next": {
            "type": "string"
          },
          "prev": {
            "type": "string"
          }
        }
      },
      "ErrorDocument": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "detail": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token authentication"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}