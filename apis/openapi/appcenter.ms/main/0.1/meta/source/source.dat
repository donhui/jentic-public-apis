                          "properties": {
                            "subscription_id": {
                              "description": "The azure subscription id",
                              "type": "string",
                              "format": "uuid"
                            },
                            "tenant_id": {
                              "description": "The tenant id of the azure subscription belongs to",
                              "type": "string",
                              "format": "uuid"
                            },
                            "subscription_name": {
                              "description": "The name of the azure subscription",
