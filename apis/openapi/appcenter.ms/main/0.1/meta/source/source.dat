                        "Unauthorized",
                        "TooManyRequests"
                      ]
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "code",
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "<b>not_found</b>: The user or the device can't be found.\n",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "code": {
                      "type": "string",
                      "enum": [
                        "BadRequest",
                        "Conflict",
                        "NotAcceptable",
                        "NotFound",
                        "InternalServerError",
                        "Unauthorized",
                        "TooManyRequests"
                      ]
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "code",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
