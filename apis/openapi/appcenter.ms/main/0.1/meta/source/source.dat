        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "id": {
                      "description": "The unique id (UUID) of the user",
                      "type": "string",
                      "format": "uuid"
                    },
                    "avatar_url": {
                      "description": "The avatar URL of the user",
