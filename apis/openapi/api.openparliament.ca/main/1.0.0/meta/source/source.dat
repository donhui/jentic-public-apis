{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenParliament Canada API",
    "description": "OpenParliament.ca API provides access to Canadian Parliament data including bills, votes, politicians, debates, and committees.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://openparliament.ca/api/"
  },
  "servers": [
    {
      "url": "https://api.openparliament.ca",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Bills",
      "description": "Legislative bills"
    },
    {
      "name": "Votes",
      "description": "Parliamentary votes"
    },
    {
      "name": "Politicians",
      "description": "Members of Parliament"
    },
    {
      "name": "Debates",
      "description": "Hansard debate records"
    },
    {
      "name": "Committees",
      "description": "Committee information"
    }
  ],
  "paths": {
    "/bills/": {
      "get": {
        "operationId": "listbills",
        "summary": "List bills",
        "description": "Returns a paginated list of legislative bills.",
        "tags": [
          "Bills"
        ],
        "parameters": [
          {
            "name": "session",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Parliamentary session filter"
          },
          {
            "name": "introduced",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Filter by introduction date"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Results per page"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Pagination offset"
          },
          {
            "name": "version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "v1"
            },
            "description": "API version"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bills/{bill_id}/": {
      "get": {
        "operationId": "getbill",
        "summary": "Get bill details",
        "description": "Returns detailed information for a specific bill.",
        "tags": [
          "Bills"
        ],
        "parameters": [
          {
            "name": "bill_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Bill identifier (e.g., 41-1/C-10)"
          },
          {
            "name": "version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "v1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bill"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/votes/": {
      "get": {
        "operationId": "listvotes",
        "summary": "List votes",
        "description": "Returns a paginated list of parliamentary votes.",
        "tags": [
          "Votes"
        ],
        "parameters": [
          {
            "name": "session",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date__gt",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Date greater than"
          },
          {
            "name": "date__gte",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Date greater than or equal"
          },
          {
            "name": "date__lt",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Date less than"
          },
          {
            "name": "date__lte",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Date less than or equal"
          },
          {
            "name": "result",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "Agreed To",
                "Negatived"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "v1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/politicians/": {
      "get": {
        "operationId": "listpoliticians",
        "summary": "List politicians",
        "description": "Returns a paginated list of Members of Parliament.",
        "tags": [
          "Politicians"
        ],
        "parameters": [
          {
            "name": "include",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Include related data"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "v1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/politicians/{politician_slug}/": {
      "get": {
        "operationId": "getpolitician",
        "summary": "Get politician details",
        "description": "Returns detailed information for a specific politician.",
        "tags": [
          "Politicians"
        ],
        "parameters": [
          {
            "name": "politician_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Politician URL slug"
          },
          {
            "name": "version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "v1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Politician"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/debates/": {
      "get": {
        "operationId": "listdebates",
        "summary": "List debates",
        "description": "Returns a paginated list of Hansard debate records.",
        "tags": [
          "Debates"
        ],
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date__gt",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date__gte",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date__lt",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date__lte",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "v1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/committees/": {
      "get": {
        "operationId": "listcommittees",
        "summary": "List committees",
        "description": "Returns a paginated list of parliamentary committees.",
        "tags": [
          "Committees"
        ],
        "parameters": [
          {
            "name": "session",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "version",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "v1"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "objects": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "next_url": {
                "type": "string",
                "nullable": true
              },
              "previous_url": {
                "type": "string",
                "nullable": true
              }
            }
          }
        }
      },
      "Bill": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "number": {
            "type": "string"
          },
          "session": {
            "type": "string"
          },
          "introduced": {
            "type": "string",
            "format": "date"
          },
          "law": {
            "type": "boolean"
          },
          "sponsor_politician_url": {
            "type": "string"
          },
          "sponsor_politician_membership_url": {
            "type": "string"
          },
          "status": {
            "type": "object"
          },
          "vote_urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Politician": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "party": {
            "type": "object",
            "properties": {
              "short_name": {
                "type": "object"
              },
              "name": {
                "type": "object"
              }
            }
          },
          "riding": {
            "type": "object",
            "properties": {
              "name": {
                "type": "object"
              },
              "province": {
                "type": "string"
              }
            }
          },
          "current": {
            "type": "boolean"
          },
          "image": {
            "type": "string"
          },
          "memberships": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  },
  "security": []
}