    "/amazon/product": {
      "get": {
        "operationId": "amazonProduct",
        "summary": "Amazon Product",
        "description": "Retrieve Amazon product details by ASIN.",
        "tags": ["Amazon"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Product ASIN (10-character code)" },
          { "name": "domain", "in": "query", "required": false, "schema": { "type": "string", "enum": ["com", "fr", "de", "co.uk", "it", "es", "ca", "co.jp", "com.br", "com.mx", "in"], "default": "com" }, "description": "Amazon marketplace domain" }
        ],
        "responses": {
          "200": { "description": "Product details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AmazonProduct" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/amazon/search": {
      "get": {
        "operationId": "amazonSearch",
        "summary": "Amazon Search",
        "description": "Search Amazon products.",
        "tags": ["Amazon"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search keyword" },
          { "name": "domain", "in": "query", "required": false, "schema": { "type": "string", "default": "com" }, "description": "Marketplace domain" },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Pagination" }
        ],
        "responses": {
          "200": { "description": "Search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/amazon/product/offer": {
      "get": {
        "operationId": "amazonProductOffer",
        "summary": "Amazon Product Offers",
        "description": "Retrieve third-party seller offers for an Amazon product.",
        "tags": ["Amazon"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Product ASIN" },
          { "name": "domain", "in": "query", "required": false, "schema": { "type": "string", "default": "com" }, "description": "Marketplace domain" },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Pagination" }
        ],
        "responses": {
