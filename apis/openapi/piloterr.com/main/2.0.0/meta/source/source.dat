{
  "openapi": "3.0.3",
  "info": {
    "title": "Piloterr API",
    "description": "Piloterr enables forward-thinking companies to leverage the full potential of web data through 100+ ready-to-use APIs covering e-commerce, search engines, professional networks, social media, email tools, website analysis, and more.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://docs.piloterr.com"
  },
  "servers": [
    {
      "url": "https://api.piloterr.com/v2",
      "description": "Piloterr Production API"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    { "name": "Google", "description": "Google search, images, news, videos, and jobs" },
    { "name": "Search Engines", "description": "Bing, Brave, and other search engines" },
    { "name": "LinkedIn", "description": "LinkedIn profile, company, job, and post data" },
    { "name": "Amazon", "description": "Amazon product and search data" },
    { "name": "Email", "description": "Email finder, verification, and analysis" },
    { "name": "Domain", "description": "Domain WHOIS, DNSBL, and malicious detection" },
    { "name": "Website", "description": "Website crawling, screenshots, and technology detection" },
    { "name": "Crunchbase", "description": "Crunchbase company, people, and funding data" },
    { "name": "Social Media", "description": "Instagram, Pinterest, Weibo, Kick, and Vinted" },
    { "name": "E-Commerce", "description": "Walmart, Bestbuy, Chewy, Shopify, and other retailers" },
    { "name": "Real Estate", "description": "SeLoger, Leboncoin, Homestra, and other real estate platforms" },
    { "name": "Business Intelligence", "description": "Trustpilot, G2, ProductHunt, Owler, Indeed, and more" },
    { "name": "Utility", "description": "Usage, finder, and dataset endpoints" }
  ],
  "paths": {
    "/google/search": {
      "get": {
        "operationId": "googleSearch",
        "summary": "Google Search",
        "description": "Scrape organic Google search results with geolocation and language targeting.",
        "tags": ["Google"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search keyword" },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Result page number" },
          { "name": "location", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Geographic location" },
          { "name": "lang", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Language code" },
          { "name": "num", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 10, "maximum": 100 }, "description": "Results per page (10-100)" }
        ],
        "responses": {
          "200": { "description": "Successful search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SearchResults" } } } },
          "400": { "description": "Bad request - missing or invalid parameters", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "402": { "description": "Insufficient credits", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "429": { "description": "Rate limit exceeded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/google/search/autocomplete": {
      "get": {
        "operationId": "googleSearchAutocomplete",
        "summary": "Google Search Autocomplete",
        "description": "Get Google search autocomplete suggestions.",
        "tags": ["Google"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search keyword" }
        ],
        "responses": {
          "200": { "description": "Autocomplete suggestions", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/google/images": {
      "get": {
        "operationId": "googleImages",
