        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search keyword" },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Result page number" }
        ],
        "responses": {
          "200": { "description": "News search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/google/videos": {
      "get": {
        "operationId": "googleVideos",
        "summary": "Google Videos",
        "description": "Search Google Videos.",
        "tags": ["Google"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search keyword" },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Result page number" }
        ],
        "responses": {
          "200": { "description": "Video search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/google/jobs": {
      "get": {
        "operationId": "googleJobs",
        "summary": "Google Jobs",
        "description": "Search Google Jobs.",
        "tags": ["Google"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search keyword" },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Result page number" }
        ],
        "responses": {
          "200": { "description": "Job search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/bing/search": {
      "get": {
        "operationId": "bingSearch",
        "summary": "Bing Search",
        "description": "Search Bing with operator support, geolocation, and market targeting.",
        "tags": ["Search Engines"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query with operator support" },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Result page number" },
          { "name": "num", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 10, "maximum": 50 }, "description": "Results per page (10-50)" },
          { "name": "location", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Geographic location" },
          { "name": "lat", "in": "query", "required": false, "schema": { "type": "number" }, "description": "Latitude" },
          { "name": "lon", "in": "query", "required": false, "schema": { "type": "number" }, "description": "Longitude" },
          { "name": "mkt", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Market code (e.g. en-US, fr-FR)" },
          { "name": "cc", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Country code" }
        ],
        "responses": {
          "200": { "description": "Search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SearchResults" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/brave/search": {
      "get": {
        "operationId": "braveSearch",
        "summary": "Brave Search",
        "description": "Search using Brave Search engine.",
        "tags": ["Search Engines"],
        "parameters": [
          { "name": "query", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query" },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Result page number" }
        ],
        "responses": {
          "200": { "description": "Search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SearchResults" } } } },
