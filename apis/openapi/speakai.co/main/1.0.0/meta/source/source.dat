  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" }
        }
      },
      "MediaItem": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string" },
          "mediaType": { "type": "string" },
          "status": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "UploadMediaRequest": {
        "type": "object",
        "required": ["name", "url", "mediaType"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string", "description": "Signed URL or external URL of the media file." },
          "mediaType": { "type": "string", "enum": ["audio", "video"] },
          "sourceLanguage": { "type": "string", "description": "Language code (e.g., en-US)." },
          "folderId": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "TextNoteRequest": {
        "type": "object",
        "required": ["name", "text"],
        "properties": {
          "name": { "type": "string" },
          "folderId": { "type": "string" },
          "description": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "text": { "type": "string", "description": "The text content (HTML supported)." },
          "rawText": { "type": "string", "description": "Raw text content without HTML." }
        }
      },
      "RecorderRequest": {
        "type": "object",
        "required": ["name", "folderId"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "folderId": { "type": "string" },
          "sourceLanguage": { "type": "string" },
          "duration": {
            "type": "object",
            "properties": {
              "minDuration": { "type": "integer" },
              "maxDuration": { "type": "integer" }
            }
          }
        }
      },
      "AutomationRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "isActive": { "type": "boolean" },
          "runType": { "type": "string", "enum": ["schedule", "trigger"] },
          "schedule": {
            "type": "object",
            "properties": {
              "timePeriod": { "type": "string" },
              "repeatAt": { "type": "string" }
            }
          }
        }
      },
      "UserRequest": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "isActive": { "type": "boolean" },
          "isVerified": { "type": "boolean" },
          "permission": {
            "type": "object",
            "properties": {
              "audio": { "type": "boolean" },
              "video": { "type": "boolean" }
            }
          }
        }
      },
      "WebhookRequest": {
        "type": "object",
        "required": ["callbackUrl", "events"],
        "properties": {
          "callbackUrl": { "type": "string", "format": "uri" },
          "metaData": {
            "type": "object",
            "properties": {
              "providedInternalUUID": { "type": "string" }
            }
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["media.created", "media.analyzed", "media.transcribed"]
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key authentication. Obtain your API key from the Speak Ai developer page."
      }
