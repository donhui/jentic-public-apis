{
  "openapi": "3.0.3",
  "info": {
    "title": "Speak Ai API",
    "version": "1.0.0",
    "description": "Speak Ai API for programmatic media upload, transcription, insights extraction, folder management, recorder management, embeds, webhooks, automations, and user administration.",
    "x-jentic-source-url": "https://speakai.co/documentation/"
  },
  "servers": [
    {
      "url": "https://api.speakai.co/v1"
    }
  ],
  "paths": {
    "/auth/accessToken": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Get Access Token",
        "description": "Authenticate and obtain an access token.",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/refreshToken": {
      "post": {
        "operationId": "refreshToken",
        "summary": "Refresh Token",
        "description": "Refresh an expired access token using a refresh token.",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refreshToken": {
                    "type": "string"
                  }
                },
                "required": ["refreshToken"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New access token returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/media/upload/signedurl": {
      "get": {
        "operationId": "getSignedUrl",
        "summary": "Get a Signed URL for upload",
        "description": "Get a pre-signed AWS URL for direct media file upload.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "isVideo",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Whether the file is a video."
          },
          {
            "name": "filename",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Name of the file to upload."
          },
          {
            "name": "mimeType",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "MIME type of the file."
          }
        ],
        "responses": {
          "200": {
            "description": "Signed URL returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "signedUrl": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/media/upload": {
      "post": {
        "operationId": "uploadMedia",
        "summary": "Upload media file",
        "description": "Upload a file using a signed URL or an external URL for transcription and analysis.",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadMediaRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Media uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaItem"
                }
              }
            }
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/media": {
      "get": {
        "operationId": "listMedia",
        "summary": "List media files",
        "description": "List media files with pagination and filtering options.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "mediaType",
            "in": "query",
            "schema": { "type": "string", "enum": ["audio", "video"] }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": { "type": "string", "default": "createdAt:desc" }
          },
          {
            "name": "filterMedia",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "filterName",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "folderId",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of media items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/MediaItem" }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/media/insight/{mediaId}": {
      "get": {
        "operationId": "getMediaInsights",
        "summary": "Get media insights",
        "description": "Get AI-generated insights for a specific media file.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Media insights returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/media/transcript/{mediaId}": {
      "get": {
        "operationId": "getMediaTranscript",
        "summary": "Get media transcript",
        "description": "Get the transcript for a specific media file.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Media transcript returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/media/speakers/{mediaId}": {
      "put": {
        "operationId": "updateTranscriptSpeakers",
        "summary": "Update transcript speakers",
        "description": "Update speaker names in a transcript.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Speakers updated successfully"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/media/status/{mediaId}": {
      "get": {
        "operationId": "getMediaStatus",
        "summary": "Get media processing status",
        "description": "Check the processing status of a media file.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Media status returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/media/{mediaId}": {
      "put": {
        "operationId": "updateMedia",
        "summary": "Update media metadata",
        "description": "Update name, description, and tags for a media file.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "tags": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Media updated successfully"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      },
      "delete": {
        "operationId": "deleteMedia",
        "summary": "Delete a media file",
        "description": "Permanently delete a media file.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Media deleted successfully"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/text/create": {
      "post": {
        "operationId": "createTextNote",
        "summary": "Create a text note",
        "description": "Create a new text note for analysis.",
        "tags": ["Text"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextNoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text note created"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/text/insight/{mediaId}": {
      "get": {
        "operationId": "getTextInsight",
        "summary": "Get text insights",
        "description": "Get AI-generated insights for a text note.",
        "tags": ["Text"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Text insights returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/text/reanalyze/{mediaId}": {
      "get": {
        "operationId": "reanalyzeText",
        "summary": "Re-analyze text",
        "description": "Trigger re-analysis of a text note.",
        "tags": ["Text"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Re-analysis triggered"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/text/update/{mediaId}": {
      "put": {
        "operationId": "updateTextNote",
        "summary": "Update a text note",
        "description": "Update an existing text note.",
        "tags": ["Text"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextNoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text note updated"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/text/{mediaId}": {
      "delete": {
        "operationId": "deleteTextNote",
        "summary": "Delete a text note",
        "description": "Permanently delete a text note.",
        "tags": ["Text"],
        "parameters": [
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Text note deleted"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/{mediaType}/export/{mediaId}/{fileType}": {
      "post": {
        "operationId": "exportMedia",
        "summary": "Export media",
        "description": "Export a media file or text note in a specific format.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "mediaType",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "enum": ["media", "text"] }
          },
          {
            "name": "mediaId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "fileType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "isSpeakerNames",
            "in": "query",
            "schema": { "type": "boolean" }
          },
          {
            "name": "isTimeStamps",
            "in": "query",
            "schema": { "type": "boolean" }
          },
          {
            "name": "isInsightVisualized",
            "in": "query",
            "schema": { "type": "boolean" }
          },
          {
            "name": "isRedacted",
            "in": "query",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "Export file returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/media/exportMultiple/{exportType}": {
      "post": {
        "operationId": "exportMultipleMedia",
        "summary": "Multi-export media",
        "description": "Export multiple media files at once.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "exportType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "mediaIds": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "isSpeakerNames": { "type": "boolean" },
                  "isTimeStamps": { "type": "boolean" },
                  "isInsightVisualized": { "type": "boolean" },
                  "isRedacted": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Export files returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/folder": {
      "get": {
        "operationId": "listFolders",
        "summary": "Get folders",
        "description": "List folders with pagination and sorting.",
        "tags": ["Folders"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer", "default": 5 }
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": { "type": "string", "default": "createdAt" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of folders"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      },
      "post": {
        "operationId": "createFolder",
        "summary": "Create folder",
        "description": "Create a new folder.",
        "tags": ["Folders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "defaultAssignTo": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Folder created"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/folder/clone": {
      "post": {
        "operationId": "cloneFolder",
        "summary": "Clone folder",
        "description": "Clone an existing folder.",
        "tags": ["Folders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["folderId"],
                "properties": {
                  "folderId": { "type": "string" },
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "defaultAssignTo": { "type": "string" },
                  "isSaveDefaultView": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Folder cloned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/folder/{folderId}": {
      "get": {
        "operationId": "getFolderInfo",
        "summary": "Get folder info",
        "description": "Get details for a specific folder.",
        "tags": ["Folders"],
        "parameters": [
          {
            "name": "folderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Folder info returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      },
      "put": {
        "operationId": "updateFolder",
        "summary": "Update folder",
        "description": "Update an existing folder.",
        "tags": ["Folders"],
        "parameters": [
          {
            "name": "folderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Folder updated"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      },
      "delete": {
        "operationId": "deleteFolder",
        "summary": "Delete folder",
        "description": "Delete a folder.",
        "tags": ["Folders"],
        "parameters": [
          {
            "name": "folderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Folder deleted"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/recorder": {
      "get": {
        "operationId": "listRecorders",
        "summary": "List recorders",
        "description": "List recorders with pagination.",
        "tags": ["Recorder"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": { "type": "string", "default": "createdAt:desc" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of recorders"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/recorder/status/{token}": {
      "get": {
        "operationId": "checkRecorderStatus",
        "summary": "Check recorder status",
        "description": "Check the status of a recorder by token.",
        "tags": ["Recorder"],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Recorder status returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/recorder/verify": {
      "post": {
        "operationId": "verifyRecorderPassword",
        "summary": "Verify recorder password",
        "description": "Verify a password-protected recorder.",
        "tags": ["Recorder"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["token", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/recorder/create": {
      "post": {
        "operationId": "createRecorder",
        "summary": "Create recorder",
        "description": "Create a new recorder for collecting audio/video responses.",
        "tags": ["Recorder"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecorderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recorder created"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/recorder/clone": {
      "post": {
        "operationId": "cloneRecorder",
        "summary": "Clone recorder",
        "description": "Clone an existing recorder.",
        "tags": ["Recorder"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["recorderId"],
                "properties": {
                  "recorderId": { "type": "string" },
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "folderId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recorder cloned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/recorder/{recorderId}": {
      "get": {
        "operationId": "getRecorderInfo",
        "summary": "Get recorder info",
        "description": "Get details of a specific recorder.",
        "tags": ["Recorder"],
        "parameters": [
          {
            "name": "recorderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Recorder info returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      },
      "delete": {
        "operationId": "deleteRecorder",
        "summary": "Delete recorder",
        "description": "Delete a recorder.",
        "tags": ["Recorder"],
        "parameters": [
          {
            "name": "recorderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Recorder deleted"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/recorder/recordings/{recorderId}": {
      "get": {
        "operationId": "getRecordingDetails",
        "summary": "Get recording details",
        "description": "Get recording details for a specific recorder.",
        "tags": ["Recorder"],
        "parameters": [
          {
            "name": "recorderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Recording details returned"
          }
        },
        "security": [{ "apiKeyAuth": [] }]
      }
    },
    "/recorder/url/{recorderId}": {
      "get": {
