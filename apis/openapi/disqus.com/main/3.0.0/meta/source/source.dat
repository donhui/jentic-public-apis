  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Disqus public API key."
      },
      "accessToken": {
        "type": "apiKey",
        "in": "query",
        "name": "access_token",
        "description": "OAuth 2.0 access token for authenticated operations."
      }
    },
    "schemas": {
      "Cursor": {
        "type": "object",
        "properties": {
          "prev": {
            "type": "string",
            "nullable": true,
            "description": "Previous page cursor."
          },
          "hasNext": {
            "type": "boolean",
            "description": "Whether there is a next page."
          },
          "next": {
            "type": "string",
            "description": "Next page cursor."
          },
          "hasPrev": {
            "type": "boolean",
            "description": "Whether there is a previous page."
          },
          "total": {
            "type": "string",
            "nullable": true,
            "description": "Total count."
          },
          "id": {
            "type": "string",
            "description": "Cursor ID."
          },
          "more": {
            "type": "boolean",
            "description": "Whether more results are available."
          }
        }
      },
      "Forum": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Forum short name identifier."
          },
          "name": {
            "type": "string",
            "description": "Forum display name."
          },
          "founder": {
            "type": "string",
            "description": "Founder user ID."
          },
          "favicon": {
            "type": "object",
            "properties": {
              "permalink": {
                "type": "string",
                "description": "Favicon URL."
              },
              "cache": {
                "type": "string",
                "description": "Cached favicon URL."
              }
            }
          }
        }
      },
      "Thread": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Thread ID."
          },
          "title": {
            "type": "string",
            "description": "Thread title."
          },
          "forum": {
            "type": "string",
            "description": "Forum short name."
          },
          "author": {
            "type": "string",
            "description": "Author user ID."
          },
          "posts": {
            "type": "integer",
            "description": "Number of posts."
          },
          "likes": {
            "type": "integer",
            "description": "Number of likes."
          },
          "dislikes": {
            "type": "integer",
            "description": "Number of dislikes."
          },
          "isClosed": {
            "type": "boolean",
            "description": "Whether the thread is closed."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp."
          },
          "slug": {
            "type": "string",
            "description": "URL slug."
          },
          "message": {
            "type": "string",
            "description": "Thread body/message."
          },
          "link": {
            "type": "string",
            "description": "Associated URL."
          },
          "identifiers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Thread identifiers."
          }
        }
      },
      "DisqusPost": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Post ID."
          },
          "message": {
            "type": "string",
            "description": "Post body (HTML)."
          },
          "author": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "username": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "avatar": {
                "type": "object",
                "properties": {
                  "permalink": {
                    "type": "string"
                  },
                  "cache": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "thread": {
            "type": "string",
            "description": "Thread ID."
          },
          "forum": {
            "type": "string",
            "description": "Forum short name."
          },
          "parent": {
            "type": "integer",
            "nullable": true,
            "description": "Parent post ID."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp."
          },
          "likes": {
            "type": "integer",
            "description": "Like count."
          },
          "dislikes": {
            "type": "integer",
            "description": "Dislike count."
          },
          "isApproved": {
            "type": "boolean",
            "description": "Whether post is approved."
          },
          "isDeleted": {
            "type": "boolean",
            "description": "Whether post is deleted."
          },
          "isSpam": {
            "type": "boolean",
            "description": "Whether post is marked as spam."
          },
          "isFlagged": {
            "type": "boolean",
            "description": "Whether post is flagged."
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID."
          },
          "username": {
            "type": "string",
            "description": "Username."
          },
          "name": {
            "type": "string",
            "description": "Display name."
          },
          "about": {
            "type": "string",
            "description": "About text."
          },
          "url": {
            "type": "string",
            "description": "Profile URL."
          },
          "avatar": {
            "type": "object",
            "properties": {
              "permalink": {
                "type": "string"
              },
              "cache": {
                "type": "string"
              }
            }
          },
          "joinedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Join date."
          },
          "numPosts": {
            "type": "integer",
            "description": "Total post count."
          },
          "numLikesReceived": {
            "type": "integer",
            "description": "Total likes received."
          }
        }
      },
      "ForumDetailsResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Response code (0 for success)."
          },
          "response": {
            "$ref": "#/components/schemas/Forum"
          }
        }
      },
      "ThreadListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Response code (0 for success)."
          },
          "cursor": {
            "$ref": "#/components/schemas/Cursor"
          },
          "response": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Thread"
            }
          }
        }
      },
      "ThreadDetailResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "response": {
            "$ref": "#/components/schemas/Thread"
          }
        }
      },
      "PostListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "cursor": {
            "$ref": "#/components/schemas/Cursor"
          },
          "response": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DisqusPost"
            }
          }
        }
      },
      "PostDetailResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "response": {
            "$ref": "#/components/schemas/DisqusPost"
          }
        }
      },
      "UserDetailResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "response": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "VoteResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "response": {
            "type": "object",
            "properties": {
              "vote": {
                "type": "integer"
              },
              "post": {
                "$ref": "#/components/schemas/DisqusPost"
              }
            }
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "cursor": {
            "$ref": "#/components/schemas/Cursor"
          },
          "response": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code."
          },
          "response": {
            "type": "string",
            "description": "Error message."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Forums",
      "description": "Forum management and listing endpoints"
    },
    {
      "name": "Threads",
      "description": "Thread management, listing, and detail endpoints"
    },
    {
      "name": "Posts",
      "description": "Post (comment) management and listing endpoints"
    },
    {
      "name": "Users",
      "description": "User profile and activity endpoints"
    },
    {
      "name": "Categories",
      "description": "Category management endpoints"
    }
  ]
}