{
  "openapi": "3.0.3",
  "info": {
    "title": "Disqus API",
    "description": "The Disqus API provides programmatic access to Disqus data including forums, threads, posts, users, and categories. Rate limited to 1,000 requests per hour for basic accounts.",
    "version": "3.0.0",
    "contact": {
      "name": "Disqus",
      "url": "https://disqus.com/api/docs/"
    },
    "x-jentic-source-url": "https://disqus.com/api/docs/"
  },
  "servers": [
    {
      "url": "https://disqus.com/api/3.0",
      "description": "Disqus API v3.0"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/forums/details.json": {
      "get": {
        "operationId": "getForumDetails",
        "summary": "Get forum details",
        "description": "Returns details about a forum identified by its short name.",
        "tags": [
          "Forums"
        ],
        "parameters": [
          {
            "name": "forum",
            "in": "query",
            "required": true,
            "description": "Forum short name identifier.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attach",
            "in": "query",
            "required": false,
            "description": "Additional data to attach to the response.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "followsForum",
                  "forumCanDisableAds",
                  "forumForumCategory",
                  "counters",
                  "forumDaysAlive",
                  "forumFeatures",
                  "forumIntegration",
                  "forumNewPolicy",
                  "forumPermissions"
                ]
              }
            }
          },
          {
            "name": "related",
            "in": "query",
            "required": false,
            "description": "Relations to include with the response.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "author"
                ]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Forum details retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForumDetailsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forums/listThreads.json": {
      "get": {
        "operationId": "listForumThreads",
        "summary": "List threads in a forum",
        "description": "Returns a paginated list of threads for a given forum.",
        "tags": [
          "Forums"
        ],
        "parameters": [
          {
            "name": "forum",
            "in": "query",
            "required": true,
            "description": "Forum short name identifier.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results per page (max 100).",
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 100
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "Pagination cursor.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "description": "Sort order.",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "description": "Unix timestamp or ISO datetime to filter results.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "Thread states to include.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "open",
                  "closed",
                  "killed"
                ]
              },
              "default": [
                "open",
                "closed"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of threads.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThreadListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/threads/list.json": {
      "get": {
        "operationId": "listThreads",
        "summary": "List threads",
        "description": "Returns a paginated list of threads, optionally filtered by forum, category, author, or thread IDs.",
        "tags": [
          "Threads"
        ],
        "parameters": [
          {
            "name": "forum",
            "in": "query",
            "required": false,
            "description": "Forum short name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "thread",
            "in": "query",
            "required": false,
            "description": "Thread ID or identifier.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "description": "Category ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "author",
            "in": "query",
            "required": false,
            "description": "User ID or username.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "description": "Unix timestamp or ISO datetime filter.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "related",
            "in": "query",
            "required": false,
            "description": "Relations to include.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "forum",
                  "author",
                  "category"
                ]
              }
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "Pagination cursor.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Results per page (max 100).",
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 100
            }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "Thread states to include.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "open",
                  "closed",
                  "killed"
                ]
              },
              "default": [
                "open",
                "closed"
              ]
            }
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "description": "Sort order.",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of threads.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThreadListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/threads/details.json": {
      "get": {
        "operationId": "getThreadDetails",
        "summary": "Get thread details",
        "description": "Returns details about a specific thread.",
        "tags": [
          "Threads"
        ],
        "parameters": [
          {
            "name": "thread",
            "in": "query",
            "required": true,
            "description": "Thread ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "forum",
            "in": "query",
            "required": false,
            "description": "Forum short name (required when using ident or link lookup).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "related",
            "in": "query",
            "required": false,
            "description": "Relations to include.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "forum",
                  "author",
                  "category"
                ]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Thread details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThreadDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/threads/create.json": {
      "post": {
        "operationId": "createThread",
        "summary": "Create a thread",
        "description": "Creates a new thread in a forum.",
        "tags": [
          "Threads"
        ],
        "security": [
          {
            "apiKey": [],
            "accessToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "forum",
                  "title"
                ],
                "properties": {
                  "forum": {
                    "type": "string",
                    "description": "Forum short name."
                  },
                  "title": {
                    "type": "string",
                    "description": "Thread title."
                  },
                  "message": {
                    "type": "string",
                    "description": "Thread body/message."
                  },
                  "identifier": {
                    "type": "string",
                    "description": "Unique identifier for the thread."
                  },
                  "url": {
                    "type": "string",
                    "description": "URL associated with the thread."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thread created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThreadDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/posts/list.json": {
      "get": {
        "operationId": "listPosts",
        "summary": "List posts",
        "description": "Returns a paginated list of posts, optionally filtered by forum, thread, or category.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "forum",
            "in": "query",
            "required": false,
            "description": "Forum short name. Use ':all' to retrieve all forums.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "thread",
            "in": "query",
            "required": false,
            "description": "Thread ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "description": "Category ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "description": "Unix timestamp or ISO datetime filter.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Start date filter (Unix timestamp or ISO datetime).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "description": "End date filter (Unix timestamp or ISO datetime).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortType",
            "in": "query",
            "required": false,
            "description": "Sort type.",
            "schema": {
              "type": "string",
              "enum": [
                "date",
                "priority"
              ],
              "default": "date"
            }
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "description": "Sort order.",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Results per page (max 100).",
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 100
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "Pagination cursor.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "Post states to include.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "unapproved",
                  "approved",
                  "spam",
                  "deleted",
                  "flagged",
                  "highlighted"
                ]
              },
              "default": [
                "approved"
              ]
            }
          },
          {
            "name": "related",
            "in": "query",
            "required": false,
            "description": "Relations to include.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "forum",
                  "thread"
                ]
              }
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": false,
            "description": "Search query string.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of posts.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/posts/details.json": {
      "get": {
        "operationId": "getPostDetails",
        "summary": "Get post details",
        "description": "Returns details about a specific post.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "post",
            "in": "query",
