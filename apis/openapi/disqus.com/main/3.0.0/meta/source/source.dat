    "/users/listPosts.json": {
      "get": {
        "operationId": "listUserPosts",
        "summary": "List user posts",
        "description": "Returns posts made by a specific user.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "user",
            "in": "query",
            "required": false,
