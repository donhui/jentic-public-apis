                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/posts/create.json": {
      "post": {
        "operationId": "createPost",
        "summary": "Create a post",
        "description": "Creates a new post (comment) in a thread.",
        "tags": [
          "Posts"
        ],
        "security": [
          {
            "apiKey": [],
            "accessToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "thread",
                  "message"
                ],
                "properties": {
                  "thread": {
                    "type": "string",
                    "description": "Thread ID to post in."
                  },
                  "message": {
                    "type": "string",
                    "description": "Comment body."
                  },
                  "parent": {
                    "type": "string",
                    "description": "Parent post ID (for nested replies)."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Post created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/posts/vote.json": {
      "post": {
        "operationId": "voteOnPost",
        "summary": "Vote on a post",
        "description": "Upvote or downvote a post.",
        "tags": [
          "Posts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "post",
                  "vote"
                ],
                "properties": {
                  "post": {
                    "type": "string",
                    "description": "Post ID."
                  },
                  "vote": {
                    "type": "integer",
                    "description": "Vote value: 1 (upvote), -1 (downvote), 0 (remove vote).",
                    "enum": [
                      -1,
                      0,
                      1
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Vote recorded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users/details.json": {
