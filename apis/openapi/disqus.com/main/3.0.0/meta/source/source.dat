            "description": "Relations to include.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "forum",
                  "thread"
                ]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Post details.",
            "content": {
              "application/json": {
