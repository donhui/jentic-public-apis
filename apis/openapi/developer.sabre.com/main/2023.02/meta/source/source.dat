                      "items": {
                        "type": "object",
                        "properties": {
                          "AllianceCode": { "type": "string" },
                          "AllianceName": { "type": "string" },
                          "Members": { "type": "array", "items": { "type": "object", "properties": { "AirlineCode": { "type": "string" }, "AirlineName": { "type": "string" } } } }
                        }
                      }
                    },
                    "Links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
