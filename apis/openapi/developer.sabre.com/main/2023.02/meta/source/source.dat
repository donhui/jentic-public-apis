{
  "openapi": "3.0.3",
  "info": {
    "title": "Sabre REST API",
    "version": "2023.02",
    "description": "Sabre is a leading technology provider to the global travel and tourism industry. The Sabre REST API provides programmatic access to Sabre's Global Distribution System (GDS), enabling travel agencies, airlines, hoteliers, and other travel companies to search, book, and manage travel content. This specification covers air shopping (including Bargain Finder Max and NDC-enabled offers), booking management (PNR creation and modification), ticketing, order management, hotel and car availability, utility/reference-data lookups, fare monitoring (FareNabber), and trip proposal workflows. Authentication uses OAuth 2.0 with both client_credentials and password grant types.",
    "contact": {
      "name": "Sabre Developer Support",
      "url": "https://developer.sabre.com/"
    },
    "x-jentic-source-url": "https://developer.sabre.com/"
  },
  "servers": [
    {
      "url": "https://api.platform.sabre.com",
      "description": "Production"
    },
    {
      "url": "https://api.cert.platform.sabre.com",
      "description": "Certification/Testing"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "OAuth 2.0 token endpoints for obtaining access tokens." },
    { "name": "Air Intelligence", "description": "Historical fare and flight data for travel planning insights." },
    { "name": "Air Shopping", "description": "Search and price air itineraries including Bargain Finder Max, InstaFlights, and NDC offers." },
    { "name": "Air FareNabber", "description": "Subscribe to fare-watch alerts that notify when fares meet specified criteria." },
    { "name": "Air Seats", "description": "Seat map retrieval and ancillary offer pricing." },
    { "name": "Booking Management", "description": "Create, retrieve, modify, and cancel bookings and passenger name records (PNRs)." },
    { "name": "Ticketing", "description": "Issue, exchange, and manage electronic tickets." },
    { "name": "NDC Order Management", "description": "Create, view, change, and cancel NDC-based orders." },
    { "name": "Hotels", "description": "Search hotel availability, view property details, and check rates." },
    { "name": "Cars", "description": "Search vehicle rental availability." },
    { "name": "Utility", "description": "Reference-data lookups for airlines, aircraft, airports, and geo locations." },
    { "name": "Trip Proposals", "description": "Create, manage, search, refresh, and book trip proposals." }
  ],
  "paths": {
    "/v2/auth/token": {
      "post": {
        "operationId": "createTokenV2",
        "tags": ["Authentication"],
        "summary": "Obtain OAuth token (client_credentials)",
        "description": "Authenticates using the client_credentials grant type and returns an access token.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id", "client_secret"],
                "properties": {
                  "grant_type": { "type": "string", "enum": ["client_credentials"], "description": "OAuth grant type." },
                  "client_id": { "type": "string", "description": "Application client ID." },
                  "client_secret": { "type": "string", "description": "Application client secret." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token issued successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v3/auth/token": {
      "post": {
        "operationId": "createTokenV3",
        "tags": ["Authentication"],
        "summary": "Obtain OAuth token with ClientID (password grant)",
        "description": "Authenticates using the password grant type, returning an access token scoped to a specific user and pseudo-city code.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id", "client_secret", "username", "password"],
                "properties": {
                  "grant_type": { "type": "string", "enum": ["password"], "description": "OAuth grant type." },
                  "client_id": { "type": "string", "description": "Application client ID." },
                  "client_secret": { "type": "string", "description": "Application client secret." },
                  "username": { "type": "string", "description": "Sabre user identifier (EPR)." },
                  "password": { "type": "string", "description": "User password or encoded credentials." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token issued successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v1/historical/flights/{origin}/seasonality": {
      "get": {
        "operationId": "getTravelSeasonality",
        "tags": ["Air Intelligence"],
        "summary": "Travel Seasonality",
        "description": "Returns historical flight demand and fare seasonality data for a given origin.",
        "parameters": [
          {
            "name": "origin",
            "in": "path",
            "required": true,
            "description": "IATA airport or city code for the origin.",
            "schema": { "type": "string", "minLength": 3, "maxLength": 3, "example": "ATL" }
          }
        ],
        "responses": {
          "200": {
            "description": "Seasonality data returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "OriginLocation": { "type": "string" },
                    "SeasonalityData": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Month": { "type": "integer" },
                          "Year": { "type": "integer" },
                          "MedianFare": { "type": "number" },
                          "DemandIndex": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v1/historical/shop/flights/fares": {
      "get": {
        "operationId": "getLowFareHistory",
        "tags": ["Air Intelligence"],
        "summary": "Low Fare History",
        "description": "Returns historical lowest fare data for a given origin-destination pair and travel dates.",
        "parameters": [
          { "name": "origin", "in": "query", "required": true, "schema": { "type": "string", "minLength": 3, "maxLength": 3 }, "description": "IATA origin airport/city code." },
          { "name": "destination", "in": "query", "required": true, "schema": { "type": "string", "minLength": 3, "maxLength": 3 }, "description": "IATA destination airport/city code." },
          { "name": "departuredate", "in": "query", "required": true, "schema": { "type": "string", "format": "date" }, "description": "Departure date (YYYY-MM-DD)." },
          { "name": "returndate", "in": "query", "required": false, "schema": { "type": "string", "format": "date" }, "description": "Return date (YYYY-MM-DD)." },
          { "name": "pointofsalecountry", "in": "query", "required": false, "schema": { "type": "string", "minLength": 2, "maxLength": 2 }, "description": "ISO 3166-1 alpha-2 country code for point of sale." }
        ],
        "responses": {
          "200": {
            "description": "Historical fare data returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "OriginLocation": { "type": "string" },
                    "DestinationLocation": { "type": "string" },
                    "FareHistory": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/FlightOffer" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v1/shop/flights": {
      "get": {
        "operationId": "instaFlightsSearch",
        "tags": ["Air Shopping"],
        "summary": "InstaFlights Search",
        "description": "Returns cached low-fare itineraries for a given origin-destination pair with optional sorting and pagination.",
        "parameters": [
          { "name": "origin", "in": "query", "required": true, "schema": { "type": "string", "minLength": 3, "maxLength": 3 }, "description": "IATA origin airport/city code." },
          { "name": "destination", "in": "query", "required": true, "schema": { "type": "string", "minLength": 3, "maxLength": 3 }, "description": "IATA destination airport/city code." },
          { "name": "departuredate", "in": "query", "required": true, "schema": { "type": "string", "format": "date" }, "description": "Departure date (YYYY-MM-DD)." },
          { "name": "returndate", "in": "query", "required": false, "schema": { "type": "string", "format": "date" }, "description": "Return date (YYYY-MM-DD)." },
          { "name": "onlineitinerariesonly", "in": "query", "required": false, "schema": { "type": "string", "enum": ["Y", "N"] }, "description": "Restrict to online (single-airline) itineraries." },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "default": 50 }, "description": "Maximum number of results to return." },
          { "name": "offset", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 }, "description": "Starting position for results pagination." },
          { "name": "sortby", "in": "query", "required": false, "schema": { "type": "string", "enum": ["totalfare", "departuredate", "arrivaldate"] }, "description": "Sort key for results." },
          { "name": "order", "in": "query", "required": false, "schema": { "type": "string", "enum": ["asc", "desc"] }, "description": "Sort order." },
          { "name": "pointofsalecountry", "in": "query", "required": false, "schema": { "type": "string", "minLength": 2, "maxLength": 2 }, "description": "ISO 3166-1 alpha-2 country code for point of sale." }
        ],
        "responses": {
          "200": {
            "description": "Flight itineraries returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "PricedItineraries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/FlightOffer" }
                    },
                    "Links": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Link" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v2/shop/flights/fares": {
      "get": {
        "operationId": "destinationFinderLeadPriceCalendar",
        "tags": ["Air Shopping"],
        "summary": "Destination Finder / Lead Price Calendar",
        "description": "Returns lowest available fares for one or many destinations, useful for flexible-date and destination-discovery searches.",
        "parameters": [
          { "name": "origin", "in": "query", "required": true, "schema": { "type": "string", "minLength": 3, "maxLength": 3 }, "description": "IATA origin airport/city code." },
          { "name": "destination", "in": "query", "required": false, "schema": { "type": "string", "minLength": 3, "maxLength": 3 }, "description": "IATA destination airport/city code. Omit for multi-destination discovery." },
          { "name": "departuredate", "in": "query", "required": false, "schema": { "type": "string", "format": "date" }, "description": "Departure date or month (YYYY-MM-DD or YYYY-MM)." },
          { "name": "returndate", "in": "query", "required": false, "schema": { "type": "string", "format": "date" }, "description": "Return date (YYYY-MM-DD)." },
          { "name": "lengthofstay", "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Length of stay in days." },
          { "name": "pointofsalecountry", "in": "query", "required": false, "schema": { "type": "string", "minLength": 2, "maxLength": 2 }, "description": "ISO 3166-1 alpha-2 country code for point of sale." }
        ],
        "responses": {
          "200": {
            "description": "Lead-price fares returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "FareInfo": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/FlightOffer" }
                    },
                    "Links": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Link" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v2/offers/shop": {
      "post": {
        "operationId": "bargainFinderMaxV2",
        "tags": ["Air Shopping"],
        "summary": "Bargain Finder Max v2",
        "description": "Performs a comprehensive air-shopping search using Sabre's Bargain Finder Max engine (version 2).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "OTA_AirLowFareSearchRQ": {
                    "type": "object",
                    "properties": {
                      "OriginDestinationInformation": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "DepartureDateTime": { "type": "string", "format": "date-time" },
                            "OriginLocation": { "type": "object", "properties": { "LocationCode": { "type": "string" } } },
                            "DestinationLocation": { "type": "object", "properties": { "LocationCode": { "type": "string" } } }
                          }
                        }
                      },
                      "TravelPreferences": { "type": "object" },
                      "TravelerInfoSummary": { "type": "object" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shopping results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "OTA_AirLowFareSearchRS": {
                      "type": "object",
                      "properties": {
                        "PricedItineraries": {
                          "type": "object",
                          "properties": {
                            "PricedItinerary": {
                              "type": "array",
                              "items": { "$ref": "#/components/schemas/FlightOffer" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v3/offers/shop": {
      "post": {
        "operationId": "bargainFinderMaxV3",
        "tags": ["Air Shopping"],
        "summary": "Bargain Finder Max v3 (NDC support)",
        "description": "Performs an air-shopping search using Bargain Finder Max version 3 with NDC content support.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "OTA_AirLowFareSearchRQ": {
                    "type": "object",
                    "properties": {
                      "OriginDestinationInformation": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "DepartureDateTime": { "type": "string", "format": "date-time" },
                            "OriginLocation": { "type": "object", "properties": { "LocationCode": { "type": "string" } } },
                            "DestinationLocation": { "type": "object", "properties": { "LocationCode": { "type": "string" } } }
                          }
                        }
                      },
                      "TravelPreferences": { "type": "object" },
                      "TravelerInfoSummary": { "type": "object" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shopping results with NDC content returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "GroupedItineraryResponse": {
                      "type": "object",
                      "properties": {
                        "Statistics": { "type": "object" },
                        "ScheduleDescs": { "type": "array", "items": { "type": "object" } },
                        "TaxDescs": { "type": "array", "items": { "type": "object" } },
                        "FareComponentDescs": { "type": "array", "items": { "type": "object" } },
                        "ItineraryGroups": { "type": "array", "items": { "$ref": "#/components/schemas/FlightOffer" } }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v4/offers/shop": {
      "post": {
        "operationId": "bargainFinderMaxV4",
        "tags": ["Air Shopping"],
        "summary": "Bargain Finder Max v4",
        "description": "Performs an air-shopping search using the latest Bargain Finder Max version 4 engine.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "OTA_AirLowFareSearchRQ": {
                    "type": "object",
                    "properties": {
                      "OriginDestinationInformation": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "DepartureDateTime": { "type": "string", "format": "date-time" },
                            "OriginLocation": { "type": "object", "properties": { "LocationCode": { "type": "string" } } },
                            "DestinationLocation": { "type": "object", "properties": { "LocationCode": { "type": "string" } } }
                          }
                        }
                      },
                      "TravelPreferences": { "type": "object" },
                      "TravelerInfoSummary": { "type": "object" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shopping results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "GroupedItineraryResponse": {
                      "type": "object",
                      "properties": {
                        "Statistics": { "type": "object" },
                        "ItineraryGroups": { "type": "array", "items": { "$ref": "#/components/schemas/FlightOffer" } }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v4.3.0/shop/flights": {
      "post": {
        "operationId": "shopFlightsV430",
        "tags": ["Air Shopping"],
        "summary": "Shop Flights v4.3.0",
        "description": "Performs a stateful air-shopping request via Sabre's orchestrated shopping service.",
        "parameters": [
          { "name": "mode", "in": "query", "required": true, "schema": { "type": "string", "enum": ["live"] }, "description": "Processing mode." }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "OTA_AirLowFareSearchRQ": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shopping results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "OTA_AirLowFareSearchRS": { "type": "object" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v4.3.0/shop/flights/revalidate": {
      "post": {
        "operationId": "revalidateItineraryV430",
        "tags": ["Air Shopping"],
        "summary": "Revalidate Itinerary v4.3.0",
        "description": "Revalidates a previously shopped itinerary to confirm current availability and pricing.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "OTA_AirLowFareSearchRQ": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Revalidation results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "OTA_AirLowFareSearchRS": { "type": "object" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v6.1.0/shop/altdates/flights": {
      "post": {
        "operationId": "alternateDateSearch",
        "tags": ["Air Shopping"],
        "summary": "Alternate Date Search",
        "description": "Searches for flight options across a range of alternate departure and return dates.",
        "parameters": [
          { "name": "mode", "in": "query", "required": true, "schema": { "type": "string", "enum": ["live"] }, "description": "Processing mode." }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "OTA_AirLowFareSearchRQ": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alternate-date results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "OTA_AirLowFareSearchRS": { "type": "object" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v6.1.0/shop/flights/revalidate": {
      "post": {
        "operationId": "revalidateItineraryV610",
        "tags": ["Air Shopping"],
        "summary": "Revalidate Itinerary v6.1.0",
        "description": "Revalidates a previously shopped itinerary using the v6.1.0 engine.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "OTA_AirLowFareSearchRQ": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Revalidation results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "OTA_AirLowFareSearchRS": { "type": "object" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v1.0/AirShopping/FareNabberSubscriptions": {
      "post": {
        "operationId": "createFareSubscription",
        "tags": ["Air FareNabber"],
        "summary": "Create Fare Subscription",
        "description": "Creates a new FareNabber subscription to monitor fares for specified criteria and receive alerts.",
        "requestBody": {
          "required": true,
          "content": {
