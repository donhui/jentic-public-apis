              "application/json": {
                "schema": { "$ref": "#/components/schemas/TripProposal" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v1/tripproposal/document/{proposalId}": {
      "get": {
        "operationId": "readProposal",
        "tags": ["Trip Proposals"],
        "summary": "Read Proposal",
        "description": "Retrieves an existing trip proposal by its identifier.",
        "parameters": [
          {
            "name": "proposalId",
            "in": "path",
            "required": true,
            "description": "Unique proposal identifier.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Proposal returned successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TripProposal" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Proposal not found.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "put": {
        "operationId": "updateProposal",
        "tags": ["Trip Proposals"],
        "summary": "Update Proposal",
        "description": "Updates an existing trip proposal.",
        "parameters": [
          {
            "name": "proposalId",
            "in": "path",
            "required": true,
            "description": "Unique proposal identifier.",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TripProposalRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Proposal updated successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TripProposal" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Proposal not found.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "delete": {
        "operationId": "deleteProposal",
        "tags": ["Trip Proposals"],
        "summary": "Delete Proposal",
        "description": "Deletes an existing trip proposal.",
        "parameters": [
          {
            "name": "proposalId",
            "in": "path",
            "required": true,
            "description": "Unique proposal identifier.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Proposal deleted successfully." },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Proposal not found.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v1/tripproposal/search": {
      "post": {
        "operationId": "searchProposals",
        "tags": ["Trip Proposals"],
        "summary": "Search Proposals",
        "description": "Searches for trip proposals matching specified criteria.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "SearchCriteria": {
                    "type": "object",
                    "properties": {
                      "ClientName": { "type": "string" },
                      "Status": { "type": "string" },
                      "CreatedAfter": { "type": "string", "format": "date-time" },
                      "CreatedBefore": { "type": "string", "format": "date-time" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Proposals": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/TripProposal" }
                    },
                    "TotalCount": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v1/tripproposal/refresh": {
      "post": {
        "operationId": "refreshProposal",
        "tags": ["Trip Proposals"],
        "summary": "Refresh Proposal",
        "description": "Refreshes pricing and availability for all options within a trip proposal.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ProposalId": { "type": "string" }
                },
                "required": ["ProposalId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Proposal refreshed successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TripProposal" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/v1/tripproposal/book": {
      "post": {
        "operationId": "bookProposal",
        "tags": ["Trip Proposals"],
        "summary": "Book Proposal",
        "description": "Books the selected option from a trip proposal, creating a reservation.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ProposalId": { "type": "string" },
                  "SelectedOptionId": { "type": "string" },
                  "TravelerInfo": { "type": "object" },
                  "Payment": { "type": "object" }
                },
                "required": ["ProposalId", "SelectedOptionId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Proposal booked successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Booking" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "Sabre OAuth 2.0 authentication supporting client_credentials and password grant types.",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api.platform.sabre.com/v2/auth/token",
            "scopes": {}
          },
          "password": {
            "tokenUrl": "https://api.platform.sabre.com/v3/auth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string", "description": "Bearer token for authenticating subsequent API requests." },
          "token_type": { "type": "string", "example": "bearer" },
          "expires_in": { "type": "integer", "description": "Token lifetime in seconds." }
        }
      },
      "FlightOffer": {
        "type": "object",
        "description": "Represents a priced air itinerary or fare offer.",
        "properties": {
          "OfferId": { "type": "string", "description": "Unique offer identifier." },
          "Source": { "type": "string", "description": "Content source (e.g., ATPCO, NDC)." },
          "TotalFare": {
            "type": "object",
            "properties": {
              "Amount": { "type": "number", "description": "Total fare amount including taxes." },
              "CurrencyCode": { "type": "string", "description": "ISO 4217 currency code." }
            }
          },
          "BaseFare": {
            "type": "object",
            "properties": {
              "Amount": { "type": "number" },
              "CurrencyCode": { "type": "string" }
            }
          },
          "Taxes": {
            "type": "object",
            "properties": {
              "Amount": { "type": "number" },
              "CurrencyCode": { "type": "string" },
              "TaxBreakdown": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "TaxCode": { "type": "string" },
                    "Amount": { "type": "number" }
                  }
                }
              }
            }
          },
          "OriginDestinationOptions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "FlightSegments": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/FlightSegment" }
                },
                "ElapsedTime": { "type": "integer", "description": "Total elapsed time in minutes." }
              }
            }
          },
          "BaggageAllowance": {
            "type": "object",
            "properties": {
              "Pieces": { "type": "integer" },
              "Weight": { "type": "number" },
              "WeightUnit": { "type": "string", "enum": ["KG", "LB"] }
            }
          },
          "FareRules": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Category": { "type": "string" },
                "Text": { "type": "string" }
              }
            }
          },
          "LastTicketingDate": { "type": "string", "format": "date" },
          "ValidatingAirlineCode": { "type": "string" }
        }
      },
      "FlightSegment": {
        "type": "object",
        "description": "A single flight leg between two airports.",
        "properties": {
          "DepartureAirport": { "type": "string", "description": "IATA departure airport code." },
          "ArrivalAirport": { "type": "string", "description": "IATA arrival airport code." },
          "DepartureDateTime": { "type": "string", "format": "date-time" },
          "ArrivalDateTime": { "type": "string", "format": "date-time" },
          "MarketingAirline": { "type": "string", "description": "IATA marketing carrier code." },
          "OperatingAirline": { "type": "string", "description": "IATA operating carrier code." },
          "FlightNumber": { "type": "string" },
          "Equipment": { "type": "string", "description": "IATA aircraft equipment code." },
          "CabinClass": { "type": "string", "description": "Cabin class (Economy, Premium Economy, Business, First)." },
          "BookingCode": { "type": "string", "description": "Reservation Booking Designator (RBD)." },
          "Duration": { "type": "integer", "description": "Segment duration in minutes." },
          "NumberOfStops": { "type": "integer" },
          "ConnectionTime": { "type": "integer", "description": "Connection time in minutes to the next segment." }
        }
      },
      "HotelAvailability": {
        "type": "object",
        "description": "Hotel availability search response.",
        "properties": {
          "GetHotelAvailRS": {
            "type": "object",
            "properties": {
              "HotelAvailInfos": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "HotelCode": { "type": "string" },
                    "HotelName": { "type": "string" },
                    "ChainCode": { "type": "string" },
                    "StarRating": { "type": "number" },
                    "Address": {
                      "type": "object",
                      "properties": {
                        "AddressLine": { "type": "string" },
                        "CityName": { "type": "string" },
                        "CountryCode": { "type": "string" },
                        "PostalCode": { "type": "string" }
                      }
                    },
                    "GeoCode": {
                      "type": "object",
                      "properties": {
                        "Latitude": { "type": "number" },
                        "Longitude": { "type": "number" }
                      }
                    },
                    "LowestRate": {
                      "type": "object",
                      "properties": {
                        "Amount": { "type": "number" },
                        "CurrencyCode": { "type": "string" }
                      }
                    },
                    "RoomTypes": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      },
      "HotelDetails": {
        "type": "object",
        "description": "Detailed hotel property information.",
        "properties": {
          "GetHotelDetailsRS": {
            "type": "object",
            "properties": {
              "HotelCode": { "type": "string" },
              "HotelName": { "type": "string" },
              "ChainCode": { "type": "string" },
              "ChainName": { "type": "string" },
              "StarRating": { "type": "number" },
              "Description": { "type": "string" },
              "Address": {
                "type": "object",
                "properties": {
                  "AddressLine": { "type": "string" },
                  "CityName": { "type": "string" },
                  "StateProv": { "type": "string" },
                  "CountryCode": { "type": "string" },
                  "PostalCode": { "type": "string" }
                }
              },
              "GeoCode": {
                "type": "object",
                "properties": {
                  "Latitude": { "type": "number" },
                  "Longitude": { "type": "number" }
                }
              },
              "ContactInfo": {
                "type": "object",
                "properties": {
                  "Phone": { "type": "string" },
                  "Fax": { "type": "string" },
                  "Email": { "type": "string" },
                  "Website": { "type": "string" }
                }
              },
              "Amenities": { "type": "array", "items": { "type": "object", "properties": { "Code": { "type": "string" }, "Description": { "type": "string" } } } },
              "Images": { "type": "array", "items": { "type": "object", "properties": { "Url": { "type": "string" }, "Category": { "type": "string" } } } },
              "CheckInTime": { "type": "string" },
              "CheckOutTime": { "type": "string" }
            }
          }
        }
      },
      "HotelRateInfo": {
        "type": "object",
        "description": "Detailed hotel rate and room information.",
        "properties": {
          "GetHotelRateInfoRS": {
            "type": "object",
            "properties": {
              "HotelCode": { "type": "string" },
              "HotelName": { "type": "string" },
              "RoomRates": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "RoomTypeCode": { "type": "string" },
                    "RatePlanCode": { "type": "string" },
                    "RoomDescription": { "type": "string" },
                    "Rate": {
                      "type": "object",
                      "properties": {
                        "Amount": { "type": "number" },
                        "CurrencyCode": { "type": "string" },
                        "RateTimeUnit": { "type": "string", "enum": ["Night", "Stay"] }
                      }
                    },
                    "TotalPrice": {
                      "type": "object",
                      "properties": {
                        "Amount": { "type": "number" },
                        "CurrencyCode": { "type": "string" }
                      }
                    },
                    "CancelPolicy": { "type": "object" },
                    "MealPlan": { "type": "string" },
                    "GuaranteeRequired": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      },
      "VehicleAvailability": {
        "type": "object",
        "description": "Vehicle rental availability response.",
        "properties": {
          "GetVehAvailRS": {
            "type": "object",
            "properties": {
              "VehicleOptions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "VendorCode": { "type": "string" },
                    "VendorName": { "type": "string" },
                    "VehicleType": { "type": "string" },
                    "VehicleClass": { "type": "string" },
                    "Description": { "type": "string" },
                    "TransmissionType": { "type": "string", "enum": ["Automatic", "Manual"] },
                    "AirConditioning": { "type": "boolean" },
                    "PassengerCapacity": { "type": "integer" },
                    "BaggageCapacity": { "type": "integer" },
                    "DoorCount": { "type": "integer" },
                    "Rate": {
                      "type": "object",
                      "properties": {
                        "DailyRate": { "type": "number" },
                        "TotalEstimate": { "type": "number" },
                        "CurrencyCode": { "type": "string" }
                      }
                    },
                    "PickUpLocation": { "type": "string" },
                    "ReturnLocation": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "PassengerNameRecordRequest": {
        "type": "object",
        "description": "Request payload for creating or updating a Passenger Name Record.",
        "properties": {
          "CreatePassengerNameRecordRQ": {
            "type": "object",
            "properties": {
              "TravelItineraryAddInfo": {
                "type": "object",
                "properties": {
                  "AgencyInfo": { "type": "object" },
                  "CustomerInfo": {
                    "type": "object",
                    "properties": {
                      "PersonName": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "GivenName": { "type": "string" },
                            "Surname": { "type": "string" },
                            "NameNumber": { "type": "string" }
                          }
                        }
                      },
                      "ContactNumbers": { "type": "array", "items": { "type": "object" } },
                      "Email": { "type": "array", "items": { "type": "object" } }
                    }
                  }
                }
              },
              "AirBook": { "type": "object" },
              "AirPrice": { "type": "object" },
              "HotelBook": { "type": "object" },
              "PostProcessing": { "type": "object" }
            }
          }
        }
      },
      "PassengerNameRecord": {
        "type": "object",
        "description": "A Sabre Passenger Name Record (PNR).",
        "properties": {
          "CreatePassengerNameRecordRS": {
            "type": "object",
            "properties": {
              "ItineraryRef": {
                "type": "object",
                "properties": {
                  "ID": { "type": "string", "description": "PNR locator (record locator)." }
                }
              },
              "AirBook": { "type": "object" },
              "AirPrice": { "type": "array", "items": { "type": "object" } },
              "TravelItineraryRead": {
                "type": "object",
                "properties": {
                  "TravelItinerary": {
                    "type": "object",
                    "properties": {
                      "CustomerInfo": { "type": "object" },
                      "ItineraryInfo": { "type": "object" },
                      "ItineraryRef": { "type": "object" },
                      "AccountingInfo": { "type": "object" }
                    }
                  }
                }
              },
              "ApplicationResults": {
                "type": "object",
                "properties": {
                  "status": { "type": "string" },
                  "Success": { "type": "array", "items": { "type": "object" } },
                  "Warning": { "type": "array", "items": { "type": "object" } }
                }
              }
            }
          }
        }
      },
      "Booking": {
        "type": "object",
        "description": "A travel booking managed through the trip orders service.",
        "properties": {
          "ConfirmationId": { "type": "string", "description": "PNR locator or booking confirmation ID." },
          "Status": { "type": "string", "description": "Booking status." },
          "Travelers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "GivenName": { "type": "string" },
                "Surname": { "type": "string" },
                "DateOfBirth": { "type": "string", "format": "date" },
                "PassengerType": { "type": "string" }
              }
            }
          },
          "FlightSegments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/FlightSegment" }
          },
          "HotelSegments": { "type": "array", "items": { "type": "object" } },
          "VehicleSegments": { "type": "array", "items": { "type": "object" } },
          "Pricing": {
            "type": "object",
            "properties": {
              "TotalAmount": { "type": "number" },
              "CurrencyCode": { "type": "string" }
            }
          },
          "Tickets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "TicketNumber": { "type": "string" },
                "Status": { "type": "string" }
              }
            }
          },
          "ContactInfo": { "type": "object" },
          "Remarks": { "type": "array", "items": { "type": "object" } },
          "CreatedAt": { "type": "string", "format": "date-time" },
          "ModifiedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Order": {
        "type": "object",
        "description": "An NDC-based order.",
        "properties": {
          "OrderId": { "type": "string", "description": "Unique NDC order identifier." },
          "Status": { "type": "string", "description": "Order status (e.g., Created, Confirmed, Ticketed, Cancelled)." },
          "Owner": { "type": "string", "description": "Airline owner of the order." },
          "OrderItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "OrderItemId": { "type": "string" },
                "FlightSegments": { "type": "array", "items": { "$ref": "#/components/schemas/FlightSegment" } },
                "Services": { "type": "array", "items": { "type": "object" } },
                "Price": {
                  "type": "object",
                  "properties": {
                    "TotalAmount": { "type": "number" },
                    "CurrencyCode": { "type": "string" }
                  }
                }
              }
            }
          },
          "Travelers": { "type": "array", "items": { "type": "object" } },
          "Payments": { "type": "array", "items": { "type": "object" } },
          "TicketDocuments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "TicketNumber": { "type": "string" },
                "Type": { "type": "string" },
                "Status": { "type": "string" }
              }
            }
          },
          "CreatedAt": { "type": "string", "format": "date-time" },
          "ModifiedAt": { "type": "string", "format": "date-time" }
        }
      },
      "FareSubscriptionRequest": {
        "type": "object",
        "description": "Request payload for creating a FareNabber subscription.",
        "properties": {
          "Origin": { "type": "string", "description": "IATA origin airport/city code." },
          "Destination": { "type": "string", "description": "IATA destination airport/city code." },
          "DepartureDate": { "type": "string", "format": "date" },
          "ReturnDate": { "type": "string", "format": "date" },
          "MaxFare": { "type": "number", "description": "Maximum fare threshold for alerts." },
          "CurrencyCode": { "type": "string" },
          "CabinPreference": { "type": "string", "enum": ["Economy", "PremiumEconomy", "Business", "First"] },
          "NotificationEmail": { "type": "string", "format": "email" },
          "PassengerCount": { "type": "integer", "default": 1 }
        }
      },
      "FareSubscription": {
        "type": "object",
        "description": "A FareNabber fare-watch subscription.",
        "properties": {
          "SubscriptionId": { "type": "string", "description": "Unique subscription identifier." },
          "Origin": { "type": "string" },
          "Destination": { "type": "string" },
          "DepartureDate": { "type": "string", "format": "date" },
          "ReturnDate": { "type": "string", "format": "date" },
          "MaxFare": { "type": "number" },
          "CurrencyCode": { "type": "string" },
          "CabinPreference": { "type": "string" },
          "NotificationEmail": { "type": "string", "format": "email" },
          "Status": { "type": "string", "enum": ["Active", "Expired", "Triggered", "Cancelled"] },
          "CurrentLowestFare": { "type": "number" },
          "CreatedAt": { "type": "string", "format": "date-time" },
          "ExpiresAt": { "type": "string", "format": "date-time" }
        }
      },
      "TripProposalRequest": {
        "type": "object",
        "description": "Request payload for creating or updating a trip proposal.",
        "properties": {
          "Title": { "type": "string" },
          "ClientName": { "type": "string" },
          "ClientEmail": { "type": "string", "format": "email" },
          "Description": { "type": "string" },
          "Options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "OptionName": { "type": "string" },
                "FlightOffers": { "type": "array", "items": { "$ref": "#/components/schemas/FlightOffer" } },
                "HotelOptions": { "type": "array", "items": { "type": "object" } },
                "VehicleOptions": { "type": "array", "items": { "type": "object" } },
                "TotalEstimate": { "type": "number" },
                "CurrencyCode": { "type": "string" }
              }
            }
          }
        }
      },
      "TripProposal": {
        "type": "object",
        "description": "A trip proposal document containing travel options for a client.",
        "properties": {
          "ProposalId": { "type": "string", "description": "Unique proposal identifier." },
          "Title": { "type": "string" },
          "ClientName": { "type": "string" },
          "ClientEmail": { "type": "string", "format": "email" },
          "Description": { "type": "string" },
          "Status": { "type": "string", "enum": ["Draft", "Sent", "Viewed", "Accepted", "Booked", "Expired"] },
          "Options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "OptionId": { "type": "string" },
                "OptionName": { "type": "string" },
                "FlightOffers": { "type": "array", "items": { "$ref": "#/components/schemas/FlightOffer" } },
                "HotelOptions": { "type": "array", "items": { "type": "object" } },
                "VehicleOptions": { "type": "array", "items": { "type": "object" } },
                "TotalEstimate": { "type": "number" },
                "CurrencyCode": { "type": "string" },
                "PriceValid": { "type": "boolean" }
              }
            }
          },
          "CreatedAt": { "type": "string", "format": "date-time" },
          "ModifiedAt": { "type": "string", "format": "date-time" },
          "ExpiresAt": { "type": "string", "format": "date-time" }
        }
      },
      "Link": {
        "type": "object",
        "description": "HATEOAS link for pagination or related resources.",
        "properties": {
          "rel": { "type": "string" },
          "href": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Standard error response returned for 4xx and 5xx status codes.",
        "properties": {
          "status": { "type": "string", "description": "Error status (e.g., NotProcessed, Incomplete)." },
          "errorCode": { "type": "string", "description": "Machine-readable error code." },
          "message": { "type": "string", "description": "Human-readable error message." },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string" },
                "issue": { "type": "string" }
              }
            },
            "description": "Detailed field-level validation errors, if applicable."
          },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request was invalid or malformed.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication failed or token is expired.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "InternalServerError": {
        "description": "An unexpected server error occurred.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  }
}