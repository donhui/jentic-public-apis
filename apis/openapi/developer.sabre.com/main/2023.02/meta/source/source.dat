    "/v1.0.0/lists/utilities/geosearch/locations": {
      "post": {
        "operationId": "geoSearch",
        "tags": ["Utility"],
        "summary": "Geo Search",
        "description": "Searches for travel locations (airports, cities, points of interest) by geographic coordinates or keyword.",
        "parameters": [
          { "name": "mode", "in": "query", "required": true, "schema": { "type": "string", "enum": ["geosearch"] }, "description": "Operation mode." }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "GeoSearchRQ": {
                    "type": "object",
                    "properties": {
                      "GeoRef": {
                        "type": "object",
                        "properties": {
                          "GeoCode": {
                            "type": "object",
                            "properties": {
                              "Latitude": { "type": "number" },
                              "Longitude": { "type": "number" }
                            }
                          },
                          "Radius": { "type": "number" },
                          "UOM": { "type": "string", "enum": ["MI", "KM"] }
                        }
