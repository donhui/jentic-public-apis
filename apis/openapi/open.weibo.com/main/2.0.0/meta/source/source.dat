          },
          "screen_name": {
            "type": "string",
            "description": "Display name"
          },
          "name": {
            "type": "string",
            "description": "Friendly name"
          },
          "location": {
            "type": "string",
            "description": "User location"
          },
          "description": {
            "type": "string",
            "description": "User bio"
          },
          "profile_image_url": {
            "type": "string",
            "description": "Avatar URL"
          },
          "followers_count": {
            "type": "integer",
            "description": "Follower count"
          },
          "friends_count": {
            "type": "integer",
            "description": "Following count"
          },
          "statuses_count": {
            "type": "integer",
            "description": "Weibo count"
          },
          "verified": {
            "type": "boolean",
            "description": "Whether verified"
          },
          "gender": {
            "type": "string",
            "description": "Gender (m/f/n)"
          }
        }
      },
      "UserList": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "next_cursor": {
            "type": "integer"
          },
          "previous_cursor": {
            "type": "integer"
          },
          "total_number": {
            "type": "integer"
          }
        }
