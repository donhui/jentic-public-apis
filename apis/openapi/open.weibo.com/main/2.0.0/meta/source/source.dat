{
  "openapi": "3.0.3",
  "info": {
    "title": "Weibo API",
    "description": "Weibo open platform API for managing statuses, comments, users, friendships, and search.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://open.weibo.com/wiki/API%E6%96%87%E6%A1%A3_V2/en"
  },
  "servers": [
    {
      "url": "https://api.weibo.com/2",
      "description": "Weibo API v2 production server"
    }
  ],
  "tags": [
    {
      "name": "Statuses",
      "description": "Weibo status/post operations"
    },
    {
      "name": "Comments",
      "description": "Comment operations"
    },
    {
      "name": "Users",
      "description": "User profile operations"
    },
    {
      "name": "Friendships",
      "description": "Follow/unfollow operations"
    },
    {
      "name": "Search",
      "description": "Search operations"
    },
    {
      "name": "Suggestions",
      "description": "Recommendation operations"
    },
    {
      "name": "OAuth",
      "description": "OAuth 2.0 authorization"
    }
  ],
  "paths": {
    "/statuses/public_timeline.json": {
      "get": {
        "operationId": "getpublictimeline",
        "summary": "Get latest public weibos",
        "tags": [
          "Statuses"
        ],
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "description": "Number of records per page (default 50)",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default 1)",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "base_app",
            "in": "query",
            "description": "Filter to current app data (0=all, 1=current app)",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/statuses/friends_timeline.json": {
      "get": {
        "operationId": "getfriendstimeline",
        "summary": "Get authenticating user's and friends' latest weibos",
        "tags": [
          "Statuses"
        ],
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "description": "Number of records per page",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "base_app",
            "in": "query",
            "description": "Filter to current app data (0=all, 1=current app)",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/statuses/home_timeline.json": {
      "get": {
        "operationId": "gethometimeline",
        "summary": "Get user and friends' recent posts",
        "tags": [
          "Statuses"
        ],
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "description": "Number of records per page",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/statuses/update.json": {
      "post": {
        "operationId": "createstatus",
        "summary": "Post a new weibo",
        "tags": [
          "Statuses"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "description": "Content of the weibo (max 140 characters)"
                  },
                  "lat": {
                    "type": "number",
                    "description": "Latitude"
                  },
                  "long": {
                    "type": "number",
                    "description": "Longitude"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/statuses/upload.json": {
      "post": {
        "operationId": "uploadstatus",
        "summary": "Upload a picture with a new weibo",
        "tags": [
          "Statuses"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "status",
                  "pic"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "description": "Content of the weibo"
                  },
                  "pic": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image to upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status with image created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/statuses/repost.json": {
      "post": {
        "operationId": "repoststatus",
        "summary": "Repost a weibo",
        "tags": [
          "Statuses"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "id": {
                    "type": "integer",
                    "format": "int64",
                    "description": "ID of the weibo to repost"
                  },
                  "status": {
                    "type": "string",
                    "description": "Additional text to add"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Repost created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/statuses/destroy.json": {
      "post": {
        "operationId": "deletestatus",
        "summary": "Delete a weibo",
        "tags": [
          "Statuses"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "id": {
                    "type": "integer",
                    "format": "int64",
                    "description": "ID of the weibo to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/comments/show.json": {
      "get": {
        "operationId": "getcomments",
        "summary": "Return comments of one weibo",
        "tags": [
          "Comments"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "Weibo ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Number of records per page",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommentList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/comments/create.json": {
      "post": {
        "operationId": "createcomment",
        "summary": "Post a comment to a weibo",
        "tags": [
          "Comments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "comment"
                ],
                "properties": {
                  "id": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Weibo ID to comment on"
                  },
                  "comment": {
                    "type": "string",
                    "description": "Comment content"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/comments/destroy.json": {
      "post": {
        "operationId": "deletecomment",
        "summary": "Delete a comment",
        "tags": [
          "Comments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "cid"
                ],
                "properties": {
                  "cid": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Comment ID to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/comments/reply.json": {
      "post": {
        "operationId": "replytocomment",
        "summary": "Reply to a comment",
        "tags": [
          "Comments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "cid",
                  "comment"
                ],
                "properties": {
                  "id": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Weibo ID"
                  },
                  "cid": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Comment ID to reply to"
                  },
                  "comment": {
                    "type": "string",
                    "description": "Reply content"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reply created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users/show.json": {
      "get": {
        "operationId": "getuser",
        "summary": "Return user profile by user ID",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "uid",
            "in": "query",
            "description": "User ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "screen_name",
            "in": "query",
            "description": "User screen name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
