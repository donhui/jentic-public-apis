          },
          "request": {
            "type": "string",
            "description": "Request path"
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://api.weibo.com/2/oauth2/authorize",
            "tokenUrl": "https://api.weibo.com/2/oauth2/access_token",
