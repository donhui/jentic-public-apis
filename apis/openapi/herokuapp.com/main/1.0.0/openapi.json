{
  "openapi": "3.0.3",
  "info": {
    "title": "MeowFacts API",
    "version": "1.0.0",
    "description": "A free public API that returns random cat facts. Supports multiple languages and batch retrieval.",
    "x-jentic-source-url": "https://github.com/wh-iterabb-it/meowfacts"
  },
  "servers": [
    {
      "url": "https://meowfacts.herokuapp.com"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getCatFacts",
        "summary": "Get random cat facts",
        "description": "Returns one or more random cat facts. Supports filtering by count, specific ID, and language.",
        "tags": [
          "Facts"
        ],
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "description": "Number of facts to return.",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "id",
            "in": "query",
            "description": "Retrieve a specific fact by index.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "description": "Language code for translated facts (e.g., ukr, esp-mx, eng-us).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cat facts retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FactsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FactsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of cat fact strings."
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}