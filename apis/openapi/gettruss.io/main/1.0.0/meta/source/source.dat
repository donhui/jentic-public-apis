              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user details",
        "description": "Returns a single user by ID.",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/assignees": {
      "post": {
        "operationId": "addAssigneeByEmail",
        "summary": "Add assignee to project by email",
        "description": "Assigns a user to a project using their email address.",
        "tags": ["Assignees"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["project_id", "assignee_email"],
                "properties": {
                  "project_id": {
                    "type": "integer"
                  },
                  "assignee_email": {
                    "type": "string"
                  },
                  "role": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assignee added"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Project or user not found"
          }
        }
      }
    },
    "/assignees/create_by_contact_id": {
      "post": {
        "operationId": "addAssigneeByContactId",
        "summary": "Add assignee to project by contact ID",
        "description": "Assigns a contact to a project using their contact ID.",
        "tags": ["Assignees"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["project_id", "contact_id"],
                "properties": {
                  "project_id": {
                    "type": "integer"
                  },
                  "contact_id": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assignee added"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Project or contact not found"
          }
        }
      }
    },
    "/firms/project_status_dropdown": {
      "get": {
        "operationId": "listProjectStatuses",
        "summary": "List project statuses",
        "description": "Returns all project statuses for the firm.",
        "tags": ["Firms"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProjectStatus"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/entities": {
      "get": {
        "operationId": "listEntities",
        "summary": "List all entities",
        "description": "Returns all entities with pagination.",
        "tags": ["Entities"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
