    "/entities/search": {
      "get": {
        "operationId": "searchEntities",
        "summary": "Search and filter entities",
        "description": "Search entities with various filters and sorting options.",
        "tags": ["Entities"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entity_types[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["name", "client_id_number", "entity_type", "primary_contact", "created_at", "updated_at"]
            }
          },
          {
            "name": "direction",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"]
            }
          },
          {
            "name": "query_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["and", "or"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filtered entities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Entity"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
