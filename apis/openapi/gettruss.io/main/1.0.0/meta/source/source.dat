      "post": {
        "operationId": "directUpload",
        "summary": "Get signed URL for direct upload",
        "description": "Returns a signed URL for uploading a file directly to cloud storage.",
        "tags": ["Drive Folders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
