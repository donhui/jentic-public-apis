                "properties": {
                  "blob": {
                    "type": "object",
                    "required": ["filename", "content_type", "byte_size", "checksum"],
                    "properties": {
                      "filename": {
                        "type": "string"
                      },
                      "content_type": {
                        "type": "string"
                      },
                      "byte_size": {
                        "type": "integer"
                      },
                      "checksum": {
                        "type": "string"
                      },
                      "metadata": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload URL generated",
