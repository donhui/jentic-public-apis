    "/private/AddOrder": {
      "post": {
        "operationId": "addOrder",
        "summary": "Add Order",
        "description": "Place a new order.",
        "tags": ["Trading"],
        "security": [{ "ApiKeyAuth": [] }, { "ApiSignAuth": [] }],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/PrivateRequest" },
                  {
                    "type": "object",
                    "properties": {
                      "ordertype": { "type": "string", "description": "Order type.", "enum": ["market", "limit", "stop-loss", "take-profit", "stop-loss-limit", "take-profit-limit", "settle-position"] },
                      "type": { "type": "string", "description": "Order direction.", "enum": ["buy", "sell"] },
                      "volume": { "type": "string", "description": "Order quantity in terms of the base asset." },
                      "displayvol": { "type": "string", "description": "Used to create an iceberg order." },
                      "pair": { "type": "string", "description": "Asset pair." },
                      "price": { "type": "string", "description": "Price (limit price for limit orders, trigger for stop orders)." },
                      "price2": { "type": "string", "description": "Secondary price." },
                      "trigger": { "type": "string", "description": "Price signal type.", "enum": ["index", "last"] },
                      "leverage": { "type": "string", "description": "Amount of leverage desired." },
                      "reduce_only": { "type": "boolean", "description": "If true, order is reduce-only." },
                      "stptype": { "type": "string", "description": "Self trade prevention type.", "enum": ["cancel-newest", "cancel-oldest", "cancel-both"] },
                      "oflags": { "type": "string", "description": "Comma-delimited order flags (post, fcib, fciq, nompp, viqc)." },
                      "timeinforce": { "type": "string", "description": "Time in force.", "enum": ["GTC", "IOC", "GTD"] },
                      "starttm": { "type": "string", "description": "Scheduled start time." },
                      "expiretm": { "type": "string", "description": "Expiration time." },
                      "close[ordertype]": { "type": "string", "description": "Conditional close order type." },
                      "close[price]": { "type": "string", "description": "Conditional close order price." },
                      "close[price2]": { "type": "string", "description": "Conditional close order secondary price." },
                      "deadline": { "type": "string", "description": "RFC3339 timestamp deadline for order." },
                      "validate": { "type": "boolean", "description": "Validate inputs only, do not submit order." },
                      "userref": { "type": "integer", "description": "User reference id." }
                    },
                    "required": ["ordertype", "type", "pair"]
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          }
        }
      }
    },
