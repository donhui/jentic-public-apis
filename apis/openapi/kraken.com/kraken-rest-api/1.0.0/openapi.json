          {
            "name": "pair",
            "in": "query",
            "required": true,
            "description": "Asset pair to get data for.",
            "schema": { "type": "string" }
          },
          {
            "name": "since",
            "in": "query",
            "description": "Return trade data since given timestamp.",
            "schema": { "type": "string" }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Number of results (default: 1000).",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          }
        }
      }
    },
    "/public/Spread": {
      "get": {
        "operationId": "getRecentSpreads",
