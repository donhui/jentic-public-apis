          {
            "name": "pair",
            "in": "query",
            "required": true,
            "description": "Asset pair to get data for.",
            "schema": { "type": "string" }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Maximum number of asks/bids.",
            "schema": { "type": "integer" }
          }
