    "/private/Balance": {
      "post": {
        "operationId": "getAccountBalance",
        "summary": "Get Account Balance",
        "description": "Retrieve all cash balances, net of pending withdrawals.",
        "tags": ["Account Data"],
        "security": [{ "ApiKeyAuth": [] }, { "ApiSignAuth": [] }],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "nonce": { "type": "integer", "description": "Nonce used in construction of API-Sign header." }
                },
                "required": ["nonce"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
