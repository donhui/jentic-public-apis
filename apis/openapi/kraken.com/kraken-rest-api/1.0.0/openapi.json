  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "API-Key",
        "description": "Your Kraken API key."
      },
      "ApiSignAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "API-Sign",
        "description": "HMAC-SHA512 signature of the request using your API secret."
      }
    },
    "schemas": {
      "GenericResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Array of error messages."
          },
          "result": {
            "description": "Response data (varies by endpoint)."
          }
        }
      },
      "PrivateRequest": {
        "type": "object",
        "properties": {
          "nonce": {
            "type": "integer",
            "description": "Nonce used in construction of API-Sign header. Must be an always increasing unsigned 64-bit integer."
          },
          "otp": {
            "type": "string",
            "description": "Two-factor authentication password (if enabled)."
          }
        },
        "required": ["nonce"]
      }
    }
  },
  "tags": [
    { "name": "Market Data", "description": "Public market data endpoints." },
    { "name": "Account Data", "description": "Private account data endpoints requiring authentication." },
    { "name": "Trading", "description": "Private trading endpoints requiring authentication." },
    { "name": "Funding", "description": "Private funding endpoints requiring authentication." },
    { "name": "Earn", "description": "Private earn/staking endpoints requiring authentication." }
  ]
}