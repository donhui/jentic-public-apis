    "/private/CancelAllOrdersAfter": {
      "post": {
        "operationId": "cancelAllOrdersAfter",
        "summary": "Cancel All Orders After X",
        "description": "Set, extend, or unset a dead man's switch timer to cancel all orders after a timeout.",
        "tags": ["Trading"],
        "security": [{ "ApiKeyAuth": [] }, { "ApiSignAuth": [] }],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
