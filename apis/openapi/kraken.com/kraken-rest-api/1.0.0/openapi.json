                  {
                    "type": "object",
                    "properties": {
                      "trades": { "type": "boolean" },
                      "userref": { "type": "integer" },
                      "start": { "type": "integer", "description": "Starting Unix timestamp or order tx ID." },
                      "end": { "type": "integer", "description": "Ending Unix timestamp or order tx ID." },
                      "ofs": { "type": "integer", "description": "Result offset for pagination." }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
