{
  "openapi": "3.1.0",
  "info": {
    "title": "Kraken Spot REST API",
    "description": "Kraken cryptocurrency exchange REST API for market data, account management, trading, and funding operations.",
    "version": "1.0.0",
    "contact": {
      "name": "Kraken Support",
      "url": "https://support.kraken.com"
    },
    "termsOfService": "https://www.kraken.com/legal"
  },
  "servers": [
    {
      "url": "https://api.kraken.com/0",
      "description": "Kraken REST API"
    }
  ],
  "security": [],
  "paths": {
    "/public/Time": {
      "get": {
        "operationId": "getServerTime",
        "summary": "Get Server Time",
        "description": "Get the server's time.",
        "tags": ["Market Data"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "array", "items": { "type": "string" } },
                    "result": {
                      "type": "object",
                      "properties": {
                        "unixtime": { "type": "integer", "description": "Unix timestamp" },
                        "rfc1123": { "type": "string", "description": "RFC 1123 time format" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/public/SystemStatus": {
      "get": {
        "operationId": "getSystemStatus",
        "summary": "Get System Status",
        "description": "Get the current system status or trading mode.",
        "tags": ["Market Data"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericResponse"
                }
              }
            }
          }
        }
      }
    },
    "/public/Assets": {
      "get": {
        "operationId": "getAssetInfo",
        "summary": "Get Asset Info",
        "description": "Get information about the assets available for trading on Kraken.",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "asset",
            "in": "query",
            "description": "Comma-delimited list of assets to get info on.",
            "schema": { "type": "string" }
          },
          {
            "name": "aclass",
            "in": "query",
            "description": "Asset class (default: currency).",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          }
        }
      }
    },
    "/public/AssetPairs": {
      "get": {
        "operationId": "getTradableAssetPairs",
        "summary": "Get Tradable Asset Pairs",
        "description": "Get tradable asset pairs with their details including fees, leverage, and margins.",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "pair",
            "in": "query",
            "description": "Comma-delimited list of asset pairs to get info on.",
            "schema": { "type": "string" }
          },
          {
            "name": "info",
            "in": "query",
            "description": "Info to retrieve: info (all, default), leverage, fees, margin.",
            "schema": { "type": "string", "enum": ["info", "leverage", "fees", "margin"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          }
        }
      }
    },
    "/public/Ticker": {
      "get": {
        "operationId": "getTickerInformation",
        "summary": "Get Ticker Information",
        "description": "Get ticker information for given asset pairs.",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "pair",
            "in": "query",
            "required": true,
            "description": "Comma-delimited list of asset pairs to get info on.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          }
        }
      }
    },
    "/public/OHLC": {
      "get": {
        "operationId": "getOHLCData",
        "summary": "Get OHLC Data",
        "description": "Get OHLC (open, high, low, close) data for a given asset pair.",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "pair",
            "in": "query",
            "required": true,
            "description": "Asset pair to get data for.",
            "schema": { "type": "string" }
          },
          {
            "name": "interval",
            "in": "query",
            "description": "Time frame interval in minutes (default: 1).",
            "schema": { "type": "integer", "enum": [1, 5, 15, 30, 60, 240, 1440, 10080, 21600] }
          },
          {
            "name": "since",
            "in": "query",
            "description": "Return committed OHLC data since given Unix timestamp.",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GenericResponse" }
              }
            }
          }
        }
      }
    },
    "/public/Depth": {
      "get": {
        "operationId": "getOrderBook",
