{
  "openapi": "3.0.3",
  "info": {
    "title": "PDFmyURL API",
    "description": "Professional HTML to PDF converter API for webpage or HTML to PDF conversion. Converts any URL or raw HTML to high-quality PDF documents with options for layout, headers, footers, watermarks, encryption, and more.",
    "version": "1.0.0",
    "contact": {
      "name": "PDFmyURL",
      "url": "https://pdfmyurl.com"
    },
    "x-jentic-source-url": "https://pdfmyurl.com/plans?tab=api"
  },
  "servers": [
    {
      "url": "https://pdfmyurl.com",
      "description": "PDFmyURL API server"
    }
  ],
  "security": [
    {
      "licenseKey": []
    }
  ],
  "paths": {
    "/api": {
      "get": {
        "operationId": "convertUrlToPdf",
        "summary": "Convert a URL to PDF",
        "description": "Converts a webpage at the specified URL to a PDF document. Supports numerous options for page dimensions, conversion settings, headers/footers, watermarks, and security.",
        "parameters": [
          {
            "name": "license",
            "in": "query",
            "required": true,
            "description": "Your PDFmyURL API license key.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "url",
            "in": "query",
            "required": false,
            "description": "The URL of the webpage to convert. Required if 'html' is not provided.",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "html",
            "in": "query",
            "required": false,
            "description": "Raw HTML code to convert. Required if 'url' is not provided.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "description": "Page size (e.g., A4, Letter).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orientation",
            "in": "query",
            "required": false,
            "description": "Page orientation.",
            "schema": {
              "type": "string",
              "enum": ["portrait", "landscape"]
            }
          },
          {
            "name": "width",
            "in": "query",
            "required": false,
            "description": "Custom page width in the specified unit.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "height",
            "in": "query",
            "required": false,
            "description": "Custom page height in the specified unit. If width is set but not height, generates one long single page PDF.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "top",
            "in": "query",
            "required": false,
            "description": "Top margin in the specified unit.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "bottom",
            "in": "query",
            "required": false,
            "description": "Bottom margin.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "left",
            "in": "query",
            "required": false,
            "description": "Left margin.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "right",
            "in": "query",
            "required": false,
            "description": "Right margin.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "unit",
            "in": "query",
            "required": false,
            "description": "Measurement unit for margins and dimensions.",
            "schema": {
              "type": "string",
              "enum": ["mm", "cm", "in", "px", "pt"],
              "default": "mm"
            }
          },
          {
            "name": "screen_width",
            "in": "query",
            "required": false,
            "description": "Viewport screen width for rendering.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "screen_height",
            "in": "query",
            "required": false,
            "description": "Viewport screen height for rendering.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "zoom_factor",
            "in": "query",
            "required": false,
            "description": "Zoom factor during conversion (0.1 to 2).",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "content",
            "in": "query",
            "required": false,
            "description": "Controls which content of the page to convert or exclude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pdf_creator_version",
            "in": "query",
            "required": false,
            "description": "PDF creator version to use for conversion.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PDF document generated successfully.",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing license key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": ["PDF Conversion"]
      },
      "post": {
        "operationId": "convertHtmlToPdf",
        "summary": "Convert HTML or URL to PDF via POST",
        "description": "Converts HTML content or a URL to PDF via POST request. Supports the same parameters as the GET endpoint.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "license": {
                    "type": "string",
                    "description": "Your API license key."
                  },
                  "url": {
                    "type": "string",
                    "description": "URL of the webpage to convert."
                  },
                  "html": {
                    "type": "string",
                    "description": "Raw HTML to convert."
                  },
                  "page_size": {
                    "type": "string"
                  },
                  "orientation": {
                    "type": "string",
                    "enum": ["portrait", "landscape"]
                  }
                },
                "required": ["license"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF document generated successfully.",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": ["PDF Conversion"]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "licenseKey": {
        "type": "apiKey",
        "in": "query",
        "name": "license",
        "description": "PDFmyURL API license key."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message."
          },
          "code": {
            "type": "integer",
            "description": "Error code."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "PDF Conversion",
      "description": "HTML/URL to PDF conversion endpoints"
    }
  ]
}