            "schema": {"type": "integer"}
          },
          {
            "name": "agent_id",
            "in": "query",
            "description": "Filter by agent ID",
            "schema": {"type": "integer"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of actions",
