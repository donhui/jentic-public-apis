  "components": {
    "securitySchemes": {
      "oauth2ClientCredentials": {
        "type": "oauth2",
        "description": "OAuth2 Client Credentials authentication. Obtain tokens via the /auth/token endpoint.",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "/auth/token",
            "scopes": {
              "all": "Full access to all API resources",
              "read:tickets": "Read access to tickets",
              "edit:tickets": "Write access to tickets",
              "read:customers": "Read access to clients/customers"
            }
          }
        }
      }
    },
    "parameters": {
      "PageSize": {
        "name": "page_size",
        "in": "query",
        "description": "Number of results per page",
        "schema": {"type": "integer", "default": 50}
      },
      "PageNo": {
        "name": "page_no",
        "in": "query",
        "description": "Page number to return",
        "schema": {"type": "integer", "default": 1}
      },
      "Order": {
        "name": "order",
        "in": "query",
        "description": "Field to order results by",
        "schema": {"type": "string"}
      },
      "OrderDesc": {
        "name": "orderdesc",
        "in": "query",
        "description": "Order results in descending order",
        "schema": {"type": "boolean", "default": false}
      },
      "Search": {
        "name": "search",
        "in": "query",
        "description": "Search term to filter results",
        "schema": {"type": "string"}
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {"type": "string", "description": "Error message"},
          "error_description": {"type": "string", "description": "Detailed error description"}
        }
      },
      "TokenRequest": {
        "type": "object",
        "required": ["grant_type", "client_id", "client_secret"],
        "properties": {
          "grant_type": {"type": "string", "enum": ["client_credentials"]},
          "client_id": {"type": "string", "description": "Application client ID"},
          "client_secret": {"type": "string", "description": "Application client secret"},
          "scope": {"type": "string", "description": "Requested scopes", "example": "all"}
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {"type": "string"},
          "token_type": {"type": "string", "example": "bearer"},
          "expires_in": {"type": "integer", "description": "Token expiry in seconds"}
        }
      },
      "Ticket": {
        "type": "object",
        "properties": {
          "id": {"type": "integer", "format": "int64"},
          "summary": {"type": "string"},
          "details": {"type": "string"},
          "status_id": {"type": "integer"},
          "tickettype_id": {"type": "integer"},
          "client_id": {"type": "integer"},
          "client_name": {"type": "string"},
          "agent_id": {"type": "integer"},
          "site_id": {"type": "integer"},
          "user_id": {"type": "integer"},
          "user_name": {"type": "string"},
          "priority_id": {"type": "integer"},
          "sla_id": {"type": "integer"},
          "category_1": {"type": "string"},
          "category_2": {"type": "string"},
          "category_3": {"type": "string"},
          "dateoccurred": {"type": "string", "format": "date-time"},
          "datecreated": {"type": "string", "format": "date-time"},
          "lastupdate": {"type": "string", "format": "date-time"},
          "deadlinedate": {"type": "string", "format": "date-time"},
          "customfields": {"type": "array", "items": {"$ref": "#/components/schemas/CustomField"}}
        }
      },
      "TicketCreate": {
        "type": "object",
        "required": ["summary"],
        "properties": {
          "summary": {"type": "string"},
          "details": {"type": "string"},
          "tickettype_id": {"type": "integer"},
          "client_id": {"type": "integer"},
          "agent_id": {"type": "integer"},
          "site_id": {"type": "integer"},
          "user_id": {"type": "integer"},
          "priority_id": {"type": "integer"},
          "status_id": {"type": "integer"},
          "category_1": {"type": "string"},
          "category_2": {"type": "string"},
          "category_3": {"type": "string"},
          "customfields": {"type": "array", "items": {"$ref": "#/components/schemas/CustomField"}}
        }
      },
      "TicketListResponse": {
        "type": "object",
        "properties": {
          "record_count": {"type": "integer"},
          "tickets": {"type": "array", "items": {"$ref": "#/components/schemas/Ticket"}}
        }
      },
      "Action": {
        "type": "object",
        "properties": {
          "id": {"type": "integer", "format": "int64"},
          "ticket_id": {"type": "integer"},
          "who": {"type": "string"},
          "who_agentid": {"type": "integer"},
          "note": {"type": "string"},
          "note_html": {"type": "string"},
          "hiddenfromuser": {"type": "boolean"},
          "actiontime": {"type": "string", "format": "date-time"},
          "outcome": {"type": "string"}
        }
      },
