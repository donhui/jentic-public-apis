{
  "openapi": "3.0.3",
  "info": {
    "title": "HaloPSA API",
    "description": "HaloPSA REST API for Professional Service Automation. Provides endpoints for managing tickets, clients, agents, assets, contracts, invoices, projects, opportunities, and other PSA resources. Authentication uses OAuth2 Client Credentials flow.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://haloacademy.halopsa.com/api/swagger/index.html",
    "contact": {
      "name": "HaloPSA Support",
      "url": "https://halopsa.com"
    }
  },
  "servers": [
    {
      "url": "https://{instance}.halopsa.com/api",
      "description": "HaloPSA instance API endpoint",
      "variables": {
        "instance": {
          "default": "your-instance",
          "description": "Your HaloPSA instance subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "oauth2ClientCredentials": []
    }
  ],
  "paths": {
    "/auth/token": {
      "post": {
        "operationId": "getAuthToken",
        "summary": "Obtain access token",
        "description": "Authenticate using OAuth2 Client Credentials flow to obtain an access token.",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token issued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid credentials or parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid client credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tickets": {
      "get": {
        "operationId": "getTickets",
        "summary": "List tickets",
        "description": "Retrieves a list of tickets with optional filtering, pagination, and sorting.",
        "tags": ["Tickets"],
        "parameters": [
          {"$ref": "#/components/parameters/PageSize"},
          {"$ref": "#/components/parameters/PageNo"},
          {"$ref": "#/components/parameters/Order"},
          {"$ref": "#/components/parameters/OrderDesc"},
          {"$ref": "#/components/parameters/Search"},
          {
            "name": "client_id",
            "in": "query",
            "description": "Filter by client ID",
            "schema": {"type": "integer"}
          },
          {
            "name": "agent_id",
            "in": "query",
            "description": "Filter by assigned agent ID",
            "schema": {"type": "integer"}
          },
          {
            "name": "status_id",
            "in": "query",
            "description": "Filter by status ID",
            "schema": {"type": "integer"}
          },
          {
            "name": "tickettype_id",
            "in": "query",
            "description": "Filter by ticket type ID",
            "schema": {"type": "integer"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of tickets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createTicket",
        "summary": "Create ticket",
        "description": "Creates one or more new tickets.",
        "tags": ["Tickets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TicketCreate"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket(s) created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Ticket"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tickets/{ticketId}": {
      "get": {
        "operationId": "getTicketById",
        "summary": "Get ticket by ID",
        "description": "Retrieves a single ticket by its ID.",
        "tags": ["Tickets"],
        "parameters": [
          {
            "name": "ticketId",
            "in": "path",
            "required": true,
            "description": "The ticket ID",
            "schema": {"type": "integer", "format": "int64"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticket"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteTicket",
        "summary": "Delete ticket",
        "description": "Deletes a ticket by its ID.",
        "tags": ["Tickets"],
        "parameters": [
          {
            "name": "ticketId",
            "in": "path",
            "required": true,
            "description": "The ticket ID",
            "schema": {"type": "integer", "format": "int64"}
          }
        ],
        "responses": {
          "200": {
            "description": "Ticket deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/actions": {
      "get": {
        "operationId": "getActions",
        "summary": "List actions",
        "description": "Retrieves a list of actions (updates/notes on tickets).",
        "tags": ["Actions"],
        "parameters": [
          {"$ref": "#/components/parameters/PageSize"},
          {"$ref": "#/components/parameters/PageNo"},
          {
            "name": "ticket_id",
