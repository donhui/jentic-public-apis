  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer token authentication"
      }
    },
    "parameters": {
      "grantIdParam": {
        "name": "grantId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the grant",
        "schema": { "type": "string" }
      },
      "messageIdParam": {
        "name": "messageId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the message",
        "schema": { "type": "string" }
      },
      "attachmentIdParam": {
        "name": "attachmentId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the attachment",
        "schema": { "type": "string" }
      },
      "draftIdParam": {
        "name": "draftId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the draft",
        "schema": { "type": "string" }
      },
      "threadIdParam": {
        "name": "threadId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the thread",
        "schema": { "type": "string" }
      },
      "folderIdParam": {
        "name": "folderId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the folder",
        "schema": { "type": "string" }
      },
      "calendarIdParam": {
        "name": "calendarId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the calendar",
        "schema": { "type": "string" }
      },
      "eventIdParam": {
        "name": "eventId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the event",
        "schema": { "type": "string" }
      },
      "contactIdParam": {
        "name": "contactId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the contact",
        "schema": { "type": "string" }
      },
      "webhookIdParam": {
        "name": "webhookId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the webhook",
        "schema": { "type": "string" }
      },
      "providerParam": {
        "name": "provider",
        "in": "path",
        "required": true,
        "description": "The provider name (e.g., google, microsoft, imap)",
        "schema": { "type": "string", "enum": ["google", "microsoft", "imap"] }
      },
      "limitParam": {
        "name": "limit",
        "in": "query",
        "description": "Maximum number of results to return",
        "schema": { "type": "integer", "default": 50, "maximum": 200 }
      },
      "pageTokenParam": {
        "name": "page_token",
        "in": "query",
        "description": "Token for pagination to retrieve the next page of results",
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "request_id": {
            "type": "string",
            "description": "Unique identifier for the request"
          },
          "error": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Error type identifier"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message"
              },
              "provider_error": {
                "type": "object",
                "description": "Error details from the upstream provider",
                "properties": {
                  "type": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            },
            "required": ["type", "message"]
          }
        },
        "required": ["request_id", "error"]
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "request_id": {
            "type": "string",
            "description": "Unique identifier for the request"
          }
        }
      },
      "EmailParticipant": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name of the participant"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the participant"
          }
        },
        "required": ["email"]
      },
      "OAuthAuthRequest": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "description": "The authentication provider",
            "enum": ["google", "microsoft", "imap"]
          },
          "redirect_uri": {
            "type": "string",
            "format": "uri",
            "description": "The redirect URI after authentication"
          },
          "login_hint": {
            "type": "string",
            "description": "Pre-fill the email address for the user"
          },
          "state": {
            "type": "string",
            "description": "Opaque state parameter passed back to redirect URI"
          },
          "scope": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of scopes to request"
          }
        },
        "required": ["provider", "redirect_uri"]
      },
      "OAuthAuthResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The URL to redirect the user to for authentication"
          }
        }
      },
      "TokenExchangeRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "The authorization code to exchange"
          },
          "redirect_uri": {
            "type": "string",
            "format": "uri",
            "description": "The redirect URI used in the initial auth request"
          },
          "grant_type": {
            "type": "string",
            "description": "The grant type",
            "enum": ["authorization_code"]
          }
        },
        "required": ["code", "redirect_uri"]
      },
      "TokenExchangeResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The access token"
          },
          "grant_id": {
            "type": "string",
            "description": "The grant ID associated with this token"
          },
          "token_type": {
            "type": "string",
            "description": "The token type (bearer)"
          },
          "expires_in": {
            "type": "integer",
            "description": "Token expiration time in seconds"
          },
          "scope": {
            "type": "string",
            "description": "Granted scopes"
          },
          "email": {
            "type": "string",
            "description": "The email address of the authenticated user"
          },
          "provider": {
            "type": "string",
            "description": "The authentication provider"
          }
        }
      },
      "RevokeTokenRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "The token to revoke"
          }
        },
        "required": ["token"]
      },
      "Grant": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
