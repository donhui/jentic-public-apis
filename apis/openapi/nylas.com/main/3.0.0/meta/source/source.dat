              "type": "object",
              "properties": {
                "im_address": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" }
              }
            }
          }
        }
      },
