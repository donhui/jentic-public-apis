      "Webhook": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique webhook identifier" },
          "description": { "type": "string" },
          "trigger_types": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Event types that trigger this webhook (e.g., message.created, event.created, contact.updated)"
          },
          "webhook_url": { "type": "string", "format": "uri", "description": "URL to receive webhook notifications" },
          "webhook_secret": { "type": "string", "description": "Secret used to verify webhook signatures" },
          "status": {
            "type": "string",
            "enum": ["active", "pause", "failing"],
            "description": "Current webhook status"
          },
          "notification_email_addresses": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Emails to notify on webhook failures"
          },
          "created_at": { "type": "integer" },
          "updated_at": { "type": "integer" }
        }
      },
