          "middle_name": { "type": "string" },
          "surname": { "type": "string", "description": "Last name" },
          "birthday": { "type": "string", "description": "Birthday in YYYY-MM-DD format" },
          "company_name": { "type": "string" },
          "job_title": { "type": "string" },
          "notes": { "type": "string" },
          "nickname": { "type": "string" },
          "suffix": { "type": "string" },
          "picture_url": { "type": "string", "format": "uri" },
          "source": { "type": "string" },
          "emails": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContactEmail" }
          },
          "phone_numbers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContactPhoneNumber" }
          },
