          "master_event_id": { "type": "string" },
          "html_link": { "type": "string", "format": "uri" },
          "created_at": { "type": "integer" },
          "updated_at": { "type": "integer" }
        }
      },
      "EventList": {
        "type": "object",
        "properties": {
          "request_id": { "type": "string" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Event" }
          },
          "next_cursor": { "type": "string" }
        }
      },
