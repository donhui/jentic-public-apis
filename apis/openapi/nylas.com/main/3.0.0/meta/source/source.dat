{
  "openapi": "3.0.3",
  "info": {
    "title": "Nylas API",
    "description": "Nylas is a platform that provides unified APIs for email, calendar, and contacts. The Nylas API v3 enables developers to integrate email sending/reading, calendar management, and contact management into their applications.",
    "version": "3.0.0",
    "x-jentic-source-url": "https://developer.nylas.com/docs/api/v3/"
  },
  "servers": [
    {
      "url": "https://api.us.nylas.com",
      "description": "US region"
    },
    {
      "url": "https://api.eu.nylas.com",
      "description": "EU region"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "OAuth flow, token management, grants, and connectors" },
    { "name": "Messages", "description": "Read, send, update, and delete email messages and attachments" },
    { "name": "Drafts", "description": "Create, read, update, delete, and send email drafts" },
    { "name": "Threads", "description": "List, read, and update email threads" },
    { "name": "Folders", "description": "Manage email folders and labels" },
    { "name": "Calendars", "description": "Manage calendars and check free/busy availability" },
    { "name": "Events", "description": "Manage calendar events and RSVPs" },
    { "name": "Contacts", "description": "Manage contacts" },
    { "name": "Webhooks", "description": "Manage webhook subscriptions for real-time notifications" }
  ],
  "paths": {
    "/v3/connect/auth": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "startOAuthFlow",
        "summary": "Start OAuth flow",
        "description": "Initiates the OAuth 2.0 authentication flow to connect a user's account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OAuthAuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OAuth flow initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthAuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/connect/token": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "exchangeCodeForToken",
        "summary": "Exchange code for token",
        "description": "Exchanges an authorization code for an access token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenExchangeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token exchange successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenExchangeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/connect/revoke": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "revokeToken",
        "summary": "Revoke token",
        "description": "Revokes an access token, ending the associated session.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RevokeTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token revoked successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants": {
      "get": {
        "tags": ["Authentication"],
        "operationId": "listGrants",
        "summary": "List grants",
        "description": "Returns a list of all grants associated with the application.",
        "parameters": [
          { "$ref": "#/components/parameters/limitParam" },
          { "$ref": "#/components/parameters/pageTokenParam" }
        ],
        "responses": {
          "200": {
            "description": "List of grants",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GrantList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants/{grantId}": {
      "get": {
        "tags": ["Authentication"],
        "operationId": "getGrant",
        "summary": "Get grant",
        "description": "Returns a specific grant by ID.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" }
        ],
        "responses": {
          "200": {
            "description": "Grant details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GrantResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Authentication"],
        "operationId": "deleteGrant",
        "summary": "Delete grant",
        "description": "Deletes a specific grant by ID.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" }
        ],
        "responses": {
          "200": {
            "description": "Grant deleted successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/connectors": {
      "get": {
        "tags": ["Authentication"],
        "operationId": "listConnectors",
        "summary": "List connectors",
        "description": "Returns a list of all connectors configured for the application.",
        "parameters": [
          { "$ref": "#/components/parameters/limitParam" },
          { "$ref": "#/components/parameters/pageTokenParam" }
        ],
        "responses": {
          "200": {
            "description": "List of connectors",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectorList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Authentication"],
        "operationId": "createConnector",
        "summary": "Create connector",
        "description": "Creates a new connector for a specific provider.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConnectorCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connector created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/connectors/{provider}": {
      "get": {
        "tags": ["Authentication"],
        "operationId": "getConnector",
        "summary": "Get connector",
        "description": "Returns a specific connector by provider name.",
        "parameters": [
          { "$ref": "#/components/parameters/providerParam" }
        ],
        "responses": {
          "200": {
            "description": "Connector details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Authentication"],
        "operationId": "updateConnector",
        "summary": "Update connector",
        "description": "Updates an existing connector for a specific provider.",
        "parameters": [
          { "$ref": "#/components/parameters/providerParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConnectorUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connector updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Authentication"],
        "operationId": "deleteConnector",
        "summary": "Delete connector",
        "description": "Deletes a connector for a specific provider.",
        "parameters": [
          { "$ref": "#/components/parameters/providerParam" }
        ],
        "responses": {
          "200": {
            "description": "Connector deleted successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants/{grantId}/messages": {
      "get": {
        "tags": ["Messages"],
        "operationId": "listMessages",
        "summary": "List messages",
        "description": "Returns a list of messages for the specified grant.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/limitParam" },
          { "$ref": "#/components/parameters/pageTokenParam" },
          {
            "name": "subject",
            "in": "query",
            "description": "Filter messages by subject",
            "schema": { "type": "string" }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Filter messages by sender email address",
            "schema": { "type": "string" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "Filter messages by recipient email address",
            "schema": { "type": "string" }
          },
          {
            "name": "unread",
            "in": "query",
            "description": "Filter by read/unread status",
            "schema": { "type": "boolean" }
          },
          {
            "name": "starred",
            "in": "query",
            "description": "Filter by starred status",
            "schema": { "type": "boolean" }
          },
          {
            "name": "thread_id",
            "in": "query",
            "description": "Filter messages by thread ID",
            "schema": { "type": "string" }
          },
          {
            "name": "received_before",
            "in": "query",
            "description": "Filter messages received before this Unix timestamp",
            "schema": { "type": "integer" }
          },
          {
            "name": "received_after",
            "in": "query",
            "description": "Filter messages received after this Unix timestamp",
            "schema": { "type": "integer" }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Specify which fields to return (e.g., 'include_headers')",
            "schema": { "type": "string" }
          },
          {
            "name": "in",
            "in": "query",
            "description": "Filter messages by folder ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants/{grantId}/messages/{messageId}": {
      "get": {
        "tags": ["Messages"],
        "operationId": "getMessage",
        "summary": "Get message",
        "description": "Returns a specific message by ID.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/messageIdParam" }
        ],
        "responses": {
          "200": {
            "description": "Message details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Messages"],
        "operationId": "updateMessage",
        "summary": "Update message",
        "description": "Updates a specific message (e.g., mark as read, star, move to folder).",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/messageIdParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MessageUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Messages"],
        "operationId": "deleteMessage",
        "summary": "Delete message",
        "description": "Deletes a specific message by ID.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/messageIdParam" }
        ],
        "responses": {
          "200": {
            "description": "Message deleted successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants/{grantId}/messages/send": {
      "post": {
        "tags": ["Messages"],
        "operationId": "sendMessage",
        "summary": "Send message",
        "description": "Sends a new email message.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants/{grantId}/messages/{messageId}/attachments": {
      "get": {
        "tags": ["Messages"],
        "operationId": "listAttachments",
        "summary": "List attachments",
        "description": "Returns a list of attachments for a specific message.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/messageIdParam" }
        ],
        "responses": {
          "200": {
            "description": "List of attachments",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants/{grantId}/messages/{messageId}/attachments/{attachmentId}": {
      "get": {
        "tags": ["Messages"],
        "operationId": "getAttachment",
        "summary": "Get attachment",
        "description": "Returns metadata for a specific attachment.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/messageIdParam" },
          { "$ref": "#/components/parameters/attachmentIdParam" }
        ],
        "responses": {
          "200": {
            "description": "Attachment metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Attachment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants/{grantId}/messages/{messageId}/attachments/{attachmentId}/download": {
      "get": {
        "tags": ["Messages"],
        "operationId": "downloadAttachment",
        "summary": "Download attachment",
        "description": "Downloads the binary content of a specific attachment.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/messageIdParam" },
          { "$ref": "#/components/parameters/attachmentIdParam" }
        ],
        "responses": {
          "200": {
            "description": "Attachment binary content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v3/grants/{grantId}/drafts": {
      "get": {
        "tags": ["Drafts"],
        "operationId": "listDrafts",
        "summary": "List drafts",
        "description": "Returns a list of drafts for the specified grant.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/limitParam" },
          { "$ref": "#/components/parameters/pageTokenParam" }
        ],
        "responses": {
          "200": {
            "description": "List of drafts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DraftList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Drafts"],
        "operationId": "createDraft",
        "summary": "Create draft",
        "description": "Creates a new email draft.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DraftCreate"
