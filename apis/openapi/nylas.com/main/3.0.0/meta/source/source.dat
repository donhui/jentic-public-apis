    "/v3/grants/{grantId}/threads": {
      "get": {
        "tags": ["Threads"],
        "operationId": "listThreads",
        "summary": "List threads",
        "description": "Returns a list of email threads for the specified grant.",
        "parameters": [
          { "$ref": "#/components/parameters/grantIdParam" },
          { "$ref": "#/components/parameters/limitParam" },
          { "$ref": "#/components/parameters/pageTokenParam" },
          {
            "name": "subject",
            "in": "query",
            "description": "Filter threads by subject",
            "schema": { "type": "string" }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Filter threads by sender email address",
            "schema": { "type": "string" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "Filter threads by recipient email address",
            "schema": { "type": "string" }
          },
          {
            "name": "unread",
            "in": "query",
            "description": "Filter by read/unread status",
            "schema": { "type": "boolean" }
          },
          {
            "name": "starred",
            "in": "query",
            "description": "Filter by starred status",
            "schema": { "type": "boolean" }
          },
          {
            "name": "latest_message_before",
            "in": "query",
            "description": "Filter threads where latest message is before this Unix timestamp",
            "schema": { "type": "integer" }
          },
          {
            "name": "latest_message_after",
            "in": "query",
            "description": "Filter threads where latest message is after this Unix timestamp",
            "schema": { "type": "integer" }
          },
          {
            "name": "in",
            "in": "query",
            "description": "Filter threads by folder ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of threads",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThreadList"
                }
              }
            }
          },
          "400": {
