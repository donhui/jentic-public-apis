        "type": "object",
        "properties": {
          "request_id": { "type": "string" },
          "data": { "$ref": "#/components/schemas/Event" }
        }
      },
      "EventCreate": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "when": { "$ref": "#/components/schemas/EventWhen" },
          "participants": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EventParticipant" }
          },
          "busy": { "type": "boolean" },
          "visibility": { "type": "string", "enum": ["public", "private"] },
          "recurrence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "conferencing": { "$ref": "#/components/schemas/EventConferencing" },
          "reminders": {
            "type": "object",
            "properties": {
              "use_default": { "type": "boolean" },
              "overrides": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "reminder_minutes": { "type": "integer" },
                    "reminder_method": { "type": "string", "enum": ["email", "popup"] }
                  }
                }
              }
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "required": ["title", "when"]
      },
      "EventUpdate": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
