{
  "openapi": "3.0.0",
  "info": {
    "version": "1.1.2",
    "title": "ADAS - A2B - Common - Services",
    "description": "Universelle Basisschnittstelle zur Anbindung eines externen Systems an die Warenwirtschaftssysteme (WaWi) deutscher Apotheken",
    "contact": {
      "name": "ADAS A2B Common Service",
      "url": "https://a2b.adas.de",
      "email": "a2b@adas.de"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.1.2/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/ADAS-A2B-Services/adas-a2b-common/1.1.2"
    },
    {
      "description": "ADAS-A2B-API Referenzsystem",
      "url": "https://portal.adas.de/a2bservice/common/1.1.2"
    }
  ],
  "tags": [
    {
      "name": "common",
      "description": "Basis-Schnittstelle f\u00fcr einen Health-Check"
    }
  ],
  "paths": {
    "/health": {
      "post": {
        "summary": "Apotheke pr\u00fcft die Verf\u00fcgbarkeit eines ADAS-A2B-Webservices",
        "description": "Erm\u00f6glicht eine Abfrage der Verf\u00fcgbarkeit eines ADAS-A2B-Webservices",
        "operationId": "post_health",
        "tags": [
          "common"
        ],
        "requestBody": {
          "description": "Vorhandene Informationen, die f\u00fcr eine Pr\u00fcfung der Verf\u00fcgbarkeit eines ADAS-A2B-Webservices relevant sind.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "meta",
                  "data"
                ],
                "properties": {
                  "meta": {
                    "$ref": "#/components/schemas/RequestMetaDTO"
                  },
                  "data": {
                    "$ref": "#/components/schemas/BaseObjectDTO"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/CommonHealthResponse"
          },
          "400": {
            "$ref": "#/components/responses/CommonErrorResponse"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "422": {
            "$ref": "#/components/responses/422"
          },
          "500": {
            "$ref": "#/components/responses/500"
          },
          "504": {
            "$ref": "#/components/responses/504"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "NGDA_OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://oc-int-auth.ngdalabor.de/auth/realms/entity/protocol/openid-connect/auth",
            "tokenUrl": "https://oc-int-auth.ngdalabor.de/auth/realms/entity/protocol/openid-connect/token",
            "scopes": {
              "urn-ngda-services-crs": "Erlaubt Zugriff auf Couponing Relay Server (notwendig, um unbefugte Zugriffe ohne Agreement mit Couponing Anbieter zu unterbinden)"
            }
          }
        }
      },
      "NGDA_OpenID": {
        "type": "openIdConnect",
        "openIdConnectUrl": "https://oc-int-auth.ngdalabor.de/auth/realms/entity/.well-known/openid-configuration"
      }
    },
    "responses": {
      "200": {
        "description": "Erfolgreich"
      },
      "201": {
        "description": "Konfigruation veraltet. Anfrage Erfolgreich bearbeitet."
      },
      "400": {
        "description": "ung\u00fcltige Parameter"
      },
      "401": {
        "description": "ung\u00fcltige Authorisierung",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/OAuthErrorResponse"
            }
          }
        }
      },
      "403": {
        "description": "Zugriff nicht erlaubt"
      },
      "404": {
        "description": "kein Object (Apotheke, Article, Order etc.) gefunden"
      },
      "422": {
        "description": "Validierung der Daten fehlgeschlagen"
      },
      "500": {
        "description": "Interner Server Fehler"
      },
      "504": {
        "description": "Gateway Timeout"
      },
      "CommonHealthResponse": {
        "description": "Unmittelbare Antwort auf eine HealthCheck Anfrage",
        "content": {
          "application/json": {
            "schema": {
              "required": [
                "meta",
                "data"
              ],
              "properties": {
                "meta": {
                  "$ref": "#/components/schemas/ResponseMetaDTO"
                },
                "data": {
                  "$ref": "#/components/schemas/BaseObjectDTO"
                }
              }
            }
          }
        }
      },
      "CommonErrorResponse": {
        "description": "Antwort wenn der gew\u00fcnschte Konfiguration als fehlerhaft abgewiesen wird. Inklusive des ersten aufgetretenen Fehlers.",
        "content": {
          "application/json": {
            "schema": {
              "required": [
                "meta",
                "error"
              ],
              "properties": {
                "meta": {
                  "$ref": "#/components/schemas/ResponseMetaDTO"
                },
                "error": {
                  "$ref": "#/components/schemas/ErrorDescription"
                }
              }
            }
          }
        }
      }
    },
    "schemas": {
      "OAuthErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "description": "Code"
          },
          "message": {
            "type": "string",
            "description": "Message"
          }
        },
        "title": "OAuthErrorResponse"
      },
      "BaseObjectDTO": {
        "description": "Felder die mit \\SERVER\\ markiert sind, sind durch den Server zu bef\u00fcllen bei Responses. Felder die mit \\CLIENT\\ markiert sind sind vom Client zu f\u00fcllen sowie vom Server sofern dieser die Information \u00fcber einen Body im Request empf\u00e4ngt (zB bei PUT / POST) - \\CLIENT\\ Felder werden vom Server nicht \u00fcbermittelt, wenn es sich um GET Requests handelt (da nicht zwingend auf Server gespeichert)",
        "type": "object",
        "properties": {
          "soid": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "\\SERVER\\ Global eindeutige ID des Objektes \u00fcber alle Instanzen des Servers hinweg.",
            "example": "abcdef1234567890"
          },
          "requested": {
            "type": "string",
            "format": "date-time",
            "description": "\\CLIENT\\ Zeitpunkt der Anfrage",
            "example": "2017-07-21T17:32:28Z"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "\\SERVER\\ Zeitpunkt der Neuanlage des Objektes",
            "example": "2017-07-21T17:32:28Z"
          },
          "modified": {
            "type": "string",
            "format": "date-time",
            "description": "\\SERVER\\ Zeitpunkt der \u00c4nderung des Objektes",
            "example": "2017-07-21T17:32:28Z"
          },
          "deleted": {
            "type": "string",
            "format": "date-time",
            "description": "\\SERVER\\ Zeitpunkt der L\u00f6schung des Objektes",
            "example": "2017-07-21T17:32:28Z"
          },
          "coid": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "\\CLIENT\\ Auf dem Clientsystem eindeutige ID des Objektes {coid]. Identifiziert \u00fcber die {client_id}. Wird serverseitig pro {client_id} persisitiert.",
            "example": "1234567890abcdef"
          },
          "coversion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "\\CLIENT\\ Auf dem Clientsystem erzeugte Version des Objektes {coid]. Identifiziert \u00fcber die {client_id}. Versioniert den Aufbau des jeweiligen Objektes",
            "example": "x.y.z"
          }
        }
      },
      "BaseMetaDTO": {
        "description": "client_id u. client_system_name sind zu f\u00fcllen bei einem Businessobjekt",
        "type": "object",
        "required": [
          "client_id"
        ],
        "properties": {
          "client_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "ID des aufrufenden System; Bei einem Service der NGDA entspricht die {client_id} der n_id der NGDA {n_id} oder in weiteren Skopes der {client_id} der Auhorisierung",
            "example": "APO1234567"
          },
          "client_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Vom Software-Haus definierter Name des aufrufenden Clients.",
            "example": "ADAS-Apotheke, Berlin"
          },
          "client_system_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Vom Software-Haus definierter Name des aufrufenden Systems. Dieses Feld muss zu Identifikationszwecken f\u00fcr das System stabil bleiben. [m\u00f6glicher Anwendungszweck ist Abrechnung]",
            "example": "System ABC der Firma XYZ"
          },
          "client_system_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "freie Angabe der Version des aufrufenden Systems",
            "example": "1.1.0"
          }
        }
      },
      "ResponseMetaDTO": {
        "allOf": [
          {
            "$ref": "#/components/schemas/RequestMetaDTO"
          },
          {
            "type": "object",
            "required": [
              "server_id"
            ],
            "properties": {
              "server_id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80,
                "description": "ID des aufgerufenen System",
                "example": "SRV1234567"
              },
              "server_name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80,
                "description": "freie Angaben des aufgerufenen System",
                "example": "A2B-Gateway der Firma XYZ aus dem Common"
              },
              "server_version": {
                "type": "string",
                "minLength": 1,
                "maxLength": 40,
                "description": "freie Angabe der Version des aufgerufenen Systems",
                "example": "1.1.0"
              },
              "stid": {
                "type": "string",
                "format": "guid",
                "description": "GUID zur Identifikation einer Transaktion auf Serverseite (Ist f\u00fcr den technischen Support relevant) Eindeutige GUID innerhalb des Server",
                "pattern": "^[{]?[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}[}]?$",
                "example": "123e4567-e89b-12d3-a456-9AC7CBDCEE52"
              },
              "val_date": {
                "type": "string",
                "format": "date-time",
                "description": "Zeitpunkt der letzten Bearbeitung",
                "example": "2017-07-21T17:32:28Z"
              }
            }
          }
        ]
      },
      "RequestMetaDTO": {
        "description": "client_id u. client_system_name sind zu f\u00fcllen bei einem Request der einen Body besitzt (post, put, etc. )",
        "type": "object",
        "properties": {
          "client_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "ID des aufrufenden System; Bei einem Service der NGDA entspricht die {client_id} der n_id der NGDA {n_id} oder in weiteren Skopes der {client_id} der Auhorisierung",
            "example": "APO1234567"
          },
          "client_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Vom Software-Haus definierter Name des aufrufenden Clients.",
            "example": "ADAS-Apotheke, Berlin"
          },
          "client_system_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Vom Software-Haus definierter Name des aufrufenden Systems. Dieses Feld muss zu Identifikationszwecken f\u00fcr das System stabil bleiben. [m\u00f6glicher Anwendungszweck ist Abrechnung]",
            "example": "System ABC der Firma XYZ"
          },
          "client_system_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "freie Angabe der Version des aufrufenden Systems",
            "example": "1.1.0"
          },
          "ctid": {
            "type": "string",
            "format": "guid",
            "description": "GUID Identifikation einer Transaktion auf Clientseite (Nach einem Timeout, kann die Transaktion mit dieser ID wiederholt werden) Eindeutige GUID innerhalb des aktuellen Client {clien_id}",
            "pattern": "^[{]?[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}[}]?$",
            "example": "753d4e7f-a12b-89a4-f123-B25a45c78d9f"
          },
          "user_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Benutzerkennung des aufrufenden System; standardm\u00e4\u00dfig entspricht die {user_id} der Benutzerkennung {user_id} der Authorisierung",
            "example": "PM"
          },
          "user_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Name des aufrufenden Benutzers",
            "example": "Peter Mustermann"
          },
          "user_status": {
            "type": "string",
            "description": "Status (Beruf) des Nutzers zu Dokumentationszwecken",
            "example": "pharmacist",
            "enum": [
              "student",
              "phip",
              "pharmacist",
              "pta",
              "pharmacyengineer",
              "pharmacyassistant"
            ]
          }
        }
      },
      "ErrorDescription": {
        "type": "object",
        "required": [
          "detailed_error_description"
        ],
        "properties": {
          "detailed_error_description": {
            "type": "string",
            "description": "Beschreibung des des Fehlers in Deutsch.",
            "example": "Der angesprochene Web-Service ist nicht verf\u00fcgbar"
          }
        }
      }
    }
  },
  "security": [
    {
      "NGDA_OAuth2": [
        "urn-ngda-services-crs"
      ]
    },
    {
      "NGDA_OpenID": [
        "urn-ngda-services-crs"
      ]
    }
  ]
}