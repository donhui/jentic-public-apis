        "description": "Interner Server Fehler"
      },
      "504": {
        "description": "Gateway Timeout"
      }
    },
    "schemas": {
      "NNFPoSDTO": {
        "properties": {
          "meta": {
            "type": "object",
            "allOf": [
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.1.2#/components/schemas/BaseMetaDTO"
              }
            ]
          },
          "data": {
            "type": "object",
            "allOf": [
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.1.1#/components/schemas/BaseObjectDTO"
              },
              {
                "type": "object",
                "description": "Datenobjekt eines Nachweis der unterst\u00fctzten TI-Services mit Payload und etwas Zusatzinfomration zur Verarbeitung",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "NNF_POS"
                    ],
                    "example": "NNF_POS",
                    "description": "Dies beschreibt den Typ des TI Nachweises"
                  },
                  "epa_version": {
                    "type": "string",
                    "description": "Version der unterst\u00fctzen ePA. Der Wert 'epa4all30' zeigt die Unterst\u00fctzung der ePA 3.0 an. Der Wert 'vorhanden' ist veraltet und wurde vorher benutzt um anzuzeigen, dass der Konnektor ePA 2.0 f\u00e4hig war.",
                    "enum": [
                      "vorhanden",
                      "epa4all30"
                    ],
                    "example": "epa4all30"
                  },
                  "kim_address": {
                    "type": "string",
                    "description": "KIM Adresse",
                    "example": "x.y.de"
                  }
                }
              }
            ]
          }
        }
      },
      "eRxPreRspDTO": {
        "description": "Dies beschreibt die R\u00fcckmeldung an einen App-Anbieter aufgrund des Stecken einer eGK \u00fcber Card-Link zum Abruf m\u00f6glicher NEUER eRezepte vom eRezept-Fachdienst (sofortige R\u00fcckmeldung innerhalb von <5 Sek) - Falls die Apotheke NIE wieder etwas h\u00f6rt nach dem Senden der R\u00fcckinfo, werden die Rezepte nach 15min wieder zur\u00fcckgegeben - Es gibt auch eine R\u00fcckantwort, wenn keine NEUEN Rezepte abgerufen wurden",
        "properties": {
          "meta": {
            "type": "object",
            "allOf": [
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.1.2#/components/schemas/BaseMetaDTO"
              }
            ]
          },
          "data": {
            "type": "object",
            "allOf": [
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.1.1#/components/schemas/BaseObjectDTO"
              },
              {
                "type": "object",
                "description": "Datenobjekt einer R\u00fcckantwort \u00fcber die mittels eGK vom Fachdienst abgerufenen NEUEN eRezepte",
                "required": [
                  "type",
                  "update",
                  "card",
                  "task"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "ERX_PRE_RSP"
                    ],
                    "example": "ERX_PRE_RSP",
                    "description": "Dies beschreibt den Typ der R\u00fcckantwort \u00fcber die mittels eGK vom Fachdienst abgerufenen NEUER eRezepte"
                  },
                  "folgeinfo": {
                    "type": "boolean",
                    "description": "handelt es sich um einen Update der Prozessdaten zu einer bereits stattgefundenen R\u00fcckantwort - Es ist erlaubt, dass zu einem so der Apotheke zugewiesenen eRezept auf dem SELBEN Weg sp\u00e4ter ggf. sogar mehrfach diese R\u00fcckantwort nochmal mit anderen aktualisierten Prozesszusatzdaten gesendet wird - Es d\u00fcrfen nur Aktualisierungen gesendet werden so lange das eRezept der Apotheke geh\u00f6rt (nicht zur\u00fcckgegeben) und NICHT Abbrechen von der App zur\u00fcck gesendet wurde.",
                    "example": "false"
                  },
                  "card": {
                    "$ref": "#/components/schemas/eRxPreCardDTO"
                  },
                  "task": {
                    "type": "array",
                    "items": {
                      "allOf": [
                        {
                          "$ref": "#/components/schemas/eRxPreTaskDTO"
                        }
                      ]
                    },
                    "description": "R\u00fcckinfo \u00fcber n(0..n) eRezepte die soeben vom Fachdienst (NEU) geladen wurden - beim ersten mal ist das array ist leer, wenn keine NEUEN eRezepte abgerufen werden konnten"
                  }
                }
              }
            ]
          }
        }
      },
      "eRxPreCardDTO": {
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.1.1#/components/schemas/BaseObjectDTO"
          },
          {
            "type": "object",
            "description": "Dies beschreibt die Informationen der verwendeten Karte (eGK)",
            "required": [
              "type",
              "iccsn"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "EGK"
                ],
                "example": "EGK",
                "description": "Objecttyp ist EGK, falls es sich um eine eGK handelt"
              },
              "iccsn": {
                "type": "string",
                "minLength": 64,
                "maxLength": 64,
                "description": "ID (ICCSN) der EGK (gem. Wissen zwischen Apo und App - damit das Backend der App wei\u00df, zu welcher konkreten App die Info geroutet werden muss)",
                "example": "xyz"
              },
              "slot": {
                "type": "integer",
                "description": "virtueller Slot (1-8) - konfigurierbar - um Zuordnung des Hub-Paketes zu einem App-Anbieter (APO_ID) zu erm\u00f6glichen",
                "example": "1"
              },
              "requested": {
                "type": "string",
                "format": "date-time",
                "description": "Zeitpunkt der Anfrage",
                "example": "2017-07-21T17:32:28Z"
              }
            }
          }
        ]
      },
      "eRxPreTaskDTO": {
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.1.1#/components/schemas/BaseObjectDTO"
          },
          {
            "type": "object",
            "description": "generisches Datenobjekt mit  Payload",
            "required": [
              "type",
              "task_id",
              "access_code"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "ERX"
                ],
                "example": "ERX",
                "description": "Objecttyp ist ERX, falls es sich um eine elektronisches Rezept handelt"
              },
              "task_id": {
                "type": "string",
                "description": "Task-ID eines eRezepts - entspricht der Rezept-ID (PrescriptionId) des jeweiligen eRezepts",
                "pattern": "^\\d{3}\\.\\d{3}\\.\\d{3}\\.\\d{3}\\.\\d{3}\\.\\d{2}$",
                "example": "160.123.456.020.221.00"
              },
              "access_code": {
                "type": "string",
                "minLength": 64,
                "maxLength": 64,
                "description": "Access-Code eines eRezepts - vom E-Rezept-Fachdienst generierter Berechtigungs-Code - Sinnvoll f\u00fcr die Bereitstellung eines Abholcodes - Sinnvoll falls in der App auf ABBRUCH gedr\u00fcckt wird, kann man dar\u00fcber auch in einer beliebigen Apotheke, durch Pr\u00e4sentation eines DMC und Scannen, das rezept einl\u00f6sen.",
                "example": "11aa3b548471178b6c2c1db98bb7b64856e2978dd23129ed5db197f4f8e34638"
              },
              "flowtype": {
                "type": "integer",
                "description": "Rezepttyp (Flowtype) eines eRezepts",
                "enum": [
                  160,
                  200
                ],
                "example": "160"
              },
              "expirydate": {
                "type": "string",
                "format": "date",
                "description": "Datum bis wann das Rezept g\u00fcltig ist",
                "example": "2017-08-21"
              },
              "acceptdate": {
                "type": "string",
                "format": "date",
                "description": "Datum bis zu welchem die Krankenkasse sp\u00e4testens die Kosten \u00fcbernimmt",
                "example": "2017-07-21"
              },
              "patient": {
                "type": "object",
                "description": "Patient",
                "required": [
                  "type",
                  "ik",
                  "name"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Objecttyp PAT f\u00fcr Patient",
                    "enum": [
                      "PAT"
                    ],
                    "example": "PAT"
                  },
                  "kvnr": {
                    "type": "string",
                    "description": "Versichertennummer () des Patienten",
                    "example": "X123456789"
                  },
                  "firstname": {
                    "type": "string",
                    "description": "Vorname des Patienten",
                    "example": "Peter"
                  },
                  "lastname": {
                    "type": "string",
                    "description": "Nachname des Patienten",
                    "example": "Mustermann"
                  },
                  "birthdate": {
                    "type": "string",
                    "format": "date",
                    "description": "Geburtsdatum des Patienten",
                    "example": "2017-07-21"
                  }
                }
              },
              "prescriber": {
                "type": "object",
                "description": "Verordner - Praxis - Arzt",
                "required": [
                  "type",
                  "ik",
                  "name"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Objecttyp DOC f\u00fcr Verordner",
                    "enum": [
                      "DOC"
                    ],
                    "example": "DOC"
                  },
                  "name": {
                    "type": "string",
                    "description": "Name der Praxis",
                    "example": "praxis Dr. Keller und Partner"
                  },
                  "adress": {
                    "type": "string",
                    "description": "Adresse der Praxis",
                    "example": "Musterstrasse 1, 12345 Musterstadt"
                  },
                  "tel": {
                    "type": "string",
                    "description": "Telefonnummer der Praxis",
                    "example": "0049 123 456789"
                  }
                }
              },
              "insurance": {
                "type": "object",
                "description": "Kostentr\u00e4ger",
                "required": [
                  "type",
                  "ik",
                  "name"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Objecttyp KTR f\u00fcr Kostentr\u00e4ger",
                    "enum": [
                      "KTR"
                    ],
                    "example": "KTR"
                  },
                  "ktrtype": {
                    "type": "string",
                    "description": "Dieses Feld enth\u00e4lt die Art des Kostentr\u00e4gers",
                    "enum": [
                      "GKV",
                      "SEL",
                      "PKV",
                      "BG",
                      "SKT",
                      "UK"
                    ],
                    "example": "GKV"
                  },
                  "ik": {
                    "type": "string",
                    "description": "Institutionskennzeichen (IK) des Kostentr\u00e4ger",
                    "example": "108310400"
                  },
                  "name": {
                    "type": "string",
                    "description": "Name des Kostentr\u00e4ger",
                    "example": "AOK Bayern"
                  }
                }
              },
              "medication": {
                "type": "object",
                "description": "Medikation",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Objecttyp MED f\u00fcr Medikation",
                    "enum": [
                      "MED"
                    ],
                    "example": "MED"
                  },
                  "medtype": {
                    "type": "string",
                    "description": "Dieses Feld enth\u00e4lt den Typ der Verordnung",
                    "enum": [
                      "PZN",
                      "FTX",
                      "REZ",
                      "WIR"
                    ],
                    "example": "PZN"
                  },
                  "article": {
                    "$ref": "#/components/schemas/eRxPreArticleDTO"
                  },
                  "freetext": {
                    "type": "string",
                    "description": "Verordnung als Freitext f\u00fcr JEDEN Verordnungstyp zur direkten Anzeige in einer UI. BeiNur bei medtyp=PZN wird wenn m\u00f6glich ZUS\u00c4TZLICH eine strukturierte Artikelinfo angegeben",
                    "example": "Nifedipin 50 mg FTA"
                  },
                  "ammount": {
                    "type": "string",
                    "description": "Menge",
                    "example": "1"
                  }
                }
              },
              "dosageinstruction": {
                "type": "string",
                "description": "Dosierungsinformationen des Medikaments, falls abweichend von der \u00e4rztlichen Verordnung",
                "example": "1-2-1"
              },
              "useinstruction": {
                "type": "string",
                "description": "Einnahmehinweis des Medikaments",
                "example": "Einnahme vor dem Essen"
              },
              "autidem": {
                "type": "boolean",
                "description": "autidem",
                "example": "true"
              },
              "freeofcharge": {
                "type": "boolean",
                "description": "Zuzahlungfei",
                "example": "true"
              },
              "processdata": {
                "type": "object",
                "description": "Prozesszusatzdaten",
                "required": [
                  "type",
                  "deliverystate",
                  "supplyoptiononPremise",
                  "supplyoptiondelivery",
                  "supplyoptionshipment"
                ],
                "properties": {
                  "deliverystate": {
                    "type": "integer",
                    "description": "Belieferungsf\u00e4higkeitsstatus",
                    "enum": [
                      10,
                      20,
                      30,
                      40,
                      50,
                      90
                    ],
                    "example": 10
                  },
                  "deliveryinfo": {
                    "type": "string",
                    "description": "Infotext zur Belieferung optional"
                  },
                  "supplyoptiononPremise": {
                    "type": "boolean",
                    "description": "Abholung in der Apotheke m\u00f6glich"
                  },
                  "supplyoptiondelivery": {
                    "type": "boolean",
                    "description": "Botenlieferung aus der Apotheke m\u00f6glich"
                  },
                  "supplyoptionshipment": {
                    "type": "boolean",
                    "description": "Versand durch Apotheke m\u00f6glich"
                  },
                  "pickUpCodeHR": {
                    "type": "string",
                    "description": "Menschenlesbarer Abholcode zur Anzeige"
                  },
                  "pickUpCodeDMC": {
                    "type": "string",
                    "description": "Abholcode als Barcode zur Anzeige in der App"
                  }
                }
              }
            }
          }
        ]
      },
      "eRxPreArticleDTO": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Objecttyp ART f\u00fcr Artikel",
            "enum": [
              "ART"
            ],
            "example": "ART"
          },
          "pzn": {
            "type": "string",
            "description": "Pharmazentralnummer (PZN oder EAN pflicht)",
            "example": 78597
          },
          "ean": {
            "type": "string",
            "description": "EAN (PZN oder EAN pflicht)",
            "example": "EAN-Code"
          },
          "name": {
            "type": "string",
            "description": "Handelsname und Anbieter des Artikel",
            "example": "Aspinin Tabletten - Bayer"
          },
          "form": {
            "type": "string",
            "description": "Darreichungsform (Tabletten, Kapseln, Salbe, etc.)",
            "example": "TAB"
          },
          "packsize": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "Menge der Einheit",
                "example": "1,5"
              },
              "unit": {
                "type": "string",
                "description": "Form der Einheit",
                "example": "ml"
              }
            }
          }
        }
      }
    }
  }
}