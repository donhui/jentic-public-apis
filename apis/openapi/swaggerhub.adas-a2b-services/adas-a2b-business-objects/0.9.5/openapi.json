          }
        }
      }
    },
    "/erx/pre/rsp": {
      "post": {
        "summary": "Apotheke / Anbieter \u00fcbergibt eine erste Vorauswahl an Detailinformationen einer eRezept-Anfrage",
        "description": "Dieser (Pseudo-)Request beschreibt die Struktur des Inhalt eines Datenpakets vom Typ ERX_PRE_RSP.",
        "operationId": "post_erx_pre_rsp",
        "tags": [
          "objecte"
        ],
        "requestBody": {
          "description": "Datenpaket - meta enth\u00e4lt Metainformationen zum Request (technisch), weitere Objektinformationen sind innerhalb des 'data' Elements",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/eRxPreRspDTO"
              }
            }
          }
