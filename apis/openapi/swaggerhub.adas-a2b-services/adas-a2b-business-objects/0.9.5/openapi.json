  "paths": {
    "/nnf/pos": {
      "post": {
        "summary": "Apotheke / Anbieter \u00fcbergibt einen Nachweis der unterst\u00fctzen TI-Services",
        "description": "Dieser (Pseudo-)Request beschreibt die Struktur des Inhalt eines Datenpakets vom Typ NNF_TIPoS.",
        "operationId": "post_tipos",
        "tags": [
          "objecte"
        ],
        "requestBody": {
          "description": "Datenpaket - meta enth\u00e4lt Metainformationen zum Request (technisch), weitere Objektinformationen sind innerhalb des 'data' Elements",
