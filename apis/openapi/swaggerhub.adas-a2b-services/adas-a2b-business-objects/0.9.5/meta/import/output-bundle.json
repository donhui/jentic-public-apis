        "description": "Gateway Timeout"
      }
    },
    "schemas": {
      "NNFPoSDTO": {
        "properties": {
          "meta": {
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/BaseMetaDTO"
              }
            ]
          },
          "data": {
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/BaseObjectDTO"
              },
              {
                "type": "object",
                "description": "Datenobjekt eines Nachweis der unterstützten TI-Services mit Payload und etwas Zusatzinfomration zur Verarbeitung",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "NNF_POS"
                    ],
                    "example": "NNF_POS",
                    "description": "Dies beschreibt den Typ des TI Nachweises"
                  },
                  "epa_version": {
                    "type": "string",
                    "description": "Version der unterstützen ePA. Der Wert 'epa4all30' zeigt die Unterstützung der ePA 3.0 an. Der Wert 'vorhanden' ist veraltet und wurde vorher benutzt um anzuzeigen, dass der Konnektor ePA 2.0 fähig war.",
                    "enum": [
                      "vorhanden",
                      "epa4all30"
                    ],
                    "example": "epa4all30"
                  },
                  "kim_address": {
                    "type": "string",
                    "description": "KIM Adresse",
                    "example": "x.y.de"
                  }
                }
              }
            ]
          }
        }
      },
      "eRxPreRspDTO": {
        "description": "Dies beschreibt die Rückmeldung an einen App-Anbieter aufgrund des Stecken einer eGK über Card-Link zum Abruf möglicher NEUER eRezepte vom eRezept-Fachdienst (sofortige Rückmeldung innerhalb von <5 Sek) - Falls die Apotheke NIE wieder etwas hört nach dem Senden der Rückinfo, werden die Rezepte nach 15min wieder zurückgegeben - Es gibt auch eine Rückantwort, wenn keine NEUEN Rezepte abgerufen wurden",
        "properties": {
          "meta": {
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/BaseMetaDTO"
              }
            ]
          },
          "data": {
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/BaseObjectDTO"
              },
              {
                "type": "object",
                "description": "Datenobjekt einer Rückantwort über die mittels eGK vom Fachdienst abgerufenen NEUEN eRezepte",
                "required": [
                  "type",
                  "update",
                  "card",
                  "task"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "ERX_PRE_RSP"
                    ],
                    "example": "ERX_PRE_RSP",
                    "description": "Dies beschreibt den Typ der Rückantwort über die mittels eGK vom Fachdienst abgerufenen NEUER eRezepte"
                  },
                  "folgeinfo": {
                    "type": "boolean",
                    "description": "handelt es sich um einen Update der Prozessdaten zu einer bereits stattgefundenen Rückantwort - Es ist erlaubt, dass zu einem so der Apotheke zugewiesenen eRezept auf dem SELBEN Weg später ggf. sogar mehrfach diese Rückantwort nochmal mit anderen aktualisierten Prozesszusatzdaten gesendet wird - Es dürfen nur Aktualisierungen gesendet werden so lange das eRezept der Apotheke gehört (nicht zurückgegeben) und NICHT Abbrechen von der App zurück gesendet wurde.",
                    "example": "false"
                  },
                  "card": {
                    "$ref": "#/components/schemas/eRxPreCardDTO"
                  },
                  "task": {
                    "type": "array",
                    "items": {
                      "allOf": [
                        {
                          "$ref": "#/components/schemas/eRxPreTaskDTO"
                        }
                      ]
                    },
                    "description": "Rückinfo über n(0..n) eRezepte die soeben vom Fachdienst (NEU) geladen wurden - beim ersten mal ist das array ist leer, wenn keine NEUEN eRezepte abgerufen werden konnten"
                  }
                }
              }
            ]
          }
        }
      },
      "eRxPreCardDTO": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseObjectDTO"
          },
          {
            "type": "object",
            "description": "Dies beschreibt die Informationen der verwendeten Karte (eGK)",
            "required": [
              "type",
              "iccsn"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "EGK"
                ],
                "example": "EGK",
                "description": "Objecttyp ist EGK, falls es sich um eine eGK handelt"
              },
              "iccsn": {
                "type": "string",
                "minLength": 64,
                "maxLength": 64,
                "description": "ID (ICCSN) der EGK (gem. Wissen zwischen Apo und App - damit das Backend der App weiß, zu welcher konkreten App die Info geroutet werden muss)",
                "example": "xyz"
              },
              "slot": {
                "type": "integer",
                "description": "virtueller Slot (1-8) - konfigurierbar - um Zuordnung des Hub-Paketes zu einem App-Anbieter (APO_ID) zu ermöglichen",
                "example": "1"
              },
              "requested": {
                "type": "string",
                "format": "date-time",
                "description": "Zeitpunkt der Anfrage",
                "example": "2017-07-21T17:32:28Z"
              }
            }
          }
        ]
      },
      "eRxPreTaskDTO": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseObjectDTO"
          },
          {
            "type": "object",
            "description": "generisches Datenobjekt mit  Payload",
            "required": [
              "type",
              "task_id",
              "access_code"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "ERX"
                ],
                "example": "ERX",
                "description": "Objecttyp ist ERX, falls es sich um eine elektronisches Rezept handelt"
              },
              "task_id": {
                "type": "string",
                "description": "Task-ID eines eRezepts - entspricht der Rezept-ID (PrescriptionId) des jeweiligen eRezepts",
                "pattern": "^\\d{3}\\.\\d{3}\\.\\d{3}\\.\\d{3}\\.\\d{3}\\.\\d{2}$",
                "example": "160.123.456.020.221.00"
              },
              "access_code": {
                "type": "string",
                "minLength": 64,
                "maxLength": 64,
                "description": "Access-Code eines eRezepts - vom E-Rezept-Fachdienst generierter Berechtigungs-Code - Sinnvoll für die Bereitstellung eines Abholcodes - Sinnvoll falls in der App auf ABBRUCH gedrückt wird, kann man darüber auch in einer beliebigen Apotheke, durch Präsentation eines DMC und Scannen, das rezept einlösen.",
                "example": "11aa3b548471178b6c2c1db98bb7b64856e2978dd23129ed5db197f4f8e34638"
              },
              "flowtype": {
                "type": "integer",
                "description": "Rezepttyp (Flowtype) eines eRezepts",
                "enum": [
                  160,
                  200
                ],
                "example": "160"
              },
              "expirydate": {
                "type": "string",
                "format": "date",
                "description": "Datum bis wann das Rezept gültig ist",
                "example": "2017-08-21"
              },
              "acceptdate": {
                "type": "string",
                "format": "date",
                "description": "Datum bis zu welchem die Krankenkasse spätestens die Kosten übernimmt",
                "example": "2017-07-21"
              },
              "patient": {
                "type": "object",
                "description": "Patient",
                "required": [
                  "type",
                  "ik",
                  "name"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Objecttyp PAT für Patient",
                    "enum": [
                      "PAT"
                    ],
                    "example": "PAT"
                  },
                  "kvnr": {
                    "type": "string",
                    "description": "Versichertennummer () des Patienten",
                    "example": "X123456789"
                  },
                  "firstname": {
                    "type": "string",
                    "description": "Vorname des Patienten",
                    "example": "Peter"
                  },
                  "lastname": {
                    "type": "string",
                    "description": "Nachname des Patienten",
                    "example": "Mustermann"
                  },
                  "birthdate": {
                    "type": "string",
                    "format": "date",
                    "description": "Geburtsdatum des Patienten",
                    "example": "2017-07-21"
                  }
                }
              },
              "prescriber": {
                "type": "object",
                "description": "Verordner - Praxis - Arzt",
                "required": [
                  "type",
                  "ik",
                  "name"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Objecttyp DOC für Verordner",
                    "enum": [
                      "DOC"
                    ],
                    "example": "DOC"
                  },
                  "name": {
                    "type": "string",
                    "description": "Name der Praxis",
                    "example": "praxis Dr. Keller und Partner"
                  },
                  "adress": {
                    "type": "string",
                    "description": "Adresse der Praxis",
                    "example": "Musterstrasse 1, 12345 Musterstadt"
                  },
                  "tel": {
                    "type": "string",
                    "description": "Telefonnummer der Praxis",
                    "example": "0049 123 456789"
                  }
                }
              },
              "insurance": {
                "type": "object",
                "description": "Kostenträger",
                "required": [
                  "type",
                  "ik",
                  "name"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Objecttyp KTR für Kostenträger",
                    "enum": [
                      "KTR"
                    ],
                    "example": "KTR"
                  },
                  "ktrtype": {
                    "type": "string",
                    "description": "Dieses Feld enthält die Art des Kostenträgers",
                    "enum": [
                      "GKV",
                      "SEL",
                      "PKV",
                      "BG",
                      "SKT",
                      "UK"
                    ],
                    "example": "GKV"
                  },
                  "ik": {
                    "type": "string",
                    "description": "Institutionskennzeichen (IK) des Kostenträger",
                    "example": "108310400"
                  },
                  "name": {
                    "type": "string",
                    "description": "Name des Kostenträger",
                    "example": "AOK Bayern"
                  }
                }
              },
              "medication": {
                "type": "object",
                "description": "Medikation",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Objecttyp MED für Medikation",
                    "enum": [
                      "MED"
                    ],
                    "example": "MED"
                  },
                  "medtype": {
                    "type": "string",
                    "description": "Dieses Feld enthält den Typ der Verordnung",
                    "enum": [
                      "PZN",
                      "FTX",
                      "REZ",
                      "WIR"
                    ],
                    "example": "PZN"
                  },
                  "article": {
                    "$ref": "#/components/schemas/eRxPreArticleDTO"
                  },
                  "freetext": {
                    "type": "string",
                    "description": "Verordnung als Freitext für JEDEN Verordnungstyp zur direkten Anzeige in einer UI. BeiNur bei medtyp=PZN wird wenn möglich ZUSÄTZLICH eine strukturierte Artikelinfo angegeben",
                    "example": "Nifedipin 50 mg FTA"
                  },
                  "ammount": {
                    "type": "string",
                    "description": "Menge",
                    "example": "1"
                  }
                }
              },
              "dosageinstruction": {
                "type": "string",
                "description": "Dosierungsinformationen des Medikaments, falls abweichend von der ärztlichen Verordnung",
                "example": "1-2-1"
              },
              "useinstruction": {
                "type": "string",
                "description": "Einnahmehinweis des Medikaments",
                "example": "Einnahme vor dem Essen"
              },
              "autidem": {
                "type": "boolean",
                "description": "autidem",
                "example": "true"
              },
              "freeofcharge": {
                "type": "boolean",
                "description": "Zuzahlungfei",
                "example": "true"
              },
              "processdata": {
                "type": "object",
                "description": "Prozesszusatzdaten",
                "required": [
                  "type",
                  "deliverystate",
                  "supplyoptiononPremise",
                  "supplyoptiondelivery",
                  "supplyoptionshipment"
                ],
                "properties": {
                  "deliverystate": {
                    "type": "integer",
                    "description": "Belieferungsfähigkeitsstatus",
                    "enum": [
                      10,
                      20,
                      30,
                      40,
                      50,
                      90
                    ],
                    "example": 10
                  },
                  "deliveryinfo": {
                    "type": "string",
                    "description": "Infotext zur Belieferung optional"
                  },
                  "supplyoptiononPremise": {
                    "type": "boolean",
                    "description": "Abholung in der Apotheke möglich"
                  },
                  "supplyoptiondelivery": {
                    "type": "boolean",
                    "description": "Botenlieferung aus der Apotheke möglich"
                  },
                  "supplyoptionshipment": {
                    "type": "boolean",
                    "description": "Versand durch Apotheke möglich"
                  },
                  "pickUpCodeHR": {
                    "type": "string",
                    "description": "Menschenlesbarer Abholcode zur Anzeige"
                  },
                  "pickUpCodeDMC": {
                    "type": "string",
                    "description": "Abholcode als Barcode zur Anzeige in der App"
                  }
                }
              }
            }
          }
        ]
      },
      "eRxPreArticleDTO": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Objecttyp ART für Artikel",
            "enum": [
              "ART"
            ],
            "example": "ART"
          },
          "pzn": {
            "type": "string",
            "description": "Pharmazentralnummer (PZN oder EAN pflicht)",
            "example": 78597
          },
          "ean": {
            "type": "string",
            "description": "EAN (PZN oder EAN pflicht)",
            "example": "EAN-Code"
          },
          "name": {
            "type": "string",
            "description": "Handelsname und Anbieter des Artikel",
            "example": "Aspinin Tabletten - Bayer"
          },
          "form": {
            "type": "string",
            "description": "Darreichungsform (Tabletten, Kapseln, Salbe, etc.)",
            "example": "TAB"
          },
          "packsize": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "description": "Menge der Einheit",
                "example": "1,5"
              },
              "unit": {
                "type": "string",
                "description": "Form der Einheit",
                "example": "ml"
              }
            }
          }
        }
      },
      "BaseMetaDTO": {
        "description": "client_id u. client_system_name sind zu füllen bei einem Businessobjekt",
        "type": "object",
        "required": [
          "client_id"
        ],
        "properties": {
          "client_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "ID des aufrufenden System; Bei einem Service der NGDA entspricht die {client_id} der n_id der NGDA {n_id} oder in weiteren Skopes der {client_id} der Auhorisierung",
            "example": "APO1234567"
          },
          "client_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Vom Software-Haus definierter Name des aufrufenden Clients.",
            "example": "ADAS-Apotheke, Berlin"
          },
          "client_system_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Vom Software-Haus definierter Name des aufrufenden Systems. Dieses Feld muss zu Identifikationszwecken für das System stabil bleiben. [möglicher Anwendungszweck ist Abrechnung]",
            "example": "System ABC der Firma XYZ"
          },
          "client_system_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "description": "freie Angabe der Version des aufrufenden Systems",
            "example": "1.1.0"
          }
        }
      },
      "BaseObjectDTO": {
        "description": "Felder die mit \\SERVER\\ markiert sind, sind durch den Server zu befüllen bei Responses. Felder die mit \\CLIENT\\ markiert sind sind vom Client zu füllen sowie vom Server sofern dieser die Information über einen Body im Request empfängt (zB bei PUT / POST) - \\CLIENT\\ Felder werden vom Server nicht übermittelt, wenn es sich um GET Requests handelt (da nicht zwingend auf Server gespeichert)",
        "type": "object",
        "properties": {
          "soid": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "\\SERVER\\ Global eindeutige ID des Objektes über alle Instanzen des Servers hinweg.",
            "example": "abcdef1234567890"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "\\SERVER\\ Zeitpunkt der Neuanlage des Objektes",
            "example": "2017-07-21T17:32:28Z"
          },
          "modified": {
            "type": "string",
            "format": "date-time",
            "description": "\\SERVER\\ Zeitpunkt der Änderung des Objektes",
            "example": "2017-07-21T17:32:28Z"
          },
          "deleted": {
            "type": "string",
            "format": "date-time",
            "description": "\\SERVER\\ Zeitpunkt der Löschung des Objektes",
            "example": "2017-07-21T17:32:28Z"
          },
          "coid": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "\\CLIENT\\ Auf dem Clientsystem eindeutige ID des Objektes {coid]. Identifiziert über die {client_id}. Wird serverseitig pro {client_id} persisitiert.",
            "example": "1234567890abcdef"
          },
          "coversion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "\\CLIENT\\ Auf dem Clientsystem erzeugte Version des Objektes {coid]. Identifiziert über die {client_id}. Versioniert den Aufbau des jeweiligen Objektes",
            "example": "x.y.z"
          }
        }
      }
    }
  },
