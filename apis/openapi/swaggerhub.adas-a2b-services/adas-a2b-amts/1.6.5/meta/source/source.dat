      "delete": {
        "summary": "Apotheke l\u00f6scht Medikationsanalysen durch die pha_soid.",
        "description": "L\u00f6scht eine Medikationsanalyse z.B. aus DGSVO-Gr\u00fcnden.",
        "operationId": "delete_pharmacy_amts_fullcheck",
        "tags": [
