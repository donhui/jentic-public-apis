              }
            ]
          }
        }
      },
      "PharmacyAmtsFullCheckResponseDataDTO": {
        "type": "object",
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ServerObjectDTO"
          },
          {
            "$ref": "#/components/schemas/AmtsFullCheckResponseDataDTO"
          }
        ]
      },
      "AmtsQuickCheckDTO": {
        "type": "object",
        "description": "Daten f\u00fcr Interaktions- und Kontraindikationschecks",
        "required": [
          "type",
          "customer",
          "medication"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Objecttyp AQC f\u00fcr AMTS-Quick-Check",
            "example": "AQC",
            "pattern": "^AQC$"
          },
          "sale_id": {
            "maxLength": 80,
            "minLength": 1,
            "type": "string",
            "description": "Eindeutige Kennung des Abverkaufsvorgangs zur Optimierung bei mehrfacher \u00dcbermittlung des gleichen Vorgangs, mit unterschiedlich vielen FAM",
            "example": "?"
          },
          "customer": {
            "type": "object",
            "allOf": [
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ClientObjectDTO"
              },
              {
                "$ref": "#/components/schemas/CustomerAmtsAnonymousDTO"
              }
            ]
          },
          "medication": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MedicationDTO"
            }
          },
          "medical_individual_parameter": {
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ClientObjectDTO"
                },
                {
                  "$ref": "#/components/schemas/MedicalIndividualParameterDTO"
                }
              ]
            }
          },
          "resolved_check_result": {
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ClientObjectDTO"
                },
                {
                  "$ref": "#/components/schemas/ResolvedCheckResultDTO"
                }
              ]
            }
          },
          "include_record_result": {
            "type": "boolean",
            "description": "Interaktionen zwischen Medikamenten der Historie, bzw. Kontraindikationen der Historie in Ergebnis ber\u00fccksichtigen.",
            "example": false
          },
          "include_add_ons": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Weitere optionale Checks ausf\u00fchren. Aktuell gibt es nur den Doppelverordnungs-Check mit dem Keyword \"duplicates\".",
            "example": [
              "duplicates"
            ]
          }
        }
      },
      "AmtsFullCheckDTO": {
        "type": "object",
        "description": "Vorhandene Daten f\u00fcr Medikationsanalyse",
        "required": [
          "type",
          "customer",
          "medication",
          "public_key"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Objecttyp AFC f\u00fcr AMTS-Full-Check",
            "example": "AFC",
            "pattern": "^AFC$"
          },
          "customer": {
            "$ref": "#/components/schemas/CustomerAmtsSecureDTO"
          },
          "medication": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MedicationDTO"
            }
          },
          "medical_individual_parameter": {
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ClientObjectDTO"
                },
                {
                  "$ref": "#/components/schemas/MedicalIndividualParameterDTO"
                }
              ]
            }
          },
          "public_key": {
            "type": "string",
            "description": "Base64 encodierter RSA Public Key im Format JWK (JSON Web Key), der verwendet wird, um PDF-Dokumente zu verschl\u00fcsseln.",
            "example": ""
          },
          "doctor": {
            "type": "object",
            "allOf": [
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ClientObjectDTO"
              },
              {
                "$ref": "#/components/schemas/AddressDTO"
              }
            ]
          },
          "pharmacy": {
            "type": "object",
            "description": "Adresse der Apotheke + Angaben zum Inhaber, damit Online f\u00fcr diesen konkreten Fall Druckinfos zur Apotheke eingef\u00fcgt werden k\u00f6nnen. Der aktuelle Anwender ist in den Metainfos definiert.",
            "allOf": [
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ClientObjectDTO"
              },
              {
                "$ref": "#/components/schemas/AddressDTO"
              }
            ]
          }
        }
      },
      "MedicalIndividualParameterDTO": {
        "required": [
          "type",
          "miv_key"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Objekttyp MIV fuer Medikationsrelevante Individualparameter",
            "example": "MIV",
            "pattern": "^MIV$"
          },
          "miv_key": {
            "type": "integer",
            "example": 636
          }
        },
        "description": "MIV (Medikationsrelevante Individualparameter) nach ABDATA"
      },
      "AddressDTO": {
        "required": [
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Objekttyp ADR f\u00fcr Adresse",
            "example": "ADR",
            "pattern": "^ADR$"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-3 L\u00e4ndercode",
            "example": "DEU"
          },
          "city": {
            "type": "string",
            "description": "Stadt",
            "example": "Berlin"
          },
          "postal_code": {
            "type": "string",
            "description": "Postleitzahl (je nach Land kein rein numerischer Wert).",
            "example": "13465"
          },
          "street_address": {
            "type": "string",
            "description": "Stra\u00dfe und Hausnummer",
            "example": "Oranienburger Chaussee 50, 2. OG"
          },
          "email": {
            "type": "string",
            "description": "Mailadresse",
            "example": "jane.doe@example.com"
          },
          "telephone": {
            "type": "string",
            "description": "Telefon",
            "example": "+49 30 123456-78"
          },
          "title": {
            "type": "string",
            "description": "Titel",
            "example": "Prof. Dr. Med."
          },
          "job_title": {
            "type": "string",
            "description": "Berufsbezeichnung, Fachrichtung",
            "example": "Urologe"
          },
          "first_name": {
            "type": "string",
            "description": "Vorname",
            "example": "Jane Jillian"
          },
          "last_name": {
            "type": "string",
            "description": "Nachname",
            "example": "Doe"
          },
          "company_name": {
            "type": "string",
            "description": "Firmen- bzw. Praxisname",
            "example": "Gemeinschaftspraxis Doe und Mustermann"
          }
        },
        "description": "Adressdatensatz einer Kontaktperson, bspw. einer Arztpraxis."
      },
      "ResolvedCheckResultDTO": {
        "required": [
          "type",
          "stable_id"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Objekttyp RCR f\u00fcr gekl\u00e4rte Interaktions- oder Kontraindikationstreffer",
            "example": "RCR",
            "pattern": "^RCR$"
          },
          "stable_id": {
            "type": "string",
            "description": "Stabile ID \u00fcber mehrere Treffer hinweg (zur Filterung gekl\u00e4rter Treffer) - Details dazu siehe Abschnitt 3.2.1 Stabile ID des Konzeptdokuments",
            "example": "interaction-693-50"
          }
        }
      },
      "CustomerAmtsAnonymousDTO": {
        "required": [
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "pattern": "^CAA$",
            "type": "string",
            "description": "Objecttyp CAA f\u00fcr Kunde-AMTS-Anonym",
            "example": "CAA"
          },
          "age_in_months": {
            "type": "number",
            "description": "Alter in Monaten (bei Alter unter 914 Tagen als age_in_days angeben). Es darf ein Dezimalwert mit zwei Nachkommastellen angegeben werden. Es darf nur age_in_months oder age_in_days angegeben werden.",
            "example": 852.25
          },
          "age_in_days": {
            "type": "integer",
            "description": "Alter in Tagen (nur bei S\u00e4uglingen im Alter unter 914 Tagen). Es darf nur age_in_months oder age_in_days angegeben werden.",
            "format": "int32",
            "example": 365
          },
          "gender": {
            "type": "string",
            "description": "Geschlecht (f\u00fcr unspezifisch oder unbekannt Attribut weg lassen)",
            "example": "female",
            "enum": [
              "female",
              "male",
              "diverse"
            ]
          },
          "gfr": {
            "type": "integer",
            "description": "eGFR als ganze Zahl",
            "format": "int32",
            "example": 32
          },
          "weight": {
            "type": "integer",
            "description": "Gewicht in KG als ganze Zahl",
            "format": "int32",
            "example": 64
          }
        }
      },
      "CustomerAmtsSecureDTO": {
        "type": "object",
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ClientObjectDTO"
          },
          {
            "required": [
              "type",
              "name",
              "first_name",
              "last_name",
              "birthday",
              "gender"
            ],
            "type": "object",
            "properties": {
              "type": {
                "pattern": "^CAS$",
                "type": "string",
                "description": "Objecttyp CAS f\u00fcr Kunde-AMTS-Secure",
                "example": "CAS"
              },
              "name": {
                "type": "string",
                "description": "Name verschl\u00fcsselt in first_name, last_name. (Wegen Objektvererbung in Spezifikation enthalten.)",
                "example": "secure",
                "enum": [
                  "secure"
                ]
              },
              "first_name": {
                "type": "string",
                "description": "Mit Datenschutzpasswort clientseitig verschl\u00fcsselter Vorname",
                "example": "33ab9ad5721fe7605927a1b63b9bbce4plSuFbRO+woXpuWEYDxODMCktYVkhf0TVS+S3HhhKXKk5/qlOVReqrPrBQ0RxvOAYPtnnve1lZXSoetMZTVskQtKNrnfgj1zS+dL0te9Q6CHMLYaDTHmZjQ2KXf/sf9Uc/1aGRgXuHFNlnoVvRxabLM37ywwJLBzwcGgb/kpKN0OQXbft6M+rTkwo580mYlB5+gutg0sZBpR0gExgvBjFw=="
              },
              "last_name": {
                "type": "string",
                "description": "Mit Datenschutzpasswort clientseitig verschl\u00fcsselter Nachname",
                "example": "7532c71c063dbdfb17aac737fadb46418sBMWsgq0ghG92OLUm22PYpHMIOlqh9TML2nuIsqNYQRVtnCIvFRyzEJPp8DOS71MB+wD5WNdOv+9Zh7MT7xnMB5TuT7J11IuhJgXho5xgJC9+zAbbBty48xFrcZfGANulnXfwHj9Ov1Pl7rtEBY8mDPM0YqLagM434nTtVPe1PHsP0A4/wzw0SnwdM5u0CCHdHvEgjW3Q4rXVi22sUVtA=="
              },
              "birthday": {
                "type": "string",
                "description": "Mit Datenschutzpasswort clientseitig verschl\u00fcsseltes Geburtsdatum, ggf. unvollst\u00e4ndig entsprechend der eGK-Spezifikation (in der Form tt.mm.jjjj)",
                "example": "25e64b41b2b21344dffc203c19a6dd37haQyfkOIpPdYSOB1VT4qyvNqRE/DGL40SDktMfOAFAADvW2bs0t3BQ3AFLa0Rj3vMcXP/QVJxpvwe9pjV7TxL8ZUOqM+bfKKHh1qCLN6eQSSv8tVmfmJA/pKujKu0i/rHR1Cb+bUV8ZmTp3rtTU7FCIwR0omF/qZZFGMP89CfFu9XANASxtZ2u0u37hhyhhHUk0D1Br+JgzCYRdSt0Mj8g=="
              },
              "insurance_number": {
                "type": "string",
                "description": "Mit Datenschutzpasswort clientseitig verschl\u00fcsselte eindeutige lebenslange Identifikationsnummer des Patienten entsprechend der eGK-Spezifikation (bspw. D123456789)",
                "example": "b539bfcfdfdf26a49821bc590dc3e33bHTFZ/m7FyqLPslHLdHQj5rj9YTmB35xGV0htfKrF5lDIWX4bqwfWji28/uoRL1PS6wXxzW9Utd9/xvgyRSColXGKSxFnJUS2gzRPCie3ZWJi713BkmhBHuBfEiScN5YA1+DW2UEciaGCAgeu3NsVPbqYyj2K1/5dAVZpDijmugE="
              },
              "gender": {
                "type": "string",
                "description": "Geschlecht (f\u00fcr unspezifisch Attribut leer lassen)",
                "example": "female",
                "enum": [
                  "female",
                  "male",
                  "diverse"
                ]
              },
              "weight": {
                "type": "integer",
                "description": "Gewicht in KG als ganze Zahl",
                "format": "int32",
                "example": 64
              },
              "size": {
                "type": "integer",
                "description": "K\u00f6rpergr\u00f6\u00dfe in CM als ganze Zahl",
                "format": "int32",
                "example": 175
              },
              "creatinine": {
                "type": "number",
                "format": "float",
                "description": "Kreatininwert in mg/dl als Kommazahl",
                "example": 0.9
              },
              "lactating": {
                "type": "boolean",
                "description": "Information dar\u00fcber, ob die Patientin aktuell stillend ist",
                "example": false
              },
              "pregnant": {
                "type": "boolean",
                "description": "Information dar\u00fcber, ob die Patientin aktuell schwanger ist",
                "example": false
              },
              "gfr": {
                "type": "integer",
                "description": "eGFR als ganze Zahl",
                "format": "int32",
                "example": 32
              }
            }
          }
        ]
      },
      "MedicationDTO": {
        "type": "object",
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ClientObjectDTO"
          },
          {
            "required": [
              "type"
            ],
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "FAM",
                  "PAC"
                ],
                "description": "Objecttyp FAM f\u00fcr Fertigarzneimittel bzw. PAC f\u00fcr Fertigarzneimittelpackung",
                "example": "FAM"
              },
              "fam_key": {
                "type": "string",
                "description": "Fertigarzneimittelschluessel nach ABDATA. (Entweder fam_key ODER pzn m\u00fcssen gef\u00fcllt sein aber nie beide!)",
                "example": 3987654321
              },
              "pzn": {
                "type": "string",
                "description": "Pharmazentralnummer nach ABDATA. (Entweder fam_key ODER pzn m\u00fcssen gef\u00fcllt sein aber nie beide!)",
                "example": 12345678
              },
              "source": {
                "type": "string",
                "description": "Herkunft des Arzneimittels (aus aktuellem Abverkauf/Abgabe oder Aufzeichnung/Historie)",
                "example": "sale",
                "enum": [
                  "sale",
                  "record"
                ]
              },
              "import_source": {
                "type": "string",
                "description": "Optionale Import-Quelle f\u00fcr die Ausgabe.",
                "example": "eml",
                "enum": [
                  "bmp",
                  "eml",
                  "emp"
                ]
              },
              "sale_date": {
                "type": "string",
                "description": "Datum an dem der Artikel abverkauft wurde.",
                "format": "date",
                "example": "2022-01-27"
              },
              "name": {
                "type": "string",
                "description": "Name des Fertigarzneimittel bzw. Fertigarzneimittelpackung",
                "example": "Aspirin Tabletten { 10 St N1 } - Bayer"
              },
              "dosage": {
                "$ref": "#/components/schemas/DosageDTO"
              },
              "indication": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/MedicalIndividualParameterDTO"
                },
                "description": "Array von medizinischen Individualparametern als Indikation(en), die zur Einnahme des Arzneimittels f\u00fchren."
              }
            }
          }
        ]
      },
      "DosageDTO": {
        "required": [
          "type",
          "morning",
          "noon",
          "evening",
          "night",
          "unit"
        ],
        "type": "object",
        "description": "Optionales konkretes Dosierschema des Arzneimittels (M-M-A-zN).",
        "properties": {
          "type": {
            "pattern": "^DOS$",
            "type": "string",
            "description": "Objekttyp",
            "example": "DOS"
          },
          "morning": {
            "type": "number",
            "format": "float",
            "description": "Einnahmedosis am Morgen",
            "example": 0.5
          },
          "noon": {
            "type": "number",
            "format": "float",
            "description": "Einnahmedosis am Mittag",
            "example": 0.5
          },
          "evening": {
            "type": "number",
            "format": "float",
            "description": "Einnahmedosis am Abend",
            "example": 0.5
          },
          "night": {
            "type": "number",
            "format": "float",
            "description": "Einnahmedosis zur Nacht",
            "example": 0.5
          },
          "unit": {
            "type": "string",
            "description": "Code einer Dosiereinheit gem\u00e4\u00df https://applications.kbv.de/S_BMP_DOSIEREINHEIT_V1.01.xhtml (z.B. 1 f\u00fcr St\u00fcck)",
            "example": "1"
          }
        }
      },
      "AmtsQuickCheckResponseDataDTO": {
        "required": [
          "type",
          "sale_id",
          "issue_count",
          "highest_risk",
          "check_results",
          "icon_group",
          "is_medication_analysis_recommended",
          "svg_url",
          "html_url",
          "pdf_url",
          "expire_datetime"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Objekttyp AQR f\u00fcr AMTS-Quick-Check-Result",
            "example": "AQR",
            "pattern": "^AQR$"
          },
          "sale_id": {
            "maxLength": 80,
            "minLength": 1,
            "type": "string",
            "description": "Eindeutige Kennung des Abverkaufsvorgangs zur Optimierung bei mehrfacher \u00dcbermittlung des gleichen Vorgangs, z.B. mit unterschiedlich vielen FAM",
            "example": "?"
          },
          "issue_count": {
            "type": "integer",
            "description": "Anzahl der gefundenen Probleme, unabh\u00e4ngig zum Schweregrad",
            "format": "int32",
            "example": 5
          },
          "highest_risk": {
            "type": "string",
            "description": "Schweregrad des h\u00f6chsten nicht-gekl\u00e4rten Pr\u00fcfergebnisses, d.h. alle bereits gekl\u00e4rten Treffer werden nicht miteinbezogen. Wenn schwerwiegende Probleme gefunden wurden, kann die WaWi damit Schritt II automatisch \u00f6ffnen oder einen Warnhinweis anzeigen.",
            "example": "veryHighRisk",
            "enum": [
              "veryHighRisk",
              "highRisk",
              "mediumRisk",
              "lowRisk",
              "noRisk"
            ]
          },
          "check_results": {
            "type": "array",
            "description": "Check-Ergebnis in Form strukturierter Daten.",
            "items": {
              "$ref": "#/components/schemas/AmtsCheckResultDTO"
            }
          },
          "icon_group": {
            "type": "array",
            "description": "Strukturierte Daten zur Darstellung des Check-Ergebnisses in zusammenfassenden Icons.",
            "items": {
              "$ref": "#/components/schemas/AmtsCheckResultIconDTO"
            }
          },
          "is_medication_analysis_recommended": {
            "type": "boolean",
            "description": "Dem Patienten sollte eine Medikationsanalyse empfohlen werden (gem. Kriterien auf Basis der ABDA Leitlinie).",
            "example": false
          },
          "medication_analysis_recommended_text": {
            "type": "string",
            "description": "Beschreibender Text zur Darstellung in der Warenwirtschaft warum eine Medikationsanalyse empfohlen werden sollte. Formatierung in Markdown (ohne Links).",
            "example": "# Weitere AMTS-Risiken gefunden!*\n\n## Starten Sie hierzu eine Medikationsanalyse.\n\n*Die hier dargestellten Treffer beziehen sich ausschlie\u00dflich auf die AMTS-Aspekte \u201cInteraktionen\u201d und \u201cKontraindikationen\u201d. Im vorliegenden Fall k\u00f6nnen weitere Risiken detektiert werden."
          },
          "svg_url": {
            "type": "string",
            "description": "Risiko-Donut mit Anzahl der Treffer, inkl. grafischer Darstellung der Schweregrade als SVG. Abrufbar bis expire_datetime.",
            "example": "https://<domain>/amts/quickCheck/123e4567-e89b-12d3-a456-9AC7CBDCEE52/donut.svg"
          },
          "html_icon_group_url": {
            "type": "string",
            "description": "Symbolhafte Darstellung von Kategorien, in denen Risiken gefunden wurden, mit Anzahl der Treffer, inkl. grafischer Darstellung der Schweregrade und des Kl\u00e4rungsstatus zur Darstellung in einer Web-View, als Alternative zum Risiko-Donut (svg_url). Abrufbar bis expire_datetime.",
            "example": "https://<domain>/amts/quickCheck/123e4567-e89b-12d3-a456-9AC7CBDCEE52/icon-group.html"
          },
          "html_url": {
            "type": "string",
            "description": "HTML-Darstellung des Ergebnisses zur Darstellung in einer Web-View. Abrufbar bis expire_datetime.",
            "example": "https://<domain>/amts/quickCheck/123e4567-e89b-12d3-a456-9AC7CBDCEE52/result.html"
          },
          "pdf_url": {
            "type": "string",
            "description": "Druckansicht aller Ergebnisse in Form einer PDF. Abrufbar bis expire_datetime.",
            "example": "https://<domain>/amts/quickCheck/123e4567-e89b-12d3-a456-9AC7CBDCEE52/result.pdf"
          },
          "warning_message": {
            "type": "object",
            "description": "Warnmeldung mit wichtigen Hinweisen, bspw. wenn eine Analyse zwar durchgef\u00fchrt werden kann, aber unvollst\u00e4ndig ist, weil \u00fcbermittelte Daten teilweise nicht interpretiert werden k\u00f6nnen.",
            "allOf": [
              {
                "$ref": "#/components/schemas/WarningMessageDTO"
              }
            ]
          },
          "expire_datetime": {
            "type": "string",
            "description": "Timestamp nach UTC, bis wann das Ergebnis auf dem Server vorgehalten wird",
            "format": "date-time",
            "example": "2022-01-27T20:23:56Z"
          }
        },
        "description": "Ergebnis von Interaktions- und Kontraindikationschecks in verschiedener Form, u.a. URLs zur Darstellung des Ergebnisses des QuickChecks in einem WebView"
      },
      "AmtsFullCheckResponseDataDTO": {
        "required": [
          "status",
          "license_type",
          "redirect_url",
          "expire_datetime",
          "updated_datetime",
          "created_datetime"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Objekttyp AFR f\u00fcr AMTS-Full-Check-Result",
            "example": "AFR",
            "pattern": "^AFR$"
          },
          "status": {
            "type": "string",
            "description": "Aktueller Zustand der Medikationsanalyse. 'pending': request wurde an das Zielsystem \u00fcbertragen. 'fetched': request wurde vom Zielsystem abgeholt, entschl\u00fcsselt und f\u00fcr Bearbeitung bereitgestellt. 'processed': AMTS-Analyse wurde durchgef\u00fchrt. 'completed': AMTS-Analyse wurde (ggf. nach Bearbeitung durch den Nutzer) als abgeschlossen markiert. 'error': bei der Verarbeitung trat ein Fehler auf. 'rejected': der Request oder die daraus resultierende AMTS-Analyse wurde (vom Nutzer) im Zielsystem gel\u00f6scht.",
            "example": "pending",
            "enum": [
              "pending",
              "fetched",
              "processed",
              "completed",
              "error",
              "rejected"
            ]
          },
          "license_type": {
            "type": "string",
            "description": "Aktuelle ADAS AMTS Lizenz",
            "example": "basic",
            "enum": [
              "basic",
              "premium"
            ]
          },
          "customer": {
            "$ref": "#/components/schemas/CustomerAmtsSecureDTO"
          },
          "notifications": {
            "type": "array",
            "description": "Letzte Benachrichtigungen zu dieser Medikationsanalyse",
            "items": {
              "allOf": [
                {
                  "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ServerObjectDTO"
                },
                {
                  "$ref": "#/components/schemas/AmtsNotificationDTO"
                }
              ]
            }
          },
          "redirect_url": {
            "type": "string",
            "description": "Weiterleitungsziel zur Eingabemaske der externen AMTS-Anwendung f\u00fcr Medikationsanalysen. URL enth\u00e4lt Sessioninformationen, kann auch auf einem anderen Ger\u00e4t, bspw. einenm Tablet ge\u00f6ffnet werden und ist bis expire_datetime g\u00fcltig.",
            "example": "https://<domain>/<...>/123e4567-e89b-12d3-a456-9AC7CBDCEE52?token=123456789"
          },
          "full_pdf_url": {
            "type": "string",
            "description": "Nur bei Status completed: Link auf das PDF mit alle Ergebnissen, bspw. f\u00fcr die interne Archivierung. Mit public_key des Falls verschl\u00fcsselt.",
            "example": "https://<domain>/<...>/123e4567-e89b-12d3-a456-9AC7CBDCEE52.full.pdf.enc"
          },
          "doctor_pdf_url": {
            "type": "string",
            "description": "Nur bei Status completed: Link auf das PDF mit den f\u00fcr den Arzt ausgew\u00e4hlten Ergebnissen. Mit public_key des Falls verschl\u00fcsselt.",
            "example": "https://<domain>/<...>/123e4567-e89b-12d3-a456-9AC7CBDCEE52.doctor.pdf.enc"
          },
          "patient_pdf_url": {
            "type": "string",
            "description": "Nur bei Status completed: Link auf das PDF mit den f\u00fcr den Patienten ausgew\u00e4hlten Ergebnissen. Mit public_key des Falls verschl\u00fcsselt.",
            "example": "https://<domain>/<...>/123e4567-e89b-12d3-a456-9AC7CBDCEE52.patient.pdf.enc"
          },
          "bmp_pdf_url": {
            "type": "string",
            "description": "Nur bei Status completed: Link auf das PDF mit bundeseinheitlichem Medikationsplan (BMP). Mit public_key des Falls verschl\u00fcsselt.",
            "example": "https://<domain>/<...>/123e4567-e89b-12d3-a456-9AC7CBDCEE52.bmp.pdf.enc"
          },
          "expire_datetime": {
            "type": "string",
            "description": "Timestamp nach UTC, bis wann das Ergebnis auf dem Server vorgehalten wird",
            "format": "date-time",
            "example": "2022-01-27T20:23:56Z"
          },
          "updated_datetime": {
            "type": "string",
            "description": "Timestamp nach UTC der letzten Aktualisierung des Transfer-Datensatzes",
            "format": "date-time",
            "example": "2021-12-27T20:23:56Z"
          },
          "created_datetime": {
            "type": "string",
            "description": "Timestamp nach UTC der Erstellung des Transfer-Datensatzes",
            "format": "date-time",
            "example": "2021-12-27T20:23:56Z"
          }
        },
        "description": "Status der Medikationsanalyse und ggf. Ergebnisse"
      },
      "AmtsCheckResultDTO": {
        "required": [
          "type",
          "stable_id",
          "check_type",
          "risk",
          "is_resolved",
          "color",
          "description",
          "problemtext"
        ],
        "type": "object",
        "properties": {
          "type": {
            "pattern": "^AMR$",
            "type": "string",
            "description": "Objekttyp",
            "example": "AMR"
          },
          "stable_id": {
            "type": "string",
            "description": "Stabile ID \u00fcber mehrere Treffer hinweg (zur Filterung gel\u00f6ster Treffer; SHA-256)",
            "example": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
          },
          "check_type": {
            "type": "string",
            "description": "Art des Checkergebnisses",
            "example": "interaction",
            "enum": [
              "interaction:medication",
              "interaction:food",
              "contraindication:disease",
              "contraindication:age",
              "contraindication:weight",
              "contraindication:allergies",
              "contraindication:gender",
              "contraindication:renal",
              "restriction:disease",
              "restriction:age",
              "restriction:weight",
              "restriction:allergies",
              "restriction:gender",
              "restriction:renal",
              "contraindication_questionable:disease",
              "contraindication_questionable:age",
              "contraindication_questionable:weight",
              "contraindication_questionable:allergies",
              "contraindication_questionable:gender",
              "contraindication_questionable:renal",
              "restriction_questionable:disease",
              "restriction_questionable:age",
              "restriction_questionable:weight",
              "restriction_questionable:allergies",
              "restriction_questionable:gender",
              "restriction_questionable:renal",
              "duplicate:medication"
            ]
          },
          "risk": {
            "type": "string",
            "description": "Risikoeinstufung des Checkergebnisses",
            "example": "veryHighRisk",
            "enum": [
              "veryHighRisk",
              "highRisk",
              "mediumRisk",
              "lowRisk"
            ]
          },
          "is_resolved": {
            "type": "boolean",
            "description": "Gekl\u00e4rter Checktreffer",
            "example": false
          },
          "color": {
            "type": "string",
            "description": "Farbcode des Checkergebnisses (hexadezimaler Farbcode)",
            "example": "FFA500"
          },
          "description": {
            "type": "string",
            "description": "Kurzbeschreibung des Treffers, bspw. zur Darstellung neben einer Checkbox zur Auswahl eines Treffers.",
            "example": "Atorvastatin \u2190 Clarithromycin (schwerwiegend)"
          },
          "problemtext": {
            "type": "string",
            "description": "Problemtext eines Treffers. Formatierung in Markdown (ggf. enthaltene Links sind stabil, also \u00fcber expire_datetime hinaus aufrufbar).",
            "example": "ABDATA-Klassifikation: schwerwiegend (rot); Datenlage gut   \nDie Interaktion kann potenziell lebensbedrohlich sein oder zu schwerwiegenden, eventuell irreversiblen Folgen f\u00fcr den Patienten f\u00fchren.\n\n- ***Atorvastatin Aristo 20mg*** (Atorvastatin) \u2190 ***Clarithromycin HEXAL 250mg*** (Clarithromycin):  \n     Erh\u00f6htes Risiko von Myopathien und Nierenversagen\n\nWeitere Informationen hierzu finden Sie in den [Details zur Interaktion](https://<domain>/core/details/abdata/int/58291)"
          },
          "solutiontext": {
            "type": "string",
            "description": "L\u00f6sungstext eines Treffers. Formatierung in Markdown (ggf. enthaltene Links sind stabil, also \u00fcber expire_datetime hinaus aufrufbar).",
            "example": "Die gleichzeitige Anwendung von Atorvastatin und Clarithromycin wird nicht empfohlen. Eine Unterbrechung der lipidsenkenden Therapie kann - au\u00dfer w\u00e4hrend akuter Koronarsyndrome - erwogen werden. Mit Fluvastatin und Rosuvastatin ist keine Interaktion zu erwarten, so dass diese als Alternativen in Frage kommen. Roxithromycin und Spiramycin erh\u00f6hen das Risiko von Myopathien unter CSE-Hemmern wahrscheinlich nicht; besonders bei hoher Dosierung des CSE-Hemmers ist aber daran zu denken. Patienten, die CSE-Hemmer erhalten, sollen \u00fcber das Risiko der Myopathie informiert werden. Treten Myopathie-Symptome auf, sollen sie umgehend ihren Arzt aufsuchen. Die Creatinkinase-Aktivit\u00e4t soll \u00fcberwacht werden: Bei einem Anstieg der Creatinkinase-Aktivit\u00e4t auf mehr als das 10-Fache des oberen Normwertes (ab etwa 2000 U/l) oder intolerablen Muskelbeschwerden muss der CSE-Hemmer abgesetzt werden. Bei einem geringeren Creatinkinase-Anstieg und leichteren Beschwerden soll die Dosierung des CSE-Hemmers vor\u00fcbergehend reduziert und die Creatinkinase-Aktivit\u00e4t engmaschig kontrolliert werden. Je nach den individuellen Umst\u00e4nden kann auch hier das Absetzen des CSE-Hemmers sinnvoll sein."
          },
          "sourcetext": {
            "type": "string",
            "description": "Quellen und Hinweise zu einem Treffer. Formatierung in Markdown (ggf. enthaltene Links sind stabil, also \u00fcber expire_datetime hinaus aufrufbar).",
            "example": "Hinweis: die ABDATA-Kategorien wie \u201eschwerwiegend\u201c (rot), \u201emittelschwer\u201c (orange), \u201egering\u201c (gelb) oder \u201ekeine Aussage m\u00f6glich\u201c (grau) beziehen sich auf die klinische Relevanz des interaktionsbedingten Effekts (falls dieser eintreten sollte)..."
          },
          "source": {
            "type": "string",
            "description": "Herkunft des Treffers (record = Historie, sale = Abverkauf; record <-> record = record, sale <-> sale = sale, sale <-> record = mixed)",
            "example": "record",
            "enum": [
              "record",
              "sale",
              "mixed"
            ]
          },
          "suffix": {
            "type": "string",
            "description": "Zus\u00e4tzlicher Erweiterung zum Check Namen um bei dem Treffer einen besonderen Kontext anzuzeigen.",
            "example": "(KH)*"
          },
          "check_detailed_data_interaction": {
            "$ref": "#/components/schemas/InteractionDetailDTO"
          },
          "check_detailed_data_contraindication": {
            "$ref": "#/components/schemas/ContraindicationDetailDTO"
          },
          "check_detailed_data_duplicates": {
            "$ref": "#/components/schemas/DuplicatesDetailDTO"
          }
        },
        "description": "Strukturierte Daten eines Check-Treffers"
      },
      "AmtsCheckResultIconDTO": {
        "required": [
          "type",
          "icon_type",
          "risk",
          "color",
          "total",
          "resolved"
        ],
        "type": "object",
        "properties": {
          "type": {
            "pattern": "^AIC$",
            "type": "string",
            "description": "Objekttyp",
            "example": "AIC"
          },
          "icon_type": {
            "type": "string",
            "description": "Gibt den Typ des Icons an (eines aus 8 definierten Icons f\u00fcr den QuickCheck).",
            "example": "interaction",
            "enum": [
              "interaction:medication",
              "interaction:food",
              "contraindication:gender",
              "contraindication:age",
              "contraindication:disease",
              "contraindication:allergies",
              "contraindication:weight",
              "contraindication:renal",
              "duplicates:medication"
            ]
          },
          "risk": {
            "type": "string",
            "description": "Gibt das h\u00f6chste nicht-gekl\u00e4rte Risiko der im Icon zusammengefassten Treffer an, d.h. alle bereits gekl\u00e4rten Treffer werden nicht miteinbezogen.",
            "example": "veryHighRisk",
            "enum": [
              "veryHighRisk",
              "highRisk",
              "mediumRisk",
              "lowRisk",
              "noRisk"
            ]
          },
          "color": {
            "type": "string",
            "description": "Hexadezimaler Farbcode der ABDATA f\u00fcr das h\u00f6chste nicht-gekl\u00e4rte Risiko der im Icon zusammengefassten Treffer, d.h. alle bereits gekl\u00e4rten Treffer werden nicht miteinbezogen. Es werden i.d.R. vier Farben zur Darstellung verwendet, lediglich bei Interaktionen ist auch ein dunkelrot m\u00f6glich.",
            "example": "E10000"
          },
          "total": {
            "type": "integer",
            "description": "Gesamtanzahl der Treffer f\u00fcr diesen Typ.",
            "format": "int32",
            "example": 14
          },
          "resolved": {
            "type": "integer",
            "description": "Gesamtanzahl der bereits als gekl\u00e4rt markierten Treffer f\u00fcr diesen Typ.",
            "format": "int32",
            "example": 8
          },
          "title": {
            "type": "string",
            "description": "Optionaler Titel f\u00fcr das Icon. Abh\u00e4ngig von vorhandenen Treffern entweder positiv formuliert ('Anwendungsrisiken - Alter') oder negativ formuliert ('kein Anwendungsrisiko - Alter').",
            "example": "Anwendungsrisiken - Alter"
          }
        }
      },
      "WarningMessageDTO": {
        "required": [
          "type",
          "body"
        ],
        "type": "object",
        "properties": {
          "type": {
            "pattern": "^WAM$",
            "type": "string",
            "description": "Objekttyp",
            "example": "WAM"
          },
          "code": {
            "type": "string",
            "description": "Eindeutiger Code/Typ f\u00fcr jede Warnmeldung, bspw. PZN-Suche nicht erfolgreich (fam_not_found) oder Key_MIV konnte nicht zugeordnet werden (miv_not_found).",
            "example": "fam_not_found"
          },
          "title": {
            "type": "string",
            "description": "\u00dcberschrift der Wanrmeldung"
          },
          "body": {
            "type": "string",
            "description": "Text der Warnmeldung, kann Markdown (ohne Links) enthalten.",
            "example": "Das Medikament *x*, aus einem fr\u00fcheren Abverkaufsvorgang, konnte in der Analyse nicht ber\u00fccksichtigt werden, da ."
          }
        }
      },
      "InteractionDetailDTO": {
        "required": [
          "type",
          "key_int",
          "direction",
          "relevance"
        ],
        "type": "object",
        "properties": {
          "type": {
            "pattern": "^INT$",
            "type": "string",
            "description": "Objekttyp",
            "example": "INT"
          },
          "key_int": {
            "type": "integer",
            "description": "ABDATA Schl\u00fcssel der Interaktion",
            "format": "int32",
            "example": 45
          },
          "right": {
            "$ref": "#/components/schemas/MedicationDTO"
          },
          "left": {
            "$ref": "#/components/schemas/MedicationDTO"
          },
          "direction": {
            "type": "string",
            "description": "Richtung der Interaktion",
            "example": "no_direction",
            "enum": [
              "no_direction",
              "unidirectional",
              "bidirectional"
            ]
          },
          "data_validation": {
            "type": "string",
            "description": "Datenlage der Interaktion",
            "example": "good",
            "enum": [
              "good",
              "sufficient",
              "weak",
              "not_sufficient",
              "unknown"
            ]
          },
          "relevance": {
            "type": "string",
            "description": "Klinische Relevanz der Interaktion",
            "example": "contraindicated",
            "enum": [
              "no_statement",
              "no_interaction",
              "product_specific_alert",
              "low",
              "moderate",
              "serious",
              "contraindicated"
            ]
          }
        },
        "description": "Strukturierte Daten einer Interaktion (genau dann gef\u00fcllt, wenn check_type mit 'interaction' beginnt. Bei check_type=interaction:medication muss left und right gef\u00fcllt sein. Bei check_type=interaction:food ist immer genau left gef\u00fcllt.)"
      },
      "ContraindicationDetailDTO": {
        "required": [
          "type",
          "ci_type",
          "medication"
        ],
        "type": "object",
        "properties": {
          "type": {
            "pattern": "^KON$",
            "type": "string",
            "description": "Objekttyp",
            "example": "KON"
          },
          "ci_type": {
            "type": "string",
            "description": "Typ der Kontraindikation",
            "example": "disease",
            "enum": [
              "disease",
              "age",
              "allergies",
              "renal",
              "weight",
              "gender"
            ]
          },
          "medication": {
            "$ref": "#/components/schemas/MedicationDTO"
          },
          "medical_individual_parameter": {
            "$ref": "#/components/schemas/MedicalIndividualParameterDTO"
          },
          "rating": {
            "type": "string",
            "description": "Bewertung der Kontraindikation",
            "example": "absolute",
            "enum": [
              "absolute",
              "relative",
              "atypical"
            ]
          }
        },
        "description": "Strukturierte Daten einer Kontraindikation oder Anwendungsbeschr\u00e4nkung. (genau dann gef\u00fcllt, wenn check_type mit 'contraindication' oder 'restriction' beginnt)"
      },
      "DuplicatesDetailDTO": {
        "required": [
          "type",
          "medication"
        ],
        "type": "object",
        "properties": {
          "type": {
            "pattern": "^DBL$",
            "type": "string",
            "description": "Objekttyp",
            "example": "DBL"
          },
          "medication": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MedicationDTO"
            }
          }
        },
        "description": "Strukturierte Daten einer Doppelverordnung."
      },
      "AmtsNotificationDTO": {
        "required": [
          "type",
          "notification_type",
          "subject",
          "timestamp"
        ],
        "type": "object",
        "properties": {
          "type": {
            "pattern": "^ANO$",
            "type": "string",
            "description": "Objekttyp",
            "example": "ANO"
          },
          "notification_type": {
            "type": "string",
            "description": "Art der Benachrichtigung",
            "example": "doctor-feedback",
            "enum": [
              "shared-record-feedback",
              "doctor-feedback"
            ]
          },
          "subject": {
            "type": "string",
            "description": "Betreff der Benachrichtigung",
            "example": "R\u00fcckmeldung eines Arztes zu einer Medikationsanalyse"
          },
          "body": {
            "type": "string",
            "description": "Text der Benachrichtigung, kann Markdown (ohne Links) enthalten.",
            "example": ""
          },
          "action_url": {
            "type": "string",
            "description": "Direkte URL unter der eine Aktion zur Benachrichtigung erfolgen kann, bspw. zur Medikationsanalyse, auf die sich die Meldung bezieht. URL enth\u00e4lt Sessioninformationen, kann auch auf einem anderen Ger\u00e4t, bspw. einenm Tablet ge\u00f6ffnet werden.",
            "example": "https://<domain>/<...>/123e4567-e89b-12d3-a456-9AC7CBDCEE52?token=123456789"
          },
          "timestamp": {
            "type": "string",
            "description": "Timestamp nach UTC, wann die Meldung ausgel\u00f6st wurde",
            "format": "date-time",
            "example": "2022-01-27T20:23:56Z"
          }
        }
      },
      "ServerVersionTypeDTO": {
        "type": "object",
        "required": [
          "server_version_type"
        ],
        "properties": {
          "server_version_type": {
            "type": "string",
            "description": "Versions-Art (Basis-Version / Premium-Version)",
            "example": "basic",
            "enum": [
              "basic",
              "premium"
            ]
          }
        }
      },
      "AmtsExtendedResponseServerMetaDTO": {
        "type": "object",
        "required": [
          "meta"
        ],
        "description": "Erg\u00e4nzt die allgemeinen Metadaten der Antwort eine Anfrage an einen A2B-Service um die Information welche Lizenz der SaaS-Nutzer serverseitig hat.",
        "properties": {
          "meta": {
            "type": "object",
            "allOf": [
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ServerDTO"
              },
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ServerTransDTO"
              },
              {
                "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/ResDTO"
              },
              {
                "$ref": "#/components/schemas/ServerVersionTypeDTO"
              }
            ]
          }
        }
      }
    }
  },
  "security": [
    {
      "NGDA_OAuth2": [
        "urn-ngda-services-crs"
      ]
    },
    {
      "NGDA_OpenID": [
        "urn-ngda-services-crs"
      ]
    }
  ]
}