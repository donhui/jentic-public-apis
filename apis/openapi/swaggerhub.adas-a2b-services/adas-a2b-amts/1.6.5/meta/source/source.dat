  "paths": {
    "/pharmacy/{pha_soid}/amts/quickcheck": {
      "post": {
        "summary": "Apotheke fordert im Rahmen eines Abverkaufsvorgangs eine Pr\u00fcfung der Medikation f\u00fcr den Kunden an",
        "description": "Es kann neben den Medikamenten im Abverkauf auch eine Historie aus der Kundendatenbank \u00fcbermittelt werden. Die \u00fcbermittelten Medikamente, Daten des Kunden und Erkrankungen werden auf Interaktionen und Kontraindikationen gepr\u00fcft. Das Ergebnis kann in Form einer SVG angezeigt, in Form einer HTML-Seite in einem WebView dargestellt oder in Form einer PDF gedruckt oder archiviert werden.",
        "operationId": "post_pharmacy_amts_quickcheck",
        "tags": [
          "amts"
        ],
        "parameters": [
          {
            "name": "pha_soid",
            "in": "path",
            "description": "Global eindeutige Object-ID der Apotheke {soid} \u00fcber alle Instanzen des Servers hinweg. Bspw. N-ID.",
            "example": 123,
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          }
        ],
        "requestBody": {
          "description": "Informationen zur Durchf\u00fchrung von Interaktions- und Kontraindikationschecks.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/RequestMetaDTO"
                  },
                  {
                    "$ref": "#/components/schemas/PharmacyAmtsQuickCheckRequestDataDTO"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/PharmacyAmtsQuickCheckPostResponse"
          },
          "400": {
            "$ref": "#/components/responses/PharmacyAmtsCheckErrorResponse"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "422": {
            "$ref": "#/components/responses/422"
          },
          "500": {
            "$ref": "#/components/responses/500"
          },
          "504": {
            "$ref": "#/components/responses/504"
          }
        }
      }
    },
    "/pharmacy/{pha_soid}/amts/fullcheck": {
      "post": {
        "summary": "Apotheke \u00fcbermittelt f\u00fcr Medikationsanalyse Basisdaten an eine externe AMTS-Anwendung",
        "description": "Die \u00fcbermittelten Medikamente inkl. Dosierung, Daten des Kunden und Erkrankungen werden im Zielsystem in einer Eingabemaske angezeigt, dort ggf. um weitere Informationen erweitert und im Anschluss analysiert. Als Einstieg in diese externe AMTS-Anwendung wird eine Redirect-URL zur\u00fcckgegeben.",
        "operationId": "post_pharmacy_amts_fullcheck",
        "tags": [
          "amts"
        ],
        "parameters": [
          {
            "name": "pha_soid",
            "in": "path",
            "description": "Global eindeutige Object-ID der Apotheke {soid} \u00fcber alle Instanzen des Servers hinweg. Bspw. N-ID.",
            "example": 123,
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          }
        ],
        "requestBody": {
          "description": "Vorhandene Informationen, die f\u00fcr eine Medikationsanalyse relevant sind, zur \u00dcbernahme in die Software.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "https://api.swaggerhub.com/apis/ADAS-A2B-Services/adas-a2b-common/1.0.0#/components/schemas/RequestMetaDTO"
                  },
                  {
                    "$ref": "#/components/schemas/PharmacyAmtsFullCheckRequestDataDTO"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/PharmacyAmtsFullCheckPostResponse"
          },
          "204": {
            "$ref": "#/components/responses/204"
          },
          "400": {
            "$ref": "#/components/responses/PharmacyAmtsCheckErrorResponse"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "422": {
            "$ref": "#/components/responses/422"
          },
          "500": {
            "$ref": "#/components/responses/500"
          },
          "504": {
            "$ref": "#/components/responses/504"
          }
        }
      },
      "get": {
        "summary": "Apotheke ruft den Status aller Medikationsanalysen und ggf. Ergebnis-Dokumente zu einer pha_soid ab.",
        "description": "Abrufen des Status und ggf. von Dokumenten aller Medikationsanalysen.",
        "operationId": "get_pharmacy_amts_fullcheck",
        "tags": [
          "amts"
        ],
        "parameters": [
          {
            "name": "pha_soid",
            "in": "path",
            "description": "Global eindeutige Object-ID der Apotheke {soid} \u00fcber alle Instanzen des Servers hinweg. Bspw. N-ID.",
            "example": 123,
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          },
          {
            "name": "updated_days",
            "in": "query",
            "description": "Einschr\u00e4nkung auf Analysen, die in den letzten x Tagen bearbeitet wurden (Standard: 30 Tage).",
            "example": 90,
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 180
            }
          },
          {
            "name": "created_days",
            "in": "query",
            "description": "Einschr\u00e4nkung auf Analysen, die in den letzten x Tagen erstellt wurden (Standard: keine Einschr\u00e4nkung).",
            "example": 90,
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 180
            }
          },
          {
            "name": "days",
            "in": "query",
            "description": "Abruf der Analysen, die in den letzten x Tagen bearbeitet wurden (Standard: 30 Tage). Deprecated: durch updated_days ersetzt.",
            "example": 90,
            "deprecated": true,
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 180
            }
          },
          {
            "name": "legacy",
            "in": "query",
            "description": "Abruf aller Analysen, die in einem Bestandsaccount VOR der Verkn\u00fcpfung mit der Datenbank erstellt wurden. Wird nur ben\u00f6tigt, falls Warenwirtschaft einen Abgleich mit den dort vorhandenen Patienten durchf\u00fchren will. Es werden ausschlie\u00dflich diese Legacy-Daten zur\u00fcckgegeben. Optionaler Parameter, kann \u00fcblicherweise entfallen.",
            "example": false,
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/PharmacyAmtsFullCheckGetArrayResponse"
          },
          "400": {
            "$ref": "#/components/responses/PharmacyAmtsCheckErrorResponse"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "500": {
            "$ref": "#/components/responses/500"
          },
          "504": {
            "$ref": "#/components/responses/504"
          }
        }
      }
    },
