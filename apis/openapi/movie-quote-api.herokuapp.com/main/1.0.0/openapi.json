{
  "openapi": "3.0.3",
  "info": {
    "title": "Movie Quote API",
    "version": "1.0.0",
    "description": "A free API to get random movie quotes. Supports filtering by show and censored mode.",
    "x-jentic-source-url": "https://github.com/F4R4N/movie-quote"
  },
  "servers": [
    {
      "url": "https://movie-quote-api.herokuapp.com"
    }
  ],
  "paths": {
    "/v1/quote/": {
      "get": {
        "operationId": "getrandomquote",
        "summary": "Get a random quote",
        "description": "Returns a random quote from all available quotes.",
        "tags": [
          "Quotes"
        ],
        "parameters": [
          {
            "name": "censored",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "If true, exclude quotes containing adult language"
          }
        ],
        "responses": {
          "200": {
            "description": "A random quote",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/shows/": {
      "get": {
        "operationId": "listshows",
        "summary": "List available shows",
        "description": "Returns a list of available show slugs.",
        "tags": [
          "Shows"
        ],
        "responses": {
          "200": {
            "description": "List of shows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Show"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/shows/{showSlug}": {
      "get": {
        "operationId": "getquotebyshow",
        "summary": "Get a random quote from a specific show",
        "description": "Returns a random quote from the specified show.",
        "tags": [
          "Quotes"
        ],
        "parameters": [
          {
            "name": "showSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The show slug identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "A random quote from the specified show",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request or invalid show slug",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Quote": {
        "type": "object",
        "properties": {
          "quote": {
            "type": "string",
            "description": "The quote text"
          },
          "role": {
            "type": "string",
            "description": "Character who said the quote"
          },
          "show": {
            "type": "string",
            "description": "Show or movie the quote is from"
          }
        }
      },
      "Show": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": [],
  "tags": [
    {
      "name": "Quotes",
      "description": "Operations related to Quotes"
    },
    {
      "name": "Shows",
      "description": "Operations related to Shows"
    }
  ]
}