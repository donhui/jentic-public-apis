                  "$ref": "#/components/schemas/LoansChangeErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoansChangeErrorResponse"
                }
              }
