              "type": "string",
              "format": "base64"
            }
          },
          {
            "in": "header",
            "name": "company-id",
            "description": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u043f\u0430\u0440\u0442\u043d\u0451\u0440\u0430",
            "example": "b4cc5d5d-4aba-47c7-b248-4854b1fe3793",
