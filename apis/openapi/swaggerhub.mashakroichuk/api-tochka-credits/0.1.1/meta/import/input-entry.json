{
  "openapi": "3.0.3",
  "info": {
    "title": "API со стороны Точки",
    "description": "Комуникации с партнером по предварительно одобренному кредитному офферу",
    "version": "0.1.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/MashaKroichuk/API_Tochka_Credits/0.1.1/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/MashaKroichuk/API_Tochka_Credits/0.1.1"
    }
  ],
  "paths": {
    "/rest-api/v1/offer": {
      "post": {
        "summary": "Передать параметры кредита в Точку",
        "tags": [
          "ApplicationController"
        ],
        "operationId": "createOffer",
        "parameters": [
          {
            "in": "header",
            "name": "signature-value",
            "description": "Значение электронной подписи УНЭП, закодированное в Base64",
            "example": "Base64",
            "required": true,
            "schema": {
              "type": "string",
              "format": "base64"
            }
          },
          {
            "in": "header",
            "name": "company-id",
            "description": "Идентификатор партнёра",
            "example": "b4cc5d5d-4aba-47c7-b248-4854b1fe3793",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SmeCreditOffer"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Предложение уже существует. Параметры не обновлены",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "201": {
            "description": "Предложение получено и сохранено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные данные запроса",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoansChangeErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoansChangeErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Ошибка соединения"
          }
        }
      }
    },
    "/rest-api/v1/application/activation/refuse": {
      "post": {
        "summary": "Сообщить о проблемах на активации",
        "tags": [
          "ApplicationController"
        ],
        "operationId": "activationRefuse",
        "parameters": [
          {
            "in": "header",
            "name": "signature-value",
            "description": "Значение электронной подписи УНЭП, закодированное в Base64",
            "example": "Base64",
            "required": true,
            "schema": {
              "type": "string",
              "format": "base64"
            }
          },
          {
            "in": "header",
            "name": "company-id",
            "description": "Идентификатор партнёра",
            "example": "b4cc5d5d-4aba-47c7-b248-4854b1fe3793",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ActivationRefused"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Информация об отказе получена",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные данные запроса",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoansChangeErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoansChangeErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Ошибка соединения"
          }
        }
      }
    },
    "/v1/loans_change": {
      "post": {
        "summary": "Сообщить об успешной активации кредита",
        "tags": [
          "ApplicationController"
        ],
        "operationId": "activationSucces",
        "parameters": [
          {
            "in": "header",
            "name": "signature-value",
            "description": "Значение электронной подписи УНЭП, закодированное в Base64",
            "example": "Base64",
            "required": true,
            "schema": {
              "type": "string",
              "format": "base64"
            }
          },
          {
            "in": "header",
            "name": "company-id",
            "description": "Идентификатор партнёра",
            "example": "b4cc5d5d-4aba-47c7-b248-4854b1fe3793",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContractInfo"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SuccessResponse"
                    },
                    {
                      "$ref": "#/components/schemas/LoansChangeErrorResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Некорректные данные запроса",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoansChangeErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoansChangeErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Ошибка соединения"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SmeCreditOffer": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "description": "ID запроса Точки на кредит"
          },
          "applicationId": {
            "type": "string",
            "description": "ID кредитной заявки"
          },
          "companyInn": {
            "type": "string",
            "description": "ИНН компании"
          },
          "offerPayload": {
            "$ref": "#/components/schemas/SmeCreditOfferPayload"
          },
          "approvalDeadlineDate": {
            "type": "string",
            "description": "Дата, до которой действителен оффер",
            "format": "date-time"
          }
        },
        "required": [
          "applicationId",
          "companyInn",
          "requestId",
          "offerPayload",
          "approvalDeadlineDate"
        ]
      },
      "SmeCreditOfferPayload": {
        "type": "object",
        "properties": {
          "clientAmount": {
            "type": "number",
            "description": "Одобренная сумма в рублях"
          },
          "maxTerm": {
            "type": "integer",
            "description": "Максимальный срок кредита в месяцах"
          },
          "minTerm": {
            "type": "integer",
            "description": "Минимальный срок кредита в месяцах"
          },
          "rate": {
            "type": "number",
            "description": "Ставка по кредиту"
          },
          "productType": {
            "type": "string",
            "enum": [
              "TL_SME"
            ],
            "description": "Тип продукта"
          },
          "applicationUuid": {
            "type": "string",
            "description": "UUID кредитного договора"
          },
          "suretyUuid": {
            "type": "string",
            "description": "UUID договора поручительства"
          }
        },
        "required": [
          "clientAmount",
          "maxClientAmount",
          "maxTerm",
          "minTerm",
          "rate",
          "productType",
          "applicationUuid"
        ]
      },
      "ActivationRefused": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "description": "ID запроса Точки на кредит"
          },
          "applicationId": {
            "type": "string",
            "description": "ID заявки"
          },
          "result": {
            "type": "string",
            "enum": [
              "REJECT"
            ],
            "description": "Результат процесса активации"
          },
          "refuseReason": {
            "type": "string",
            "description": "Причина ошибки"
          }
        },
        "required": [
          "requestId",
          "applicationId",
          "result",
          "refuseReason"
        ]
      },
      "ContractInfo": {
        "type": "object",
        "description": "Информация по договорам",
        "required": [
          "id",
          "inn",
          "loans"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "requestId запроса Точки на кредит",
            "example": "1328786969"
          },
          "name": {
            "type": "string",
            "description": "Наименование клиента",
            "example": "ООО Еврострой сервис"
          },
          "inn": {
            "type": "string",
            "description": "ИНН компании",
            "example": "7700958462"
          },
          "loans": {
            "type": "array",
            "description": "Список активированных кредитов",
            "items": {
              "$ref": "#/components/schemas/ServicedLoanInfo"
            }
          }
        }
      },
      "ServicedLoanInfo": {
        "type": "object",
        "description": "Информация по обслуживаемому кредиту",
        "required": [
          "info",
          "graphPayment"
        ],
        "properties": {
          "info": {
            "$ref": "#/components/schemas/LoanInfo",
            "description": "Общая информация по кредиту"
          },
          "nextPayment": {
            "$ref": "#/components/schemas/Payment",
            "description": "Информация по платежу"
          },
          "earlyPayment": {
            "$ref": "#/components/schemas/EarlyPayment",
            "description": "Информация по досрочному погашению"
          },
          "graphPayment": {
            "type": "array",
            "description": "График платежей",
            "items": {
              "$ref": "#/components/schemas/Payment"
            }
          }
        }
      },
      "LoanInfo": {
        "type": "object",
        "description": "Информация по кредиту",
        "required": [
          "productName",
          "contractNumber",
          "contractId",
          "amount",
          "baseRate",
          "status",
          "remainАmount",
          "percentAccrued",
          "overPrincipalTotal",
          "paidOverPrincipalTotal",
          "overPercentsTotal",
          "paidOverPercentsTotal",
          "penOverPercentsTotal",
          "paidPenOverPercentsTotal",
          "penOverPrincipalTotal",
          "issueDate",
          "validDate",
          "loanTerm",
          "percentsOverDebt",
          "paidPercentsOverDebt",
          "paidPenOverPrincipalTotal"
        ],
        "properties": {
          "productName": {
            "type": "string",
            "description": "Наименование продукта",
            "example": "Оборотный кредит межбанк"
          },
          "contractNumber": {
            "type": "string",
            "description": "Номер кредитного договора в Тбанке",
            "example": "498416565"
          },
          "contractId": {
            "type": "integer",
            "format": "int64",
            "description": "Id кредита в вызывающей системе (номер договора в Тбанке)",
            "example": 498416565
          },
          "transferAccountNumber": {
            "type": "string",
            "description": "Номер транзитного счета клиента в Тбанке",
            "example": "47422810900000099999"
          },
          "amount": {
            "type": "number",
            "format": "float",
            "description": "Сумма, на которую выдали кредит",
            "example": 3000000
          },
          "baseRate": {
            "type": "number",
            "format": "float",
            "description": "Ставка (комиссия)",
            "example": 20
          },
          "overPrincipalTotal": {
            "type": "number",
            "format": "float",
            "description": "Просроченная задолженность по кредиту на текущий момент",
            "example": 0
          },
          "paidOverPrincipalTotal": {
            "type": "number",
            "format": "float",
            "description": "Оплаченная просроченная задолженность",
            "example": 0
          },
          "overPercentsTotal": {
            "type": "number",
            "format": "float",
            "description": "Просроченная комиссия (проценты), начисленная на текущий момент",
            "example": 0
          },
          "paidOverPercentsTotal": {
            "type": "number",
            "format": "float",
            "description": "Оплаченная просроченная комиссия (проценты)",
            "example": 0
          },
          "penOverPercentsTotal": {
            "type": "number",
            "format": "float",
            "description": "Пени за просроченные проценты (Начисленные на текущий момент)",
            "example": 0
          },
          "paidPenOverPercentsTotal": {
            "type": "number",
            "format": "float",
            "description": "Оплаченные пени за просроченные проценты (Общая)",
            "example": 0
          },
          "penOverPrincipalTotal": {
            "type": "number",
            "format": "float",
            "description": "Пени (штраф) за просроченный основной дол, начисленные на текущий момент",
            "example": 0
          },
          "paidPenOverPrincipalTotal": {
            "type": "number",
            "format": "float",
            "description": "Оплаченные пени (штрафы) за просроченный основной долг (Общая)",
            "example": 0
          },
          "issueDate": {
            "type": "string",
            "format": "date",
            "description": "Дата выдачи кредита",
            "example": "2022-04-25"
          },
          "validDate": {
            "type": "string",
            "format": "date",
            "description": "Дата закрытия кредита",
            "example": "2022-04-25"
          },
          "loanTerm": {
            "type": "integer",
            "format": "int64",
            "description": "Срок кредитования, мес.",
            "example": 84
          },
          "remainАmount": {
            "type": "number",
            "format": "float",
            "description": "Остаток основного долга",
            "example": 2934000
          },
          "percentAccrued": {
            "type": "number",
            "format": "float",
            "description": "Проценты текущие",
            "example": 3500
          },
          "percentsOverDebt": {
            "type": "number",
            "format": "float",
            "description": "Проценты на просроченный основной долг",
            "example": 0
          },
          "paidPercentsOverDebt": {
            "type": "number",
            "format": "float",
            "description": "Оплаченные проценты на просроченный основной долг",
            "example": 0
          },
          "status": {
            "type": "string",
            "enum": [
              "AVAILABLE",
              "CREATED",
              "NEW",
              "CLOSED",
              "EXECUTED"
            ],
            "description": "Статус кредита:\n * `AVAILABLE` - Доступен в работе\n * `CREATED` - Создан\n * `CLOSED` -  Закрыт         \n * `EXECUTED` - Исполнен\n"
          }
        }
      },
      "Payment": {
        "type": "object",
        "description": "Платеж",
        "required": [
          "paymentDate",
          "paymentAmount",
          "debtАmount",
          "percentАmount"
        ],
        "properties": {
          "paymentDate": {
            "type": "string",
            "format": "date",
            "description": "Дата платежа",
            "example": "2022-05-26"
          },
          "paymentAmount": {
            "type": "number",
            "format": "float",
            "description": "Сумма платежа",
            "example": 66000
          },
          "debtАmount": {
            "type": "number",
            "format": "float",
            "description": "основной долг",
            "example": 40000
          },
          "percentАmount": {
            "type": "number",
            "format": "float",
            "description": "Проценты (комиссия)",
            "example": 26000
          },
          "remainАmount": {
            "type": "number",
            "format": "float",
            "description": "Остаток основного долга",
            "example": 2934000
          }
        }
      },
      "EarlyPayment": {
        "type": "object",
        "description": "Досрочное погашение",
        "required": [
          "type",
          "operation",
          "date",
          "amount",
          "reduction"
        ],
        "properties": {
          "contractId": {
            "type": "integer",
            "format": "int64",
            "description": "Номер кредита",
            "example": 498416565
          },
          "type": {
            "type": "string",
            "enum": [
              "PARTIAL",
              "FULL"
            ],
            "description": "Тип погашения:\n * `PARTIAL` - Частичное погашение кредита\n * `FULL` - Полное погашение кредита\n"
          },
          "inn": {
            "type": "string",
            "description": "ИНН Клиента",
            "pattern": "^(([0-9]{12})|([0-9]{10}))?$",
            "example": 7754651564
          },
          "name": {
            "type": "string",
            "description": "Наименование Клиента",
            "example": "ООО Прайм"
          },
          "operation": {
            "type": "string",
            "enum": [
              "CALCULATE",
              "CREATE",
              "CANCEL"
            ],
            "description": "Выполняемое действие:\n * `CALCULATE` - Рассчитать\n * `CREATE` - Создать\n * `CANCEL` - Отменить\n"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Дата платежа",
            "example": "2022-05-26"
          },
          "amount": {
            "type": "number",
            "format": "float",
            "description": "Сумма операции",
            "example": 1000
          },
          "reduction": {
            "type": "string",
            "enum": [
              "TERM",
              "AMOUNT"
            ],
            "description": "Cнижение платежа:\n * `TERM` - Снижение срока \n * `AMOUNT` - Снижение размера платежа\n"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "LoansChangeErrorResponse": {
        "description": "Ошибка на ответ на запрос",
        "type": "object",
        "properties": {
          "code": {
            "type": "number",
            "format": "float",
            "description": "Код ошибки",
            "example": -32000
          },
          "message": {
            "type": "string",
            "description": "Сообщение об ошибке",
            "example": "Parse error"
          }
        }
      }
    }
  }
}