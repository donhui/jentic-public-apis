              }
            }
          },
          "400": {
            "description": "Token informado inv\u00e1lido ou inexistente.\n\n CPF do usu\u00e1rio autorizado inexistente ou inv\u00e1lido. \n\n Bad Request"
          },
          "404": {
            "description": "Sem resultado para estes par\u00e2metros."
          }
        }
      }
    },
    "/orgao/{numeroProtocolo}/detalhe": {
      "get": {
        "description": "Servi\u00e7o que retorna os detalhes de uma \u00fanica reclama\u00e7\u00e3o. Ser\u00e3o retornados os dados dos tr\u00e2mites e as informa\u00e7\u00f5es sobre o consumidor e o gestor da reclama\u00e7\u00e3o. Os anexos dos tr\u00e2mites estar\u00e3o sem os bytes do arquivo, sendo necess\u00e1rio acesso a outro recurso para baixar os bytes.",
        "tags": [
          "\u00d3rg\u00e3os de Monitoramento"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/host_param"
          },
          {
            "$ref": "#/components/parameters/user_agent_param"
          },
          {
            "$ref": "#/components/parameters/versao_param"
          },
          {
            "$ref": "#/components/parameters/cpf_autorizado_param"
          },
          {
            "name": "numeroProtocolo",
            "in": "path",
            "description": "Protocolo que deseja detalhar",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/response_200_detalhe"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Token informado inv\u00e1lido ou inexistente.\n\n CPF do usu\u00e1rio autorizado inexistente ou inv\u00e1lido. \n\n Bad Request"
          },
          "404": {
            "description": "Sem resultado para estes par\u00e2metros."
          }
        }
      }
    },
    "/orgao/reclamacao/{numeroProtocolo}/baixar": {
      "get": {
        "description": "Servi\u00e7o que retorna arquivo em base 64 de um relat\u00f3rio com os detalhes da reclama\u00e7\u00e3o dado um n\u00famero de protocolo.",
        "tags": [
          "\u00d3rg\u00e3os de Monitoramento"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/host_param"
          },
          {
            "$ref": "#/components/parameters/user_agent_param"
          },
          {
            "$ref": "#/components/parameters/versao_param"
          },
          {
            "$ref": "#/components/parameters/cpf_autorizado_param"
          },
          {
            "name": "numeroProtocolo",
            "in": "path",
            "description": "Protocolo que deseja detalhar",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/response_200_baixar"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Token informado inv\u00e1lido ou inexistente.\n\n CPF do usu\u00e1rio autorizado inexistente ou inv\u00e1lido. \n\n Bad Request"
          },
          "404": {
            "description": "Sem resultado para estes par\u00e2metros."
          }
        }
      }
    },
    "/orgao/{numeroProtocolo}/situacao": {
      "get": {
        "description": "Servi\u00e7o que retorna a situa\u00e7\u00e3o de um dado numero de protocolo.",
