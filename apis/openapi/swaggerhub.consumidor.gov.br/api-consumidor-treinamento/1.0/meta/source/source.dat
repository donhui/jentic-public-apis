    "/reclamacao/{numeroProtocolo}/complementar": {
      "post": {
        "description": "Servi\u00e7o para complementar uma reclama\u00e7\u00e3o.",
        "tags": [
          "Fornecedores"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/host_param"
          },
          {
            "$ref": "#/components/parameters/user_agent_param"
          },
          {
            "$ref": "#/components/parameters/versao_param"
          },
          {
            "$ref": "#/components/parameters/cpf_autorizado_param"
          },
          {
            "name": "numeroProtocolo",
            "in": "path",
            "description": "N\u00famero do protocolo que identifica uma \u00fanica reclama\u00e7\u00e3o.",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": "{\"texto\": \"Prezado consumidor, estamos avaliando sua reclama\u00e7\u00e3o e logo mais entraremos em contato.\"}"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/response_201_created"
                  }
                }
              }
            }
          }
        }
      }
    },
