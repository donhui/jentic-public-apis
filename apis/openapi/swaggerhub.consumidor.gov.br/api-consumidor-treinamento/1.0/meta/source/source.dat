    "/orgao/obter/situacoes": {
      "post": {
        "description": "Servi\u00e7o que retorna as situa\u00e7\u00f5es de uma lista de protocolos passada no corpo da requisi\u00e7\u00e3o.",
        "tags": [
          "\u00d3rg\u00e3os de Monitoramento"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/host_param"
          },
          {
