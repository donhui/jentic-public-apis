                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "codigoTipoTramiteReclamacao": {
        "name": "codigoTipoTramiteReclamacao",
        "in": "query",
        "description": "C\u00f3digo de um tipo de tr\u00e2mite das reclama\u00e7\u00f5es, sendo: Sendo 1) Abertura da reclama\u00e7\u00e3o, 2)Visualizada pelo fornecedor, 3) Resposta do fornecedor, 4) Avalia\u00e7\u00e3o do consumidor, 5)Reclama\u00e7\u00e3o finalizada, 6) Complemento da reclama\u00e7\u00e3o, 7) Ativa\u00e7\u00e3o do fornecedor indicado, 8) Reclama\u00e7\u00e3o encaminhada para an\u00e1lise do gestor, 9) Reclama\u00e7\u00e3o devolvida para a empresa, 10) Redirecionamento da reclama\u00e7\u00e3o, 11) Edi\u00e7\u00e3o de conte\u00fado, 12) Prazo expirado para an\u00e1lise da recusa, 13) Recusa forncecedor indicado, 14) Prazo expirado para avalia\u00e7\u00e3o, 15) Intera\u00e7\u00e3o do gestor, 16) Reclama\u00e7\u00e3o cancelada pelo gestor,  17) Prazo expirado para resposta, 18) Reclama\u00e7\u00e3o exclu\u00edda",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      },
      "codigoSituacaoReclamacao": {
        "name": "codigoSituacaoReclamacao",
        "in": "query",
        "description": "C\u00f3digo de uma situa\u00e7\u00e3o das reclama\u00e7\u00f5es, sendo  1) Aberta, 2) Em an\u00e1lise pelo gestor,  3) Em an\u00e1lise pelo fornecedor, 4) Respondida, 5) N\u00e3o Respondida, 6) Finalizada avaliada, 7) Finalizada n\u00e3o avaliada, 8) Cancelada, 9) Encerrada, 10) Fornecedor em credenciamento",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      },
      "numAvaliacao": {
        "name": "numAvaliacao",
        "in": "query",
        "description": "Referente \u00e0 conclus\u00e3o da avalia\u00e7\u00e3o. sendo: 1) Resolvida, 2) N\u00e3o Resolvida, 3) N\u00e3o Avaliada",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true,
          "enum": [
            1,
            2,
            3
          ]
        }
      },
      "nomeReclamante": {
        "name": "nomeReclamante",
        "in": "query",
        "description": "Nome do reclamante das reclama\u00e7\u00f5es. Assume prefixos e sufixos. Por exemplo:o nome 'Jo\u00e3o' poder\u00e1 retornar 'Jo\u00e3o Paulo' e 'Ant\u00f4nio Jo\u00e3o'",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "cpfReclamante": {
        "name": "cpfReclamante",
        "in": "query",
        "description": "CPF do reclamante das reclama\u00e7\u00f5es. Somente os n\u00fameros.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      },
      "siglaRegiao": {
        "name": "siglaRegiao",
        "in": "query",
        "description": "Sigla da regi\u00e3o dos endere\u00e7os das reclama\u00e7\u00f5es. SE, S, CO, N, NE",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true,
          "enum": [
            "SE",
            "S",
            "CO",
            "N",
            "NE"
          ]
        }
      },
      "siglaUF": {
        "name": "siglaUF",
        "in": "query",
        "description": "Sigla do estado dos endere\u00e7os das reclama\u00e7\u00f5es. Ex: PA, SP, MS, DF",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "codigoMunicipio": {
        "name": "codigoMunicipio",
        "in": "query",
        "description": "C\u00f3digo do munic\u00edpio dos endere\u00e7os das reclama\u00e7\u00f5es. https://www.ibge.gov.br/explica/codigos-dos-municipios.php",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      },
      "notaConsumidor": {
        "name": "notaConsumidor",
        "in": "query",
        "description": "Avalia\u00e7\u00e3o que o consumidor fez em rela\u00e7\u00e3o ao atendimento (1 a 5).",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true,
          "enum": [
            1,
            2,
            3,
            4,
            5
          ]
        }
      },
      "codigoMeioConsumo": {
        "name": "codigoMeioConsumo",
        "in": "query",
        "description": "C\u00f3digo do meio de consumo (campo 'Como Comprou/Contratou'), sendo: 1) Internet, 2)Loja f\u00edsica, 3) Telefone, 4) Cat\u00e1logo, 5) Domic\u00edlio, 6) Ganhei de presente, 7) Stand, feiras e eventos, 8) N\u00e3o comprei / contratei, 9) SMS / Mensagem de texto",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true,
          "enum": [
            1,
            2,
            3,
            4,
            5,
            6,
            7,
            8,
            9
          ]
        }
      },
      "textoReferenciaFornecedor": {
        "name": "textoReferenciaFornecedor",
        "in": "query",
        "description": "Texto livre de refer\u00eancia nas reclama\u00e7\u00f5es.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "dataIniPeriodo": {
        "name": "dataIniPeriodo",
        "in": "query",
        "description": "Data inicial da abertura das reclama\u00e7\u00f5es, no formato 'dd-MM-yyyy'. \u00c9 obrigat\u00f3rio caso a data final for preenchida.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "dataFimPeriodo": {
        "name": "dataFimPeriodo",
        "in": "query",
        "description": "Data final da abertura das reclama\u00e7\u00f5es, no formato 'dd-MM-yyyy'. \u00c9 obrigat\u00f3rio caso a data inicial for preenchida.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "dataIniPrazo": {
        "name": "dataIniPrazo",
        "in": "query",
        "description": "Data inicial do prazo das reclama\u00e7\u00f5es, no formato 'dd-MM-yyyy'. N\u00e3o h\u00e1 op\u00e7\u00e3o com horas. \u00c9 obrigat\u00f3rio caso a data final do prazo for preenchida.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "dataFimPrazo": {
        "name": "dataFimPrazo",
        "in": "query",
        "description": "Data final do prazo das reclama\u00e7\u00f5es, no formato 'dd-MM-yyyy'. N\u00e3o h\u00e1 op\u00e7\u00e3o com horas. \u00c9 obrigat\u00f3rio caso a data inicial do prazo for preenchida.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "horaInicialPeriodo": {
        "name": "horaInicialPeriodo",
        "in": "query",
        "description": "Hora referente a data inicial da abertura das reclama\u00e7\u00f5es, no formato 'HH:mm:ss'. Caso n\u00e3o preenchida assumir\u00e1 '00:00:00'.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "horaFinalPeriodo": {
        "name": "horaFinalPeriodo",
        "in": "query",
        "description": "Hora referente a data final da abertura das reclama\u00e7\u00f5es, no formato 'HH:mm:ss'. Caso n\u00e3o preenchida assumir\u00e1 '23:59:59'.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "string",
          "nullable": true
        }
      },
      "codigoGrupoEconomico": {
        "name": "codigoGrupoEconomico",
        "in": "query",
        "description": "C\u00f3digo do grupo ec\u00f4nomico do fornecedor das reclama\u00e7\u00f5es.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      },
      "codigoArea": {
        "name": "codigoArea",
        "in": "query",
        "description": "C\u00f3digo da \u00e1rea das reclama\u00e7\u00f5es.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      },
      "codigoAssunto": {
        "name": "codigoAssunto",
        "in": "query",
        "description": "C\u00f3digo do assunto relacionado com a \u00e1rea.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      },
      "codigoProblema": {
        "name": "codigoProblema",
        "in": "query",
        "description": "C\u00f3digo do problema relacionado com o assunto.",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      },
      "host_param": {
        "name": "Host",
        "in": "header",
        "required": true,
        "style": "simple",
        "explode": false,
        "schema": {
          "type": "string",
          "nullable": false,
          "default": "api-treinamento.consumidor.gov.br"
        }
      },
      "user_agent_param": {
        "name": "User-Agent",
        "in": "header",
        "required": true,
        "style": "simple",
        "explode": false,
        "schema": {
          "type": "string",
          "default": "api-consumidor"
        }
      },
      "versao_param": {
        "name": "versao",
        "in": "header",
        "required": true,
        "style": "simple",
        "explode": false,
        "schema": {
          "type": "string",
          "default": "1.0"
        }
      },
      "cpf_autorizado_param": {
        "name": "cpfAutorizado",
        "in": "header",
        "description": "CPF do usu\u00e1rio autorizado. Deve ser um usu\u00e1rio v\u00e1lido ativo da credenciada",
        "required": true,
        "style": "simple",
        "explode": false,
        "schema": {
          "type": "integer"
        }
      },
      "numero_protocolo_param": {
        "name": "numeroProtocolo",
        "in": "query",
        "description": "N\u00famero do protocolo, que identifica uma \u00fanica reclama\u00e7\u00e3o",
        "required": false,
        "style": "form",
        "explode": true,
        "schema": {
          "type": "integer",
          "nullable": true
        }
      }
    },
    "schemas": {
      "response_201_created": {
        "properties": {
          "tipo": {
            "type": "object",
            "properties": {
              "codigo": {
                "type": "number"
              },
              "descricao": {
                "type": "string"
              }
            }
          },
          "data": {
            "type": "integer"
          },
          "protocoloReclamacao": {
            "type": "string"
          }
        }
      },
      "response_200_listar": {
        "properties": {
          "protocolo": {
            "type": "string"
          },
          "situacao": {
            "type": "object",
            "properties": {
              "codigo": {
                "type": "number"
              },
              "descricao": {
                "type": "string"
              }
            }
          },
          "meioConsumo": {
            "type": "object",
            "properties": {
              "codigo": {
                "type": "number"
              },
              "descricao": {
                "type": "string"
              }
            }
          },
          "prazo": {
            "type": "string"
          },
          "prazoManifestacao": {
            "type": "string"
          },
          "nomeCampoPrazo": {
            "type": "string"
          },
          "dataAbertura": {
            "type": "string"
          },
          "area": {
            "type": "object",
            "properties": {
              "codigo": {
                "type": "number"
              },
              "descricao": {
                "type": "string"
              }
            }
          },
          "assunto": {
            "type": "object",
            "properties": {
              "codigo": {
                "type": "number"
              },
              "descricao": {
                "type": "string"
              }
            }
          },
          "problema": {
            "type": "object",
            "properties": {
              "codigo": {
                "type": "number"
              },
              "descricao": {
                "type": "string"
              }
            }
          },
          "reclamante": {
