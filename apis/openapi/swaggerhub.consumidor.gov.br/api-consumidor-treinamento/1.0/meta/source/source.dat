    "/orgao/reclamacao/{numeroProtocolo}/tramite/{numeroTramite}/anexo/{numeroAnexo}/baixar": {
      "get": {
        "description": "Servi\u00e7o que retorna arquivo em base 64 de um anexo existente em um dado tramite.",
        "tags": [
          "\u00d3rg\u00e3os de Monitoramento"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/host_param"
          },
          {
            "$ref": "#/components/parameters/user_agent_param"
          },
          {
            "$ref": "#/components/parameters/versao_param"
          },
          {
            "$ref": "#/components/parameters/cpf_autorizado_param"
          },
          {
            "name": "numeroProtocolo",
            "in": "path",
            "description": "Protocolo que deseja detalhar",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "numeroTramite",
            "in": "path",
            "description": "C\u00f3digo interno do tramite (id)",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "numeroAnexo",
