                  }
                }
              }
            }
          }
        }
      }
    },
    "/reclamacao/{numeroProtocolo}/redirecionar": {
      "post": {
        "description": "Servi\u00e7o para redirecionar uma reclama\u00e7\u00e3o para outra empresa de mesmo grupo econ\u00f4mico.",
        "tags": [
          "Fornecedores"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/host_param"
          },
          {
            "$ref": "#/components/parameters/user_agent_param"
          },
          {
            "$ref": "#/components/parameters/versao_param"
          },
          {
            "$ref": "#/components/parameters/cpf_autorizado_param"
          },
          {
            "name": "numeroProtocolo",
            "in": "path",
            "description": "N\u00famero do protocolo que identifica uma \u00fanica reclama\u00e7\u00e3o.",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "texto": {
                    "type": "string",
                    "example": "Redicionando da empreda Planeta Operacional para a empresa Planeta Financeira por envolver assuntos de pagamento"
                  },
                  "identificacaoEmpresaGrupo": {
                    "type": "number",
                    "example": 123
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/response_201_created"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/reclamacao/{numeroProtocolo}/recusar": {
      "post": {
        "description": "Servi\u00e7o para encaminhar uma reclama\u00e7\u00e3o para an\u00e1lise do gestor.",
        "tags": [
          "Fornecedores"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/host_param"
          },
          {
            "$ref": "#/components/parameters/user_agent_param"
          },
          {
            "$ref": "#/components/parameters/versao_param"
          },
          {
            "$ref": "#/components/parameters/cpf_autorizado_param"
          },
          {
            "name": "numeroProtocolo",
            "in": "path",
            "description": "N\u00famero do protocolo que identifica uma \u00fanica reclama\u00e7\u00e3o.",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": "{\"texto\": \"O consumidor se confundiu. A nossa empresa Planeta n\u00e3o trabalha com vendas de produtos de pescaria.\"}"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "CREATED",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/response_201_created"
                  }
                }
              }
            }
          }
        }
      }
    },
