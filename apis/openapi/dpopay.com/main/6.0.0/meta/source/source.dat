          "trans_token": { "type": "string" },
          "phone_number": { "type": "string", "description": "Customer mobile number" },
          "mno_id": { "type": "string", "description": "Mobile network operator ID" }
        }
      },
      "ChargeBankRequest": {
        "type": "object",
        "required": ["company_token", "trans_token", "bank_id"],
        "properties": {
          "company_token": { "type": "string" },
          "trans_token": { "type": "string" },
          "bank_id": { "type": "string", "description": "Bank identifier" }
        }
      },
      "ChargeAuthRequest": {
        "type": "object",
        "required": ["company_token", "trans_token"],
        "properties": {
