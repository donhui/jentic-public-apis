        "type": "object",
        "properties": {
          "result_code": { "type": "string" },
          "result_explanation": { "type": "string" },
          "trans_token": { "type": "string" }
        }
      },
      "ChargeCardRequest": {
        "type": "object",
        "required": ["company_token", "trans_token", "card_number", "card_expiry", "card_cvv"],
        "properties": {
          "company_token": { "type": "string" },
          "trans_token": { "type": "string" },
          "card_number": { "type": "string" },
          "card_expiry": { "type": "string", "description": "Card expiry in MMYY format" },
          "card_cvv": { "type": "string" },
          "card_holder": { "type": "string" }
        }
      },
      "ChargeMobileRequest": {
        "type": "object",
