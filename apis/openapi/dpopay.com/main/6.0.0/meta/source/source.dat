        "properties": {
          "company_token": { "type": "string" },
          "customer_email": { "type": "string", "format": "email" },
          "card_token": { "type": "string" }
        }
      },
      "WalletResponse": {
        "type": "object",
        "properties": {
          "result_code": { "type": "string" },
          "result_explanation": { "type": "string" }
        }
      },
      "WalletTransactionsRequest": {
        "type": "object",
        "required": ["company_token", "customer_email"],
        "properties": {
          "company_token": { "type": "string" },
          "customer_email": { "type": "string", "format": "email" }
        }
      },
      "WalletTransactionsResponse": {
        "type": "object",
        "properties": {
          "result_code": { "type": "string" },
          "transactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "trans_ref": { "type": "string" },
                "amount": { "type": "number" },
                "currency": { "type": "string" },
                "status": { "type": "string" },
                "date": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      },
      "RecurrentChargeRequest": {
        "type": "object",
        "required": ["company_token", "trans_token", "customer_email"],
        "properties": {
          "company_token": { "type": "string" },
          "trans_token": { "type": "string" },
          "customer_email": { "type": "string", "format": "email" }
        }
      },
      "MerchantServicesResponse": {
        "type": "object",
        "properties": {
          "result_code": { "type": "string" },
          "services": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
