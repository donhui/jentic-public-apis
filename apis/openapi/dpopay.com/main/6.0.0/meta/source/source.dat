{
  "openapi": "3.0.3",
  "info": {
    "title": "DPO Pay API",
    "version": "6.0.0",
    "description": "DPO Pay (formerly DPO Group) provides payment processing for African markets. The API supports creating payment tokens, processing charges via credit card, mobile money, and bank transfer, managing refunds and cancellations, and super wallet operations.",
    "x-jentic-source-url": "https://docs.dpopay.com/api/index.html"
  },
  "servers": [
    {
      "url": "https://secure.3gdirectpay.com/API/v6",
      "description": "DPO Pay API v6 Production"
    }
  ],
  "security": [
    {
      "companyToken": []
    }
  ],
  "tags": [
    { "name": "Transaction Operations", "description": "Core transaction token management" },
    { "name": "Payment Options", "description": "Charge tokens via various payment methods" },
    { "name": "Super Wallet", "description": "Customer wallet and recurring payment management" },
    { "name": "Merchant", "description": "Merchant operations" },
    { "name": "xPay", "description": "xPay payment operations" }
  ],
  "paths": {
    "/token/create": {
      "post": {
        "operationId": "createToken",
        "summary": "Create a transaction token",
        "description": "Initiates a payment transaction and generates a token for checkout processing.",
        "tags": ["Transaction Operations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": { "$ref": "#/components/schemas/CreateTokenRequest" }
            },
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token created successfully",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/CreateTokenResponse" }
              },
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateTokenResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Missing or invalid company token",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/token/verify": {
      "post": {
        "operationId": "verifyToken",
        "summary": "Verify a transaction token",
        "description": "Confirms payment status and retrieves transaction details for a given token.",
        "tags": ["Transaction Operations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token verification result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/VerifyTokenResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/token/refund": {
      "post": {
        "operationId": "refundToken",
        "summary": "Refund a transaction",
        "description": "Processes a refund for a completed transaction.",
        "tags": ["Transaction Operations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefundTokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund processed",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TransactionResult" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/token/cancel": {
      "post": {
        "operationId": "cancelToken",
        "summary": "Cancel a transaction token",
        "description": "Cancels a pending or authorized transaction.",
        "tags": ["Transaction Operations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token cancelled",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TransactionResult" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/token/update": {
      "post": {
        "operationId": "updateToken",
        "summary": "Update a transaction token",
        "description": "Modifies transaction details before completion.",
        "tags": ["Transaction Operations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateTokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token updated",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TransactionResult" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/token/email": {
      "post": {
        "operationId": "emailPaymentLink",
        "summary": "Email a payment link",
        "description": "Sends a payment link to a customer's email address.",
        "tags": ["Transaction Operations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EmailTokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email sent",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TransactionResult" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/charge/card": {
      "post": {
        "operationId": "chargeTokenCreditCard",
        "summary": "Charge token via credit card",
        "description": "Processes a credit card payment for a given transaction token.",
        "tags": ["Payment Options"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChargeCardRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card charge result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ChargeResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/charge/mobile": {
      "post": {
        "operationId": "chargeTokenMobile",
        "summary": "Charge token via mobile money",
        "description": "Processes a mobile money payment for a given transaction token.",
        "tags": ["Payment Options"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChargeMobileRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mobile charge result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ChargeResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/charge/bank": {
      "post": {
        "operationId": "chargeTokenBankTransfer",
        "summary": "Charge token via bank transfer",
        "description": "Processes a bank transfer payment for a given transaction token.",
        "tags": ["Payment Options"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChargeBankRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bank transfer charge result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ChargeResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/charge/auth": {
      "post": {
        "operationId": "chargeTokenAuth",
        "summary": "Charge token with authorization",
        "description": "Processes an authorized charge for a given transaction token.",
        "tags": ["Payment Options"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChargeAuthRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Auth charge result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ChargeResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/mobile/options": {
      "post": {
        "operationId": "getMobilePaymentOptions",
        "summary": "Get mobile payment options",
        "description": "Retrieves available mobile money payment providers for a transaction.",
        "tags": ["Payment Options"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Available mobile payment options",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PaymentOptionsResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/bank/options": {
      "post": {
        "operationId": "getBankTransferOptions",
        "summary": "Get bank transfer options",
        "description": "Lists supported bank transfer payment methods.",
        "tags": ["Payment Options"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Available bank transfer options",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PaymentOptionsResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
