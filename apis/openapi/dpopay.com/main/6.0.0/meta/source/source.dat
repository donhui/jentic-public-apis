          "trans_token": { "type": "string" }
        }
      },
      "ChargeResponse": {
        "type": "object",
        "properties": {
          "result_code": { "type": "string" },
          "result_explanation": { "type": "string" },
          "trans_token": { "type": "string" },
          "redirect_url": { "type": "string", "description": "URL for 3DS or external redirect" }
        }
      },
      "PaymentOptionsResponse": {
        "type": "object",
        "properties": {
          "result_code": { "type": "string" },
          "result_explanation": { "type": "string" },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "logo": { "type": "string" }
              }
            }
          }
        }
      },
      "CreateWalletRequest": {
        "type": "object",
