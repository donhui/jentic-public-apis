          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/wallet/create": {
      "post": {
        "operationId": "createWalletAccount",
        "summary": "Create a super wallet account",
        "description": "Creates a new customer wallet account.",
        "tags": ["Super Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateWalletRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Wallet account created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WalletResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/wallet/card/add": {
      "post": {
        "operationId": "addWalletCard",
        "summary": "Add a card to wallet",
        "description": "Adds a payment card to a customer's super wallet.",
        "tags": ["Super Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WalletCardRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card added to wallet",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WalletResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/wallet/card/delete": {
      "post": {
        "operationId": "deleteWalletCard",
        "summary": "Delete a card from wallet",
        "description": "Removes a payment card from a customer's super wallet.",
        "tags": ["Super Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WalletCardRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card deleted from wallet",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WalletResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/wallet/transactions": {
      "post": {
        "operationId": "getWalletTransactions",
        "summary": "Get wallet transactions",
        "description": "Retrieves transaction history for a super wallet account.",
        "tags": ["Super Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WalletTransactionsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Wallet transaction history",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WalletTransactionsResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/wallet/charge/recurrent": {
      "post": {
        "operationId": "chargeTokenRecurrent",
        "summary": "Process a recurring wallet charge",
        "description": "Charges a customer's wallet for a recurring payment.",
        "tags": ["Super Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecurrentChargeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recurring charge result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ChargeResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/merchant/services": {
      "post": {
        "operationId": "getMerchantServices",
        "summary": "Get merchant services",
        "description": "Retrieves available services for the authenticated merchant.",
        "tags": ["Merchant"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompanyTokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of merchant services",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/MerchantServicesResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/xpay/verify": {
      "post": {
        "operationId": "verifyXpay",
        "summary": "Verify xPay transaction",
        "description": "Verifies an xPay payment transaction.",
        "tags": ["xPay"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "xPay verification result",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TransactionResult" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/xpay/balance": {
      "post": {
        "operationId": "getXpayBalance",
        "summary": "Check xPay balance",
        "description": "Checks the balance for an xPay account.",
        "tags": ["xPay"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompanyTokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "xPay balance",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/BalanceResponse" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "companyToken": {
        "type": "apiKey",
        "in": "header",
        "name": "CompanyToken",
        "description": "Company authentication token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "result_code": { "type": "string", "description": "Error result code" },
          "result_explanation": { "type": "string", "description": "Human-readable error description" }
        }
      },
      "CompanyTokenRequest": {
        "type": "object",
        "required": ["company_token"],
        "properties": {
          "company_token": { "type": "string", "description": "Company authentication token" }
        }
      },
      "CreateTokenRequest": {
        "type": "object",
        "required": ["company_token", "amount", "currency", "service_type"],
        "properties": {
          "company_token": { "type": "string", "description": "Company authentication token" },
          "amount": { "type": "number", "description": "Transaction amount" },
          "currency": { "type": "string", "description": "ISO 4217 currency code (e.g., ZAR, USD, KES)" },
          "service_type": { "type": "string", "description": "Service type identifier" },
          "company_ref": { "type": "string", "description": "Merchant reference" },
          "redirect_url": { "type": "string", "format": "uri", "description": "URL to redirect after payment" },
          "back_url": { "type": "string", "format": "uri", "description": "URL for back/cancel navigation" },
          "customer_email": { "type": "string", "format": "email", "description": "Customer email address" },
          "customer_first_name": { "type": "string" },
          "customer_last_name": { "type": "string" },
          "customer_phone": { "type": "string" }
        }
      },
      "CreateTokenResponse": {
        "type": "object",
        "properties": {
          "result_code": { "type": "string" },
          "result_explanation": { "type": "string" },
          "trans_token": { "type": "string", "description": "Transaction token for checkout" },
          "trans_ref": { "type": "string", "description": "Transaction reference" }
        }
      },
      "TokenRequest": {
        "type": "object",
        "required": ["company_token", "trans_token"],
        "properties": {
          "company_token": { "type": "string" },
          "trans_token": { "type": "string", "description": "Transaction token" }
        }
      },
      "RefundTokenRequest": {
        "type": "object",
        "required": ["company_token", "trans_token"],
        "properties": {
          "company_token": { "type": "string" },
          "trans_token": { "type": "string" },
          "amount": { "type": "number", "description": "Refund amount (for partial refund)" }
        }
      },
      "UpdateTokenRequest": {
        "type": "object",
        "required": ["company_token", "trans_token"],
        "properties": {
          "company_token": { "type": "string" },
          "trans_token": { "type": "string" },
          "amount": { "type": "number" },
          "company_ref": { "type": "string" }
        }
      },
      "EmailTokenRequest": {
        "type": "object",
        "required": ["company_token", "trans_token", "customer_email"],
        "properties": {
          "company_token": { "type": "string" },
          "trans_token": { "type": "string" },
          "customer_email": { "type": "string", "format": "email" }
        }
      },
      "VerifyTokenResponse": {
        "type": "object",
        "properties": {
          "result_code": { "type": "string" },
          "result_explanation": { "type": "string" },
