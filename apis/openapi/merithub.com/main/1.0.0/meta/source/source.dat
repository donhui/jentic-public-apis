{
  "openapi": "3.0.3",
  "info": {
    "title": "MeritHub Virtual Classroom API",
    "version": "1.0.0",
    "description": "MeritHub API for managing virtual classroom users, scheduling and managing live classes, and handling class enrollment.",
    "x-jentic-source-url": "https://merithub.com/api"
  },
  "servers": [
    {
      "url": "https://serviceaccount1.meritgraph.com"
    }
  ],
  "paths": {
    "/v1/{clientId}/api/token": {
      "post": {
        "operationId": "generateaccesstoken",
        "summary": "Generate Access Token",
        "description": "Obtain OAuth 2.0 access token using JWT assertion.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "assertion",
                  "grant_type"
                ],
                "properties": {
                  "assertion": {
                    "type": "string",
                    "description": "JWT token with Bearer prefix"
                  },
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "urn:ietf:params:oauth:grant-type:jwt-bearer"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/{clientId}/users": {
      "post": {
        "operationId": "adduser",
        "summary": "Add User",
        "description": "Add users to MeritHub organization account.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/{clientId}/users/{userId}": {
      "put": {
        "operationId": "updateuser",
        "summary": "Update User",
        "description": "Update existing user information.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteuser",
        "summary": "Delete User",
        "description": "Remove user from account (irreversible).",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/{clientId}/{instructorId}": {
      "post": {
        "operationId": "scheduleclass",
        "summary": "Schedule Class",
        "description": "Create oneTime or permanent live class sessions.",
        "tags": [
          "Classes"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "instructorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleClassRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Class scheduled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClassResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/{clientId}/{classId}": {
      "put": {
        "operationId": "editclass",
        "summary": "Edit Class",
        "description": "Modify class settings (except type).",
        "tags": [
          "Classes"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "classId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditClassRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Class updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteclass",
        "summary": "Delete Class",
        "description": "Remove class and all associated data.",
        "tags": [
          "Classes"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "classId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Class deleted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/{clientId}/{classId}/users": {
      "post": {
        "operationId": "adduserstoclass",
        "summary": "Add Users to Class",
        "description": "Enroll users in specific class with unique links.",
        "tags": [
          "Classes"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "classId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "userId": {
                      "type": "string"
                    },
                    "userLink": {
                      "type": "string"
                    },
                    "userType": {
                      "type": "string",
                      "description": "su for student user"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users enrolled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "userId": {
                        "type": "string"
                      },
                      "userLink": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/{clientId}/{classId}/removeuser": {
      "post": {
        "operationId": "removeusersfromclass",
        "summary": "Remove Users from Class",
        "description": "Unenroll users from class.",
        "tags": [
          "Classes"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "classId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users removed"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer"
          },
          "api_domain": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "img": {
            "type": "string"
          },
          "desc": {
            "type": "string"
          },
          "lang": {
            "type": "string"
          },
          "clientUserId": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "C",
              "M"
            ],
            "description": "C=Creator, M=Member"
          },
          "timeZone": {
            "type": "string"
          },
          "permission": {
            "type": "string",
            "enum": [
              "CC",
              "CJ"
            ],
            "description": "CC=Can Create, CJ=Can Join"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "img": {
            "type": "string"
          },
          "desc": {
            "type": "string"
          },
          "lang": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "C",
              "M"
            ]
          },
          "timeZone": {
            "type": "string"
          },
          "permission": {
            "type": "string",
            "enum": [
              "CC",
              "CJ"
            ]
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "userToken": {
            "type": "string"
          }
        }
      },
      "ScheduleClassRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "recordingDownload": {
            "type": "boolean"
          },
          "duration": {
            "type": "integer"
          },
          "lang": {
            "type": "string"
          },
          "timeZoneId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "oneTime",
              "perma"
            ]
          },
          "access": {
            "type": "string"
          },
          "login": {
            "type": "string"
          },
          "layout": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "recording": {
            "type": "boolean"
          },
          "participantControl": {
            "type": "object"
          },
          "schedule": {
            "type": "object"
          },
          "totalClasses": {
            "type": "integer"
          },
          "avMode": {
            "type": "string"
          },
          "whiteboard": {
            "type": "boolean"
          }
        }
      },
      "EditClassRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "recordingDownload": {
            "type": "boolean"
          },
          "duration": {
            "type": "integer"
          },
          "lang": {
            "type": "string"
          },
          "timeZoneId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "login": {
            "type": "string"
          },
          "layout": {
            "type": "string"
          },
          "recording": {
            "type": "boolean"
          },
          "participantControl": {
            "type": "object"
          },
          "schedule": {
            "type": "object"
          }
        }
      },
      "ClassResponse": {
        "type": "object",
        "properties": {
          "classId": {
            "type": "string"
          },
          "commonLinks": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "moderator": {
                "type": "string"
              },
              "participant": {
                "type": "string"
              }
            }
          },
          "hostLink": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 JWT Bearer token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Operations related to Authentication"
    },
    {
      "name": "Classes",
      "description": "Operations related to Classes"
    },
    {
      "name": "Users",
      "description": "Operations related to Users"
    }
  ]
}