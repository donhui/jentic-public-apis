{
  "openapi": "3.0.3",
  "info": {
    "title": "MeritHub Virtual Classroom API",
    "description": "MeritHub API for managing virtual classroom users, classes, scheduling, and enrollment. Uses OAuth 2.0 with JWT for authentication.",
    "version": "1.0",
    "x-jentic-source-url": "https://merithub.com/api"
  },
  "servers": [
    {
      "url": "https://serviceaccount1.meritgraph.com",
      "description": "Service Account API (Users & Auth)"
    },
    {
      "url": "https://class1.meritgraph.com",
      "description": "Class API (Classes & Enrollment)"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication and token generation" },
    { "name": "Users", "description": "User management" },
    { "name": "Classes", "description": "Class scheduling and management" },
    { "name": "Enrollment", "description": "Class enrollment management" }
  ],
  "paths": {
    "/v1/{clientId}/api/token": {
      "post": {
        "operationId": "generateAccessToken",
        "summary": "Exchange JWT for OAuth access token",
        "tags": ["Auth"],
        "security": [],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Client identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/{clientId}/users": {
      "post": {
        "operationId": "addUser",
        "summary": "Create a new user in the organization",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateUserResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/{clientId}/users/{userId}": {
      "put": {
        "operationId": "updateUser",
        "summary": "Update an existing user",
        "tags": ["Users"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Permanently remove a user (irreversible)",
        "tags": ["Users"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "User deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/{clientId}/{instructorId}": {
      "post": {
        "operationId": "scheduleClass",
        "summary": "Create a one-time or recurring class session",
        "tags": ["Classes"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "instructorId", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Instructor user ID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleClassRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Class scheduled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClassResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/{clientId}/{classId}": {
      "put": {
        "operationId": "editClass",
        "summary": "Modify class settings (except type)",
        "tags": ["Classes"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "classId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditClassRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Class updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "operationId": "deleteClass",
        "summary": "Permanently remove a class and all associated data",
        "tags": ["Classes"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "classId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Class deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/{clientId}/{classId}/users": {
      "post": {
        "operationId": "addUsersToClass",
        "summary": "Enroll users in a class with specific roles",
        "tags": ["Enrollment"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "classId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddUsersToClassRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users enrolled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnrolledUsersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/{clientId}/{classId}/removeuser": {
      "post": {
        "operationId": "removeUsersFromClass",
        "summary": "Unenroll users from a class",
        "tags": ["Enrollment"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "classId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RemoveUsersRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users removed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "OAuth 2.0 Bearer token obtained via JWT exchange. Expires after 60 minutes."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "TokenRequest": {
        "type": "object",
        "required": ["assertion", "grant_type"],
        "properties": {
          "assertion": { "type": "string", "description": "Bearer JWT token" },
          "grant_type": { "type": "string", "description": "Must be urn:ietf:params:oauth:grant-type:jwt-bearer" }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "expires_in": { "type": "integer" },
          "api_domain": { "type": "string" },
          "token_type": { "type": "string" }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["name", "email"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "title": { "type": "string" },
          "img": { "type": "string", "description": "Profile image URL" },
          "desc": { "type": "string" },
          "lang": { "type": "string" },
          "clientUserId": { "type": "string", "description": "External user ID" },
          "role": { "type": "string", "enum": ["C", "M"], "description": "C=Creator, M=Member" },
          "timeZone": { "type": "string" },
          "permission": { "type": "string", "enum": ["CC", "CJ"], "description": "CC=Can Create, CJ=Can Join" }
        }
      },
      "CreateUserResponse": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "userToken": { "type": "string" }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "title": { "type": "string" },
          "img": { "type": "string" },
          "desc": { "type": "string" },
          "lang": { "type": "string" },
          "clientUserId": { "type": "string" },
          "role": { "type": "string", "enum": ["C", "M"] },
          "timeZone": { "type": "string" },
          "permission": { "type": "string", "enum": ["CC", "CJ"] }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "title": { "type": "string" },
          "img": { "type": "string" },
          "desc": { "type": "string" },
          "lang": { "type": "string" },
          "clientUserId": { "type": "string" },
          "role": { "type": "string" },
          "timeZone": { "type": "string" },
          "permission": { "type": "string" }
        }
      },
      "ScheduleClassRequest": {
        "type": "object",
        "required": ["title", "startTime", "duration"],
        "properties": {
          "title": { "type": "string" },
          "startTime": { "type": "string", "format": "date-time", "description": "RFC3339 format" },
          "duration": { "type": "integer", "description": "Duration in minutes" },
          "type": { "type": "string", "enum": ["oneTime", "perma"], "description": "One-time or recurring" },
          "endDate": { "type": "string", "format": "date-time", "description": "End date for recurring classes" },
          "schedule": { "type": "array", "items": { "type": "object" }, "description": "Recurring schedule definition" },
          "totalClasses": { "type": "integer", "description": "Total number of classes for recurring" },
          "recordingDownload": { "type": "boolean" },
          "login": { "type": "boolean" },
          "layout": { "type": "string", "enum": ["CR", "GL", "WB", "SS"], "description": "CR=Classroom, GL=Gallery, WB=Whiteboard, SS=Screen Share" },
          "status": { "type": "string", "enum": ["up", "lv", "cp", "ex", "dl"], "description": "up=Upcoming, lv=Live, cp=Completed, ex=Expired, dl=Deleted" },
          "recording": { "type": "object", "description": "Recording settings" },
          "participantControl": { "type": "object", "description": "Participant control settings" },
          "whiteboard": { "type": "object", "description": "Whiteboard settings" }
        }
      },
      "EditClassRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "startTime": { "type": "string", "format": "date-time" },
          "duration": { "type": "integer" },
          "endDate": { "type": "string", "format": "date-time" },
          "schedule": { "type": "array", "items": { "type": "object" } },
          "totalClasses": { "type": "integer" },
          "recordingDownload": { "type": "boolean" },
          "login": { "type": "boolean" },
          "layout": { "type": "string", "enum": ["CR", "GL", "WB", "SS"] },
          "status": { "type": "string", "enum": ["up", "lv", "cp", "ex", "dl"] },
          "recording": { "type": "object" },
          "participantControl": { "type": "object" },
          "whiteboard": { "type": "object" }
        }
      },
      "ClassResponse": {
        "type": "object",
        "properties": {
          "classId": { "type": "string" },
          "commonLinks": {
            "type": "object",
            "properties": {
              "attendeeLink": { "type": "string" },
              "moderatorLink": { "type": "string" }
            }
          },
          "hostLink": { "type": "string" }
        }
      },
      "AddUsersToClassRequest": {
        "type": "object",
        "required": ["users"],
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "userId": { "type": "string" },
                "userLink": { "type": "string" },
                "userType": { "type": "string", "enum": ["su"], "description": "su=Standard User" }
              }
            }
          }
        }
      },
      "EnrolledUsersResponse": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "userId": { "type": "string" },
                "userLink": { "type": "string" }
              }
            }
          }
        }
      },
      "RemoveUsersRequest": {
        "type": "object",
        "required": ["users"],
        "properties": {
          "users": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Array of user IDs to remove"
          }
        }
      }
    }
  }
}