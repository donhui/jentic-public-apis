{
  "openapi": "3.0.3",
  "info": {
    "title": "Jooble Job Search API",
    "description": "The Jooble API provides access to Jooble's job search engine, aggregating job listings from thousands of job boards and websites worldwide. The API accepts search queries via POST requests and returns matching job listings with details including title, location, salary, company, and application links.",
    "version": "1.0.0",
    "contact": {
      "name": "Jooble",
      "url": "https://jooble.org"
    },
    "x-jentic-source-url": "https://jooble.org/api/about"
  },
  "servers": [
    {
      "url": "https://jooble.org/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Job Search",
      "description": "Search for jobs across multiple job boards"
    }
  ],
  "paths": {
    "/{api_key}": {
      "post": {
        "operationId": "searchJobs",
        "summary": "Search for jobs",
        "description": "Search Jooble's aggregated job listings using keywords and location. The API key is provided as a path parameter. Returns paginated results with job details.",
        "tags": ["Job Search"],
        "parameters": [
          {
            "name": "api_key",
            "in": "path",
            "required": true,
            "description": "Your Jooble API key",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              },
              "example": {
                "keywords": "software engineer",
                "location": "Berlin",
                "page": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful search response with job listings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters or request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests - rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "path",
        "name": "api_key",
        "description": "API key obtained from Jooble after registration. Passed as a path parameter."
      }
    },
    "schemas": {
      "SearchRequest": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "string",
            "description": "Job search keywords (e.g., job title, skills, company name)"
          },
          "location": {
            "type": "string",
            "description": "Job location (city, state, country)"
          },
          "radius": {
            "type": "integer",
            "description": "Search radius in miles from the specified location"
          },
          "salary": {
            "type": "integer",
            "description": "Minimum salary filter"
          },
          "page": {
            "type": "integer",
            "description": "Page number for pagination (starts at 1)",
            "minimum": 1
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "totalCount": {
            "type": "integer",
            "description": "Total number of matching jobs"
          },
          "jobs": {
            "type": "array",
            "description": "Array of matching job listings",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Job title"
          },
          "location": {
            "type": "string",
            "description": "Job location"
          },
          "snippet": {
            "type": "string",
            "description": "Short description or snippet of the job listing"
          },
          "salary": {
            "type": "string",
            "description": "Salary information"
          },
          "source": {
            "type": "string",
            "description": "Original source website of the job listing"
          },
          "type": {
            "type": "string",
            "description": "Employment type (e.g., Full-time, Part-time, Contract)"
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "URL to the full job listing"
          },
          "company": {
            "type": "string",
            "description": "Hiring company name"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time the listing was last updated"
          },
          "id": {
            "type": "string",
            "description": "Unique job identifier"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    }
  }
}
