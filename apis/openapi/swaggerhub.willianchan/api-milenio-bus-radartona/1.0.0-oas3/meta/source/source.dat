    "/v1/Login/GetToken": {
      "get": {
        "tags": [
          "Autenticacao"
        ],
        "summary": "Rotas de autenticacao de usuario",
        "description": "Get de um token novo, para que seja poss\u00edvel utilizar endpoints da API. Prazo de expira\u00e7\u00e3o configurado para 1 dia. Utilizar token como Autentica\u00e7\u00e3o \"Bearer Token\" ao realizar requests.\n",
        "operationId": "Token",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "description": "E-mail utilizado no cadastro do usu\u00e1rio",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "senha",
            "in": "query",
            "description": "Senha utilizada no cadastro do usu\u00e1rio",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Crit\u00e9rios de busca atendem ao esperado",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/Token"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Inputs n\u00e3o inseridos corretamente"
          },
          "401": {
            "description": "Usu\u00e1rio n\u00e3o possui acesso a API"
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://mileniotech.com.br/"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Radar": {
        "type": "object",
        "required": [
          "lote",
          "codigo",
          "endereco",
          "sentido",
          "referencia",
          "tipoEquipamento",
          "enquadramento",
          "qtdeFaixas",
          "dataPublicacao",
          "velocidade",
          "lat",
          "lon",
          "bairro"
        ],
        "properties": {
          "lote": {
            "type": "integer",
            "example": 1
          },
          "codigo": {
            "type": "string",
            "example": "6748-6901"
          },
          "endereco": {
            "type": "string",
            "example": "Rod. Presidente Dutra"
          },
          "sentido": {
            "type": "string",
            "example": "Ayrton Senna/Castelo Branco"
          },
          "referencia": {
            "type": "string",
            "example": "a menos 75m da Ponte Janio Quadros"
          },
          "tipoEquipamento": {
            "type": "string",
            "example": "Fixo - Grupo A"
          },
          "enquadramento": {
            "type": "string",
            "example": "V"
          },
          "qtdeFaixas": {
            "type": "string",
            "example": "5"
          },
          "dataPublicacao": {
            "type": "string",
            "example": "2015/07/18 00:00:00.000"
          },
          "velocidade": {
            "type": "string",
            "example": "60/50 km/h"
          },
          "lat": {
            "type": "string",
            "example": "-23.52684996"
          },
          "lon": {
            "type": "string",
            "example": "-46.59507216"
          },
          "bairro": {
            "type": "string",
            "example": "Cangaiba"
          }
        }
      },
      "FluxoVeiculosRadar": {
        "type": "object",
        "required": [
          "codigo",
          "data_hora",
          "tipo_veiculo",
          "contagem",
          "autuacoes",
          "placas",
          "qtde_faixas",
          "velocidade",
          "lat",
          "lon",
          "bairro"
        ],
        "properties": {
          "codigo": {
            "type": "string",
            "example": 6707
          },
          "data_hora": {
            "type": "string",
