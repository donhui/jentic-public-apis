        "description": "Este endpoint \u00e9 para usu\u00e1rios que desejam receber dados de radares, por perfil de velocidade (m\u00ednima e m\u00e1xima)\n",
        "operationId": "PerfilVelocidadesRadar",
        "parameters": [
          {
            "name": "VelocidadeMin",
            "in": "query",
            "description": "velocidade m\u00ednima do radar a ser consultada(1 a 100)",
