          },
          "market": {
            "$ref": "#/components/schemas/ISO3166Country",
            "description": "The [ISO 3166-1 alpha-3](https://www.iso.org/obp/ui/#search/code/) code of the country the `Company` Soldo account is registered in.",
            "example": "GBR"
