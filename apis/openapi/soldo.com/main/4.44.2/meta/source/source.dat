          "category": {
            "$ref": "#/components/schemas/TransactionCategory",
            "description": "The category of the `Transaction` (sortable: yes).",
            "example": "Payment"
          },
          "transaction_sign": {
            "$ref": "#/components/schemas/TransactionSign",
