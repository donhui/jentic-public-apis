          },
          "scope": {
            "type": "string",
            "description": "The name of the scope.",
            "example": "ALL"
          }
        }
      },
      "Role": {
        "properties": {
          "id": {
            "type": "string",
            "description": "The ID of the `Role`.",
            "example": "7bf79328-a7ae-4222-aa54-091ff7f429a7"
          },
          "name": {
            "type": "string",
            "description": "The name of the `Role`.",
            "example": "superAdmin"
          },
          "description": {
            "type": "string",
            "description": "The description of the `Role`.",
