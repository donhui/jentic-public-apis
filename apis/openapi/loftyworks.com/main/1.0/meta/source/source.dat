    }
  ],
  "tags": [
    {
      "name": "Tenancies",
      "description": "Operations for CRM tenancies"
    },
    {
      "name": "Transactions",
      "description": "Operations for CRM transactions"
    },
    {
      "name": "Contacts",
      "description": "Operations for CRM contacts"
    },
    {
      "name": "Contractors",
      "description": "Operations for CRM contractors/suppliers"
    },
    {
      "name": "Notes",
      "description": "Operations for CRM notes"
    },
    {
      "name": "Properties",
      "description": "Operations for CRM properties"
    },
    {
      "name": "Documents",
      "description": "Operations for CRM documents"
    },
    {
      "name": "Users",
      "description": "Operations for CRM users"
    }
  ],
  "paths": {
    "/v1.0/users/{id}": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get user by ID",
        "description": "Retrieve a single user by their ID",
        "operationId": "getUserById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "User ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "example": 10001
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer [access_token]",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Users"
        ],
        "summary": "Edit user",
        "description": "Update an existing user's information",
        "operationId": "editUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "User ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "example": 10001
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer [access_token]",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Type",
            "in": "header",
            "description": "application/json",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "application/json"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data",
            "content": {
              "*/*": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "*/*": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1.0/users/me/status/updated": {
      "put": {
        "tags": [
          "Users"
        ],
        "summary": "Terminate association with Loftyworks",
        "description": "Terminate the current user's association with Loftyworks (only TERMINATED status is supported)",
        "operationId": "updateUserStatus",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "User status (only TERMINATED is supported)",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "TERMINATED"
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer [access_token]",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Type",
            "in": "header",
            "description": "application/json",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "application/json"
          }
        ],
        "responses": {
          "200": {
            "description": "Association terminated successfully"
          },
          "400": {
            "description": "Invalid status value"
          }
        }
      }
    },
