            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "desc",
            "in": "query",
            "description": "Descending sort(true) or ascending sort(false)",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "languages",
            "in": "query",
            "description": "Search for contact with any languages (abbreviation)",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          {
            "name": "preciseSearchFlag",
            "in": "query",
            "description": "Whether to precise search for contacts based on email or phone",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer [access_token]",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactPageResult"
                }
              }
            }
          }
        }
      }
    },
    "/v1.0/contacts/{id}": {
      "get": {
        "tags": [
          "Contacts"
        ],
        "summary": "Get contact by ID",
        "description": "Retrieve a single contact by their ID",
        "operationId": "getContactById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Contact ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "example": 30001
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer [access_token]",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          }
        }
      }
    }
  },
