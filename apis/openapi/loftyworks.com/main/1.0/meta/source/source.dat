    "/v1.0/notes/notes/{noteId}": {
      "get": {
        "tags": [
          "Notes"
        ],
        "summary": "Get note by ID",
        "description": "Retrieve a single note by its ID and type",
        "operationId": "getNoteByNoteId",
        "parameters": [
          {
            "name": "noteId",
            "in": "path",
            "description": "ID of the note",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "businessType",
            "in": "query",
            "description": "Note type: PROPERTY, CONTACT, or CONTRACTOR",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Business type enum",
              "enum": [
                "PROPERTY",
                "CONTACT",
                "CONTRACTOR"
              ]
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer [access_token]",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoteResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Notes"
        ],
        "summary": "Update a note",
        "description": "Update the content and pin status of an existing note. Returns the new note ID.",
        "operationId": "update",
        "parameters": [
          {
            "name": "noteId",
            "in": "path",
            "description": "The ID of the note to update",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer [access_token]",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Type",
            "in": "header",
            "description": "application/json",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "application/json"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Note updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "example": {
                    "newId": 12345
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Notes"
        ],
        "summary": "Delete a note",
        "description": "Delete an existing note by its ID and business type",
        "operationId": "delete",
        "parameters": [
          {
            "name": "noteId",
            "in": "path",
            "description": "The ID of the note to delete",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "businessType",
            "in": "query",
            "description": "Business type: PROPERTY, CONTACT, or CONTRACTOR",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Business type enum",
              "enum": [
                "PROPERTY",
                "CONTACT",
                "CONTRACTOR"
              ]
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer [access_token]",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Type",
            "in": "header",
            "description": "application/json",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "application/json"
          }
        ],
        "responses": {
          "200": {
            "description": "Note deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    },
