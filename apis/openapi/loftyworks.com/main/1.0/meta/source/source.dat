            "example": true
          },
          "textOptIn": {
            "type": "boolean",
            "description": "Opt-in status for text messages. True means can text, false means cannot text",
            "example": true
          },
          "emailOptIn": {
            "type": "boolean",
            "description": "Opt-in status for emails. True means can email, false means cannot email",
            "example": true
          },
          "unsubscription": {
            "type": "boolean",
            "description": "Unsubscription the email",
            "example": false
          },
          "address": {
            "$ref": "#/components/schemas/ContactAddress"
          },
          "id": {
            "type": "integer",
            "description": "Contact ID",
            "format": "int64",
            "example": 30001
          },
          "createdTime": {
            "type": "integer",
            "description": "Created time",
            "format": "int64",
            "example": 1765866344280
          }
        },
        "description": "Contact information"
      },
      "ContactPageResult": {
        "type": "object",
        "properties": {
          "pageSize": {
            "type": "integer",
            "description": "Page Size",
            "format": "int32",
            "example": 0
          },
          "pageNum": {
            "type": "integer",
            "description": "Page Num",
            "format": "int32",
            "example": 20
          },
          "totalCount": {
            "type": "integer",
            "description": "Total Count",
            "format": "int32",
            "example": 1000
          },
          "pageData": {
            "type": "array",
            "description": "Page Data",
            "items": {
              "$ref": "#/components/schemas/Contact"
            }
          }
        },
        "description": "Paginated result for contacts"
      },
      "ContactPhone": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "description": "Phone number",
            "example": "7911123456"
          },
          "isPrimary": {
            "type": "boolean",
            "description": "Whether this is the primary phone",
            "example": true
          },
          "type": {
            "type": "string",
            "description": "Phone type: mobile, landline, other",
            "example": "mobile"
          },
          "state": {
            "type": "string",
            "description": "Phone state: Unknown, Invalid Number, Valid Number, Talked, DNC Number, DNC Contact",
            "example": "Valid Number"
          },
          "phoneCountry": {
            "type": "string",
            "description": "Phone country",
            "example": "US"
          },
          "phoneCode": {
            "type": "string",
            "description": "Phone code",
            "example": "+1"
          },
          "consentState": {
            "type": "string",
            "description": "Consent state: Do Not Call, Business Relationship, Unknown consent, System Recorded consent, User consent",
            "example": "Unknown consent"
          },
          "id": {
            "type": "integer",
            "description": "Phone ID",
            "format": "int64",
            "example": 200001
          },
          "contactId": {
            "type": "integer",
            "description": "Contact ID",
            "format": "int64",
            "example": 30001
          }
        },
        "description": "Contact phone information"
      },
      "ContactEmail": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address",
            "example": "james.brown@example.com"
          },
          "isPrimary": {
            "type": "boolean",
            "description": "Whether this is the primary email",
            "example": true
          },
          "valid": {
            "type": "boolean",
            "description": "Whether this email is valid",
            "example": true
          },
          "description": {
            "type": "string",
            "description": "Description of this email",
            "example": "Work email"
          },
          "id": {
            "type": "integer",
            "description": "Email ID",
            "format": "int64",
            "example": 100001
          },
          "contactId": {
            "type": "integer",
            "description": "Contact ID",
            "format": "int64",
            "example": 30001
          },
          "isBounced": {
            "type": "boolean",
            "description": "Whether this email has bounced",
            "example": false
          }
        },
        "description": "Contact email information"
      }
    }
  }
}