{
  "openapi": "3.0.3",
  "info": {
    "title": "Webdam REST API",
    "description": "Webdam (now part of Bynder) digital asset management REST API. Provides programmatic access to assets, folders, lightboxes, and metadata within a Webdam account.",
    "version": "1.0.0",
    "contact": {
      "name": "Webdam Support",
      "url": "https://www.damsuccess.com/hc/en-us"
    },
    "x-jentic-source-url": "https://www.damsuccess.com/hc/en-us/articles/202134055-REST-API"
  },
  "servers": [
    {
      "url": "https://apiv2.webdamdb.com",
      "description": "Webdam API v2 Production"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "OAuth 2.0 token management"
    },
    {
      "name": "Assets",
      "description": "Digital asset operations"
    },
    {
      "name": "Folders",
      "description": "Folder management"
    },
    {
      "name": "Lightboxes",
      "description": "Lightbox management"
    },
    {
      "name": "Users",
      "description": "User account management"
    },
    {
      "name": "Search",
      "description": "Asset search operations"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/oauth2/token": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Obtain access token",
        "description": "Obtain an OAuth 2.0 access token using client credentials or password grant.",
        "operationId": "getAccessToken",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id", "client_secret"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["password", "client_credentials"],
                    "description": "OAuth 2.0 grant type"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Application client ID"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Application client secret"
                  },
                  "username": {
                    "type": "string",
                    "description": "User email (required for password grant)"
                  },
                  "password": {
                    "type": "string",
                    "description": "User password (required for password grant)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid grant or missing parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Invalid client credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
