  "components": {
    "schemas": {
      "SmartRoute": {
        "type": "object",
        "required": [
          "name",
          "lane"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "nullable": true,
            "example": 123
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "example": "Smart Route I"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "createdBy": {
            "type": "string",
            "example": "broker@email.com"
          },
          "createdAt": {
            "type": "string",
            "format": "MM/DD/YY HH:mm",
            "example": "01/10/22"
          },
          "carriers": {
            "$ref": "#/components/schemas/Carriers"
          },
          "tendering": {
            "$ref": "#/components/schemas/Tendering"
          },
          "lane": {
            "$ref": "#/components/schemas/Lane"
          },
          "criteria": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Criteria"
            }
          }
        }
      },
      "Carriers": {
        "type": "object",
        "properties": {
          "strategyType": {
            "type": "string",
            "enum": [
              "enhance",
              "restrict",
              "hide"
            ]
          },
          "useMasterList": {
            "type": "boolean"
          },
          "masterListCount": {
            "type": "integer"
          },
          "list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Carrier"
            }
          }
        }
      },
      "Carrier": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 123
          },
          "tier": {
            "type": "integer",
            "enum": [
              1,
              2,
              3,
              4,
              5
            ],
            "example": 1
          },
          "carrierId": {
            "type": "integer",
            "example": 12345
          },
          "companyName": {
            "type": "string",
            "example": "Carrier Limited"
          },
          "mcNumber": {
            "type": "string",
            "example": "MC10000001"
          },
          "dotNumber": {
            "type": "string",
            "example": 20000001
          },
          "contactName": {
            "type": "string",
            "example": "Joe Contact"
          },
          "email": {
            "type": "string",
            "example": "jcontact@broker.com"
          },
          "phone": {
            "type": "string",
            "example": 9008007060
          },
          "externalId": {
            "type": "string",
            "example": "76cdba21-6c83-4133-a86c-8a9a8dcae24d"
          }
        }
      },
      "Tendering": {
        "properties": {
          "loadRevealStrategy": {
            "$ref": "#/components/schemas/Strategy"
          },
          "BookItNowRevealStrategy": {
            "$ref": "#/components/schemas/Strategy"
          },
          "BookItNowRateStrategy": {
            "$ref": "#/components/schemas/Strategy"
          }
        }
      },
      "Strategy": {
        "type": "object",
        "properties": {
          "condition": {
            "type": "string",
            "enum": [
              "PICKUP_AT_MINUS",
              "CREATED_AT_PLUS"
            ]
          },
          "interval": {
            "type": "string",
            "enum": [
              "hour",
              "day"
            ],
            "example": "hour"
          },
          "milestones": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Milestone"
            }
          },
          "maxRateThreshold": {
            "type": "number",
            "example": 5.5
          },
          "minRateCondition": {
            "type": "string",
            "example": "PERCENTAGE"
          }
        }
      },
      "Milestone": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "example": "abc-xyz"
          },
          "tiers": {
            "type": "array",
            "items": {
              "type": "integer",
              "enum": [
                1,
                2,
                3,
                4,
                5
              ]
            },
            "example": [
              1,
              2
            ]
          },
          "value": {
            "type": "string",
            "example": 8
          }
        }
      },
      "Lane": {
        "type": "object",
        "required": [
          "originType",
          "origin",
          "destinationType",
          "destination"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "nullable": true,
            "example": 101
          },
          "originType": {
            "type": "string",
            "enum": [
              "market",
              "city",
              "state",
              "zone",
              "country",
              "anywhere"
            ],
            "example": "state"
          },
          "origin": {
            "$ref": "#/components/schemas/LaneOption"
          },
          "destinationType": {
            "type": "string",
            "enum": [
              "market",
              "city",
              "state",
              "zone",
              "country",
              "anywhere"
            ],
            "example": "zone"
          },
          "destination": {
            "$ref": "#/components/schemas/LaneOption"
          },
          "excludeOrigin": {
            "type": "boolean"
          },
          "excludeDestination": {
            "type": "boolean"
          }
        }
      },
      "LaneOption": {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "$ref": "#/components/schemas/MarketOption"
            },
            {
              "$ref": "#/components/schemas/CityOption"
            },
            {
              "$ref": "#/components/schemas/StateOption"
            },
            {
              "$ref": "#/components/schemas/CountryOption"
            },
            {
              "$ref": "#/components/schemas/ZoneOption"
            }
          ]
        }
      },
      "MarketOption": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "ATLANTA GA"
          }
        }
      },
      "CityOption": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "example": "Albany"
          },
          "state": {
            "type": "string",
            "example": "OR"
          }
        }
      },
      "StateOption": {
        "type": "string",
        "description": "2 letter abbreviation",
        "example": "VA"
      },
      "CountryOption": {
        "type": "string",
        "enum": [
          "US",
          "CA",
          "MX"
        ],
        "example": "US"
      },
      "ZoneOption": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "Z1"
          },
          "value": {
            "type": "string",
            "example": "Zone 1(DE,NY, PE)"
          }
        }
      },
      "Criteria": {
        "type": "object",
        "properties": {
          "criteriaId": {
            "type": "integer",
            "example": 123
          },
          "key": {
            "type": "string",
            "enum": [
              "DISPATCHER_ID",
              "EQUIPMENT_TYPE",
              "LOAD_CONTACT",
              "CUSTOMER_CODE",
              "REVENUE_CODE",
              "LOAD_NUMBER",
              "OPERATIONS_USER",
              "ORDER_STATUS",
              "CARRIER_MANAGER",
              "RESPONSIBILITY_CODE"
            ],
            "example": "CUSTOMER_CODE"
          },
          "value": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "code1",
              "code2"
            ]
          },
          "operator": {
            "type": "string",
            "enum": [
              "IN",
              "NOT_IN",
              "CONTAIN",
              "DOES_NOT_CONTAIN"
            ],
            "example": "IN"
          },
          "includeUnset": {
            "type": "boolean"
          }
        }
      },
      "SuccessfulResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "UnauthenticatedResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean",
            "default": false
          },
          "message": {
            "type": "string",
            "default": "Unauthenticated."
          },
          "error": {
            "type": "string",
            "default": "Unauthenticated."
          }
        }
      },
      "NotFoundResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean",
            "default": false
          },
          "statusCode": {
            "type": "string",
            "default": 404,
            "description": "Status of API call"
          },
          "message": {
            "type": "string",
            "default": "SmartRoute id {id} does not exist."
          }
        }
      },
      "InvalidInputResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "object",
            "example": {
              "name": [
                "The name field is required."
              ]
            }
          }
        }
      }
    }
  }
}