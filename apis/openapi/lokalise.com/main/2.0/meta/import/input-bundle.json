  "components": {
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "created_by": {
            "type": "integer"
          },
          "team_id": {
            "type": "integer"
          },
          "base_language_id": {
            "type": "integer"
          },
          "base_language_iso": {
            "type": "string"
          },
          "settings": {
            "type": "object"
          },
          "statistics": {
            "type": "object"
          }
        }
      },
      "ProjectInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "languages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lang_iso": {
                  "type": "string"
                }
              }
            }
          },
          "base_lang_iso": {
            "type": "string"
          }
        }
      },
      "Key": {
        "type": "object",
        "properties": {
          "key_id": {
            "type": "integer"
          },
          "key_name": {
            "type": "object",
            "properties": {
              "ios": {
                "type": "string"
              },
              "android": {
                "type": "string"
              },
              "web": {
                "type": "string"
              },
              "other": {
                "type": "string"
              }
            }
          },
          "description": {
            "type": "string"
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filenames": {
            "type": "object"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "translations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Translation"
            }
          }
        }
      },
      "KeyInput": {
        "type": "object",
        "required": [
          "key_name",
          "platforms"
        ],
        "properties": {
          "key_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "ios",
                "android",
                "web",
                "other"
              ]
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "translations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "language_iso": {
                  "type": "string"
                },
                "translation": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Translation": {
        "type": "object",
        "properties": {
          "translation_id": {
            "type": "integer"
          },
          "key_id": {
            "type": "integer"
          },
          "language_iso": {
            "type": "string"
          },
          "translation": {
            "type": "string"
          },
          "modified_by": {
            "type": "integer"
          },
          "modified_at": {
            "type": "string"
          },
          "is_reviewed": {
            "type": "boolean"
          }
        }
      },
      "File": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string"
          },
          "key_count": {
            "type": "integer"
          }
        }
      },
      "FileUploadRequest": {
        "type": "object",
        "required": [
          "data",
          "filename",
          "lang_iso"
        ],
        "properties": {
          "data": {
            "type": "string",
            "description": "Base64-encoded file content"
          },
          "filename": {
            "type": "string"
          },
          "lang_iso": {
            "type": "string"
          },
          "convert_placeholders": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "FileDownloadRequest": {
        "type": "object",
        "required": [
          "format"
        ],
        "properties": {
          "format": {
            "type": "string",
