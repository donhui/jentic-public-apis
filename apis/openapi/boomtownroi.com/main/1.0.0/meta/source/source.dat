                    "value": {
                      "contactAddressId": 456,
                      "contactId": 123,
                      "address": "635 Rutledge Avenue",
                      "city": "Charleston",
                      "state": "SC",
                      "zipCode": 29403,
                      "addressChangedByUserId": 789,
                      "addressEntryType": "agentEntered",
                      "addressType": "NotSpecified",
                      "description": "string",
                      "dateCreated": "2016-01-27T14:45:14.703Z",
                      "dateModified": "2016-01-27T14:45:14.703Z"
                    }
