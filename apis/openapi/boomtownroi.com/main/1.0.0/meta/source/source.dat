      "Organization": {
        "type": "object",
        "properties": {
          "orgId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "Primary identifier of the organization. Value set by BoomTown."
          },
          "networkId": {
            "type": "number",
            "example": 456,
            "description": "Primary identifier for a network grouping associating multiple sites owned by the organization. Networks will be available in a future release of BoomTown API."
          },
          "timeZoneId": {
            "type": "string",
            "example": "America/New_York",
            "description": "The local time zone of the organization.  Assign a values using the <a href=\"https://en.wikipedia.org/wiki/List_of_tz_database_time_zones\" target=\"_blank\">tz timezone database</a>."
          },
          "website": {
            "type": "string",
            "example": "cobblestonegroup.com",
            "description": "Fully qualified damain name for the organization's website."
          },
          "name": {
            "type": "string",
            "example": "The Cobblestone Group",
            "description": "Name of the organization."
          },
          "legalName": {
            "type": "string",
            "example": "The Cobblestone Group LLC",
            "description": "Legal name of the organization."
          },
          "serviceArea": {
            "type": "string",
            "example": "Charleston, SC",
            "description": "Short description of the geographic area that the organization serves."
          },
          "emailAddress": {
            "type": "string",
            "example": "info@cobblestonegroup.com",
            "description": "Primary email address of the organization."
          },
          "phoneNumber": {
            "type": "string",
            "example": "(843) 300-3388",
            "description": "Phone number of the organization."
          },
          "faxNumber": {
            "type": "string",
            "example": "(843) 555-3300",
            "description": "Fax number of the organization."
          },
          "street": {
            "type": "string",
            "example": "635 Rutledge Ave.",
            "description": "Street address of the organization."
          },
          "city": {
            "type": "string",
            "example": "Charleston",
            "description": "City of the organization."
          },
          "state": {
            "type": "string",
            "example": "SC",
            "description": "State of the organization."
          },
          "zipCode": {
            "type": "string",
            "example": "29414",
            "description": "Zip code of the organization."
          },
          "emailDomains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "cobblestonegroup.com"
            ],
            "description": "List of fully qualified email domains for the organization.  The primary email is first in the list."
          },
          "isLive": {
            "type": "boolean",
            "example": true,
            "description": "If set to true, the organization has fully launched their BoomTown service and has not cancelled."
          },
          "launchDate": {
            "type": "string",
            "format": "date-time",
            "example": "2015-07-21T16:05:38.788Z",
            "readOnly": true,
            "description": "Date the organization launched their BoomTown service. Value set by BoomTown."
          },
          "cancelDate": {
            "type": "string",
            "format": "date-time",
            "example": "2015-07-21T16:05:38.788Z",
            "readOnly": true,
            "description": "Date the organization cancelled their BoomTown service. Value set by BoomTown."
          },
          "primaryContactId": {
            "type": "number",
            "example": 789,
            "description": "The id of the user that is the primary contact of the organization."
          },
          "isCanadian": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the organization is registered business in Canada."
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the organization was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the organization was last changed. Value set by  BoomTown.s"
          }
        },
        "description": "An organization object contains basic information about an organization and its account status with BoomTown.\n",
        "required": [
          "orgId",
          "timeZoneId",
          "website",
          "name",
          "legalName",
          "serviceArea",
          "emailAddress",
          "phoneNumber",
          "street",
          "city",
          "state",
          "zipCode",
          "emailDomains",
          "isLive",
          "isCanadian",
          "dateCreated",
          "dateModified"
        ]
      },
      "Communication": {
        "type": "object",
        "properties": {
          "contactName": {
            "type": "string",
            "description": "Name of contact."
          },
          "communicationType": {
            "type": "string",
            "enum": [
              "email",
              "text",
              "callLog"
            ],
            "description": "'Type of communication. <br>Allowed values: `email`, `text`, `callLog`'\n"
          },
          "communicationObject": {
            "type": "object",
            "items": {
              "type": "object",
              "properties": {
                "emailId": {
                  "type": "number",
                  "format": "int64",
                  "example": 123,
                  "readOnly": true,
                  "description": "The primary identifier for the email.  Value set by BoomTown."
                },
                "orgId": {
                  "type": "number",
                  "format": "int64",
                  "example": 2,
                  "description": "The identifier of the Organization associated with the email."
                },
                "contactId": {
                  "type": "number",
                  "format": "int64",
                  "example": 2223,
                  "description": "The identifier of the Contact who is associated with the email."
                },
                "ownerId": {
                  "type": "number",
                  "format": "int64",
                  "example": 2,
                  "description": "The identifier of the User who is responsible for replying to the email."
                },
                "threadId": {
                  "type": "string",
                  "format": "UUID",
                  "description": "The identifier for the conversation thread. Not needed if not part of an existing conversation."
                },
                "authorId": {
                  "type": "number",
                  "format": "int64",
                  "example": 47,
                  "description": "The identifier of the user who wrote and sent the email. May be different than the owner."
                },
                "emailType": {
                  "type": "string",
                  "enum": [
                    "notSelected",
                    "outBoundAgent",
                    "outBoundLender",
                    "inBound",
                    "onBehalf",
                    "agentProxyReply",
                    "lenderProxyReply",
                    "buyerProxyReply",
                    "buyerProxyReplyToLender",
                    "ccProxyReply",
                    "dripStepAgent",
                    "dripStepLender",
                    "bulkEmailAgent",
                    "bulkEmailLender",
                    "bestFitAgent",
                    "bestFitLender",
                    "parsedLeadImport",
                    "parsedLeadInquiry"
                  ],
                  "example": "outBound",
                  "description": "Indicates the how the email was generated. Allowed values:\n- `notSelected` (default)\n- `outBoundAgent`: Agent sent from leads.\n- `outBoundLender`: Lender sent from leads.\n- `inBound`: Contact email to agent.\n- `onBehalf`: Automated email (e.g. welcome email)\n- `agentProxyReply`: From agent's personal email, BoomTown logs and sends to buyer.\n- `lenderProxyReply`: From lenders's personal email, BoomTown logs and sends to buyer.\n- `buyerProxyReply`: Buyer replies, Boomtown logs and sends to agent.\n- `buyerProxyReplyToLender`: Buyer replies, BoomTowm logs and sends to lender.\n- `ccProxyReply`: cc'd person replies, BoomTown logs and sends to buyer.\n- `dripStepAgent`: Agent drip campaign\n- `dripStepLender`: Lender drip campaign\n- `bulkEmailAgent`: Agent bulk email\n- `bulkEmailLender`: Lender bulk email\n- `bestFitAgent`: Agent best fit email\n- `bestFitLender`: Lender best fit email\n- `parsedLeadImport`: Third-party lead email\n- `parsedLeadInquiry`: - Imported from third-party email\"\n"
                },
                "openDate": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Date email was opened."
                },
                "replyDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2015-07-21T16:07:38.788Z",
                  "description": "Date email was replied to."
                },
                "alertDismissedDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2015-07-21T16:08:38.788Z",
                  "description": "Date email was dismissed. \n"
                },
                "lastOpenDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2015-07-21T16:09:38.788Z",
                  "description": "Date the email was last opened and read."
                },
                "openCount": {
                  "type": "number",
                  "example": 3,
                  "description": "Number of times the email was opened."
                },
                "subject": {
                  "type": "string",
                  "example": "RE: Looking for a home",
                  "description": "Subject line of the email."
                },
                "synopsis": {
                  "type": "string",
                  "example": "Hey John, I am in the market for a new home.  Please let me know what",
                  "description": "Brief version of the email body with formatting removed."
                },
                "senderEmail": {
                  "type": "string",
                  "example": "Rick@BoomTownROI.com",
                  "description": "Email of the person who sent the email."
                },
                "senderName": {
                  "type": "string",
                  "example": "Rick Smith",
                  "description": "Name of the person who sent the email."
                },
                "recipientEmail": {
                  "type": "string",
                  "example": "John@IneedAHome.com",
                  "description": "Email of the person who the email was sent to."
                },
                "recipientName": {
                  "type": "string",
                  "example": "John Doe",
                  "description": "Name of the person who the email was sent to."
                },
                "forwardedTo": {
                  "type": "string",
                  "example": [
                    "Janie@BoomTownROI.com"
                  ],
                  "description": "Email of person who email was forwarded to."
                },
                "hasAttachments": {
                  "type": "boolean",
                  "example": true,
                  "description": "If set to `true`, the email had attachments."
                },
                "templateId": {
                  "type": "number",
                  "format": "int64",
                  "example": 3,
                  "description": "The id of the email template used, if one was used."
                },
                "copiedAgentBroker": {
                  "type": "boolean",
                  "example": false,
                  "description": "If set to `true`, the agent or broker was copied on the email."
                },
                "copiedLender": {
                  "type": "boolean",
                  "example": false,
                  "description": "If set to `true`, the lender was copied on the email."
                },
                "dripEmail": {
                  "type": "boolean",
                  "example": true,
                  "description": "If set to `true`, indicated the email was scheduled as part of a series\nof automated marketing emails.\n"
                },
                "dateCreated": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time the email was created. Value set by BoomTown."
                },
                "dateModified": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time when the email was last changed. Value set by BoomTown."
                }
              },
              "description": "The email object contains the basic fields needed to display a preview of the emails. Additional body, bodyThreadText, headers and fileAttachments are appended when the Get a full email by id endpoint is used.\n",
              "required": [
                "emailId",
                "orgId",
                "contactId",
                "ownerId",
                "threadId",
                "emailType",
                "subject",
                "synopsis",
                "senderEmail",
                "recipientEmail",
                "dateCreated",
                "dateModified"
              ]
            },
            "description": "Email, text or callLog object. Must match the `communicationType`."
          }
        },
        "description": "A wrapper returning various communication types. `communicationObject` is set to *`Email`*, *`Text`* or *`CallLog`* and matchs\nthe `communicationType`.      \n",
        "required": [
          "contactName",
          "communicationType",
          "communicationObject"
        ]
      },
      "Email": {
        "type": "object",
        "properties": {
          "emailId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "The primary identifier for the email.  Value set by BoomTown."
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "example": 2,
            "description": "The identifier of the Organization associated with the email."
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 2223,
            "description": "The identifier of the Contact who is associated with the email."
          },
          "ownerId": {
            "type": "number",
            "format": "int64",
            "example": 2,
            "description": "The identifier of the User who is responsible for replying to the email."
          },
          "threadId": {
            "type": "string",
            "format": "UUID",
            "description": "The identifier for the conversation thread. Not needed if not part of an existing conversation."
          },
          "authorId": {
            "type": "number",
            "format": "int64",
            "example": 47,
            "description": "The identifier of the user who wrote and sent the email. May be different than the owner."
          },
          "emailType": {
            "type": "string",
            "enum": [
              "notSelected",
              "outBoundAgent",
              "outBoundLender",
              "inBound",
              "onBehalf",
              "agentProxyReply",
              "lenderProxyReply",
              "buyerProxyReply",
              "buyerProxyReplyToLender",
              "ccProxyReply",
              "dripStepAgent",
              "dripStepLender",
              "bulkEmailAgent",
              "bulkEmailLender",
              "bestFitAgent",
              "bestFitLender",
              "parsedLeadImport",
              "parsedLeadInquiry"
            ],
            "example": "outBound",
            "description": "Indicates the how the email was generated. Allowed values:\n- `notSelected` (default)\n- `outBoundAgent`: Agent sent from leads.\n- `outBoundLender`: Lender sent from leads.\n- `inBound`: Contact email to agent.\n- `onBehalf`: Automated email (e.g. welcome email)\n- `agentProxyReply`: From agent's personal email, BoomTown logs and sends to buyer.\n- `lenderProxyReply`: From lenders's personal email, BoomTown logs and sends to buyer.\n- `buyerProxyReply`: Buyer replies, Boomtown logs and sends to agent.\n- `buyerProxyReplyToLender`: Buyer replies, BoomTowm logs and sends to lender.\n- `ccProxyReply`: cc'd person replies, BoomTown logs and sends to buyer.\n- `dripStepAgent`: Agent drip campaign\n- `dripStepLender`: Lender drip campaign\n- `bulkEmailAgent`: Agent bulk email\n- `bulkEmailLender`: Lender bulk email\n- `bestFitAgent`: Agent best fit email\n- `bestFitLender`: Lender best fit email\n- `parsedLeadImport`: Third-party lead email\n- `parsedLeadInquiry`: - Imported from third-party email\"\n"
          },
          "openDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date email was opened."
          },
          "replyDate": {
            "type": "string",
            "format": "date-time",
            "example": "2015-07-21T16:07:38.788Z",
            "description": "Date email was replied to."
          },
          "alertDismissedDate": {
            "type": "string",
            "format": "date-time",
            "example": "2015-07-21T16:08:38.788Z",
            "description": "Date email was dismissed. \n"
          },
          "lastOpenDate": {
            "type": "string",
            "format": "date-time",
            "example": "2015-07-21T16:09:38.788Z",
            "description": "Date the email was last opened and read."
          },
          "openCount": {
            "type": "number",
            "example": 3,
            "description": "Number of times the email was opened."
          },
          "subject": {
            "type": "string",
            "example": "RE: Looking for a home",
            "description": "Subject line of the email."
          },
          "synopsis": {
            "type": "string",
            "example": "Hey John, I am in the market for a new home.  Please let me know what",
            "description": "Brief version of the email body with formatting removed."
          },
          "senderEmail": {
            "type": "string",
            "example": "Rick@BoomTownROI.com",
            "description": "Email of the person who sent the email."
          },
          "senderName": {
            "type": "string",
            "example": "Rick Smith",
            "description": "Name of the person who sent the email."
          },
          "recipientEmail": {
            "type": "string",
            "example": "John@IneedAHome.com",
            "description": "Email of the person who the email was sent to."
          },
          "recipientName": {
            "type": "string",
            "example": "John Doe",
            "description": "Name of the person who the email was sent to."
          },
          "forwardedTo": {
            "type": "string",
            "example": [
              "Janie@BoomTownROI.com"
            ],
            "description": "Email of person who email was forwarded to."
          },
          "hasAttachments": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, the email had attachments."
          },
          "templateId": {
            "type": "number",
            "format": "int64",
            "example": 3,
            "description": "The id of the email template used, if one was used."
          },
          "copiedAgentBroker": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the agent or broker was copied on the email."
          },
          "copiedLender": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the lender was copied on the email."
          },
          "dripEmail": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, indicated the email was scheduled as part of a series\nof automated marketing emails.\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the email was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the email was last changed. Value set by BoomTown."
          }
        },
        "description": "The email object contains the basic fields needed to display a preview of the emails. Additional body, bodyThreadText, headers and fileAttachments are appended when the Get a full email by id endpoint is used.\n",
        "required": [
          "emailId",
          "orgId",
          "contactId",
          "ownerId",
          "threadId",
          "emailType",
          "subject",
          "synopsis",
          "senderEmail",
          "recipientEmail",
          "dateCreated",
          "dateModified"
        ]
      },
      "Text": {
        "type": "object",
        "properties": {
          "textId": {
            "type": "number",
            "format": "int64",
            "example": 23,
            "readOnly": true,
            "description": "The primary identifier for a text message. Value set by BoomTown.\n"
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "example": 18,
            "readOnly": true,
            "description": "The identifier for the organization associated with the text message.\nValue set by BoomTown.\n"
          },
          "userId": {
            "type": "number",
            "format": "int64",
            "example": 2964,
            "readOnly": true,
            "description": "The identifier for the Agent/User receiving or sending the text message.\nValue set by BoomTown.\n"
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 5674,
            "readOnly": true,
            "description": "The identifier for the contact receiving or sending the text message.\nValue set by BoomTown.\n"
          },
          "message": {
            "type": "string",
            "example": "Do you want to view the home on Saturday?",
            "description": "The body of the text message sent."
          },
          "fromNumber": {
            "type": "string",
            "example": "8431234567",
            "readOnly": true,
            "description": "Phone number from which the text message was sent.  Value set by\nBoomTown.\n"
          },
          "toNumber": {
            "type": "string",
            "example": "9164325678",
            "description": "Phone number to which the text message was sent."
          },
          "status": {
            "type": "string",
            "enum": [
              "received",
              "queued",
              "sending",
              "sent",
              "error"
            ],
            "example": "sent",
            "readOnly": true,
            "description": "The delivery status of the text message. Value set by BoomTown.\nAllowed values: `received`, `queued`,`sending`, `sent`, `error`.\n"
          },
          "type": {
            "type": "string",
            "enum": [
              "userToContact",
              "contactToUser",
              "notification"
            ],
            "example": "userToContact",
            "readOnly": true,
            "description": "Who sent the text or was it a notification. Value set by BoomTown.\n<br>Allowed values:`userToContact``contactToUser``notification`\n"
          },
          "markedAsRead": {
            "type": "boolean",
            "example": true,
            "readOnly": true,
            "description": "If `true`, the text was read by the User. Value set by BoomTown."
          },
          "templateId": {
            "type": "number",
            "example": 3,
            "description": "The id number of the template (if used) for the text message."
          },
          "isFromMobile": {
            "type": "boolean",
            "example": false,
            "description": "If `true`, the text message sent from a mobile device."
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the text message was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the text message was last changed. Value set by BoomTown."
          },
          "deliveryStatus": {
            "type": "string",
            "enum": [
              "waiting",
              "delivered",
              "notDelivered"
            ],
            "example": "delivered",
            "readOnly": true,
            "description": "The delivery status of the text message.\n"
          },
          "deliveryDescription": {
            "type": "string",
            "example": "Message delivered to carrier",
            "readOnly": true,
            "description": "Information about the delivery of the message.\n"
          }
        },
        "description": "The text object contains the body of the message, as well as sender information, delivery status, and vital information about the contact sending or receiving the text.\n",
        "required": [
          "textId",
          "orgId",
          "message",
          "fromNumber",
          "toNumber",
          "status",
          "type",
          "markedAsRead",
          "isFromMobile",
          "dateCreated",
          "dateModified"
        ]
      },
      "CallLog": {
        "type": "object",
        "properties": {
          "callLogId": {
            "type": "number",
            "format": "int64",
            "example": 678,
            "readOnly": true,
            "description": "The main identifier for each call log. Value set by BoomTown.\n"
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "The identifier for the contact associated with the callLog. Value set by BoomTown.\n"
          },
          "userId": {
            "type": "number",
            "format": "int64",
            "example": 456,
            "readOnly": true,
            "description": "The identifier for the user associated with the callLog. Value set by BoomTown.\n"
          },
          "callDetails": {
            "type": "string",
            "example": "Tim wants to tour a home next week",
            "description": "Description and any notes about the call.\n"
          },
          "isPrivate": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, indicates the note is viewable only by the author, and hidden from others in the organization.\n"
          },
          "logType": {
            "type": "string",
            "enum": [
              "phoneConversation",
              "leftMessage",
              "callAttempt",
              "wrongNumber",
              "optedOut",
              "notSelected"
            ],
            "example": "phoneConversation",
            "description": "Outcome of the call. Allowed values:\n- `phoneConversation`\n- `leftMessage`\n- `callAttempt` (no message left)\n- `wrongNumber`\n- `optedOut`\n- `notSelected`\n"
          },
          "contactPhoneId": {
            "type": "number",
            "format": "int64",
            "example": 2,
            "description": "Identifier matching to a particular phone for a contact.\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the call log record was created. Value set by BoomTown.\n"
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the call log record was last changed. Value set by BoomTown.\n"
          },
          "callStartTime": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-15T16:51:08.530Z",
            "readOnly": true,
            "description": "Time the phone call started. Value set by BoomTown.\n"
          },
          "callEndTime": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-15T16:58:08.530Z",
            "readOnly": true,
            "description": "Time the phone call ended. Value set by BoomTown.\n"
          }
        },
        "description": "The call log object contains all details and notes from phone conversations.\n",
        "required": [
          "callLogId",
          "contactId",
          "isPrivate",
          "logType",
          "dateCreated",
          "dateModified"
        ]
      },
      "communications-response": {
        "type": "object",
        "description": "A wrapper returning various communication types. `communicationObject` is set to *`Email`*, *`Text`* or *`CallLog`* and matchs\nthe `communicationType`.\n",
        "properties": {
          "contactName": {
            "type": "string",
            "description": "Name of contact."
          },
          "communicationType": {
            "type": "string",
            "enum": [
              "email",
              "text",
              "callLog"
            ],
            "description": "Type of communication. <br>Allowed values: `email`, `text` `callLog`"
          },
          "communicationObject": {
            "$ref": "#/components/schemas/Communication/properties/communicationObject/items"
          }
        },
        "required": [
          "contactName",
          "communicationType",
          "communicationObject"
        ]
      },
      "Todo": {
        "type": "object",
        "properties": {
          "todoId": {
            "type": "number",
            "example": 123,
            "readOnly": true,
            "description": "The primary identifier for a todo. Value set by BoomTown."
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 2,
            "description": "Id of the contact associated with the todo."
          },
          "authorId": {
            "type": "number",
            "format": "int64",
            "example": 57,
            "readOnly": true,
            "description": "Id number of the user who created the todo. Value set by  BoomTown."
          },
          "ownerId": {
            "type": "number",
            "format": "int64",
            "example": 57,
            "readOnly": true,
            "description": "Id number of user whom the todo belongs. With Contacts, may be different from authorId, but defaults to authorId if not specified when\nthe todo is created. For users, the value is set by BoomTown.\n"
          },
          "isPrivate": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the todo is visible only to the user and is not shared with others in the organization.\n"
          },
          "todoType": {
            "type": "string",
            "enum": [
              "custom",
              "call",
              "email",
              "fax",
              "mail",
              "followUp",
              "meeting",
              "arrivalDate",
              "showing",
              "closing",
              "openHouse",
              "thankYou",
              "text"
            ],
            "example": "call",
            "description": "Type of action the user needs to take. Defaults to `custom`."
          },
          "label": {
            "type": "string",
            "example": null,
            "description": "Label for display if `todoType` is set to `custom`."
          },
          "body": {
            "type": "string",
            "example": "Call Bill about buying a home",
            "description": "Description of what to do."
          },
          "timeFrame": {
            "type": "string",
            "enum": [
              "later",
              "today",
              "tomorrow",
              "2days",
              "3days",
              "1week",
              "2weeks",
              "3weeks",
              "1month",
              "thisWeek",
              "nextWeek",
              "specific"
            ],
            "example": "2days",
            "description": "When the task should be completed.  Defaults to `later`."
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-15T16:51:08.530Z",
            "description": "Time when the todo is due."
          },
          "dueDateType": {
            "type": "string",
            "enum": [
              "anytime",
              "specific"
            ],
            "example": "specific",
            "description": "Modifier on dueDate. Defaults to `specific`."
          },
          "alertDate": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-15T16:51:08.530Z",
            "description": "Time to remind the user."
          },
          "completeDate": {
            "type": "string",
            "format": "date-time",
            "example": null,
            "description": "Time completed."
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the todo was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the todo was last changed. Value set by BoomTown."
          },
          "createdBy": {
            "type": "string",
            "enum": [
              "notSpecified",
              "self",
              "anotherUser",
              "dripCampaign"
            ],
            "example": "dripGenerated",
            "description": "Specifies who/what generated the Todo. Defaults to `notSpecified`.\n"
          },
          "isCalendarSyncEnabled": {
            "example": true,
            "type": "boolean"
          },
          "invitees": {
            "type": "array",
            "example": [
              "john@gmail.com",
              "alice@gmail.com"
            ],
            "items": {
              "type": "string"
            }
          },
          "location": {
            "type": "string",
            "example": "Somewhere"
          }
        },
        "description": "The todo object contains the details of a task or action that needs to be taken for the contact. It can include a type categorization, an expected time frame, and a date to remind the user.\n",
        "required": [
          "authorId",
          "ownerId",
          "dateCreated",
          "dateModified",
          "createdBy"
        ]
      },
      "tag-create": {
        "type": "object",
        "properties": {
          "orgId": {
            "example": 25
          },
          "userId": {
            "example": 4543
          },
          "tagName": {
            "example": "New Buyer"
          },
          "tagOwner": {
            "example": "org"
          }
        }
      },
      "Assignable_Drip_Plan": {
        "type": "object",
        "properties": {
          "dripPlanId": {
            "type": "number",
            "format": "int64",
            "example": 18,
            "description": "The identifier of drip plan."
          },
          "name": {
            "type": "string",
            "example": "Plan with one step",
            "description": "Assigned drip plan name"
          },
          "description": {
            "type": "string",
            "example": null,
            "description": "Description of the assigned drip plan"
          },
          "dripPlanType": {
            "type": "string",
            "enum": [
              "company",
              "system",
              "user"
            ],
            "example": "system",
            "description": "All available assignable drip plans enum values: `company``system``user`"
          }
        },
        "description": "The assignable drip plan object contains drip plans that can be assigned.\n"
      },
      "Assigned_Drip_Plan": {
        "type": "object",
        "properties": {
          "assignedDripPlanId": {
            "type": "string",
            "example": "MTU2NDY6OjI0",
            "readOnly": true,
            "description": "The primary identifier of an assigned drip plan. Value set by BoomTown."
          },
          "dripPlanId": {
            "type": "number",
            "format": "int64",
            "example": 302,
            "description": "The identifier of drip plan."
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "example": 23,
            "readOnly": true,
            "description": "The identifier of the organization. Value set by BoomTown."
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 23409,
            "description": "The identifier of the contact."
          },
          "userId": {
            "type": "number",
            "format": "int64",
            "example": 4567,
            "description": "UserId responsible for the assigned plan."
          },
          "status": {
            "type": "object",
            "properties": {
              "dateOfNextDrip": {
                "type": "string",
                "format": "date-time",
                "example": "2016-01-27T14:45:14.703Z",
                "description": "Time of the next content drip."
              },
              "dateOfLastDrip": {
                "type": "string",
                "format": "date-time",
                "example": "2016-01-26T14:45:14.703Z",
                "description": "Time of the last content drip."
              },
              "assignedDripStatus": {
                "type": "string",
                "enum": [
                  "paused",
                  "ended",
                  "terminated"
                ],
                "example": "running",
                "description": "Status of the campaign. Use to restart, pause or terminate a drip\ncampaign for a contact.<br>Allowed values: `running` (default)`paused``ended``terminated`\n"
              },
              "dateCompleted": {
                "type": "string",
                "format": "date-time",
                "example": null,
                "description": "Time the drip campaign completed."
              },
              "nextStepInPlan": {
                "type": "number",
                "format": "int64",
                "example": 3,
                "description": "The identifier of the next drip step in the campaign."
              }
            },
            "description": "These read-only attributes make up the status field and provide additional information about the assigned drip plan.\n"
          },
          "name": {
            "type": "string",
            "example": "Long-Term Drip Campaign",
            "description": "Assigned drip plan name"
          },
          "description": {
            "type": "string",
            "example": "BoomTown Long-Term Drip Campaign",
            "description": "Description of the assigned drip plan"
          },
          "stepCount": {
            "type": "number",
            "example": 1,
            "description": "Number of steps in the drip plan"
          },
          "dripPlanType": {
            "type": "string",
            "enum": [
              "company",
              "system",
              "user"
            ],
            "example": "company",
            "description": "Visibility of the drip plan. Allowed values: `company`, `system`, `user`"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the drip plan was assigned to the contact. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the assigned plan was last changed. Value set by BoomTown."
          }
        },
        "description": "The assigned drip plan object contains basic assignments for the drip plan, including the organization that owns the drip plan and associated user and contact.\n",
        "required": [
          "assignedDripPlanId",
          "dripPlanId",
          "orgId",
          "contactId",
          "userId",
          "dateCreated",
          "dateModified"
        ]
      },
      "Organization_Text_Search_Contact": {
        "type": "object",
        "properties": {
          "networkId": {
            "type": "number",
            "format": "int64",
            "description": "The network id that this organization belongs to."
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "readOnly": true,
            "description": "The organization owning the contact record. Value set by BoomTown."
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "description": "The contact id associated with the record",
            "example": 454
          },
          "firstName": {
            "type": "string",
            "description": "First name of the contact.",
            "example": "Bob"
          },
          "lastName": {
            "type": "string",
            "description": "Last name of the contact.",
            "example": "User"
          },
          "hasRelation": {
            "type": "boolean",
            "description": "If `true`, contact has a related contact.",
            "example": false
          },
          "buyerAgent": {
            "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender"
          },
          "listingAgent": {
            "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender"
          },
          "lender": {
            "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender"
          }
        }
      },
      "Visable_Text_Search_Contact": {
        "type": "object",
        "properties": {
          "networkId": {
            "type": "number",
            "format": "int64",
            "description": "The network id that this organization belongs to."
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "readOnly": true,
            "description": "The organization owning the contact record. Value set by BoomTown.\n"
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "description": "The contact id associated with the record"
          },
          "firstName": {
            "type": "string",
            "description": "First name of the contact."
          },
          "lastName": {
            "type": "string",
            "description": "Last name of the contact."
          },
          "email": {
            "type": "string",
            "description": "The email of the user",
            "example": "bob@company.com"
          },
          "phones": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The phone numbers of the user",
            "example": [
              "555-555-4321"
            ]
          },
          "hasRelation": {
            "type": "boolean",
            "example": false,
            "description": "If `true`, contact has a related contact."
          },
          "transactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "transactionId": {
                  "type": "string",
                  "example": "0F696528-176C-47E0-87D3-72F402C4A95B",
                  "readOnly": true,
                  "description": "Primary identifier for this transaction Value set by BoomTown."
                },
                "contactId": {
                  "type": "number",
                  "format": "int64",
                  "example": 12345,
                  "readOnly": true,
                  "description": "Identifier for the contact attached to this transaction."
                },
                "agentIds": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "example": [
                    6789
                  ],
                  "description": "Identifies the agents attached to this transaction."
                },
                "primaryAgentId": {
                  "type": "number",
                  "example": 6789,
                  "description": "Identifies the primary agent on this transaction."
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "buyer",
                    "seller"
                  ],
                  "example": "buyer",
                  "readOnly": true,
                  "description": "Specifies which type of transaction this tracks."
                },
                "originalStatus": {
                  "type": "string",
                  "enum": [
                    "preListing",
                    "activeListing",
                    "underContract",
                    "closed",
                    "abandoned",
                    "preContract"
                  ],
                  "example": "underContract",
                  "readOnly": true,
                  "description": "Specifies the status of this transaction when it was first created.\nFor seller type transactions valid status are `preListing`,`activeListing`, `underContract`, `closed`, `abandoned`\nfor buyer type transactions valid status are `preContract`, `underContract`, `closed`, `abandoned`\n"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "preListing",
                    "activeListing",
                    "underContract",
                    "closed",
                    "abandoned",
                    "preContract"
                  ],
                  "example": "underContract",
                  "description": "Specifies the current status of this transaction. For seller type\ntransactions valid status are `preListing`,`activeListing`,`underContract`,`closed`, `abandoned`\nfor buyer type transactions valid status are `preContract`, `underContract`,`closed`,`abandoned`\n"
                },
                "activeListingId": {
                  "type": "string",
                  "example": "1234457",
                  "description": "The listingId for the on-market listing associated with this transaction"
                },
                "soldListingId": {
                  "type": "string",
                  "example": null,
                  "description": "The listingId for the sold data listing record associated with this transaction\n"
                },
                "listDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "description": "The date the listing associated with this transactions went on the market.\n"
                },
                "expirationDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "description": "The date the contract between the buyer and seller expires (if not closed).\n"
                },
                "acceptanceDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "description": "The date the seller accepted the buyer's offer."
                },
                "closingDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "description": "The date the transaction is set to close."
                },
                "originalPrice": {
                  "type": "number",
                  "example": 150000,
                  "readOnly": true,
                  "description": "The original negotiated price of the property.  Stored as a whole number with two decimal places. \n"
                },
                "price": {
                  "type": "number",
                  "example": 150000,
                  "description": "The negotiated sales price of the property.  Stored as a whole number\nwith two decimal places.\n"
                },
                "address": {
                  "type": "object",
                  "properties": {
                    "contactAddressId": {
                      "type": "number",
                      "format": "int64",
                      "example": 456,
                      "readOnly": true,
                      "description": "Primary identifier. Value set by BoomTown."
                    },
                    "contactId": {
                      "type": "number",
                      "format": "int64",
                      "example": 123,
                      "readOnly": true,
                      "description": "The contact associated with the address. Value set by BoomTown."
                    },
                    "address": {
                      "type": "string",
                      "example": "635 Rutledge Avenue",
                      "description": "Street number and name. May include apt, suite, or other."
                    },
                    "city": {
                      "type": "string",
                      "example": "Charleston",
                      "description": "City"
                    },
                    "state": {
                      "type": "string",
                      "example": "SC",
                      "description": "State (US), Province (Canada)."
                    },
                    "zipCode": {
                      "type": "string",
                      "example": "29403",
                      "description": "Zip code (US), Postal code (Canada)."
                    },
                    "addressChangedByUserId": {
                      "type": "number",
                      "format": "int64",
                      "example": 789,
                      "readOnly": true,
                      "description": "User who last updated the physical address (modified by the contact via visitor or by a CRM user). Value set by BoomTown."
                    },
                    "addressEntryType": {
                      "type": "string",
                      "enum": [
                        "notSpecified",
                        "systemIPCalc",
                        "contactEntered",
                        "agentEntered",
                        "lenderEntered",
                        "adminEntered"
                      ],
                      "example": "agentEntered",
                      "description": "How the address was entered. <br>Allowed values: \n- `notSpecified`(default) \n- `systemIPCalc`\n- `contactEntered`\n- `agentEntered`\n- `lenderEntered`\n- `adminEntered`\n"
                    },
                    "addressType": {
                      "type": "string",
                      "enum": [
                        "NotSpecified",
                        "Home",
                        "MailAddress",
                        "Office"
                      ],
                      "description": "Disabled, Future release. Allowed values:  `Home` `Office` `NotSpecified``MailAddress`"
                    },
                    "description": {
                      "type": "string",
                      "description": "Disabled, Future release. Optional description for the address."
                    },
                    "dateCreated": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-27T14:45:14.703Z",
                      "readOnly": true,
                      "description": "Time the address was created. Value set by BoomTown."
                    },
                    "dateModified": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-27T14:45:14.703Z",
                      "readOnly": true,
                      "description": "Time when the address was last changed. Value set by BoomTown."
                    }
                  },
                  "description": "The address object contains details of a contact\u2019s physical address.\n",
                  "required": [
                    "contactAddressId",
                    "contactId",
                    "addressEntryType",
                    "dateCreated",
                    "dateModified"
                  ]
                },
                "dateCreated": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "description": ""
                },
                "dateModified": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "description": ""
                },
                "commission": {
                  "type": "object",
                  "properties": {
                    "grossCommission": {
                      "type": "number",
                      "example": 1099900,
                      "description": "Value of the commission. Stored as a whole number with two decimal\nplaces.  For example $250,234.34 should be set and returned as 25023434.\n"
                    },
                    "grossCommissionType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "percentage",
                      "description": "The type of commission. Allowed values:`percentage``absolute`  This\nis an indcator of how UIs might want to display the data and does not imply\nhow the grossCommision is stored.\n"
                    },
                    "agentCommission": {
                      "type": "number",
                      "example": 329970,
                      "description": "Value of the agents portion of the commission, stored as a whole\nnumber with two decimal places.  For example $15,992.00 should be set and returned\nas 1599200.\n"
                    },
                    "agentCommissionType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "absolute",
                      "description": "The type of commission. Allowed values:`percentage``absolute`  This\nis an indcator of how UIs might want to display the data and does not imply\nhow the agentCommission is stored.\n"
                    },
                    "leadCoordinatorCommission": {
                      "type": "number",
                      "example": 0,
                      "description": "Value of the lead coordinator's portion of the commission. Stored\nas a whole number with two decimal places.  For example $567.29 should be set\nand returned as 56729.\n"
                    },
                    "leadCoordinatorCommissionType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "percentage",
                      "description": "The type of commission. Allowed values:`percentage``absolute`  This\nis an indcator of how UIs might want to display the data and does not imply\nhow the leadCoordinatorCommission is stored.\n"
                    },
                    "brokerCommission": {
                      "type": "number",
                      "example": 769930,
                      "description": "Value of the broker's portion of the commission. Stored  as a whole\nnumber to two decimal places.  For example $8723.49 should be set and returned\nas 872349.\n"
                    },
                    "brokerCommissionType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "absolute",
                      "description": "The type of commission. Allowed values:`percentage``absolute`  This\nis an indcator of how UIs might want to display the data and does not imply\nhow the brokerCommission is stored.\n"
                    },
                    "franchiseFee": {
                      "type": "number",
                      "example": 0,
                      "description": "Value of the of the commission attributed to the franchise fee as\na whole number to two decimal places.  For example $2,382.05 should be set and\nreturned as 238205.\n"
                    },
                    "franchiseFeeType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "percentage",
                      "description": "The type of the franchise fee. Allowed values:`percentage``absolute`  This\nis an indcator of how UIs might want to display the data and does not imply\nhow the franchiseFee is stored.\n"
                    },
                    "referralFee": {
                      "type": "number",
                      "example": 0,
                      "description": "Value of the fee stored as a whole number with two decimal places.  For\nexample $925.36 should be set and returned as 92536.\n"
                    },
                    "referralFeeType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "absolute",
                      "description": "The type of the fee. Allowed values:`percentage``absolute`   This\nis an indcator of how UIs might want to display the data and does not imply\nhow the referralFee is stored.\n"
                    },
                    "businessExpenses": {
                      "type": "number",
                      "example": 0,
                      "description": "Value of the business expense stored  as a whole number to two decimal\nplaces.  For example $237.91 should be set and returned as 23791.\n"
                    },
                    "businessExpensesType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "absolute",
                      "description": "Allowed values:`percentage``absolute`  This is an indcator of how\nUIs might want to display the data and does not imply how the businessExpenses\nis stored.\n"
                    },
                    "transactionCoordinationFee": {
                      "type": "number",
                      "example": 0,
                      "description": "Value of the fee stored as a whole number to two decimal places.  For\nexample 15.51% should be set and returned as 1551.\n"
                    },
                    "transactionCoordinationFeeType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "absolute",
                      "description": "Allowed values:`percentage``absolute`  This is an indcator of how\nUIs might want to display the data and does not imply how the transactionCoordinationFee\nis stored.\n"
                    },
                    "miscellaneousFee": {
                      "type": "number",
                      "example": 0,
                      "description": "Value of the fee stored  as a whole number to two decimal places.  For\nexample $34.20 should be set and returned as 3420.\n"
                    },
                    "miscellaneousFeeType": {
                      "type": "string",
                      "enum": [
                        "percentage",
                        "absolute"
                      ],
                      "example": "absolute",
                      "description": "This is an indcator of how UIs might want to display the data and does not imply how the miscellaneousFee\nis stored.\n"
                    }
                  },
                  "description": "A commission object records information about the commission and fee breakdown for a transaction\n"
                },
                "integrations": {
                  "type": "object",
                  "properties": {
                    "integrationId": {
                      "type": "number",
                      "readOnly": true,
                      "description": "The id of the 3rd party integration.  Value set by BoomTown.",
                      "example": 1
                    },
                    "name": {
                      "type": "string",
                      "enum": [
                        "DotLoop"
                      ],
                      "description": "The name of the 3rd party integration.  Allowed values:`DotLoop`",
                      "example": "DotLoop"
                    },
                    "createdById": {
                      "type": "number",
                      "readOnly": true,
                      "description": "The userId of the person who created the integration.  Value set by BoomTown.",
                      "example": null
                    },
                    "vendorId": {
                      "type": "string",
                      "description": "Id that uniquely identifies the integration in the 3rd party integration's system.\n",
                      "example": "AnId"
                    },
                    "dateCreated": {
                      "type": "string",
                      "format": "date-time",
                      "readOnly": true,
                      "description": "Date the integration was added.  Value set by BoomTown.",
                      "example": "2016-01-27T14:45:14.703Z"
                    },
                    "dateModified": {
                      "type": "string",
                      "format": "date-time",
                      "readOnly": true,
                      "description": "Date the integration was last modified.  Value set by BoomTown.",
                      "example": "2016-01-27T14:45:14.703Z"
                    },
                    "templateId": {
                      "type": "string",
                      "description": "The 3rd party integration template Id, Will be null if Id does not\nexist. Value set by 3rd Party and passed through by client.\n",
                      "example": "templateId"
                    }
                  },
                  "description": "A transaction integration object records information about the integration of the transaction with a 3rd party service\n",
                  "required": [
                    "name"
                  ]
                }
              },
              "description": "A transaction object records a potential, in-progress, or completed purchase or sale by a contact.\n",
              "required": [
                "transactionId",
                "contactId"
              ]
            },
            "description": "Information associated with the transactions associated with the contact\n"
          },
          "buyerAgent": {
            "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender"
          },
          "listingAgent": {
            "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender"
          },
          "lender": {
            "type": "object",
            "properties": {
              "userId": {
                "type": "string",
                "description": "The id associated with the user.",
                "example": 6867
              }
            },
            "description": "User Information associated with the buyer agent"
          }
        }
      },
      "Contact_Text_Search_Request": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The text to look for in the contacts",
            "example": 8435551234
          },
          "orgIds": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "The organizations to restrict the search across",
            "example": [
              32,
              25
            ]
          },
          "filterField": {
            "type": "string",
            "enum": [
              "name",
              "email",
              "phone",
              "transactionAddress"
            ],
            "description": "Restricts the search to the specified field. Allowed values: `name`, `email`, `phone`, `transactionAddress`\n",
            "example": "phone"
          }
        }
      },
      "Contact_Text_Search_Response": {
        "type": "object",
        "properties": {
          "visibleContacts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "networkId": {
                  "type": "number",
                  "format": "int64",
                  "description": "The network id that this organization belongs to."
                },
                "orgId": {
                  "type": "number",
                  "format": "int64",
                  "readOnly": true,
                  "description": "The organization owning the contact record. Value set by BoomTown.\n"
                },
                "contactId": {
                  "type": "number",
                  "format": "int64",
                  "description": "The contact id associated with the record"
                },
                "firstName": {
                  "type": "string",
                  "description": "First name of the contact."
                },
                "lastName": {
                  "type": "string",
                  "description": "Last name of the contact."
                },
                "email": {
                  "type": "string",
                  "description": "The email of the user",
                  "example": "bob@company.com"
                },
                "phones": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "The phone numbers of the user",
                  "example": [
                    "555-555-4321"
                  ]
                },
                "hasRelation": {
                  "type": "boolean",
                  "example": false,
                  "description": "If `true`, contact has a related contact."
                },
                "transactions": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/transactions/items"
                  },
                  "description": "Information associated with the transactions associated with the contact\n"
                },
                "buyerAgent": {
                  "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender",
                  "description": "User Information associated with the buyer agent"
                },
                "listingAgent": {
                  "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender",
                  "description": "User Information associated with the listing agent"
                },
                "lender": {
                  "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender",
                  "description": "User Information associated with the lender"
                }
              }
            },
            "description": "Contacts that match the search and the user has access to."
          },
          "orgContacts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "networkId": {
                  "type": "number",
                  "format": "int64",
                  "description": "The network id that this organization belongs to."
                },
                "orgId": {
                  "type": "number",
                  "format": "int64",
                  "readOnly": true,
                  "description": "The organization owning the contact record. Value set by BoomTown."
                },
                "contactId": {
                  "type": "number",
                  "format": "int64",
                  "description": "The contact id associated with the record",
                  "example": 454
                },
                "firstName": {
                  "type": "string",
                  "description": "First name of the contact.",
                  "example": "Bob"
                },
                "lastName": {
                  "type": "string",
                  "description": "Last name of the contact.",
                  "example": "User"
                },
                "hasRelation": {
                  "type": "boolean",
                  "description": "If `true`, contact has a related contact.",
                  "example": false
                },
                "buyerAgent": {
                  "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender",
                  "description": "User Information associated with the buyer agent"
                },
                "listingAgent": {
                  "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender",
                  "description": "User Information associated with the listing agent"
                },
                "lender": {
                  "$ref": "#/components/schemas/Visable_Text_Search_Contact/properties/lender",
                  "description": "User Information associated with the lender"
                }
              }
            },
            "description": "Contacts that match the search in the user's organization but the\ncurrent user does not have access to.\n"
          }
        }
      },
      "Full_Email": {
        "type": "object",
        "properties": {
          "body": {
            "type": "string",
            "example": "Hey John, I am in the market for a new home.  Please let me know what\nis available.  Thanks, Rick\n",
            "description": "Content of the email."
          },
          "bodyThreadText": {
            "type": "string",
            "example": "Hey Bill, What can I help you with?  Thanks, John\n",
            "description": "Content from previous replies starting with the original email."
          },
          "headers": {
            "type": "string",
            "example": "From: Rick Ricky (Rick.Ricky@someEmail.com) Subject: RE: Looking for\na home Date: January 25, 2011 3:30:58 PM PDT To: BillSmith@BoomTownROI.com ...\n",
            "description": "Header information that identifies routing information including\nsender, recipient, date and subject.\n"
          },
          "cc": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "BillSmith@BoomTownROI.com",
            "description": "A list of emails that received a duplicate copy the email."
          },
          "bcc": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": "TedSmith@BoomTownROI.com",
            "description": "A list of emails that privately received a duplicate copy of the email."
          }
        },
        "description": "These attributes are appended to the email object when retrieving a full email by id.\n"
      },
      "Email_Send_Body": {
        "type": "object",
        "properties": {
          "senderId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "description": "The user sending the email. This may be different than the current user."
          },
          "emailAddressId": {
            "type": "number",
            "format": "int64",
            "example": 2422,
            "description": "The destination email address."
          },
          "threadId": {
            "type": "string",
            "format": "UUID",
            "example": "123e4567-e89b-12d3-a456-426655440000",
            "description": "The identifier for the conversation thread. Will be generated if not replying to an existing conversation.\n"
          },
          "subject": {
            "type": "string",
            "example": "RE: Looking for a home",
            "description": "Subject line of the email."
          },
          "body": {
            "type": "string",
            "example": "Hey John, I am in the market for a new home.  Please let me know what\n",
            "description": "Brief version of the email body with formatting removed."
          },
          "cc": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "BillSmith@BoomTownROI.com"
            ],
            "description": "A list of emails that received a duplicate copy the email."
          },
          "bcc": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "TedSmith@BoomTownROI.com"
            ],
            "description": "A list of emails that privately received a duplicate copy of the email.\n"
          },
          "fileAttachments": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "integer"
            },
            "description": "If set to true, the email had attachments.",
            "example": [
              1234,
              2345
            ]
          },
          "templateId": {
            "type": "number",
            "format": "int64",
            "example": 3,
            "description": "The id of the email template used, if one was used."
          },
          "copyAgentBroker": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the agent or broker was copied on the email."
          },
          "copyLender": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the lender was copied on the email."
          }
        },
        "required": [
          "senderId",
          "emailAddressId",
          "subject",
          "body"
        ]
      }
    },
    "parameters": {
      "contactIdParam": {
        "name": "contactId",
        "in": "path",
        "description": "ID of contact",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "associatedUserIdParam": {
        "name": "associatedUserId",
