  "servers": [
    {
      "url": "https://api.boomtownroi.com/X1"
    }
  ],
  "components": {
    "securitySchemes": {
      "Access-Token": {
        "type": "apiKey",
        "in": "header",
        "name": "Access-Token",
        "description": "The access key created via oauth or user login"
      },
      "Api-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "This api key is the sha256 hash of your `client_id` and `client_secret`"
      }
    },
    "schemas": {
      "AccessToken": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "1/fFAGRNJru1FTz70BzhT3Zg",
            "description": "The token that can be sent to the API."
          },
          "expires_in": {
            "type": "number",
            "example": 3920,
            "description": "The remaining lifetime of the access token."
          },
          "token_type": {
            "type": "string",
            "example": "Bearer",
            "description": "Always set to bearer."
          }
        }
      },
      "RefreshToken": {
        "type": "object",
        "properties": {
          "refresh_token": {
            "type": "string",
            "example": "6c96220b-07d3-4c83-afa6-0fbabf867e1c",
            "description": "A renewable token that can be used to fetch access tokens"
          },
          "access_token": {
            "type": "string",
            "example": "1/fFAGRNJru1FTz70BzhT3Zg",
            "description": "The token that can be sent to the API."
          },
          "expires_in": {
            "type": "number",
            "example": 3920,
            "description": "The remaining lifetime of the access token."
          },
          "token_type": {
            "type": "string",
            "example": "Bearer",
            "description": "Always set to bearer."
          }
        }
      },
      "Authentication": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "The access token to be used with all future requests.",
            "example": "WjA0jrjfQ808fQaqqKTWXdCRN36saa6c0OKZkoWKgjbvgaMHHidTZGYFwziMcQoq"
          },
          "userId": {
            "type": "number",
            "format": "int64",
            "description": "The ID of the user making the request.",
            "example": 123
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "description": "The parent organization of the user.",
            "example": null
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "A list of the user's role(s). See User Roles for more information.",
            "example": [
              "AGENT"
            ]
          },
          "appId": {
            "type": "string",
            "format": "UUID",
            "description": "The ID of the application making the request for the user.",
            "example": "7b3a5e45-b714-41e4-a2f1-a22d75ad0eeb"
          },
          "id": {
            "type": "string",
            "description": "Same as access_token.",
            "example": "WjA0jrjfQ808fQaqqKTWXdCRN36saa6c0OKZkoWKgjbvgaMHHidTZGYFwziMcQoq"
          },
          "ttl": {
            "type": "number",
            "description": "Time in seconds for token to remain valid.",
            "example": 1209600
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "ISO string of date token created.",
            "example": "2015-07-21T16:05:38.788Z"
          }
        },
        "description": "The authentication object contains a valid token used for additional requests during a user session. It is returned with a successful login, or when verifying or renewing a session.\n"
      },
      "GrantCode": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "example": "9541cbd4-0477-4b42-a49a-472d846d6bc2"
          },
          "tokenType": {
            "type": "string",
            "enum": [
              "admin",
              "user"
            ]
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "example": 11,
            "description": "Only provided when the `tokenType` is `admin`."
          },
          "scope": {
            "type": "string",
            "example": "all"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 3532,
            "readOnly": true,
            "description": "Primary identifier for the contact. Value set by BoomTown."
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "example": 23,
            "readOnly": true,
            "description": "The organization owning the contact record. Value set by BoomTown."
          },
          "firstName": {
            "type": "string",
            "example": "John",
            "description": "First name of the contact."
          },
          "lastName": {
            "type": "string",
            "example": "Smith",
            "description": "Last name of the contact."
          },
          "visitorId": {
            "type": "number",
            "format": "int64",
            "example": 35426,
            "description": "The linked Visitor ID for the contact. Attribute exists if the contact\nis a web visitor. Visitor functionality will be available in Boomtown API V2.\n"
          },
          "sourceId": {
            "type": "string",
            "example": "OPENHOUSE",
            "description": "How the contact is connected to the organization.  Set based on how\nthe contact was directed to website, or manually entered by agent. See Get all\nsources endpoint for accepted values. \n"
          },
          "sourceName": {
            "type": "string",
            "example": "Open House",
            "readOnly": true,
            "description": "Displayable name for the source set in sourceId. Value set by BoomTown."
          },
          "contactBy": {
            "type": "string",
            "enum": [
              "phone",
              "email"
            ],
            "example": "Text",
            "description": "Best way to reach the contact. Allowed values: `phone``email`"
          },
          "description": {
            "type": "string",
            "example": "Looking to buy 3 bed 2.5bath house downtown.",
            "description": "Notes shared by agents, brokers and lenders."
          },
          "ownershipStatus": {
            "type": "string",
            "description": "Indicates if the contact owns or rents property. \n"
          },
          "communicationPreferences": {
            "type": "object",
            "properties": {
              "phoneStatus": {
                "type": "string",
                "enum": [
                  "unknown",
                  "active",
                  "valid",
                  "optedOut",
                  "wrongNumber"
                ],
                "readOnly": true,
                "example": "unknown",
                "description": "Read-only aggregate over all of the contact's phone numbers to determine\nif they can be contacted by phone. This status reflects any changes to the\ncontact's phoneNumber records. \n"
              },
              "emailAddressStatus": {
                "type": "string",
                "enum": [
                  "unknown",
                  "twoWayEmailing",
                  "validAddress",
                  "invalidAddress",
                  "optedOut"
                ],
                "readOnly": true,
                "example": "unknown",
                "description": "Read-only aggregate over all of the contact's emailAddresses to determine\nif they can be contacted by email. This status reflects changes to the contact's\nemailAddress records. Allowed values:\n- `unknown`(default)\n- `twoWayEmailing`: has been used in communication\n- `validAddress`\n- `optedOut`: contact who has globally opted out or opted out of agent or lender communications\n- `invalidAddress`\n"
              },
              "eAlertStatus": {
                "type": "string",
                "enum": [
                  "Active",
                  "AgentUnsubscribed",
                  "ContactUnsubscribed"
                ],
                "example": "Active",
                "description": "Controls the contact's ability to receive email alerts. Defaults to active.\n"
              }
            },
            "description": "The communicationPreferences object looks up and stores a contact\u2019s status for receiving calls, texts, emails, and automated email alerts (eAlerts) on saved searches.\n"
          },
          "physicalAddresses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "contactAddressId": {
                  "type": "number",
                  "format": "int64",
                  "example": 456,
                  "readOnly": true,
                  "description": "Primary identifier. Value set by BoomTown."
                },
                "contactId": {
                  "type": "number",
                  "format": "int64",
                  "example": 123,
                  "readOnly": true,
                  "description": "The contact associated with the address. Value set by BoomTown."
                },
                "address": {
                  "type": "string",
                  "example": "635 Rutledge Avenue",
                  "description": "Street number and name. May include apt, suite, or other."
                },
                "city": {
                  "type": "string",
                  "example": "Charleston",
                  "description": "City"
                },
                "state": {
                  "type": "string",
                  "example": "SC",
                  "description": "State (US), Province (Canada)."
                },
                "zipCode": {
                  "type": "string",
                  "example": "29403",
                  "description": "Zip code (US), Postal code (Canada)."
                },
                "addressChangedByUserId": {
                  "type": "number",
                  "format": "int64",
                  "example": 789,
                  "readOnly": true,
                  "description": "User who last updated the physical address (modified by the contact via visitor or by a CRM user). Value set by BoomTown."
                },
                "addressEntryType": {
                  "type": "string",
                  "enum": [
                    "notSpecified",
                    "systemIPCalc",
                    "contactEntered",
                    "agentEntered",
                    "lenderEntered",
                    "adminEntered"
                  ],
                  "example": "agentEntered",
                  "description": "How the address was entered. <br>Allowed values: \n- `notSpecified`(default) \n- `systemIPCalc`\n- `contactEntered`\n- `agentEntered`\n- `lenderEntered`\n- `adminEntered`\n"
                },
                "addressType": {
                  "type": "string",
                  "enum": [
                    "NotSpecified",
                    "Home",
                    "MailAddress",
                    "Office"
                  ],
                  "description": "Disabled, Future release. Allowed values:  `Home` `Office` `NotSpecified``MailAddress`"
                },
                "description": {
                  "type": "string",
                  "description": "Disabled, Future release. Optional description for the address."
                },
                "dateCreated": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time the address was created. Value set by BoomTown."
                },
                "dateModified": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time when the address was last changed. Value set by BoomTown."
                }
              },
              "description": "The address object contains details of a contact\u2019s physical address.\n",
              "required": [
                "contactAddressId",
                "contactId",
                "addressEntryType",
                "dateCreated",
                "dateModified"
              ]
            },
            "description": "Physical addresses for the contact."
          },
          "emailAddresses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "emailAddressId": {
                  "type": "number",
                  "format": "int64",
                  "example": 123,
                  "readOnly": true,
                  "description": "The primary identifier for the email address. Value set by BoomTown.\n"
                },
                "emailAddress": {
                  "type": "string",
                  "example": "JohnSmith@BoomTownROI.com",
                  "description": "The email address."
                },
                "isLogin": {
                  "type": "boolean",
                  "example": true,
                  "description": "If set to `true`, this email is used to login. Defaults to `true` if\nthere are no other emails for the contact.\n"
                },
                "isPrimary": {
                  "type": "boolean",
                  "example": true,
                  "description": "If set to `true`, send all emails to this address. Defaults to `true`\nif no other email addresses exist for the contact.\n"
                },
                "description": {
                  "type": "string",
                  "example": null,
                  "description": "A brief note about the email address."
                },
                "emailAddressStatus": {
                  "type": "string",
                  "enum": [
                    "unknown",
                    "validAddress",
                    "invalidAddress",
                    "twoWayEmailing",
                    "optedOut"
                  ],
                  "example": "unknown",
                  "description": "The status of the email address. \n\n- Defaults to `unknown`(default)\n- `twoWayEmailing`: has been used in communication\n- `optedOut`: contact has requested no contact via email\n"
                },
                "contactId": {
                  "type": "number",
                  "format": "int64",
                  "example": 123,
                  "readOnly": true,
                  "description": "Contact identifier for the contact who owns the email address. Value\nset by BoomTown.\n"
                },
                "dateCreated": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time the email address was created. Value set by BoomTown."
                },
                "dateModified": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time when the email address was last changed. Value set by BoomTown."
                }
              },
              "description": "The email address object contains information about a specific email address, including whether it is being used for login, or if is the best email to use for the contact. It also includes a current status showing if the email is known to be valid, if the contact has opted-out at this address, or has been used in recent communications.\n",
              "required": [
                "emailAddressId",
                "emailAddress",
                "contactId",
                "dateCreated"
              ]
            },
            "description": "Email addresses for the contact."
          },
          "phoneNumbers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phoneNumberId": {
                  "type": "number",
                  "format": "int64",
                  "example": 456,
                  "readOnly": true,
                  "description": "The primary identifier for the phone number. Value set by BoomTown.\n"
                },
                "label": {
                  "type": "string",
                  "example": "phone number for contact",
                  "description": "Descriptive label for the phone number (\"Work\", \"Cell\", etc...).\nDefaults to an empty string.\n"
                },
                "phoneNumber": {
                  "type": "string",
                  "example": "123-456-7890",
                  "description": "The phone number for the contact."
                },
                "phoneStatus": {
                  "type": "string",
                  "enum": [
                    "unknown",
                    "active",
                    "valid",
                    "optedOut",
                    "wrongNumber"
                  ],
                  "example": "active",
                  "description": "'The status of the phone number. \n"
                },
                "contactId": {
                  "type": "number",
                  "format": "int64",
                  "example": 123,
                  "readOnly": true,
                  "description": "The identifier for the contact which is associated with the phone\nnumber. Value set by BoomTown.\n"
                },
                "phoneType": {
                  "type": "string",
                  "enum": [
                    "mobile",
                    "landline",
                    "voip",
                    "other"
                  ],
                  "example": "mobile",
                  "description": "'The type of the phone.\n"
                },
                "dateCreated": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time the phone number was created. Value set by BoomTown.\n"
                },
                "dateModified": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time when the phone number was last changed. Value set by BoomTown.\n"
                }
              },
              "description": "A phone number object contains a description and status for each phone number.\n",
              "required": [
                "phoneNumberId",
                "phoneNumber",
                "contactId",
                "dateCreated",
                "dateModified"
              ]
            },
            "description": "Phone numbers for the contact."
          },
          "associatedUsers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "associatedUserId": {
                  "type": "number",
                  "format": "int64",
                  "example": 1233,
                  "readOnly": true,
                  "description": "Primary identifier for the associated user relationship. Value set by BoomTown.\n"
                },
                "contactId": {
                  "type": "number",
                  "format": "int64",
                  "example": 33,
                  "description": "Primary identifier for the contact."
                },
                "userId": {
                  "type": "number",
                  "format": "int64",
                  "example": 3438,
                  "description": "User associated with the contact."
                },
                "contactCategory": {
                  "type": "string",
                  "enum": [
                    "new",
                    "trash",
                    "watch",
                    "qualify",
                    "nurture",
                    "hot",
                    "archive",
                    "closed",
                    "pending"
                  ],
                  "example": "nurture",
                  "description": "Status of the contact associated with the user. Allowed values:\n- `new`\n- `trash`: using another agent\n- `watch`: just looking, no timeframe\n- `qualify`: new and unqualified\n- `nurture`: more than 3 months out\n- `hot: working towards a deal\n- `archive`: archive contact for later\n- `closed`: deal closed\n- `pending`: contact pending\n"
                },
                "categoryDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-26T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time the contact category was assigned. Value set by BoomTown."
                },
                "assignedDate": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-26T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time the contact was assigned. Value set by BoomTown."
                },
                "communicationStatus": {
                  "type": "string",
                  "enum": [
                    "active",
                    "agentUnsubscribed",
                    "contactUnsubscribed",
                    "lenderUnsubscribed"
                  ],
                  "example": "active",
                  "description": "If communication is allowed with the contact; and if not, who unsubsribed\nthem. Allowed values: `active` (default), `agentUnsubscribed`, `lenderUnsubscribed`,`contactUnsubscribed`\n"
                },
                "associatedUserType": {
                  "type": "string",
                  "enum": [
                    "buyerAgent",
                    "lender",
                    "sellerAgent"
                  ],
                  "example": "buyerAgent",
                  "description": "The role of the user in this relationship. Allowed values:`buyerAgent`,`lender`,`sellerAgent`"
                },
                "dateCreated": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time the associated user was created. Value set by BoomTown."
                },
                "dateModified": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2016-01-27T14:45:14.703Z",
                  "readOnly": true,
                  "description": "Time when the associated user was last changed. Value set by BoomTown."
                }
              },
              "description": "An associated user object categorizes the user\u2019s relationship and communication status with the contact.\n",
              "required": [
                "associatedUserId",
                "contactId",
                "userId",
                "associatedUserType",
                "dateCreated",
                "dateModified"
              ]
            },
            "description": "Users assigned to the contact."
          },
          "socialProfiles": {
            "type": "object",
            "properties": {
              "contactId": {
                "type": "number",
                "format": "int64",
                "readOnly": true,
                "description": "Unique identifier for the contact. Value set by BoomTown.",
                "example": 4336
              },
              "primaryPhotoUrl": {
                "type": "string",
                "description": "The primary photo for the contact in BoomTown.",
                "example": null
              },
              "socialAccounts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "profilePhotoUrl": {
                      "type": "string",
                      "description": "Url to the user's main social photo."
                    },
                    "profileUrl": {
                      "type": "string",
                      "example": "https://www.facebook.com/JohnSmith12",
                      "description": "Url to the user's profile."
                    },
                    "socialProfileType": {
                      "type": "string",
                      "enum": [
                        "facebook",
                        "googlePlus",
                        "linkedIn",
                        "twitter"
                      ],
                      "example": "facebook",
                      "description": "The type of profile. <br>Allowed values: `facebook`,`googlePlus`,`linkedIn`,`twitter`\n"
                    },
                    "dateCreated": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-15T16:51:08.530Z",
                      "description": "Time the social account was added."
                    },
                    "dateModified": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-15T16:51:08.530Z",
                      "description": "Time the social account information was last modified."
                    }
                  },
                  "description": "The social account object contains information on a single social media account.\n",
                  "required": [
                    "socialProfileType"
                  ]
                },
                "description": "A series of Social Accounts."
              },
              "dateCreated": {
                "type": "string",
                "format": "date-time",
                "readOnly": true,
                "description": "Time the social profile was created. Value set by BoomTown.",
                "example": "2016-01-15T16:51:08.530Z"
              },
              "dateModified": {
                "type": "string",
                "format": "date-time",
                "readOnly": true,
                "description": "Time when the social profile was last changed. Value set by BoomTown.",
                "example": "2016-01-15T16:51:08.530Z"
              }
            },
            "description": "The social profile object contains a list of social media accounts for the contact.\n",
            "required": [
              "contactId",
              "socialAccounts",
              "dateCreated",
              "dateModified"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tagId": {
                  "type": "number",
                  "format": "int64",
                  "example": 4234,
                  "description": "The primary identifier for a tag. Value set by BoomTown."
                },
                "orgId": {
                  "type": "number",
                  "format": "int64",
                  "example": 25,
                  "readOnly": true,
                  "description": "Primary identifier of the organization which created the tag or the\norganization of the User who created the tag. Value set by BoomTown.\n"
                },
                "userId": {
                  "type": "number",
                  "format": "int64",
                  "example": 4543,
                  "readOnly": true,
                  "description": "Primary identifier of the user who created the tag. Value set by BoomTown.\n"
                },
                "tagName": {
                  "type": "string",
                  "example": "New Buyer",
                  "readOnly": true,
                  "description": "Short description of the tag. For example, \"Qualified Buyer\", \"Buying\nSoon\", etc. \n"
                },
                "tagOwner": {
                  "type": "string",
                  "enum": [
                    "user",
                    "org"
                  ],
                  "example": "org",
                  "readOnly": true,
                  "description": "Determines the level of access.<br>Allowed values:\n- `user`: private to user.  \n- `org` - available to anyone in the organization.\n"
                },
                "dateCreated": {
                  "type": "string",
                  "format": "date-time",
                  "readOnly": true,
                  "description": "Time the tag was created. Value set by BoomTown."
                },
                "dateModified": {
                  "type": "string",
                  "format": "date-time",
                  "readOnly": true,
                  "description": "Time when the tag was last changed. Value set by BoomTown."
                }
              },
              "description": "A tag object contains the tag label, and all ownership information for the tag which defines who is allowed to use the tag (e.g., user only, or all users in an organization).\n",
              "required": [
                "tagId",
                "tagName",
                "tagOwner",
                "dateCreated",
                "dateModified"
              ]
            },
            "description": "Tags assigned to the contact."
          },
          "relatedContact": {
            "type": "object",
            "properties": {
              "contactId": {
                "type": "number",
                "example": 3532,
                "readOnly": true,
                "description": "Primary identifier for the contact. Value set by BoomTown. \n"
              },
              "orgId": {
                "type": "number",
                "example": 23,
                "description": "The organization that owns the contact record.\n"
              },
              "visitorId": {
                "type": "number",
                "example": 35426,
                "description": "The linked Visitor ID for the contact. Attribute exists if the contact\nis a web visitor. Visitor functionality will be available in Boomtown API V2.\n"
              },
              "associatedUsers": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Contact/properties/associatedUsers/items"
                },
                "description": "The associated users assigned to this contact\n"
              },
              "firstName": {
                "type": "string",
                "example": "John",
                "description": "First name of the contact."
              },
              "lastName": {
                "type": "string",
                "example": "Smith",
                "description": "Last name of the contact."
              },
              "sourceName": {
                "type": "string",
                "example": "Open House",
                "description": "How the contact is connected to the organization. Set based on how\nthe contact was directed to website, or manually entered by agent.\n"
              },
              "phoneNumber": {
                "type": "string",
                "example": "123-555-1212",
                "description": "Primary phone for the contact. Available based on contact's communication\npreferences.\n"
              },
              "emailAddress": {
                "type": "string",
                "description": "Primary email address for the contact. Available based on contact's\ncommunication preferences.\n"
              },
              "defaultPhotoUrl": {
                "type": "string",
                "description": "Default photo for the contact profile."
              },
              "dateCreated": {
                "type": "string",
                "format": "date-time",
                "example": "2016-01-27T14:45:14.703Z",
                "readOnly": true,
                "description": "Time the contact record was created. Value set by BoomTown."
              },
              "dateModified": {
                "type": "string",
                "format": "date-time",
                "example": "2016-01-27T14:45:14.703Z",
                "readOnly": true,
                "description": "Time when the contact record was last changed. Value set by BoomTown.\n"
              }
            },
            "description": "The small contact object contains a basic set of contact information which can be access by appending the query parameter ?size=small.\n",
            "required": [
              "contactId",
              "orgId",
              "dateCreated",
              "dateModified"
            ]
          },
          "contactOriginType": {
            "type": "string",
            "enum": [
              "WebRegistered",
              "ManuallyAdded",
              "ThirdPartyImport",
              "AdminImport",
              "ApiImport",
              "ApiBulkImport"
            ],
            "example": "ApiBulkImport",
            "description": "This status reflects where the contact originated. Allowed values:\n- `WebRegistered`\n- `ManuallyAdded`\n- `ThirdPartyImport`\n- `AdminImport`\n- `ApiImport`\n- `ApiBulkImport`\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the record was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the record or a child record was last changed. Value set by BoomTown."
          }
        },
        "description": "A contact object contains detailed information about a person including physical address, emails and phone numbers. Contacts \u201cbelong to\u201d only one organization, but may have multiple users associated to them.\n",
        "required": [
          "contactId",
          "orgId",
          "firstName",
          "lastName",
          "sourceId",
          "tags",
          "dateCreated",
          "dateModified"
        ]
      },
      "Small_Contact": {
