          "originalPrice": {
            "type": "integer",
            "description": "The original negotiated price of the property. Stored as a whole number with two decimal places.",
            "format": "int64",
            "nullable": true,
            "example": 55000000
          },
          "price": {
            "type": "integer",
            "description": "The negotiated sales price of the property. Stored as a whole number with two decimal places.",
            "format": "int64",
            "nullable": true,
            "example": 52500000
          },
          "commission": {
            "$ref": "#/components/schemas/Commission"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "pending": {
            "type": "boolean",
            "description": "Used to determine whether to create a regular or incoming transaction",
            "nullable": true,
            "example": true
          },
          "dateCreated": {
            "type": "string",
            "description": "The date the transaction was created",
            "format": "date-time",
            "example": "2020-01-10T12:34:48"
          },
          "dateModified": {
            "type": "string",
            "description": "The last date the transaction was modified",
            "format": "date-time",
            "example": "2020-01-10T12:34:48"
          }
        },
        "additionalProperties": false
      },
      "TransactionMetadata": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "The Total Number of Transactions in the results",
            "format": "int32",
            "example": 20
          },
          "offset": {
            "type": "integer",
            "description": "The current page of transactions being viewed",
            "format": "int32",
            "example": 10
          },
          "links": {
            "$ref": "#/components/schemas/Links"
          },
          "type": {
            "type": "string",
            "description": "The type of result?",
            "nullable": true,
            "readOnly": true,
            "example": "[transaction]"
          },
          "url": {
            "type": "string",
            "description": "The current results URL",
            "nullable": true,
            "example": "/organizations/2/transactions"
          }
        },
        "additionalProperties": false
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string",
            "description": "Primary identifier for this transaction Value set by BoomTown.",
            "nullable": true,
            "example": "0F696528-176C-47E0-87D3-72F402C4A95B"
          },
          "contactId": {
            "type": "integer",
            "description": "Identifier for the contact attached to this transaction.",
            "format": "int64",
            "example": 11343
          },
          "agentIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Identifies the agents attached to this transaction.",
            "nullable": true,
            "example": [
              11,
              1234
            ]
          },
          "primaryAgentId": {
            "type": "integer",
            "description": "Identifies the primary agent on this transaction.",
            "format": "int64",
            "nullable": true,
            "example": 11
          },
          "type": {
            "$ref": "#/components/schemas/TransactionType"
          },
          "status": {
            "$ref": "#/components/schemas/TransactionStatus"
          },
          "activeListingId": {
            "type": "string",
            "description": "The BoomTown listingId for the on-market listing associated with this transaction",
            "nullable": true,
            "example": "134381"
          },
          "soldListingId": {
            "type": "string",
            "description": "The BoomTown listingId for the sold data listing record associated with this transaction",
            "nullable": true,
            "example": "248204"
          },
          "listDate": {
            "type": "string",
            "description": "The date the listing associated with this transactions went on the market.",
            "format": "date-time",
            "nullable": true,
            "example": "2020-01-10T12:34:48"
          },
          "expirationDate": {
            "type": "string",
            "description": "The date the contract between the buyer and seller expires (if not closed).",
            "format": "date-time",
            "nullable": true,
            "example": "2020-11-10T12:34:48"
          },
          "acceptanceDate": {
            "type": "string",
            "description": "The date the seller accepted the buyer's offer.",
            "format": "date-time",
            "nullable": true,
            "example": "2020-02-10T12:34:48"
          },
          "closingDate": {
            "type": "string",
            "description": "The date the transaction is set to close.",
            "format": "date-time",
            "nullable": true,
            "example": "2020-03-10T12:34:48"
          },
          "originalPrice": {
            "type": "integer",
            "description": "The original negotiated price of the property. Stored as a whole number with two decimal places.",
            "format": "int64",
            "nullable": true,
            "example": 55000000
          },
          "price": {
            "type": "integer",
            "description": "The negotiated sales price of the property. Stored as a whole number with two decimal places.",
            "format": "int64",
            "nullable": true,
            "example": 52500000
          },
          "commission": {
            "$ref": "#/components/schemas/Commission"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "pending": {
            "type": "boolean",
            "description": "Used to determine whether to create a regular or incoming transaction",
            "nullable": true,
            "example": true
          },
          "dateCreated": {
            "type": "string",
            "description": "The date the transaction was created",
            "format": "date-time",
            "example": "2020-01-10T12:34:48"
          },
          "dateModified": {
            "type": "string",
            "description": "The last date the transaction was modified",
            "format": "date-time",
            "example": "2020-01-10T12:34:48"
          }
        },
        "additionalProperties": false
      },
      "TransactionSearchResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransactionIntegrationsResponse"
            },
            "description": "The list of transactions that meet the filter.",
            "nullable": true
          },
          "metadata": {
            "$ref": "#/components/schemas/TransactionMetadata"
          }
        },
        "additionalProperties": false
      },
      "TransactionStatus": {
        "enum": [
          "preListing",
          "activeListing",
          "underContract",
          "closed",
          "abandoned",
          "preContract"
        ],
        "type": "string"
      },
      "TransactionType": {
        "enum": [
          "buyer",
          "seller"
        ],
        "type": "string"
      },
      "UnclaimedListingMetaData": {
        "type": "object",
        "properties": {
          "listingPhotoUrl": {
            "type": "string",
            "description": "URL to the photo",
            "nullable": true,
            "example": "www.exampleimage.com"
          },
          "listingMLS": {
            "type": "string",
            "description": "The MLS ID for the Listing",
            "nullable": true,
            "example": "0F696528"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "listingId": {
            "type": "string",
            "nullable": true
          },
          "transactionType": {
            "$ref": "#/components/schemas/TransactionType"
          },
          "isBuyerSide": {
            "type": "boolean"
          },
          "soldDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "soldPrice": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "userId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UnclaimedResponse": {
        "type": "object",
        "properties": {
          "totalPotentialGrossSales": {
            "type": "integer",
            "description": "Total potential gross sales of sold unclaimed listings",
            "format": "int32",
            "example": 5000000
          },
          "totalPotentialCount": {
            "type": "integer",
            "description": "Total potential count of sold unclaimed listings",
            "format": "int32",
            "example": 200
          },
          "listings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UnclaimedListingMetaData"
            },
            "description": "List of listing data",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateIntegrationRequest": {
        "type": "object",
        "properties": {
          "createdById": {
            "type": "integer",
            "description": "The userId of the person who update the integration. Value set by BoomTown.",
            "format": "int64",
            "nullable": true,
            "example": 11
          },
          "vendorId": {
            "type": "string",
            "description": "Id that uniquely identifies the integration in the 3rd party integration's system.",
            "nullable": true,
            "example": "134"
          },
          "templateId": {
            "type": "string",
            "description": "The 3rd party integration template Id, Will be null if Id does not exist. Value set by 3rd Party and passed through by client.",
            "nullable": true,
            "example": "41553"
          }
        },
        "additionalProperties": false
      },
      "UpdateTransactionRequest": {
        "type": "object",
        "properties": {
          "contactId": {
            "type": "integer",
            "description": "ID of contact",
            "format": "int64",
            "example": 14538
          },
          "transactionId": {
            "type": "string",
            "description": "ID of the transaction",
            "nullable": true,
            "example": "0F696528-176C-47E0-87D3-72F402C4A95B"
          },
          "agentIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Identifies the agents attached to this transaction",
            "nullable": true,
            "example": [
              11,
              1234
            ]
          },
          "primaryAgentId": {
            "$ref": "#/components/schemas/Int64NullableOptional"
          },
          "type": {
            "$ref": "#/components/schemas/TransactionType"
          },
          "status": {
            "$ref": "#/components/schemas/TransactionStatus"
          },
          "activeListingId": {
            "$ref": "#/components/schemas/StringOptional"
          },
          "soldListingId": {
            "$ref": "#/components/schemas/StringOptional"
          },
          "listDate": {
            "$ref": "#/components/schemas/DateTimeNullableOptional"
          },
          "expirationDate": {
            "$ref": "#/components/schemas/DateTimeNullableOptional"
          },
          "acceptanceDate": {
            "$ref": "#/components/schemas/DateTimeNullableOptional"
          },
          "closingDate": {
            "$ref": "#/components/schemas/DateTimeNullableOptional"
          },
          "price": {
            "$ref": "#/components/schemas/Int64NullableOptional"
          },
          "commission": {
            "$ref": "#/components/schemas/OptionalCommissionRequest"
          },
          "address": {
            "$ref": "#/components/schemas/OptionalAddressRequest"
          },
