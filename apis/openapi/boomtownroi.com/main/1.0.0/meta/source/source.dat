        ],
        "summary": "Update a contact",
        "description": "Partially update information for a single contact.\n\n**WARNING** \u2014 Complex attributes, such as objects or arrays, are fully replaced if included in this request. For example, updating contact\u2019s `emailAddresses`, `socialProfiles` or any other array/object type attributes, requires you to include both updated AND unchanged values; as any pre-existing unspecified values are deleted.\n",
        "operationId": "updateContact",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          }
        ],
        "responses": {
          "default": {
            "description": "Returns an object containing the updated contact record and the status of the request. If the request is not fully completed, the response contains a list of errors. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.\n",
