    "/contacts/sources": {
      "get": {
        "x-boomtown-external": true,
        "tags": [
          "Sources"
        ],
        "summary": "Get all sources",
        "description": "Retrieve lead sources.",
        "operationId": "getLeadSources",
        "parameters": [
          {
            "name": "userSelectable",
            "in": "query",
            "required": false,
            "description": "Set to `true` to get sources that may be manually selected by a user.\n",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "An array of all possible new lead sources including metadata. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Source"
                  }
                },
                "examples": {
                  "response": {
                    "value": [
                      {
                        "sourceId": "AGENTREFERRAL",
                        "name": "Agent Referral",
                        "dateCreated": "2016-01-27T14:45:14.703Z",
                        "dateModified": "2016-01-27T14:45:14.703Z"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/{userId}/templates/emails": {
      "get": {
        "x-boomtown-external": true,
        "tags": [
          "Email Templates"
        ],
        "summary": "Get email templates",
        "description": "Retrieve all email templates for a particular user (as specified by the ID in the URL), as well as all the email templates for the user\u2019s Organization. See /organizations/:orgId/templates/emails to retrieve Organization email templates only.\n",
        "operationId": "getEmailTemplates",
        "parameters": [
          {
            "$ref": "#/components/parameters/userIdParam"
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "description": "Complies with Paging defaults *(See Request Filtering: Paging)*.\n",
            "schema": {
              "type": "integer",
              "maximum": 250,
              "default": 50
            }
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "description": "Complies with Paging defaults *(See Request Filtering: Paging)*.\n",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "orderby",
            "in": "query",
            "description": "Applies to `templateId`, `title`, `dateCreated`, `dateModified`.\n\nDefault ordering is by template title ascending. Specify the ordered parameter(s) followed by the direction&#58; ascending (ASC) or descending (DESC). See *Request Filtering: Ordering (in API Standards)*..\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "where",
            "in": "query",
            "description": "Applies to `communicationType`, `dateCreated`, `dateModified`.\n\nSpecify the where parameter followed by the property name and value pair, and optional operation. See *Request Filtering&#58; Selecting (in API Standards)*\n",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns an array of email template objects, including metadata. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Email_Template"
                  }
                },
                "examples": {
                  "response": {
                    "value": [
                      {
                        "templateId": 123,
                        "body": "Hello {VisitorName}. This is {AgentFirstName} {AgentLastName} with {CompanyName}.",
                        "subject": "string",
                        "title": "Visitor Greeting Number 1",
                        "type": "user",
                        "dateCreated": "2016-12-13 11:27:30.937",
                        "dateModified": "2016-12-15 13:01:27.012"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
