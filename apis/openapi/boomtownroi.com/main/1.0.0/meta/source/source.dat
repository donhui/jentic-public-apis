  "paths": {
    "/oauth2/grant/code": {
      "post": {
        "x-boomtown-external-only": true,
        "security": [
          {
            "Api-Key": []
          },
          {
            "Access-Token": []
          }
        ],
        "tags": [
          "oauth"
        ],
        "summary": "Grant an access token for a particular user. Requires admin permissions.",
        "description": "Grant an access token for a particular user. Requires an access token with `BoomAdmin` level permissions.",
        "operationId": "grantCode",
        "responses": {
          "default": {
            "description": "Returns an authorization code. The authorization code is a one time use code that is valid for five minutes.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string"
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "code": "67bf1c5d-0071-4d76-9cd8-ecbde7d369a4"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GrantCode"
              }
            }
          },
          "description": "A request to grant a code for a particular user"
        }
      }
    },
    "/oauth2/token": {
      "post": {
        "x-boomtown-external-only": true,
        "tags": [
          "oauth"
        ],
        "summary": "Refresh token request",
        "description": "Refresh token request",
        "operationId": "refreshToken",
        "responses": {
          "default": {
            "description": "Returns an object that contains the access token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessToken"
                },
                "examples": {
                  "response": {
                    "value": {
                      "access_token": "500c10c4-2c8b-4dc0-908c-a18203799373",
                      "expires_in": "3920,",
                      "token_type": "Bearer"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refresh_token": {
                    "type": "string",
                    "example": "84a36f4e-0736-4daf-af51-964e0b5d7b52",
                    "description": "The refresh token returned from the authorization code exchange."
                  },
                  "client_id": {
                    "type": "string",
                    "example": "f5308489-13d8-4056-a363-8cca168439c7",
                    "description": "Your client_id."
                  },
                  "client_secret": {
                    "type": "string",
                    "example": "7b9f29ed-bf53-445d-ae8c-4dc1289ad269",
                    "description": "Your client_secret."
                  },
                  "grant_type": {
                    "type": "string",
                    "example": "refresh_token",
                    "description": "Must be set to refresh_token. The Access Token Response object contains a new access token."
                  }
                }
              }
            }
          },
          "description": "A request for an access token, given a refresh token"
        },
        "security": [
          {
            "Api-Key": []
          }
        ]
      },
      "get": {
        "x-boomtown-external-only": true,
        "tags": [
          "oauth"
        ],
        "summary": "Exchange a code for a refresh token",
        "description": "Exchange a code for a refresh token",
        "operationId": "redeemCode",
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client_secret",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_url",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "grant_type",
            "in": "query",
            "description": "Must be set to authorization_code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Returns an object that contains the Refresh and Access Tokens.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshToken"
                },
                "examples": {
                  "response": {
                    "value": {
                      "refresh_token": "0b30fa24-9251-4c71-8f06-3bb861ff0025",
                      "access_token": "944b7453-e641-4f1d-a591-9147dbe5a7d5",
                      "expires_in": "3920,",
                      "token_type": "Bearer"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "Api-Key": []
          }
        ]
      }
    },
    "/oauth2/verify": {
      "post": {
        "x-boomtown-external-only": true,
        "tags": [
          "oauth"
        ],
        "summary": "Verify a clientId, redirectUrl and scope",
        "responses": {
          "200": {
            "description": "Returns verification of clientId, redirectUrl and scope.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "The name of the organization that owns this clientId"
                    },
                    "clientId": {
                      "type": "string"
                    },
                    "redirectUrls": {
                      "type": "array",
                      "description": "All available redirect urls for this clientId",
                      "items": {
                        "type": "string"
                      }
                    },
                    "scope": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "photoUrl": {
                      "type": "string",
                      "description": "An optional link to a photo representing this organization."
                    }
                  }
                },
                "examples": {
                  "response": {
                    "value": {
                      "name": "Test Company",
                      "clientId": "b910a5ce-b7cb-4a18-b874-18c50925e17a",
                      "redirectUrls": [
                        "https://callback.com"
                      ],
                      "scope": "all",
                      "description": "Test Company Credentials",
                      "photoUrl": "https://testcompany.com/photo"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Returned when the parameters are invalid"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "clientId": {
                    "type": "string",
                    "example": "bc4415ae-185a-4737-af52-220022a8ec3f"
                  },
                  "redirectUrl": {
                    "type": "string",
                    "example": "https://foobar.com/oauth/landingpage"
                  },
                  "scope": {
                    "type": "string",
                    "example": "all"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "Api-Key": []
          }
        ]
      }
    },
    "/session": {
      "get": {
        "x-boomtown-external-only": true,
        "tags": [
          "user session"
        ],
        "summary": "Check for Valid Session",
        "description": "Check for Valid Session",
        "operationId": "validSession",
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "description": "The SHA256 hash of your ClientId and ClientSecret",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "access token",
            "required": true,
            "description": "Valid Access Token\n",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "401": {
            "description": "Token has expired. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.\n"
          },
          "default": {
            "description": "Returns an authentication object. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Authentication"
                },
                "examples": {
                  "response": {
                    "value": {
                      "accessToken": "a1d3a857-7fb6-4835-990d-7b69cf55f496",
                      "userId": 123,
                      "orgId": null,
                      "roles": [
                        "Agent"
                      ],
                      "appId": "8ceb25b9-c759-4d03-a298-69cfe1c6812a",
                      "id": "WjA0jrjfQ808fQaqqKTWXdCRN36saa6c0OKZkoWKgjbvgaMHHidTZGYFwziMcQoq",
                      "ttl": 1209600,
                      "created": "2015-07-21T16:05:38.788Z"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "Api-Key": []
          }
        ]
      }
    },
    "/contacts": {
      "post": {
        "x-boomtown-external": true,
        "tags": [
          "contacts"
        ],
        "summary": "Create a contact",
        "description": "Create a new contact.",
        "operationId": "createContact",
        "parameters": [
          {
            "name": "suppressBuyerAgentAutoAssign",
            "in": "query",
            "description": "Set to true to leave the buyer\u2019s agent unassigned if one is not provided in the request body.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "suppressLenderAutoAssign",
            "in": "query",
            "description": "Set to true to leave the lender unassigned if one is not provided in the request body.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "suppressListingAgentAutoAssign",
            "in": "query",
            "description": "Set to true to leave the seller's agent unassigned if one is not provided in the request body.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "emailOptOut",
            "in": "query",
            "description": "Set to true to halt the sending of all emails to the contact.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sendWelcomeEmail",
            "in": "query",
            "description": "Set to `buyerRegistration`, `listingRegistration`, or `invitation` to indicate the type of welcome email to send to the new contact. If not sending a welcome email, do not send this parameter.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Returns an object that contains the contact object that was created and the status of the request. If the request was not able to be fully completed but a contact was created the response will contain a list of errors that occured.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/contact-create-response"
                },
                "examples": {
                  "response": {
                    "value": {
                      "record": {
                        "contactId": 3532,
                        "orgId": 23,
                        "firstName": "John",
                        "lastName": "Smith",
                        "visitorId": 35426,
                        "sourceId": "OPENHOUSE",
                        "sourceName": "Open House",
                        "contactBy": "Text",
                        "description": "Looking to buy 3 bed 2.5bath house downtown.",
                        "communicationPreferences": {
                          "phoneStatus": "unknown",
                          "emailAddressStatus": "unknown",
                          "eAlertStatus": "Active"
                        },
                        "physicalAddresses": [
                          {
