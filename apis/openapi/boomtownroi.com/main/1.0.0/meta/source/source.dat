                  },
                  "reassignLender": {
                    "type": "boolean",
                    "example": false,
                    "description": "If set to true, also assign the contact to a new lender when transferring\nagents.\n"
                  }
                }
              }
            }
          },
          "description": "Valid transfer contact object in the body. Must the new agent/lender (newUserId) to transfer the contact to. The (newUserId) value is used to update the (userId) in the Associated User object.\n"
        }
