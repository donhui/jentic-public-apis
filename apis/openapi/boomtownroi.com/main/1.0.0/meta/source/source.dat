              "$ref": "#/components/schemas/Contact/properties/associatedUsers/items"
            },
            "description": "The associated users assigned to this contact\n"
          },
          "firstName": {
            "type": "string",
            "example": "John",
            "description": "First name of the contact."
          },
          "lastName": {
            "type": "string",
            "example": "Smith",
            "description": "Last name of the contact."
          },
          "sourceName": {
            "type": "string",
            "example": "Open House",
            "description": "How the contact is connected to the organization. Set based on how\nthe contact was directed to website, or manually entered by agent.\n"
          },
          "phoneNumber": {
            "type": "string",
