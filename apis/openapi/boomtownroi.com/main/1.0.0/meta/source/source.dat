    "/users/todos": {
      "get": {
        "tags": [
          "todos"
        ],
        "summary": "Get todos for all users",
        "description": "Retrieve the todos for all users that the requesting user has access to.",
        "operationId": "getAllUserTodos",
        "parameters": [
          {
            "$ref": "#/components/parameters/limitQueryParam"
          },
          {
            "$ref": "#/components/parameters/offsetQueryParam"
          },
          {
            "name": "orderby",
            "in": "query",
            "description": "Applies to `todoId, `authorId`, `ownerId`, `todoType`, `timeFrame`, `dueDate`, `alertDate`, `completeDate`, `dateCreated`, `dateModified` \n\nSpecify the ordered parameter(s) followed by the direction&#58; ascending (ASC) or descending (DESC). See *Request Filtering: Ordering (in API Standards)*.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "where",
            "in": "query",
            "description": "Applies to `todoId, `authorId`, `ownerId`, `isPrivate`, `todoType`, `timeFrame`, `dueDate`, `alertDate`, `completeDate`, `dateCreated`, `dateModified`   \n\nSpecify the where parameter followed by the property name and value pair, and optional operation. See *Request Filtering&#58; Selecting (in API Standards)*\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDate/endDate",
            "in": "query",
            "description": "Filter todos where dueDate >= startDate and/or dueDate <= endDate. startDate and endDate are of type date-time.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "isCompleted",
            "in": "query",
            "description": "Set to false to return incomplete todos, and set to true to return completed todos. \n",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "turns an array of todo object, including metadata. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/todo"
                  }
                }
              }
            }
          }
        }
      }
    },
