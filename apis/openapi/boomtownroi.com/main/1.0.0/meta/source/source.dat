    "/contacts/{contactId}/notes": {
      "post": {
        "x-boomtown-external": true,
        "tags": [
          "Notes"
        ],
        "summary": "Create note",
        "description": "Create note",
        "operationId": "createNote",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          },
          {
            "name": "notifyBuyerAgent",
            "in": "query",
            "required": false,
            "description": "Set to `true` to notify buyer agent. If the user is the assigned Buyer Agent, the notification flag is ignored.\n",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "notifyListingAgent",
            "in": "query",
            "required": false,
            "description": "Set to `true` to notify listing agent. If the user is the assigned Listing Agent, the notification flag is ignored.\n",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "notifyLender",
            "in": "query",
            "required": false,
            "description": "Set to `true` to notify lender. If the user is the assigned Lender, the notification flag is ignored.\n",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Returns a note object. The response includes the noteId that uniquely identifies the note. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Note"
                },
                "examples": {
                  "response": {
                    "value": {
                      "noteId": 678,
                      "noteContent": "Contents of note",
                      "authorId": 456,
                      "contactId": 123,
                      "topicType": "notSelected",
                      "isPrivate": true,
                      "dateCreated": "2016-01-27T14:45:14.703Z",
                      "dateModified": "2016-01-27T14:45:14.703Z"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "noteContent": {
                    "type": "string",
                    "example": "Contents of note",
                    "description": "The body of the note."
                  },
                  "authorId": {
                    "type": "number",
                    "format": "int64",
                    "example": 456,
                    "readOnly": true,
                    "description": "The user ID of the person creating the note. Value set by BoomTown."
                  },
                  "contactId": {
                    "type": "number",
                    "format": "int64",
                    "example": 123,
                    "readOnly": true,
                    "description": "Contact's ID which is associated with the particular note. Value set by BoomTown.\n"
                  },
                  "topicType": {
                    "type": "string",
                    "enum": [
                      "notSelected",
                      "generalInfo",
                      "profileBackgroundInfo",
                      "propertyRelatedInfo",
                      "financingInfo",
                      "meetingInfo"
                    ],
                    "example": "notSelected",
                    "description": "Topic of the conversation.<br>Allowed values: `notSelected` (default)`generalInfo``profileBackgroundInfo` `propertyRelatedInfo``financingInfo``meetingInfo`"
                  },
                  "isPrivate": {
                    "type": "boolean",
                    "example": true,
                    "description": "If set to `true`, indicates the note is viewable only by the author,\nand hidden from others in the organization.  Defaults to `false.\n"
                  }
                }
              }
            }
          },
          "description": "The note object to be added.",
          "required": true
        }
      },
