    "/contacts/{contactId}/emails/{emailId}/full": {
      "get": {
        "x-boomtown-external": true,
        "tags": [
          "Emails"
        ],
        "summary": "Get full email by id",
        "description": "Retrieve an email including all replies in the thread, file attachments and email headers.",
        "operationId": "getFullContactEmailById",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          },
          {
            "$ref": "#/components/parameters/emailIdParam"
          }
        ],
        "responses": {
          "default": {
            "description": "Returns an email object which includes the body, bodyThreadText, fileAttachments and headers. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Full_Email"
                },
                "examples": {
                  "response": {
                    "value": {
                      "body": "Hey John, I am in the market for a new home.  Please let me know what\nis available.  Thanks, Rick\n",
                      "bodyThreadText": "Hey Bill, What can I help you with?  Thanks, John\n",
                      "headers": "From: Rick Ricky (Rick.Ricky@someEmail.com) Subject: RE: Looking for\na home Date: January 25, 2011 3:30:58 PM PDT To: BillSmith@BoomTownROI.com ...\n",
                      "cc": "BillSmith@BoomTownROI.com",
                      "bcc": "TedSmith@BoomTownROI.com"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
