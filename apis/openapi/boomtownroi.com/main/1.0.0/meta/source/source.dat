      "Internal_Contact": {
        "type": "object",
        "properties": {
          "emailAssignedId": {
            "type": "number",
            "description": "An internal lookup identifier used for email proxying."
          },
          "password": {
            "type": "string",
            "description": "Website visitor password for login. Stored in database as Contact.Password."
          },
          "isInvited": {
            "type": "boolean",
            "description": "If set to `true`, contact was invited to the site and a visitor record\nwas created for them. <span class=\"needsreview\">IsInvited ..We may want to rename\nor consider moving this to another location.</span>\n"
          },
          "isBulkInvited": {
            "type": "boolean",
            "description": "If set to `true`, contact was invited to the site via auto import and\na visitor record was created for them.\n"
          },
          "thirdPartyLeadSourceId": {
            "type": "string",
            "description": "Internal. <span class=\"needsreview\">But we may want to allow for\nall systems to provide this for any new contact. maybe clean this name up. Zillow\nsends this to us and we may send it back. Probably internal to only the third\nparty integration service.</span>\n"
          },
          "agentSelected": {
            "type": "boolean",
            "description": "Internal. If set to `true`, contact is  registered on the agents subdomain.\nVisitor attribute.\n"
          },
          "roleId": {
            "type": "number",
            "description": "Legacy type specifier for visitor/contact. Values:<br> 1 - visitor\n(deprecated)<br>< 1 - contact<br>7 - auto import\n"
          },
          "lastAlertType": {
            "type": "number",
            "description": "Internal value for last e-alert type.  \n"
          },
          "isThirdPartyImported": {
            "type": "boolean",
            "description": "If set to true, the contact was imported via third party auto import service"
          },
          "autoEAlertEnabled": {
            "type": "boolean",
            "description": "If set to `true` (default), a system (auto defined) e-alert is generated\nfor the contact.\n"
          },
          "optedOutOfAllEmail": {
            "type": "boolean",
            "description": "Included in internal for legacy code. This boolean is user specified,\nhowever if users want to mark all of a users emails as opted out a better alternative\nis to update the emailStatus on each email.\n"
          },
          "canadianEmailOptInDate": {
            "type": "string",
            "format": "date-time",
            "description": "_Internal to Boomtown for Canadian email marketing compliance. Set if contact has opted into automated marketing emails.  Defaults to null. Stored in database as Contacts.OptInDate"
          }
        },
        "description": "_ContactInternal is an internal resource and may only be accessed by BoomTown systems._\n\n- API clients must have an authorized BoomTown-Internal token to read or write `contactsInternal` records.\n- Access by appending the query parameter `?contactInternal=true`. \n- `Contact.roleId` is a legacy setting, but still internally needed. Set for auto import (`roleId=7`) when contact is a third party lead.\n"
      },
      "contact-create-response": {
        "type": "object",
        "properties": {
          "record": {
            "type": "object",
            "properties": {
              "contactId": {
                "example": 3532
              },
              "orgId": {
                "example": 23
              },
              "firstName": {
                "example": "John"
              },
              "lastName": {
                "example": "Smith"
              },
              "visitorId": {
                "example": 35426
              },
              "sourceId": {
                "example": "OPENHOUSE"
              },
              "sourceName": {
                "example": "Open House"
              },
              "contactBy": {
                "example": "Text"
              },
              "description": {
                "example": "Looking to buy 3 bed 2.5bath house downtown."
              },
              "communicationPreferences": {
                "$ref": "#/components/schemas/Contact/properties/communicationPreferences"
              },
              "physicalAddresses": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Contact/properties/physicalAddresses/items"
                }
              },
              "emailAddresses": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Contact/properties/emailAddresses/items"
                }
              },
              "phoneNumbers": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Contact/properties/phoneNumbers/items"
                }
              },
              "associatedUsers": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Contact/properties/associatedUsers/items"
                },
                "description": "Users assigned to the contact."
              },
              "socialProfiles": {
                "$ref": "#/components/schemas/Contact/properties/socialProfiles"
              },
              "tags": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Contact/properties/tags/items"
                }
              },
              "relatedContact": {
                "$ref": "#/components/schemas/Contact/properties/communicationPreferences"
              },
              "contactOriginType": {
                "$ref": "#/components/schemas/Contact/properties/contactOriginType"
              }
            }
          },
          "requestStatus": {
            "type": "object",
            "properties": {
              "complete": {
                "example": true
              },
              "errors": {
                "example": []
              }
            }
          }
        }
      },
      "contact-create": {
        "type": "object",
        "properties": {
          "orgId": {
            "type": "number",
            "format": "int64",
            "example": 23,
            "readOnly": true,
            "description": "The organization owning the contact record. Value set by BoomTown."
          },
          "firstName": {
            "type": "string",
            "example": "John",
            "description": "First name of the contact."
          },
          "lastName": {
            "type": "string",
            "example": "Smith",
            "description": "Last name of the contact."
          },
          "visitorId": {
            "type": "number",
            "format": "int64",
            "example": 35426,
            "description": "The linked Visitor ID for the contact. Attribute exists if the contact\nis a web visitor. Visitor functionality will be available in Boomtown API V2.\n"
          },
          "sourceId": {
            "type": "string",
            "example": "OPENHOUSE",
            "description": "How the contact is connected to the organization.  Set based on how\nthe contact was directed to website, or manually entered by agent. See Get all\nsources endpoint for accepted values. \n"
          },
          "sourceName": {
            "type": "string",
            "example": "Open House",
            "readOnly": true,
            "description": "Displayable name for the source set in sourceId. Value set by BoomTown."
          },
          "contactBy": {
            "type": "string",
            "enum": [
              "phone",
              "email"
            ],
            "example": "Text",
            "description": "Best way to reach the contact. Allowed values: `phone``email`"
          },
          "description": {
            "type": "string",
            "example": "Looking to buy 3 bed 2.5bath house downtown.",
            "description": "Notes shared by agents, brokers and lenders."
          },
          "communicationPreferences": {
            "$ref": "#/components/schemas/Contact/properties/communicationPreferences"
          },
          "physicalAddresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contact/properties/physicalAddresses/items"
            }
          },
          "emailAddresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contact/properties/emailAddresses/items"
            }
          },
          "phoneNumbers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contact/properties/phoneNumbers/items"
            }
          },
          "associatedUsers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contact/properties/associatedUsers/items"
            },
            "description": "Users assigned to the contact."
          },
          "socialProfiles": {
            "$ref": "#/components/schemas/Contact/properties/socialProfiles"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contact/properties/tags/items"
            }
          },
          "relatedContact": {
            "$ref": "#/components/schemas/Contact/properties/communicationPreferences"
          },
          "contactOriginType": {
            "$ref": "#/components/schemas/Contact/properties/contactOriginType"
          }
        }
      },
      "Associated_User": {
        "type": "object",
        "properties": {
          "associatedUserId": {
            "type": "number",
            "format": "int64",
            "example": 1233,
            "readOnly": true,
            "description": "Primary identifier for the associated user relationship. Value set by BoomTown.\n"
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 33,
            "description": "Primary identifier for the contact."
          },
          "userId": {
            "type": "number",
            "format": "int64",
            "example": 3438,
            "description": "User associated with the contact."
          },
          "contactCategory": {
            "type": "string",
            "enum": [
              "new",
              "trash",
              "watch",
              "qualify",
              "nurture",
              "hot",
              "archive",
              "closed",
              "pending"
            ],
            "example": "nurture",
            "description": "Status of the contact associated with the user. Allowed values:\n- `new`\n- `trash`: using another agent\n- `watch`: just looking, no timeframe\n- `qualify`: new and unqualified\n- `nurture`: more than 3 months out\n- `hot: working towards a deal\n- `archive`: archive contact for later\n- `closed`: deal closed\n- `pending`: contact pending\n"
          },
          "categoryDate": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-26T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the contact category was assigned. Value set by BoomTown."
          },
          "assignedDate": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-26T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the contact was assigned. Value set by BoomTown."
          },
          "communicationStatus": {
            "type": "string",
            "enum": [
              "active",
              "agentUnsubscribed",
              "contactUnsubscribed",
              "lenderUnsubscribed"
            ],
            "example": "active",
            "description": "If communication is allowed with the contact; and if not, who unsubsribed\nthem. Allowed values: `active` (default), `agentUnsubscribed`, `lenderUnsubscribed`,`contactUnsubscribed`\n"
          },
          "associatedUserType": {
            "type": "string",
            "enum": [
              "buyerAgent",
              "lender",
              "sellerAgent"
            ],
            "example": "buyerAgent",
            "description": "The role of the user in this relationship. Allowed values:`buyerAgent`,`lender`,`sellerAgent`"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the associated user was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the associated user was last changed. Value set by BoomTown."
          }
        },
        "description": "An associated user object categorizes the user\u2019s relationship and communication status with the contact.\n",
        "required": [
          "associatedUserId",
          "contactId",
          "userId",
          "associatedUserType",
          "dateCreated",
          "dateModified"
        ]
      },
      "Associated_User_Transfer": {
        "type": "object",
        "properties": {
          "newUserId": {
            "type": "number",
            "format": "int64",
            "example": 54321,
            "description": "The userId of the agent/lender to transfer this contact to."
          },
          "notifyOldUser": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, send an email/text to the current agent/lender notifying\nthem the contact is being transferred away.\n"
          },
          "notifyNewUser": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, send an email/text to the new agent/lender notifying\nthem a contact is being transferred to them.\n"
          },
          "message": {
            "type": "string",
            "example": "ISA qualified lead transferring to agent",
            "description": "Notes to the new agent or lender."
          },
          "leaveCategory": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the contactCategory values stays the same."
          },
          "reassignLender": {
            "type": "boolean",
            "example": false,
            "description": "If set to true, also assign the contact to a new lender when transferring\nagents.\n"
          }
        },
        "description": "A transfer object contains information about the transfer of a contact to another associated user, including whether to email or text the agents or lenders involved.\n",
        "required": [
          "newUserId"
        ]
      },
      "todo": {
        "type": "object",
        "properties": {
          "todoId": {
            "type": "number",
            "example": 123,
            "readOnly": true,
            "description": "The primary identifier for a todo. Value set by BoomTown."
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 2,
            "description": "Id of the contact associated with the todo."
          },
          "authorId": {
            "type": "number",
            "format": "int64",
            "example": 57,
            "readOnly": true,
            "description": "Id number of the user who created the todo. Value set by  BoomTown."
          },
          "ownerId": {
            "type": "number",
            "format": "int64",
            "example": 57,
            "readOnly": true,
            "description": "Id number of user whom the todo belongs. With Contacts, may be different from authorId, but defaults to authorId if not specified when\nthe todo is created. For users, the value is set by BoomTown.\n"
          },
          "isPrivate": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the todo is visible only to the user and is not shared with others in the organization.\n"
          },
          "todoType": {
            "type": "string",
            "enum": [
              "custom",
              "call",
              "email",
              "fax",
              "mail",
              "followUp",
              "meeting",
              "arrivalDate",
              "showing",
              "closing",
              "openHouse",
              "thankYou",
              "text"
            ],
            "example": "call",
            "description": "Type of action the user needs to take. Defaults to `custom`."
          },
          "label": {
            "type": "string",
            "example": null,
            "description": "Label for display if `todoType` is set to `custom`."
          },
          "body": {
            "type": "string",
            "example": "Call Bill about buying a home",
            "description": "Description of what to do."
          },
          "timeFrame": {
            "type": "string",
            "enum": [
              "later",
              "today",
              "tomorrow",
              "2days",
              "3days",
              "1week",
              "2weeks",
              "3weeks",
              "1month",
              "thisWeek",
              "nextWeek",
              "specific"
            ],
            "example": "2days",
            "description": "When the task should be completed.  Defaults to `later`."
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-15T16:51:08.530Z",
            "description": "Time when the todo is due."
          },
          "dueDateType": {
            "type": "string",
            "enum": [
              "anytime",
              "specific"
            ],
            "example": "specific",
            "description": "Modifier on dueDate. Defaults to `specific`."
          },
          "alertDate": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-15T16:51:08.530Z",
            "description": "Time to remind the user."
          },
          "completeDate": {
            "type": "string",
            "format": "date-time",
            "example": null,
            "description": "Time completed."
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the todo was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the todo was last changed. Value set by BoomTown."
          },
          "createdBy": {
            "type": "string",
            "enum": [
              "notSpecified",
              "self",
              "anotherUser",
              "dripCampaign"
            ],
            "example": "dripGenerated",
            "description": "Specifies who/what generated the Todo. Defaults to `notSpecified`.\n"
          },
          "isCalendarSyncEnabled": {
            "example": true,
            "type": "boolean"
          },
          "invitees": {
            "type": "array",
            "example": [
              "john@gmail.com",
              "alice@gmail.com"
            ],
            "items": {
              "type": "string"
            }
          },
          "location": {
            "type": "string",
            "example": "Somewhere"
          }
        },
        "description": "The todo object contains the details of a task or action that needs to be taken for the contact. It can include a type categorization, an expected time frame, and a date to remind the user.\n",
        "required": [
          "authorId",
          "ownerId",
          "dateCreated",
          "dateModified",
          "createdBy"
        ]
      },
      "todo-create": {
        "type": "object",
        "properties": {
          "contactId": {
            "type": "number",
            "example": 2
          },
          "isPrivate": {
            "type": "boolean",
            "example": false
          },
          "todoType": {
            "type": "string",
            "example": "call"
          },
          "label": {
            "type": "string",
            "example": null
          },
          "body": {
            "type": "string",
            "example": "Call Bill about buying a home"
          },
          "timeFrame": {
            "type": "string",
            "example": "2days"
          },
          "dueDate": {
            "type": "string",
            "format": "datetime",
            "example": "2016-01-15T16:51:08.530Z"
          },
          "dueDateType": {
            "type": "string",
            "example": "specific"
          },
          "alertDate": {
            "type": "string",
            "format": "datetime",
            "example": "2016-01-15T16:51:08.530Z"
          },
          "completeDate": {
            "type": "string",
            "format": "datetime",
            "example": "2016-01-15T16:51:08.530Z"
          },
          "isCalendarSyncEnabled": {
            "example": true,
            "type": "boolean"
          },
          "invitees": {
            "type": "array",
            "example": [
              "john@gmail.com",
              "alice@gmail.com"
            ],
            "items": {
              "type": "string"
            }
          },
          "location": {
            "type": "string",
            "example": "Somewhere"
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "tagId": {
            "type": "number",
            "format": "int64",
            "readOnly": true,
            "example": 4234,
            "description": "The primary identifier for a tag. Value set by BoomTown."
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "example": 25,
            "readOnly": true,
            "description": "Primary identifier of the organization which created the tag or the\norganization of the User who created the tag. Value set by BoomTown.\n"
          },
          "userId": {
            "type": "number",
            "format": "int64",
            "example": 4543,
            "readOnly": true,
            "description": "Primary identifier of the user who created the tag. Value set by BoomTown.\n"
          },
          "tagName": {
            "type": "string",
            "example": "New Buyer",
            "description": "Short description of the tag. For example, \"Qualified Buyer\", \"Buying\nSoon\", etc. \n"
          },
          "tagOwner": {
            "type": "string",
            "enum": [
              "user",
              "org"
            ],
            "example": "org",
            "description": "Determines the level of access.<br>Allowed values:\n- `user`: private to user.  \n- `org` - available to anyone in the organization.\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "readOnly": true,
            "description": "Time the tag was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "readOnly": true,
            "description": "Time when the tag was last changed. Value set by BoomTown."
          }
        },
        "description": "A tag object contains the tag label, and all ownership information for the tag which defines who is allowed to use the tag (e.g., user only, or all users in an organization).\n",
        "required": [
          "tagId",
          "tagName",
          "tagOwner",
          "dateCreated",
          "dateModified"
        ]
      },
      "Note": {
        "type": "object",
        "properties": {
          "noteId": {
            "type": "number",
            "format": "int64",
            "example": 678,
            "readOnly": true,
            "description": "The primary identifier for the note. Value set by BoomTown."
          },
          "noteContent": {
            "type": "string",
            "example": "Contents of note",
            "description": "The body of the note."
          },
          "authorId": {
            "type": "number",
            "format": "int64",
            "example": 456,
            "readOnly": true,
            "description": "The user ID of the person creating the note. Value set by BoomTown."
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "Contact's ID which is associated with the particular note. Value set by BoomTown.\n"
          },
          "topicType": {
            "type": "string",
            "enum": [
              "notSelected",
              "generalInfo",
              "profileBackgroundInfo",
              "propertyRelatedInfo",
              "financingInfo",
              "meetingInfo"
            ],
            "example": "notSelected",
            "description": "Topic of the conversation.<br>Allowed values: `notSelected` (default)`generalInfo``profileBackgroundInfo` `propertyRelatedInfo``financingInfo``meetingInfo`"
          },
          "isPrivate": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, indicates the note is viewable only by the author,\nand hidden from others in the organization.  Defaults to `false.\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the note was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the note was last changed. Value set by BoomTown."
          }
        },
        "description": "The note object contains descriptive content about a contact.\n",
        "required": [
          "noteId",
          "noteContent",
          "contactId",
          "topicType",
          "dateCreated",
          "dateModified"
        ]
      },
      "Address": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "The city for the transaction",
            "nullable": true,
            "example": "Mount Pleasant"
          },
          "postalCode": {
            "type": "string",
            "description": "The zip or postal code",
            "nullable": true,
            "example": "29466"
          },
          "postalCity": {
            "type": "string",
            "description": "The city used for mailing purposes",
            "nullable": true,
            "example": "Charleston"
          },
          "stateOrProvince": {
            "type": "string",
            "description": "The state or province name",
            "nullable": true,
            "example": "SC"
          },
          "streetDirPrefix": {
            "type": "string",
            "description": "The directional prefix before the street name",
            "nullable": true,
            "example": "N"
          },
          "streetDirSuffix": {
            "type": "string",
            "description": "The directional suffix after the street name",
            "nullable": true,
            "example": "S"
          },
          "streetName": {
            "type": "string",
            "description": "The name of the street",
            "nullable": true,
            "example": "Gulf Drive"
          },
          "streetNumber": {
            "type": "string",
            "description": "The number of the street in string format",
            "nullable": true,
            "example": "2148"
          },
          "streetNumberNumeric": {
            "type": "integer",
            "description": "The number of the street in int format",
            "format": "int32",
            "nullable": true,
            "example": 2148
          },
          "streetSuffix": {
            "type": "string",
            "description": "The suffix after the street name",
            "nullable": true,
            "example": "Drive"
          },
          "streetSuffixModifier": {
            "type": "string",
            "description": "Modification to the street suffix",
            "nullable": true,
            "example": "N"
          },
          "township": {
            "type": "string",
            "description": "Special weird little city county state things",
            "nullable": true,
            "example": "Mount Pleasant"
          },
          "unitNumber": {
            "type": "string",
            "description": "THe number of the apartment or unit",
            "nullable": true,
            "example": "B"
          },
          "unparsedAddress": {
            "type": "string",
            "description": "The fully qualified address of the transaction",
            "nullable": true,
            "example": "2148 S Gulf Drive N 104B"
          },
          "contractAddressType": {
            "type": "string",
            "description": "The Type of address",
            "nullable": true,
            "example": "Address"
          }
        },
        "additionalProperties": false
      },
      "Email_Address": {
        "type": "object",
        "properties": {
          "emailAddressId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "The primary identifier for the email address. Value set by BoomTown.\n"
          },
          "emailAddress": {
            "type": "string",
            "example": "JohnSmith@BoomTownROI.com",
            "description": "The email address."
          },
          "isLogin": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, this email is used to login. Defaults to `true` if\nthere are no other emails for the contact.\n"
          },
          "isPrimary": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, send all emails to this address. Defaults to `true`\nif no other email addresses exist for the contact.\n"
          },
          "description": {
            "type": "string",
            "example": null,
            "description": "A brief note about the email address."
          },
          "emailAddressStatus": {
            "type": "string",
            "enum": [
              "unknown",
              "validAddress",
              "invalidAddress",
              "twoWayEmailing",
              "optedOut"
            ],
            "example": "unknown",
            "description": "The status of the email address. \n\n- Defaults to `unknown`(default)\n- `twoWayEmailing`: has been used in communication\n- `optedOut`: contact has requested no contact via email\n"
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "Contact identifier for the contact who owns the email address. Value\nset by BoomTown.\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the email address was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the email address was last changed. Value set by BoomTown."
          }
        },
        "description": "The email address object contains information about a specific email address, including whether it is being used for login, or if is the best email to use for the contact. It also includes a current status showing if the email is known to be valid, if the contact has opted-out at this address, or has been used in recent communications.\n",
        "required": [
          "emailAddressId",
          "emailAddress",
          "contactId",
          "dateCreated"
        ]
      },
      "Phone_Number": {
        "type": "object",
        "properties": {
          "phoneNumberId": {
            "type": "number",
            "format": "int64",
            "example": 456,
            "readOnly": true,
            "description": "The primary identifier for the phone number. Value set by BoomTown.\n"
          },
          "label": {
            "type": "string",
            "example": "phone number for contact",
            "description": "Descriptive label for the phone number (\"Work\", \"Cell\", etc...).\nDefaults to an empty string.\n"
          },
          "phoneNumber": {
            "type": "string",
            "example": "123-456-7890",
            "description": "The phone number for the contact."
          },
          "phoneStatus": {
            "type": "string",
            "enum": [
              "unknown",
              "active",
              "valid",
              "optedOut",
              "wrongNumber"
            ],
            "example": "active",
            "description": "'The status of the phone number. \n"
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "The identifier for the contact which is associated with the phone\nnumber. Value set by BoomTown.\n"
          },
          "phoneType": {
            "type": "string",
            "enum": [
              "mobile",
              "landline",
              "voip",
              "other"
            ],
            "example": "mobile",
            "description": "'The type of the phone.\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the phone number was created. Value set by BoomTown.\n"
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the phone number was last changed. Value set by BoomTown.\n"
          }
        },
        "description": "A phone number object contains a description and status for each phone number.\n",
        "required": [
          "phoneNumberId",
          "phoneNumber",
          "contactId",
          "dateCreated",
          "dateModified"
        ]
      },
      "phone-number-create": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "example": "phone number for contact",
            "description": "Descriptive label for the phone number (\"Work\", \"Cell\", etc...).\nDefaults to an empty string.\n"
          },
          "phoneNumber": {
            "type": "string",
            "example": "123-456-7890",
            "description": "The phone number for the contact."
          },
          "phoneStatus": {
            "type": "string",
            "enum": [
              "unknown",
              "active",
              "valid",
              "optedOut",
              "wrongNumber"
            ],
            "example": "active",
            "description": "'The status of the phone number.\n"
          },
          "phoneType": {
            "type": "string",
            "enum": [
              "mobile",
              "landline",
              "voip",
              "other"
            ],
            "example": "mobile",
            "description": "'The type of the phone.\n"
          }
        },
        "description": "A phone number request object contains a label, phoneNumber, phoneStatus, and phoneType for each phone number.\n",
        "required": [
          "phoneNumber"
        ]
      },
      "Call_Log": {
        "type": "object",
        "properties": {
          "callLogId": {
            "type": "number",
            "format": "int64",
            "example": 678,
            "readOnly": true,
            "description": "The main identifier for each call log. Value set by BoomTown.\n"
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "The identifier for the contact associated with the callLog. Value set by BoomTown.\n"
          },
          "userId": {
            "type": "number",
            "format": "int64",
            "example": 456,
            "readOnly": true,
            "description": "The identifier for the user associated with the callLog. Value set by BoomTown.\n"
          },
          "callDetails": {
            "type": "string",
            "example": "Tim wants to tour a home next week",
            "description": "Description and any notes about the call.\n"
          },
          "isPrivate": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, indicates the note is viewable only by the author, and hidden from others in the organization.\n"
          },
          "logType": {
            "type": "string",
            "enum": [
              "phoneConversation",
              "leftMessage",
              "callAttempt",
              "wrongNumber",
              "optedOut",
              "notSelected"
            ],
            "example": "phoneConversation",
            "description": "Outcome of the call. Allowed values:\n- `phoneConversation`\n- `leftMessage`\n- `callAttempt` (no message left)\n- `wrongNumber`\n- `optedOut`\n- `notSelected`\n"
          },
          "contactPhoneId": {
            "type": "number",
            "format": "int64",
            "example": 2,
            "description": "Identifier matching to a particular phone for a contact.\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the call log record was created. Value set by BoomTown.\n"
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the call log record was last changed. Value set by BoomTown.\n"
          },
          "callStartTime": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-15T16:51:08.530Z",
            "readOnly": true,
            "description": "Time the phone call started. Value set by BoomTown.\n"
          },
          "callEndTime": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-15T16:58:08.530Z",
            "readOnly": true,
            "description": "Time the phone call ended. Value set by BoomTown.\n"
          }
        },
        "description": "The call log object contains all details and notes from phone conversations.\n",
        "required": [
          "callLogId",
          "contactId",
          "isPrivate",
          "logType",
          "dateCreated",
          "dateModified"
        ]
      },
      "Special_Date": {
        "type": "object",
        "properties": {
          "specialDateId": {
            "type": "string",
            "example": 456,
            "readOnly": true,
            "description": "Primary identifier for record. Value set by BoomTown."
          },
          "contactId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "Contact associated with the special date. Value set by BoomTown."
          },
          "month": {
            "type": "number",
            "example": 3,
            "description": "Month of date, format MM. Ex: 06 or 11 "
          },
          "day": {
            "type": "number",
            "example": 12,
            "description": "Day of date, format DD. Ex: 04 or 15"
          },
          "year": {
            "type": "number",
            "example": 1983,
            "description": "Year of date, format YYYY. Ex: 2015"
          },
          "specialDateType": {
            "type": "string",
            "enum": [
              "notSpecified",
              "birthday",
              "purchaseAnniversary"
            ],
            "example": "birthday",
            "description": "The type of occasion. <br>Allowed values: `notSpecified` (default)`birthday``purchaseAnniversary`"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the special date record was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the special date record was last changed. Value set by BoomTown."
          }
        },
        "description": "The special date object contains reminder information of a contact\u2019s closing date or birthday.\n",
        "required": [
          "specialDateId",
          "contactId",
          "month",
          "specialDateType",
          "dateCreated",
          "dateModified"
        ]
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "webhookId": {
            "type": "number",
            "format": "int64",
            "example": 12345,
            "readOnly": true,
            "description": "Identifier for the webhook. Webhooks callback from BoomTown have an X-BoomTown-WebhookId header set to this value.\n"
          },
          "isActive": {
            "type": "boolean",
            "example": false,
            "description": "If set to `true`, the webhook is active and delivers callbacks to the callbackUrl."
          },
          "ownerUserId": {
            "type": "number",
            "format": "int64",
            "example": 45678,
            "readOnly": true,
            "description": "User who owns the webhook. Value set via the userId of the user making the api call."
          },
          "targetUserId": {
            "type": "number",
            "format": "int64",
            "example": 668238,
            "description": "User who the webhook is monitoring. Defaults to `ownerUserId` if not specified."
          },
          "orgId": {
            "type": "number",
            "format": "int64",
            "example": 23,
            "description": "Organization Id for the targetUserId associated with the Webhook."
          },
          "description": {
            "type": "string",
            "example": "A webhook to track new registrations for Example Companys back-end system.",
            "description": "Text describing the webhook definition."
          },
          "callbackUrl": {
            "type": "string",
            "example": "https://somesite.com/callback",
            "description": "URI where callbacks are delivered. All callbackUrls must be https://\n"
          },
          "signingKey": {
            "type": "string",
            "example": "cb819d1f71bd783b818a9c9a6912158b7aa315b2",
            "readOnly": true,
            "description": "Used to sign webhook requests. All webhook callbacks from boomtown include an X-BoomTown-Signature header with an HMAC_SHA256 signature of the callback body using this key. It should be stored in secure, persistent storage.\n"
          },
          "webhookType": {
            "type": "string",
            "enum": [
              "callLogged",
              "contactAssignmentsChanged",
              "contactCategoryChanged",
              "contactImported",
              "contactUpdated",
              "emailReceived",
              "newRegistration",
              "questionAskedOnSite",
              "textReceived",
              "todoCompleted",
              "todoCreated",
              "transactionCreated",
              "transactionDeleted",
              "transactionModified",
              "tagAdded",
              "tagRemoved"
            ],
            "example": "newRegistration",
            "readOnly": true,
            "description": "Specifies which type of event this tracks."
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": ""
          },
          "dateDeactivated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": ""
          },
          "deactivatedReason": {
            "type": "string",
            "description": "A text description indicating why the webhook was deactivated.",
            "example": "The callback server returned a 404 error code",
            "readOnly": true
          },
          "deactivatedEmail": {
            "type": "string",
            "description": "An email address that is contacted when a webhook is deactivated.",
            "example": "webhook-deactivated@domain.com"
          }
        },
        "description": "A webhook object records certain events raised in the BoomTown system.\n",
        "required": [
          "webhookId",
          "ownerUserId",
          "isActive",
          "description",
          "signingKey",
          "dateCreated",
          "callbackUrl",
          "webhookType"
        ]
      },
      "webhook": {
        "type": "object",
        "properties": {
          "callbackUrl": {
            "type": "string",
            "example": "https://system.cobblestonellc.com/someEvent",
            "description": "URI where callbacks are delivered. All callbackUrls must be https://\n"
          },
          "description": {
            "type": "string",
            "example": "A webhook to track some event for Example Companys back-end system.",
            "description": "Text describing the webhook definition."
          },
          "targetUserId": {
            "type": "number",
            "format": "int64",
            "example": 668238,
            "description": "User who the webhook is monitoring. Defaults to `ownerUserId` (which is derived from the userId of the user making the api call) if not specified.\n"
          },
          "deactivatedEmail": {
            "type": "string",
            "description": "An email address that is contacted when a webhook is deactivated.",
            "example": "webhook-deactivated@domain.com"
          }
        },
        "required": [
          "callbackUrl",
          "description"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "Unique identifier for the user. Value set by BoomTown."
          },
          "orgId": {
            "type": "number",
            "example": 456,
            "readOnly": true,
            "description": "Unique identifier for the organization that the user belongs to. Value set by BoomTown."
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "agent",
                "agentProfile",
                "blogContributor",
                "boomAdmin",
                "broker",
                "contentEditor",
                "lender",
                "lenderAdmin",
                "networkAdmin",
                "owner"
              ],
              "example": "agent"
            },
            "example": [
              "agent",
              "broker"
            ],
            "description": "One or more user types, used to grant and deny permission to information\nand features. For example, users with the role of agent are only allowed to\naccess their own contacts, whereas a user with the role of broker can access\nall contacts for their organization. See *User Roles* for more information about access on each role.\n\nAllowed values:\n\n- `agent`<br>Real Estate Agent. Has privileges for most features, but is generally limited in scope. \n\n- `agentProfile`<br>Agent Profile User. Has a free BoomTown account with limited features. They can create a profile on the organization's website and receive leads via that profile page.\n\n- `blogContributor`:<br> Website Blog Contributor Contributes to blog posts on the front-end website.\n\n- `broker`: <br> Has all access and permissions as agents, but their privileges are not as limited...they have access to details for all users and contacts in their organization.\n\n- `contentEditor`:<br> Website Content Editor. Can edit content for the front-end website.\n\n- `lender`: <br>Has nearly identical privileges to agents. Like agents, they only have access to their own records and associated contact records. However, they cannot view their user settings, dismiss alerts, nor have access to user insight features. \n\n- `lenderAdmin`: <br>Lender Administrator. Has similar privileges as brokers, but privileges extend over only to lender users and lender-associated contacts.  \n\n- `networkAdmin`: <br>Network Administator. Has administrator privileges for all users in a network, and can view leads and reports from all organizations in a network. *Network information will be available in an upcoming release of BoomTown API.*\n\n- `owner`: <br>Organization Owner. Are organization administrators, with all access and permissions. Can update an organization's account information. Does not have permission to view or manage users outside of the organization, even if they are part of the same network.\n"
          },
          "isApproved": {
            "type": "boolean",
            "example": true,
            "description": "If set to `true`, the user has claimed the account by logging in for the first time.\n"
          },
          "agentSubdomain": {
            "type": "string",
            "example": "Joe",
            "description": "Another name for the user."
          },
          "firstName": {
            "type": "string",
            "example": "Joseph",
            "description": "First name."
          },
          "lastName": {
            "type": "string",
            "example": "Appletree",
            "description": "Last name."
          },
          "email": {
            "type": "string",
            "example": "joseph@boomtownroi.com",
            "description": "Email address."
          },
          "socialLinks": {
            "type": "array",
            "items": {
              "type": "string",
              "example": [
                "www.facebook.com/joseph",
                "www.linkedin.com/in/joseph"
              ]
            },
            "description": "A series of URLs for the user's social profile pages."
          },
          "restricted": {
            "type": "boolean",
            "example": false,
            "description": "If set to true, the user is blocked from logging into the system."
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the user was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the user was last changed. Value set by BoomTown."
          }
        },
        "description": "The user object provides basic details about the user; including their roles in the Real Estate team, when they were added to the system, and their email address and social media links.\n",
        "required": [
          "userId",
          "orgId",
          "roles",
          "isApproved",
          "agentSubdomain",
          "firstName",
          "lastName",
          "email",
          "dateCreated",
          "dateModified"
        ]
      },
      "User_Profiles": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "Id of the user the profile belongs to. Value set by BoomTown."
          },
          "profilePicture": {
            "type": "string",
            "example": "http://boomtownroi.com/content/tenant/agroup/agent/1.jpg",
            "readOnly": true,
            "description": "URL to user's profile picture Value set by BoomTown."
          },
          "additionalEmails": {
            "type": "string",
            "example": "joe@gmail.com, joseph@yahoo.com",
            "description": "Other emails lead notifications can be sent to. The list should be comma separated\n"
          },
          "officePhone": {
            "type": "string",
            "example": "1234567890",
            "description": "Office phone number"
          },
          "homePhone": {
            "type": "string",
            "example": "1234567890",
            "description": "Home phone number"
          },
          "mobilePhone": {
            "type": "string",
            "example": "1234567890",
            "description": "Mobile phone number"
          },
          "directPhone": {
            "type": "string",
            "example": "1234567890",
            "description": "Direct phone number"
          },
          "boomTownNumber": {
            "type": "string",
            "example": "9876543210",
            "readOnly": true,
            "description": "Boomtown phone number lead calls go to get in touch with the user.  Value set by BoomTown.\n"
          },
          "tollFreePhone": {
            "type": "string",
            "example": "8001234567",
            "description": "Toll free number to get to the user"
          },
          "faxNumber": {
            "type": "string",
            "example": "123456789",
            "description": "User's fax number"
          },
          "personalWebsite": {
            "type": "string",
            "example": "http://joe.cobblestonellc.com",
            "description": "User's personal website"
          },
          "professionalTitle": {
            "type": "string",
            "example": "Broker",
            "description": "User's current title at the organization."
          },
          "awardsAndDesignations": {
            "type": "string",
            "example": "BestBrokerNA",
            "description": "User's awards and designations they want shown. New-line separated"
          },
          "tagLine": {
            "type": "string",
            "example": "At your service",
            "description": "User's tag line"
          },
          "professionalBio": {
            "type": "string",
            "example": "Have been in the real estate scene for going on 20 years now, with a 99.8% satisfaction rating.\n",
            "description": "An excerpt about user"
          },
          "emailSignature": {
            "type": "string",
            "example": "You can reach me here: 9876543210. Any question, any time.\n",
            "description": "Email signature to add to boomtown sent emails.\n"
          },
          "agentAttributes": {
            "type": "object",
            "properties": {
              "officeId": {
                "type": "number",
                "format": "int64",
                "example": 2345,
                "description": "Id of the office the user is in."
              },
              "agentSubdomain": {
                "type": "string",
                "example": "some Sub domain",
                "description": "User's subdomain on the organization's website."
              },
              "MLSInfo": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "AgentMLSId": {
                      "type": "string",
                      "example": 2345,
                      "readOnly": true
                    },
                    "OfficeMLSId": {
                      "type": "string",
                      "example": 8543,
                      "readOnly": true
                    },
                    "MLSId": {
                      "type": "number",
                      "example": 12345,
                      "readOnly": true
                    },
                    "MLSName": {
                      "type": "string",
                      "example": "Charleston Test MLS",
                      "readOnly": true
                    }
                  }
                },
                "description": "Array of MLSs and their corresponding agentMLS and officeMLS.  *Value set by BoomTown*\n",
                "readOnly": true
              }
            },
            "description": "Agent specific information, see agentAttributes.\n",
            "required": [
              "officeId",
              "agentSubdomain"
            ]
          },
          "lenderAttributes": {
            "type": "object",
            "properties": {
              "loanAppUrl": {
                "type": "string",
                "description": "The URL for the loan application."
              },
              "logoLink": {
                "type": "string",
                "readOnly": true,
                "description": "The URL for the location of the organization's logo file. Value set by BoomTown.\n"
              },
              "licenseNumber": {
                "type": "string",
                "description": "The lender's license number."
              },
              "companyName": {
                "type": "string",
                "description": "The company that the user works for."
              },
              "street": {
                "type": "string",
                "description": "Street address for the company."
              },
              "city": {
                "type": "string",
                "description": "City for the company address."
              },
              "state": {
                "type": "string",
                "description": "State for the company address."
              },
              "postalCode": {
                "type": "string",
                "description": "Zip code for the company addresss."
              }
            },
            "required": [
              "companyName",
              "street",
              "city",
              "state",
              "postalCode"
            ]
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time the profile record was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-01-27T14:45:14.703Z",
            "readOnly": true,
            "description": "Time when the profile record was last changed. Value set by BoomTown.\n"
          }
        },
        "description": "The profile object contains various information about agents and lenders, that is shown on the organization\u2019s website. It includes a profile picture, emails, phone numbers, a short professional biography with awards and designations, email signatures, and more.\n",
        "required": [
          "userId",
          "professionalTitle",
          "dateCreated",
          "dateModified"
        ]
      },
