    "/contacts/{contactId}/callLogs": {
      "post": {
        "x-boomtown-external": true,
        "tags": [
          "Call Logs"
        ],
        "summary": "Add call log",
        "description": "Create a new call log.",
        "operationId": "addCallLog",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          },
          {
            "name": "notifyBuyerAgent",
            "in": "query",
            "required": false,
            "description": "Set to `true` to notify buyer agent. If the user is the assigned Buyer Agent, the notification flag is ignored.\n",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "notifyListingAgent",
            "in": "query",
            "required": false,
            "description": "Set to `true` to notify listing agent. If the user is the assigned Listing Agent, the notification flag is ignored.\n",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "notifyLender",
            "in": "query",
            "required": false,
            "description": "Set to `true` to notify lender. If the user is the assigned Lender, the notification flag is ignored.\n",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Returns a call log object. The response includes a callLogId that uniquely identifies the call log. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "callLogId": {
                      "type": "number",
                      "format": "int64",
                      "example": 678,
                      "readOnly": true,
                      "description": "The main identifier for each call log. Value set by BoomTown.\n"
                    },
                    "contactId": {
                      "type": "number",
                      "format": "int64",
                      "example": 123,
                      "readOnly": true,
                      "description": "The identifier for the contact associated with the callLog. Value set by BoomTown.\n"
                    },
                    "userId": {
                      "type": "number",
                      "format": "int64",
                      "example": 456,
                      "readOnly": true,
                      "description": "The identifier for the user associated with the callLog. Value set by BoomTown.\n"
                    },
                    "callDetails": {
                      "type": "string",
                      "example": "Tim wants to tour a home next week",
                      "description": "Description and any notes about the call.\n"
                    },
                    "isPrivate": {
                      "type": "boolean",
                      "example": true,
                      "description": "If set to `true`, indicates the note is viewable only by the author, and hidden from others in the organization.\n"
                    },
                    "logType": {
                      "type": "string",
                      "enum": [
                        "phoneConversation",
                        "leftMessage",
                        "callAttempt",
                        "wrongNumber",
                        "optedOut",
                        "notSelected"
                      ],
                      "example": "phoneConversation",
                      "description": "Outcome of the call. Allowed values:\n- `phoneConversation`\n- `leftMessage`\n- `callAttempt` (no message left)\n- `wrongNumber`\n- `optedOut`\n- `notSelected`\n"
                    },
                    "contactPhoneId": {
                      "type": "number",
                      "format": "int64",
                      "example": 2,
                      "description": "Identifier matching to a particular phone for a contact.\n"
                    },
                    "dateCreated": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-27T14:45:14.703Z",
                      "readOnly": true,
                      "description": "Time the call log record was created. Value set by BoomTown.\n"
                    },
                    "dateModified": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-27T14:45:14.703Z",
                      "readOnly": true,
                      "description": "Time when the call log record was last changed. Value set by BoomTown.\n"
                    },
                    "callStartTime": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-15T16:51:08.530Z",
                      "readOnly": true,
                      "description": "Time the phone call started. Value set by BoomTown.\n"
                    },
                    "callEndTime": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-15T16:58:08.530Z",
                      "readOnly": true,
                      "description": "Time the phone call ended. Value set by BoomTown.\n"
                    }
                  },
                  "description": "The call log object contains all details and notes from phone conversations.\n",
                  "required": [
                    "callLogId",
                    "contactId",
                    "isPrivate",
                    "logType",
                    "dateCreated",
                    "dateModified"
                  ]
                },
                "examples": {
                  "response": {
                    "value": {
                      "callLogId": 678,
                      "contactId": 123,
                      "userId": 456,
                      "callDetails": "Tim wants to tour a home next week",
                      "isPrivate": true,
                      "logType": "phoneConversation",
                      "contactPhoneId": 2,
                      "dateCreated": "2016-01-27T14:45:14.703Z",
                      "dateModified": "2016-01-27T14:45:14.703Z",
                      "callStartTime": "2016-01-15T16:51:08.530Z",
                      "callEndTime": "2016-01-15T16:58:08.530Z"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": {
                    "type": "number",
                    "format": "int64",
                    "example": 456,
                    "readOnly": true,
                    "description": "The identifier for the user associated with the callLog. Value set\nby BoomTown.\n"
                  },
                  "contactId": {
                    "type": "number",
                    "format": "int64",
                    "example": 123,
                    "readOnly": true,
                    "description": "The identifier for the contact associated with the callLog. Value\nset by BoomTown.\n"
                  },
                  "callDetails": {
                    "type": "string",
                    "example": "Tim wants to tour a home next week",
                    "description": "Description and any notes about the call.\n"
                  },
                  "isPrivate": {
                    "type": "boolean",
                    "example": true,
                    "description": "If set to `true`, indicates the note is viewable only by the author,\nand hidden from others in the organization.\n"
                  },
                  "logType": {
                    "type": "string",
                    "enum": [
                      "phoneConversation",
                      "leftMessage",
                      "callAttempt",
                      "wrongNumber",
                      "optedOut",
                      "notSelected"
                    ],
                    "example": "phoneConversation",
                    "description": "Outcome of the call. Allowed values:\n- `phoneConversation`\n- `leftMessage`\n- `callAttempt` (no message left)\n- `wrongNumber`\n- `optedOut`\n- `notSelected`\n"
                  },
                  "contactPhoneId": {
                    "type": "number",
                    "format": "int64",
                    "example": 2,
                    "description": "Identifier matching to a particular phone for a contact.\n"
                  },
                  "callStartTime": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2016-01-15T16:51:08.530Z",
                    "readOnly": true,
                    "description": "Time the phone call started. Value set by BoomTown.\n"
                  },
                  "callEndTime": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2016-01-15T16:58:08.530Z",
                    "readOnly": true,
                    "description": "Time the phone call ended. Value set by BoomTown.\n"
                  }
                }
              }
            }
          },
          "description": "Call log object to be added.",
          "required": true
        }
      },
