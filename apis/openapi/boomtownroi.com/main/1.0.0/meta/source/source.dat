          "description": "Contact object",
          "required": true
        }
      },
      "get": {
        "x-boomtown-external": true,
        "tags": [
          "contacts"
        ],
        "summary": "Get contacts",
        "description": "Retrieve all contacts that the current user has access to.",
        "operationId": "getContacts",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "description": "Complies with Paging defaults *(See Request Filtering: Paging)*.\n",
            "schema": {
              "type": "integer",
              "maximum": 250,
              "default": 50
            }
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "description": "Complies with Paging defaults *(See Request Filtering: Paging)*.\n",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "orderby",
            "in": "query",
            "description": "Applies to `contactId`, `orgId`, `visitorId`, `dateCreated`.  \n\nSpecify the ordered parameter(s) followed by the direction&#58; ascending (ASC) or descending (DESC). See *Request Filtering: Ordering (in API Standards)*.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "where",
            "in": "query",
            "description": "Applies to `contactId`, `orgId`, `userId`, `visitorId`, `dateCreated`, `dateModified (gt only)`, `orgTag (eq only)`.  \n\nSpecify the where parameter followed by the property name and value pair, and optional operation. See *Request Filtering&#58; Selecting (in API Standards)*\n",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns an array of contact objects accessible to the current logged in user. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Contact"
                  }
                },
                "examples": {
                  "response": {
                    "value": [
                      {
                        "contactId": 3532,
                        "orgId": 23,
                        "firstName": "John",
                        "lastName": "Smith",
                        "visitorId": 35426,
                        "sourceId": "OPENHOUSE",
                        "sourceName": "Open House",
                        "contactBy": "Text",
