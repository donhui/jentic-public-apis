{
  "openapi": "3.0.3",
  "x-boomtown-external-only": true,
  "info": {
    "title": "BoomTown API",
    "version": "1.0.0",
    "description": "\nBoomTown uses the OAuth v2.0 protocol for authentication and authorization, and allows you to access to the API on behalf of a user without obtaining their password.\n\nClients are issued a `client_id` and `client_secret`. All redirect URIs must be pre-registered. The following list are the various codes and how they are used to gain access to the APIs.\n\n*Authorization code*<br/> <ul><li>Lifetime of 5 minutes</li><li>Used only once</li></ul>\n*Access token*<br/><ul><li>Used as many times as desired within the lifetime of the token.</li> <li>The token lifespan will be returned with the token object</li></ul>\n*Refresh token*<br/><ul><li>Indefinite lifetime</li><li>Used to generate new access tokens</li><li>Store in secure persistent storage</li><li>This token should never be exposed on a client-side page or application</li></ul>\n",
    "x-jentic-source-url": "https://boomtown-api.readme.io/"
  },
  "x-samples-languages": [
    "curl",
    "csharp",
    "go",
    "java",
    "javascript",
    "node",
    "python",
    "ruby",
    "swift"
  ],
