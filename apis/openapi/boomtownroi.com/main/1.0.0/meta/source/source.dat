    "/contacts/{contactId}/emailAddresses": {
      "post": {
        "x-boomtown-external": true,
        "tags": [
          "Email Addresses"
        ],
        "summary": "Add email address",
        "description": "Create a new email address for a contact.",
        "operationId": "addEmailAddress",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          },
          {
            "name": "emailAddressId",
            "in": "query",
            "required": false,
            "description": "Primary identifier for the email address. Use to retrieve a series of emails with the same subject line.",
            "schema": {
              "type": "number",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Returns an email address object and either a 200 (OK) or 201 (Created) status code in the header. The response includes a emailAddressId that uniquely identifies the email address.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Email_Address"
                },
                "examples": {
                  "response": {
                    "value": {
                      "emailAddressId": 123,
                      "emailAddress": "JohnSmith@BoomTownROI.com",
                      "isLogin": true,
                      "isPrimary": true,
                      "description": null,
                      "emailAddressStatus": "unknown",
                      "contactId": 123,
                      "dateCreated": "2016-01-27T14:45:14.703Z",
                      "dateModified": "2016-01-27T14:45:14.703Z"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "emailAddress": {
                    "type": "string",
                    "example": "JohnSmith@BoomTownROI.com",
                    "description": "The email address."
                  },
                  "isLogin": {
                    "type": "boolean",
                    "example": true,
                    "description": "If set to `true`, this email is used to login. Defaults to `true` if\nthere are no other emails for the contact.\n"
                  },
                  "isPrimary": {
                    "type": "boolean",
                    "example": true,
                    "description": "If set to `true`, send all emails to this address. Defaults to `true`\nif no other email addresses exist for the contact.\n"
                  },
                  "description": {
                    "type": "string",
                    "example": null,
                    "description": "A brief note about the email address."
                  },
                  "emailAddressStatus": {
                    "type": "string",
                    "enum": [
                      "unknown",
                      "validAddress",
                      "invalidAddress",
                      "twoWayEmailing",
                      "optedOut"
                    ],
                    "example": "unknown",
                    "description": "The status of the email address. \n\n- Defaults to `unknown`(default)\n- `twoWayEmailing`: has been used in communication\n- `optedOut`: contact has requested no contact via email\n"
                  },
                  "contactId": {
                    "type": "number",
                    "format": "int64",
                    "example": 123,
                    "readOnly": true,
                    "description": "Contact identifier for the contact who owns the email address. Value\nset by BoomTown.\n"
                  }
                }
              }
            }
          },
          "description": "Email address object to add.",
          "required": true
        }
      },
