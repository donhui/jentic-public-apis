    "/contacts/{contactId}/emails": {
      "get": {
        "x-boomtown-external": true,
        "tags": [
          "Emails"
        ],
        "summary": "Get emails by contact",
        "description": "Retrieve all emails for a contact.",
        "operationId": "getEmailByContactId",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          },
          {
            "name": "threadId",
            "in": "query",
            "required": false,
            "description": "Primary identifier for the email thread. Use to retrieve a series of emails with the same subject line.",
            "schema": {
              "type": "number",
              "format": "int64"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "description": "Complies with Paging defaults *(See Request Filtering: Paging)*.\n",
            "schema": {
              "type": "integer",
              "maximum": 250,
              "default": 50
            }
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "description": "Complies with Paging defaults *(See Request Filtering: Paging)*.\n",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "orderby",
            "in": "query",
            "description": "Applies to `emailId`, `authorId`, `emailType`, `dripEmail`, `ownerId`, `dateCreated`\n\nSpecify the ordered parameter(s) followed by the direction&#58; ascending (ASC) or descending (DESC). See *Request Filtering: Ordering (in API Standards)*.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "where",
            "in": "query",
            "description": "Applies to `emailId`, `authorId`, `emailType`, `dripEmail`, `ownerId`, `threadId`, `hasAttachments`, `dateCreated`\n\nSpecify the where parameter followed by the property name and value pair, and optional operation. See *Request Filtering&#58; Selecting (in API Standards)*\n",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Returns an array of email objects.  For help with error codes, refer to *HTTP Status Codes (in API Standards)*.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Email"
                  }
                },
                "examples": {
                  "response": {
                    "value": [
                      {
                        "emailId": 123,
                        "orgId": 2,
                        "contactId": 2223,
                        "ownerId": 2,
                        "threadId": "string",
                        "authorId": 47,
                        "emailType": "outBound",
                        "openDate": "2018-10-21T20:53:00.701Z",
                        "replyDate": "2015-07-21T16:07:38.788Z",
                        "alertDismissedDate": "2015-07-21T16:08:38.788Z",
