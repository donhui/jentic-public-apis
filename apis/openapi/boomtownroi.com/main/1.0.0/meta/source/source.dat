      "Email_Template": {
        "type": "object",
        "properties": {
          "templateId": {
            "type": "number",
            "format": "int64",
            "example": 123,
            "readOnly": true,
            "description": "The primary identifier for an email template. Value set by BoomTown."
          },
          "body": {
            "type": "string",
            "example": "Hello {VisitorName}. This is {AgentFirstName} {AgentLastName} with {CompanyName}.",
            "description": "Body of the email, still containing the replacement tokens.\n\nValid tokens include: \n- CompanyName\n- CompanyNameAsLink\n- CompanyWebsite\n- CompanyWebsiteAsLink\n- CompanyServiceArea\n- CompanyListingsNew\n- CompanyListingsForeclosures\n- CompanyListingsReduced\n- TimeOfDay\n- DayOfWeek\n- Season\n- ListingBeginSection\n- ListingAddress\n- ListingCity\n- ListingEndSection\n- AgentBeginSection\n- AgentFirstName\n- AgentLastName\n- AgentEmail\n- AgentAlias\n- AgentMobilePhone\n- AgentOfficePhone\n- AgentSignature\n- AgentEndSection\n- LenderBeginSection\n- LenderEndSection\n- LenderAlias\n- LenderEmail\n- LenderFirstName\n- LenderLastName\n- LenderMobilePhone\n- LenderOfficePhone\n- LenderSignature\n- VisitorFirstName\n- VisitorLastName\n- WebsiteLink:\"Saved Searches\"\n- WebsiteLink:\"Favorites\"\n"
          },
          "subject": {
            "type": "string",
            "description": "Subject of the email, still containing the replacement tokens."
          },
          "title": {
            "type": "string",
            "example": "Visitor Greeting Number 1",
            "description": "Short description of the template."
          },
          "type": {
            "type": "string",
            "enum": [
              "organization",
              "user"
            ],
            "example": "user",
            "readOnly": true,
            "description": "Determines the level of access. Value set by BoomTown.\n<br>Allowed values: \n- organization: available to anyone in the organization\n- user: private to user'\n"
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-12-13 11:27:30.937",
            "readOnly": true,
            "description": "Time the email template was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-12-15 13:01:27.012",
            "readOnly": true,
            "description": "Time when the email template was last changed. Value set by BoomTown."
          }
        },
        "description": "An email template object contains the template title, body, subject, and all ownership information for the template that defines who is allowed to use the template (e.g., user only, or all users in an organization)\n",
        "required": [
          "templateId",
          "subject",
          "title",
          "type",
          "dateCreated",
          "dateModified"
        ]
      },
      "Email_Template_Rendered": {
        "type": "object",
        "properties": {
          "templateId": {
            "type": "number",
            "format": "int64",
            "example": 12342,
            "readOnly": true,
            "description": "The primary identifier for an email template. Value set by BoomTown."
          },
          "body": {
            "type": "string",
            "example": "Hello Rutherford. This is John Smith with RealBigFish.",
            "description": "Body of the email, with the replacement tokens substituted."
          },
          "subject": {
            "type": "string",
            "example": "Hello Rutherford",
            "description": "Subject of the email, with the replacement tokens substituted."
          },
          "title": {
            "type": "string",
            "example": "Visitor Greeting 1",
            "description": "Short description of the template."
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fileUploadId": {
                  "type": "number",
                  "format": "int64",
                  "example": 15,
                  "description": "The primary identifier for the attachment. Value set by BoomTown."
                },
                "fileName": {
                  "type": "string",
                  "example": "Welcome.txt",
                  "description": "Name of the attachment, including extension."
                },
                "contentType": {
                  "type": "string",
                  "description": "The type of attachment.",
                  "example": "text/plain\n"
                },
                "contentLength": {
                  "type": "number",
                  "description": "The size of attachment.",
                  "example": 1000
                }
              },
              "description": "A template attachment object contains the attachment name, type, content length, and fileUploadId.\n"
            },
            "description": "List of Template Attachments associated with the template"
          },
          "dateRendered": {
            "type": "string",
            "format": "date-time",
            "example": "2016-12-13 11:27:30.937",
            "readOnly": true,
            "description": "Time the email template was rendered. Value set by BoomTown."
          },
          "dateCreated": {
            "type": "string",
            "format": "date-time",
            "example": "2016-12-13 11:27:30.937",
            "readOnly": true,
            "description": "Time the email template was created. Value set by BoomTown."
          },
          "dateModified": {
            "type": "string",
            "format": "date-time",
            "example": "2016-12-15 13:01:27.012",
            "readOnly": true,
            "description": "Time when the email template was last changed. Value set by BoomTown."
          }
        },
        "description": "A rendered email template object contains the template title, rendered body and subject (replacement tokens substituted), and the date rendered.\n",
        "required": [
          "templateId",
          "subject",
          "title",
          "dateRendered",
          "dateCreated",
          "dateModified"
        ]
      },
