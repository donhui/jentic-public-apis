    "/contacts/{contactId}/assignedDripPlans": {
      "post": {
        "x-boomtown-external": true,
        "tags": [
          "Assigned Drip Plans"
        ],
        "summary": "Assign drip plan to contact",
        "description": "Assign a contact to a drip plan.",
        "operationId": "assignDripPlan",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          }
        ],
        "responses": {
          "default": {
            "description": "Returns an assigned drip plan object. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "assignedDripPlanId": {
                      "type": "string",
                      "example": "MTU2NDY6OjI0",
                      "readOnly": true,
                      "description": "The primary identifier of an assigned drip plan. Value set by BoomTown."
                    },
                    "dripPlanId": {
                      "type": "number",
                      "format": "int64",
                      "example": 302,
                      "description": "The identifier of drip plan."
                    },
                    "orgId": {
                      "type": "number",
                      "format": "int64",
                      "example": 23,
                      "readOnly": true,
                      "description": "The identifier of the organization. Value set by BoomTown."
                    },
                    "contactId": {
                      "type": "number",
                      "format": "int64",
                      "example": 23409,
                      "description": "The identifier of the contact."
                    },
                    "userId": {
                      "type": "number",
                      "format": "int64",
                      "example": 4567,
                      "description": "UserId responsible for the assigned plan."
                    },
                    "status": {
                      "description": "Assigned Drip Plan Status containing details about the status of\nthe drip plan.\n",
                      "type": "object",
                      "properties": {
                        "dateOfNextDrip": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "description": "Time of the next content drip."
                        },
                        "dateOfLastDrip": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-26T14:45:14.703Z",
                          "description": "Time of the last content drip."
                        },
                        "assignedDripStatus": {
                          "type": "string",
                          "enum": [
                            "paused",
                            "ended",
                            "terminated"
                          ],
                          "example": "running",
                          "description": "Status of the campaign. Use to restart, pause or terminate a drip\ncampaign for a contact.<br>Allowed values: `running` (default)`paused``ended``terminated`\n"
                        },
                        "dateCompleted": {
                          "type": "string",
                          "format": "date-time",
                          "example": null,
                          "description": "Time the drip campaign completed."
                        },
                        "nextStepInPlan": {
                          "type": "number",
                          "format": "int64",
                          "example": 3,
                          "description": "The identifier of the next drip step in the campaign."
                        }
                      }
                    },
                    "name": {
                      "type": "string",
                      "example": "Long-Term Drip Campaign",
                      "description": "Assigned drip plan name"
                    },
                    "description": {
                      "type": "string",
                      "example": "BoomTown Long-Term Drip Campaign",
                      "description": "Description of the assigned drip plan"
                    },
                    "stepCount": {
                      "type": "number",
                      "example": 1,
                      "description": "Number of steps in the drip plan"
                    },
                    "dripPlanType": {
                      "type": "string",
                      "enum": [
                        "company",
                        "system",
                        "user"
                      ],
                      "example": "company",
                      "description": "Visibility of the drip plan. Allowed values: `company`, `system`, `user`"
                    },
                    "dateCreated": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-27T14:45:14.703Z",
                      "readOnly": true,
                      "description": "Time the drip plan was assigned to the contact. Value set by BoomTown."
                    },
                    "dateModified": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2016-01-27T14:45:14.703Z",
                      "readOnly": true,
                      "description": "Time when the assigned plan was last changed. Value set by BoomTown."
                    }
                  },
                  "description": "The assigned drip plan object contains basic assignments for the drip plan, including the organization that owns the drip plan and associated user and contact.\n",
                  "required": [
                    "assignedDripPlanId",
                    "dripPlanId",
                    "orgId",
                    "contactId",
                    "userId",
                    "dateCreated",
                    "dateModified"
                  ]
                },
                "examples": {
                  "response": {
                    "value": {
                      "assignedDripPlanId": "MTU2NDY6OjI0",
                      "dripPlanId": 302,
                      "orgId": 23,
                      "contactId": 23409,
                      "userId": 4567,
                      "status": null,
                      "dateOfNextDrip": "2016-01-27T14:45:14.703Z",
                      "dateOfLastDrip": "2016-01-26T14:45:14.703Z",
                      "assignedDripStatus": "running",
                      "dateCompleted": null,
                      "nextStepInPlan": 3,
                      "name": "Long-Term Drip Campaign",
                      "description": "BoomTown Long-Term Drip Campaign",
                      "stepCount": 1,
                      "dripPlanType": "company",
                      "dateCreated": "2016-01-27T14:45:14.703Z",
                      "dateModified": "2016-01-27T14:45:14.703Z"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "dripPlanId": {
                    "type": "number",
                    "format": "int64",
                    "example": 302
                  },
                  "orgId": {
                    "type": "number",
                    "format": "int64",
                    "example": 23
                  },
                  "contactId": {
                    "type": "number",
                    "format": "int64",
                    "example": 23409
                  },
                  "userId": {
                    "type": "number",
                    "format": "int64",
                    "example": 4567
                  }
                }
              }
            }
          },
          "description": "Drip Plan object to be assigned.\n",
          "required": true
        }
      }
    },
