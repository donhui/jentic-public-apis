        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contactBy": {
                    "type": "string",
                    "example": "Text"
                  },
                  "communicationPreferences": {
                    "type": "object",
                    "properties": {
                      "eAlertStatus": {
                        "type": "string",
                        "enum": [
                          "active",
                          "agentUnsubscribed",
                          "contactUnsubscribed"
                        ],
                        "example": "Active"
                      }
                    }
                  },
                  "physicalAddresses": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "contactAddressId": {
                          "type": "number",
                          "format": "int64",
                          "example": 456,
                          "readOnly": true,
                          "description": "Primary identifier. Value set by BoomTown."
                        },
                        "contactId": {
                          "type": "number",
                          "format": "int64",
                          "example": 123,
                          "readOnly": true,
                          "description": "The contact associated with the address. Value set by BoomTown."
                        },
                        "address": {
                          "type": "string",
                          "example": "635 Rutledge Avenue",
                          "description": "Street number and name. May include apt, suite, or other."
                        },
                        "city": {
                          "type": "string",
                          "example": "Charleston",
                          "description": "City"
                        },
                        "state": {
                          "type": "string",
                          "example": "SC",
                          "description": "State (US), Province (Canada)."
                        },
                        "zipCode": {
                          "type": "string",
                          "example": "29403",
                          "description": "Zip code (US), Postal code (Canada)."
                        },
                        "addressChangedByUserId": {
                          "type": "number",
                          "format": "int64",
                          "example": 789,
                          "readOnly": true,
                          "description": "User who last updated the physical address (modified by the contact via visitor or by a CRM user). Value set by BoomTown."
                        },
                        "addressEntryType": {
                          "type": "string",
                          "enum": [
                            "notSpecified",
                            "systemIPCalc",
                            "contactEntered",
                            "agentEntered",
                            "lenderEntered",
                            "adminEntered"
                          ],
                          "example": "agentEntered",
                          "description": "How the address was entered. <br>Allowed values: \n- `notSpecified`(default) \n- `systemIPCalc`\n- `contactEntered`\n- `agentEntered`\n- `lenderEntered`\n- `adminEntered`\n"
                        },
                        "addressType": {
                          "type": "string",
                          "enum": [
                            "NotSpecified",
                            "Home",
                            "MailAddress",
                            "Office"
                          ],
                          "description": "Disabled, Future release. Allowed values:  `Home` `Office` `NotSpecified``MailAddress`"
                        },
                        "description": {
                          "type": "string",
                          "description": "Disabled, Future release. Optional description for the address."
                        },
                        "dateCreated": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time the address was created. Value set by BoomTown."
                        },
                        "dateModified": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time when the address was last changed. Value set by BoomTown."
                        }
                      },
                      "description": "The address object contains details of a contact\u2019s physical address.\n",
                      "required": [
                        "contactAddressId",
                        "contactId",
                        "addressEntryType",
                        "dateCreated",
                        "dateModified"
                      ]
                    }
                  },
                  "emailAddresses": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "emailAddressId": {
                          "type": "number",
                          "format": "int64",
                          "example": 123,
                          "readOnly": true,
                          "description": "The primary identifier for the email address. Value set by BoomTown.\n"
                        },
                        "emailAddress": {
                          "type": "string",
                          "example": "JohnSmith@BoomTownROI.com",
                          "description": "The email address."
                        },
                        "isLogin": {
                          "type": "boolean",
                          "example": true,
                          "description": "If set to `true`, this email is used to login. Defaults to `true` if\nthere are no other emails for the contact.\n"
                        },
                        "isPrimary": {
                          "type": "boolean",
                          "example": true,
                          "description": "If set to `true`, send all emails to this address. Defaults to `true`\nif no other email addresses exist for the contact.\n"
                        },
                        "description": {
                          "type": "string",
                          "example": null,
                          "description": "A brief note about the email address."
                        },
                        "emailAddressStatus": {
                          "type": "string",
                          "enum": [
                            "unknown",
                            "validAddress",
                            "invalidAddress",
                            "twoWayEmailing",
                            "optedOut"
                          ],
                          "example": "unknown",
                          "description": "The status of the email address. \n\n- Defaults to `unknown`(default)\n- `twoWayEmailing`: has been used in communication\n- `optedOut`: contact has requested no contact via email\n"
                        },
                        "contactId": {
                          "type": "number",
                          "format": "int64",
                          "example": 123,
                          "readOnly": true,
                          "description": "Contact identifier for the contact who owns the email address. Value\nset by BoomTown.\n"
                        },
                        "dateCreated": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time the email address was created. Value set by BoomTown."
                        },
                        "dateModified": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time when the email address was last changed. Value set by BoomTown."
                        }
                      },
                      "description": "The email address object contains information about a specific email address, including whether it is being used for login, or if is the best email to use for the contact. It also includes a current status showing if the email is known to be valid, if the contact has opted-out at this address, or has been used in recent communications.\n",
                      "required": [
                        "emailAddressId",
                        "emailAddress",
                        "contactId",
                        "dateCreated"
                      ]
                    }
                  },
                  "phoneNumbers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "phoneNumberId": {
                          "type": "number",
                          "format": "int64",
                          "example": 456,
                          "readOnly": true,
                          "description": "The primary identifier for the phone number. Value set by BoomTown.\n"
                        },
                        "label": {
                          "type": "string",
                          "example": "phone number for contact",
                          "description": "Descriptive label for the phone number (\"Work\", \"Cell\", etc...).\nDefaults to an empty string.\n"
                        },
                        "phoneNumber": {
                          "type": "string",
                          "example": "123-456-7890",
                          "description": "The phone number for the contact."
                        },
                        "phoneStatus": {
                          "type": "string",
                          "enum": [
                            "unknown",
                            "active",
                            "valid",
                            "optedOut",
                            "wrongNumber"
                          ],
                          "example": "active",
                          "description": "'The status of the phone number. \n"
                        },
                        "contactId": {
                          "type": "number",
                          "format": "int64",
                          "example": 123,
                          "readOnly": true,
                          "description": "The identifier for the contact which is associated with the phone\nnumber. Value set by BoomTown.\n"
                        },
                        "phoneType": {
                          "type": "string",
                          "enum": [
                            "mobile",
                            "landline",
                            "voip",
                            "other"
                          ],
                          "example": "mobile",
                          "description": "'The type of the phone.\n"
                        },
                        "dateCreated": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time the phone number was created. Value set by BoomTown.\n"
                        },
                        "dateModified": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time when the phone number was last changed. Value set by BoomTown.\n"
                        }
                      },
                      "description": "A phone number object contains a description and status for each phone number.\n",
                      "required": [
                        "phoneNumberId",
                        "phoneNumber",
                        "contactId",
                        "dateCreated",
                        "dateModified"
                      ]
                    }
                  },
                  "associatedUsers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "associatedUserId": {
                          "type": "number",
                          "format": "int64",
                          "example": 1233,
                          "readOnly": true,
                          "description": "Primary identifier for the associated user relationship. Value set by BoomTown.\n"
                        },
                        "contactId": {
                          "type": "number",
                          "format": "int64",
                          "example": 33,
                          "description": "Primary identifier for the contact."
                        },
                        "userId": {
                          "type": "number",
                          "format": "int64",
                          "example": 3438,
                          "description": "User associated with the contact."
                        },
                        "contactCategory": {
                          "type": "string",
                          "enum": [
                            "new",
                            "trash",
                            "watch",
                            "qualify",
                            "nurture",
                            "hot",
                            "archive",
                            "closed",
                            "pending"
                          ],
                          "example": "nurture",
                          "description": "Status of the contact associated with the user. Allowed values:\n- `new`\n- `trash`: using another agent\n- `watch`: just looking, no timeframe\n- `qualify`: new and unqualified\n- `nurture`: more than 3 months out\n- `hot: working towards a deal\n- `archive`: archive contact for later\n- `closed`: deal closed\n- `pending`: contact pending\n"
                        },
                        "categoryDate": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-26T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time the contact category was assigned. Value set by BoomTown."
                        },
                        "assignedDate": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-26T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time the contact was assigned. Value set by BoomTown."
                        },
                        "communicationStatus": {
                          "type": "string",
                          "enum": [
                            "active",
                            "agentUnsubscribed",
                            "contactUnsubscribed",
                            "lenderUnsubscribed"
                          ],
                          "example": "active",
                          "description": "If communication is allowed with the contact; and if not, who unsubsribed\nthem. Allowed values: `active` (default), `agentUnsubscribed`, `lenderUnsubscribed`,`contactUnsubscribed`\n"
                        },
                        "associatedUserType": {
                          "type": "string",
                          "enum": [
                            "buyerAgent",
                            "lender",
                            "sellerAgent"
                          ],
                          "example": "buyerAgent",
                          "description": "The role of the user in this relationship. Allowed values:`buyerAgent`,`lender`,`sellerAgent`"
                        },
                        "dateCreated": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time the associated user was created. Value set by BoomTown."
                        },
                        "dateModified": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2016-01-27T14:45:14.703Z",
                          "readOnly": true,
                          "description": "Time when the associated user was last changed. Value set by BoomTown."
                        }
                      },
                      "description": "An associated user object categorizes the user\u2019s relationship and communication status with the contact.\n",
                      "required": [
                        "associatedUserId",
                        "contactId",
                        "userId",
                        "associatedUserType",
                        "dateCreated",
                        "dateModified"
                      ]
                    }
                  },
                  "contactOriginType": {
                    "type": "string",
                    "enum": [
                      "WebRegistered",
                      "ManuallyAdded",
                      "ThirdPartyImport",
                      "AdminImport",
                      "ApiImport",
                      "ApiBulkImport"
                    ],
                    "example": "ApiBulkImport",
                    "description": "This status reflects where the contact originated. Allowed values:\n- `WebRegistered`\n- `ManuallyAdded`\n- `ThirdPartyImport`\n- `AdminImport`\n- `ApiImport`\n- `ApiBulkImport`\n"
                  }
                }
              }
            }
          },
          "description": "Partial contact object with attributes to be updated.",
          "required": true
        }
      }
    },
    "/contacts/{contactId}/associatedUsers": {
      "post": {
        "x-boomtown-external": true,
        "tags": [
          "associated users"
        ],
        "summary": "Create a new connection between a contact and a user.",
        "description": "Add associated user",
        "operationId": "addAssociatedUser",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          },
          {
            "$ref": "#/components/parameters/notifyLenderQueryParam"
          },
          {
            "$ref": "#/components/parameters/notifyListingParam"
          },
          {
            "$ref": "#/components/parameters/notifyBuyerAgentQueryParam"
          }
        ],
        "responses": {
          "default": {
            "description": "Returns an associated user object. The response includes an associatedUserId that uniquely identifies the associated user relationship. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Associated_User"
                },
                "examples": {
                  "response": {
                    "value": {
                      "associatedUserId": 1233,
                      "contactId": 33,
                      "userId": 3438,
                      "contactCategory": "nurture",
                      "categoryDate": "2016-01-26T14:45:14.703Z",
                      "assignedDate": "2016-01-26T14:45:14.703Z",
                      "communicationStatus": "active",
                      "associatedUserType": "buyerAgent",
                      "dateCreated": "2016-01-27T14:45:14.703Z",
                      "dateModified": "2016-01-27T14:45:14.703Z"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contactId": {
                    "type": "number",
                    "format": "int64",
                    "example": 33,
                    "description": "Primary identifier for the contact."
                  },
                  "userId": {
                    "type": "number",
                    "format": "int64",
                    "example": 3438,
                    "description": "User associated with the contact."
                  },
                  "contactCategory": {
                    "type": "string",
                    "enum": [
                      "new",
                      "trash",
                      "watch",
                      "qualify",
                      "nurture",
                      "hot",
                      "archive",
                      "closed",
                      "pending"
                    ],
                    "example": "nurture",
                    "description": "Status of the contact associated with the user. Allowed values:\n- `new`\n- `trash`: using another agent\n- `watch`: just looking, no timeframe\n- `qualify`: new and unqualified\n- `nurture`: more than 3 months out\n- `hot: working towards a deal\n- `archive`: archive contact for later\n- `closed`: deal closed\n- `pending`: contact pending\n"
                  },
                  "categoryDate": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2016-01-26T14:45:14.703Z",
                    "readOnly": true,
                    "description": "Time the contact category was assigned. Value set by BoomTown."
                  },
                  "assignedDate": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2016-01-26T14:45:14.703Z",
                    "readOnly": true,
                    "description": "Time the contact was assigned. Value set by BoomTown."
                  },
                  "communicationStatus": {
                    "type": "string",
                    "enum": [
                      "active",
                      "agentUnsubscribed",
                      "contactUnsubscribed",
                      "lenderUnsubscribed"
                    ],
                    "example": "active",
                    "description": "If communication is allowed with the contact; and if not, who unsubsribed\nthem. Allowed values: `active` (default), `agentUnsubscribed`, `lenderUnsubscribed`,`contactUnsubscribed`\n"
                  },
                  "associatedUserType": {
                    "type": "string",
                    "enum": [
                      "buyerAgent",
                      "lender",
                      "sellerAgent"
                    ],
                    "example": "buyerAgent",
                    "description": "The role of the user in this relationship. Allowed values:`buyerAgent`,`lender`,`sellerAgent`"
                  }
                }
              }
            }
          },
          "description": "The associated user object to be added.",
          "required": true
        }
      },
