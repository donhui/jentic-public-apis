                    "type": "array",
                    "example": [
                      "john@gmail.com",
                      "alice@gmail.com"
                    ],
                    "items": {
                      "type": "string"
                    }
                  },
                  "location": {
                    "type": "string",
                    "example": "Somewhere"
                  }
                }
              }
            }
          },
          "description": "Partial todo object with attributes to be updated.",
          "required": true
        }
      },
      "put": {
        "x-boomtown-external": true,
        "tags": [
          "todos"
        ],
        "summary": "Replace todo",
        "description": "Partially replace the information for a task.",
        "operationId": "replaceContactTodo",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          },
          {
            "$ref": "#/components/parameters/todoIdParam"
          }
        ],
        "responses": {
          "default": {
            "description": "Returns the saved todo object, including metadata. For help with error codes, refer to *HTTP Status Codes (in API Standards)*.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Todo"
                },
                "examples": {
                  "response": {
                    "value": {
                      "todoId": 123,
                      "contactId": 2,
                      "authorId": 57,
                      "ownerId": 57,
                      "isPrivate": false,
                      "todoType": "call",
                      "label": null,
                      "body": "Call Bill about buying a home",
                      "timeFrame": "2days",
                      "dueDate": "2016-01-15T16:51:08.530Z",
                      "dueDateType": "specific",
                      "alertDate": "2016-01-15T16:51:08.530Z",
                      "completeDate": null,
                      "dateCreated": "2016-01-27T14:45:14.703Z",
                      "dateModified": "2016-01-27T14:45:14.703Z",
                      "createdBy": "dripGenerated",
                      "isCalendarSyncEnabled": true,
                      "invitees": [
                        "john@gmail.com",
                        "alice@gmail.com"
                      ],
                      "location": "Somewhere"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contactId": {
                    "type": "number",
                    "format": "int64",
                    "example": 2,
                    "description": "Id of the contact associated with the todo."
                  },
                  "authorId": {
                    "type": "number",
                    "format": "int64",
                    "example": 57,
                    "readOnly": true,
                    "description": "Id number of the user who created the todo. Value set by  BoomTown."
                  },
                  "ownerId": {
                    "type": "number",
                    "format": "int64",
                    "example": 57,
                    "readOnly": true,
                    "description": "Id number of user whom the todo belongs. With Contacts, may be different from authorId, but defaults to authorId if not specified when\nthe todo is created. For users, the value is set by BoomTown.\n"
                  },
                  "isPrivate": {
                    "type": "boolean",
                    "example": false,
                    "description": "If set to `true`, the todo is visible only to the user and is not shared with others in the organization.\n"
                  },
                  "todoType": {
                    "type": "string",
                    "enum": [
                      "custom",
                      "call",
                      "email",
                      "fax",
                      "mail",
                      "followUp",
                      "meeting",
                      "arrivalDate",
                      "showing",
                      "closing",
                      "openHouse",
                      "thankYou",
                      "text"
                    ],
                    "example": "call",
                    "description": "Type of action the user needs to take. Defaults to `custom`."
                  },
                  "label": {
                    "type": "string",
                    "example": null,
                    "description": "Label for display if `todoType` is set to `custom`."
                  },
                  "body": {
                    "type": "string",
                    "example": "Call Bill about buying a home",
                    "description": "Description of what to do."
                  },
                  "timeFrame": {
                    "type": "string",
                    "enum": [
                      "later",
                      "today",
                      "tomorrow",
                      "2days",
                      "3days",
                      "1week",
                      "2weeks",
                      "3weeks",
                      "1month",
                      "thisWeek",
                      "nextWeek",
                      "specific"
                    ],
                    "example": "2days",
                    "description": "When the task should be completed.  Defaults to `later`."
                  },
                  "dueDate": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2016-01-15T16:51:08.530Z",
                    "description": "Time when the todo is due."
                  },
                  "dueDateType": {
                    "type": "string",
                    "enum": [
                      "anytime",
                      "specific"
                    ],
                    "example": "specific",
                    "description": "Modifier on dueDate. Defaults to `specific`."
                  },
                  "alertDate": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2016-01-15T16:51:08.530Z",
                    "description": "Time to remind the user."
                  },
                  "completeDate": {
                    "type": "string",
                    "format": "date-time",
                    "example": null,
                    "description": "Time completed."
                  },
                  "createdBy": {
                    "type": "string",
                    "enum": [
                      "notSpecified",
                      "self",
                      "anotherUser",
                      "dripCampaign"
                    ],
                    "example": "dripGenerated",
                    "description": "Specifies who/what generated the Todo. Defaults to `notSpecified`.\n"
                  },
                  "isCalendarSyncEnabled": {
                    "example": true,
                    "type": "boolean"
                  },
                  "invitees": {
                    "type": "array",
                    "example": [
                      "john@gmail.com",
                      "alice@gmail.com"
                    ],
                    "items": {
                      "type": "string"
                    }
                  },
                  "location": {
                    "type": "string",
                    "example": "Somewhere"
                  }
                }
              }
            }
          },
          "description": "Valid todo object of non-read-only attributes in the body.",
          "required": true
        }
      },
      "delete": {
        "x-boomtown-external": true,
        "tags": [
          "todos"
        ],
        "summary": "Delete todo",
        "description": "Delete a todo task.",
        "operationId": "deleteContactTodo",
        "parameters": [
          {
            "$ref": "#/components/parameters/contactIdParam"
          },
          {
            "$ref": "#/components/parameters/todoIdParam"
          }
        ],
        "responses": {
          "204": {
            "description": "Deletion successful. For help with error codes, refer to *HTTP Status Codes (in API Standards)*."
          },
          "403": {
            "description": "User doesn\u2019t have the rights to perform the operation. For help with error codes, refer to *HTTP Status Codes (in API Standards)*."
          }
        }
      }
    },
