{
  "openapi": "3.0.3",
  "info": {
    "title": "Infobip API",
    "version": "1.0.0",
    "description": "Infobip omnichannel communications platform API supporting SMS, Email, WhatsApp, Viber, Voice, MMS, RCS, Push notifications, 2FA, and Number Lookup.",
    "x-jentic-source-url": "https://www.infobip.com/docs/api"
  },
  "servers": [
    {
      "url": "https://{baseUrl}.api.infobip.com",
      "variables": {
        "baseUrl": {
          "default": "api",
          "description": "Customer-specific base URL prefix"
        }
      }
    }
  ],
  "paths": {
    "/sms/2/text/advanced": {
      "post": {
        "operationId": "sendSmsMessage",
        "summary": "Send SMS message",
        "description": "Send one or more SMS messages to one or more destinations.",
        "tags": ["SMS"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SmsAdvancedTextualRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sms/2/binary/advanced": {
      "post": {
        "operationId": "sendBinarySmsMessage",
        "summary": "Send binary SMS message",
        "description": "Send one or more binary SMS messages to one or more destinations.",
        "tags": ["SMS"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SmsBinaryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sms/1/reports": {
      "get": {
        "operationId": "getSmsDeliveryReports",
        "summary": "Get SMS delivery reports",
        "description": "Get one-time delivery reports for sent SMS messages.",
        "tags": ["SMS"],
        "parameters": [
          {
            "name": "bulkId",
            "in": "query",
            "description": "Unique ID assigned to the request.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "messageId",
            "in": "query",
            "description": "Unique SMS message ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of reports to return.",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsDeliveryReportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sms/1/logs": {
      "get": {
        "operationId": "getSmsLogs",
        "summary": "Get SMS message logs",
        "description": "Get logs for sent SMS messages.",
        "tags": ["SMS"],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Sender address.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "Destination address.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bulkId",
            "in": "query",
            "description": "Bulk ID for which logs are requested.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "messageId",
            "in": "query",
            "description": "Message ID for which logs are requested.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sentSince",
            "in": "query",
            "description": "Lower limit on date and time of sending the message (ISO 8601).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "sentUntil",
            "in": "query",
            "description": "Upper limit on date and time of sending the message (ISO 8601).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of logs to return.",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsLogsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sms/1/inbox/reports": {
      "get": {
        "operationId": "getInboundSmsMessages",
        "summary": "Get inbound SMS messages",
        "description": "Get received (inbound/MO) SMS messages.",
