  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "requestError": {
            "type": "object",
            "properties": {
              "serviceException": {
                "type": "object",
                "properties": {
                  "messageId": {
                    "type": "string",
                    "description": "Unique error message ID."
                  },
                  "text": {
                    "type": "string",
                    "description": "Error message text."
                  }
                }
              }
            }
          }
        }
      },
      "SmsAdvancedTextualRequest": {
        "type": "object",
        "properties": {
          "bulkId": {
            "type": "string",
            "description": "Unique ID assigned to the request if messaging multiple recipients or sending multiple messages."
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SmsTextualMessage"
            },
            "description": "Array of messages to send."
          },
          "sendingSpeedLimit": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "integer",
                "description": "Speed limit value."
              },
              "timeUnit": {
                "type": "string",
                "enum": ["MINUTE", "HOUR", "DAY"],
                "description": "Time unit for speed limit."
              }
            }
          },
          "tracking": {
            "type": "object",
            "properties": {
              "track": {
                "type": "string",
                "description": "Tracking type."
              },
              "type": {
                "type": "string",
                "description": "Custom tracking type."
              }
            }
          }
        },
        "required": ["messages"]
      },
      "SmsTextualMessage": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "Sender ID (alphanumeric or numeric)."
          },
          "destinations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SmsDestination"
            },
            "description": "Array of destination objects."
          },
          "text": {
            "type": "string",
            "description": "Text of the message."
          },
          "language": {
            "type": "object",
            "properties": {
              "languageCode": {
                "type": "string",
                "description": "Language code for transliteration."
              }
            }
          },
          "transliteration": {
            "type": "string",
            "description": "Transliteration type."
          },
          "notifyUrl": {
            "type": "string",
            "description": "URL for delivery report webhook."
          },
          "notifyContentType": {
            "type": "string",
            "description": "Content type for delivery report webhook."
          },
          "callbackData": {
            "type": "string",
            "description": "Custom data included in delivery report."
          },
          "validityPeriod": {
            "type": "integer",
            "description": "Validity period in minutes."
          },
          "sendAt": {
            "type": "string",
            "format": "date-time",
            "description": "Scheduled send time (ISO 8601)."
          },
          "flash": {
            "type": "boolean",
            "description": "Send as flash SMS."
          },
          "intermediateReport": {
            "type": "boolean",
            "description": "Enable intermediate delivery reports."
          }
        },
        "required": ["destinations", "text"]
      },
      "SmsDestination": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "description": "Destination phone number (E.164 format)."
          },
          "messageId": {
            "type": "string",
            "description": "Unique message ID for this destination."
          }
        },
        "required": ["to"]
      },
      "SmsBinaryRequest": {
        "type": "object",
        "properties": {
          "bulkId": {
            "type": "string",
            "description": "Unique ID assigned to the bulk request."
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "from": {
                  "type": "string",
                  "description": "Sender ID."
                },
                "destinations": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SmsDestination"
                  }
                },
                "binary": {
                  "type": "object",
                  "properties": {
                    "hex": {
                      "type": "string",
                      "description": "Hexadecimal message content."
                    },
                    "dataCoding": {
                      "type": "integer",
                      "description": "SMS data coding value."
                    },
                    "esmClass": {
                      "type": "integer",
                      "description": "ESM class value."
                    }
                  },
                  "required": ["hex"]
                }
              },
              "required": ["destinations", "binary"]
            }
          }
        },
        "required": ["messages"]
      },
      "SmsSingleTextualRequest": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "Sender ID."
          },
          "to": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of destination phone numbers."
          },
          "text": {
            "type": "string",
            "description": "Text of the message."
          }
        },
        "required": ["to", "text"]
      },
      "SmsResponse": {
        "type": "object",
        "properties": {
          "bulkId": {
            "type": "string",
            "description": "Unique ID assigned to the request."
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SmsResponseMessage"
            }
          }
        }
      },
      "SmsResponseMessage": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "description": "Destination phone number."
          },
          "status": {
            "$ref": "#/components/schemas/MessageStatus"
          },
          "messageId": {
            "type": "string",
            "description": "Unique message ID."
          }
        }
      },
      "MessageStatus": {
        "type": "object",
        "properties": {
          "groupId": {
            "type": "integer",
            "description": "Status group ID."
          },
          "groupName": {
            "type": "string",
            "description": "Status group name.",
            "enum": ["ACCEPTED", "PENDING", "UNDELIVERABLE", "DELIVERED", "REJECTED", "EXPIRED"]
          },
          "id": {
            "type": "integer",
            "description": "Status ID."
          },
          "name": {
            "type": "string",
            "description": "Status name."
          },
          "description": {
            "type": "string",
            "description": "Human-readable description."
          },
          "action": {
            "type": "string",
            "description": "Suggested action."
          }
        }
      },
      "SmsDeliveryReportResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SmsDeliveryReport"
            }
          }
        }
      },
      "SmsDeliveryReport": {
        "type": "object",
        "properties": {
          "bulkId": {
            "type": "string"
          },
          "messageId": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "sentAt": {
            "type": "string",
            "format": "date-time"
          },
          "doneAt": {
            "type": "string",
            "format": "date-time"
          },
          "smsCount": {
            "type": "integer"
          },
          "price": {
            "$ref": "#/components/schemas/MessagePrice"
          },
          "status": {
            "$ref": "#/components/schemas/MessageStatus"
          },
          "error": {
            "$ref": "#/components/schemas/MessageError"
          }
        }
      },
      "MessagePrice": {
        "type": "object",
        "properties": {
          "pricePerMessage": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "MessageError": {
        "type": "object",
        "properties": {
          "groupId": {
            "type": "integer"
          },
          "groupName": {
            "type": "string"
          },
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "permanent": {
            "type": "boolean"
          }
        }
      },
      "SmsLogsResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SmsLogEntry"
            }
          }
        }
      },
      "SmsLogEntry": {
        "type": "object",
        "properties": {
          "bulkId": {
            "type": "string"
          },
          "messageId": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "sentAt": {
            "type": "string",
            "format": "date-time"
          },
          "doneAt": {
            "type": "string",
            "format": "date-time"
          },
          "smsCount": {
            "type": "integer"
