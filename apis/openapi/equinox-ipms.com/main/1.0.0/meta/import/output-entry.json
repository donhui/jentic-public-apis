        "operationId": "markTaskComplete",
        "summary": "Mark a task as complete",
        "description": "Marks a task as complete. Returns the task state prior to completion.",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "taskId"
