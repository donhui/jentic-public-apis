  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication using email and API key (Base64 encoded email:key)"
      },
      "passwordAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Password-based basic auth for key creation (Base64 encoded email:md5(password))"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ApiKeyResponse": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "The newly created API key"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "oldId": {
            "type": "integer"
          },
          "subscriberId": {
            "type": "integer"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "secondaryEmail": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "firstName": {
            "type": "string"
          },
          "secondName": {
            "type": "string"
          },
          "subscriberRef": {
            "type": "string"
          },
          "clientSQL": {
            "type": "string",
            "nullable": true
          },
          "loginCount": {
            "type": "integer"
          },
          "lastLogin": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "initials": {
            "type": "string"
          },
          "legalEntity": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Matter": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "matterCode": {
