{
  "openapi": "3.0.3",
  "info": {
    "title": "Equinox IPMS API",
    "description": "Equinox is an efficient IP portfolio management system that helps you manage trademarks, patents, registered designs and more. The API provides access to matters, documents, tasks, reports, correspondence, and user management.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://help.equinox-ipms.com/support/solutions/articles/8000106087-equinox-api"
  },
  "servers": [
    {
      "url": "https://{region}.workanyware.co.uk/products/api",
      "description": "Equinox API Server (UK/Regional)",
      "variables": {
        "region": {
          "default": "www",
          "description": "Regional hostname prefix (e.g., www, ca, pacific)",
          "enum": [
            "www",
            "ca",
            "pacific"
          ]
        }
      }
    },
    {
      "url": "https://central-us.equinox-ipms.com/products/api",
      "description": "Equinox API Server (US Central)"
    }
  ],
  "paths": {
    "/key/new": {
      "post": {
        "operationId": "createApiKey",
        "summary": "Create a new API key",
        "description": "Creates a new API key. Requires password-based basic auth (email:md5(password)).",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "passwordAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "User-friendly reference name for the key"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Key created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Input validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/key/validate": {
      "post": {
        "operationId": "validateApiKey",
        "summary": "Validate an API key",
        "description": "Validates the provided API key credentials. Returns 'true' on success.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Key validation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "400": {
            "description": "Input validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
