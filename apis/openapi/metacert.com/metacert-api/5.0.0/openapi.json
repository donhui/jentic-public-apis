{
  "openapi": "3.0.3",
  "info": {
    "title": "MetaCert Security API",
    "description": "A light but powerful layer of security for your app by providing intelligence on 10 billion URLs so you can protect users from Fake News, Satire, Alt-right, Far-right, Conservative News, Far-Left, Liberal, Phishing, Malware and Pornography.",
    "version": "5.0.0",
    "license": {
      "name": "MetaCert Inc. License",
      "url": "https://developer.metacert.com/api-documentation/legal/"
    },
    "contact": {
      "name": "MetaCert",
      "url": "https://metacert.com",
      "email": "business@metacert.com"
    }
  },
  "servers": [
    {
      "url": "https://core.metacert.com/api",
      "description": "MetaCert Core API"
    }
  ],
  "externalDocs": {
    "description": "MetaCert Developer Portal",
    "url": "https://developer.metacert.com"
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/check": {
      "post": {
        "operationId": "checkUrl",
        "summary": "Check URL",
        "description": "Look up the reputation of a URL against categories such as Fake News, Phishing, Malware and Pornography.",
        "tags": ["URL"],
        "parameters": [
          {
            "name": "apiKey",
            "in": "header",
            "required": true,
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckUrlRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful URL check response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckUrlResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "apikey",
        "in": "header",
        "description": "API key obtained from https://developer.metacert.com/signup/"
      }
    },
    "schemas": {
      "CheckUrlRequest": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "description": "The URL to check for classification/reputation.",
            "example": "https://example.com"
          }
        }
      },
      "CheckUrlResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "object",
            "properties": {
              "code": {
                "type": "number",
                "description": "Response status code"
              },
              "message": {
                "type": "string",
                "description": "Response status message"
              }
            }
          },
          "data": {
            "type": "object",
            "properties": {
              "URLs": {
                "type": "array",
                "description": "URL classification results",
                "items": {
                  "type": "string"
                }
              },
              "Folders": {
                "type": "array",
                "description": "Folder classification results",
                "items": {
                  "type": "string"
                }
              },
              "Domains": {
                "type": "array",
                "description": "Domain classification results",
                "items": {
                  "type": "object",
                  "properties": {
                    "domain": {
                      "type": "string",
                      "description": "The domain name"
                    },
                    "type": {
                      "type": "string",
                      "description": "The classification type (e.g., phishing, malware, pornography, safe)"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "URL",
      "description": "URL classification and reputation checking"
    }
  ]
}
