{
  "openapi": "3.0.3",
  "info": {
    "title": "Cloudmersive Natural Language Processing API",
    "version": "2.0.0",
    "description": "NLP API v2 providing sentiment analysis, profanity detection, hate speech detection, subjectivity analysis, text similarity, entity extraction, language detection, translation, parsing, part-of-speech tagging, rephrasing, segmentation, and spell checking.",
    "x-jentic-source-url": "https://api.cloudmersive.com/docs/nlp.asp"
  },
  "servers": [
    {
      "url": "https://api.cloudmersive.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/nlp-v2/analytics/sentiment": {
      "post": {
        "operationId": "analyzeSentiment",
        "summary": "Analyze sentiment of text",
        "description": "Analyze input text using advanced Sentiment Analysis to determine if the input is positive, negative, or neutral.",
        "tags": ["Analytics"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TextInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful sentiment analysis",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SentimentResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/nlp-v2/analytics/profanity": {
      "post": {
        "operationId": "detectProfanity",
        "summary": "Detect profanity in text",
        "description": "Detect profanity and obscene language in the input text.",
