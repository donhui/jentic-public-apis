                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/nlp-v2/segmentation/words": {
      "post": {
        "operationId": "segmentWords",
        "summary": "Segment text into words",
        "description": "Extract individual words from input text.",
        "tags": ["Segmentation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TextInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Segmented words",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SegmentationResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/nlp-v2/spellcheck/check/word": {
      "post": {
        "operationId": "spellCheckWord",
        "summary": "Spell check a word",
        "description": "Find spelling correction suggestions for a single word and return result as JSON.",
        "tags": ["Spell Check"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SpellCheckWordInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Spell check result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpellCheckResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/nlp-v2/spellcheck/check/sentence": {
      "post": {
        "operationId": "spellCheckSentence",
        "summary": "Spell check a sentence",
        "description": "Validate sentence spelling with corrections.",
        "tags": ["Spell Check"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TextInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Spell check result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpellCheckSentenceResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TextInput": {
        "type": "object",
        "required": ["TextToAnalyze"],
        "properties": {
          "TextToAnalyze": {
            "type": "string",
            "description": "Input text to process"
          }
        }
      },
      "SimilarityInput": {
        "type": "object",
        "required": ["TextToAnalyze1", "TextToAnalyze2"],
        "properties": {
          "TextToAnalyze1": {
            "type": "string",
            "description": "First text string to compare"
          },
          "TextToAnalyze2": {
            "type": "string",
            "description": "Second text string to compare"
          }
        }
      },
      "SpellCheckWordInput": {
        "type": "object",
        "required": ["Word"],
        "properties": {
          "Word": {
            "type": "string",
            "description": "Word to spell check"
          }
        }
      },
      "SentimentResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "SentimentClassificationResult": { "type": "string", "description": "Positive, Negative, or Neutral" },
          "SentimentScoreResult": { "type": "number", "description": "Sentiment score" },
          "SentenceCount": { "type": "integer" }
        }
      },
      "ProfanityResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "ProfanityScoreResult": { "type": "number" },
          "SentenceCount": { "type": "integer" }
        }
      },
      "HateSpeechResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "HateSpeechScoreResult": { "type": "number" },
          "SentenceCount": { "type": "integer" }
        }
      },
      "SubjectivityResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "SubjectivityScoreResult": { "type": "number" },
          "SentenceCount": { "type": "integer" }
        }
      },
      "SimilarityResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "SimilarityScoreResult": { "type": "number", "description": "Similarity score between 0 and 1" },
          "SentenceCount": { "type": "integer" }
        }
      },
      "EntitiesResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "Entities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "EntityType": { "type": "string" },
                "EntityText": { "type": "string" }
              }
            }
          }
        }
      },
      "LanguageDetectionResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "DetectedLanguage_ThreeLetterCode": { "type": "string" },
          "DetectedLanguage_FullName": { "type": "string" }
        }
      },
      "TranslationResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "TranslatedTextResult": { "type": "string" },
          "SentenceCount": { "type": "integer" }
        }
      },
      "ParseTreeResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "ParseTree": { "type": "string", "description": "Penn Treebank format parse tree" }
        }
      },
      "PosTagResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "TaggedSentences": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Words": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "Word": { "type": "string" },
                      "Tag": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "RephraseResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "RephrasedResults": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "RephrasedSentence": { "type": "string" }
              }
            }
          }
        }
      },
      "SegmentationResponse": {
        "type": "object",
        "properties": {
          "Successful": { "type": "boolean" },
          "Sentences": {
            "type": "array",
            "items": { "type": "string" }
          },
          "Words": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "SpellCheckResponse": {
        "type": "object",
        "properties": {
          "Correct": { "type": "boolean" },
          "Suggestions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "SpellCheckSentenceResponse": {
        "type": "object",
        "properties": {
          "IncorrectCount": { "type": "integer" },
          "Words": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Word": {
                  "type": "object",
                  "properties": {
                    "Word": { "type": "string" },
                    "IsCorrect": { "type": "boolean" },
                    "Suggestions": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error message" }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Apikey",
        "description": "Cloudmersive API key passed in the Apikey header"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}