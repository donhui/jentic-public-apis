          {
            "description": "",
            "in": "path",
            "name": "folder_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/Common.UUID"
            }
          },
          {
            "description": "Whether to recursively delete all nested folders and projects",
            "in": "query",
            "name": "recursive",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/Folders.Recursive"
            }
          }
        ],
        "responses": {
