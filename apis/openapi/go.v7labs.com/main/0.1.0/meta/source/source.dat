        "type": "string"
      },
      "Cases.CaseErrorCode": {
        "description": "The error code of the case. Only present if the case is in an error state. Can be one of:\n- agent_timeout - If a case called an agent and it took too long to respond.\n- file_not_found - If a case tried to use a file that was deleted or not found.\n- file_upload_timeout - If a file upload timed out.\n- invalid_html_response - The AI did not return valid HTML.\n- max_iterations_exceeded - The agent reached the maximum number of iterations.\n- max_output_tokens_exceeded - The agent reached the maximum number of output tokens.\n- agent_interrupted - The agent was interrupted by the user.\n- model_unexpected_stop - A model provider sent an unexpected stop signal.\n- model_context_length_exceeded - A model provider returned a context length exceeded error.\n- model_rate_limit_exceeded - A model provider returned a rate limit exceeded error.\n- usage_limit_exceeded - A case exceeded the usage limit associated with the workspace. It can be billing plan or system limit.\n- no_model_available - No AI model is currently available for the workspace.\n- skill_execution_error - A skill failed to execute.\n- internal_error - An unhandled error occurred while processing the case.\n",
        "enum": [
          "agent_timeout",
          "file_not_found",
          "file_upload_timeout",
          "invalid_html_response",
          "max_iterations_exceeded",
          "max_output_tokens_exceeded",
          "agent_interrupted",
          "model_unexpected_stop",
          "model_context_length_exceeded",
          "model_rate_limit_exceeded",
          "usage_limit_exceeded",
          "no_model_available",
          "skill_execution_error",
          "internal_error"
        ],
        "nullable": true,
        "title": "Cases.CaseErrorCode",
        "type": "string"
      },
