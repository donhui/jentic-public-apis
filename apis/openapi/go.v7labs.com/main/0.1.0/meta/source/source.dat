      "TriggersInbound.SystemPropertyIds.Simplified": {
        "additionalProperties": false,
        "description": "System property IDs for simplified trigger deployment.\n\n## Architecture Overview\n\nThe simplified deployment creates a property pipeline across three projects:\n\n- **Backing Project**: Receives webhook payloads and contains the row collection\n- **Pipeline Project**: Child project of the collection - processes individual rows\n- **Target Project**: The user's project where entities are created/updated\n\n## Property Flow\n\n```\nBACKING PROJECT              PIPELINE PROJECT              TARGET PROJECT\n\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550              \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550              \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\nwebhook_payload \u2500\u2500\u25ba row_collection \u2500\u25ba row_webhook_payload\n                    (splits payload)         \u2502\n                                       \u250c\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2510\n                                       \u25bc           \u25bc\n                                  match_keys  source_actions\n                                  (if matchers) (from source)\n                                       \u2502\n                                       \u25bc\n                                  linked_targets \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u25ba target_trigger_source\n                                       \u2502                 (ref to Pipeline)\n                                       \u25bc\n                                  target_reference_value \u25ba target_match_keys\n                                       \u2502                  (hidden, stores values)\n                                       \u25bc\n                                    action \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u25ba (creates/updates entity)\nstatus \u25c4\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n```\n",
        "properties": {
          "action": {
            "description": "Action property that performs create/update/upsert operations on target project entities.\nExecutes after all extraction properties have computed their values.\nFor update/upsert, uses linked_targets to find existing entities.\nLocated in: Pipeline Project.\n",
            "nullable": true,
            "properties": {
              "project_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "property_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "public": {
                "type": "boolean"
              }
            },
            "required": [
              "property_id",
              "project_id",
              "public"
            ],
            "type": "object"
          },
          "linked_targets": {
            "description": "Reference property that finds existing target entities by comparing match keys.\nQueries target project entities where target_match_keys match extracted match_keys values.\nReturns matching entity IDs to the action property for update/upsert operations.\nOnly created for update_entity and upsert_entity actions.\nLocated in: Pipeline Project.\n",
            "nullable": true,
            "properties": {
              "project_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "property_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "public": {
                "type": "boolean"
              }
            },
            "required": [
              "property_id",
              "project_id",
              "public"
            ],
            "type": "object"
          },
          "match_keys": {
            "description": "Extraction properties that extract matcher values from the webhook payload.\nEach corresponds to a matcher_definition in the deployment configuration.\nValues are wrapped as {\"value\": X} or {\"value\": null} if extraction fails.\nUsed only for update_entity and upsert_entity actions.\nLocated in: Pipeline Project.\n",
            "items": {
              "$ref": "#/components/schemas/TriggersInbound.SystemPropertyIds.PropertyRef"
            },
            "type": "array"
          },
          "row_collection": {
            "description": "Collection property that splits the webhook payload into rows.\nEach row becomes a child entity in the pipeline project.\nSupports three splitting modes: none (passthrough), code, or LLM.\nLocated in: Backing Project.\n",
            "nullable": true,
            "properties": {
              "project_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "property_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "public": {
                "type": "boolean"
              }
            },
            "required": [
              "property_id",
              "project_id",
              "public"
            ],
            "type": "object"
          },
          "row_webhook_payload": {
            "description": "Trigger raw data property for a single row in the pipeline project.\nContains the payload for one row after the row_collection splits the webhook payload.\nFor no-splitter mode, this is the full payload wrapped as a single item.\nLocated in: Pipeline Project (child of row_collection).\n",
            "nullable": true,
            "properties": {
              "project_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "property_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "public": {
                "type": "boolean"
              }
            },
            "required": [
              "property_id",
              "project_id",
              "public"
            ],
            "type": "object"
          },
          "source_actions": {
            "description": "Properties deployed from an enriched trigger source's template.\nCreated using the source's import_properties_request when the trigger uses a Pipedream source.\nEach property can extract, transform, or compute values from the webhook payload.\nLocated in: Pipeline Project.\n",
            "items": {
              "$ref": "#/components/schemas/TriggersInbound.SystemPropertyIds.PropertyRef"
            },
            "type": "array"
          },
          "status": {
            "description": "Status property showing the result of the action execution.\nDisplays success/failure state of entity creation/update operations.\nLocated in: Backing Project.\n",
            "nullable": true,
            "properties": {
              "project_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "property_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "public": {
                "type": "boolean"
              }
            },
            "required": [
              "property_id",
              "project_id",
              "public"
            ],
            "type": "object"
          },
          "target_match_keys": {
            "description": "Hidden properties on target entities that store matcher values.\nSet when entities are created/updated via target_reference_value.\nUsed by linked_targets to find existing entities on subsequent webhooks.\nThese properties are automatically removed from all views.\nLocated in: Target Project.\n",
            "items": {
              "$ref": "#/components/schemas/TriggersInbound.SystemPropertyIds.PropertyRef"
            },
            "type": "array"
          },
          "target_reference_value": {
            "description": "JSON action property that sets values on target entities.\nSets the target_trigger_source reference and target_match_keys values.\nFor append mode, reads existing IDs through linked_targets before appending.\nLocated in: Pipeline Project.\n",
            "nullable": true,
            "properties": {
              "project_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "property_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "public": {
                "type": "boolean"
              }
            },
            "required": [
              "property_id",
              "project_id",
              "public"
            ],
            "type": "object"
          },
          "target_trigger_source": {
            "description": "Reference property in the target project pointing back to the pipeline project entity.\nAllows target entities to access the source webhook payload via this reference.\nThis is a public property visible in views.\nLocated in: Target Project.\n",
            "nullable": true,
            "properties": {
              "project_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "property_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "public": {
                "type": "boolean"
              }
            },
            "required": [
              "property_id",
              "project_id",
              "public"
            ],
            "type": "object"
          },
          "webhook_payload": {
            "description": "Raw webhook payload property in the backing project.\nReceives the full JSON payload from incoming webhook requests.\nLocated in: Backing Project.\n",
            "properties": {
              "project_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "property_id": {
                "$ref": "#/components/schemas/Common.UUID"
              },
              "public": {
                "type": "boolean"
              }
            },
            "required": [
              "property_id",
              "project_id",
              "public"
            ],
            "type": "object"
          }
        },
        "required": [
          "webhook_payload"
        ],
        "title": "TriggersInbound.SystemPropertyIds.Simplified",
        "type": "object"
      },
      "Imports.ListImportsResponse": {
        "additionalProperties": false,
        "description": "List import response",
        "properties": {
          "data": {
