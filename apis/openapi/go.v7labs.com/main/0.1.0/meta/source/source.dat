          "original_filename",
          "updated_by"
        ],
        "title": "Projects.ListEntities.FieldFileResponse",
        "type": "object"
      },
      "Projects.PropertyToolConfig": {
        "additionalProperties": false,
        "description": "Configuration for AI tool behavior",
        "properties": {
          "auto_llm_config": {
            "$ref": "#/components/schemas/Projects.AutoLlmToolConfig"
          },
          "code_config": {
            "$ref": "#/components/schemas/Projects.CodeToolConfig"
          },
          "dependencies": {
            "deprecated": true,
            "description": "Deprecated: use code_config.dependencies instead",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "input_mode": {
            "default": "primary_and_extracted",
            "description": "How to handle input data: primary_only (default), extracted_only, primary_and_extracted",
            "enum": [
              "primary_only",
              "extracted_only",
              "primary_and_extracted"
            ],
            "type": "string"
          },
          "llm_config": {
            "$ref": "#/components/schemas/Projects.LlmToolConfig"
          },
          "thinking_effort": {
            "deprecated": true,
            "description": "Deprecated: use llm_config.thinking_effort instead",
            "enum": [
              "disabled",
              "minimal",
              "low",
              "medium",
              "high",
              "xhigh",
              "auto"
            ],
            "type": "string"
          },
          "upsert_entity_config": {
            "$ref": "#/components/schemas/Projects.UpsertEntityToolConfig"
          }
        },
        "title": "Projects.PropertyToolConfig",
        "type": "object"
      },
