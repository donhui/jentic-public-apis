          "has_kwargs": {
            "description": "Whether the skill accepts arbitrary keyword arguments via **kwargs",
            "type": "boolean"
          },
          "id": {
            "$ref": "#/components/schemas/Common.UUID"
          },
          "modified": {
            "description": "Whether the skill has been modified from its original generated values.\nAlways true for non-generated skills (no baseline to compare).\nFor generated skills, true when any field differs from the generated values.\n",
