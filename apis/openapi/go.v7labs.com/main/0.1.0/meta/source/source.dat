      "Skills.ChainOutputType": {
        "description": "Output type for the skill chain:\n- :json - Chain returns JSON data (can only be used if last skill outputs JSON)\n- :file - Chain returns a file (must be used if last skill outputs file,\n          can also be used when last skill returns JSON with a downloadable URL\n          that will be converted to a file by the system)\n",
        "enum": [
          "json",
          "file"
        ],
        "title": "Skills.ChainOutputType",
        "type": "string"
      },
