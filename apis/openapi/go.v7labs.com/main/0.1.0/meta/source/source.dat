{
  "components": {
    "responses": {},
    "schemas": {
      "TriggersOutbound.CreateTriggerRequest": {
        "additionalProperties": false,
        "description": "Create trigger request",
        "properties": {
          "action": {
            "$ref": "#/components/schemas/TriggersOutbound.Action"
          },
          "events": {
            "$ref": "#/components/schemas/TriggersOutbound.EventsRequest"
          },
          "project_id": {
            "$ref": "#/components/schemas/Common.NullableUUID"
          }
        },
        "required": [
          "project_id",
          "events"
        ],
        "title": "TriggersOutbound.CreateTriggerRequest",
        "type": "object"
      },
      "TokenReports.PendingReport": {
        "additionalProperties": false,
        "description": "Token report in pending status (waiting to be processed)",
        "properties": {
          "created_at": {
            "$ref": "#/components/schemas/Common.DateTime"
          },
          "created_by_id": {
            "$ref": "#/components/schemas/Common.UUID"
          },
          "filters": {
            "$ref": "#/components/schemas/TokenReports.ReportFilters"
          },
          "from": {
            "$ref": "#/components/schemas/Common.DateTime"
          },
          "granularity": {
            "$ref": "#/components/schemas/TokenReports.Granularity"
          },
          "group_by": {
            "items": {
              "$ref": "#/components/schemas/TokenReports.GroupByDimension"
            },
            "type": "array"
          },
          "id": {
            "$ref": "#/components/schemas/Common.UUID"
          },
          "report_type": {
            "$ref": "#/components/schemas/TokenReports.ReportType"
          },
          "status": {
            "enum": [
              "pending"
            ],
            "type": "string"
          },
          "to": {
            "$ref": "#/components/schemas/Common.DateTime"
          },
          "workspace_id": {
            "$ref": "#/components/schemas/Common.UUID"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "report_type",
          "status",
          "granularity",
          "from",
          "to",
          "group_by",
          "created_at",
          "created_by_id"
        ],
        "title": "TokenReports.PendingReport",
        "type": "object"
      },
      "TokenReports.NullableModelProvider": {
        "description": "AI model provider (only present when model is in group_by)",
        "enum": [
          "anthropic",
          "aws_bedrock",
          "azure_open_ai",
          "google_ai",
          "open_ai",
          "vertex_ai"
        ],
        "nullable": true,
        "title": "TokenReports.NullableModelProvider",
        "type": "string"
      },
      "ShareableLinks.ListShareableLinksOrderBy": {
