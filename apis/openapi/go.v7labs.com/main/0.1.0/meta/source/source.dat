        "description": "Request body for listing hub files with pagination and optional filters",
        "properties": {
          "after": {
            "$ref": "#/components/schemas/Pagination.Cursor"
          },
          "before": {
            "$ref": "#/components/schemas/Pagination.Cursor"
          },
          "file_ids": {
            "description": "Filter by file IDs (Files context IDs)",
            "items": {
              "$ref": "#/components/schemas/Common.UUID"
            },
            "minItems": 1,
            "nullable": true,
            "type": "array"
          },
          "first": {
            "$ref": "#/components/schemas/Pagination.First"
          },
          "full_path_starts_with": {
            "description": "Filter by full_path prefix (e.g. /docs or /docs/report)",
            "minLength": 1,
            "nullable": true,
            "type": "string"
          },
          "full_paths": {
            "description": "Filter by exact full file paths (e.g. /docs/report.pdf)",
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "nullable": true,
            "type": "array"
          },
          "is_source_integration_file_stale": {
            "description": "Filter by whether the linked file has a non-nil source_updated_at timestamp.",
            "nullable": true,
            "type": "boolean"
          },
          "last": {
            "$ref": "#/components/schemas/Pagination.Last"
          },
          "limit": {
            "$ref": "#/components/schemas/Pagination.Limit"
          },
          "offset": {
            "$ref": "#/components/schemas/Pagination.Offset"
          },
          "order_by": {
            "$ref": "#/components/schemas/Hubs.ListHubFilesOrderBy"
          },
          "order_directions": {
            "$ref": "#/components/schemas/Pagination.OrderDirections"
          },
          "parent_paths": {
            "description": "Filter by parent folder paths - returns only direct children of the given folders (e.g. [\"/docs\", \"/reports\"]). Use \"/\" for root-level items.",
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "nullable": true,
            "type": "array"
          },
          "type": {
            "description": "Filter by type: 'file' or 'folder'",
            "enum": [
              "file",
              "folder"
            ],
            "nullable": true,
            "type": "string"
          }
        },
        "title": "Hubs.ListHubFilesRequest",
        "type": "object"
      },
