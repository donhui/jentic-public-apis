      "Templates.TriggerSimplifiedDeploymentDefinition": {
        "additionalProperties": false,
        "description": "Simplified trigger deployment definition.\n\nThis deployment type creates entities in the target project with a reference back to\nthe webhook payload in the backing project. No field-by-field extraction is performed -\nthe entire payload is accessible via the reference.\n\n## Actions\n\n- `create_entity`: Always creates new entities. Matchers are NOT allowed.\n- `update_entity`: Updates existing entities matched by matchers. If no match found, skips.\n  At least one matcher is REQUIRED.\n- `upsert_entity`: Updates if match found, creates if not.\n  At least one matcher is REQUIRED.\n\n## Matching Behavior\n\nFor update/upsert actions, matchers extract values from the webhook payload and compare\nthem against stored values on target entities. The extracted values are also stored on\ntarget entities (in hidden properties) so future payloads can match against them.\n\nIf a matcher extracts `null` (value not found in payload), that matcher is skipped\nfor matching purposes. If ALL matchers extract `null`, no entity will be matched\n(for update_entity this means the payload is skipped; for upsert_entity, a new entity\nis created without matcher values).\n\n## Update Methods\n\n- `replace`: Each webhook payload replaces any previous reference (default)\n- `append`: Webhook references are appended to existing ones (entity tracks all source payloads)\n",
        "nullable": true,
        "properties": {
          "matcher_definitions": {
            "description": "List of matcher definitions for identifying existing entities.\n\nRequired for `update_entity` and `upsert_entity` actions (at least one matcher).\nMust be empty or omitted for `create_entity` action.\n\nMultiple matchers are combined with AND logic - all must match for an entity to be found.\n",
            "items": {
              "$ref": "#/components/schemas/TriggersInbound.TriggerSimplifiedDeploymentDefinition.MatcherDefinition"
            },
            "type": "array"
          },
          "row_splitter": {
            "$ref": "#/components/schemas/TriggersInbound.TriggerRowSplitter"
          },
          "target_action": {
            "description": "Action to perform on target entities:\n- `create_entity`: Always create new entity (matchers NOT allowed)\n- `update_entity`: Update existing entity found by matchers (matchers REQUIRED, skips if no match)\n- `upsert_entity`: Update if found, create if not (matchers REQUIRED)\n",
            "enum": [
              "create_entity",
              "update_entity",
              "upsert_entity"
            ],
            "type": "string"
          },
          "update_method": {
            "default": "replace",
            "description": "How to handle references when updating existing entities:\n- `replace`: New payload reference replaces any existing reference\n- `append`: New payload reference is appended to existing references\n",
            "enum": [
              "replace",
              "append"
            ],
            "type": "string"
          }
        },
        "required": [
          "target_action",
          "matcher_definitions",
          "row_splitter"
        ],
        "title": "Templates.TriggerSimplifiedDeploymentDefinition",
        "type": "object"
      },
