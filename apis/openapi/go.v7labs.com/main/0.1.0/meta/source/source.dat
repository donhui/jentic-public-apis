              "schema": {
                "$ref": "#/components/schemas/TriggersInbound.EnableTriggerRequest"
              }
            }
          },
          "description": "TriggersInbound.EnableTriggerRequest",
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
