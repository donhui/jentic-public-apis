        "type": "integer"
      },
      "Hubs.AddFilesRequestFolder": {
        "additionalProperties": false,
        "description": "A folder to create",
        "properties": {
          "relative_path": {
            "description": "path of the file relative to the parent folder",
            "type": "string"
          },
          "type": {
            "enum": [
              "folder"
            ],
            "type": "string"
          }
        },
        "required": [
          "type",
          "relative_path"
        ],
        "title": "Hubs.AddFilesRequestFolder",
        "type": "object"
      },
      "Projects.SingleSelectPropertyConfig": {
        "additionalProperties": false,
        "description": "Initial configuration for single-select property.\nAllows to provide initial select options.\n",
        "properties": {
          "default_option": {
            "$ref": "#/components/schemas/Projects.SelectDefaultOption"
          },
          "options": {
            "items": {
              "$ref": "#/components/schemas/Projects.SelectOption"
            },
            "maxItems": 1000,
            "type": "array"
          }
        },
        "required": [
          "options"
        ],
        "title": "Projects.SingleSelectPropertyConfig",
        "type": "object"
      },
      "Projects.CloneWarning": {
        "additionalProperties": false,
        "description": "A warning or follow up action required after project cloning",
        "properties": {
          "code": {
            "type": "string"
          },
          "data": {
            "type": "object"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "Projects.CloneWarning",
        "type": "object"
      },
      "Integrations.PipedreamActionAuth": {
        "additionalProperties": false,
        "description": "Pipedream-specific authentication data",
        "properties": {
          "account_id": {
            "description": "Pipedream account ID",
            "type": "string"
          },
          "external_user_id": {
            "description": "External user ID in Pipedream",
            "type": "string"
          },
          "project_id": {
            "description": "Pipedream project ID",
            "type": "string"
          },
          "token": {
            "description": "Pipedream authentication token",
            "type": "string"
          }
        },
        "required": [
          "token",
          "project_id",
          "external_user_id",
          "account_id"
        ],
        "title": "Integrations.PipedreamActionAuth",
        "type": "object"
      },
      "Library.UpsertEntityAttributesRequest": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "The name of the entity",
            "example": "My Entity",
            "maxLength": 255,
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "title": "Library.UpsertEntityAttributesRequest",
        "type": "object"
      },
      "Projects.NumberFormatCustomResponse": {
        "additionalProperties": false,
        "description": "Custom number format",
        "nullable": true,
        "properties": {
          "decimal_places": {
            "oneOf": [
              {
                "maximum": 20,
                "minimum": 0,
                "type": "integer"
              },
              {
                "default": "auto",
                "enum": [
                  "auto"
                ],
                "type": "string"
              }
            ]
          },
          "negative_format": {
            "default": "minus",
            "enum": [
              "minus",
              "parentheses",
              "colored",
              "colored_parentheses"
            ],
            "type": "string"
          },
          "right_align": {
            "default": false,
            "type": "boolean"
          },
          "thousand_separator": {
            "default": "none",
            "enum": [
              "comma",
              "none"
            ],
            "type": "string"
          }
        },
        "required": [
          "decimal_places",
          "negative_format",
          "thousand_separator",
          "right_align"
        ],
        "title": "Projects.NumberFormatCustomResponse",
        "type": "object"
      },
      "Skills.AuthType": {
        "description": "Authentication type for HTTP skills",
        "enum": [
          "bearer",
          "api_key"
        ],
        "nullable": true,
        "title": "Skills.AuthType",
        "type": "string"
      },
      "Projects.DynamicArgumentOverrideReference": {
        "additionalProperties": false,
        "description": "Override for a dynamic skill argument with input reference",
        "properties": {
          "arg_name": {
            "type": "string"
          },
          "arg_type": {
            "enum": [
              "dynamic"
            ],
            "type": "string"
          },
          "value": {
            "$ref": "#/components/schemas/Projects.InputReference"
          },
          "value_format": {
            "$ref": "#/components/schemas/Projects.ArgumentOverrideValueFormat"
          },
          "value_type": {
            "enum": [
              "input_reference"
            ],
            "type": "string"
          }
        },
        "required": [
          "arg_name",
          "arg_type",
          "value_type",
          "value"
        ],
        "title": "Projects.DynamicArgumentOverrideReference",
        "type": "object"
      },
      "Hubs.FolderContentsFolder": {
        "additionalProperties": false,
        "description": "Contents of a folder",
        "properties": {
          "children": {
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/Hubs.Folder"
                },
                {
                  "$ref": "#/components/schemas/Hubs.File"
                }
              ]
            },
            "type": "array"
          },
          "full_path": {
            "description": "Canonical full path (e.g. /a/b). For folders, equals path.",
            "nullable": false,
            "type": "string"
          },
          "id": {
            "$ref": "#/components/schemas/Common.NullableUUID"
          },
          "name": {
            "type": "string"
          },
          "parent_id": {
            "$ref": "#/components/schemas/Common.NullableUUID"
          },
          "path": {
            "description": "Path from root (e.g. /a/b), including the folder name; derived from full_path",
            "nullable": false,
            "type": "string"
          }
        },
        "required": [
          "name",
          "parent_id",
          "children",
          "path",
          "full_path"
        ],
        "title": "Hubs.FolderContentsFolder",
        "type": "object"
      },
      "Hubs.HubIndexItem": {
        "additionalProperties": false,
        "properties": {
          "content": {
            "$ref": "#/components/schemas/Common.NullableString"
          },
          "description": {
            "$ref": "#/components/schemas/Common.String"
          },
          "document_type": {
            "enum": [
              "excel",
              "document",
              "invalid",
              "image",
              "text",
              "docx"
            ],
            "nullable": true,
            "type": "string"
          },
          "file_id": {
            "$ref": "#/components/schemas/Common.NullableUUID"
          },
          "full_path": {
            "$ref": "#/components/schemas/Common.String"
          },
          "hub_file_id": {
            "$ref": "#/components/schemas/Common.NullableUUID"
          },
          "slug": {
            "$ref": "#/components/schemas/Common.String"
          },
          "storage_key": {
            "$ref": "#/components/schemas/Common.NullableString"
          }
        },
        "required": [
          "full_path",
          "slug",
          "description"
        ],
        "title": "Hubs.HubIndexItem",
        "type": "object"
      },
      "TokenReports.CreateHubReportRequest": {
        "additionalProperties": false,
        "description": "Request to create a hub token usage report",
        "properties": {
          "from": {
            "$ref": "#/components/schemas/Common.DateTime"
          },
          "granularity": {
            "$ref": "#/components/schemas/TokenReports.Granularity"
          },
          "group_by": {
            "description": "Dimensions to group by. Default: [model]",
            "items": {
              "$ref": "#/components/schemas/TokenReports.HubGroupByDimension"
            },
            "type": "array"
          },
          "report_type": {
            "enum": [
              "hub"
            ],
            "type": "string"
          },
          "to": {
            "$ref": "#/components/schemas/Common.DateTime"
          }
        },
        "required": [
          "granularity",
          "from",
          "to",
          "report_type"
        ],
        "title": "TokenReports.CreateHubReportRequest",
        "type": "object"
      },
      "Projects.SelectDefaultOption": {
        "description": "Default select option.\nIf the value doesn't exist, it will be ignored.\n",
        "nullable": true,
        "title": "Projects.SelectDefaultOption",
        "type": "string"
      },
      "fields": {
        "additionalProperties": {
          "$ref": "#/components/schemas/field_value"
        },
        "description": "Fields to update, note that the field key is the property id or property slug for that field.",
        "title": "fields",
        "type": "object"
      },
      "Skills.SkillOrderByField": {
        "description": "Field name to order skills by",
        "enum": [
          "name",
          "created_at",
          "updated_at"
        ],
        "title": "Skills.SkillOrderByField",
        "type": "string"
      },
      "Templates.ReferencePropertyConfig": {
        "additionalProperties": false,
        "description": "Initial configuration for reference property.\nAllows to provide source project and entity limit (0 for to use system maximum).\n",
        "properties": {
