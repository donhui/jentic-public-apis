          },
          "step_type": {
            "description": "The type of step (e.g., 'tool_use', 'tool_result', 'text')",
            "type": "string"
          },
          "summary": {
            "description": "User-friendly summary of a tool step (max 20 words). Present tense for tool_use, past tense for tool_result. Null for non-tool steps or if summarization was skipped.",
            "nullable": true,
            "type": "string"
          },
          "text": {
