      "Hubs.FileNameConflict": {
        "additionalProperties": false,
        "description": "Details about a file name conflict. Returned when attempting to add files with duplicate names.",
        "properties": {
          "conflict_type": {
            "description": "Type of conflict: 'batch_duplicate' means the filename appears multiple times in the upload batch, 'existing_file' means a file with the same name already exists in the target folder, 'existing_folder' means a folder with the same name already exists in the target folder",
            "enum": [
              "batch_duplicate",
              "existing_file",
              "existing_folder"
            ],
            "type": "string"
          },
          "filename": {
            "description": "The conflicting filename",
            "type": "string"
          },
          "parent_id": {
            "$ref": "#/components/schemas/Common.NullableUUID"
          }
        },
        "required": [
          "parent_id",
          "filename",
          "conflict_type"
        ],
        "title": "Hubs.FileNameConflict",
        "type": "object"
      },
