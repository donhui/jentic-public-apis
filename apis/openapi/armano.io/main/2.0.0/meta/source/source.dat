{
  "openapi": "3.0.3",
  "info": {
    "title": "Armano HRMS",
    "description": "Armano Human Resource management system",
    "version": "2.0.0",
    "contact": {},
    "x-jentic-source-url": "https://armano.io/wp-content/uploads/2025/05/armano-integration-swagger.json"
  },
  "servers": [
    {
      "url": "https://api.armano.io"
    }
  ],
  "components": {
    "securitySchemes": {
      "x-api-key": {
        "type": "apiKey",
        "name": "x-api-key",
        "in": "header"
      }
    },
    "schemas": {
      "IntegrationUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique ID (uuid v4)",
            "format": "uud"
          },
          "firstName": {
            "type": "string",
            "description": "First name"
          },
          "lastName": {
            "type": "string",
            "description": "Lsat name"
          },
          "email": {
            "type": "string",
            "description": "Email address"
          }
        },
        "required": [
          "id",
          "firstName",
          "lastName",
          "email"
        ]
      },
      "IntegrationJobCandidateDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Candidate Unique ID (uuid v4)",
            "format": "uuid"
          },
          "firstName": {
            "type": "string",
            "description": "Candidate First name"
          },
          "lastName": {
            "type": "string",
            "description": "Candidate Last name"
          },
          "email": {
            "type": "string",
            "description": "Candidate Email"
          },
          "phone": {
            "type": "string",
            "description": "Candidate Phone Number"
          },
          "job": {
            "type": "object",
            "description": "Job Detail which candidate apply for",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "Job Unique ID (uuid v4)"
              },
              "title": {
                "type": "string",
                "description": "Job Title"
              }
            }
          },
          "createdByUser": {
            "description": "User Who add candidate organization",
            "allOf": [
              {
                "$ref": "#/components/schemas/IntegrationUserDto"
              }
            ]
          }
        },
        "required": [
          "id",
          "firstName",
          "lastName",
          "email",
          "phone",
          "job"
        ]
      }
    }
  },
  "paths": {
    "/core/integrations/api-keys/me": {
      "get": {
        "description": "Get API Key Company",
        "operationId": "IntegrationApiKeyController_getMe",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "(Integration API)",
        "tags": [
          "integration/api-keys"
        ]
      }
    },
    "/core/integrations/users/{email}": {
      "get": {
        "description": "Get one user by email",
        "operationId": "IntegrationUserController_getOne",
        "parameters": [
          {
            "name": "email",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntegrationUserDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "(Integration API)",
        "tags": [
          "integration/users"
        ]
      }
    },
    "/core/integrations/users": {
      "get": {
        "description": "Get latest users",
        "operationId": "IntegrationUserController_getLatestUsers",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IntegrationUserDto"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "(Integration API)",
        "tags": [
          "integration/users"
        ]
      }
    },
    "/ats/integrations/jobs-candidates": {
      "get": {
        "operationId": "IntegrationJobCandidateController_getMany",
        "summary": "(Integration API)",
        "description": "Get new Candidates",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IntegrationJobCandidateDto"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        },
        "tags": [
          "integrations/jobs-candidates"
        ],
        "security": [
          {
            "x-api-key": []
          }
        ]
      }
    }
  }
}