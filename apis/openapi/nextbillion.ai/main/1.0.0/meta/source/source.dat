{
  "openapi": "3.0.3",
  "info": {
    "title": "NextBillion.ai Mapping API",
    "version": "1.0.0",
    "description": "NextBillion.ai Mapping and Navigation APIs including Directions, Distance Matrix, Geocoding (Forward and Reverse), Snap to Roads, and Isochrone APIs. All endpoints require an API key passed as a query parameter.",
    "x-jentic-source-url": "https://docs.nextbillion.ai/"
  },
  "servers": [
    {
      "url": "https://api.nextbillion.io",
      "description": "NextBillion.ai API"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    { "name": "Directions", "description": "Route calculation between waypoints" },
    { "name": "DistanceMatrix", "description": "Distance and duration calculations between origins and destinations" },
    { "name": "Geocoding", "description": "Forward and reverse geocoding" },
    { "name": "SnapToRoads", "description": "Snap GPS coordinates to roads" },
    { "name": "Isochrone", "description": "Reachability analysis by time or distance" }
  ],
  "paths": {
    "/directions/json": {
      "get": {
        "operationId": "getDirections",
        "summary": "Get directions between waypoints",
        "description": "Calculate route directions between up to 50 waypoints. Use option=flexible for truck routing and advanced features.",
        "tags": ["Directions"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "origin",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Origin coordinates as latitude,longitude"
          },
          {
            "name": "destination",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Destination coordinates as latitude,longitude"
          },
          {
            "name": "waypoints",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Intermediate waypoints as pipe-separated coordinates"
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["car", "truck", "bike", "foot"] },
            "description": "Transport mode"
          },
          {
            "name": "option",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["flexible"] },
            "description": "Set to 'flexible' for truck routing and advanced options"
          },
          {
            "name": "avoid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Features to avoid: highways, tolls, ferries (pipe-separated)"
          },
          {
            "name": "alternatives",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Return alternative routes"
          }
        ],
        "responses": {
          "200": {
            "description": "Directions response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DirectionsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "postDirections",
        "summary": "Get directions (POST for large requests)",
        "description": "Calculate route directions between up to 200 waypoints using POST method.",
        "tags": ["Directions"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "option",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["flexible"] },
            "description": "Set to 'flexible' for truck routing and advanced options"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DirectionsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Directions response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DirectionsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/distancematrix/json": {
      "get": {
        "operationId": "getDistanceMatrix",
        "summary": "Get distance matrix",
        "description": "Calculate distances and durations between sets of origins and destinations. Use option=flexible for truck routing.",
        "tags": ["DistanceMatrix"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "origins",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Origin coordinates as pipe-separated latitude,longitude pairs"
          },
          {
            "name": "destinations",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Destination coordinates as pipe-separated latitude,longitude pairs"
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["car", "truck", "bike", "foot"] },
            "description": "Transport mode"
          },
          {
            "name": "option",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["flexible"] },
            "description": "Set to 'flexible' for advanced routing"
          }
        ],
        "responses": {
          "200": {
            "description": "Distance matrix response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DistanceMatrixResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "postDistanceMatrix",
        "summary": "Get distance matrix (POST for large requests)",
        "description": "Calculate distance matrix using POST method for larger origin/destination sets.",
        "tags": ["DistanceMatrix"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "option",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["flexible"] }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DistanceMatrixRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Distance matrix response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DistanceMatrixResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/geocode": {
      "get": {
        "operationId": "forwardGeocode",
        "summary": "Forward geocode",
        "description": "Convert a place name, address, or locality to geographic coordinates. Rate limit: 2400 queries/minute.",
        "tags": ["Geocoding"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Search query (place, address, locality)"
          },
          {
            "name": "in",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Country filter (format: countryCode:USA)"
          },
          {
            "name": "at",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Proximity bias coordinates (latitude,longitude)"
          }
        ],
        "responses": {
          "200": {
            "description": "Geocoding results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GeocodeResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/revgeocode": {
      "get": {
        "operationId": "reverseGeocode",
        "summary": "Reverse geocode",
        "description": "Convert geographic coordinates to a human-readable address. Rate limit: 2400 queries/minute.",
        "tags": ["Geocoding"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "at",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Coordinates as latitude,longitude"
          }
        ],
        "responses": {
          "200": {
            "description": "Reverse geocoding results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GeocodeResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/snapToRoads/json": {
      "get": {
        "operationId": "getSnapToRoads",
        "summary": "Snap coordinates to roads",
        "description": "Snap GPS coordinates to the nearest roads. Use GET for fewer than 100 points. Rate limit: 6000 queries/minute.",
        "tags": ["SnapToRoads"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Pipe-separated coordinate points to snap"
          },
          {
            "name": "radiuses",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Pipe-separated search radius for each point"
          },
          {
            "name": "timestamps",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Pipe-separated Unix timestamps per point"
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["car", "truck"] },
            "description": "Vehicle type"
          },
          {
            "name": "geometry",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["geojson", "polyline"] },
            "description": "Output geometry format"
          }
        ],
        "responses": {
          "200": {
            "description": "Snap to roads response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SnapToRoadsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "postSnapToRoads",
        "summary": "Snap coordinates to roads (POST for large requests)",
        "description": "Snap up to 200 GPS coordinates to the nearest roads using POST method.",
        "tags": ["SnapToRoads"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "description": "Pipe-separated coordinate points" },
                  "radiuses": { "type": "string" },
                  "timestamps": { "type": "string" },
                  "mode": { "type": "string" },
                  "geometry": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Snap to roads response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SnapToRoadsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/isochrone/json": {
      "get": {
        "operationId": "getIsochrone",
        "summary": "Calculate isochrone",
        "description": "Calculate reachable area from a point within time or distance constraints. Max 4 isochrones per request. Rate limit: 6000 queries/minute.",
        "tags": ["Isochrone"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "coordinates",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Starting location as latitude,longitude"
          },
          {
            "name": "mode",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["car", "truck", "bike", "foot"] },
            "description": "Transport type"
          },
          {
            "name": "contours_minutes",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Comma-separated time limits in minutes (max 40 minutes, max 4 values)"
          },
          {
            "name": "contours_meters",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Comma-separated distance limits in meters (max 60000m, max 4 values)"
          },
          {
            "name": "denoise",
            "in": "query",
            "required": false,
            "schema": { "type": "number" },
            "description": "Denoising factor; lower values reveal detailed coverage gaps"
          }
        ],
        "responses": {
          "200": {
            "description": "Isochrone response as GeoJSON FeatureCollection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IsochroneResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key passed as query parameter"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - validation failed",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "DirectionsRequest": {
        "type": "object",
        "required": ["origin", "destination"],
        "properties": {
          "origin": { "type": "string", "description": "Origin coordinates" },
          "destination": { "type": "string", "description": "Destination coordinates" },
          "waypoints": { "type": "string", "description": "Intermediate waypoints" },
          "mode": { "type": "string", "enum": ["car", "truck", "bike", "foot"] },
          "avoid": { "type": "string" },
          "alternatives": { "type": "boolean" }
        }
      },
      "DirectionsResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "routes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "summary": { "type": "string" },
                "distance": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "value": { "type": "number" }
                  }
                },
                "duration": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "value": { "type": "number" }
                  }
                },
                "geometry": { "type": "string" },
                "legs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "distance": { "type": "object" },
                      "duration": { "type": "object" },
                      "steps": { "type": "array", "items": { "type": "object" } }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "DistanceMatrixRequest": {
        "type": "object",
        "required": ["origins", "destinations"],
        "properties": {
          "origins": { "type": "string", "description": "Pipe-separated origin coordinates" },
          "destinations": { "type": "string", "description": "Pipe-separated destination coordinates" },
          "mode": { "type": "string" }
        }
      },
      "DistanceMatrixResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "origin_addresses": {
            "type": "array",
            "items": { "type": "string" }
          },
          "destination_addresses": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "elements": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "status": { "type": "string" },
                      "duration": {
                        "type": "object",
                        "properties": {
                          "text": { "type": "string" },
                          "value": { "type": "number" }
                        }
                      },
                      "distance": {
                        "type": "object",
                        "properties": {
                          "text": { "type": "string" },
                          "value": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "GeocodeResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "address": {
                  "type": "object",
                  "properties": {
                    "street": { "type": "string" },
                    "city": { "type": "string" },
                    "state": { "type": "string" },
                    "postalCode": { "type": "string" },
                    "country": { "type": "string" },
                    "countryCode": { "type": "string" },
                    "label": { "type": "string" }
                  }
                },
                "position": {
                  "type": "object",
                  "properties": {
                    "lat": { "type": "number" },
                    "lng": { "type": "number" }
                  }
                },
                "distance": { "type": "number" },
                "mapView": {
                  "type": "object",
                  "properties": {
                    "west": { "type": "number" },
                    "south": { "type": "number" },
                    "east": { "type": "number" },
                    "north": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      },
      "SnapToRoadsResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "snappedPoints": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "location": {
                  "type": "object",
                  "properties": {
                    "latitude": { "type": "number" },
                    "longitude": { "type": "number" }
                  }
                },
                "originalIndex": { "type": "integer" }
              }
            }
          },
          "distance": { "type": "string" },
          "geometry": { "type": "object" }
        }
      },
      "IsochroneResponse": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["FeatureCollection"] },
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["Feature"] },
                "geometry": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string" },
                    "coordinates": { "type": "array", "items": { "type": "array" } }
                  }
                },
                "properties": {
                  "type": "object",
                  "properties": {
                    "contour": { "type": "number" },
                    "metric": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}