  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Use the format: Authorization: Bearer YOUR_API_KEY"
      }
    },
    "schemas": {
      "Agent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the agent"
          },
          "name": {
            "type": "string",
            "description": "Name of the agent"
          },
          "description": {
            "type": "string",
            "description": "Description of the agent"
          },
          "type": {
            "type": "string",
            "enum": ["scraper", "crawler", "screenshot", "automation"],
            "description": "Type of agent"
          },
          "status": {
            "type": "string",
            "enum": ["active", "inactive"],
            "description": "Current status"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      },
      "AgentCreate": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the agent"
          },
          "description": {
            "type": "string",
            "description": "Description of the agent"
          },
          "type": {
            "type": "string",
            "enum": ["scraper", "crawler", "screenshot", "automation"],
            "description": "Type of agent"
          },
          "config": {
            "type": "object",
            "description": "Agent configuration settings"
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the job"
          },
          "agent_id": {
            "type": "string",
            "description": "ID of the agent running this job"
          },
          "status": {
            "type": "string",
            "enum": ["running", "completed", "failed", "stopped"],
            "description": "Current job status"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "Job start time"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "description": "Job completion time"
          },
          "records_processed": {
            "type": "integer",
            "description": "Number of records processed"
          },
          "errors": {
            "type": "integer",
            "description": "Number of errors encountered"
          }
        }
      },
      "JobCreate": {
        "type": "object",
        "required": ["agent_id"],
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "ID of the agent to run"
          },
          "input_urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "URLs to process"
          },
          "input_list_id": {
            "type": "string",
            "description": "ID of input list to use"
          },
          "config": {
            "type": "object",
            "description": "Job-specific configuration overrides"
          }
        }
      },
      "DataList": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the list"
          },
          "name": {
            "type": "string",
            "description": "Name of the list"
          },
          "description": {
            "type": "string",
            "description": "Description of the list"
          },
          "row_count": {
            "type": "integer",
            "description": "Number of rows in the list"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "details": {
            "type": "object",
            "description": "Additional error details"
          }
        }
      }
    }
  }
}
