{
  "openapi": "3.0.3",
  "info": {
    "title": "Capital.com Trading API",
    "description": "Capital.com REST API for trading CFDs, managing positions, orders, watchlists, and retrieving market data and client sentiment.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://open-api.capital.com/"
  },
  "servers": [
    {
      "url": "https://api-capital.backend-capital.com",
      "description": "Live trading server"
    },
    {
      "url": "https://demo-api-capital.backend-capital.com",
      "description": "Demo trading server"
    }
  ],
  "security": [
    {
      "CSTToken": [],
      "SecurityToken": []
    }
  ],
  "tags": [
    { "name": "Session", "description": "Session management and authentication" },
    { "name": "Accounts", "description": "Account information and preferences" },
    { "name": "Positions", "description": "Trading position management" },
    { "name": "WorkingOrders", "description": "Working order management" },
    { "name": "Markets", "description": "Market information and navigation" },
    { "name": "Prices", "description": "Historical price data" },
    { "name": "ClientSentiment", "description": "Client sentiment data" },
    { "name": "Watchlists", "description": "Watchlist management" },
    { "name": "General", "description": "General utility endpoints" }
  ],
  "paths": {
    "/api/v1/ping": {
      "get": {
        "operationId": "pingService",
        "summary": "Ping the service to check connectivity",
        "tags": ["General"],
        "responses": {
          "200": {
            "description": "Service is reachable",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PingResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/time": {
      "get": {
        "operationId": "getServerTime",
        "summary": "Get current server time",
        "tags": ["General"],
        "security": [],
        "responses": {
          "200": {
            "description": "Server time retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServerTimeResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/v1/session/encryptionKey": {
      "get": {
        "operationId": "getEncryptionKey",
        "summary": "Get encryption key for password encryption",
        "tags": ["Session"],
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Encryption key retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EncryptionKeyResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/session": {
      "get": {
        "operationId": "getSessionDetails",
        "summary": "Get current session details",
        "tags": ["Session"],
        "responses": {
          "200": {
            "description": "Session details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SessionDetailsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createSession",
        "summary": "Create a new trading session (login)",
        "tags": ["Session"],
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSessionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created successfully. CST and X-SECURITY-TOKEN returned in headers.",
            "headers": {
              "CST": {
                "description": "Client session token",
                "schema": { "type": "string" }
              },
              "X-SECURITY-TOKEN": {
                "description": "Account security token",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SessionDetailsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "switchActiveAccount",
        "summary": "Switch the active account",
        "tags": ["Session"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SwitchAccountRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account switched successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SwitchAccountResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteSession",
        "summary": "Log out and delete the current session",
        "tags": ["Session"],
        "responses": {
          "200": {
            "description": "Session deleted successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/accounts": {
      "get": {
        "operationId": "getAllAccounts",
        "summary": "Retrieve all accounts for the current session",
        "tags": ["Accounts"],
        "responses": {
          "200": {
            "description": "Accounts retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccountsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/accounts/preferences": {
      "get": {
        "operationId": "getAccountPreferences",
        "summary": "Get account preferences",
        "tags": ["Accounts"],
        "responses": {
          "200": {
            "description": "Preferences retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccountPreferencesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateAccountPreferences",
        "summary": "Update account preferences",
        "tags": ["Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdatePreferencesRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Preferences updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/accounts/topUp": {
      "post": {
        "operationId": "topUpDemoAccount",
        "summary": "Adjust demo account balance",
        "tags": ["Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TopUpRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Top-up successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TopUpResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/history/activity": {
      "get": {
        "operationId": "getActivityHistory",
        "summary": "Get account activity history",
        "tags": ["Accounts"],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Start date (ISO 8601)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End date (ISO 8601)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "lastPeriod",
            "in": "query",
            "description": "Time period in seconds",
            "schema": { "type": "integer" }
          },
          {
            "name": "detailed",
            "in": "query",
            "description": "Include detailed information",
            "schema": { "type": "boolean" }
          },
          {
            "name": "dealId",
            "in": "query",
            "description": "Filter by deal ID",
            "schema": { "type": "string" }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Activity type filter",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Activity history retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActivityHistoryResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/history/transactions": {
      "get": {
        "operationId": "getTransactionsHistory",
        "summary": "Get account transaction history",
        "tags": ["Accounts"],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Start date (ISO 8601)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End date (ISO 8601)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "lastPeriod",
            "in": "query",
            "description": "Time period in seconds",
            "schema": { "type": "integer" }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Transaction type filter",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction history retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TransactionsHistoryResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/confirms/{dealReference}": {
      "get": {
        "operationId": "getDealConfirmation",
        "summary": "Get deal confirmation by reference",
        "tags": ["Positions"],
        "parameters": [
          {
            "name": "dealReference",
            "in": "path",
            "required": true,
            "description": "Deal reference identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Deal confirmation retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DealConfirmationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/positions": {
      "get": {
        "operationId": "getAllPositions",
        "summary": "Retrieve all open positions",
        "tags": ["Positions"],
        "responses": {
          "200": {
            "description": "Positions retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PositionsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createPosition",
        "summary": "Create a new trading position",
        "tags": ["Positions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePositionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Position created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DealReferenceResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/positions/{dealId}": {
      "get": {
        "operationId": "getPosition",
        "summary": "Retrieve a single position by deal ID",
        "tags": ["Positions"],
        "parameters": [
          {
            "name": "dealId",
            "in": "path",
            "required": true,
            "description": "Position deal identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Position retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Position" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updatePosition",
        "summary": "Update position stop loss and take profit",
        "tags": ["Positions"],
        "parameters": [
          {
            "name": "dealId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdatePositionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Position updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "closePosition",
        "summary": "Close a position",
        "tags": ["Positions"],
        "parameters": [
          {
            "name": "dealId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Position closed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DealReferenceResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/workingorders": {
      "get": {
        "operationId": "getAllWorkingOrders",
        "summary": "Retrieve all active working orders",
        "tags": ["WorkingOrders"],
        "responses": {
          "200": {
            "description": "Working orders retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkingOrdersResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createWorkingOrder",
        "summary": "Create a new working order",
        "tags": ["WorkingOrders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateWorkingOrderRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Working order created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DealReferenceResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/workingorders/{dealId}": {
      "put": {
        "operationId": "updateWorkingOrder",
        "summary": "Update a working order",
        "tags": ["WorkingOrders"],
        "parameters": [
          {
            "name": "dealId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateWorkingOrderRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Working order updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteWorkingOrder",
        "summary": "Delete a working order",
        "tags": ["WorkingOrders"],
        "parameters": [
          {
            "name": "dealId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Working order deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DealReferenceResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/marketnavigation": {
      "get": {
        "operationId": "getMarketNavigation",
        "summary": "Retrieve top-level market categories",
        "tags": ["Markets"],
        "responses": {
          "200": {
            "description": "Market categories retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MarketNavigationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/marketnavigation/{nodeId}": {
      "get": {
        "operationId": "getMarketNavigationNode",
        "summary": "Retrieve subcategories and instruments for a node",
        "tags": ["Markets"],
        "parameters": [
          {
            "name": "nodeId",
            "in": "path",
            "required": true,
            "description": "Market category node identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Node details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MarketNavigationNodeResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/markets": {
      "get": {
        "operationId": "searchMarkets",
        "summary": "Search for markets by term",
        "tags": ["Markets"],
        "parameters": [
          {
            "name": "searchTerm",
            "in": "query",
            "description": "Search term for market name",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Markets retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MarketsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/markets/{epic}": {
      "get": {
        "operationId": "getMarketDetails",
        "summary": "Retrieve details for a single market",
        "tags": ["Markets"],
        "parameters": [
          {
            "name": "epic",
            "in": "path",
            "required": true,
            "description": "Market instrument identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Market details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MarketDetail" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/prices/{epic}": {
      "get": {
        "operationId": "getHistoricalPrices",
        "summary": "Retrieve historical price data for a market",
        "tags": ["Prices"],
        "parameters": [
          {
            "name": "epic",
            "in": "path",
            "required": true,
            "description": "Market instrument identifier",
            "schema": { "type": "string" }
          },
          {
            "name": "resolution",
            "in": "query",
            "required": true,
            "description": "Price resolution",
            "schema": {
              "type": "string",
              "enum": ["MINUTE", "MINUTE_5", "MINUTE_15", "MINUTE_30", "HOUR", "HOUR_4", "DAY", "WEEK"]
            }
          },
          {
            "name": "max",
            "in": "query",
            "description": "Maximum number of price bars to return (default 20, max 1000)",
            "schema": { "type": "integer", "default": 20, "maximum": 1000 }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Start date (ISO 8601)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End date (ISO 8601)",
            "schema": { "type": "string", "format": "date-time" }
          }
        ],
        "responses": {
          "200": {
            "description": "Historical prices retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PricesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/clientsentiment": {
      "get": {
        "operationId": "getClientSentiment",
        "summary": "Retrieve client sentiment across all markets",
        "tags": ["ClientSentiment"],
        "parameters": [
          {
            "name": "max",
            "in": "query",
            "description": "Maximum number of results",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Client sentiment retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ClientSentimentListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/clientsentiment/{epic}": {
      "get": {
        "operationId": "getMarketSentiment",
        "summary": "Retrieve client sentiment for a specific market",
        "tags": ["ClientSentiment"],
        "parameters": [
          {
            "name": "epic",
            "in": "path",
            "required": true,
            "description": "Market instrument identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Market sentiment retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ClientSentiment" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/watchlists": {
      "get": {
        "operationId": "getAllWatchlists",
        "summary": "Retrieve all watchlists",
        "tags": ["Watchlists"],
        "responses": {
          "200": {
            "description": "Watchlists retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WatchlistsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createWatchlist",
        "summary": "Create a new watchlist",
        "tags": ["Watchlists"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateWatchlistRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Watchlist created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Watchlist" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/watchlists/{watchlistId}": {
      "get": {
        "operationId": "getWatchlist",
        "summary": "Retrieve watchlist contents",
        "tags": ["Watchlists"],
        "parameters": [
          {
            "name": "watchlistId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Watchlist retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WatchlistDetailResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "addMarketToWatchlist",
        "summary": "Add a market to a watchlist",
        "tags": ["Watchlists"],
        "parameters": [
          {
            "name": "watchlistId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddMarketToWatchlistRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Market added to watchlist",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteWatchlist",
        "summary": "Delete an entire watchlist",
        "tags": ["Watchlists"],
        "parameters": [
          {
            "name": "watchlistId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Watchlist deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/watchlists/{watchlistId}/{epic}": {
      "delete": {
        "operationId": "removeMarketFromWatchlist",
        "summary": "Remove a market from a watchlist",
        "tags": ["Watchlists"],
        "parameters": [
          {
            "name": "watchlistId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "epic",
            "in": "path",
            "required": true,
            "description": "Market instrument identifier to remove",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Market removed from watchlist",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "CSTToken": {
        "type": "apiKey",
        "in": "header",
        "name": "CST",
        "description": "Client session token obtained from POST /api/v1/session"
      },
      "SecurityToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-SECURITY-TOKEN",
        "description": "Account security token obtained from POST /api/v1/session"
      },
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CAP-API-KEY",
        "description": "API key for creating sessions"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters or request body",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or expired session tokens",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errorCode": { "type": "string" }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" }
        }
      },
      "PingResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "OK" }
        }
      },
      "ServerTimeResponse": {
        "type": "object",
        "properties": {
          "serverTime": { "type": "integer", "description": "Server time in milliseconds" }
        }
      },
      "EncryptionKeyResponse": {
        "type": "object",
        "properties": {
          "encryptionKey": { "type": "string" },
          "timeStamp": { "type": "integer" }
        }
      },
      "CreateSessionRequest": {
        "type": "object",
        "required": ["identifier", "password"],
        "properties": {
          "identifier": { "type": "string", "description": "Email or username" },
          "password": { "type": "string", "description": "Password (plain or encrypted)" },
          "encryptedPassword": { "type": "boolean", "description": "Whether the password is encrypted" }
        }
      },
      "SessionDetailsResponse": {
        "type": "object",
        "properties": {
          "clientId": { "type": "string" },
          "accountId": { "type": "string" },
          "timezoneOffset": { "type": "integer" },
          "locale": { "type": "string" },
          "currency": { "type": "string" },
          "streamEndpoint": { "type": "string" }
        }
      },
      "SwitchAccountRequest": {
        "type": "object",
        "required": ["accountId"],
        "properties": {
          "accountId": { "type": "string" }
        }
      },
      "SwitchAccountResponse": {
        "type": "object",
        "properties": {
          "trailingStopsEnabled": { "type": "boolean" },
          "dealingEnabled": { "type": "boolean" },
          "hasActiveDemoAccounts": { "type": "boolean" },
          "hasActiveLiveAccounts": { "type": "boolean" }
        }
      },
      "AccountsResponse": {
        "type": "object",
        "properties": {
          "accounts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Account" }
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "accountId": { "type": "string" },
          "accountName": { "type": "string" },
          "accountType": { "type": "string" },
          "balance": {
            "type": "object",
            "properties": {
              "balance": { "type": "number" },
              "deposit": { "type": "number" },
              "profitLoss": { "type": "number" },
              "available": { "type": "number" }
            }
          }
        }
      },
      "AccountPreferencesResponse": {
        "type": "object",
        "properties": {
          "hedgingMode": { "type": "boolean" },
          "leverages": { "type": "object", "additionalProperties": { "type": "number" } }
        }
      },
      "UpdatePreferencesRequest": {
        "type": "object",
        "properties": {
          "hedgingMode": { "type": "boolean" },
          "leverages": { "type": "object", "additionalProperties": { "type": "number" } }
        }
      },
      "TopUpRequest": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": { "type": "number", "description": "Amount to adjust (-400000 to 400000)" }
        }
      },
      "TopUpResponse": {
        "type": "object",
        "properties": {
          "successful": { "type": "boolean" }
        }
      },
      "ActivityHistoryResponse": {
        "type": "object",
        "properties": {
          "activities": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Activity" }
          }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date-time" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "epic": { "type": "string" },
          "dealId": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "TransactionsHistoryResponse": {
        "type": "object",
        "properties": {
          "transactions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Transaction" }
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date-time" },
          "type": { "type": "string" },
          "reference": { "type": "string" },
          "instrumentName": { "type": "string" },
          "size": { "type": "number" },
          "openLevel": { "type": "number" },
          "closeLevel": { "type": "number" },
          "profitAndLoss": { "type": "string" }
        }
      },
      "DealConfirmationResponse": {
        "type": "object",
        "properties": {
          "dealId": { "type": "string" },
          "dealReference": { "type": "string" },
          "dealStatus": { "type": "string" },
          "direction": { "type": "string" },
          "epic": { "type": "string" },
          "status": { "type": "string" },
          "affectedDeals": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "dealId": { "type": "string" },
                "status": { "type": "string" }
              }
            }
          }
        }
      },
      "DealReferenceResponse": {
        "type": "object",
        "properties": {
          "dealReference": { "type": "string" },
          "dealId": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "PositionsResponse": {
        "type": "object",
        "properties": {
          "positions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Position" }
          }
        }
      },
      "Position": {
        "type": "object",
        "properties": {
          "dealId": { "type": "string" },
          "epic": { "type": "string" },
          "direction": { "type": "string", "enum": ["BUY", "SELL"] },
          "size": { "type": "number" },
          "openLevel": { "type": "number" },
          "closeLevel": { "type": "number" },
          "status": { "type": "string" },
          "stopLoss": { "type": "number" },
          "takeProfit": { "type": "number" },
          "profit": { "type": "number" }
        }
      },
      "CreatePositionRequest": {
        "type": "object",
        "required": ["epic", "direction", "size"],
        "properties": {
          "epic": { "type": "string", "description": "Market instrument identifier" },
          "direction": { "type": "string", "enum": ["BUY", "SELL"] },
          "size": { "type": "number", "description": "Position size" },
          "orderType": { "type": "string", "enum": ["MARKET", "LIMIT"] },
          "stopLoss": { "type": "number" },
          "takeProfit": { "type": "number" }
        }
      },
      "UpdatePositionRequest": {
        "type": "object",
        "properties": {
          "stopLoss": { "type": "number" },
          "takeProfit": { "type": "number" }
        }
      },
      "WorkingOrdersResponse": {
        "type": "object",
        "properties": {
          "workingOrders": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/WorkingOrder" }
          }
        }
      },
      "WorkingOrder": {
        "type": "object",
        "properties": {
          "dealId": { "type": "string" },
          "epic": { "type": "string" },
          "direction": { "type": "string", "enum": ["BUY", "SELL"] },
          "size": { "type": "number" },
          "orderLevel": { "type": "number" },
          "stopDistance": { "type": "number" },
          "profitDistance": { "type": "number" },
          "orderType": { "type": "string", "enum": ["LIMIT", "STOP"] },
          "timeInForce": { "type": "string", "enum": ["GTC", "GTD"] },
          "status": { "type": "string" }
        }
      },
      "CreateWorkingOrderRequest": {
        "type": "object",
        "required": ["epic", "direction", "size", "orderType", "orderLevel"],
        "properties": {
          "epic": { "type": "string" },
          "direction": { "type": "string", "enum": ["BUY", "SELL"] },
          "size": { "type": "number" },
          "orderType": { "type": "string", "enum": ["LIMIT", "STOP"] },
          "orderLevel": { "type": "number", "description": "Trigger price" },
          "stopDistance": { "type": "number" },
          "profitDistance": { "type": "number" },
          "timeInForce": { "type": "string", "enum": ["GTC", "GTD"] }
        }
      },
      "UpdateWorkingOrderRequest": {
        "type": "object",
        "properties": {
          "orderLevel": { "type": "number" },
          "stopDistance": { "type": "number" },
          "profitDistance": { "type": "number" }
        }
      },
      "MarketNavigationResponse": {
        "type": "object",
        "properties": {
          "nodes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MarketNode" }
          }
        }
      },
      "MarketNavigationNodeResponse": {
        "type": "object",
        "properties": {
          "nodes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MarketNode" }
          },
          "markets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MarketSummary" }
          }
        }
      },
      "MarketNode": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "MarketsResponse": {
        "type": "object",
        "properties": {
          "markets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MarketSummary" }
          }
        }
      },
      "MarketSummary": {
        "type": "object",
        "properties": {
          "epic": { "type": "string" },
          "name": { "type": "string" },
          "instrumentType": { "type": "string" },
          "bid": { "type": "number" },
          "offer": { "type": "number" },
          "lotSize": { "type": "number" },
          "maxStakeSize": { "type": "number" },
          "minStakeSize": { "type": "number" }
        }
      },
      "MarketDetail": {
        "type": "object",
        "properties": {
          "epic": { "type": "string" },
          "name": { "type": "string" },
          "instrumentType": { "type": "string" },
          "bid": { "type": "number" },
          "offer": { "type": "number" },
          "netChange": { "type": "number" },
          "percentageChange": { "type": "number" },
          "lotSize": { "type": "number" },
          "minStakeSize": { "type": "number" },
          "maxStakeSize": { "type": "number" },
          "marginFactor": { "type": "number" },
          "marginFactorUnit": { "type": "string" },
          "slippageFactor": { "type": "number" },
          "expiry": { "type": "string" },
          "multiplier": { "type": "number" }
        }
      },
      "PricesResponse": {
        "type": "object",
        "properties": {
          "instrumentType": { "type": "string" },
          "metadata": {
            "type": "object",
            "properties": {
              "allowance": {
                "type": "object",
                "properties": {
                  "remainingAllowance": { "type": "integer" },
                  "totalAllowance": { "type": "integer" },
                  "nextAllowanceRefresh": { "type": "integer" }
                }
              },
              "size": { "type": "integer" },
              "pageData": {
                "type": "object",
                "properties": {
                  "pageSize": { "type": "integer" }
                }
              }
            }
          },
          "prices": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PriceBar" }
          }
        }
      },
      "PriceBar": {
        "type": "object",
        "properties": {
          "snapshotTime": { "type": "string", "format": "date-time" },
          "lastUpdated": { "type": "string", "format": "date-time" },
          "bid": { "$ref": "#/components/schemas/OHLC" },
          "ofr": { "$ref": "#/components/schemas/OHLC" },
          "ohlc": { "$ref": "#/components/schemas/OHLC" }
        }
      },
      "OHLC": {
        "type": "object",
        "properties": {
          "open": { "type": "number" },
          "high": { "type": "number" },
          "low": { "type": "number" },
          "close": { "type": "number" }
        }
      },
      "ClientSentimentListResponse": {
        "type": "object",
        "properties": {
          "clientSentiments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ClientSentiment" }
          }
        }
      },
      "ClientSentiment": {
        "type": "object",
        "properties": {
          "epic": { "type": "string" },
          "longPositionPercentage": { "type": "number" },
          "shortPositionPercentage": { "type": "number" }
        }
      },
      "WatchlistsResponse": {
        "type": "object",
        "properties": {
          "watchlists": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Watchlist" }
          }
        }
      },
      "Watchlist": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "editable": { "type": "boolean" }
        }
      },
      "WatchlistDetailResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "markets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MarketSummary" }
          }
        }
      },
      "CreateWatchlistRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "description": "Watchlist name" }
        }
      },
      "AddMarketToWatchlistRequest": {
        "type": "object",
        "required": ["epic"],
        "properties": {
          "epic": { "type": "string", "description": "Market instrument identifier to add" }
        }
      }
    }
  }
}