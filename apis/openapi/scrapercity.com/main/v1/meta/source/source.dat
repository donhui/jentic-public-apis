{
  "openapi": "3.0.3",
  "info": {
    "title": "ScraperCity API",
    "version": "v1",
    "description": "ScraperCity provides ready-to-run web scrapers for instant lead lists. The API allows you to scrape leads from various platforms including Apollo, Google Maps, Yelp, and more. Scrape jobs are asynchronous - start a scrape, poll for status, then download results.",
    "x-jentic-source-url": "https://scrapercity.com/api-docs"
  },
  "servers": [
    {
      "url": "https://app.scrapercity.com/api/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Scrape",
      "description": "Start scraping jobs on various platforms"
    },
    {
      "name": "Status",
      "description": "Check scrape job status"
    },
    {
      "name": "Download",
      "description": "Download scrape results"
    },
    {
      "name": "Database",
      "description": "Query lead, local business, and ecommerce databases"
    }
  ],
  "paths": {
    "/scrape/apollo": {
      "post": {
        "operationId": "scrapeapollo",
        "summary": "Scrape Apollo leads",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApolloScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/google-maps": {
      "post": {
        "operationId": "scrapegooglemaps",
        "summary": "Scrape Google Maps businesses",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/people-finder": {
      "post": {
        "operationId": "scrapepeoplefinder",
        "summary": "Skiptrace / People Finder",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/email-validator": {
      "post": {
        "operationId": "scrapeemailvalidator",
        "summary": "Validate emails",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/youtube": {
      "post": {
        "operationId": "scrapeyoutube",
        "summary": "Scrape YouTube channel emails",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/airbnb": {
      "post": {
        "operationId": "scrapeairbnb",
        "summary": "Scrape Airbnb pro host emails",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/yelp": {
      "post": {
        "operationId": "scrapeyelp",
        "summary": "Scrape Yelp listings",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/domain-email": {
      "post": {
        "operationId": "scrapedomainemail",
        "summary": "Find emails for a domain",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/bizbuysell": {
      "post": {
        "operationId": "scrapebizbuysell",
        "summary": "Scrape BizBuySell listings",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/scrape/crexi": {
      "post": {
        "operationId": "scrapecrexi",
        "summary": "Scrape Crexi property listings",
        "tags": [
          "Scrape"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape job started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStartResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/status/{runId}": {
      "get": {
        "operationId": "getscrapestatus",
        "summary": "Get scrape job status",
        "tags": [
          "Status"
        ],
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The run ID returned from a scrape request"
          }
        ],
        "responses": {
          "200": {
            "description": "Scrape job status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStatus"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/download/{runId}": {
      "get": {
        "operationId": "downloadresults",
        "summary": "Download scrape results",
        "description": "Download results once a scrape job completes. Results are stored for 48 hours.",
        "tags": [
          "Download"
        ],
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The run ID returned from a scrape request"
          }
        ],
        "responses": {
          "200": {
            "description": "Scrape results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeResults"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/database/leads": {
      "get": {
        "operationId": "queryleaddatabase",
        "summary": "Query the lead database",
        "description": "Returns up to 100 records per request. Daily limit of 100,000 records. Included with $649/mo plan.",
        "tags": [
          "Database"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 100
            },
            "description": "Number of records to return (max 100)"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "Lead results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatabaseResults"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/database/local-business": {
      "get": {
        "operationId": "querylocalbusinessdatabase",
        "summary": "Query the local business database",
        "description": "Returns up to 100 records per request. Included with $649/mo plan.",
        "tags": [
          "Database"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 100
            },
            "description": "Number of records to return (max 100)"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "Local business results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatabaseResults"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/database/ecommerce": {
      "get": {
        "operationId": "queryecommercedatabase",
        "summary": "Query the ecommerce store database",
        "description": "Returns up to 100 records per request. Included with $649/mo plan.",
        "tags": [
          "Database"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 100
            },
            "description": "Number of records to return (max 100)"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "Ecommerce store results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatabaseResults"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key created in your ScraperCity dashboard"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ApolloScrapeRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "Apollo search URL to scrape"
          },
          "count": {
            "type": "integer",
            "description": "Number of leads to scrape",
            "example": 1000
          }
        }
      },
      "UrlScrapeRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to scrape"
          },
          "count": {
            "type": "integer",
            "description": "Number of results to scrape"
          }
        }
      },
      "ScrapeStartResponse": {
        "type": "object",
        "properties": {
          "runId": {
            "type": "string",
            "description": "Unique identifier for this scrape job"
          },
          "message": {
            "type": "string",
            "description": "Human-readable status message"
          }
        }
      },
      "ScrapeStatus": {
        "type": "object",
        "properties": {
          "runId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "running",
              "completed",
              "failed"
            ]
          },
          "progress": {
            "type": "integer",
            "description": "Progress percentage (0-100)"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ScrapeResults": {
        "type": "object",
        "properties": {
          "runId": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Array of scraped result objects"
          },
          "total": {
            "type": "integer",
            "description": "Total number of results"
          }
        }
      },
      "DatabaseResults": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Array of database records"
          },
          "total": {
            "type": "integer",
            "description": "Total number of matching records"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    }
  }
}