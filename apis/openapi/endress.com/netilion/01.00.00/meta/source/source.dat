    "/thresholds/{threshold_id}/specifications": {
      "get": {
        "summary": "Get specifications of a threshold",
        "operationId": "getSpecificationsOfThreshold",
        "description": "Returns the specification of an object in your accessible scope. If no specifications are defined, this is just an empty object. Specification must have the form below.",
        "parameters": [
          {
            "name": "threshold_id",
            "in": "path",
            "description": "Id of the specified threshold",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "required": true
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "Filter accepts '*' as wildcard"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpecificationsResponse"
                }
              }
            }
          },
          "304": {
            "$ref": "#/components/responses/304"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Threshold",
          "Specification"
        ]
      },
      "patch": {
        "summary": "Update specifications of a threshold",
        "operationId": "updateSpecificationsOfThreshold",
        "description": "Update the specification object of a threshold in your accessible scope. To add specifications, just add the key and set the value object with value, unit and source_timestamp. To mark an existing specification to be unknown, the value could be set to null. To delete keys, use the delete method. Multiple specification objects can be sent in the same request. Keys inside a specification are unique and can only be added once. Keys can only consist of a-z A-Z 0-9 . - _ all uppercase A-Z are converted to lower-case a-z. For a key that is send multiple times in the request body, only the last key-value is saved.",
        "parameters": [
          {
            "name": "threshold_id",
            "in": "path",
            "description": "Id of the specified threshold",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "required": true
          }
        ],
        "responses": {
          "204": {
            "$ref": "#/components/responses/204"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Threshold",
          "Specification"
        ],
        "requestBody": {
          "description": "The specifications objects to patch.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SpecificationsRequest"
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete specifications of a threshold",
        "operationId": "removeSpecificationsFromThreshold",
        "description": "The specification keys in the body will be removed of the object in your accessible scope. Multiple specification keys can be sent in the same request. If a key does not exist it will be ignored.",
        "parameters": [
          {
            "name": "threshold_id",
            "in": "path",
            "description": "Id of the specified threshold",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "required": true
          }
        ],
        "responses": {
          "204": {
            "$ref": "#/components/responses/204"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Threshold",
          "Specification"
        ],
        "requestBody": {
          "description": "Array of keys to delete from specifications",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SpecificationsDelete"
              }
            }
          }
        }
      }
    },
