                  },
                  "remarks": {
                    "type": "string"
                  },
                  "languages": {
                    "type": "string",
                    "description": "the files content languages. Send as comma separated list with alpha2 language codes (eg. de,en,fr). Supported languages are defined in ISO639-1"
                  }
                },
                "required": [
                  "image",
                  "document_id"
                ]
              }
            }
          }
        },
        "responses": {
          "204": {
            "$ref": "#/components/responses/204"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
