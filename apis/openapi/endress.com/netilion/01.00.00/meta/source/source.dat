      "post": {
        "summary": "Updates the information of a connected asset.",
        "operationId": "updateConnectedAssetInformation",
        "description": "Updates the information of a connected asset and processes all measured values collected by a connected asset:\n* By adding ```accept: application/json+get``` to the header, the response will contain the updated information \nfor the connected asset. Otherwise the response will be empty.",
        "parameters": [
          {
