    "/assets/{asset_id}/product-options": {
      "get": {
        "summary": "Get all possible products of the specified assets",
        "operationId": "getAssetProductOptions",
        "description": "Returns a list of all possible products for the specified asset.\nYou can apply the query parameters listed below to get a filtered list.\nParameters supporting translation: ```name, description```. To get a translation set Accept-Language.\nPossible include values: ```status, tenant, parent, manufacturer, pictures, categories, categories.parent```",
        "parameters": [
          {
            "name": "asset_id",
            "in": "path",
            "description": "Id of the specified asset",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "required": true
          },
          {
            "$ref": "#/components/parameters/Pagination_Page"
          },
          {
            "$ref": "#/components/parameters/Pagination_Per_Page"
          },
          {
            "$ref": "#/components/parameters/IncludeTotalCountParam"
          },
          {
            "$ref": "#/components/parameters/IncludeParam"
          },
          {
            "$ref": "#/components/parameters/ProductCodeFilter"
          },
          {
            "$ref": "#/components/parameters/NameFilter"
          },
          {
            "$ref": "#/components/parameters/ManufacturerIDFilter"
          },
          {
            "$ref": "#/components/parameters/StatusIDFilter"
          },
          {
            "$ref": "#/components/parameters/CategoryIDFilter"
          },
          {
            "$ref": "#/components/parameters/ParentIDFilter"
          },
          {
            "$ref": "#/components/parameters/TenantIDFilter"
          },
          {
            "$ref": "#/components/parameters/DefaultOrderBy"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "title": "products",
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ProductResponse"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
