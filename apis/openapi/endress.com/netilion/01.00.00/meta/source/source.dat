          "event_type",
          "value"
        ],
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether the notification is enabled or not (default true)."
          },
          "event_type": {
            "type": "string",
            "description": "possible values are: 'health_status', 'event_created'"
          },
          "asset_statuses": {
            "type": "array",
            "description": "An array of asset status code strings in case of 'health_status' type. Example: ['out_of_specification']",
            "items": {
              "type": "string"
            }
          },
          "diagnosis_codes": {
            "type": "array",
            "description": "An array of diagnosis code strings in case of 'health_status' type. Example: ['F123']",
            "items": {
              "type": "string"
            }
          },
          "specification_keys": {
            "type": "array",
            "description": "An array of event specification key strings in case of 'event_created' type. Example: ['eh.pcps.asset_health.failure']",
            "items": {
              "type": "string"
            }
          },
          "user_specific": {
            "type": "boolean",
            "description": "Whether the notification is user specific or public (default false).",
            "default": false
          }
        }
      },
