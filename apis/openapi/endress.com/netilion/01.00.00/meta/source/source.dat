    "/connected_assets/{asset_id}/upload": {
      "post": {
        "summary": "Create and upload a new file attached to the asset",
        "operationId": "uploadFileByConnectedAsset",
        "description": "The creation of a file works through a multipart/form-data upload of the file, its name, version and category.\nThis creates a document of the given name, version and category. The uploaded file will then be attached to the document as \nattachment.\nSpecial characters (&$+,/:;=?@<>[]{}|^~%#) and white spaces in the file name will be replaced with underscores.\n\nForbidden content-types are\n- application/xhtml+xml\n- text/html\n- application/javascript\n- text/javascript\n- application/x-shockwave-flash\n- application/vnd.adobe.flash.movie\n- video/x-flv\n- text/php\n- application/php\n- application/x-php\n- application/x-httpd-php",
        "parameters": [
          {
            "name": "asset_id",
            "in": "path",
            "description": "Id of the asset to assign the document to.",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "required": true
          }
        ],
        "requestBody": {
          "description": "The file to upload",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "name": {
                    "type": "string",
                    "description": "the name of the document"
                  },
                  "version": {
                    "type": "string",
                    "description": "the version of the document"
                  },
                  "category": {
                    "type": "string",
                    "description": "an existing category code to be assigned to the document"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/201"
          }
        },
        "tags": [
          "ConnectedAssetAPI"
        ]
      }
    },
    "/delivery/statuses": {
