              "type": "string",
              "pattern": "^\\d+(,\\d+)*$"
            },
            "required": false
          },
          {
            "name": "assignable_type",
            "in": "query",
            "description": "Filter by a specific type of assignables eg. `User` or `Usergroup`.",
            "schema": {
              "type": "string"
            },
