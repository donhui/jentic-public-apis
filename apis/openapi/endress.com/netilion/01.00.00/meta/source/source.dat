    "/instrumentations/search": {
      "post": {
        "summary": "Post equivalent of `GET /instrumentations`",
        "operationId": "postInstrumentationsSearch",
        "description": "This endpoint is a replicates the behaviour of the `GET /instrumentations` endpoint and accepts the request parameters as json body instead. It returns a list of instrumentations in your accessible scope. If the query has no matches, the response is an empty list.\n\nPossible include values: ```assets, assets.status, assets.specifications, nodes, nodes.type, specifications, specifications[key1,key2], pictures, tenant, parent, status, worst_asset_status, type, type.tenant, type.parent, values, values.unit, values_in_preferred_units, values_in_preferred_units.unit``` ",
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstrumentationsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "402": {
            "$ref": "#/components/responses/402"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Instrumentation"
        ],
        "requestBody": {
          "description": "JSON Object with the same parameters as the GET /instrumentations endpoint",
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "asset_id": {
                    "type": "string",
                    "description": "A comma separated list of all asset ids e.g. \"654,1234\""
                  }
                }
              }
            }
          }
        }
      }
    },
