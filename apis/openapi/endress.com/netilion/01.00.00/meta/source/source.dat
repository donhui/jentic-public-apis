          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Product",
          "Specification"
        ],
        "requestBody": {
          "description": "The specifications object to patch.",
