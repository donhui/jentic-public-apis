            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "402": {
            "$ref": "#/components/responses/402"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "SoftwareAttachment"
        ]
      },
      "post": {
        "summary": "Create and upload a new software attachment",
        "operationId": "uploadSoftwareAttachment",
        "description": "the creation of an software attachment works through a multipart/form-data upload of the file and its filename.\n\nForbidden content-types are\n\n- application/xhtml+xml\n- text/html\n- application/javascript\n- text/javascript\n- application/x-shockwave-flash\n- application/vnd.adobe.flash.movie\n- video/x-flv\n- text/php\n- application/php\n- application/x-php\n- application/x-httpd-php",
        "requestBody": {
          "description": "The file to upload",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "the filedata to upload"
                  },
                  "software_id": {
                    "type": "integer",
                    "format": "int64",
                    "description": "the software id this software attachment belongs to"
                  },
                  "blob_id": {
                    "type": "string",
                    "description": "blob id of the direct uploaded software file"
                  },
                  "content_date": {
                    "type": "string",
                    "format": "dateTime",
                    "description": "last edit date of the file. Datetime must be in format YYYY-MM-DD or YYYY-MM-DDThh:mm:ss"
                  },
                  "remarks": {
                    "type": "string"
                  }
                },
                "required": [
                  "file",
                  "software_id"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The software attachment was created successful and the file is saved. The response body contains the software attachment representation",
            "headers": {
              "Location": {
                "description": "url of the created software attachment",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SoftwareAttachmentResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "402": {
            "$ref": "#/components/responses/402"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "SoftwareAttachment"
        ]
      }
    },
