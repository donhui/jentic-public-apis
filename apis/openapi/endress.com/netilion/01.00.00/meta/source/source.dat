    "parameters": {
      "AcceptLanguageHeader": {
        "name": "Accept-Language",
        "in": "header",
        "description": "The client's accepted languages. One or several (e.g. fr,de,en)",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AccessibilityFilter": {
        "name": "accessibility",
        "in": "query",
        "description": "Filter accepts undefined, easy, moderate or difficult",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AddOnPathID": {
        "name": "add_on_id",
        "in": "path",
        "description": "The ID of the Add-On",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "AddOnScopeFilter": {
        "name": "scope",
        "in": "query",
        "description": "Filter accepts `USABLE`",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AddOnTypeFilter": {
        "name": "add_on_type",
        "in": "query",
        "description": "Filter accepts addon, connectivity or outcome",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AdminOrUserIDFilter": {
        "name": "admin_or_user_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+(,\\d+)*$"
        }
      },
      "AdminUserIDFilter": {
        "name": "admin_user_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+(,\\d+)*$"
        }
      },
      "AggregationFilter": {
        "name": "aggregation",
        "in": "query",
        "description": "Supported aggregation methods are `mean, min, max, sum, stddev, count, last, first`. This value is mandatory if interval is defined.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AggregationIntervalFilter": {
        "name": "interval",
        "in": "query",
        "description": "Interval which is used for the aggregation. The value is mandatory if aggregation is defined. Supported intervals are number of `s, m, h, d, w`. Example `3h`.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AggregationIntervalRequiredFilter": {
        "name": "interval",
        "in": "query",
        "description": "Interval which is used for the aggregation. The value is mandatory. Supported intervals are number of `s, m, h, d, w`. Example `3h`.",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "AggregationRequiredFilter": {
        "name": "aggregation",
        "in": "query",
        "description": "Supported aggregation methods are `mean, min, max, sum, stddev, count, last, first`. This value is mandatory.",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "ApiKeyFilter": {
        "name": "api_key",
        "in": "query",
        "description": "Filter accepts `*` as wildcard",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "ApiSubscriptionPathID": {
        "name": "api_subscription_id",
        "in": "path",
        "description": "The ID of the API subscription",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "AssetHealthConditionTimemachineOrderByParameter": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `created_datetime` or `deleted_datetime`, add `-` as a prefix for descending order.",
        "schema": {
          "type": "string"
        }
      },
      "AssetIDFilter": {
        "name": "asset_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+(,\\d+)*$"
        }
      },
      "AssetIDInEventFilter": {
        "name": "asset_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). By adding '+' after the ID, the filter considers the given asset and all its children (e.g., 3+). The filter also accepts \"null\" for all events with no asset assigned or \"!null\" for any assigned asset.",
        "schema": {
          "type": "string",
          "pattern": "^(null|!null|\\d+\\+?(,\\d+\\+?)*)$"
        }
      },
      "AssetIDNullFilter": {
        "name": "asset_id",
        "in": "query",
        "required": false,
        "description": "One or multiple IDs (comma-separated). Also accepts \"null\" for all objects with no assets assigned, or \"!null\" for any assigned asset.\n",
        "schema": {
          "type": "string",
          "pattern": "^\\s*(null|!null|\\d+(\\s*,\\s*\\d+)*)\\s*$"
        }
      },
      "AssetNotificationStatusFilter": {
        "name": "asset_notification_status",
        "in": "query",
        "description": "Filter by asset notification status - no wildcard support",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AssetPathID": {
        "name": "asset_id",
        "in": "path",
        "description": "The resource defined in the URL",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "AssetStatusIDFilter": {
        "name": "asset_status_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+(,\\d+)*$"
        }
      },
      "AssetValueDateTimeFilter": {
        "name": "datetime",
        "in": "query",
        "description": "exact date for history values. Expected date format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "AssetValueHoldFilter": {
        "name": "hold",
        "in": "query",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      },
      "AssetValueKeyPathID": {
        "name": "key",
        "in": "path",
        "description": "key for the asset values",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "AssetValueSimulatedFilter": {
        "name": "simulated",
        "in": "query",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      },
      "AssetValueStatusFilter": {
        "name": "status",
        "in": "query",
        "description": "Status of the value. Possible values are good, uncertain, bad.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AssetValuesOrderByParameter": {
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `timestamp`, add `-` as a prefix for descending order. Default ordering is the order the values were entered in.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "AssetsHistoryOrderByParameter": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `event` or `event_datetime`, add `-` as a prefix for descending order.",
        "schema": {
          "type": "string"
        }
      },
      "AssetsOrderByParameter": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `id`, `serial_number`, `created_at` or `updated_at`, `last_seen_at` or `last_status_changed_at`, add `-` as a prefix for descending order. Default value is `id`",
        "schema": {
          "type": "string"
        }
      },
      "AttachmentIDFilter": {
        "name": "attachment_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer. Maximum length is 25.",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+(,\\d+)*$"
        }
      },
      "AttributeHistoryOrderByParameter": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `timestamp`, add `-` as a prefix for descending order.",
        "schema": {
          "type": "string"
        }
      },
