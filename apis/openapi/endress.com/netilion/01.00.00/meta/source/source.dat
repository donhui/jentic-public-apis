    "/nodes/{node_id}/specifications": {
      "get": {
        "summary": "Get specifications of a node",
        "operationId": "getSpecificationsOfNode",
        "description": "Returns the specification of an object in your accessible scope. If no specifications are defined, this is just an empty object. Specification must have the form below.",
        "parameters": [
          {
            "name": "node_id",
            "in": "path",
            "description": "Id of the specified node",
            "schema": {
              "type": "integer",
