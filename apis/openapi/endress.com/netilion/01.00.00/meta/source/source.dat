          },
          "max": {
            "type": "string",
            "description": "the maximum value for the requested time slot"
          },
          "min": {
            "type": "string",
            "description": "the minimum value for the requested time slot"
          },
          "mean": {
            "type": "string",
            "description": "the mean (average) value for the requested time slot"
          },
