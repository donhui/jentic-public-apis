          }
        ],
        "requestBody": {
          "description": "The image to upload (up to 1 MB)",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
