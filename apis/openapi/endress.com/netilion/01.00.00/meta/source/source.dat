    "/endress/product_lookup": {
      "get": {
        "summary": "lookup for Endress+Hauser products with asset specific search criteria",
        "operationId": "ehProductLookup",
        "description": "Returns an Endress+Hauser product, matching the serial number.\nThe serial number is at least 4 characters long and may include letters, numbers, dashes (-), underscores (_) and backslashes (\\\\).",
        "parameters": [
          {
            "name": "serial_number",
            "in": "query",
            "description": "Any Endress+Hauser serial number",
