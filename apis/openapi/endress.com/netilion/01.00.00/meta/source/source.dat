    "/assets/{asset_id}/values": {
      "post": {
        "summary": "Create asset values",
        "operationId": "createAssetValues",
        "description": "Store values measured by an asset. For performance reasons, this endpoint behaves somewhat differently than normal endpoints:\n\n* The data passed to this endpoint is processed asynchronously.\n* This endpoint always returns an empty response with status 204 No Content.\n* The data will be validated during processing. Invalid data will be dropped silently.\n* The request size is limited to 500kb, requests larger then 500kb will get an \"413 Payload Too Large\" error.\n\nData validations and manipulation:\n\n  * Keys and groups can only consist of the characters [a-z A-Z 0-9 . - _ ].\n  * Keys and groups will be converted to lower case strings.\n  * Keys and groups must be between 1 and 128 characters long.\n  * Units can be passed as id or code. See the units endpoint for all available units.\n  * The timestamp is not mandatory and will be set to the time the value was transmitted to the server (This only works if the values get transferred one at a time, if you send multiple values without timestamp at once, all values will get the same timestamp and there for only the last one will be stored)",
        "parameters": [
          {
            "$ref": "#/components/parameters/AssetPathID"
          }
        ],
        "responses": {
          "204": {
            "$ref": "#/components/responses/204"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "413": {
            "$ref": "#/components/responses/413"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Values",
          "Asset"
        ],
        "requestBody": {
          "description": "Values to store to an asset.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssetValuesRequest"
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete asset values.",
        "operationId": "deleteAssetValues",
        "description": "Delete values for the asset. The values will be removed for all existing keys within a specified time range, if  no \nkey filter is provided. The time range is determined by the 'from' and 'to' parameters.\nThe 'to' parameter is mandatory. To delete all values for the asset, set the 'to' parameter to a future date.",
        "parameters": [
          {
            "$ref": "#/components/parameters/AssetPathID"
          },
          {
            "$ref": "#/components/parameters/ValueKeysFilter"
          },
          {
            "$ref": "#/components/parameters/ValueFromFilter"
          },
          {
            "$ref": "#/components/parameters/ValueToRequiredFilter"
          },
          {
            "$ref": "#/components/parameters/ValuesWithReferencesFilter"
          }
        ],
        "responses": {
          "204": {
            "$ref": "#/components/responses/204"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Values",
          "Asset"
        ]
      },
      "get": {
        "summary": "Get latest values for the asset.",
        "operationId": "getAssetValues",
        "description": "Returns a collection of the latest value for every key of the asset.\nPossible include values: ```unit, unit.base_unit```",
        "parameters": [
          {
            "$ref": "#/components/parameters/AssetPathID"
          },
          {
            "$ref": "#/components/parameters/Pagination_Page"
          },
          {
            "$ref": "#/components/parameters/Pagination_Per_Page"
          },
          {
            "$ref": "#/components/parameters/IncludeTotalCountParam"
          },
          {
            "$ref": "#/components/parameters/IncludeParam"
          },
          {
            "$ref": "#/components/parameters/UsePreferredUnitsAssetParam"
          },
          {
            "$ref": "#/components/parameters/KeyFilter"
          },
          {
            "$ref": "#/components/parameters/KeyUnitIDFilter"
          },
          {
            "$ref": "#/components/parameters/GroupFilter"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetValuesResponse"
                }
              }
            }
          },
          "304": {
            "$ref": "#/components/responses/304"
