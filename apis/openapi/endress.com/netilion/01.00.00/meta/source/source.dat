          },
          {
            "$ref": "#/components/parameters/IncludeTotalCountParam"
          },
          {
            "$ref": "#/components/parameters/IncludeParam"
          },
          {
            "$ref": "#/components/parameters/ValueFromFilter"
          },
          {
            "$ref": "#/components/parameters/ValueToFilter"
          },
          {
            "$ref": "#/components/parameters/AssetValueDateTimeFilter"
          },
          {
            "$ref": "#/components/parameters/SelectorFilter"
          },
          {
            "$ref": "#/components/parameters/SelectorIntervalFilter"
          },
          {
            "$ref": "#/components/parameters/AssetValuesOrderByParameter"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetKeyValueObjectsResponse"
                }
              }
            }
          },
          "304": {
            "$ref": "#/components/responses/304"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Asset"
        ]
      }
    },
    "/attachments": {
      "get": {
        "summary": "Get a range of attachments",
        "operationId": "getAttachments",
        "description": "Returns a list of all attachments that are available in your scope. You can apply query parameters in the request to get a filtered list. If the query has no matches, the response will show an empty array.'",
        "parameters": [
          {
            "$ref": "#/components/parameters/Pagination_Page"
          },
          {
            "$ref": "#/components/parameters/Pagination_Per_Page"
          },
          {
            "$ref": "#/components/parameters/IncludeTotalCountParam"
          },
          {
            "$ref": "#/components/parameters/ContentAuthorFilter"
          },
          {
            "$ref": "#/components/parameters/ContentVersionFilter"
          },
          {
            "$ref": "#/components/parameters/RemarksFilter"
          },
          {
            "$ref": "#/components/parameters/ContentDateFilter"
          },
          {
            "$ref": "#/components/parameters/ContentDateFromFilter"
          },
          {
            "$ref": "#/components/parameters/ContentDateToFilter"
          },
          {
            "$ref": "#/components/parameters/FileNameFilter"
          },
          {
            "$ref": "#/components/parameters/DefaultOrderBy"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "402": {
            "$ref": "#/components/responses/402"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Attachment"
        ]
      },
      "post": {
        "summary": "Create and upload a new attachment",
        "operationId": "uploadAttachment",
        "description": "the creation of an attachment works through a multipart/form-data upload of the file, its filename, content-author, content-date and languages of the file.\nSpecial characters (&$+,/:;=?@<>[]{}|^~%#) and white spaces in the file name will be replaced with underscores. Checks for the file-storage quota.\n\nForbidden content-types are\n\n- application/xhtml+xml\n- text/html\n- application/javascript\n- text/javascript\n- application/x-shockwave-flash\n- application/vnd.adobe.flash.movie\n- video/x-flv\n- text/php\n- application/php\n- application/x-php\n- application/x-httpd-php",
        "requestBody": {
          "description": "The file to upload",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "document_id": {
                    "type": "integer",
                    "format": "int64"
                  },
                  "content_author": {
                    "type": "string"
                  },
                  "content_version": {
                    "type": "string"
                  },
                  "content_date": {
                    "type": "string",
                    "format": "dateTime",
                    "description": "last edit date of the file. Datetime must be in format YYYY-MM-DD or YYYY-MM-DDThh:mm:ss"
                  },
                  "remarks": {
                    "type": "string"
                  },
                  "languages": {
                    "type": "string",
                    "description": "the files content languages. Send as comma separated list with alpha2 language codes (eg. de,en,fr). Supported languages are defined in ISO639-1"
                  }
                },
                "required": [
                  "file",
                  "document_id"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The attachment was created successful and the file is saved. The response body contains the attachment representation",
            "headers": {
              "Location": {
                "description": "url of the created attachment",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "402": {
            "$ref": "#/components/responses/402"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Attachment"
        ]
      }
    },
