    "/software/attachments/{id}/download": {
      "get": {
        "summary": "Download the software attachments file",
        "operationId": "downloadSoftwareAttachment",
        "description": "Download the file of the software attachment with the original filename. Content-Transfer-Encoding header is set to binary",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the software attachment to fetch",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "required": true
          },
          {
            "name": "disposition",
            "in": "query",
            "description": "Disposition type the download should be returned with. Allowed values are \"inline\" and \"attachment\". Default is \"attachment\".",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A file download stream",
            "headers": {
              "Content-Type": {
                "description": "the original files mime-type is used here (eg. application/zip)",
                "schema": {
                  "type": "string"
                }
              },
              "Content-Disposition": {
                "description": "contains the original files filename (eg. software attachment; filename=\"test_software.zip\")",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "SoftwareAttachment"
        ]
      }
    },
    "/software/attachments/direct_upload": {
      "post": {
        "summary": "prepare software file blob for direct upload",
        "operationId": "prepareSoftwareFileDirectUpload",
        "description": "Prepare a software file for direct upload. This endpoint returns a blob_id and an upload_url to which the software file can be uploaded. The binary file has to be uploaded to the upload_url via PATCH. The upload_url has an expiry time of 30 minutes. The byte_size and the checksum needs to be correct, otherwise the upload will fail.",
