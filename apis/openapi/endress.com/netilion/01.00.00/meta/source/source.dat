            "type": "integer",
            "format": "int64"
          },
          "content_type": {
            "type": "string",
            "description": "in doubt set it to 'application/binary'"
          },
          "checksum": {
            "type": "string",
            "description": "needs to be the md5 hash of file base64 encoded"
          },
          "metadata": {
            "type": "object",
            "description": "additional metadata for the software file",
            "properties": {
              "fingerprint": {
                "type": "string",
                "description": "sha256 hash of the file"
              }
            }
          }
        }
