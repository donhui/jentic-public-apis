    "/connected_assets/{asset_id}": {
      "get": {
        "summary": "Returns information for a connected asset.",
        "operationId": "getConnectedAssetInformation",
        "description": "Returns information for a connected asset, containing information like server time, scheduled firmware updates, scheduled certificate updates, etc.",
        "parameters": [
          {
