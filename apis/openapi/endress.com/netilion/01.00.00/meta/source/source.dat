        "description": "The resource defined in the URL",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "ValidAtFilter": {
        "name": "valid_at",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DD or YYYY-MM or YYYY",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValidFromFilter": {
        "name": "valid_from",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DD",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValidFromFromFilter": {
        "name": "valid_from_from",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DD",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValidFromToFilter": {
        "name": "valid_from_to",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DD",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValidUntilFilter": {
        "name": "valid_until",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DD",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValidUntilFromFilter": {
        "name": "valid_until_from",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DD",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValidUntilToFilter": {
        "name": "valid_until_to",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DD",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValueFromFilter": {
        "name": "from",
        "in": "query",
        "description": "Start date filter for history values. Expected date format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValueKeyPathID": {
        "name": "key",
        "in": "path",
        "description": "key for the aggregated values",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "ValueKeysFilter": {
        "name": "key",
        "in": "query",
        "description": "One or multiple value keys as a comma separated list",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "ValueToFilter": {
        "name": "to",
        "in": "query",
        "description": "End date filter for history values. Expected date format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValueToRequiredFilter": {
        "name": "to",
        "in": "query",
        "description": "End date filter for history values. Expected date format is YYYY-MM-DDThh:mm:ss",
        "required": true,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ValuesIncludeStatisticsParam": {
        "name": "include_query_statistics",
        "in": "query",
        "description": "whether to return query statistics for historical values such 'min', 'max', 'mean' and 'latest'. Using false value will enhance the performance of this call. Default value is true. Please specify the value of this parameter if you want a specific behavior.",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      },
      "ValuesIncludeTotalCountParam": {
        "name": "include_total_count",
        "in": "query",
        "description": "whether to return total count related information in the response or just the next url if it exists. Using false value will enhance the performance of this call. Default value is false. Please specify the value of this parameter if you want a specific behavior.",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      },
      "ValuesPagination_Per_Page": {
        "name": "per_page",
        "in": "query",
        "description": "Number of items to load per page, default value is 500, maximum is 1000",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        }
      },
      "ValuesWithReferencesFilter": {
        "name": "with_references",
        "in": "query",
        "description": "Delete asset values and also the reference to these values from associated instrumentations and systems",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      }
    },
    "responses": {
      "201": {
        "description": "The request was successful, the resource was created."
      },
      "204": {
        "description": "The request was successful, and the response body is empty."
      },
      "304": {
        "description": "The resources was not changed, and the response body is empty."
      },
      "400": {
        "description": "Bad request. The data given in the request failed validation, or the authorization was missing. Please inspect the response body for details on the error.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "401": {
        "description": "Unauthorized request. API-Key or authorization were invalid."
      },
      "402": {
        "description": "Quota is exceeded. Cant upload anymore files or create any more assets. In case of storage exceeded, contains the MB how much its exceeded in the message.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "403": {
        "description": "It is forbidden to create, delete or update an object. Please inspect the response body for details on the error.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "404": {
        "description": "The resource or the specified URL could not be found or the requesting user has no permission.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "409": {
        "description": "Failed to create, update or delete a resource because of a conflict with an existing resource or due to existing assignments on the resource. Please inspect the response body for details on the error.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "413": {
        "description": "Request entity too large. The send request exceeded the maximum allowed request size for this endpoint.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "429": {
        "description": "Too many request. Overload protection has been enabled.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "500": {
        "description": "Internal server error. The request failed. Please try again.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "503": {
        "description": "Service currently not available. Please try again later.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "info": {
    "title": "Netilion API",
    "description": "Welcome to the Netilion API Documentation, which provides interactive access and documentation to our REST API.\nPlease visit our developer portal for further detailes instructions and informations\n",
    "version": "01.00.00",
    "termsOfService": "https://netilion.endress.com/legal",
    "contact": {
      "url": "https://developer.netilion.endress.com",
      "name": "Netilion Developer Support",
      "email": "netilion@endress.com"
    }
  },
  "openapi": "3.0.3",
  "security": [
    {
      "ApiKeyAuth": [],
      "BasicAuth": []
    }
  ],
  "paths": {
    "/add_ons": {
      "get": {
        "summary": "Get all add ons",
        "operationId": "getAddons",
        "description": "Returns a list of add ons\n\nPossible include values: ```addonable_name``` ",
        "parameters": [
          {
            "$ref": "#/components/parameters/Pagination_Page"
          },
          {
            "$ref": "#/components/parameters/Pagination_Per_Page"
          },
          {
            "$ref": "#/components/parameters/IncludeTotalCountParam"
          },
          {
            "$ref": "#/components/parameters/IncludeParam"
          },
          {
            "$ref": "#/components/parameters/NameFilter"
          },
          {
            "$ref": "#/components/parameters/ProductCodeFilter"
          },
          {
            "$ref": "#/components/parameters/MaterialNumberFilter"
          },
          {
            "$ref": "#/components/parameters/AddOnTypeFilter"
          },
          {
            "$ref": "#/components/parameters/AddOnScopeFilter"
          },
          {
            "$ref": "#/components/parameters/DefaultOrderBy"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddOnsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "AddOn"
        ]
      }
    },
    "/api_keys": {
      "get": {
        "summary": "Get a range of APIKeys",
        "operationId": "getAPIKeys",
        "description": "Returns a list of APIKeys in your accessible scope. If the query has no matches, the response is an empty list.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Pagination_Page"
          },
          {
            "$ref": "#/components/parameters/Pagination_Per_Page"
          },
          {
            "$ref": "#/components/parameters/IncludeTotalCountParam"
          },
          {
            "$ref": "#/components/parameters/ApiKeyFilter"
          },
          {
            "$ref": "#/components/parameters/ValidFromFilter"
          },
          {
            "$ref": "#/components/parameters/ValidFromFromFilter"
          },
          {
            "$ref": "#/components/parameters/ValidFromToFilter"
          },
          {
            "$ref": "#/components/parameters/ValidUntilFilter"
          },
          {
            "$ref": "#/components/parameters/ValidUntilFromFilter"
          },
          {
            "$ref": "#/components/parameters/ValidUntilToFilter"
          },
          {
            "$ref": "#/components/parameters/DefaultOrderBy"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIKeysResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "402": {
            "$ref": "#/components/responses/402"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "APIKey"
        ]
      },
      "post": {
        "summary": "Create a new APIKey",
        "operationId": "createAPIKey",
        "description": "Create a new APIKey. The values of the api_key and the api_secret can't be set and will be generated. To create an APIKey, the client_application must have an API Subscription assigned. valid_from and valid_until will be adopted from the API Subscription",
        "responses": {
          "201": {
            "description": "The new resource was successfully created. The response body contains its representation.",
            "headers": {
              "Location": {
                "description": "url of the created api_key",
                "schema": {
