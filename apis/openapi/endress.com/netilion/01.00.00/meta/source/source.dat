              }
            }
          }
        }
      },
      "delete": {
        "summary": "Remove users (existing users) or emails (new users) from a seat in subscription",
        "operationId": "removeSeatUsersFromSubscription",
        "description": "Remove one or more users or emails from a seat in subscription. **Either id or email pro entry should be provided (not both).** If an email is provided for existing user, then given user will be used.\nThis operation does send notification emails to the seat user, so it should be used by the owner to remove seats.",
