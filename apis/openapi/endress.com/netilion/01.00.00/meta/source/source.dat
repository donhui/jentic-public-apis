      "CertificateRenewalRequest": {
        "type": "object",
        "required": [
          "status",
          "csr"
        ],
        "properties": {
          "status": {
            "type": "string",
            "description": "The status of the certificate renewal process. \"requesting\" indicates that a csr is sent in the request. \"success\" indicates that the connected asset has installed the new certificate and that the process can be closed. \"failed\" indicates that the connected asset has not installed the new certificate and that the process should be reset."
          },
          "csr": {
            "type": "string",
            "description": "Must be base64-encoded and contain the serial number as CN=MySerialNumber, needed only with status \"requesting\"."
          }
        }
      },
      "CertificateRenewalResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "description": "The status of the certificate renewal process. \"renewal\" is requesting a new csr (base64 encoded, containing the serial number as CN=MySerialNumber) from the connected asset. \"replace\" indicates that a new certificate is present in the response to be picked up."
          },
          "certificate": {
            "type": "string",
            "description": "A base64-encoded PEM certificate that was created for the connected asset, returned only with status \"replace\"."
          }
        }
      },
      "ClientApplicationBase": {
