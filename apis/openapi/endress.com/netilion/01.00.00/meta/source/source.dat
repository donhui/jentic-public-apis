    "/api_subscriptions/{id}/specifications": {
      "get": {
        "summary": "Get specifications of an api subscription",
        "operationId": "getSpecificationsOfAPISubscription",
        "description": "Returns the specification of an object in your accessible scope. If no specifications are defined, this is just an empty object. Specification must have the form below.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the specified api subscription",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "required": true
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "Filter accepts '*' as wildcard"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
