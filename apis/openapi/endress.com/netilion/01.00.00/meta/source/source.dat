      "SubscriptionSeatStatusFilter": {
        "name": "status",
        "in": "query",
        "description": "one or multiple statuses (comma list). Allowed values are `pending`, `invited`, `accepted`",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "SubscriptionStatusFilter": {
        "name": "status",
        "in": "query",
        "description": "one or multiple statuses (comma list). Allowed values are `open`, `payment_required`, `confirmed`, `scheduled_update`, `non_renewing` and `cancelled`",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "SubscriptionTypeFilter": {
        "name": "subscription_type",
        "in": "query",
        "description": "Filter by subscription type - no wildcard support",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "SymbolFilter": {
        "name": "symbol",
        "in": "query",
        "description": "Filter accepts `*` as wildcard",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "SystemIDNullFilter": {
        "name": "system_id",
        "in": "query",
        "required": false,
        "description": "One or multiple IDs (comma-separated). Also accepts \"null\" for all objects with no assets assigned, or \"!null\" for any assigned asset.\n",
        "schema": {
          "type": "string",
          "pattern": "^\\s*(null|!null|\\d+(\\s*,\\s*\\d+)*)\\s*$"
        }
      },
      "SystemPathID": {
        "name": "system_id",
        "in": "path",
        "description": "The resource defined in the URL",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "SystemValueKeyPathID": {
        "name": "key",
        "in": "path",
        "description": "key for the system values",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "SystemsOrderByParameter": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `id`, `name`, `created_at` or `updated_at`. Add `-` as a prefix for descending order. Default value is `id`",
        "schema": {
          "type": "string"
        }
      },
      "TagFilter": {
        "name": "tag",
        "in": "query",
        "description": "Filter accepts `*` as wildcard",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "TechnicalUserIDFilter": {
        "name": "technical_user_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+(,\\d+)*$"
        }
      },
      "TenantIDFilter": {
        "name": "tenant_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+(,\\d+)*$"
        }
      },
      "TenantOrderBy": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `id`, `name`, `created_at` or `updated_at`. Add `-` as a prefix for descending order. Default value is `id`",
        "schema": {
          "type": "string"
        }
      },
      "TenantPathID": {
        "name": "tenant_id",
        "in": "path",
        "description": "The resource defined in the URL",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "ThresholdPathID": {
        "name": "id",
        "in": "path",
        "description": "The resource defined in the URL",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "ThresholdsOrderBy": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `name`, `key`, `threshold_type`, `notification`, `severity`, `created_at`, `updated_at`. Add `-` as a prefix for descending order. Default value is `id`",
        "schema": {
          "type": "string"
        }
      },
      "TimeFilter": {
        "name": "time",
        "in": "query",
        "description": "Expected format is YYYY-MM-DD",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "TimeFromFilter": {
        "name": "time_from",
        "in": "query",
        "description": "Expected format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "dateTime"
        }
      },
      "TimeToFilter": {
        "name": "time_to",
        "in": "query",
        "description": "Expected format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "dateTime"
        }
      },
      "ToFilter": {
        "name": "to",
        "in": "query",
        "description": "End date for history values. Ending with ```+``` will include the next value as well. Expected date format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "ToPlainFilter": {
        "name": "to",
        "in": "query",
        "description": "End date for timemachine values. Expected date format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date-time"
        }
      },
      "TypeCodeFilter": {
        "name": "type_code",
        "in": "query",
        "description": "One or multiple type codes (comma list). Expected id format is integer.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "TypeIDFilter": {
        "name": "type_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer. By adding '+' after the ID, the filter considers the given object and all its children (e.g., 3+).",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+\\+?(,\\d+\\+?)*$"
        }
      },
      "UnitFilter": {
        "name": "unit_id",
        "in": "query",
        "description": "Id of the unit in which the values are to be returned.",
        "required": false,
        "schema": {
          "type": "integer"
        }
      },
      "UnitOrderBy": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `id`, `code`, `name`, `created_at` or `updated_at`. Add `-` as a prefix for descending order. Default value is `id`",
        "schema": {
          "type": "string"
        }
      },
      "UpdatedAtFilter": {
        "name": "updated_at",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DD",
        "required": false,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "UpdatedAtFromFilter": {
        "name": "updated_at_from",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "dateTime"
        }
      },
      "UpdatedAtToFilter": {
        "name": "updated_at_to",
        "in": "query",
        "description": "Expected date format is YYYY-MM-DDThh:mm:ss",
        "required": false,
        "schema": {
          "type": "string",
          "format": "dateTime"
        }
      },
      "UsePreferredUnitsAssetKeyParam": {
        "name": "use_preferred_units",
        "in": "query",
        "description": "whether to return the values in the preferred units described in the asset specification 'preferred_units' or not. These values have lower precedence than the parameter unit_id. Example value of the specification is '{\"key_1\"\\:\"unit_code_1\", \"key_2\"\\:\"unit_code_2\"}'",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      },
      "UsePreferredUnitsAssetParam": {
        "name": "use_preferred_units",
        "in": "query",
        "description": "whether to return the values in the preferred units described in the asset specification 'preferred_units' or not. These values have lower precedence than the parameter key_unit_id. Example value of the specification is '{\"key_1\"\\:\"unit_code_1\", \"key_2\"\\:\"unit_code_2\"}'",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      },
      "UsePreferredUnitsInstrumentationKeyParam": {
        "name": "use_preferred_units",
        "in": "query",
        "description": "whether to return the values in the preferred units described in the asset specification 'preferred_units' or not, for the instrumentation the mapping will result from the merge of all its assets mappings. These values have lower precedence than the parameter unit_id. Example value of the specification is '{\"key_1\"\\:\"unit_code_1\", \"key_2\"\\:\"unit_code_2\"}'",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      },
      "UsePreferredUnitsInstrumentationParam": {
        "name": "use_preferred_units",
        "in": "query",
        "description": "whether to return the values in the preferred units described in the asset specification 'preferred_units' or not, for the instrumentation the mapping will result from the merge of all its assets mappings. These values have lower precedence than the parameter key_unit_id. Example value of the specification is '{\"key_1\"\\:\"unit_code_1\", \"key_2\"\\:\"unit_code_2\"}'",
        "required": false,
        "schema": {
          "type": "boolean"
        }
      },
      "UserGroupOrderBy": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `id`, `name`, `created_at` or `updated_at`. Add `-` as a prefix for descending order. Default value is `id`",
        "schema": {
          "type": "string"
        }
      },
      "UserIDFilter": {
        "name": "user_id",
        "in": "query",
        "description": "One or multiple IDs (comma-separated). Each ID must be an integer",
        "required": false,
        "schema": {
          "type": "string",
          "pattern": "^\\d+(,\\d+)*$"
        }
      },
      "UserOrderBy": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `id`, `email`, `first_name`, `last_name`, `created_at` or `updated_at`. Add `-` as a prefix for descending order. Default value is `id`",
        "schema": {
          "type": "string"
        }
      },
      "UserPathID": {
        "name": "user_id",
        "in": "path",
        "description": "The resource defined in the URL",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64"
        }
      },
      "UserRoleOrderBy": {
        "required": false,
        "name": "order_by",
        "in": "query",
        "description": "Order result by attribute value, accepts `id`, `name`, `created_at` or `updated_at`. Add `-` as a prefix for descending order. Default value is `id`",
        "schema": {
          "type": "string"
        }
      },
      "UserSpecificFilter": {
        "name": "user_specific",
        "in": "query",
        "description": "Filter resource notification if user specific or not",
