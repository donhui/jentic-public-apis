          },
          {
            "$ref": "#/components/parameters/NameFilter"
          },
          {
            "$ref": "#/components/parameters/DefaultOrderBy"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "title": "tenants",
                  "type": "object",
                  "properties": {
                    "tenants": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TenantResponse"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Asset",
          "Tenant"
        ]
      }
    },
    "/assets/{asset_id}/value_objects": {
      "post": {
        "summary": "Create asset value objects",
        "operationId": "createAssetValueObjects",
        "description": "Store value objects measured by an asset. For performance reasons, this endpoint behaves somewhat differently than normal endpoints:\n\n* The data passed to this endpoint is processed asynchronously.\n* This endpoint always returns an empty response with status 204 No Content.\n* The data will be validated during processing. Invalid data will be dropped silently.\n* The request size is limited to 500kb, requests larger then 500kb will get an \"413 Payload Too Large\" error.\n\nData validations and manipulation:\n\n  * Keys can only consist of the characters [a-z A-Z 0-9 . - _ ].\n  * Keys will be converted to lower case strings.\n  * Keys must be between 1 and 128 characters long.\n  * The timestamp is not mandatory and will be set to the time the value was transmitted to the server (This only works if the value objects get transferred one at a time, if you send multiple value objects without timestamp at once, all value objects will get the same timestamp and there for only the last one will be stored)\n\nDifference to path /assets/{asset_id}/values is that the values given here are json objects and not numeric values, the json objects can have any structure.",
        "parameters": [
          {
            "$ref": "#/components/parameters/AssetPathID"
          }
        ],
        "responses": {
          "204": {
            "$ref": "#/components/responses/204"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "404": {
            "$ref": "#/components/responses/404"
          },
          "409": {
            "$ref": "#/components/responses/409"
          },
          "413": {
            "$ref": "#/components/responses/413"
          },
          "429": {
            "$ref": "#/components/responses/429"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "tags": [
          "Asset"
        ],
        "requestBody": {
          "description": "Values to store to an asset.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssetValueObjectsRequest"
              }
            }
          }
        }
      }
    },
    "/assets/{asset_id}/value_objects/{key}": {
      "get": {
        "summary": "Get asset value objects for a specific key.",
        "operationId": "getAssetValueObjectsForKey",
        "description": "Returns a collection of the history value objects of the value objects for the specified key.\nFor a selected result of the value objects the filter parameters selector and interval are mandatory.\nWith the filter parameters from, to or datetime, it is possible to receive the history of a defined time period.",
        "parameters": [
          {
            "$ref": "#/components/parameters/AssetPathID"
          },
          {
            "$ref": "#/components/parameters/AssetValueKeyPathID"
          },
          {
            "$ref": "#/components/parameters/Pagination_Page"
          },
