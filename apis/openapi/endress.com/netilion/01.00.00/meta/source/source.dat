            "required": true
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "Filter accepts '*' as wildcard"
          },
          {
            "name": "ui_visible",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
