      "ConnectedAssetRequest": {
        "required": [
          "values"
        ],
        "properties": {
          "connection": {
            "type": "object",
            "description": "Details about the connection status of the connected asset",
            "properties": {
              "type": {
                "type": "string",
                "description": "The type of connection (mobile, ethernet or wifi)"
              },
              "standard": {
                "type": "string",
                "description": "The used standard of the connection (wifi: [802.11, 802.11a, 802.11b, 802.11g, 802.11n, 802.11ac, 802.11ax, 802.11be, 802.11ad], ethernet: [802.3, 802.3a, 802.3i, 802.3j, 802.3u, 802.3z, 802.3ab, 802.3ae, 802.3an], mobile: [1G, GSM, GPRS, 2G, EDGE, 3G, UMTS, HSPDA, HSUPA, HSPA+, 4G, LTE, LTE Advanced, LTE Advanced Pro, 5G, NR, NB-IoT, LTE-M])"
              },
              "rssi": {
                "type": "number",
                "description": "Received signal strength indication in dBm"
              },
              "imei": {
                "type": "string",
                "description": "International Mobile Equipment Identity (identifier of the asset modem)"
              },
              "iccid": {
                "type": "string",
                "description": "Integrated circuit card identifier (identifier of the sim card)"
              },
              "imsi": {
                "type": "string",
                "description": "International mobile subscriber identity (identifier of the provider)"
              }
            },
            "example": {
              "type": "mobile",
              "standard": "LTE",
              "rssi": "-83",
              "imei": "228017000538642",
              "imsi": "862061044708344",
              "iccid": "89410118310705386420"
            }
          },
          "location": {
            "type": "array",
            "description": "Geolocation of the connected asset as array [latitude, longitude, accuracy(in meters)]",
            "items": {
              "type": "number"
            },
            "example": [
              "16.8354574",
              "-99.8974137",
              "33.234"
            ]
          },
          "battery": {
            "type": "array",
            "description": "Details about the battery status of the connected asset [level in percent]",
            "items": {
              "type": "number"
            },
            "example": [
              "35.78"
            ]
          },
          "health_conditions": {
            "type": "array",
            "description": "Source identifiers of health conditions to be set active for the connected asset",
            "items": {
              "type": "number"
            },
            "example": [
              "16777265",
              "16777319"
            ]
          },
          "firmware": {
            "type": "object",
            "description": "Details about the firmware update status",
            "properties": {
              "version": {
                "type": "string",
                "description": "The software version of the firmware"
              },
              "status": {
                "type": "string",
                "description": "The status of the update, either \"success\" or \"failed\""
              }
            },
            "example": {
              "version": "1.2.3",
              "status": "success"
            }
          },
          "certificate": {
            "$ref": "#/components/schemas/CertificateRenewalRequest"
          },
          "values": {
            "type": "object",
            "description": "Values to be sent to the asset",
            "properties": {
              "definition": {
                "description": "definition of the key name, unit and group of the values",
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "example": [
                  [
                    "temperature",
                    "degree_celsius",
                    "important"
                  ],
                  [
                    "humidity",
                    "percent",
                    "important"
                  ],
                  [
                    "pressure",
                    "hectopascal"
                  ]
                ]
              },
              "data": {
                "description": "timestamp as integer and values for all keys defined in values_definition. To write the the quality attributes, the  value has to be formated the following way: 'value|status|simulated|hold'. The value is mandatory, if one of the other fields are not needed, they have to be transferred as blank e.g. '12|good||true'",
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "example": [
                  [
                    1620299703000,
                    "23.456",
                    "43.2245",
                    "856"
                  ],
                  [
                    1620293403000,
                    "22.123",
                    "38.567",
                    "1021"
                  ],
                  [
                    1620277203000,
                    "21.056",
                    "31.345",
                    "1221"
                  ]
                ]
              }
            }
          },
          "diagnosis": {
            "type": "string",
            "description": "Diagnosis result for the last sent diagnosis command. If the value is not text e.g. JSON or XML, the value should be encoded accordingly and converted to string before sending. Maximum length of the string is 6000 chars. The result value will be saved in specification 'eh.connected_assets.diagnosis_result'. The diagnosis command which was evaluated will be moved from specification key 'eh.connected_assets.diagnosis_command' to the key 'eh.connected_assets.last_diagnosis_command'",
            "example": "{report: 'the cable is disconnected', solution: 'reconnect'}"
          },
          "configuration": {
            "type": "object",
            "description": "device configuration data of the connected asset as key value pairs",
            "properties": {
              "config_parameter_key_name": {
                "type": "string"
              }
            },
            "example": {
              "transmission_interval": "86400000",
              "measuring_interval": "3600000",
              "sensitivity": "34"
            }
          }
        }
      },
      "ConnectedAssetResponse": {
        "type": "object",
        "properties": {
          "current_time": {
            "type": "string",
            "format": "dateTime",
            "description": "current server time in UTC"
          },
          "certificate": {
            "$ref": "#/components/schemas/CertificateRenewalResponse"
          },
          "firmware": {
            "$ref": "#/components/schemas/FirmwareResponse"
          },
          "diagnosis_command": {
            "type": "string",
            "description": "diagnosis command to be sent to the connected asset"
          },
          "configuration": {
            "type": "string",
            "description": "All device configuration key/value pairs set by the user that differ from the latest configuration the device sent to the server"
          }
        }
      },
