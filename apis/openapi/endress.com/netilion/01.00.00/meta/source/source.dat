          },
          "expected_max": {
            "type": "number",
            "description": "Expected maximum value for stable chart scaling instead of auto-scaling based on time period"
          },
          "is_primary": {
            "type": "boolean",
            "description": "Whether this value is displayed in the live view. Default is false"
          }
