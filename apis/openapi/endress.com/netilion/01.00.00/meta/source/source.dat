          },
          {
            "$ref": "#/components/parameters/UsePreferredUnitsAssetKeyParam"
          },
          {
            "$ref": "#/components/parameters/ValuesIncludeTotalCountParam"
          },
          {
            "$ref": "#/components/parameters/ValuesIncludeStatisticsParam"
          },
          {
            "$ref": "#/components/parameters/ObjectIDRequiredFilter"
          },
          {
            "$ref": "#/components/parameters/ObjectTypeRequiredFilter"
          },
          {
            "$ref": "#/components/parameters/AssetIDFilter"
          },
          {
            "$ref": "#/components/parameters/GroupAggregationRequiredFilter"
          },
          {
            "$ref": "#/components/parameters/AggregationIntervalRequiredFilter"
          },
          {
            "$ref": "#/components/parameters/AggregationRequiredFilter"
          },
          {
            "$ref": "#/components/parameters/FitToPageFilter"
          },
          {
            "$ref": "#/components/parameters/ValueFromFilter"
          },
          {
            "$ref": "#/components/parameters/ValueToFilter"
          },
          {
            "$ref": "#/components/parameters/UnitFilter"
          },
          {
            "$ref": "#/components/parameters/DifferenceFilter"
          },
          {
            "$ref": "#/components/parameters/AssetValueStatusFilter"
          },
          {
            "$ref": "#/components/parameters/AssetValueHoldFilter"
          },
          {
            "$ref": "#/components/parameters/AssetValueSimulatedFilter"
          },
          {
            "$ref": "#/components/parameters/AssetValuesOrderByParameter"
          }
        ],
        "responses": {
          "200": {
            "description": "The request was successful.",
            "content": {
