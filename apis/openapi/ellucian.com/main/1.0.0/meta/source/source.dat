    "/api/grade-definitions": {
      "get": {
        "operationId": "listGradeDefinitions",
        "summary": "List grade definitions",
        "description": "Returns a collection of institutional grade scheme definitions.",
        "tags": ["Grade Definitions"],
        "parameters": [
          { "$ref": "#/components/parameters/offset" },
