{
  "openapi": "3.0.3",
  "info": {
    "title": "Ellucian Ethos Integration API",
    "version": "1.0.0",
    "description": "Ellucian Ethos Integration is a cloud-based integration platform for higher education institutions. It provides a standardized RESTful API following the Ellucian Education Data Model (EEDM), enabling interoperability across student information systems (Banner, Colleague, PowerCampus), HR, finance, financial aid, and other campus applications. The API exposes 316+ EEDM-versioned resources covering the full spectrum of institutional data including persons, students, courses, sections, registrations, grades, academic programs, financial aid, employees, positions, and facilities. Authentication uses an API key exchanged for a JWT bearer token. Resource versioning is controlled via the Accept header using the application/vnd.hedtech.integration.v{version}+json media type.",
    "contact": {
      "name": "Ellucian Developer Support",
      "url": "https://developer.ellucian.com/"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://www.ellucian.com/legal"
    },
    "x-jentic-source-url": "https://developer.ellucian.com/"
  },
  "servers": [
    {
      "url": "https://integrate.elluciancloud.com",
      "description": "Ellucian Ethos Integration production endpoint"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Exchange API key for JWT bearer token"
    },
    {
      "name": "Change Notifications",
      "description": "Publish and consume change notification messages"
    },
    {
      "name": "Persons",
      "description": "Person demographic and biographical records"
    },
    {
      "name": "Students",
      "description": "Student enrollment records"
    },
    {
      "name": "Courses",
      "description": "Course catalog entries"
    },
    {
      "name": "Sections",
      "description": "Course section offerings within academic periods"
    },
    {
      "name": "Section Registrations",
      "description": "Student registrations in course sections"
    },
    {
      "name": "Grades",
      "description": "Student grade records"
    },
    {
      "name": "Grade Definitions",
      "description": "Institutional grade scheme definitions"
    },
    {
      "name": "Academic Periods",
      "description": "Terms, semesters, and other academic time periods"
    },
    {
      "name": "Academic Programs",
      "description": "Degree programs and academic plans"
    },
    {
      "name": "Student Academic Credentials",
      "description": "Degrees, certificates, and other credentials awarded to students"
    },
    {
      "name": "Instructional Events",
      "description": "Scheduled class meetings and instructional activities"
    },
    {
      "name": "Financial Aid Applications",
      "description": "Student financial aid application records (FAFSA, ISIR)"
    },
    {
      "name": "Financial Aid Awards",
      "description": "Financial aid award packages for students"
    },
    {
      "name": "Financial Aid Funds",
      "description": "Financial aid fund definitions"
    },
    {
      "name": "Employees",
      "description": "Employee records for institutional staff and faculty"
    },
    {
      "name": "Positions",
      "description": "Institutional job position definitions"
    },
    {
      "name": "Accounting Strings",
      "description": "General ledger accounting string components"
    },
    {
      "name": "Institutions",
      "description": "Higher education institution records"
    },
    {
      "name": "Buildings",
      "description": "Campus building records"
    },
    {
      "name": "Rooms",
      "description": "Room records within campus buildings"
    }
  ],
  "paths": {
    "/auth": {
      "post": {
        "operationId": "createAuthToken",
        "summary": "Exchange API key for JWT token",
        "description": "Authenticates using an Ethos Integration API key and returns a JWT bearer token for subsequent API calls. The token has a limited lifetime and must be refreshed before expiry.",
        "tags": ["Authentication"],
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "JWT token returned successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "JWT bearer token"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/publish": {
      "post": {
        "operationId": "publishChangeNotification",
        "summary": "Publish a change notification",
        "description": "Publishes a change notification message to the Ethos Integration message queue. Subscribers consuming notifications will receive these messages.",
        "tags": ["Change Notifications"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeNotification"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification published successfully"
          },
          "400": {
            "description": "Invalid notification payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/consume": {
      "get": {
        "operationId": "consumeChangeNotifications",
        "summary": "Consume change notifications",
        "description": "Retrieves available change notification messages from the Ethos Integration message queue using long-polling. Returns an array of change notification messages. If no messages are available, the request waits up to the specified timeout before returning an empty array.",
        "tags": ["Change Notifications"],
        "parameters": [
          {
            "name": "lastProcessedID",
            "in": "query",
            "description": "The ID of the last successfully processed notification. Messages after this ID will be returned.",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of notifications to return.",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Change notifications retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ChangeNotification"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/persons": {
      "get": {
        "operationId": "listPersons",
        "summary": "List persons",
        "description": "Returns a collection of person records. Supports pagination via offset and limit, and filtering via the criteria parameter.",
        "tags": ["Persons"],
        "parameters": [
          { "$ref": "#/components/parameters/offset" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/criteria" },
          { "$ref": "#/components/parameters/acceptVersionHeader" }
        ],
        "responses": {
          "200": {
            "description": "A list of persons",
            "headers": {
              "X-Total-Count": { "$ref": "#/components/headers/X-Total-Count" },
              "X-Content-Restricted": { "$ref": "#/components/headers/X-Content-Restricted" }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Person" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createPerson",
        "summary": "Create a person",
        "description": "Creates a new person record in the institution's system of record.",
        "tags": ["Persons"],
        "parameters": [
          { "$ref": "#/components/parameters/acceptVersionHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Person" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Person created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Person" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/persons/{id}": {
      "get": {
        "operationId": "getPerson",
        "summary": "Get a person by ID",
        "description": "Returns a single person record by its globally unique identifier (GUID).",
        "tags": ["Persons"],
        "parameters": [
          { "$ref": "#/components/parameters/id" },
          { "$ref": "#/components/parameters/acceptVersionHeader" }
        ],
        "responses": {
          "200": {
            "description": "Person record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Person" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "operationId": "updatePerson",
        "summary": "Update a person",
        "description": "Updates an existing person record identified by its GUID.",
        "tags": ["Persons"],
        "parameters": [
          { "$ref": "#/components/parameters/id" },
          { "$ref": "#/components/parameters/acceptVersionHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Person" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Person updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Person" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
