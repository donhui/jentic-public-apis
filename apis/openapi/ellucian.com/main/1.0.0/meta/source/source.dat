    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from the /auth endpoint. Include as: Authorization: Bearer {token}"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Ethos Integration API key used to obtain a JWT token via the /auth endpoint."
      }
    },
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Globally unique identifier (GUID) for the resource.",
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "offset": {
        "name": "offset",
        "in": "query",
        "description": "Zero-based pagination offset. Indicates the number of records to skip.",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "description": "Maximum number of records to return per page.",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 500
        }
      },
      "criteria": {
        "name": "criteria",
        "in": "query",
        "description": "JSON-formatted filter criteria for narrowing results. The structure depends on the resource type.",
        "schema": {
          "type": "string"
        }
      },
      "acceptVersionHeader": {
        "name": "Accept",
        "in": "header",
        "description": "EEDM versioned media type. Format: application/vnd.hedtech.integration.v{version}+json",
        "schema": {
          "type": "string",
          "example": "application/vnd.hedtech.integration.v12+json"
        }
      }
    },
    "headers": {
      "X-Total-Count": {
        "description": "Total number of records matching the query (before pagination).",
        "schema": {
          "type": "integer"
        }
      },
      "X-Content-Restricted": {
        "description": "Indicates if the response content has been restricted due to data privacy rules.",
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters or request body",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing, invalid, or expired bearer token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "Standard error response returned by the Ethos Integration API.",
        "properties": {
          "severity": {
            "type": "string",
            "description": "Severity level of the error.",
            "enum": ["error", "warning", "information"]
          },
          "code": {
            "type": "string",
            "description": "Machine-readable error code."
          },
          "description": {
            "type": "string",
            "description": "Human-readable error description."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message."
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the error instance."
          },
          "sourceId": {
            "type": "string",
            "description": "Identifier of the source system that generated the error."
          }
        }
      },
      "GuidReference": {
        "type": "object",
        "description": "A reference to another EEDM resource by GUID.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier of the referenced resource."
          }
        },
        "required": ["id"]
      },
      "ChangeNotification": {
        "type": "object",
        "description": "A change notification message from the Ethos Integration message queue.",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Sequential message ID."
          },
          "published": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the notification was published."
          },
          "resource": {
            "type": "object",
            "description": "The resource that changed.",
            "properties": {
              "name": {
                "type": "string",
                "description": "EEDM resource name (e.g., persons, courses)."
              },
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "GUID of the changed resource."
              },
              "version": {
                "type": "string",
                "description": "EEDM version of the resource representation."
              }
            }
          },
          "operation": {
            "type": "string",
            "description": "The type of change that occurred.",
            "enum": ["created", "replaced", "deleted"]
          },
          "contentType": {
            "type": "string",
            "description": "The media type of the content.",
            "example": "application/vnd.hedtech.integration.v12+json"
          },
          "content": {
            "type": "object",
            "description": "The full resource representation after the change (not present for deletes).",
            "additionalProperties": true
          },
          "publisher": {
            "type": "object",
            "description": "Information about the application that published the notification.",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "GUID of the publishing application."
              },
              "applicationName": {
                "type": "string",
                "description": "Name of the publishing application."
              }
            }
          }
        }
      },
      "Person": {
        "type": "object",
        "description": "A person record following the EEDM persons data model. Represents any individual known to the institution.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier for the person."
          },
          "names": {
            "type": "array",
            "description": "The names associated with this person.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "object",
                  "description": "The type of name.",
                  "properties": {
                    "category": {
                      "type": "string",
                      "enum": ["legal", "birth", "preferred", "personal", "favored"],
                      "description": "The name type category."
                    }
                  }
                },
                "fullName": {
                  "type": "string",
                  "description": "The full name of the person."
                },
                "title": {
                  "type": "string",
                  "description": "Title or prefix (e.g., Mr., Dr., Ms.)."
                },
                "firstName": {
                  "type": "string",
                  "description": "The first or given name."
                },
                "middleName": {
                  "type": "string",
                  "description": "The middle name."
                },
                "lastNamePrefix": {
                  "type": "string",
                  "description": "Prefix to the last name (e.g., van, de)."
                },
                "lastName": {
                  "type": "string",
                  "description": "The last or family name."
                },
                "pedigree": {
                  "type": "string",
                  "description": "Pedigree or suffix (e.g., Jr., III)."
                },
                "preference": {
                  "type": "string",
                  "enum": ["preferred", "notPreferred"],
                  "description": "Indicates whether this is the preferred name."
                }
              }
            }
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "Date of birth."
          },
          "dateDeceased": {
            "type": "string",
            "format": "date",
            "description": "Date of death, if applicable."
          },
          "gender": {
            "type": "string",
            "enum": ["male", "female", "unknown"],
            "description": "Gender of the person."
          },
          "maritalStatus": {
            "type": "object",
            "description": "Marital status.",
            "properties": {
              "maritalCategory": {
                "type": "string",
                "enum": ["single", "married", "divorced", "widowed", "separated"]
              }
            }
          },
          "citizenshipStatus": {
            "type": "object",
            "description": "Citizenship status.",
            "properties": {
              "category": {
                "type": "string",
                "enum": ["citizen", "nonCitizen"],
                "description": "The citizenship category."
              },
              "detail": {
                "$ref": "#/components/schemas/GuidReference"
              }
            }
          },
          "ethnicity": {
            "type": "object",
            "description": "Ethnicity information for US regulatory reporting.",
            "properties": {
              "ethnicGroup": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              },
              "reporting": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "country": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "enum": ["USA", "CAN", "GBR", "BRA"],
                          "description": "ISO 3166-1 alpha-3 country code."
                        }
                      }
                    },
                    "ethnicity": {
                      "type": "object",
                      "properties": {
                        "category": {
                          "type": "string",
                          "enum": ["hispanicOrLatino", "nonHispanicOrLatino", "nonResident"]
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "races": {
            "type": "array",
            "description": "Race information for US regulatory reporting.",
            "items": {
              "type": "object",
              "properties": {
                "race": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid"
                    }
                  }
                },
                "reporting": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "country": {
                        "type": "object",
                        "properties": {
                          "code": { "type": "string" }
                        }
                      },
                      "race": {
                        "type": "object",
                        "properties": {
                          "category": {
                            "type": "string",
                            "enum": ["white", "blackOrAfricanAmerican", "asian", "americanIndianOrAlaskaNative", "nativeHawaiianOrOtherPacificIslander"]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "credentials": {
            "type": "array",
            "description": "Identifiers and credentials for the person.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["bannerId", "colleaguePersonId", "ssn", "sin", "passportNumber", "driverLicense", "elevateId", "colleagueUserName", "bannerUserName", "bannerUdcId"],
                  "description": "The type of credential."
                },
                "value": {
                  "type": "string",
                  "description": "The credential value."
                }
              }
            }
          },
          "addresses": {
            "type": "array",
            "description": "Addresses associated with the person.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "object",
                  "properties": {
                    "addressType": {
                      "type": "string",
                      "enum": ["home", "school", "vacation", "billing", "shipping", "mailing", "business", "parent", "family", "poBox", "main", "branch", "region", "support", "matchingGifts"]
                    }
                  }
                },
                "addressLines": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Address lines."
                },
                "place": {
                  "type": "object",
                  "description": "Geographic place components.",
                  "properties": {
                    "country": {
                      "type": "object",
                      "properties": {
                        "code": { "type": "string" },
                        "title": { "type": "string" }
                      }
                    },
                    "region": {
                      "type": "object",
                      "properties": {
                        "code": { "type": "string" },
                        "title": { "type": "string" }
                      }
                    },
                    "locality": { "type": "string" },
                    "postalCode": { "type": "string" }
                  }
                },
                "startOn": {
                  "type": "string",
                  "format": "date",
                  "description": "Start date of the address."
                },
                "endOn": {
                  "type": "string",
                  "format": "date",
                  "description": "End date of the address."
                },
                "preference": {
                  "type": "string",
                  "enum": ["primary", "secondary"]
                }
              }
            }
          },
          "phones": {
            "type": "array",
            "description": "Phone numbers associated with the person.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "object",
                  "properties": {
                    "phoneType": {
                      "type": "string",
                      "enum": ["mobile", "home", "school", "vacation", "business", "fax", "parent", "tdd", "pager"]
                    }
                  }
                },
                "countryCallingCode": { "type": "string" },
                "number": { "type": "string" },
                "extension": { "type": "string" },
                "preference": {
                  "type": "string",
                  "enum": ["primary", "secondary"]
                }
              }
            }
          },
          "emails": {
            "type": "array",
            "description": "Email addresses associated with the person.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "object",
                  "properties": {
                    "emailType": {
                      "type": "string",
                      "enum": ["personal", "school", "business", "parent", "family", "sales", "support", "general", "billing", "legal", "hr", "media"]
                    }
                  }
                },
                "address": {
                  "type": "string",
                  "format": "email",
                  "description": "The email address."
                },
                "preference": {
                  "type": "string",
                  "enum": ["primary", "secondary"]
                }
              }
            }
          },
          "roles": {
            "type": "array",
            "description": "Institutional roles held by the person.",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string",
                  "enum": ["student", "instructor", "employee", "vendor", "alumni", "prospectiveStudent", "advisor"],
                  "description": "The role type."
                },
                "startOn": {
                  "type": "string",
                  "format": "date-time"
                },
                "endOn": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          },
          "privacyStatus": {
            "type": "object",
            "description": "Privacy status indicator (FERPA, etc.).",
            "properties": {
              "privacyCategory": {
                "type": "string",
                "enum": ["unrestricted", "restricted"]
              }
            }
          }
        }
      },
      "Student": {
        "type": "object",
        "description": "A student record representing an individual enrolled at the institution.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier for the student."
          },
          "person": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the associated person record."
          },
          "type": {
            "type": "object",
            "description": "The student type classification.",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "detail": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              }
            }
          },
          "cohorts": {
            "type": "array",
            "description": "Student cohort memberships.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            }
          },
          "residency": {
            "type": "object",
            "description": "Residency classification for tuition purposes.",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              }
            }
          },
          "measures": {
            "type": "array",
            "description": "Student measures such as admissions test scores.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            }
          }
        }
      },
      "Course": {
        "type": "object",
        "description": "A course catalog entry representing a curriculum offering.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier for the course."
          },
          "title": {
            "type": "string",
            "description": "The course title."
          },
          "description": {
            "type": "string",
            "description": "Full description of the course."
          },
          "subject": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the academic subject/department."
          },
          "number": {
            "type": "string",
            "description": "Course number (e.g., 101, 4500)."
          },
          "courseLevels": {
            "type": "array",
            "description": "Academic levels at which this course is offered.",
            "items": {
              "$ref": "#/components/schemas/GuidReference"
            }
          },
          "academicLevels": {
            "type": "array",
            "description": "Academic levels for the course.",
            "items": {
              "$ref": "#/components/schemas/GuidReference"
            }
          },
          "instructionalMethodDetails": {
            "type": "array",
            "description": "Instructional delivery methods.",
            "items": {
              "type": "object",
              "properties": {
                "instructionalMethod": {
                  "$ref": "#/components/schemas/GuidReference"
                },
                "instructionalDeliveryMethod": {
                  "$ref": "#/components/schemas/GuidReference"
                }
              }
            }
          },
          "credits": {
            "type": "array",
            "description": "Credit definitions for the course.",
            "items": {
              "type": "object",
              "properties": {
                "creditCategory": {
                  "type": "object",
                  "properties": {
                    "creditType": {
                      "type": "string",
                      "enum": ["institutional", "transfer", "continuingEducation"],
                      "description": "Category of credit."
                    }
                  }
                },
                "measure": {
                  "type": "string",
                  "enum": ["credit", "hour", "ceu"],
                  "description": "Unit of credit measure."
                },
                "minimum": {
                  "type": "number",
                  "description": "Minimum credits."
                },
                "maximum": {
                  "type": "number",
                  "description": "Maximum credits."
                },
                "increment": {
                  "type": "number",
                  "description": "Credit increment."
                }
              }
            }
          },
          "effectiveStartDate": {
            "type": "string",
            "format": "date",
            "description": "Date from which the course is effective."
          },
          "effectiveEndDate": {
            "type": "string",
            "format": "date",
            "description": "Date after which the course is no longer effective."
          },
          "owningInstitutionUnits": {
            "type": "array",
            "description": "Departments or units owning this course.",
            "items": {
              "type": "object",
              "properties": {
                "institutionUnit": {
                  "$ref": "#/components/schemas/GuidReference"
                },
                "ownershipPercentage": {
                  "type": "number",
                  "description": "Percentage of ownership."
                }
              }
            }
          }
        }
      },
      "Section": {
        "type": "object",
        "description": "A course section offering within a specific academic period.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier for the section."
          },
          "title": {
            "type": "string",
            "description": "Section title."
          },
          "description": {
            "type": "string",
            "description": "Section description."
          },
          "code": {
            "type": "string",
            "description": "Section code or number."
          },
          "number": {
            "type": "string",
            "description": "Section number within the course."
          },
          "course": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the parent course."
          },
          "academicPeriod": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the academic period."
          },
          "academicLevels": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GuidReference" }
          },
          "site": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the campus site."
          },
          "status": {
            "type": "object",
            "description": "Section registration status.",
            "properties": {
              "category": {
                "type": "string",
                "enum": ["open", "closed", "pending", "cancelled"],
                "description": "Status category."
              }
            }
          },
          "maxEnrollment": {
            "type": "integer",
            "description": "Maximum number of students allowed."
          },
          "currentEnrollment": {
            "type": "integer",
            "description": "Current number of enrolled students."
          },
          "waitlist": {
            "type": "object",
            "description": "Waitlist information.",
            "properties": {
              "maxWaitlist": {
                "type": "integer"
              },
              "currentWaitlist": {
                "type": "integer"
              }
            }
          },
          "credits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "creditCategory": {
                  "type": "object",
                  "properties": {
                    "creditType": {
                      "type": "string",
                      "enum": ["institutional", "transfer", "continuingEducation"]
                    }
                  }
                },
                "measure": {
                  "type": "string",
                  "enum": ["credit", "hour", "ceu"]
                },
                "minimum": { "type": "number" },
                "maximum": { "type": "number" }
              }
            }
          },
          "startOn": {
            "type": "string",
            "format": "date-time",
            "description": "Start date/time of the section."
          },
          "endOn": {
            "type": "string",
            "format": "date-time",
            "description": "End date/time of the section."
          },
          "instructionalPlatform": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the instructional platform (e.g., LMS)."
          },
          "instructors": {
            "type": "array",
            "description": "Instructors assigned to this section.",
            "items": {
              "type": "object",
              "properties": {
                "instructor": {
                  "$ref": "#/components/schemas/GuidReference"
                },
                "instructorRole": {
                  "type": "string",
                  "enum": ["primary", "secondary"],
                  "description": "Role of the instructor in this section."
                },
                "workLoadPercentage": {
                  "type": "number"
                },
                "responsibilityPercentage": {
                  "type": "number"
                }
              }
            }
          },
          "owningInstitutionUnits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "institutionUnit": {
                  "$ref": "#/components/schemas/GuidReference"
                },
                "ownershipPercentage": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "SectionRegistration": {
        "type": "object",
        "description": "A student's registration in a course section.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier for the registration."
          },
          "registrant": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the person (student) registered."
          },
          "section": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the section."
          },
          "status": {
            "type": "object",
            "description": "Registration status.",
            "properties": {
              "registrationStatus": {
                "type": "string",
                "enum": ["registered", "notRegistered"],
                "description": "High-level registration status."
              },
              "sectionRegistrationStatusReason": {
                "type": "string",
                "enum": ["newRegistration", "dropped", "withdrawn", "canceled", "pending"],
                "description": "Detailed reason for the status."
              },
              "detail": {
                "$ref": "#/components/schemas/GuidReference"
              }
            }
          },
          "approvals": {
            "type": "array",
