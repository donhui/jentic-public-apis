                    }
                  },
                  "ends": {
                    "type": "object",
                    "properties": {
                      "date": {
                        "type": "string",
                        "format": "date"
                      },
                      "repetitions": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          },
          "locations": {
            "type": "array",
