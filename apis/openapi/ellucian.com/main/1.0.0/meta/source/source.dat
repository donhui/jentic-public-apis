            "type": "string",
            "enum": ["available", "unavailable"],
            "description": "Whether the accounting string is available for use."
          },
          "components": {
            "type": "array",
            "description": "Individual components of the accounting string.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["fund", "organization", "account", "program", "activity", "location"],
                  "description": "Component type."
                },
                "value": {
                  "type": "string",
                  "description": "Component value."
                },
                "description": {
                  "type": "string",
                  "description": "Component description."
                }
              }
            }
          }
        }
      },
      "Institution": {
        "type": "object",
        "description": "A higher education institution record.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier for the institution."
          },
          "title": {
            "type": "string",
            "description": "Name of the institution."
          },
          "code": {
            "type": "string",
            "description": "Institutional code (e.g., FICE, OPEID, IPEDS)."
          },
          "type": {
            "type": "array",
            "description": "Types of institution.",
            "items": {
              "type": "string",
              "enum": ["postSecondarySchool", "secondarySchool", "highSchool"]
            }
          },
          "addresses": {
            "type": "array",
            "description": "Institution addresses.",
            "items": {
              "type": "object",
              "properties": {
                "addressLines": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "place": {
                  "type": "object",
                  "properties": {
                    "country": {
                      "type": "object",
                      "properties": {
                        "code": { "type": "string" },
                        "title": { "type": "string" }
                      }
                    },
                    "region": {
                      "type": "object",
                      "properties": {
                        "code": { "type": "string" },
                        "title": { "type": "string" }
                      }
                    },
                    "locality": { "type": "string" },
                    "postalCode": { "type": "string" }
                  }
                }
              }
            }
          },
          "phones": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "number": { "type": "string" },
                "type": {
                  "type": "object",
                  "properties": {
                    "phoneType": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "Building": {
        "type": "object",
        "description": "A campus building record.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier for the building."
          },
          "title": {
            "type": "string",
            "description": "Name of the building."
          },
          "code": {
            "type": "string",
            "description": "Institutional code for the building."
          },
          "description": {
            "type": "string",
            "description": "Description of the building."
          },
          "site": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the campus site."
          },
          "status": {
            "type": "string",
            "enum": ["active", "inactive"],
            "description": "Building status."
          },
          "address": {
            "type": "object",
            "description": "Building address.",
            "properties": {
              "addressLines": {
                "type": "array",
                "items": { "type": "string" }
              },
              "place": {
                "type": "object",
                "properties": {
                  "country": {
                    "type": "object",
                    "properties": {
                      "code": { "type": "string" }
                    }
                  },
                  "region": {
                    "type": "object",
                    "properties": {
                      "code": { "type": "string" }
                    }
                  },
                  "locality": { "type": "string" },
                  "postalCode": { "type": "string" }
                }
              }
            }
          },
          "latitude": {
            "type": "number",
            "description": "Geographic latitude."
          },
          "longitude": {
            "type": "number",
            "description": "Geographic longitude."
          }
        }
      },
      "Room": {
        "type": "object",
        "description": "A room within a campus building.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Globally unique identifier for the room."
          },
          "title": {
            "type": "string",
            "description": "Room name or title."
          },
          "number": {
            "type": "string",
            "description": "Room number."
          },
          "description": {
            "type": "string",
            "description": "Room description."
          },
          "building": {
            "$ref": "#/components/schemas/GuidReference",
            "description": "Reference to the building containing this room."
          },
          "floor": {
            "type": "string",
            "description": "Floor on which the room is located."
          },
          "roomTypes": {
            "type": "array",
            "description": "Room type classifications.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "$ref": "#/components/schemas/GuidReference"
                },
                "roomTypesCategory": {
                  "type": "string",
                  "enum": ["classroom", "laboratory", "office", "residentialRoom", "studyRoom", "conferenceRoom", "lecturHall", "other"],
                  "description": "Room type category."
                }
              }
            }
          },
          "occupancies": {
            "type": "array",
            "description": "Occupancy capacities for different uses.",
            "items": {
              "type": "object",
              "properties": {
                "maxOccupancy": {
                  "type": "integer",
                  "description": "Maximum number of occupants."
                },
                "roomLayoutType": {
                  "type": "string",
                  "enum": ["default", "exam", "theater", "conference", "banquet"],
                  "description": "Room layout configuration."
                }
              }
            }
          },
          "status": {
            "type": "string",
            "enum": ["active", "inactive"],
            "description": "Room status."
          }
        }
      }
    }
  }
}