            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "current_value": {
                    "description": "New current value for key result\n",
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
