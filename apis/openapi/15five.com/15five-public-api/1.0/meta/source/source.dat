                      },
                      "description": {
                        "description": "Key result's description\n",
                        "type": "string"
                      },
                      "type": {
                        "description": "Type of key result\n",
                        "type": "string",
                        "enum": [
                          "currency",
                          "boolean",
                          "number",
                          "percent"
                        ]
                      },
                      "currency": {
                        "description": "Currency if key result type is \"currency\", default \"USD\"\n",
                        "type": "string"
                      },
                      "start_value": {
                        "description": "Start value\n",
                        "type": "number"
                      },
                      "target_value": {
                        "description": "Target value\n",
                        "type": "number"
                      },
                      "owner_id": {
                        "description": "Owner user's ID\n",
                        "type": "integer"
                      },
                      "weight": {
                        "description": "Key result's weight\n",
                        "type": "number",
                        "nullable": true
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
