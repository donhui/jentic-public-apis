    "/api/public/one-on-one/": {
      "get": {
        "tags": [
          "1-on-1"
        ],
        "summary": "List 1-on-1s",
        "description": "Get a list of 1-on-1 objects.\n\nReturns 1-on-1 objects for all users within the company.\n",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "If Manager-Reporter include only 1-on-1 objects between manager and reporter If Non-Manager-Reporter exclude 1-on-1 objects between manager and reporter\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "is_draft",
            "in": "query",
            "description": "If true include only draft 1-on-1. If false include only non-draft 1-on-1s.\n",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "group_id",
            "in": "query",
            "description": "Include only 1-on-1 participated by a members of group with the specified ID.\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "description": "Include only 1-on-1 participated by a user with the specified ID.\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_on_start",
            "in": "query",
            "description": "Only include 1-on-1 objects having creation date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_on_end",
            "in": "query",
            "description": "Only include 1-on-1 objects having creation date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scheduled_on_start",
            "in": "query",
            "description": "Only include 1-on-1 objects having scheduled date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scheduled_on_end",
            "in": "query",
            "description": "Only include 1-on-1 objects having scheduled date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ended_on_start",
            "in": "query",
            "description": "Only include 1-on-1 objects having ended date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ended_on_end",
            "in": "query",
            "description": "Only include 1-on-1 objects having ended date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "description": "1-on-1's ID\n",
                      "type": "integer"
                    },
                    "user_1": {
                      "description": "Link to all user_1 details\n",
                      "type": "string"
                    },
                    "user_1_details": {
                      "description": null,
                      "type": "object",
                      "properties": {
                        "id": {
                          "description": "User_1 id\n",
                          "type": "integer"
                        },
                        "full_name": {
                          "description": "Full user_1 name\n",
                          "type": "string"
                        },
                        "email": {
                          "description": "User_1 email\n",
                          "type": "string",
                          "format": "email"
                        }
                      }
                    },
                    "user_1_role": {
                      "description": "User_1 role (manager or reporter)\n",
                      "type": "string"
                    },
                    "user_2": {
                      "description": "Link to all user_2 details\n",
                      "type": "string"
                    },
                    "user_2_details": {
                      "description": null,
                      "type": "object",
                      "properties": {
                        "id": {
                          "description": "User_2 id\n",
                          "type": "integer"
                        },
                        "full_name": {
                          "description": "Full user_2 name\n",
                          "type": "string"
                        },
                        "email": {
                          "description": "User_2 email\n",
                          "type": "string",
                          "format": "email"
                        }
                      }
                    },
                    "user_2_role": {
                      "description": "User_2 role (manager or reporter)\n",
                      "type": "string"
                    },
                    "is_draft": {
                      "description": "Designates whether the 1-on-1 is draft\n",
                      "type": "boolean"
                    },
                    "for_date:": {
                      "description": "Scheduled date\n",
                      "type": "string"
                    },
                    "end_ts:": {
                      "description": "Ended time\n",
                      "type": "string"
                    },
                    "create_ts": {
                      "description": "The actual time this 1-on-1 was created\n",
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          }
        }
      }
    },
