    "/api/public/key-result/": {
      "post": {
        "tags": [
          "Key Result"
        ],
        "summary": "Create key results",
        "description": "Create one or more key results.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "objective_id": {
                      "description": "Associated objective's id\n",
                      "type": "integer"
                    },
                    "description": {
                      "description": "Key result's description\n",
                      "type": "string"
                    },
                    "type": {
                      "description": "Type of key result\n",
                      "type": "string",
                      "enum": [
                        "currency",
                        "boolean",
                        "number",
                        "percent"
                      ]
                    },
                    "currency": {
                      "description": "Currency if key result type is \"currency\", default \"USD\"\n",
                      "type": "string"
                    },
                    "start_value": {
                      "description": "Start value\n",
                      "type": "number"
                    },
                    "target_value": {
                      "description": "Target value\n",
                      "type": "number"
                    },
                    "owner_id": {
                      "description": "Owner user's ID\n",
                      "type": "integer"
                    },
                    "weight": {
                      "description": "Key result's weight\n",
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "Key result's id\n",
                        "type": "integer"
                      },
                      "create_ts": {
                        "description": "timestamp of the creation\n",
                        "type": "string",
                        "format": "date-time"
                      },
                      "update_ts": {
                        "description": "timestamp of the update\n",
