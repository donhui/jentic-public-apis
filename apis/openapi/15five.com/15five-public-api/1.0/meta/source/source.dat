    "/api/public/user/bulk/": {
      "post": {
        "tags": [
          "Bulk User Operations"
        ],
        "summary": "Create or update users in bulk",
        "description": "Create or update user objects.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "description": "User primary key specified by 15Five. If provided, it will be used as the unique identifier regardless of the company's setting for \"Employee identifier\".\n",
                      "type": "integer"
                    },
                    "email": {
                      "description": "The email address for the employee.\n",
                      "type": "string",
                      "format": "email"
                    },
                    "first_name": {
                      "description": "The first name for the employee.\n",
                      "type": "string"
                    },
                    "last_name": {
                      "description": "The last name for the employee.\n",
                      "type": "string"
                    },
                    "phone_number": {
                      "description": "The phone number for the employee. This field only supports United States phone numbers. The value must start with the US area code followed by 10 digits: 1##########.\n",
                      "type": "string",
                      "format": "phone",
                      "pattern": "^1\\d{10}$"
                    },
                    "due_day": {
                      "description": "The day of the week that the employee\u2019s Check-in is due.\n",
                      "type": "integer"
                    },
                    "title": {
                      "description": "Employee's title\n",
                      "type": "string"
                    },
                    "hire_date": {
                      "description": "The date the employee started working at the company.\n",
                      "type": "string"
                    },
                    "termination_date": {
                      "description": "The date of the employee's termination, if applicable\n\nNote: Unlike other attributes, termination_date will apply for users which are deactivated.\n",
                      "type": "string"
                    },
                    "start_date_ts": {
                      "description": "The date a new employee will be invited to and have access to 15Five.\n",
                      "type": "string"
                    },
                    "reviewer_id": {
                      "description": "Email address of the person that will review the employee\u2019s Check-in. This establishes the manager/employee (reviewer/reporter) relationship in 15Five.\n",
                      "type": "integer"
                    },
                    "time_zone": {
                      "description": "Timezone for the employee.\n",
                      "type": "string"
                    },
                    "group_ids": {
                      "description": "Ids for groups that the employee is active in. This property cannot be used with the `update_group_membership_by_group_type` property.\n",
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    },
                    "update_group_membership_by_group_type": {
                      "description": "Specify group memberships per group type using an object keyed by the group type id. For example:\n```\n{ 1: [2]}\n```\n`1` is the group type id, and `2` is the group id.\n\nNote: For each group type specified, you must include every group to which the employee should belong. Employees will be removed from any group not included in the groups array for a specified group type.\n\nIf a key is not specified for an existing group type, that group type will not be affected by the import.\n\nThis property cannot be used with the `group_ids` property.\n",
                      "type": "object"
                    },
                    "is_group_admin_for": {
                      "description": "Use this field to update group admins in bulk (group ids to be specified).\n",
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    },
                    "is_active": {
                      "description": "Flag indicating if this employee is active or inactive.\n",
                      "type": "boolean"
                    },
                    "location": {
                      "description": "Primary employee work location.\n",
                      "type": "string"
                    },
                    "employee_id": {
                      "description": "This field is required if \"Employee ID\" is selected as the company's \"Employee identifier\". Go to Company settings > Import settings to view and configure the \"Employee identifier\" setting.\n",
                      "type": "string"
                    },
                    "job_description": {
                      "description": "The employee\u2019s job description.\n",
                      "type": "string"
                    },
                    "strengths": {
                      "description": "Employee\u2019s strengths as determined by Gallup Strength Finder, VIA personality test, Big Five, Meyers-Briggs, or other methods.\n",
                      "type": "string"
                    },
                    "send_welcome_from_user_id": {
                      "description": "Email address of the person from 15Five.\n",
                      "type": "string"
                    },
                    "custom_[field name]": {
                      "description": "Custom attributes are used to bring in employee data that currently does not exist within 15Five using text and date-based fields like \"Department\" or \"Birthday\".\n",
                      "type": "string"
                    }
                  },
                  "required": [
                    "email"
                  ]
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Created",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "processed_users": {
                        "description": null,
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "email": {
                              "description": "User's email\n",
                              "type": "string",
                              "format": "email"
                            },
                            "id": {
                              "description": "User's ID\n",
                              "type": "integer"
                            },
                            "status": {
                              "description": "Status of the import\n",
                              "type": "string",
                              "enum": [
                                "created",
                                "updated",
                                "deactivated",
                                "unchanged"
                              ]
                            }
                          }
                        }
                      },
                      "errors": {
                        "description": "list of errors\n",
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            },
            "401": {
              "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
            },
            "403": {
              "description": "Forbidden: you don't have access to this resource.\n"
            }
          }
        }
      }
    },
