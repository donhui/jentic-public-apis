    "/api/public/pulse/": {
      "get": {
        "tags": [
          "Pulse"
        ],
        "summary": "Retrieve pulse data",
        "description": "Get a list of pulse values.\n\nReturns pulse values for all users within the company.\n\nResponse is paginated, with a default page size of 50 objects.\n",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Results page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Use to specify ordering. Defaults to \"id\".\nAdd a \"-\" before the field name to reverse the order, e.g. \"-create_ts\".\n",
            "schema": {
              "type": "string",
              "enum": [
                "id",
                "create_ts",
                "update_ts"
              ]
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only include users with creation date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only include users with creation date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_after",
            "in": "query",
            "description": "Only include users with updated date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_before",
            "in": "query",
            "description": "Only include users with updated date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "report_id",
            "in": "query",
            "description": "Include only pulse values for a report/reports with the specified ID.\n\nIn order to query for pulse values for multiple reports, specify reports' ids as a list of parameters, eg.: ?report_id=1&report_id=2\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "description": "Include only pulse values given by a user or users with the specified ID.\n\nIn order to query for pulse values given by multiple users, specify users' ids as a list of parameters, eg.: ?user_id=1&user_id=2\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_on_start",
            "in": "query",
            "description": "Only include pulse values having creation date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_on_end",
            "in": "query",
            "description": "Only include pulse values having creation date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Results page",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "description": "Total number of results",
                      "type": "integer"
                    },
                    "next": {
                      "description": "URL of the next page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "previous": {
                      "description": "URL of the previous page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "results": {
                      "type": "array",
                      "minItems": 0,
                      "maxItems": 50,
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Pulse's ID\n",
                            "type": "integer"
                          },
                          "report": {
                            "description": "Report that created this pulse value\n",
                            "type": "string"
                          },
                          "user": {
                            "description": "User that gave the answer\n",
                            "type": "string"
                          },
                          "create_ts": {
                            "description": "The actual date this answer was saved (submitted) by user\n",
                            "type": "string"
                          },
                          "value": {
                            "description": "Pulse's value\n",
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          }
        }
      }
    },
