    "/api/public/objective/": {
      "get": {
        "tags": [
          "Objective"
        ],
        "summary": "List objectives",
        "description": "Get a list of objectives within the company.\n\nResponse is paginated, with a default page size of 50 objects.\n",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "description": "Include only person-specific objectives for a user with the specified ID.\n",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "parent_id",
            "in": "query",
            "description": "Include only objectives of a parent with the specified ID.\n",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "department_id",
            "in": "query",
            "description": "Include only objectives for a department/departments with the specified ID. In order to query for multiple departments, specify departments' ids as a list of parameters, eg.: ?department_id=1&department_id=2\n",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start_after",
            "in": "query",
            "description": "Only include objectives with start date greater than or equal to the date specified in the YYYY-MM-DD format.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end_before",
            "in": "query",
            "description": "Only include objectives with end date less than or equal to the date specified in the YYYY-MM-DD format.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scope",
            "in": "query",
            "description": "Include only objectives with the specified scope\ntype: string\nenum:\n  - company-wide\n  - group-type\n  - individual\n  - self-development\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Include only objectives with the specified state; deprecated values: 'past', 'current', 'deactivated'\n",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "future",
                "archived",
                "closed"
              ]
            }
          },
          {
            "name": "color",
            "in": "query",
            "description": "Include only objectives with the specified current status\n",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "green",
                "yellow",
                "red",
                "undefined"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Results page",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only include objectives with creation date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only include objectives with creation date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_after",
            "in": "query",
            "description": "Only include objectives with updated date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_before",
            "in": "query",
            "description": "Only include objectives with updated date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Order results by the specified field.\nThe default ordering is: \"end_ts,sort_order,id\".\nAdd \"-\" prefix to the field name to reverse the order.\n",
            "schema": {
              "type": "string",
              "enum": [
                "id",
                "end_ts",
                "create_ts",
                "update_ts",
                "sort_order",
                "-id",
                "-end_ts",
                "-create_ts",
                "-update_ts",
                "-sort_order"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "description": "Total number of results",
                      "type": "integer"
                    },
                    "next": {
                      "description": "URL of the next page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "previous": {
                      "description": "URL of the previous page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "results": {
                      "type": "array",
                      "minItems": 0,
                      "maxItems": 50,
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Objective's ID\n",
                            "type": "integer"
                          },
                          "create_ts": {
                            "description": "timestamp of the creation\n",
                            "type": "string",
                            "format": "date-time"
                          },
                          "update_ts": {
                            "description": "timestamp of the update\n",
                            "type": "string",
                            "format": "date-time"
                          },
                          "parent": {
                            "description": "Link to objective's parent\n",
                            "type": "string"
                          },
                          "user": {
                            "description": "Link to objective's user\n",
                            "type": "string"
                          },
                          "user_details": {
                            "description": null,
                            "type": "object",
                            "properties": {
                              "id": {
                                "description": "user id\n",
                                "type": "integer"
                              },
                              "full_name": {
                                "description": "full user name\n",
                                "type": "string"
                              },
                              "email": {
                                "description": "user email\n",
                                "type": "string",
                                "format": "email"
                              }
                            }
                          },
                          "description": {
                            "description": "Objective's description\n",
                            "type": "string"
                          },
                          "scope": {
                            "description": "Objective's scope\n",
                            "type": "string",
                            "enum": [
                              "company-wide",
                              "group-type",
                              "individual",
                              "self-development"
                            ]
                          },
                          "start_ts": {
                            "description": "Objective's start date\n",
                            "type": "string"
                          },
                          "end_ts": {
                            "description": "Objective's end date\n",
                            "type": "string"
                          },
                          "color": {
                            "description": "Objective's status color\n",
                            "type": "string",
                            "enum": [
                              "green",
                              "yellow",
                              "red",
                              "undefined"
                            ]
                          },
                          "percentage": {
                            "description": "Objective's composite percentage of completion\n",
                            "type": "integer"
                          },
                          "is_active": {
                            "description": "Designates whether the objective is active\n",
                            "type": "boolean"
                          },
                          "is_closed": {
                            "description": "Designates whether the objective is closed\n",
                            "type": "boolean"
                          },
                          "is_complete": {
                            "description": "Designates whether the objective is closed. Warning: deprecated. Use is_closed instead.\n",
                            "type": "boolean"
                          },
                          "is_archived": {
                            "description": "Designates whether the objective is archived\n",
                            "type": "boolean"
                          },
                          "is_past_due": {
                            "description": "Designates whether the objective is past due\n",
                            "type": "boolean"
                          },
                          "is_future": {
                            "description": "Designates whether the objective's start date is in the future\n",
                            "type": "boolean"
                          },
                          "visibility": {
                            "description": "Objective's visibility\n",
                            "type": "string",
                            "enum": [
                              "public",
                              "report",
                              "custom"
                            ]
                          },
                          "result_count": {
                            "description": "Number of objective's key results\n",
                            "type": "integer"
                          },
                          "weight": {
                            "description": "Objective's weight\n",
                            "type": "number",
                            "nullable": true
                          }
                        }
                      }
                    }
                  }
