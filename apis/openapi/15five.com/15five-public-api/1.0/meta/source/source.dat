            "schema": {
              "type": "string",
              "enum": [
                "id",
                "create_ts",
                "user",
                "start_dt",
                "end_dt"
              ]
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only include vacations with creation date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only include vacations with creation date less than or equal to the value.\n",
