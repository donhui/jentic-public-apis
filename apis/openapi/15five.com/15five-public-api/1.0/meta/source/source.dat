    "/api/public/review-cycle/{id}/participants/": {
      "get": {
        "tags": [
          "Review Cycle"
        ],
        "summary": "Retrieve cycle participants information",
        "description": "Get a list of participants within a cycle.\n\nReturns detailed information about all participants in a review cycle.\n\nResponse is paginated.\n",
        "parameters": [
          {
            "name": "cycle_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only include participants having creation date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n\nNote: this parameter has an alias name \"created_on_start\", which is deprecated.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only include participants having creation date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n\nNote: this parameter has an alias name \"created_on_end\", which is deprecated.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "updated_after",
            "in": "query",
            "description": "Only include participants having update date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n\nNote: this parameter has an alias name \"updated_on_start\", which is deprecated.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "updated_before",
            "in": "query",
            "description": "Only include participants having update date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n\nNote: this parameter has an alias name \"updated_on_end\", which is deprecated.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hierarchy_updated_after",
            "in": "query",
            "description": "Only include participants having hierarchy update date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n\nNote: this filter is currently in testing phase. Please contact support if you plan to use it.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hierarchy_updated_before",
            "in": "query",
            "description": "Only include participants having hierarchy update date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n\nNote: this filter is currently in testing phase. Please contact support if you plan to use it.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "description": "Filter participants by participant user's id.\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "group_id",
            "in": "query",
            "description": "Filter participants by user's group id.\n",
            "schema": {
              "type": "integer"
            }
          },
          {
