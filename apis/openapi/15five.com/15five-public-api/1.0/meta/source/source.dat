    "/api/public/report/": {
      "get": {
        "tags": [
          "Check-in"
        ],
        "summary": "List check-ins",
        "description": "Get a list of check-ins.\n\nReturns check-ins for all users within the company.\n\nResponse is paginated, with a default page size of 100 objects.\n",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "description": "Filter reports by user id.\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "due_date_start",
            "in": "query",
            "description": "Only include reports with due date greater than or equal to the date specified in the YYYY-MM-DD format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "due_date_end",
            "in": "query",
            "description": "Only include reports with due date less than or equal to the date specified in the YYYY-MM-DD format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Available sorting fields (id, user, due_date), defaults to \"-id\".\n\nAdd a \"-\" before the field name to reverse the order e.g. \"-due_date\"\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Results page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only include users with creation date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only include users with creation date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "description": "Total number of results",
                      "type": "integer"
                    },
                    "next": {
                      "description": "URL of the next page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "previous": {
                      "description": "URL of the previous page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "results": {
                      "type": "array",
                      "minItems": 0,
                      "maxItems": 100,
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Report's ID\n",
                            "type": "integer"
                          },
                          "user": {
                            "description": "User that submitted this report\n",
                            "type": "string"
                          },
                          "due_date": {
                            "description": "The actual date this report is/was due - can be different than the present due day as the due day may change\n",
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          }
        }
      }
    },
    "/api/public/report/{id}/": {
      "get": {
        "tags": [
          "Check-in"
        ],
        "summary": "Get check-in details",
        "description": "Get check-in object details.\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "description": "Report's ID\n",
                      "type": "integer"
                    },
                    "user": {
                      "description": "User that submitted this report\n",
                      "type": "string"
                    },
                    "due_date": {
                      "description": "The actual date this report is/was due - can be different than the present due day as the due day may change\n",
                      "type": "string"
                    },
                    "reporting_period": {
                      "description": null,
                      "type": "string"
                    },
                    "reporting_period_start": {
                      "description": "Timestamp that designates when the reporting period started or starts\n",
                      "type": "string"
                    },
                    "reporting_period_end": {
                      "description": "Timestamp that designates when the reporting period ended or ends\n",
                      "type": "string"
                    },
                    "submit_ts": {
                      "description": "Timestamp that designates when this report was submitted\n",
                      "type": "string"
                    },
                    "reviewed_ts": {
                      "description": "Report's review timestamp\n",
                      "type": "string"
                    },
                    "reviewed_by": {
                      "description": "If this report is submitted but not yet reviewed, this field is set to the reviewer who is responsible for reviewing this report. This reviewer can change. If the report is already reviewed, this field is set to the user who actually reviewed the report\n",
                      "type": "string"
                    },
                    "was_submitted_late": {
                      "description": "Designates whether this report was submitted late\n",
                      "type": "boolean"
                    },
                    "questions": {
                      "description": "List of questions included in the report. Each question may contain a list of answers and each answer may contain a list of comments.\n",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "question": {
                            "description": "The questions being asked\n",
                            "type": "object"
                          }
                        }
                      }
                    },
                    "comments": {
                      "description": "List of report-wide comments\n",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "user": {
                            "description": "User who left the comment\n",
                            "type": "object"
                          },
                          "comment_text": {
                            "description": "Content of comment\n",
                            "type": "string"
                          }
                        }
                      }
                    },
                    "goals": {
                      "description": "List of goals in the report along with their answers and comments if they exist.\n",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "goals": {
                            "description": "goal object\n",
                            "type": "object"
                          }
                        }
                      }
                    },
                    "accomplishments": {
                      "description": "List of goals from the prior report, which had their status set in this report, along with their answers and comments.\n",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "qoals": {
                            "description": "goal object\n",
                            "type": "object"
                          }
                        }
                      }
                    },
                    "pulse": {
                      "description": "List of pulse questions in the report along with their answers and comments if they exist.\n",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "question": {
                            "description": "question object\n",
                            "type": "object"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          },
          "404": {
            "description": "Resource not found.\n"
          }
        }
      },
      "delete": {
