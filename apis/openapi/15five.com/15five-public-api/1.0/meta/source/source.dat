            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hierarchy_updated_after",
            "in": "query",
            "description": "Only include review cycles having hierarchy update date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n\nNote: this filter is currently in testing phase. Please contact support if you plan to use it.\n",
