            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          }
        }
      },
      "post": {
        "tags": [
          "Group Type"
        ],
        "summary": "Create group type",
        "description": "Create a group type within a company.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name_plural": {
                    "description": "Plural name of the company group type\n",
                    "type": "string"
                  },
                  "name_singular": {
                    "description": "Name of the company group type\n",
                    "type": "string"
                  }
                },
                "required": [
                  "name_plural"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "description": "Group Type's ID\n",
                      "type": "integer"
                    },
                    "name_plural": {
                      "description": "Group Type's plural name\n",
                      "type": "string"
                    },
                    "name_singular": {
                      "description": "Group Type's singular name\n",
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          },
          "409": {
            "description": "Group type with `name_plural` already exists.\n"
          }
        }
      }
    },
