    "/api/public/objective/history/": {
      "get": {
        "tags": [
          "Objective History"
        ],
        "summary": "Get all objectives history",
        "description": "List all objectives history.\n\nResponse is paginated, with a default page size of 50 objects.\n",
        "parameters": [
          {
            "name": "created_after",
            "in": "query",
            "description": "Only include history with creation date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only include history with creation date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_after",
            "in": "query",
            "description": "Only include history with updated date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_before",
            "in": "query",
            "description": "Only include history with updated date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Order results by the specified field.\nAdd \"-\" prefix to the field name to reverse the order.\n",
            "schema": {
              "type": "string",
              "enum": [
                "create_ts",
                "update_ts",
                "-create_ts",
                "-update_ts"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "description": "Total number of results",
                      "type": "integer"
                    },
                    "next": {
                      "description": "URL of the next page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "previous": {
                      "description": "URL of the previous page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "create_ts": {
                            "type": "string",
                            "required": true,
                            "description": "timestamp of the creation",
                            "format": "date-time"
                          },
                          "update_ts": {
                            "type": "string",
                            "required": true,
                            "description": "timestamp of the change",
                            "format": "date-time"
                          },
                          "user": {
                            "type": "string",
                            "required": true,
                            "description": "user who made the change"
                          },
                          "user_details": {
                            "type": "array",
                            "required": true,
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "integer",
                                  "required": true,
                                  "description": "user id"
                                },
                                "full_name": {
                                  "type": "string",
                                  "required": true,
                                  "description": "full name"
                                },
                                "email": {
                                  "type": "string",
                                  "required": true,
                                  "description": "user email",
                                  "format": "email"
                                }
                              }
                            }
                          },
                          "event": {
                            "type": "string",
                            "required": true,
                            "description": "type of the change",
                            "enum": [
                              "created_objective",
                              "updated_owner",
                              "updated_type",
                              "updated_department",
                              "updated_parent_objective",
                              "updated_start_date",
                              "updated_end_date",
                              "updated_title",
                              "updated_visibility",
                              "created_key_result",
                              "deleted_key_result",
                              "updated_key_result_type",
                              "updated_key_result_currency",
                              "updated_key_result_start_value",
                              "updated_key_result_target_value",
                              "updated_key_result_description",
                              "updated_key_result_owner",
                              "created_aligned_objective",
                              "converted_aligned_objective",
                              "closed_objective",
                              "bulk_closed_objectives",
                              "archived_objective",
                              "bulk_archived_objectives",
                              "unarchived_objective",
                              "created_assessment",
                              "edited_assessment",
                              "deleted_assessment",
                              "updated_status",
                              "updated_key_result_value",
                              "commented_from_report",
                              "commented_from_activity_feed"
                            ]
                          },
                          "objective_id": {
                            "type": "integer",
                            "description": "objective id"
                          },
                          "description": {
                            "type": "string",
                            "description": "objective description"
                          },
                          "report_id": {
                            "type": "integer",
                            "description": "report id"
                          },
                          "key_result_id": {
                            "type": "integer",
                            "description": "key result id"
                          },
                          "key_result": {
                            "type": "string",
                            "description": "key result description"
                          },
                          "prior_value": {
                            "type": "string",
                            "description": "value before the change"
                          },
                          "current_value": {
                            "type": "string",
                            "description": "value after the change"
                          },
                          "comment_text": {
                            "type": "string",
                            "description": "comment text"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          },
          "404": {
            "description": "Resource not found.\n"
          }
        }
      }
    },
