    "/api/public/high-five/": {
      "get": {
        "tags": [
          "High Five"
        ],
        "summary": "List high fives",
        "description": "Get a list of high fives within the company.\n\nResponse is paginated, with a default page size of 50 objects.\n",
        "parameters": [
          {
            "name": "report_id",
            "in": "query",
            "description": "Include only high fives within the report with the specified ID.\n\nIn order to query for high fives given by multiple reports, specify report ids as a list of parameters, eg.: ?report_id=1&report_id=2\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "receiver_id",
            "in": "query",
            "description": "Include only high fives received by the provided user ID(s).\n\nIn order to query for high fives received by multiple IDs, specify receiver ids as a list of parameters, eg.: ?receiver_id=1&receiver_id=2\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_on_start",
            "in": "query",
            "description": "Only include high fives having creation date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_on_end",
            "in": "query",
            "description": "Only include high fives having creation date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Available sorting fields (id, report, create_ts), defaults to \"create_ts\".\n\nAdd a \"-\" before the field name to reverse the order e.g. \"-create_ts\"\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Results page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only include users with creation date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only include users with creation date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_after",
            "in": "query",
            "description": "Only include users with updated date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_before",
            "in": "query",
            "description": "Only include users with updated date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "description": "Total number of results",
                      "type": "integer"
                    },
                    "next": {
                      "description": "URL of the next page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "previous": {
                      "description": "URL of the previous page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "results": {
                      "type": "array",
                      "minItems": 0,
                      "maxItems": 50,
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "High fives's ID\n",
                            "type": "integer"
                          },
                          "report": {
                            "description": "Report that contains the high five\n",
                            "type": "string"
                          },
                          "create_ts": {
                            "description": "The actual date this high five was saved (submitted) by user\n",
                            "type": "string"
                          },
                          "text": {
                            "description": "High Five's content\n",
                            "type": "string"
                          },
                          "creator_id": {
                            "description": "High five creator's ID\n",
                            "type": "integer"
                          },
                          "creator": {
                            "description": "Link to high five's creator\n",
                            "type": "string"
                          },
                          "creator_details": {
                            "description": null,
                            "type": "object",
                            "properties": {
                              "id": {
                                "description": "creator id\n",
                                "type": "integer"
                              },
                              "full_name": {
                                "description": "full creator name\n",
                                "type": "string"
                              },
                              "email": {
                                "description": "creator email\n",
                                "type": "string",
                                "format": "email"
                              }
                            }
                          },
                          "receivers": {
                            "description": "list of all mentioned users (incl. users mentioned by all, and groups)\n",
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "description": "user id\n",
                                  "type": "integer"
                                },
                                "url": {
                                  "description": "link to user details\n",
                                  "type": "string"
                                },
                                "full_name": {
                                  "description": "full user name\n",
                                  "type": "string"
                                },
                                "email": {
                                  "description": "user email\n",
                                  "type": "string",
                                  "format": "email"
                                }
                              }
                            }
                          },
                          "email_receivers": {
                            "description": "list of email mentions\n",
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "email": {
                                  "description": "mentioned email\n",
                                  "type": "string",
