                                "description": "user id\n",
                                "type": "integer"
                              },
                              "full_name": {
                                "description": "full user name\n",
                                "type": "string"
                              },
                              "email": {
                                "description": "user email\n",
                                "type": "string",
                                "format": "email"
                              }
                            }
                          },
                          "additional_managers": {
                            "description": "Participant's additional managers\n",
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "user": {
                                  "type": "object",
                                  "properties": {
                                    "id": {
                                      "description": "user id\n",
                                      "type": "integer"
                                    },
                                    "full_name": {
                                      "description": "full user name\n",
                                      "type": "string"
                                    },
