    "/api/public/one-on-one/bulk-export/": {
      "get": {
        "tags": [
          "1-on-1"
        ],
        "summary": "Bulk export 1-on-1s",
        "description": "Bulk exporting for 1-on-1s.\n\nThis view is hidden behind a feature flag. Please contact support if you plan to use it.\n",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
