  "paths": {
    "/hello": {
      "get": {
        "summary": "Check API connection",
        "description": "Check API connection and API key validity. Returns 15Five's server current timestamp.",
        "operationId": "hello",
        "tags": [
          "Introduction"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "timestamp": {
                      "type": "integer",
                      "description": "15Five's server current timestamp"
                    }
                  }
                },
                "examples": {
                  "User submits report": {
                    "value": {
                      "timestamp": 1670536702
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          }
        },
        "x-codeSamples": [
          {
            "lang": "bash",
            "source": "$ curl -v -H \"Authorization: <TOKEN>\" https://<company subdomain>.15five.com/api/public/hello/\n"
          },
          {
            "lang": "JavaScript",
            "source": "var coreapi = window.coreapi;\nvar token = new coreapi.auth.TokenAuthentication({token: \"<TOKEN>\"})\nvar client = new coreapi.Client({auth: token});\nclient.get(\"https://<company subdomain>.15five.com/api/public/hello/\")\n    .then((data) => {\n        console.log(\"Status: \", data);\n    })\n    .catch((error) => {\n        console.log(\"Error: \", error);\n    });\n"
          },
          {
            "lang": "Python",
            "source": "import coreapi\nauth = coreapi.auth.TokenAuthentication(token='<TOKEN>')\nclient = coreapi.Client(auth=auth)\nresponse = client.get(\"https://<company subdomain>.15five.com/api/public/hello/\")\n"
          }
        ]
      }
    },
    "/api/public/answer/": {
      "get": {
        "tags": [
          "Answer"
        ],
        "summary": "List answers",
        "description": "Get a list of answers.\n\nReturns check-in answers for all users within the company.\n\nResponse is paginated, with a default page size of 50 objects.\n",
        "parameters": [
          {
            "name": "question_id",
            "in": "query",
            "description": "Include only answers for a question/questions with the specified ID.\n\nIn order to query for answers for multiple questions, specify questions' ids as a list of parameters, eg.: ?question_id=1&question_id=2\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "description": "Include only answers given by a user or users with the specified ID.\n\nIn order to query for answers given by multiple users, specify users' ids as a list of parameters, eg.: ?user_id=1&user_id=2\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_on_start",
            "in": "query",
            "description": "Only include answers having creation date greater than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_on_end",
            "in": "query",
            "description": "Only include answers having creation date less than or equal to the date time specified in the YYYY-MM-DD HH:MM:SS format.\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Available sorting fields (id, user, question, create_ts), defaults to \"create_ts\".\n\nAdd a \"-\" before the field name to reverse the order e.g. \"-create_ts\".\n",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Results page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Only include users with creation date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Only include users with creation date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_after",
            "in": "query",
            "description": "Only include users with updated date greater than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "updated_before",
            "in": "query",
            "description": "Only include users with updated date less than or equal to the value.\n",
            "schema": {
              "type": "string",
              "pattern": " YYYY-MM-DD or YYYY-MM-DD HH:MM:SS"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Results page",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "description": "Total number of results",
                      "type": "integer"
                    },
                    "next": {
                      "description": "URL of the next page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "previous": {
                      "description": "URL of the previous page of results",
                      "type": "string",
                      "format": "uri",
                      "nullable": true
                    },
                    "results": {
                      "type": "array",
                      "minItems": 0,
                      "maxItems": 50,
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Answers's ID\n",
                            "type": "integer"
                          },
                          "report_id": {
                            "description": "Report's ID\n",
                            "type": "integer"
                          },
                          "question": {
                            "description": "Question that this answer answers\n",
                            "type": "string"
                          },
                          "user": {
                            "description": "User that gave the answer\n",
                            "type": "string"
                          },
                          "create_ts": {
                            "description": "The actual date this answer was saved (submitted) by user\n",
                            "type": "string"
                          },
                          "answer_text": {
                            "description": "Answer's content\n",
                            "type": "string"
                          },
                          "metrics_value": {
                            "description": "Answer's metrics value\n",
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
            "description": "Forbidden: you don't have access to this resource.\n"
          }
        }
      }
    },
    "/api/public/answer/{id}/": {
      "get": {
        "tags": [
          "Answer"
        ],
        "summary": "Get answer details",
        "description": "Get answer object details.\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "description": "Answers's ID\n",
                      "type": "integer"
                    },
                    "report_id": {
                      "description": "Report's ID\n",
                      "type": "integer"
                    },
                    "question": {
                      "description": "Question that this answer answers\n",
                      "type": "string"
                    },
                    "user": {
                      "description": "User that gave the answer\n",
                      "type": "string"
                    },
                    "create_ts": {
                      "description": "The actual date this answer was saved (submitted) by user\n",
                      "type": "string"
                    },
                    "answer_text": {
                      "description": "Answer's content\n",
                      "type": "string"
                    },
                    "metrics_value": {
                      "description": "Answer's metrics value\n",
                      "type": "number"
                    },
                    "comments": {
                      "description": "List of comments related to this answer\n",
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "user": {
                            "description": "User who left the comment\n",
                            "type": "object"
                          },
                          "comment_text": {
                            "description": "Content of comment\n",
                            "type": "string"
                          }
                        }
                      }
                    },
                    "goal_status": {
                      "description": "Status code or None\n",
                      "type": "integer"
                    },
                    "goal_completed_ts": {
                      "description": "Timestamp of when goal was completed\n",
                      "type": "string"
                    },
                    "goal_status_comments": {
                      "description": "Comments related to goal status\n",
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request: missing or incorrect request parameters.\n"
          },
          "401": {
            "description": "Unauthorized: API key is missing, invalid, or expired. API key owner or organization might be inactive.\n"
          },
          "403": {
