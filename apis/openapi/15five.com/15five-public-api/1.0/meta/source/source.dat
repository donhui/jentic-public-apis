            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Use to specify ordering. Defaults to \"id\".\nAdd a \"-\" before the field name to reverse the order, e.g. \"-create_ts\".\n",
            "schema": {
              "type": "string",
              "enum": [
                "id",
                "create_ts",
                "update_ts",
                "hierarchy_update_ts"
