        "summary": "List vacations",
        "description": "Get a list of vacations within the company.\n\nResponse is paginated, with a default page size of 50 objects.\n",
        "parameters": [
          {
            "name": "user",
            "in": "query",
            "description": "Include only vacations for given user ids.\n",
            "schema": {
              "type": "array",
