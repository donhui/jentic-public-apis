  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using API login and password. Credentials are generated in Firmao under Company -> Settings -> API."
      }
    },
    "parameters": {
      "PageParam": {
        "name": "page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 0
        },
        "description": "Page number (0-based)"
      },
      "PageSizeParam": {
        "name": "pageSize",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 25
        },
        "description": "Number of items per page"
      },
      "SortParam": {
        "name": "sort",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Sort field and direction (e.g., 'name,asc')"
      },
      "FilterParam": {
        "name": "filter",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Filter expression"
      }
    },
    "schemas": {
      "IdReference": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Entity ID"
          }
        }
      },
      "TagReference": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Tag ID"
          }
        }
      },
      "ProjectInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Project name"
          },
          "description": {
            "type": "string",
            "description": "Project description"
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "description": "Project start date"
          },
          "teamMembers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IdReference"
            },
            "description": "Team member references"
          },
          "restrictedTeamMembers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IdReference"
            }
          },
          "managers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IdReference"
            },
            "description": "Manager references"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagReference"
            }
          }
        }
      },
      "TaskInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Task name"
          },
          "description": {
            "type": "string",
            "description": "Task description"
          },
          "taskType": {
            "type": "string",
            "enum": [
              "PROJECT",
              "PERSONAL"
            ],
            "description": "Task type"
          },
          "priority": {
            "type": "string",
            "description": "Priority level (e.g., 300)"
          },
          "status": {
            "type": "string",
            "enum": [
              "WAITING",
              "IN_PROGRESS",
              "DONE"
            ],
            "description": "Task status"
          },
          "responsibleUsers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IdReference"
            },
            "description": "Assigned users"
          },
          "estimatedHours": {
            "type": "number",
            "description": "Estimated hours for the task"
          },
          "plannedStartDate": {
            "type": "string",
            "format": "date-time",
            "description": "Planned start date"
          },
          "plannedEndDate": {
            "type": "string",
            "format": "date-time",
            "description": "Planned end date"
          },
          "plannedStartDateType": {
            "type": "string",
            "enum": [
              "EXACTLY",
              "FLEXIBLE"
            ]
          },
          "plannedEndDateType": {
            "type": "string",
            "enum": [
              "EXACTLY",
              "FLEXIBLE"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagReference"
            }
          }
        }
      },
      "ProductInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Product name"
          },
          "productCode": {
            "type": "string",
            "description": "Product code/SKU"
          },
          "saleable": {
            "type": "boolean",
            "description": "Whether the product is available for sale"
          },
          "purchasePriceGroup.netPrice": {
            "type": "number",
            "description": "Net purchase price"
          },
          "purchasePriceGroup.grossPrice": {
            "type": "number",
            "description": "Gross purchase price"
          },
          "purchasePriceGroup.vat": {
            "type": "number",
            "description": "VAT percentage"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagReference"
            }
          }
        }
      },
      "CustomerInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Customer/company name"
          },
          "label": {
            "type": "string",
            "description": "Short label/identifier"
          },
          "description": {
            "type": "string",
            "description": "Customer description"
          },
          "customerType": {
            "type": "string",
            "enum": [
              "PARTNER",
              "CLIENT",
              "SUPPLIER"
            ],
            "description": "Customer type"
          },
          "ownership": {
            "type": "string",
            "enum": [
              "PRIVATE",
              "PUBLIC"
            ]
          },
          "nipNumber": {
            "type": "string",
            "description": "Tax identification number (NIP)"
          },
          "bankAccountNumber": {
            "type": "string",
            "description": "Bank account number"
          },
          "website": {
            "type": "string",
            "description": "Company website URL"
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Email addresses"
          },
          "phones": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Phone numbers"
          },
          "faxNumber": {
            "type": "string"
          },
          "employeesNumber": {
            "type": "integer",
            "description": "Number of employees"
          },
          "officeAddress.street": {
            "type": "string"
          },
          "officeAddress.city": {
            "type": "string"
          },
          "officeAddress.postCode": {
            "type": "string"
          },
          "officeAddress.country": {
            "type": "string"
          },
          "correspondenceAddress.street": {
            "type": "string"
          },
          "correspondenceAddress.city": {
            "type": "string"
          },
          "correspondenceAddress.postCode": {
            "type": "string"
          },
          "correspondenceAddress.country": {
            "type": "string"
          },
          "correspondenceAddress.county": {
            "type": "string"
          },
          "customerGroups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IdReference"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagReference"
            }
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "voivodeship": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "TransactionInput": {
        "type": "object",
        "required": [
          "type",
          "mode"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "INVOICE",
              "PROFORMA",
              "RECEIPT",
              "CORRECTION"
            ],
            "description": "Transaction type"
          },
          "mode": {
            "type": "string",
            "enum": [
              "SALE",
              "PURCHASE"
            ],
            "description": "Transaction mode"
          },
          "customer": {
            "type": "integer",
            "description": "Customer ID"
          },
          "transactionNumber": {
            "type": "string",
            "description": "Invoice number"
          },
          "autoNumber": {
            "type": "boolean",
            "description": "Auto-generate invoice number"
          },
          "currency": {
            "type": "string",
            "description": "Currency code (e.g., PLN, EUR)"
          },
          "paymentType": {
            "type": "string",
            "enum": [
              "CASH",
              "TRANSFER",
              "CARD"
            ]
          },
          "paid": {
            "type": "boolean"
          },
          "paidValue": {
            "type": "number"
          },
          "restOfPaidValue": {
            "type": "number"
          },
          "transactionNettoPrice": {
            "type": "string",
            "description": "Total net price"
          },
          "transactionBruttoPrice": {
            "type": "string",
            "description": "Total gross price"
          },
          "transactionVatPrice": {
            "type": "string",
            "description": "Total VAT amount"
          },
          "invoiceDate": {
            "type": "string",
            "format": "date",
            "description": "Invoice date"
          },
          "paymentDate": {
            "type": "string",
            "format": "date",
            "description": "Payment due date"
          },
          "transactionDate": {
            "type": "string",
            "format": "date",
            "description": "Transaction date"
          },
          "invoiceAnnotations": {
            "type": "string",
            "nullable": true
          },
          "issuingPerson": {
            "type": "string",
            "description": "Person issuing the invoice"
          },
          "createNewCustomerIfNeeded": {
            "type": "boolean",
            "description": "Create a new customer if one doesn't exist"
          },
          "customerName": {
            "type": "string",
            "description": "Customer name (used with createNewCustomerIfNeeded)"
          },
          "transactionEntries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransactionEntry"
            },
            "description": "Line items"
          }
        }
      },
      "TransactionEntry": {
        "type": "object",
        "properties": {
          "product": {
            "type": "integer",
            "description": "Product ID"
          },
          "productCode": {
            "type": "string",
            "description": "Product code"
          },
          "quantity": {
            "type": "number"
          },
          "unit": {
            "type": "string",
            "nullable": true
          },
          "unitNettoPrice": {
            "type": "string",
            "description": "Unit net price"
          },
          "vatPercent": {
            "type": "number",
            "description": "VAT percentage"
          },
          "discount": {
            "type": "number",
            "nullable": true
          },
          "classificationNumber": {
            "type": "string"
          }
        }
      },
      "OfferInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Offer name"
          },
          "customer": {
            "type": "integer",
            "description": "Customer ID"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ContactInput": {
        "type": "object",
        "required": [
          "firstName",
          "lastName"
        ],
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "position": {
            "type": "string"
          },
          "customer": {
            "type": "integer",
            "description": "Associated customer ID"
          }
        }
      },
      "SalesNoteInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Sales note title"
          },
          "description": {
            "type": "string"
          },
          "customer": {
            "type": "integer",
            "description": "Associated customer ID"
          }
        }
      },
      "SalesOpportunityInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Sales opportunity name"
          },
          "description": {
            "type": "string"
          },
          "customer": {
            "type": "integer",
            "description": "Associated customer ID"
          },
          "value": {
            "type": "number",
            "description": "Estimated value"
          }
        }
      },
      "WorkTimeInput": {
        "type": "object",
        "properties": {
          "task": {
            "type": "integer",
            "description": "Associated task ID"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "ChangelogResponse": {
        "type": "object",
        "properties": {
          "changelog": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChangelogEntry"
            }
          }
        }
      },
      "ChangelogEntry": {
        "type": "object",
        "properties": {
          "modification": {
            "type": "string",
            "enum": [
              "CREATE",
              "CHANGE",
              "DELETE"
            ]
          },
          "objectClass": {
            "type": "string",
            "description": "Type of object modified"
          },
          "objectId": {
            "type": "integer",
            "description": "ID of the modified object"
          },
          "objectLabel": {
            "type": "string",
            "description": "Label of the modified object"
          },
          "property": {
            "type": "string",
            "description": "Property that was changed"
          },
          "deletedWith": {
            "type": "string"
          },
          "newValueDisplay": {
            "type": "string"
          },
          "oldValueDisplay": {
            "type": "string"
          },
          "newValueIsDictionary": {
            "type": "boolean"
          },
          "oldValueIsDictionary": {
            "type": "boolean"
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Array of result objects"
          },
          "totalCount": {
            "type": "integer",
            "description": "Total number of results"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "pageSize": {
            "type": "integer",
            "description": "Number of items per page"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errorCode": {
            "type": "string",
            "description": "Error code identifier"
          },
          "field": {
            "type": "string",
            "description": "Field that caused the error"
          },
          "rejectedValue": {
            "type": "string",
            "description": "The rejected value"
          },
          "additionalInfo": {
            "type": "object",
            "description": "Additional error details"
          }
        }
      },
      "DuplicateErrorResponse": {
        "type": "object",
        "properties": {
          "errorCode": {
            "type": "string",
            "description": "Error code (e.g., duplicateValueFoundException)"
          },
          "objectName": {
            "type": "string"
          },
          "fieldName": {
            "type": "string"
          },
          "duplicateValues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lineNumber": {
                  "type": "integer"
                },
                "objectId": {
                  "type": "integer"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
