  "components": {
    "securitySchemes": {
      "appKey": {
        "type": "apiKey",
        "in": "header",
        "name": "APPKEY",
        "description": "Application key for API authentication"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "AUTH_FAILED_NO_DATA"
          },
          "message": {
            "type": "string",
            "example": "You have not provided APPKEY"
          },
          "data": {
            "type": "array",
            "items": {}
          }
        }
      },
      "SendSmsRequest": {
        "type": "object",
        "required": [
          "to",
          "message"
        ],
        "properties": {
          "to": {
            "type": "string",
            "description": "Recipient mobile number in international format"
          },
          "message": {
            "type": "string",
            "description": "SMS message content"
          },
          "from": {
            "type": "string",
            "description": "Sender ID or number"
          },
          "list_id": {
            "type": "integer",
            "description": "Contact list ID to send to"
          },
          "schedule": {
            "type": "string",
            "format": "date-time",
            "description": "Schedule the SMS for a future time"
          }
        }
      },
      "ContactInput": {
        "type": "object",
        "required": [
          "phone"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Contact ID (for updates)"
          },
          "phone": {
            "type": "string",
            "description": "Mobile number"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "list_id": {
            "type": "integer",
            "description": "Contact list to add the contact to"
          }
        }
      },
      "ContactListInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "List ID (for updates)"
          },
          "name": {
            "type": "string",
            "description": "Name of the contact list"
          }
        }
      }
    }
  },
  "security": [
    {
      "appKey": []
    }
  ]
}