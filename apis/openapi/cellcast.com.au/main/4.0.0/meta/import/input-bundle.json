{
  "openapi": "3.0.3",
  "info": {
    "title": "Cellcast SMS API",
    "description": "Cellcast optimises business communications with secure, simple SMS and MMS messaging for bulk and two-way communications.",
    "version": "4.0.0",
    "x-jentic-source-url": "https://cellcast.com.au/api/documentation/v4/"
  },
  "servers": [
    {
      "url": "https://cellcast.com.au/api/v4"
    }
  ],
  "paths": {
    "/sms/send": {
      "post": {
        "operationId": "sendSms",
        "summary": "Send an SMS message",
        "description": "Send an SMS message to one or more recipients.",
        "tags": [
          "SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendSmsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed - APPKEY not provided or invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sms/history": {
      "get": {
        "operationId": "getSmsHistory",
        "summary": "View SMS history",
        "description": "Retrieve the history of sent SMS messages.",
        "tags": [
          "SMS"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "date_from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date_to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SMS history retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
