  "components": {
    "schemas": {
      "IntegrationKey": {
        "type": "string",
        "description": "Your EBANX integration key (API key)"
      },
      "Hash": {
        "type": "string",
        "description": "EBANX unique payment hash identifier"
      },
      "Amount": {
        "type": "number",
        "format": "double",
        "description": "Monetary amount"
      },
      "Country": {
        "type": "string",
        "description": "Two-letter country code (e.g. BR, MX, CO)"
      },
      "CreditCard": {
        "type": "object",
        "description": "Credit card details",
        "properties": {
          "card_number": {
            "type": "string",
            "description": "Card number"
          },
          "card_name": {
            "type": "string",
            "description": "Cardholder name"
          },
          "card_due_date": {
            "type": "string",
            "description": "Card expiration date (MM/YYYY)"
          },
          "card_cvv": {
            "type": "string",
            "description": "Card CVV/CVC code"
          }
        }
      },
      "Payment": {
        "type": "object",
        "description": "Payment object for direct checkout",
        "properties": {
          "name": {
            "type": "string",
            "description": "Customer name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Customer email"
          },
          "document": {
            "type": "string",
            "description": "Customer document (CPF, CNPJ, etc.)"
          },
          "country": {
            "$ref": "#/components/schemas/Country"
          },
          "payment_type_code": {
            "type": "string",
            "description": "Payment method code"
          },
          "merchant_payment_code": {
            "type": "string",
            "description": "Unique merchant payment reference"
          },
          "currency_code": {
            "type": "string",
            "description": "Currency code (e.g. USD, BRL)"
          },
          "amount_total": {
            "$ref": "#/components/schemas/Amount"
          },
          "instalments": {
            "type": "integer",
            "description": "Number of installments"
          },
          "creditcard": {
            "$ref": "#/components/schemas/CreditCard"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          }
        }
      },
      "Address": {
        "type": "object",
        "description": "Customer address",
        "properties": {
          "address": {
            "type": "string",
            "description": "Street address"
          },
          "street_number": {
            "type": "string",
            "description": "Street number"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "state": {
            "type": "string",
            "description": "State code"
          },
          "zipcode": {
            "type": "string",
            "description": "Postal/ZIP code"
          },
          "country": {
            "$ref": "#/components/schemas/Country"
          }
        }
      },
      "BankInfo": {
        "type": "object",
        "description": "Bank account information",
        "properties": {
          "bank_code": {
            "type": "string",
            "description": "Bank code"
          },
          "bank_branch": {
            "type": "string",
            "description": "Bank branch number"
          },
          "bank_account": {
            "type": "string",
            "description": "Bank account number"
          },
          "account_type": {
            "type": "string",
            "description": "Account type (e.g. C for checking, S for savings)"
          },
          "bank_name": {
            "type": "string",
            "description": "Bank name"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "description": "Standard EBANX API response",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status (SUCCESS or ERROR)",
            "enum": [
              "SUCCESS",
              "ERROR"
            ]
          },
          "status_code": {
            "type": "string",
            "description": "Response status code"
          },
          "status_message": {
            "type": "string",
            "description": "Human-readable status message"
          }
        }
      }
    },
    "securitySchemes": {
      "IntegrationKey": {
        "type": "apiKey",
        "in": "header",
        "name": "integration_key",
        "description": "EBANX integration key passed in the request body for all endpoints"
      }
    }
  },
  "tags": [
    {
      "name": "FX",
      "description": "Foreign exchange operations"
    },
    {
      "name": "Tokenization",
