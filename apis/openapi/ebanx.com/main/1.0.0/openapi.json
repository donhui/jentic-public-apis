    "/ws/exchange": {
      "post": {
        "tags": [
          "FX"
        ],
        "summary": "Query exchange rate",
        "operationId": "queryExchangeRate",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "integration_key",
                  "currency_code",
                  "currency_base_code"
                ],
                "properties": {
                  "integration_key": {
                    "$ref": "#/components/schemas/IntegrationKey"
                  },
                  "currency_code": {
                    "type": "string",
                    "description": "Target currency code (e.g. BRL)"
                  },
                  "currency_base_code": {
                    "type": "string",
                    "description": "Base currency code (e.g. USD)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Exchange rate retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
