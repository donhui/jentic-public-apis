    },
    "/services/stats": {
      "get": {
        "operationId": "getServiceStats",
        "summary": "Get aggregated service statistics",
        "description": "Return aggregated service status statistics (ok, warning, critical, unknown counts).",
        "tags": ["Services"],
        "responses": {
          "200": {
            "description": "Service statistics",
