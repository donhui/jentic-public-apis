        }
      }
    },
    "/processinfo": {
      "get": {
        "operationId": "listProcessinfo",
        "summary": "Get process information for all backends",
        "description": "Return process information and status of all connected monitoring backends.",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Backend process information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
