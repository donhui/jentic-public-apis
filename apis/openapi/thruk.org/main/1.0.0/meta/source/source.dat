        }
      }
    },
    "/cmd": {
      "post": {
        "operationId": "sendCommand",
        "summary": "Send external commands",
        "description": "Send external commands to the monitoring backend.",
        "tags": ["Commands"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "cmd": {"type": "string", "description": "Command to execute"}
                },
                "required": ["cmd"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command result",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/CommandResult"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/hosts/stats": {
      "get": {
        "operationId": "getHostStats",
        "summary": "Get aggregated host statistics",
        "description": "Return aggregated host status statistics (up, down, unreachable counts).",
        "tags": ["Hosts"],
        "responses": {
          "200": {
            "description": "Host statistics",
            "content": {
              "application/json": {
                "schema": {"type": "object"}
