    "/commands": {
      "get": {
        "operationId": "listCommands",
        "summary": "List all commands",
        "description": "Return a list of all configured commands.",
        "tags": ["Commands"],
        "parameters": [
          {"$ref": "#/components/parameters/columns"},
          {"$ref": "#/components/parameters/sort"},
