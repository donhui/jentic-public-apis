        }
      }
    },
    "/checks/stats": {
      "get": {
        "operationId": "getCheckStats",
        "summary": "Get host and service check statistics",
        "description": "Return aggregated check execution statistics.",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Check statistics",
            "content": {
              "application/json": {
                "schema": {"type": "object"}
