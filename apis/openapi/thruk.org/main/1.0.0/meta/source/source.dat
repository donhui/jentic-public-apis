{
  "openapi": "3.0.3",
  "info": {
    "title": "Thruk REST API",
    "version": "1.0.0",
    "description": "Thruk REST API exposes monitoring data from Naemon, Nagios, Icinga, and Shinken monitoring systems. It provides access to hosts, services, hostgroups, servicegroups, contacts, commands, downtimes, comments, notifications, and more.",
    "x-jentic-source-url": "https://www.thruk.org/documentation/rest.html"
  },
  "servers": [
    {
      "url": "https://{server}/thruk/r/v1",
      "variables": {
        "server": {
          "default": "localhost",
          "description": "Thruk server hostname"
        }
      }
    }
  ],
  "paths": {
    "/hosts": {
      "get": {
        "operationId": "listHosts",
        "summary": "List all hosts",
        "description": "Return a list of all monitored hosts with their current status.",
        "tags": ["Hosts"],
        "parameters": [
          {"$ref": "#/components/parameters/columns"},
          {"$ref": "#/components/parameters/sort"},
          {"$ref": "#/components/parameters/limit"},
          {"$ref": "#/components/parameters/offset"},
          {"$ref": "#/components/parameters/q"}
        ],
        "responses": {
          "200": {
            "description": "List of hosts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Host"}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/hosts/{name}": {
      "get": {
        "operationId": "getHost",
        "summary": "Get a specific host",
        "description": "Return details of a single host by name.",
        "tags": ["Hosts"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Host name"
          }
        ],
        "responses": {
          "200": {
            "description": "Host details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Host"}
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
    "/hosts/{name}/cmd/schedule_host_downtime": {
      "post": {
        "operationId": "scheduleHostDowntime",
        "summary": "Schedule downtime for a host",
        "description": "Schedule a downtime for the specified host.",
        "tags": ["Hosts", "Commands"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Host name"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "comment": {"type": "string", "description": "Downtime comment"},
                  "start_time": {"type": "string", "description": "Start time (unix timestamp or date string)"},
                  "end_time": {"type": "string", "description": "End time (unix timestamp or date string)"},
                  "fixed": {"type": "integer", "description": "1 for fixed, 0 for flexible"},
                  "duration": {"type": "integer", "description": "Duration in seconds for flexible downtimes"}
                },
                "required": ["comment"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command executed successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/CommandResult"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/services": {
      "get": {
        "operationId": "listServices",
        "summary": "List all services",
        "description": "Return a list of all monitored services with their current status.",
        "tags": ["Services"],
        "parameters": [
          {"$ref": "#/components/parameters/columns"},
          {"$ref": "#/components/parameters/sort"},
          {"$ref": "#/components/parameters/limit"},
          {"$ref": "#/components/parameters/offset"},
          {"$ref": "#/components/parameters/q"}
        ],
        "responses": {
          "200": {
            "description": "List of services",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Service"}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/hosts/{hostName}/services/{description}": {
      "get": {
        "operationId": "getService",
        "summary": "Get a specific service",
        "description": "Return details of a single service for a host.",
        "tags": ["Services"],
        "parameters": [
          {
            "name": "hostName",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Host name"
          },
          {
            "name": "description",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Service description"
          }
        ],
        "responses": {
          "200": {
            "description": "Service details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Service"}
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
    "/hostgroups": {
      "get": {
        "operationId": "listHostgroups",
        "summary": "List all host groups",
        "description": "Return a list of all host groups.",
        "tags": ["Hostgroups"],
        "parameters": [
          {"$ref": "#/components/parameters/columns"},
          {"$ref": "#/components/parameters/sort"},
          {"$ref": "#/components/parameters/limit"},
          {"$ref": "#/components/parameters/offset"},
          {"$ref": "#/components/parameters/q"}
        ],
        "responses": {
          "200": {
            "description": "List of host groups",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Hostgroup"}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/servicegroups": {
      "get": {
        "operationId": "listServicegroups",
        "summary": "List all service groups",
        "description": "Return a list of all service groups.",
        "tags": ["Servicegroups"],
        "parameters": [
          {"$ref": "#/components/parameters/columns"},
          {"$ref": "#/components/parameters/sort"},
          {"$ref": "#/components/parameters/limit"},
          {"$ref": "#/components/parameters/offset"},
          {"$ref": "#/components/parameters/q"}
        ],
        "responses": {
          "200": {
            "description": "List of service groups",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Servicegroup"}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "List all contacts",
        "description": "Return a list of all contacts.",
        "tags": ["Contacts"],
        "parameters": [
          {"$ref": "#/components/parameters/columns"},
          {"$ref": "#/components/parameters/sort"},
          {"$ref": "#/components/parameters/limit"},
          {"$ref": "#/components/parameters/offset"},
          {"$ref": "#/components/parameters/q"}
        ],
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Contact"}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/downtimes": {
      "get": {
        "operationId": "listDowntimes",
        "summary": "List all downtimes",
        "description": "Return a list of all scheduled downtimes.",
        "tags": ["Downtimes"],
        "parameters": [
          {"$ref": "#/components/parameters/columns"},
          {"$ref": "#/components/parameters/sort"},
          {"$ref": "#/components/parameters/limit"},
          {"$ref": "#/components/parameters/offset"},
          {"$ref": "#/components/parameters/q"}
        ],
        "responses": {
          "200": {
            "description": "List of downtimes",
