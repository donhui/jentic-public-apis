    },
    "/hosts/{name}/services": {
      "get": {
        "operationId": "listHostServices",
        "summary": "List services for a specific host",
        "description": "Return all services monitored on the specified host.",
        "tags": ["Hosts", "Services"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Host name"
          },
          {"$ref": "#/components/parameters/columns"},
          {"$ref": "#/components/parameters/sort"},
