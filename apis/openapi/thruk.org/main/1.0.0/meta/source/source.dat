    "/hosts/{name}/outages": {
      "get": {
        "operationId": "listHostOutages",
        "summary": "List outages for a host",
        "description": "Return outage history for a specific host.",
        "tags": ["Hosts"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
