        }
      }
    }
  },
  "components": {
    "parameters": {
      "columns": {
        "name": "columns",
        "in": "query",
        "required": false,
        "schema": {"type": "string"},
        "description": "Comma-separated list of columns to return"
      },
      "sort": {
        "name": "sort",
        "in": "query",
        "required": false,
        "schema": {"type": "string"},
        "description": "Comma-separated list of columns to sort by. Prefix with - for descending."
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {"type": "integer"},
        "description": "Maximum number of results to return"
      },
      "offset": {
        "name": "offset",
        "in": "query",
        "required": false,
        "schema": {"type": "integer"},
        "description": "Number of results to skip"
      },
      "q": {
        "name": "q",
        "in": "query",
        "required": false,
        "schema": {"type": "string"},
        "description": "Complex filter query using Thruk query language"
      }
    },
    "schemas": {
      "Host": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "description": "Host name"},
          "state": {"type": "integer", "description": "Current host state (0=UP, 1=DOWN, 2=UNREACHABLE)"},
          "address": {"type": "string", "description": "Host IP address"},
          "alias": {"type": "string", "description": "Host alias"},
          "groups": {"type": "array", "items": {"type": "string"}, "description": "Host groups"},
          "plugin_output": {"type": "string", "description": "Plugin output"},
          "last_check": {"type": "number", "description": "Last check timestamp"},
          "next_check": {"type": "number", "description": "Next check timestamp"},
          "acknowledged": {"type": "integer", "description": "Whether host is acknowledged"},
          "scheduled_downtime_depth": {"type": "integer", "description": "Downtime depth"},
          "num_services": {"type": "integer"},
          "num_services_ok": {"type": "integer"},
          "num_services_warn": {"type": "integer"},
          "num_services_crit": {"type": "integer"},
          "num_services_unknown": {"type": "integer"},
          "perf_data": {"type": "string", "description": "Performance data"},
          "custom_variables": {"type": "object", "additionalProperties": {"type": "string"}}
        }
      },
      "Service": {
        "type": "object",
        "properties": {
          "host_name": {"type": "string"},
          "description": {"type": "string"},
          "state": {"type": "integer", "description": "Current state (0=OK, 1=WARNING, 2=CRITICAL, 3=UNKNOWN)"},
          "plugin_output": {"type": "string"},
          "last_check": {"type": "number"},
          "next_check": {"type": "number"},
          "acknowledged": {"type": "integer"},
          "scheduled_downtime_depth": {"type": "integer"},
          "perf_data": {"type": "string"}
        }
      },
      "Hostgroup": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "alias": {"type": "string"},
          "members": {"type": "array", "items": {"type": "string"}}
        }
      },
      "Servicegroup": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "alias": {"type": "string"},
          "members": {"type": "array", "items": {"type": "string"}}
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "alias": {"type": "string"},
          "email": {"type": "string"}
        }
      },
      "Downtime": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "host_name": {"type": "string"},
          "service_description": {"type": "string"},
          "author": {"type": "string"},
          "comment": {"type": "string"},
          "start_time": {"type": "number"},
          "end_time": {"type": "number"},
          "fixed": {"type": "integer"},
          "duration": {"type": "integer"}
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "host_name": {"type": "string"},
          "service_description": {"type": "string"},
          "author": {"type": "string"},
          "comment": {"type": "string"},
          "entry_time": {"type": "number"}
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "host_name": {"type": "string"},
          "service_description": {"type": "string"},
          "contact_name": {"type": "string"},
          "message": {"type": "string"},
          "start_time": {"type": "number"}
        }
      },
      "Command": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "line": {"type": "string"}
        }
      },
      "CommandResult": {
        "type": "object",
        "properties": {
          "message": {"type": "string"},
          "count": {"type": "integer"}
        }
      },
      "ApiKey": {
        "type": "object",
        "properties": {
          "hashed_key": {"type": "string"},
          "comment": {"type": "string"},
          "superuser": {"type": "boolean"},
          "created": {"type": "number"},
          "username": {"type": "string"}
        }
      },
      "Session": {
        "type": "object",
        "properties": {
          "username": {"type": "string"},
          "active": {"type": "number"},
          "address": {"type": "string"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {"type": "string"},
          "code": {"type": "integer"},
          "description": {"type": "string"}
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Thruk-Auth-Key",
        "description": "API key for authentication"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic HTTP authentication"
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/ErrorResponse"}
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/ErrorResponse"}
          }
        }
      },
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/ErrorResponse"}
          }
        }
      }
    }
  },
  "security": [
    {"apiKeyAuth": []},
    {"basicAuth": []}
  ]
}