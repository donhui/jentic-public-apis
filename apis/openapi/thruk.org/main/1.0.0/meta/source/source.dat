          {"$ref": "#/components/parameters/offset"},
          {"$ref": "#/components/parameters/q"}
        ],
        "responses": {
          "200": {
            "description": "List of services for the host",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Service"}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
    "/hosts/{name}/availability": {
      "get": {
        "operationId": "getHostAvailability",
        "summary": "Get host availability data",
        "description": "Return availability statistics for a specific host.",
        "tags": ["Hosts"],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Host name"
