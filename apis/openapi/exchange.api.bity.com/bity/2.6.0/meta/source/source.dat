      "PostalAddressStructured": {
        "properties": {
          "building_name": {
            "type": "string"
          },
          "building_number": {
            "type": "string"
          },
          "country": {
            "$ref": "#/components/schemas/CountryCode"
          },
          "country_subdivision": {
            "description": "Identifies a subdivision of the country such as a state or region.\n",
            "type": "string"
          },
          "department": {
            "description": "Identifies a part of large organization or large building.\n",
            "type": "string"
          },
          "district_name": {
            "description": "Identifies a subdivision of the country subdivision.\n",
            "type": "string"
          },
          "floor": {
            "type": "string"
          },
          "post_box": {
            "type": "string"
          },
          "post_code": {
            "type": "string"
          },
          "room": {
            "type": "string"
          },
          "street_name": {
            "type": "string"
          },
          "subdepartment": {
            "description": "Identifies a subdivision within a department of a large organization or large building.\n",
            "type": "string"
          },
          "town_location_name": {
            "description": "Identifies a location within a town.\n",
            "type": "string"
          },
          "town_name": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "PriceBreakdown": {
        "properties": {
          "customer_trading_fee": {
            "description": "The customer trading fee applied to this order.",
