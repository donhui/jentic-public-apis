      "PlaceOrderRequestOutputCryptoAddress": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PlaceOrderRequestOutputCommon"
          },
          {
            "description": "Output object for an order where the result of the exchange is sent\nto a crypto-address.\n",
