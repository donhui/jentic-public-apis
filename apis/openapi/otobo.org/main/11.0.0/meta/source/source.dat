{
  "openapi": "3.0.3",
  "info": {
    "title": "OTOBO GenericInterface REST API",
    "description": "REST API for OTOBO (Open Ticket Based on OTRS) ticketing system via the GenericInterface. Provides operations for session management and ticket CRUD operations. The base path includes the web service name configured in the OTOBO admin interface.",
    "version": "11.0.0",
    "contact": {
      "name": "Rother OSS GmbH",
      "url": "https://otobo.org"
    },
    "license": {
      "name": "GNU General Public License v3.0",
      "url": "https://www.gnu.org/licenses/gpl-3.0.html"
    },
    "x-jentic-source-url": "https://doc.otobo.org/manual/developer/11.0/en/content/how-to-extend-otobo/otrs-module-layers/web-service.html"
  },
  "servers": [
    {
      "url": "https://{hostname}/otobo/nph-genericinterface.pl/Webservice/{webserviceName}",
      "description": "OTOBO GenericInterface REST endpoint",
      "variables": {
        "hostname": {
          "default": "localhost",
          "description": "OTOBO server hostname"
        },
        "webserviceName": {
          "default": "GenericTicketConnectorREST",
          "description": "Name of the configured web service in OTOBO admin"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Session",
      "description": "Session management operations for authentication"
    },
    {
      "name": "Ticket",
      "description": "Ticket CRUD and search operations"
    }
  ],
  "paths": {
    "/Session": {
      "post": {
        "operationId": "SessionCreate",
        "summary": "Create a new session",
        "description": "Authenticates a user (agent or customer) and returns a session ID that can be used for subsequent API calls.",
        "tags": ["Session"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionCreateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "Error": {
                    "ErrorCode": "SessionCreate.MissingParameter",
                    "ErrorMessage": "SessionCreate: Got no Password!"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "Error": {
                    "ErrorCode": "SessionCreate.AuthFail",
                    "ErrorMessage": "SessionCreate: User could not be authenticated!"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/Session/{SessionID}": {
      "get": {
        "operationId": "SessionGet",
        "summary": "Get session data",
        "description": "Retrieves session information for a given session ID. Sensitive fields like UserPw and UserChallengeToken are automatically filtered out.",
        "tags": ["Session"],
        "parameters": [
          {
            "name": "SessionID",
            "in": "path",
            "required": true,
            "description": "The session ID to retrieve information for",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionGetResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "Error": {
                    "ErrorCode": "SessionGet.MissingParameter",
                    "ErrorMessage": "SessionGet: SessionID is missing!"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Session invalid or expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "Error": {
                    "ErrorCode": "SessionGet.SessionInvalid",
                    "ErrorMessage": "SessionGet: SessionID is invalid!"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/Ticket": {
      "post": {
        "operationId": "TicketCreate",
        "summary": "Create a new ticket",
        "description": "Creates a new ticket with an initial article. Supports dynamic fields and attachments.",
        "tags": ["Ticket"],
        "security": [
          { "basicAuth": [] },
          { "sessionId": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TicketCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketCreateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "Error": {
                    "ErrorCode": "TicketCreate.AuthFail",
                    "ErrorMessage": "TicketCreate: Authorization failing!"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "TicketSearch",
        "summary": "Search for tickets",
        "description": "Searches for tickets matching the specified criteria. Returns an array of matching ticket IDs. Default sort is by Age descending with a limit of 500 results.",
        "tags": ["Ticket"],
        "security": [
          { "basicAuth": [] },
          { "sessionId": [] }
        ],
        "parameters": [
          {
            "name": "UserLogin",
            "in": "query",
            "description": "Agent username for authentication",
            "schema": { "type": "string" }
          },
          {
            "name": "Password",
            "in": "query",
            "description": "Password for authentication",
            "schema": { "type": "string" }
          },
          {
            "name": "SessionID",
            "in": "query",
            "description": "Session ID for authentication (alternative to UserLogin/Password)",
            "schema": { "type": "string" }
          },
          {
            "name": "TicketNumber",
            "in": "query",
            "description": "Filter by ticket number (supports wildcards)",
            "schema": { "type": "string" }
          },
          {
            "name": "Title",
            "in": "query",
            "description": "Filter by ticket title (supports wildcards)",
            "schema": { "type": "string" }
          },
          {
            "name": "Queues",
            "in": "query",
            "description": "Filter by queue names",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "QueueIDs",
            "in": "query",
            "description": "Filter by queue IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "Types",
            "in": "query",
            "description": "Filter by ticket type names",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "TypeIDs",
            "in": "query",
            "description": "Filter by ticket type IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "States",
            "in": "query",
            "description": "Filter by state names",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "StateIDs",
            "in": "query",
            "description": "Filter by state IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "StateType",
            "in": "query",
            "description": "Filter by state type (e.g., Open, Closed)",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "Priorities",
            "in": "query",
            "description": "Filter by priority names",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "PriorityIDs",
            "in": "query",
            "description": "Filter by priority IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "Services",
            "in": "query",
            "description": "Filter by service names",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "ServiceIDs",
            "in": "query",
            "description": "Filter by service IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "SLAs",
            "in": "query",
            "description": "Filter by SLA names",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "SLAIDs",
            "in": "query",
            "description": "Filter by SLA IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "Locks",
            "in": "query",
            "description": "Filter by lock state names",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "LockIDs",
            "in": "query",
            "description": "Filter by lock state IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "OwnerIDs",
            "in": "query",
            "description": "Filter by owner user IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "ResponsibleIDs",
            "in": "query",
            "description": "Filter by responsible user IDs",
            "schema": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          {
            "name": "CustomerID",
            "in": "query",
            "description": "Filter by customer ID",
            "schema": { "type": "string" }
          },
          {
            "name": "CustomerUserLogin",
            "in": "query",
            "description": "Filter by customer user login",
            "schema": { "type": "string" }
          },
          {
            "name": "TicketCreateTimeNewerDate",
            "in": "query",
            "description": "Tickets created after this date (YYYY-MM-DD HH:MM:SS)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "TicketCreateTimeOlderDate",
            "in": "query",
            "description": "Tickets created before this date (YYYY-MM-DD HH:MM:SS)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "TicketChangeTimeNewerDate",
            "in": "query",
            "description": "Tickets changed after this date",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "TicketChangeTimeOlderDate",
            "in": "query",
            "description": "Tickets changed before this date",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "TicketCloseTimeNewerDate",
            "in": "query",
            "description": "Tickets closed after this date",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "TicketCloseTimeOlderDate",
            "in": "query",
            "description": "Tickets closed before this date",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "SortBy",
            "in": "query",
            "description": "Field to sort results by",
            "schema": {
              "type": "string",
              "enum": ["Owner", "Responsible", "CustomerID", "State", "TicketNumber", "Queue", "Priority", "Age", "Type", "Lock", "Changed", "Title", "Service", "SLA", "PendingTime", "EscalationTime", "EscalationUpdateTime", "EscalationResponseTime", "EscalationSolutionTime"],
              "default": "Age"
            }
          },
          {
            "name": "OrderBy",
            "in": "query",
            "description": "Sort order",
            "schema": {
              "type": "string",
              "enum": ["Down", "Up"],
              "default": "Down"
            }
          },
          {
            "name": "Limit",
            "in": "query",
            "description": "Maximum number of results to return",
            "schema": {
              "type": "integer",
              "default": 500
            }
          },
          {
            "name": "FullTextIndex",
            "in": "query",
            "description": "Full-text search term",
            "schema": { "type": "string" }
          },
          {
            "name": "ContentSearch",
            "in": "query",
            "description": "Content search logic",
            "schema": {
              "type": "string",
              "enum": ["AND", "OR"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/Ticket/{TicketID}": {
      "get": {
        "operationId": "TicketGet",
        "summary": "Get ticket details",
        "description": "Retrieves detailed information about one or more tickets, optionally including articles, dynamic fields, and attachments.",
        "tags": ["Ticket"],
        "security": [
          { "basicAuth": [] },
          { "sessionId": [] }
        ],
        "parameters": [
          {
            "name": "TicketID",
            "in": "path",
            "required": true,
            "description": "Ticket ID to retrieve. Use comma-separated values for multiple tickets.",
            "schema": { "type": "string" }
          },
          {
            "name": "UserLogin",
            "in": "query",
            "description": "Agent username for authentication",
            "schema": { "type": "string" }
          },
          {
            "name": "Password",
            "in": "query",
            "description": "Password for authentication",
            "schema": { "type": "string" }
          },
          {
            "name": "SessionID",
            "in": "query",
            "description": "Session ID for authentication",
            "schema": { "type": "string" }
          },
          {
            "name": "DynamicFields",
            "in": "query",
            "description": "Include dynamic fields in the response (0 or 1)",
            "schema": { "type": "integer", "enum": [0, 1], "default": 0 }
          },
          {
            "name": "Extended",
            "in": "query",
            "description": "Return extended ticket attributes (0 or 1)",
            "schema": { "type": "integer", "enum": [0, 1], "default": 0 }
          },
          {
            "name": "AllArticles",
            "in": "query",
            "description": "Include all articles (0 or 1)",
            "schema": { "type": "integer", "enum": [0, 1], "default": 0 }
          },
          {
            "name": "ArticleSenderType",
            "in": "query",
            "description": "Filter articles by sender type",
            "schema": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          {
            "name": "ArticleOrder",
            "in": "query",
            "description": "Article sort order",
            "schema": {
              "type": "string",
              "enum": ["ASC", "DESC"],
              "default": "ASC"
            }
          },
          {
            "name": "ArticleLimit",
            "in": "query",
            "description": "Maximum number of articles to return per ticket",
            "schema": { "type": "integer" }
          },
          {
            "name": "Attachments",
            "in": "query",
            "description": "Include article attachments (0 or 1)",
            "schema": { "type": "integer", "enum": [0, 1], "default": 0 }
          },
          {
            "name": "GetAttachmentContents",
            "in": "query",
            "description": "Return attachment data base64-encoded (0 or 1)",
            "schema": { "type": "integer", "enum": [0, 1], "default": 1 }
          },
          {
            "name": "HTMLBodyAsAttachment",
            "in": "query",
            "description": "Include HTML body as attachment (0 or 1)",
            "schema": { "type": "integer", "enum": [0, 1] }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticket data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketGetResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "Error": {
                    "ErrorCode": "TicketGet.AccessDenied",
                    "ErrorMessage": "TicketGet: User does not have access to the ticket!"
                  }
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "TicketUpdate",
        "summary": "Update an existing ticket",
        "description": "Updates ticket properties, optionally creates a new article, sets dynamic fields, and adds attachments. At least one of Ticket, Article, DynamicField, or Attachment must be provided.",
        "tags": ["Ticket"],
        "security": [
          { "basicAuth": [] },
          { "sessionId": [] }
        ],
        "parameters": [
          {
            "name": "TicketID",
            "in": "path",
            "required": true,
            "description": "ID of the ticket to update",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TicketUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketUpdateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/TicketHistory/{TicketID}": {
      "get": {
        "operationId": "TicketHistoryGet",
        "summary": "Get ticket history",
        "description": "Retrieves the complete history of changes and events for one or more tickets. Requires agent authentication (not available to customer users).",
        "tags": ["Ticket"],
        "security": [
          { "basicAuth": [] },
          { "sessionId": [] }
        ],
        "parameters": [
          {
            "name": "TicketID",
            "in": "path",
            "required": true,
            "description": "Ticket ID to retrieve history for. Use comma-separated values for multiple tickets.",
            "schema": { "type": "string" }
          },
          {
            "name": "UserLogin",
            "in": "query",
            "description": "Agent username for authentication",
            "schema": { "type": "string" }
          },
          {
            "name": "Password",
            "in": "query",
            "description": "Password for authentication",
            "schema": { "type": "string" }
          },
          {
            "name": "SessionID",
            "in": "query",
            "description": "Session ID for authentication",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticket history retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketHistoryGetResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication using OTOBO agent or customer user credentials (UserLogin/Password or CustomerUserLogin/Password passed in request body or query parameters)"
      },
      "sessionId": {
        "type": "apiKey",
        "in": "query",
        "name": "SessionID",
        "description": "Session-based authentication. Obtain a SessionID via the SessionCreate operation."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "Error": {
            "type": "object",
            "properties": {
              "ErrorCode": {
                "type": "string",
                "description": "Machine-readable error code (e.g., TicketCreate.AuthFail)"
              },
              "ErrorMessage": {
                "type": "string",
                "description": "Human-readable error description"
              }
            },
            "required": ["ErrorCode", "ErrorMessage"]
          }
        }
      },
      "AuthCredentials": {
        "type": "object",
        "description": "Authentication credentials. Provide either UserLogin+Password, CustomerUserLogin+Password, or SessionID.",
        "properties": {
          "UserLogin": {
            "type": "string",
            "description": "Agent user login name"
          },
          "CustomerUserLogin": {
            "type": "string",
            "description": "Customer user login name"
          },
          "Password": {
            "type": "string",
            "description": "Password for UserLogin or CustomerUserLogin"
          },
          "SessionID": {
            "type": "string",
            "description": "Valid session ID from SessionCreate"
          }
        }
      },
      "DynamicFieldValue": {
        "type": "object",
        "description": "A dynamic field name-value pair",
        "properties": {
          "Name": {
            "type": "string",
            "description": "Dynamic field name"
          },
          "Value": {
            "description": "Dynamic field value (type depends on field configuration)",
            "oneOf": [
              { "type": "string" },
              { "type": "integer" },
              { "type": "number" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "required": ["Name", "Value"]
      },
      "Attachment": {
        "type": "object",
        "description": "File attachment",
        "properties": {
          "Content": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded file content"
          },
          "ContentType": {
            "type": "string",
            "description": "MIME type of the attachment (e.g., text/plain, application/pdf)"
          },
          "Filename": {
            "type": "string",
            "description": "Original filename"
          }
        },
        "required": ["Content", "ContentType", "Filename"]
      },
      "PendingTime": {
        "type": "object",
        "description": "Pending time specification. Provide either a specific date/time or a Diff in minutes.",
        "properties": {
          "Year": { "type": "integer" },
          "Month": { "type": "integer" },
          "Day": { "type": "integer" },
          "Hour": { "type": "integer" },
          "Minute": { "type": "integer" },
          "Diff": {
            "type": "integer",
            "description": "Time difference in minutes from now"
          }
        }
      },
      "Article": {
        "type": "object",
        "description": "Article to create with a ticket",
        "properties": {
          "CommunicationChannel": {
            "type": "string",
            "description": "Communication channel name (e.g., Email, Internal, Phone)"
          },
          "CommunicationChannelID": {
            "type": "integer",
            "description": "Communication channel ID"
          },
          "SenderType": {
            "type": "string",
            "description": "Sender type name (e.g., agent, system, customer)"
          },
          "SenderTypeID": {
            "type": "integer",
            "description": "Sender type ID"
          },
          "IsVisibleForCustomer": {
            "type": "integer",
            "description": "Whether the article is visible to customers (0 or 1)",
            "enum": [0, 1]
          },
          "From": {
            "type": "string",
            "description": "Sender email address or name"
          },
          "Subject": {
            "type": "string",
            "description": "Article subject"
          },
          "Body": {
            "type": "string",
            "description": "Article body content"
          },
          "ContentType": {
            "type": "string",
            "description": "Full MIME content type (e.g., text/plain; charset=utf-8). Alternative to MimeType+Charset."
          },
          "MimeType": {
            "type": "string",
            "description": "MIME type (e.g., text/plain). Use with Charset."
          },
          "Charset": {
            "type": "string",
            "description": "Character encoding (e.g., utf-8). Use with MimeType."
          },
          "AutoResponseType": {
            "type": "string",
            "description": "Auto-response type classification"
          },
          "TimeUnit": {
            "type": "number",
            "description": "Time units spent on this article"
          },
          "NoAgentNotify": {
            "type": "integer",
            "description": "Suppress agent notifications (0 or 1)",
            "enum": [0, 1]
          },
          "ForceNotificationToUserID": {
            "type": "array",
            "description": "User IDs to force-send notifications to",
            "items": { "type": "integer" }
          },
          "ExcludeNotificationToUserID": {
            "type": "array",
            "description": "User IDs to exclude from notifications",
            "items": { "type": "integer" }
          },
          "ExcludeMuteNotificationToUserID": {
            "type": "array",
            "description": "User IDs to exclude from mute notifications",
            "items": { "type": "integer" }
          }
        },
        "required": ["Subject", "Body"]
      },
      "TicketData": {
        "type": "object",
        "description": "Core ticket properties",
        "properties": {
          "Title": {
            "type": "string",
            "description": "Ticket title/subject"
          },
          "Queue": {
            "type": "string",
            "description": "Queue name"
          },
          "QueueID": {
            "type": "integer",
            "description": "Queue ID"
          },
          "Lock": {
            "type": "string",
            "description": "Lock state name (lock, unlock)"
          },
          "LockID": {
            "type": "integer",
            "description": "Lock state ID"
          },
          "Type": {
            "type": "string",
            "description": "Ticket type name"
          },
          "TypeID": {
            "type": "integer",
            "description": "Ticket type ID"
          },
          "Service": {
            "type": "string",
            "description": "Service name"
          },
          "ServiceID": {
            "type": "integer",
            "description": "Service ID"
          },
          "SLA": {
            "type": "string",
            "description": "SLA name"
          },
          "SLAID": {
            "type": "integer",
            "description": "SLA ID"
          },
          "State": {
            "type": "string",
            "description": "Ticket state name"
          },
          "StateID": {
            "type": "integer",
            "description": "Ticket state ID"
          },
          "Priority": {
            "type": "string",
            "description": "Priority name"
          },
          "PriorityID": {
            "type": "integer",
            "description": "Priority ID"
          },
          "Owner": {
            "type": "string",
            "description": "Owner user login"
          },
          "OwnerID": {
            "type": "integer",
            "description": "Owner user ID"
          },
          "Responsible": {
            "type": "string",
            "description": "Responsible user login"
          },
          "ResponsibleID": {
            "type": "integer",
            "description": "Responsible user ID"
          },
          "CustomerUser": {
            "type": "string",
            "description": "Customer user login"
          },
          "CustomerID": {
            "type": "string",
            "description": "Customer company ID"
          },
          "PendingTime": {
            "$ref": "#/components/schemas/PendingTime"
          }
        }
      },
      "TicketResponse": {
        "type": "object",
        "description": "Full ticket data as returned by TicketGet",
        "properties": {
          "TicketID": { "type": "integer" },
          "TicketNumber": { "type": "string" },
          "Title": { "type": "string" },
          "Age": { "type": "integer", "description": "Ticket age in seconds" },
          "Created": { "type": "string", "format": "date-time" },
          "Changed": { "type": "string", "format": "date-time" },
          "Queue": { "type": "string" },
          "QueueID": { "type": "integer" },
          "State": { "type": "string" },
          "StateID": { "type": "integer" },
          "StateType": { "type": "string" },
          "Priority": { "type": "string" },
          "PriorityID": { "type": "integer" },
          "Lock": { "type": "string" },
          "LockID": { "type": "integer" },
          "Type": { "type": "string" },
          "TypeID": { "type": "integer" },
          "Service": { "type": "string" },
          "ServiceID": { "type": "integer" },
          "SLA": { "type": "string" },
          "SLAID": { "type": "integer" },
          "Owner": { "type": "string" },
          "OwnerID": { "type": "integer" },
          "Responsible": { "type": "string" },
          "ResponsibleID": { "type": "integer" },
          "CustomerID": { "type": "string" },
          "CustomerUserID": { "type": "string" },
          "TimeUnit": { "type": "number" },
          "EscalationTime": { "type": "integer", "description": "Escalation time in seconds" },
          "EscalationUpdateTime": { "type": "integer" },
          "EscalationResponseTime": { "type": "integer" },
          "EscalationSolutionTime": { "type": "integer" },
          "EscalationDestinationDate": { "type": "string", "format": "date-time" },
          "EscalationDestinationIn": { "type": "string" },
          "DynamicField": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DynamicFieldValue" }
          },
          "Article": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ArticleResponse" }
          }
        }
      },
      "ArticleResponse": {
        "type": "object",
        "description": "Article data as returned by TicketGet",
        "properties": {
          "ArticleID": { "type": "integer" },
          "ArticleNumber": { "type": "integer" },
          "SenderType": { "type": "string" },
          "SenderTypeID": { "type": "integer" },
          "CommunicationChannel": { "type": "string" },
          "CommunicationChannelID": { "type": "integer" },
          "IsVisibleForCustomer": { "type": "integer" },
          "From": { "type": "string" },
          "To": { "type": "string" },
          "Cc": { "type": "string" },
          "Subject": { "type": "string" },
          "Body": { "type": "string" },
          "ContentType": { "type": "string" },
          "MimeType": { "type": "string" },
          "Charset": { "type": "string" },
          "CreateTime": { "type": "string", "format": "date-time" },
          "ChangeTime": { "type": "string", "format": "date-time" },
          "Attachment": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AttachmentResponse" }
          },
          "DynamicField": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DynamicFieldValue" }
          }
        }
      },
      "AttachmentResponse": {
        "type": "object",
        "description": "Attachment data as returned by TicketGet",
        "properties": {
          "Content": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded file content (when GetAttachmentContents=1)"
          },
          "ContentAlternative": { "type": "string" },
          "ContentID": { "type": "string" },
          "ContentType": { "type": "string" },
          "Disposition": { "type": "string" },
          "Filename": { "type": "string" },
          "FilesizeRaw": { "type": "integer", "description": "File size in bytes" }
        }
      },
      "HistoryEntry": {
        "type": "object",
        "description": "A single ticket history entry",
        "properties": {
          "TicketID": { "type": "integer" },
          "ArticleID": { "type": "integer" },
          "Name": { "type": "string", "description": "History entry description" },
          "CreateBy": { "type": "integer", "description": "User ID who made the change" },
          "CreateTime": { "type": "string", "format": "date-time" },
          "HistoryType": { "type": "string", "description": "Type of history event" },
          "HistoryTypeID": { "type": "integer" },
          "QueueID": { "type": "integer" },
          "OwnerID": { "type": "integer" },
          "PriorityID": { "type": "integer" },
          "StateID": { "type": "integer" },
          "TypeID": { "type": "integer" }
        }
      },
      "SessionCreateRequest": {
        "type": "object",
        "properties": {
          "UserLogin": {
            "type": "string",
            "description": "Agent user login name"
          },
          "CustomerUserLogin": {
            "type": "string",
            "description": "Customer user login name (alternative to UserLogin)"
          },
          "Password": {
            "type": "string",
            "description": "Password for the specified user"
          }
        },
        "required": ["Password"]
      },
      "SessionCreateResponse": {
        "type": "object",
        "properties": {
          "SessionID": {
            "type": "string",
            "description": "The created session ID"
          }
        }
      },
      "SessionGetResponse": {
        "type": "object",
        "properties": {
          "SessionData": {
            "type": "array",
            "description": "Array of session data key-value pairs",
            "items": {
              "type": "object",
              "properties": {
                "Key": { "type": "string" },
                "Value": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "integer" },
                    { "type": "boolean" }
                  ]
                },
                "Serialized": {
                  "type": "integer",
                  "description": "1 if the value was JSON-serialized from a complex structure"
                }
              }
            }
          }
        }
      },
      "TicketCreateRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/AuthCredentials" },
          {
            "type": "object",
            "properties": {
              "Ticket": {
                "allOf": [
                  { "$ref": "#/components/schemas/TicketData" },
                  {
                    "type": "object",
                    "required": ["Title", "CustomerUser"]
                  }
                ]
              },
              "Article": {
                "$ref": "#/components/schemas/Article"
              },
              "DynamicField": {
                "oneOf": [
                  { "$ref": "#/components/schemas/DynamicFieldValue" },
                  {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/DynamicFieldValue" }
                  }
                ]
              },
              "Attachment": {
                "oneOf": [
                  { "$ref": "#/components/schemas/Attachment" },
                  {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Attachment" }
                  }
                ]
              }
            },
            "required": ["Ticket", "Article"]
          }
        ]
      },
      "TicketCreateResponse": {
        "type": "object",
        "properties": {
          "TicketID": {
            "type": "integer",
            "description": "ID of the created ticket"
          },
          "TicketNumber": {
            "type": "string",
            "description": "Human-readable ticket number"
          },
          "ArticleID": {
            "type": "integer",
            "description": "ID of the created article"
          }
        }
      },
      "TicketGetResponse": {
        "type": "object",
        "properties": {
          "Ticket": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TicketResponse" }
          }
        }
      },
      "TicketSearchResponse": {
        "type": "object",
        "properties": {
          "TicketID": {
            "type": "array",
            "description": "Array of matching ticket IDs",
            "items": { "type": "integer" }
          }
        }
      },
      "TicketUpdateRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/AuthCredentials" },
          {
            "type": "object",
            "properties": {
              "TicketID": {
                "type": "integer",
                "description": "ID of the ticket to update (alternative to path parameter)"
              },
              "TicketNumber": {
                "type": "string",
                "description": "Ticket number to update (alternative to TicketID)"
              },
              "Ticket": {
                "$ref": "#/components/schemas/TicketData"
              },
              "Article": {
                "$ref": "#/components/schemas/Article"
              },
              "DynamicField": {
                "oneOf": [
                  { "$ref": "#/components/schemas/DynamicFieldValue" },
                  {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/DynamicFieldValue" }
                  }
                ]
              },
              "Attachment": {
                "oneOf": [
                  { "$ref": "#/components/schemas/Attachment" },
                  {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Attachment" }
                  }
                ]
              }
            }
          }
        ]
      },
      "TicketUpdateResponse": {
        "type": "object",
        "properties": {
          "TicketID": {
            "type": "integer",
            "description": "ID of the updated ticket"
          },
          "TicketNumber": {
            "type": "string",
            "description": "Updated ticket number"
          },
          "ArticleID": {
            "type": "integer",
            "description": "ID of the created article (if an article was added)"
          }
        }
      },
      "TicketHistoryGetResponse": {
        "type": "object",
        "properties": {
          "TicketHistory": {
            "type": "array",
            "description": "Array of ticket history objects",
            "items": {
              "type": "object",
              "properties": {
                "TicketID": { "type": "integer" },
                "History": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/HistoryEntry" }
                }
              }
            }
          }
        }
      }
    }
  }
}