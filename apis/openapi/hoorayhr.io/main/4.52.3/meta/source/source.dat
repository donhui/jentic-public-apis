              "type": "string",
              "format": "date",
              "example": "2025-05-31"
            },
            "description": "End date of the report. Format: YYYY-MM-DD. The end date cannot be more than 31 days after the start date",
            "required": true,
            "in": "query"
          },
          {
            "name": "includeInactiveEmployment",
            "schema": {
              "type": "boolean"
            },
            "description": "Whether to include users without an active employment in the provided date range",
