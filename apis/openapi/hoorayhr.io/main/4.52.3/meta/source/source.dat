                }
              }
            }
          },
          "401": {
            "description": "not authenticated"
          },
          "500": {
            "description": "general error"
          }
        },
        "description": "**NOTE:** The response for this endpoint is cached for 12 hours per API token and query parameters to avoid heavy load on our API. Updates will not be reflected immediately.",
        "summary": "Find attendance report",
        "tags": [
          "attendance-report"
        ],
        "security": [
          {
            "access_token": []
          }
        ],
        "operationId": "findAttendanceReport"
      }
    },
