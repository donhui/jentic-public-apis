    {
      "name": "oauth-token",
      "description": "OAuth2 token endpoint. Used to exchange an authorization code for an access token that provides access to the HoorayHR API. The request follows the OAuth2 spec."
    },
    {
      "name": "teams-information",
      "description": "A service to get information about teams, their members, and their leaders for the company or user. OAuth2 scopes: \"team_information\""
