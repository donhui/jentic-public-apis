{
  "openapi": "3.0.3",
  "info": {
    "description": "Tjeneste for uthenting av hendelser for Arbeidsforhold fra A-ordningen API.",
    "version": "1.0.1",
    "title": "Arbeidsforhold hendelser API",
    "termsOfService": "https://www.skatteetaten.no/deling/bruksvilkar-for-delingstjenester",
    "contact": {
      "name": "Brukerst\u00f8tte",
      "url": "https://www.skatteetaten.no/deling/kontakt/"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/skatteetaten/arbeidsforhold-hendelser-api/1.0.1/swagger.json"
  },
  "externalDocs": {
    "description": "Dokumentasjon p\u00e5 Skatteetatens GitHub",
    "url": "https://skatteetaten.github.io/api-dokumentasjon/api/hendelser"
  },
  "servers": [
    {
      "url": "https://arbeidsforholdhendelser.api.skatteetaten-test.no/v1",
      "description": "Ekstern test"
    },
    {
      "url": "https://arbeidsforholdhendelser.api.skatteetaten.no/v1",
      "description": "Produksjon"
    }
  ],
  "security": [
    {
      "maskinporten": [
        "skatteetaten:arbeidsforhold"
      ]
    }
  ],
  "components": {
    "securitySchemes": {
      "maskinporten": {
        "type": "http",
        "description": "Maskinporten benyttes for autentisering",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Feil": {
        "description": "Feilstruktur for alle feilmeldinger.",
        "type": "object",
        "properties": {
          "kode": {
            "type": "string",
            "description": "Feilkode, for maskinell h\u00e5ndtering",
            "example": "AFO-0xx"
          },
          "melding": {
            "type": "string",
            "description": "Beskrivelse av feilen som har oppst\u00e5tt",
            "example": "Fant ikke gitt personidentifikator"
          },
          "korrelasjonsid": {
            "type": "string",
            "description": "Korrelasjonsid",
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        }
      },
      "Hendelser": {
        "type": "object",
        "description": "",
        "properties": {
          "hendelser": {
            "type": "array",
            "description": "",
            "items": {
              "$ref": "#/components/schemas/HendelseArbeidsforhold"
            }
          }
        }
      },
      "HendelseArbeidsforhold": {
        "type": "object",
        "description": "",
        "properties": {
          "sekvensnummer": {
            "description": "",
            "$ref": "#/components/schemas/Heltall"
          },
          "aggregatId": {
            "description": "",
            "$ref": "#/components/schemas/Heltall"
          },
          "inntektsmottakerIdentifikator": {
            "description": "",
            "$ref": "#/components/schemas/NorskIdentifikator"
          },
          "underenhetsIdentifikator": {
            "description": "",
            "$ref": "#/components/schemas/NorskIdentifikator"
          },
          "opplysningspliktigIdentifikator": {
            "description": "",
            "$ref": "#/components/schemas/NorskIdentifikator"
          },
          "periode": {
            "description": "",
            "$ref": "#/components/schemas/AarOgMaaned"
          },
          "ajourholdstidspunkt": {
            "description": "",
            "$ref": "#/components/schemas/DatoTid"
          },
          "type": {
            "description": "",
            "$ref": "#/components/schemas/Tekst"
          },
          "opprettet": {
            "description": "",
            "$ref": "#/components/schemas/DatoKlokkeslett"
          }
        }
      },
      "Start": {
        "type": "object",
        "description": "",
        "properties": {
          "sekvensnummer": {
            "description": "",
            "$ref": "#/components/schemas/Heltall"
          }
        }
      },
      "Heltall": {
        "type": "integer",
        "description": "hele tall, dvs. hele tall i mengden {..., -2, -1, 0, 1, 2, ...} (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b52af0-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "int64"
      },
      "NorskIdentifikator": {
        "type": "string",
        "description": "(<a href='https://data.skatteetaten.no/begreper/dcfb4778-e484-11e6-9cb3-005056821322'>Begrepsreferanse</a>)"
      },
      "AarOgMaaned": {
        "type": "string",
        "description": "\u00e5rstall og m\u00e5ned angitt i nummer (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b2e149-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "pattern": "^(19|20)\\d\\d-(0[1-9]|1[012])$"
      },
      "DatoTid": {
        "type": "string",
        "description": "",
        "format": "date-time"
      },
      "Tekst": {
        "type": "string",
        "description": ""
      },
      "DatoKlokkeslett": {
        "type": "string",
        "description": "en kombinasjon av typene Dato og Klokkeslett. Kodes som en tekststreng etter datoformatering spesifisert i ISO 8601 (ISO 8601:2004 Data elements and interchange formats -- Information interchange -- Representation of dates and times). (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b52aee-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "date-time"
      }
    }
  },
  "paths": {
    "/hendelser": {
      "get": {
        "summary": "Hent hendelser for Arbeidsforhold",
        "description": "Hent hendelser for Arbeidsforhold",
        "operationId": "HentHendelserArbeidsforhold",
        "tags": [
          "hendelser"
        ],
        "parameters": [
          {
            "name": "fraSekvensnummer",
            "in": "query",
            "description": "Fra og med hvilket sekvensnummer skal sp\u00f8rres etter. M\u00e5 v\u00e6re st\u00f8rre enn 0.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "antall",
            "in": "query",
            "description": "Maks antall \u00f8nskede hendelser i responsen. M\u00e5 v\u00e6re st\u00f8rre enn 0.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske foresp\u00f8rselen. M\u00e5 v\u00e6re p\u00e5 UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Hendelser"
                }
              }
            }
          },
          "default": {
            "description": "Diverse feilmeldinger, se egen dokumentasjon",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    },
    "/hendelser/start": {
      "get": {
        "summary": "Hent startpunkt for hendelseslisten",
        "description": "Hent start for hendelseslisten",
        "operationId": "HentStart",
        "tags": [
          "hendelser"
        ],
        "parameters": [
          {
            "name": "dato",
            "in": "query",
            "description": "En dato p\u00e5 ISO 8601-format, YYYY-MM-DD. Dersom dette parameteret er satt vil endepunktet returnere sekvensnummer for f\u00f8rste hendelse fra og med denne denne datoen. Dersom dato ikke er satt vil endepunktet returnere sekvensnummer for aller f\u00f8rste hendelse i listen.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "2021-08-21"
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske foresp\u00f8rselen. M\u00e5 v\u00e6re p\u00e5 UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Start"
                }
              }
            }
          },
          "default": {
            "description": "Diverse feilmeldinger, se egen dokumentasjon",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  }
}