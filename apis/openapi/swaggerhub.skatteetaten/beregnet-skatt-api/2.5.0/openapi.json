  "paths": {
    "/{rettighetspakke}/{inntektsaar}/{personidentifikator}": {
      "get": {
        "summary": "Hent beregnet skatt for person",
        "description": "Hent beregnet skatt for person for angitt inntekts\u00e5r. Tildelt rettighetspakke m\u00e5 angis i foresp\u00f8rselen.",
        "operationId": "hentBeregnetSkattForPerson",
        "tags": [
          "BeregnetSkatt V2"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert p\u00e5 en juridisk vurdering. Rettighetspakken styrer Skjermingsregler, Filtrering og Detaljering som benyttes n\u00e5r det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inntektsaar",
            "in": "path",
            "description": "Inntekts\u00e5ret det skal hentes opplysninger fra.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 2020
          },
          {
            "name": "personidentifikator",
            "in": "path",
            "description": "personidentifikator",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 12345678901
          },
          {
            "name": "ajourholdtDato",
            "in": "query",
            "description": "Valgfri parameter p\u00e5 format YYYY-MM-DD. Dersom denne benyttes returneres siste ajourholdte opplysninger for gitt dato.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "2023-03-21"
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske foresp\u00f8rselen. M\u00e5 v\u00e6re p\u00e5 UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BeregnetSkatt"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/BeregnetSkatt"
                }
              }
            }
          },
          "default": {
            "description": "Alle feil fra applikasjonen kommer p\u00e5 f\u00f8lgende format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  }
