{
  "openapi": "3.0.3",
  "info": {
    "title": "Innrapportering boligsameie API",
    "description": "Tjeneste for innrapportering av tredjepartsopplysninger for et boligsameie fra sluttbrukersystemer",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/skatteetaten/boligsameie-api/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://innrapporteringboligsameie.api.skatteetaten-test.no/v1",
      "description": "Ekstern test"
    },
    {
      "url": "https://innrapporteringboligsameie.api.skatteetaten.no/v1",
      "description": "Produksjon (Prod)"
    }
  ],
  "paths": {
    "/{inntektsaar}": {
      "post": {
        "summary": "Lever tredjepartsopplysninger for et boligsameie",
        "description": "Lever tredjepartsopplysninger for et boligsameie for ett inntekts\u00e5r og en oppgavegiver",
        "operationId": "innsending_boligsameie",
        "tags": [
          "boligsameie"
        ],
        "parameters": [
          {
            "name": "inntektsaar",
            "schema": {
              "type": "string"
            },
            "in": "path",
            "required": true,
            "description": "Inntekts\u00e5r opplysningene i innrapporteringen gjelder for."
          },
          {
            "name": "idempotencyKey",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "in": "header",
            "required": true,
            "description": "Idempotensn\u00f8kkel for \u00e5 sikre unik innsending. En ny innsending med nytt innhold skal ha ny n\u00f8kkel."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Melding"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Innsending levert OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Leveransebekreftelse"
                }
              }
            }
          },
          "default": {
            "description": "Alle feil fra applikasjonen kommer p\u00e5 f\u00f8lgende format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    },
    "/{inntektsaar}/forsendelser/{forsendelseId}/dokumenter/{dokumentId}": {
      "get": {
        "summary": "Hent ut dokument (attachment i dialogporten)",
        "description": "Henter ut ett spesifikt dokument tilknyttet en forsendelse",
        "operationId": "uthenting_dokument",
        "tags": [
          "boligsameie"
        ],
        "parameters": [
          {
            "name": "inntektsaar",
            "schema": {
              "type": "string"
            },
            "in": "path",
            "required": true,
            "description": "Inntekts\u00e5r opplysningene i innrapporteringen gjelder for."
          },
          {
            "name": "forsendelseId",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "in": "path",
            "required": true,
            "description": "Identifikator for forsendelse"
          },
          {
            "name": "dokumentId",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "in": "path",
            "required": true,
            "description": "Identifikator for dokument man skal hente ut."
          }
        ],
        "responses": {
          "200": {
            "description": "Uthenting av fil OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/xml": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/zip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "default": {
            "description": "Alle feil fra applikasjonen kommer p\u00e5 f\u00f8lgende format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  },
