{
  "openapi": "3.0.3",
  "info": {
    "description": "Tjenesten leverer informasjon om BSU renteinntekter pr kalender\u00e5r for en person.",
    "version": "1.2.1",
    "title": "Boligsparing for ungdom API",
    "termsOfService": "https://www.skatteetaten.no/deling/bruksvilkar-for-delingstjenester",
    "contact": {
      "name": "Brukerst\u00f8tte",
      "url": "https://www.skatteetaten.no/deling/kontakt/"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/skatteetaten/boligsparing-for-ungdom-api/1.2.1/swagger.json"
  },
  "externalDocs": {
    "description": "Dokumentasjon p\u00e5 Skatteetatens GitHub",
    "url": "https://skatteetaten.github.io/api-dokumentasjon/api/bsu.html"
  },
  "servers": [
    {
      "url": "https://bsu.api.skatteetaten-test.no/v1",
      "description": "Ekstern test"
    },
    {
      "url": "https://bsu.api.skatteetaten.no/v1",
      "description": "Produksjon"
    }
  ],
  "security": [
    {
      "maskinporten": [
        "skatteetaten:boligsparingforungdom"
      ]
    }
  ],
  "paths": {
    "/{rettighetspakke}/{inntektsaar}/{foedselsnummer}": {
      "get": {
        "summary": "Hent boligsparing for ungdom for person",
        "description": "Hent boligsparing for ungdom for person",
        "operationId": "hentBoligsparingForUngdomForPerson",
        "tags": [
          "Boligsparing for ungdom"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert p\u00e5 en juridisk vurdering. Rettighetspakken styrer skjermingsregler, filtrering og detaljering som benyttes n\u00e5r det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inntektsaar",
            "in": "path",
            "description": "Inntekts\u00e5ret det skal hentes opplysninger fra.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 2020
          },
          {
            "name": "foedselsnummer",
            "in": "path",
            "description": "F\u00f8dselsnummer til personen det sp\u00f8rres p\u00e5.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 12345678901
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske foresp\u00f8rselen. M\u00e5 v\u00e6re p\u00e5 UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoligsparingForUngdom"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/BoligsparingForUngdom"
                }
              }
            }
          },
          "default": {
            "description": "Alle feil fra applikasjonen kommer p\u00e5 f\u00f8lgende format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "maskinporten": {
        "type": "http",
        "description": "Maskinporten benyttes for autentisering",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Feil": {
        "description": "Feilstruktur for alle feilmeldinger.",
        "type": "object",
        "properties": {
          "kode": {
            "type": "string",
            "description": "Feilkode, for maskinell h\u00e5ndtering",
            "example": "BSU-0xx"
          },
          "melding": {
            "type": "string",
            "description": "Beskrivelse av feilen som har oppst\u00e5tt",
            "example": "Fant ikke gitt personidentifikator"
          },
          "korrelasjonsid": {
            "type": "string",
            "description": "Korrelasjonsid",
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        },
        "xml": {
          "name": "feil",
          "namespace": "urn:no:skatteetaten:datasamarbeid:feil:v1"
        }
      },
      "BoligsparingForUngdom": {
        "type": "object",
        "description": "",
        "properties": {
          "personidentifikator": {
            "description": "",
            "$ref": "#/components/schemas/Foedselsnummer"
          },
          "inntektsaar": {
            "description": "",
            "$ref": "#/components/schemas/Aarstall"
          },
          "aaretsRenter": {
            "description": "",
            "$ref": "#/components/schemas/Beloep"
          }
        },
        "xml": {
          "name": "boligsparingForUngdom",
          "namespace": "no:skatteetaten:datasamarbeid:boligsparingforungdom:v1"
        },
        "required": [
          "personidentifikator",
          "inntektsaar"
        ]
      },
      "Foedselsnummer": {
        "type": "string",
        "description": "ellevesifret identifikasjonsnummer for personer bosatt i Norge, der de seks f\u00f8rste sifrene angir f\u00f8dselsdato og de fem siste personnummer. (<a href='https://data.skatteetaten.no/begrep/5138da10-be20-11e6-8004-005056825ca0'>Begrepsreferanse</a>)",
        "minLength": 11,
        "pattern": "[0-9]+",
        "maxLength": 11
      },
      "Aarstall": {
        "type": "string",
        "description": "\u00e5rstall er et tall som angir \u00e5rets nummer i tidsregningen i den gregorianske kalender (<a href='https://data.skatteetaten.no/begrep/20b2e14a-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "year"
      },
      "Beloep": {
        "type": "number",
        "description": "en sum av penger brukt i en kontekst. Dette kan v\u00e6re en transaksjon, saldo o.l. (<a href='https://data.skatteetaten.no/begrep/20b2e146-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "double"
      }
    }
  }
}