  "paths": {
    "/{rettighetspakke}/person/{personidentifikator}": {
      "get": {
        "summary": "Hent arbeidsforholdsopplysninger for inntektsmottaker",
        "description": "Informasjon om arbeidsgivers (opplysningspliktiges) innrapporterte arbeidsforholdsopplysninger for en inntektsmottaker for en gitt periode",
        "operationId": "hentArbeidsforholdForInntektsmottaker",
        "tags": [
          "arbeidsforhold"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert p\u00e5 en juridisk vurdering. Rettighetspakken styrer skjermingsregler, filtrering og detaljering som benyttes n\u00e5r det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "personidentifikator",
            "in": "path",
            "description": "personidentifikator",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 12345678901
          },
          {
            "name": "virksomhet",
            "in": "query",
            "description": "Identifikator (Organisasjonsnummer, f\u00f8dselsnummer eller d-nummer) for virksomhet.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": 123456789
          },
          {
            "name": "opplysningspliktig",
            "in": "query",
            "description": "Identifikator (Organisasjonsnummer, f\u00f8dselsnummer eller d-nummer) for opplysningspliktig.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": 12345678901
          },
          {
            "name": "fraOgMed",
            "in": "query",
            "description": "Fra og med hvilken periode innrapporterte opplysninger skal leveres.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "2022-01"
          },
          {
            "name": "tilOgMed",
            "in": "query",
            "description": "Til og med hvilken periode innrapporterte opplysninger skal leveres. Dersom tilOgMed ikke er satt brukes innev\u00e6rende \u00e5r og m\u00e5ned som parameter.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "2023-01"
          },
          {
            "name": "historikk",
            "in": "query",
            "description": "historikk \u2013 boolean (default false): false \u2013 bare sist rapporterte opplysninger (gjeldende opplysninger) for en periode vil bli returnert. True - alle rapporterte opplysninger i en periode vil bli returnert",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "example": "true"
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske foresp\u00f8rselen. M\u00e5 v\u00e6re p\u00e5 UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArbeidsforholdForInntektsmottaker"
                }
              }
            }
          },
          "default": {
            "description": "Alle feil fra applikasjonen kommer p\u00e5 f\u00f8lgende format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    },
