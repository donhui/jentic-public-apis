{
  "openapi": "3.0.3",
  "info": {
    "title": "Aksjebeholdning API",
    "description": "Tjenesten leverer informasjon en person eller en virksomhet sin aksjebeholdning pr. 31.12 sist kalenderår.",
    "version": "1.1.2",
    "termsOfService": "https://www.skatteetaten.no/deling/bruksvilkar-for-delingstjenester",
    "contact": {
      "name": "Brukerstøtte",
      "url": "https://www.skatteetaten.no/deling/kontakt/"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/skatteetaten/aksjebeholdning-api/1.1.2/swagger.json"
  },
  "servers": [
    {
      "url": "https://aksjebeholdning.api.skatteetaten-test.no/v1",
      "description": "Ekstern test"
    },
    {
      "url": "https://aksjebeholdning.api.skatteetaten.no/v1",
      "description": "Produksjon"
    }
  ],
  "paths": {
    "/virksomhet/{rettighetspakke}/{kalenderaar}/{organisasjonsnummer}": {
      "get": {
        "summary": "Hent aksjebeholdning for en virksomhet",
        "description": "Hent aksjebeholdning for en virksomhet for oppgitt kalenderår",
        "operationId": "hentAksjebeholdningForVirksomhet",
        "tags": [
          "aksjebeholdning"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert på en juridisk vurdering. Rettighetspakken styrer skjermingsregler, filtrering og detaljering som benyttes når det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "kalenderaar",
            "in": "path",
            "description": "Kalenderåret det skal hentes opplysninger fra.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 2022
          },
          {
            "name": "organisasjonsnummer",
            "in": "path",
            "description": "Organisasjonsnummer for virksomhet",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 123456789
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske forespørselen. Må være på UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Aksjebeholdning"
                }
              }
            }
          },
          "default": {
            "description": "Diverse feilmeldinger, se egen dokumentasjon",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    },
    "/person/{rettighetspakke}/{kalenderaar}/{personidentifikator}": {
      "get": {
        "summary": "Hent aksjebeholdning for en person",
        "description": "Hent aksjebeholdning for en person for oppgitt kalenderår",
        "operationId": "hentAksjebeholdningForPerson",
        "tags": [
          "aksjebeholdning"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert på en juridisk vurdering. Rettighetspakken styrer skjermingsregler, filtrering og detaljering som benyttes når det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "kalenderaar",
            "in": "path",
            "description": "Kalenderår det skal hentes opplysninger fra.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 2022
          },
          {
            "name": "personidentifikator",
            "in": "path",
            "description": "Fødselsnummer for en person.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 123456789
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske forespørselen. Må være på UUID-format.",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Aksjebeholdning"
                }
              }
            }
          },
          "default": {
            "description": "Diverse feilmeldinger, se egen dokumentasjon",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "maskinporten": {
        "type": "http",
        "description": "Maskinporten benyttes for autentisering",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Feil": {
        "description": "Feilstruktur for alle feilmeldinger.",
        "type": "object",
        "properties": {
          "kode": {
            "type": "string",
            "description": "Feilkode, for maskinell håndtering",
            "example": "ABE-0xx"
          },
          "melding": {
            "type": "string",
            "description": "Beskrivelse av feilen som har oppstått",
            "example": "Oppgitt rettighetspakke er ugyldig."
          },
          "korrelasjonsid": {
            "type": "string",
            "description": "Korrelasjonsid",
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        }
      },
      "Aksjebeholdning": {
        "type": "object",
        "description": "",
        "properties": {
          "aksjebeholdningPerSelskap": {
            "type": "array",
            "description": "",
            "items": {
              "$ref": "#/components/schemas/AksjebeholdningPerSelskap"
            }
          },
          "identifikator": {
            "description": "",
            "$ref": "#/components/schemas/NorskIdentifikator"
          },
          "kalenderaar": {
            "description": "",
            "$ref": "#/components/schemas/Aarstall"
          }
        }
      },
      "Aksje": {
        "type": "object",
        "description": "",
        "properties": {
          "isinnummer": {
            "description": "",
            "$ref": "#/components/schemas/Tekst"
          },
          "aksjeklasse": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/1e333067-6837-11e6-a7ce-fac03dffe1d7'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Aksjeklasse"
          },
          "antallAksjer": {
            "description": "",
            "$ref": "#/components/schemas/Antall"
          }
        }
      },
      "AksjebeholdningPerSelskap": {
        "type": "object",
        "description": "mengde aksjer som blir regnskapsført eller omsatt som en enhet",
        "properties": {
          "selskap": {
            "description": "",
            "$ref": "#/components/schemas/Organisasjonsnummer"
          },
          "antallAksjerTotaltISelskap": {
            "description": "",
            "$ref": "#/components/schemas/Antall"
          },
          "aksjer": {
            "type": "array",
            "description": "",
            "items": {
              "$ref": "#/components/schemas/Aksje"
            }
          }
        }
      },
      "NorskIdentifikator": {
        "type": "string",
        "description": "(<a href='https://data.skatteetaten.no/begreper/dcfb4778-e484-11e6-9cb3-005056821322'>Begrepsreferanse</a>)"
      },
      "Aarstall": {
        "type": "string",
        "description": "årstall er et tall som angir årets nummer i tidsregningen i den gregorianske kalender (<a href='https://data.skatteetaten.no/begrep/20b2e14a-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "year"
      },
      "Tekst": {
        "type": "string",
        "description": "vilkårlig lang sekvens av tegn inkludert aksenter og spesielle tegn fra standardiserte tegnsett (<a href='https://data.skatteetaten.no/begrep/20b52af3-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "maxLength": 4000
      },
      "Aksjeklasse": {
        "type": "string",
        "description": "Lovlige verdier for kodelisten ligger her: https://skatteetaten.github.io/api-dokumentasjon/download/aksjeklasse_kodeliste.xml (<a href='https://skatteetaten.github.io/api-dokumentasjon/download/aksjeklasse_kodeliste.xml'>Kodelistereferanse</a>)"
      },
      "Antall": {
        "type": "integer",
        "description": "mengde som utgjør eller kan uttrykkes i et visst tall (<a href='https://data.skatteetaten.no/begrep/20b2e145-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "int64"
      },
      "Organisasjonsnummer": {
        "type": "string",
        "description": "9 sifret nummer gitt de som er registrert i Enhetsregisteret. (<a href='https://data.skatteetaten.no/begrep/20b2e1a8-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "minLength": 9,
        "pattern": "[0-9]+",
        "maxLength": 9
      }
    }
  },
  "security": [
    {
      "maskinporten": [
        "skatteetaten:aksjebeholdning"
      ]
    }
  ],
  "externalDocs": {
    "description": "Dokumentasjon på Skatteetatens GitHub",
    "url": "https://skatteetaten.github.io/api-dokumentasjon/api/aksjebeholdning"
  }
}