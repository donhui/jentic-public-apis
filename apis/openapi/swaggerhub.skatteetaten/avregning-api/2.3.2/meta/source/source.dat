{
  "openapi": "3.0.3",
  "info": {
    "description": "Tjenesten leverer informasjon om forskuddstrekk og restskatt eller bel\u00f8p til gode i skatteoppgj\u00f8ret.",
    "version": "2.3.2",
    "title": "Avregning API",
    "termsOfService": "https://www.skatteetaten.no/deling/bruksvilkar-for-delingstjenester",
    "contact": {
      "name": "Brukerst\u00f8tte",
      "url": "https://www.skatteetaten.no/deling/kontakt/"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/skatteetaten/avregning-api/2.3.2/swagger.json"
  },
  "externalDocs": {
    "description": "Dokumentasjon p\u00e5 Skatteetatens GitHub",
    "url": "https://skatteetaten.github.io/api-dokumentasjon/api/avregning"
  },
  "servers": [
    {
      "url": "https://avregning.api.skatteetaten-test.no/v2",
      "description": "Ekstern test"
    },
    {
      "url": "https://avregning.api.skatteetaten.no/v2",
      "description": "Produksjon"
    }
  ],
  "security": [
    {
      "maskinporten": [
        "skatteetaten:avregning"
      ]
    }
  ],
  "components": {
    "securitySchemes": {
      "maskinporten": {
        "type": "http",
        "description": "Maskinporten benyttes for autentisering",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Feil": {
        "description": "Feilstruktur for alle feilmeldinger.",
        "type": "object",
        "properties": {
          "kode": {
            "type": "string",
            "description": "Feilkode, for maskinell haandtering",
            "example": "AR-0xx"
          },
          "melding": {
            "type": "string",
            "description": "Beskrivelse av feilen som har oppstaatt",
            "example": "Fant ikke gitt personidentifikator"
          },
          "korrelasjonsid": {
            "type": "string",
            "description": "Korrelasjonsid",
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        },
        "xml": {
          "name": "feil",
          "namespace": "urn:no:skatteetaten:datasamarbeid:feil:v1"
        }
      },
      "Avregning": {
        "type": "object",
        "description": "",
        "properties": {
          "personidentifikator": {
            "description": "Gjeldene personidentifikator for personen det ble s\u00f8kt p\u00e5.",
            "$ref": "#/components/schemas/Foedselsnummer"
          },
          "inntektsaar": {
            "description": "Inntekts\u00e5ret det ble s\u00f8kt p\u00e5.",
            "$ref": "#/components/schemas/Aarstall"
          },
          "skjermet": {
            "description": "Returnerer true dersom informasjon er fjernet",
            "$ref": "#/components/schemas/Boolsk"
          },
          "skatteoppgjoersdato": {
            "description": "Dato da skatteoppgj\u00f8r ble gjort gjeldene",
            "$ref": "#/components/schemas/Dato"
          },
          "fastland": {
            "description": "Verdier for fastland",
            "$ref": "#/components/schemas/Avregningsresultat"
          },
          "svalbard": {
            "description": "Verdier for Svalbard",
            "$ref": "#/components/schemas/Avregningsresultat"
          },
          "kildeskattPaaLoenn": {
            "description": "Verdier for kildeskatt p\u00e5 l\u00f8nn",
            "$ref": "#/components/schemas/Avregningsresultat"
          },
          "ajourholdstidspunkt": {
            "description": "Tidspunkt for n\u00e5r et sett av informasjon ble registrert hos kilden",
            "$ref": "#/components/schemas/DatoKlokkeslett"
          }
        },
        "xml": {
          "name": "avregning",
          "namespace": "urn:no:skatteetaten:datasamarbeid:avregning:v2"
        },
        "required": [
          "personidentifikator",
          "inntektsaar"
        ]
      },
      "Avregningsresultat": {
        "type": "object",
        "description": "",
        "properties": {
          "restskatt": {
            "description": "bel\u00f8p som viser at innbetalt forskudd ikke dekker bergegnet skatt.  Bel\u00f8pet er uten rentetillegg.",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "avregnetForskuddstrekk": {
            "description": "sum forskuddstrekk fra a-meldinger, trekkontroll og manuelt registrerte forskuddstrekk hos skatteoppkrever (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/60a34eb0-e979-11e8-9ab2-0050568351d2'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "beloepTilgode": {
            "description": "bel\u00f8p som skal utbetales skattepliktige, eventuelt motregnes mot skyldige offentlige bel\u00f8p",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "forhaandsfastsatt": {
            "description": "skatteoppgj\u00f8r er laget f\u00f8r man starter opp med produksjon av skatteoppgj\u00f8r for inntekts\u00e5ret. Forh\u00e5ndsfastsetting gjelder d\u00f8de og personer som flytter ut fra Norge i skattleggingsperioden",
            "$ref": "#/components/schemas/Boolsk"
          },
          "skatteregnskapskommune": {
            "description": "(<a href='https://data.skatteetaten.no/web/datakatalog/begrep/649cbcf1-ad07-11e8-8ffd-005056821322'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Kommunenummer"
          },
          "beregnetSkatt": {
            "description": "fastsatt skatt for inntekts\u00e5ret (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/649cbcd4-ad07-11e8-8ffd-005056821322'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "nektetGodskrevet": {
            "description": "forskuddstrekk som ikke er innbetalt og som gjelder daglig leder/styreleder i firmaet (opplysningspliktige) som har sendt inn a-meldingen. Bel\u00f8pet reduserer forskuddstrekket i skatteoppgj\u00f8ret",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "tilbakebetaltFoerAvregning": {
            "description": "forskuddstrekk som er utbetalt skattyter f\u00f8r skatteoppgj\u00f8ret er produsert. Forskuddsutbetalt bel\u00f8p reduserer forskuddstrekket i skatteoppgj\u00f8ret",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "avregnetForskuddsskatt": {
            "description": "forskuddsskatt som er tatt med i skatteoppgj\u00f8ret (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b2e1f9-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "betaltTilleggsforskudd": {
            "description": "innbetaling av forventet skyldig skatt. Frist for innbetaling av tilleggsforskudd er 31. mai i skattefastsettings\u00e5ret (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/27c11490-571e-11e7-a43d-0050568351d2'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "forskudd": {
            "description": "",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "overskytende": {
            "description": "bel\u00f8p som viser at innbetalt forskudd er h\u00f8yere enn beregnet skatt. Bel\u00f8pet er uten rentegodtgj\u00f8relse",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "rentetillegg": {
            "description": "rentetillegg etter sktbl \u00a7 11-5. Renten beregnes av restskatt",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "rentegodtgjoerelse": {
            "description": "rentegodtgj\u00f8relse etter sktbl \u00a7 11-5. Renten beregnes av overskytende",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "beregnedeDebetAvsavnsrenter": {
            "description": "rentetillegg etter sktbl \u00a7 11-2. Renten beregnes av \u00f8kt skatt ved endring av skatteoppgj\u00f8r",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "beregnedeKreditAvsavnsrenter": {
            "description": "rentegodtgj\u00f8relse etter sktbl \u00a7 11-4. Renten beregnes av \u00f8kt overskytende/tilbakebetaling av tidligere innbetalt restskatt ved endring av skatteoppgj\u00f8r",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "forskuddPaaRestskatt": {
            "description": "innbetaling av tilleggsforskudd etter frist 31.05 i skattefastsettings\u00e5ret blir benyttet til \u00e5 dekke restskatt i skatteoppgj\u00f8ret",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "ubetaltForskuddsskatt": {
            "description": "andel av forskuddsskatt som ikke er betalt",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "utbetaltTidligere": {
            "description": "bel\u00f8p som er utbetalt/motregnet etter tidligere skatteoppgj\u00f8r",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "innbetaltTidligere": {
            "description": "bel\u00f8p som er innbetalt etter tidligere skatteoppgj\u00f8r",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "aaBetale": {
            "description": "bel\u00f8p skattepliktig skal betale",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "aaBetaleFrafaltUnderOrdinaerBeloepsgrense": {
            "description": "bel\u00f8p <kr 100 som skattepliktig ikke skal betale",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "aaBetaleFrafaltUnderBeloepsgrenseForSjoemenn": {
            "description": "bel\u00f8p <kr 2000 som skattepliktig ikke skal betale. Gjelder sj\u00f8folk (s\u00e6rskilt skatteplikt)",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "tilgodeBlirIkkeUtbetaltUnderOrdinaerBeloepsgrense": {
            "description": "bel\u00f8p <kr 100 som skattepliktig ikke f\u00e5r utbetalt",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "tilgodeBlirIkkeUtbetaltUnderBeloepsgrenseForSjoemenn": {
            "description": "bel\u00f8p <kr 2000 som skattepliktig ikke f\u00e5r utbetalt. Gjelder sj\u00f8folk (s\u00e6rskilt skatteplikt)",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "enoekFradrag": {
            "description": "ikke i bruk fra og med inntekts\u00e5ret 2022",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "restskattFrafaltUnderOrdinaerBeloepsgrense": {
            "description": "bel\u00f8p <kr 100 som skattepliktig ikke skal betale. Feltet brukes n\u00e5r skattepliktig ogs\u00e5 har ubetalt forskuddsskatt",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "refusjonAvKildeskattPaaLoenn": {
            "description": "gjelder skattepliktig med skatteplikt kildeskatt p\u00e5 l\u00f8nn. Arbeidsgiver har trukket mer skatt enn skattyter skal betale. Skattepliktig kan s\u00f8ke om \u00e5 f\u00e5 bel\u00f8pet tilbakebetalt",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          },
          "fastsattKildeskattPaaLoenn": {
            "description": "gjelder skattepliktig med skatteplikt kildeskatt p\u00e5 l\u00f8nn. Arbeidsgiver har ikke trukket skatt av utbetalt l\u00f8nn. Skattepliktig skal selv betale inn fastsatt kildeskatt",
            "$ref": "#/components/schemas/BeloepSomHeltall"
          }
        }
      },
      "Foedselsnummer": {
        "type": "string",
        "description": "ellevesifret identifikasjonsnummer for personer bosatt i Norge, der de seks f\u00f8rste sifrene angir f\u00f8dselsdato og de fem siste personnummer. (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/5138da10-be20-11e6-8004-005056825ca0'>Begrepsreferanse</a>)",
        "minLength": 11,
        "pattern": "[0-9]+",
        "maxLength": 11
      },
      "Aarstall": {
        "type": "string",
        "description": "\u00e5rstall er et tall som angir \u00e5rets nummer i tidsregningen i den gregorianske kalender (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b2e14a-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "year"
      },
      "Boolsk": {
        "type": "boolean",
        "description": "angir verdien sann eller usann (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b52aec-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)"
      },
      "Dato": {
        "type": "string",
        "description": "gir verdier for \u00e5r, m\u00e5ned og dag. Kodes som en tekststreng etter datoformatering spesifisert i  ISO 8601 (ISO 8601:2004 Data elements and interchange formats -- Information interchange -- Representation of dates and times). Eksempel : 1998-12-21 eller 19981221. (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b52aed-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "date"
      },
      "DatoKlokkeslett": {
        "type": "string",
        "description": "en kombinasjon av typene Dato og Klokkeslett. Kodes som en tekststreng etter datoformatering spesifisert i ISO 8601 (ISO 8601:2004 Data elements and interchange formats -- Information interchange -- Representation of dates and times). (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b52aee-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "date-time"
      },
      "BeloepSomHeltall": {
        "type": "integer",
        "description": "en sum av penger i hele kroner brukt i en kontekst. Dette kan v\u00e6re en transaksjon, saldo o.l. (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b2e146-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "int64"
      },
      "Kommunenummer": {
        "type": "string",
        "description": "nummer for kommune (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b2e0f3-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "minLength": 4,
        "pattern": "([0-9]){4}",
        "maxLength": 4
      }
    }
  },
  "paths": {
    "/{rettighetspakke}/{inntektsaar}/{personidentifikator}": {
      "get": {
        "summary": "Hent avregning for person",
        "description": "Hent avregning for person for et angitt inntekts\u00e5r. Foresp\u00f8rselen m\u00e5 inneholde tildelt rettighetspakke.",
        "operationId": "hentAvregningForPerson",
        "tags": [
          "Avregning"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert p\u00e5 en juridisk vurdering. Rettighetspakken styrer Skjermingsregler, Filtrering og Detaljering som benyttes n\u00e5r det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inntektsaar",
            "in": "path",
            "description": "Inntekts\u00e5ret det skal hentes opplysninger fra.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 2020
          },
          {
            "name": "personidentifikator",
            "in": "path",
            "description": "F\u00f8dsels- eller Dnummer",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 12345678901
          },
          {
            "name": "gjelderPaaTidspunkt",
            "in": "query",
            "description": "Tidspunkt for hvilken gjeldende avregning som skal returneres.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "2020-10-21T11:11:11"
          },
          {
            "name": "ajourholdtDato",
            "in": "query",
            "description": "Valgfri parameter p\u00e5 format YYYY-MM-DD. Dersom denne benyttes returneres siste ajourholdte opplysninger for gitt dato.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "2023-03-21"
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske foresp\u00f8rselen. M\u00e5 v\u00e6re p\u00e5 UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Avregning"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Avregning"
                }
              }
            }
          },
          "default": {
            "description": "Diverse feilmeldinger, se dokumentasjon",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  }
}