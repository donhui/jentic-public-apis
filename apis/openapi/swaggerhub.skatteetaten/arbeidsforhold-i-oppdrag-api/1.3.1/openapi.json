{
  "openapi": "3.0.3",
  "info": {
    "description": "Tjenesten leverer informasjon om hvorvidt det foreligger, og ev. perioden for, et arbeidsforhold og mellom angitt oppdragsgiver og en angitt arbeidstaker.",
    "version": "1.3.1",
    "title": "Arbeidsforhold i oppdrag API",
    "termsOfService": "https://www.skatteetaten.no/deling/bruksvilkar-for-delingstjenester",
    "contact": {
      "name": "Brukerst\u00f8tte",
      "url": "https://www.skatteetaten.no/deling/kontakt/"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/skatteetaten/arbeidsforhold-i-oppdrag-api/1.3.1/swagger.json"
  },
  "externalDocs": {
    "description": "Dokumentasjon p\u00e5 Skatteetatens GitHub",
    "url": "https://skatteetaten.github.io/api-dokumentasjon/api/arbeidsforholdioppdrag"
  },
  "servers": [
    {
      "url": "https://arbeidsforholdioppdrag.api.skatteetaten-test.no/v1",
      "description": "Ekstern test"
    },
    {
      "url": "https://arbeidsforholdioppdrag.api.skatteetaten.no/v1",
      "description": "Produksjon"
    }
  ],
  "security": [
    {
      "maskinporten": [
        "skatteetaten:arbeidsforhold"
      ]
    }
  ],
  "components": {
    "securitySchemes": {
      "maskinporten": {
        "type": "http",
        "description": "Maskinporten benyttes for autentisering",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Feil": {
        "description": "Feilstruktur for alle feilmeldinger.",
        "type": "object",
        "properties": {
          "kode": {
            "type": "string",
            "description": "Feilkode, for maskinell h\u00e5ndtering",
            "example": "ARBEIDSFORHOLD-0xx"
          },
          "melding": {
            "type": "string",
            "description": "Beskrivelse av feilen som har oppst\u00e5tt",
            "example": "Fant ikke gitt personidentifikator"
          },
          "korrelasjonsid": {
            "type": "string",
            "description": "Korrelasjonsid",
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        }
      },
      "Arbeidsforhold": {
        "type": "object",
        "description": "Informasjon om hvorvidt det foreligger, og ev. perioden for, et arbeidsforhold og mellom angitt oppdragsgiver og en angitt arbeidstaker.",
        "properties": {
          "aktiv": {
            "description": "",
            "$ref": "#/components/schemas/AktivArbeidsforholdsstatus"
          },
          "perioder": {
            "type": "array",
            "description": "",
            "items": {
              "$ref": "#/components/schemas/Periode"
            }
          }
        }
      },
      "Periode": {
        "type": "object",
        "description": "(<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b52b6d-9fe1-11e5-a9f8-e4115b280940''>Begrepsreferanse</a>)",
        "properties": {
          "startdato": {
            "description": "(<a href='https://data.skatteetaten.no/web/datakatalog/begrep/dcfb47c2-e484-11e6-9cb3-005056821322''>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Dato"
          },
          "sluttdato": {
            "description": "(<a href='https://data.skatteetaten.no/web/datakatalog/begrep/dcfb47b7-e484-11e6-9cb3-005056821322''>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Dato"
          }
        }
      },
      "AktivArbeidsforholdsstatus": {
        "type": "string",
        "description": "Hvorvidt det foreligger et aktivt arbeidsforhold.",
        "enum": [
          "JA",
          "NEI"
        ]
      },
      "Dato": {
        "type": "string",
        "description": "gir verdier for \u00e5r, m\u00e5ned og dag. Kodes som en tekststreng etter datoformatering spesifisert i  ISO 8601 (ISO 8601:2004 Data elements and interchange formats -- Information interchange -- Representation of dates and times). Eksempel : 1998-12-21 eller 19981221. (<a href='https://data.skatteetaten.no/web/datakatalog/begrep/20b52aed-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "date"
      }
    }
  },
  "paths": {
    "/{rettighetspakke}/arbeidsgiver/{organisasjonsnummer}/arbeidstaker/{foedselsnummer}/aktiv": {
      "get": {
        "summary": "Hent arbeidsforhold i oppdrag for person",
        "description": "Hent arbeidsforhold i oppdrag for person",
        "operationId": "hentArbeidsforholdIOppdragForPerson",
        "tags": [
          "ArbeidsforholdIOppdrag"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert p\u00e5 en juridisk vurdering. Rettighetspakken styrer skjermingsregler, filtrering og detaljering som benyttes n\u00e5r det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "foedselsnummer",
            "in": "path",
            "description": "F\u00f8dselsnummer eller D-nummer for arbeidstaker",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 12345678901
          },
          {
            "name": "organisasjonsnummer",
            "in": "path",
            "description": "Organisasjonsnummer for arbeidsgiver",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 123456789
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske foresp\u00f8rselen. M\u00e5 v\u00e6re p\u00e5 UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Arbeidsforhold"
                }
              }
            }
          },
          "default": {
            "description": "Diverse feilmeldinger, se dokumentasjon",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  }
}