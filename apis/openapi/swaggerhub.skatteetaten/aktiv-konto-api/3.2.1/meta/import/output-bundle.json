{
  "openapi": "3.0.3",
  "info": {
    "description": "Tjenesten leverer informasjon om valgt konto for utbetalinger av beløp til gode fra Skatteetaten.",
    "version": "3.2.1",
    "title": "Aktiv konto API",
    "termsOfService": "https://www.skatteetaten.no/deling/bruksvilkar-for-delingstjenester",
    "contact": {
      "name": "Brukerstøtte",
      "url": "https://www.skatteetaten.no/deling/kontakt/"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/skatteetaten/aktiv-konto-api/3.2.1/swagger.json"
  },
  "servers": [
    {
      "url": "https://aktivkonto.api.skatteetaten-test.no/v3",
      "description": "Ekstern test"
    },
    {
      "url": "https://aktivkonto.api.skatteetaten.no/v3",
      "description": "Produksjon"
    }
  ],
  "paths": {
    "/{rettighetspakke}/{personidentifikator}": {
      "get": {
        "summary": "Hent aktiv konto for person",
        "description": "Hent aktiv konto for person.",
        "operationId": "hentAktivKontoForPerson",
        "tags": [
          "AktivKonto V3"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert på en juridisk vurdering. Rettighetspakken styrer skjermingsregler, filtrering og detaljering som benyttes når det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "personidentifikator",
            "in": "path",
            "description": "personidentifikator",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 12345678901
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske forespørselen. Må være på UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AktivKonto"
                }
              }
            }
          },
          "default": {
            "description": "Alle feil fra applikasjonen kommer på følgende format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "maskinporten": {
        "type": "http",
        "description": "Maskinporten benyttes for autentisering",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Feil": {
        "description": "Feilstruktur for alle feilmeldinger.",
        "type": "object",
        "properties": {
          "kode": {
            "type": "string",
            "description": "Feilkode, for maskinell håndtering",
            "example": "AKE-0xx"
          },
          "melding": {
            "type": "string",
            "description": "Beskrivelse av feilen som har oppstått",
            "example": "Fant ikke gitt personidentifikator"
          },
          "korrelasjonsid": {
            "type": "string",
            "description": "Korrelasjonsid",
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        },
        "xml": {
          "name": "feil",
          "namespace": "urn:no:skatteetaten:datasamarbeid:feil:v1"
        }
      },
      "AktivKonto": {
        "type": "object",
        "description": "",
        "properties": {
          "personidentifikator": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/98da4325-dff2-11e7-a0fd-005056821322'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Tekst"
          },
          "konto": {
            "description": "",
            "$ref": "#/components/schemas/Konto"
          }
        },
        "required": [
          "personidentifikator"
        ]
      },
      "Konto": {
        "type": "object",
        "description": "",
        "properties": {
          "kontonummer": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/20b2e328-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Kontonummer"
          },
          "kontotype": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/20b2e329-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Kontotype"
          },
          "skattekontoegnethet": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/20b2e32e-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Skattekontoegnethetstype"
          },
          "bicEllerSwift": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/20b2e31d-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Tekst"
          },
          "bankkode": {
            "description": "En kode som brukes i forbindelse med betalinger til utlandet for å identifisere mottakers bankfilial i land som ikke har IBAN. Koden er forskjellig fra land til land, og bør brukes sammen med BIC (SWIFT) i USA, Canada, Sør-Afrika, Australia, New Zealand og Hong Kong.",
            "$ref": "#/components/schemas/Tekst"
          },
          "bankNavn": {
            "description": "",
            "$ref": "#/components/schemas/Tekst"
          },
          "bankLandkode": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/20b2e112-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Landkode"
          },
          "iban": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/20b2e322-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Tekst"
          },
          "valuta": {
            "description": "(<a href='https://data.skatteetaten.no/begrep/20b2e1a2-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
            "$ref": "#/components/schemas/Valutakode"
          },
          "erUtbetalingskort": {
            "description": "Skattepliktig har valgt å få skatteoppgjør ved bruk av utbetalingskort, eller har ikke gitt opplysninger om bankkonto. Et betalingskort er en norsk betalingsanmodning fra betaler til utstedende bank om å utbetale anvisningens pålydende til mottaker.",
            "$ref": "#/components/schemas/Boolsk"
          },
          "valgtDato": {
            "description": "",
            "$ref": "#/components/schemas/Dato"
          }
        }
      },
      "Tekst": {
        "type": "string",
        "description": "vilkårlig lang sekvens av tegn inkludert aksenter og spesielle tegn fra standardiserte tegnsett (<a href='https://data.skatteetaten.no/begrep/20b52af3-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "maxLength": 4000
      },
      "Kontonummer": {
        "type": "string",
        "description": "(<a href='https://data.skatteetaten.no/begrep/20b2e328-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)"
      },
      "Kontotype": {
        "type": "string",
        "description": ""
      },
      "Skattekontoegnethetstype": {
        "type": "string",
        "description": "",
        "enum": [
          "ikkeEgnet",
          "finnesLoennsutbetaling",
          "finnesMinibankkort",
          "brukskonto"
        ]
      },
      "Landkode": {
        "type": "string",
        "description": "koder for land etter ISO 3166-1 Alpha-2 (<a href='https://data.skatteetaten.no/begrep/20b2e112-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "minLength": 2,
        "pattern": "([A-Z]){2}",
        "maxLength": 2
      },
      "Valutakode": {
        "type": "string",
        "description": "koder for offisielle valutaer etter ISO 4217 (<a href='https://data.skatteetaten.no/begrep/20b2e1a2-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)"
      },
      "Boolsk": {
        "type": "boolean",
        "description": "angir verdien sann eller usann (<a href='https://data.skatteetaten.no/begrep/20b52aec-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)"
      },
      "Dato": {
        "type": "string",
        "description": "gir verdier for år, måned og dag. Kodes som en tekststreng etter datoformatering spesifisert i  ISO 8601 (ISO 8601:2004 Data elements and interchange formats -- Information interchange -- Representation of dates and times). Eksempel : 1998-12-21 eller 19981221. (<a href='https://data.skatteetaten.no/begrep/20b52aed-9fe1-11e5-a9f8-e4115b280940'>Begrepsreferanse</a>)",
        "format": "date"
      }
    }
  },
  "security": [
    {
      "maskinporten": [
        "skatteetaten:aktivkonto"
      ]
    }
  ],
