{
  "openapi": "3.0.3",
  "info": {
    "description": "Tjenesten leverer informasjon om en virksomhet sitt grunnlag for arbeidsgiveravgift  pr 2 m\u00e5neds termin for de siste tre terminer.",
    "version": "1.1.1",
    "title": "Arbeidsgiveravgift API",
    "termsOfService": "https://www.skatteetaten.no/deling/bruksvilkar-for-delingstjenester",
    "contact": {
      "name": "Brukerst\u00f8tte",
      "url": "https://www.skatteetaten.no/deling/kontakt/"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/skatteetaten/arbeidsgiveravgift-api/1.1.1/swagger.json"
  },
  "externalDocs": {
    "description": "Dokumentasjon p\u00e5 Skatteetatens GitHub",
    "url": "https://skatteetaten.github.io/api-dokumentasjon/api/arbeidsgiveravgift"
  },
  "servers": [
    {
      "url": "https://arbeidsgiveravgift.api.skatteetaten-test.no/v1",
      "description": "Ekstern test"
    },
    {
      "url": "https://arbeidsgiveravgift.api.skatteetaten.no/v1",
      "description": "Produksjon"
    }
  ],
  "security": [
    {
      "maskinporten": [
        "skatteetaten:arbeidsgiveravgift"
      ]
    }
  ],
  "paths": {
    "/{rettighetspakke}/{organisasjonsnummer}": {
      "get": {
        "summary": "Hent arbeidsgiveravgift for enhet",
        "description": "Hent arbeidsgiveravgift for enhet",
        "operationId": "hentArbeidsgiveravgiftForEnhet",
        "tags": [
          "Arbeidsgiveravgift"
        ],
        "parameters": [
          {
            "name": "rettighetspakke",
            "in": "path",
            "description": "Datakonsumenter plasseres i en rettighetspakke (per datasett) basert p\u00e5 en juridisk vurdering. Rettighetspakken styrer Skjermingsregler, Filtrering og Detaljering som benyttes n\u00e5r det gis innsyn i data i datasett.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "organisasjonsnummer",
            "in": "path",
            "description": "organisasjonsnummer",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Korrelasjonsid",
            "in": "header",
            "description": "Korrelasjonsid, unik identifikator for den tekniske foresp\u00f8rselen. M\u00e5 v\u00e6re p\u00e5 UUID-format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "123e4567-e89b-12d3-a456-426655440000"
          },
          {
            "name": "AltinnSamtykke",
            "in": "header",
            "description": "Claims for altinnsamtykke",
            "required": false,
            "schema": {
              "type": "string",
              "format": "jws"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Gyldig respons",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Arbeidsgiveravgifter"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Arbeidsgiveravgifter"
                }
              }
            }
          },
          "400": {
            "description": "Valideringsfeil",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          },
          "403": {
            "description": "Bruker har ikke tilgang",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          },
          "500": {
            "description": "Tekniske feil",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          },
          "default": {
            "description": "unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Feil"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "maskinporten": {
        "type": "http",
        "description": "Maskinporten benyttes for autentisering",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Feil": {
        "description": "Feilstruktur for alle feilmeldinger. [Feilkoder](https://skatteetaten.github.io/api-dokumentasjon/api/arbeidsgiveravgift?tab=Feilkoder)",
        "type": "object",
        "properties": {
          "kode": {
            "type": "string",
            "description": "Feilkode, for maskinell h\u00e5ndtering",
            "example": "ARBAVG-0xx"
          },
          "melding": {
            "type": "string",
            "description": "Beskrivelse av feilen som har oppst\u00e5tt",
            "example": "Fant ikke gitt personidentifikator"
          },
          "korrelasjonsid": {
            "type": "string",
            "description": "Korrelasjonsid",
            "example": "123e4567-e89b-12d3-a456-426655440000"
          }
        },
        "xml": {
          "name": "feil"
        }
      },
      "Arbeidsgiveravgifter": {
        "description": "Rot-element for respons",
        "type": "object",
        "properties": {
          "levert": {
            "$ref": "#/components/schemas/DatoKlokkeslett"
          },
          "forespurteOrganisasjon": {
            "$ref": "#/components/schemas/Organisasjonsnummer"
          },
          "arbeidsgiveravgifter": {
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/Arbeidsgiveravgift"
                }
              ]
            },
            "minItems": 0
          }
        }
      },
      "Organisasjonsnummer": {
        "description": "Organisasjonsnummeret",
        "type": "string",
        "pattern": "[0-9]*",
        "example": 987654231
      },
      "Organisasjonsnavn": {
        "description": "navn p\u00e5 organisasjon",
        "type": "string",
        "maxLength": 175,
        "example": "Freidige Forretninger AS"
      },
      "Arbeidsgiveravgift": {
        "type": "object",
        "properties": {
          "termin": {
            "$ref": "#/components/schemas/ArbeidsgiveravgiftTermin"
          },
          "aar": {
            "$ref": "#/components/schemas/Aarstall"
          },
          "sumavgiftsgrunnlagBeloep": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Beloep"
              },
              {
                "description": "sum av avgiftsgrunnlagBel\u00f8p felt i ArbeidsgiveravgiftGrunnlag for 2 m\u00e5neds- termin"
              }
            ]
          }
        }
      },
      "Skjemamottaker": {
        "type": "object",
        "properties": {
          "mottakersOrganisasjonsnavn": {
            "$ref": "#/components/schemas/Organisasjonsnavn"
          },
          "mottakersOrganisasjonsnummer": {
            "$ref": "#/components/schemas/Organisasjonsnummer"
          }
        }
      },
      "DatoKlokkeslett": {
        "description": "en kombinasjon av typene Dato og Klokkeslett. Kodes som en tekststreng etter datoformatering spesifisert i ISO 8601 (ISO 8601:2004 Data elements and interchange formats -- Information interchange -- Representation of dates and times). '",
        "type": "string",
        "format": "datetime",
        "example": "2020-01-02T12:43:23"
      },
      "Beloep": {
        "type": "integer",
        "description": "en sum av penger brukt i en kontekst. Dette kan v\u00e6re en transaksjon, saldo o.l."
      },
      "Aarstall": {
        "description": "",
        "type": "string"
      },
      "ArbeidsgiveravgiftTermin": {
        "description": "1 = Termin 1 = Januar-Februar 2 = Termin 2 =  Mars-April 3 = Termin 3 =  Mai-Juni 4 = Termin 4 =  Juli-August 5 = Termin 5 =  September-Oktober 6 = Termin 6 =  November-Desember",
        "type": "string",
        "enum": [
          "jan-feb",
          "mar-apr",
          "mai-jun",
          "jul-aug",
          "sep-okt",
          "nov-des"
        ]
      }
    }
  }
}