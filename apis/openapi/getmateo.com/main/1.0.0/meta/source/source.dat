{
  "openapi": "3.0.3",
  "info": {
    "title": "Mateo API",
    "description": "Mateo is the platform for GDPR-compliant communication between businesses and customers, automating workflows and connecting apps seamlessly. Manage contacts, appointments, deals, messages, channels, tags, custom fields, and marketing subscriptions.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.getmateo.com"
  },
  "servers": [
    {
      "url": "https://integration.getmateo.com/api/v1",
      "description": "Mateo Integration API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/segment": {
      "get": {
        "operationId": "listSegments",
        "summary": "List segments",
        "description": "Retrieve a list of segments with filtering options.",
        "tags": ["Segments"],
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "select", "in": "query", "description": "Comma-separated list of fields to return", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of segments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Segment" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/appointment": {
      "get": {
        "operationId": "listAppointments",
        "summary": "List appointments",
        "description": "Retrieve appointments ordered by start_time.",
        "tags": ["Appointments"],
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "select", "in": "query", "schema": { "type": "string" } },
          { "name": "order", "in": "query", "description": "Order by start_time", "schema": { "type": "string", "enum": ["start_time.asc", "start_time.desc"] } }
        ],
        "responses": {
          "200": {
            "description": "List of appointments",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Appointment" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createAppointment",
        "summary": "Create an appointment",
        "tags": ["Appointments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AppointmentCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Appointment created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Appointment" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateAppointment",
        "summary": "Update an appointment",
        "tags": ["Appointments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AppointmentUpdate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Appointment updated" }
        }
      },
      "delete": {
        "operationId": "deleteAppointment",
        "summary": "Delete an appointment",
        "tags": ["Appointments"],
        "responses": {
          "200": { "description": "Appointment deleted" }
        }
      }
    },
    "/deal": {
      "get": {
        "operationId": "listDeals",
        "summary": "List deals",
        "description": "Retrieve deals with ordering by lost_at or won_at.",
        "tags": ["Deals"],
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "select", "in": "query", "schema": { "type": "string" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["lost_at.asc", "lost_at.desc", "won_at.asc", "won_at.desc"] } }
        ],
        "responses": {
          "200": {
            "description": "List of deals",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Deal" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createDeal",
        "summary": "Create a deal",
        "tags": ["Deals"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DealCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deal created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Deal" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateDeal",
        "summary": "Update a deal",
        "tags": ["Deals"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DealCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Deal updated" }
        }
      },
      "delete": {
        "operationId": "deleteDeal",
        "summary": "Delete a deal",
        "tags": ["Deals"],
        "responses": {
          "200": { "description": "Deal deleted" }
        }
      }
    },
    "/message": {
      "get": {
        "operationId": "listMessages",
        "summary": "List messages",
        "description": "Retrieve messages ordered by timestamp.",
        "tags": ["Messages"],
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "select", "in": "query", "schema": { "type": "string" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["timestamp.asc", "timestamp.desc"] } }
        ],
        "responses": {
          "200": {
            "description": "List of messages",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Message" } }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteMessage",
        "summary": "Delete a message",
        "tags": ["Messages"],
        "responses": {
          "200": { "description": "Message deleted" }
        }
      }
    },
    "/channel": {
      "get": {
        "operationId": "listChannels",
        "summary": "List channels",
        "description": "Retrieve communication channels ordered by name.",
        "tags": ["Channels"],
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "select", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of channels",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Channel" } }
              }
            }
          }
        }
      }
    },
    "/tag": {
      "get": {
        "operationId": "listTags",
        "summary": "List tags",
        "description": "Retrieve tags ordered by name.",
        "tags": ["Tags"],
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "select", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of tags",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Tag" } }
              }
            }
          }
        }
      }
    },
    "/custom_field": {
      "get": {
        "operationId": "listCustomFields",
        "summary": "List custom fields",
        "tags": ["Custom Fields"],
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of custom fields",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CustomField" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCustomField",
        "summary": "Create a custom field",
        "tags": ["Custom Fields"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CustomFieldCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Custom field created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CustomField" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateCustomField",
        "summary": "Update a custom field",
        "tags": ["Custom Fields"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CustomFieldCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Custom field updated" }
        }
      },
      "delete": {
        "operationId": "deleteCustomField",
        "summary": "Delete a custom field",
        "tags": ["Custom Fields"],
        "responses": {
          "200": { "description": "Custom field deleted" }
        }
      }
    },
    "/deal_type": {
      "get": {
        "operationId": "listDealTypes",
        "summary": "List deal types",
        "tags": ["Deals"],
        "responses": {
          "200": {
            "description": "List of deal types",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/DealType" } }
              }
            }
          }
        }
      }
    },
    "/appointment_status": {
      "get": {
        "operationId": "listAppointmentStatuses",
        "summary": "List appointment statuses",
        "tags": ["Appointments"],
        "responses": {
          "200": {
            "description": "List of appointment statuses",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AppointmentStatus" } }
              }
            }
          }
        }
      }
    },
    "/event": {
      "get": {
        "operationId": "listEvents",
        "summary": "List events",
        "description": "Retrieve system events ordered by created_at.",
        "tags": ["Events"],
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["created_at.asc", "created_at.desc"] } }
        ],
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Event" } }
              }
            }
          }
        }
      }
    },
    "/contact_custom_field": {
      "get": {
        "operationId": "listContactCustomFields",
        "summary": "List contact custom field values",
        "tags": ["Contact Custom Fields"],
        "responses": {
          "200": {
            "description": "Contact custom field values",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ContactCustomField" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createContactCustomField",
        "summary": "Set contact custom field value",
        "tags": ["Contact Custom Fields"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactCustomFieldCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Contact custom field value set" }
        }
      },
      "patch": {
        "operationId": "updateContactCustomField",
        "summary": "Update contact custom field value",
        "tags": ["Contact Custom Fields"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactCustomFieldCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Contact custom field value updated" }
        }
      },
      "delete": {
        "operationId": "deleteContactCustomField",
        "summary": "Delete contact custom field value",
        "tags": ["Contact Custom Fields"],
        "responses": {
          "200": { "description": "Contact custom field value deleted" }
        }
      }
    },
    "/appointment_custom_field": {
      "get": {
        "operationId": "listAppointmentCustomFields",
        "summary": "List appointment custom field values",
        "tags": ["Appointment Custom Fields"],
        "responses": {
          "200": {
            "description": "Appointment custom field values",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AppointmentCustomField" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createAppointmentCustomField",
        "summary": "Set appointment custom field value",
        "tags": ["Appointment Custom Fields"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AppointmentCustomFieldCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Appointment custom field value set" }
        }
      },
      "patch": {
        "operationId": "updateAppointmentCustomField",
        "summary": "Update appointment custom field value",
        "tags": ["Appointment Custom Fields"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AppointmentCustomFieldCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Appointment custom field value updated" }
        }
      },
      "delete": {
        "operationId": "deleteAppointmentCustomField",
        "summary": "Delete appointment custom field value",
        "tags": ["Appointment Custom Fields"],
        "responses": {
          "200": { "description": "Appointment custom field value deleted" }
        }
      }
    },
    "/marketing_subscription": {
      "get": {
        "operationId": "listMarketingSubscriptions",
        "summary": "List marketing subscriptions",
        "tags": ["Marketing"],
        "responses": {
          "200": {
            "description": "List of marketing subscriptions",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/MarketingSubscription" } }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createMarketingSubscription",
        "summary": "Create a marketing subscription",
        "tags": ["Marketing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MarketingSubscriptionCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Subscription created" }
        }
      },
      "patch": {
        "operationId": "updateMarketingSubscription",
        "summary": "Update a marketing subscription",
        "tags": ["Marketing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MarketingSubscriptionCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Subscription updated" }
        }
      },
      "delete": {
        "operationId": "deleteMarketingSubscription",
        "summary": "Delete a marketing subscription",
        "tags": ["Marketing"],
        "responses": {
          "200": { "description": "Subscription deleted" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Segment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Appointment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "start_time": { "type": "string", "format": "date-time" },
          "end_time": { "type": "string", "format": "date-time" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "AppointmentCreate": {
        "type": "object",
        "required": ["title", "start_time"],
        "properties": {
          "title": { "type": "string" },
          "start_time": { "type": "string", "format": "date-time" },
          "end_time": { "type": "string", "format": "date-time" },
          "status": { "type": "string" }
        }
      },
      "AppointmentUpdate": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "start_time": { "type": "string", "format": "date-time" },
          "end_time": { "type": "string", "format": "date-time" },
          "status": { "type": "string" }
        }
      },
      "Deal": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "value": { "type": "number" },
          "status": { "type": "string" },
          "won_at": { "type": "string", "format": "date-time" },
          "lost_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "DealCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "number" },
          "status": { "type": "string" }
        }
      },
      "DealType": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "channel_id": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Channel": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "CustomField": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["date", "string", "number", "boolean", "datetime", "string_list"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CustomFieldCreate": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["date", "string", "number", "boolean", "datetime", "string_list"] }
        }
      },
      "AppointmentStatus": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "data": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ContactCustomField": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "contact_id": { "type": "string" },
          "custom_field_id": { "type": "string" },
          "value": { "type": "string" }
        }
      },
      "ContactCustomFieldCreate": {
        "type": "object",
        "required": ["contact_id", "custom_field_id", "value"],
        "properties": {
          "contact_id": { "type": "string" },
          "custom_field_id": { "type": "string" },
          "value": { "type": "string" }
        }
      },
      "AppointmentCustomField": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "appointment_id": { "type": "string" },
          "custom_field_id": { "type": "string" },
          "value": { "type": "string" }
        }
      },
      "AppointmentCustomFieldCreate": {
        "type": "object",
        "required": ["appointment_id", "custom_field_id", "value"],
        "properties": {
          "appointment_id": { "type": "string" },
          "custom_field_id": { "type": "string" },
          "value": { "type": "string" }
        }
      },
      "MarketingSubscription": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "channel_id": { "type": "string" },
          "contact_id": { "type": "string" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "MarketingSubscriptionCreate": {
        "type": "object",
        "required": ["channel_id", "contact_id"],
        "properties": {
          "channel_id": { "type": "string" },
          "contact_id": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}