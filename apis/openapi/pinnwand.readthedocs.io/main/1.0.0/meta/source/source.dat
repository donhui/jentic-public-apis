{
  "openapi": "3.0.3",
  "info": {
    "title": "Pinnwand API",
    "description": "REST API for Pinnwand (BPaste), an open-source pastebin service. Allows creating pastes via JSON API and retrieving raw paste content.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://github.com/supakeen/pinnwand"
  },
  "servers": [
    {
      "url": "https://bpaste.net",
      "description": "BPaste public instance"
    }
  ],
  "paths": {
    "/api/v1/paste": {
      "post": {
        "operationId": "createPaste",
        "summary": "Create a new paste",
        "description": "Creates a new paste with one or more files. Returns the paste URL and a removal URL.",
        "tags": ["Pastes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasteCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Paste created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PasteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/curl": {
      "post": {
        "operationId": "createPasteViaCurl",
        "summary": "Create a paste via curl",
        "description": "Simplified endpoint for creating pastes from curl. Defaults to text lexer and 1 day expiry.",
        "tags": ["Pastes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["raw"],
                "properties": {
                  "raw": {
                    "type": "string",
                    "description": "Raw text content of the paste"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Paste created. Returns URLs for paste, raw, and removal.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/raw/{id}": {
      "get": {
        "operationId": "getRawPaste",
        "summary": "Get raw paste content",
        "description": "Retrieves the raw text content of a paste.",
        "tags": ["Pastes"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Paste identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Raw paste content",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Paste not found"
          }
        }
      }
    },
    "/remove/{token}": {
      "get": {
        "operationId": "removePaste",
        "summary": "Remove a paste",
        "description": "Removes a paste using its removal token.",
        "tags": ["Pastes"],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Removal token provided when the paste was created"
          }
        ],
        "responses": {
          "200": {
            "description": "Paste removed successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Paste not found or invalid token"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PasteCreate": {
        "type": "object",
        "required": ["expiry", "files"],
        "properties": {
          "expiry": {
            "type": "string",
            "description": "Expiration time (e.g., '1hour', '1day', '1week')"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PasteFile"
            },
            "description": "Array of file objects to include in the paste"
          }
        }
      },
      "PasteFile": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "name": {
            "type": "string",
            "description": "File name"
          },
          "lexer": {
            "type": "string",
            "description": "Syntax highlighting lexer (e.g., 'python', 'text')",
            "default": "text"
          },
          "content": {
            "type": "string",
            "description": "File content"
          }
        }
      },
      "PasteResponse": {
        "type": "object",
        "properties": {
          "link": {
            "type": "string",
            "format": "uri",
            "description": "URL to view the paste"
          },
          "removal": {
            "type": "string",
            "format": "uri",
            "description": "URL to remove the paste"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}