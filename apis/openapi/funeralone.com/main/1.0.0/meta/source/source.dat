{
  "openapi": "3.0.3",
  "info": {
    "title": "funeralOne API",
    "description": "API for managing funeral cases on the funeralOne platform.",
    "version": "1.0.0",
    "contact": {
      "name": "funeralOne",
      "url": "https://api.funeralone.com/docs/"
    }
  },
  "servers": [
    {
      "url": "https://api.funeralone.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cases",
      "description": "Operations for creating, updating, and retrieving funeral cases"
    }
  ],
  "paths": {
    "/cases": {
      "post": {
        "operationId": "createOrUpdateCase",
        "summary": "Create or update a case",
        "description": "Creates a new case or updates an existing one. Returns 201 when a new case is created, or 200 when an existing case is updated.",
        "tags": ["Cases"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Case updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaseDetails"
                }
              }
            }
          },
          "201": {
            "description": "Case created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaseDetails"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/cases/AccountExternalId/{AccountExternalId}": {
      "get": {
        "operationId": "listCasesByAccount",
        "summary": "List all cases for an account",
        "description": "Returns an array of case summaries for the specified account.",
        "tags": ["Cases"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountExternalIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "List of case summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CaseSummary"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/cases/AccountExternalId/{AccountExternalId}/CaseExternalId/{CaseExternalId}": {
      "get": {
        "operationId": "getCaseByExternalId",
        "summary": "Get a specific case",
        "description": "Returns full details for a specific case identified by account and case external IDs.",
        "tags": ["Cases"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountExternalIdPath"
          },
          {
            "$ref": "#/components/parameters/CaseExternalIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Full case details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaseDetails"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication. Use your API key as the username and leave the password blank or use a dummy value."
      }
    },
    "parameters": {
      "AccountExternalIdPath": {
        "name": "AccountExternalId",
        "in": "path",
        "required": true,
        "description": "The external identifier for the account",
        "schema": {
          "type": "string"
        }
      },
      "CaseExternalIdPath": {
        "name": "CaseExternalId",
        "in": "path",
        "required": true,
        "description": "The external identifier for the case",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Location": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string",
            "description": "Name of the location"
          },
          "Address": {
            "type": "string",
            "description": "Street address"
          },
          "City": {
            "type": "string",
            "description": "City"
          },
          "State": {
            "type": "string",
            "description": "State or province"
          },
          "Zip": {
            "type": "string",
            "description": "ZIP or postal code"
          },
          "Country": {
            "type": "string",
            "description": "Country"
          },
          "Phone": {
            "type": "string",
            "description": "Phone number"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "EventType": {
            "type": "string",
            "description": "Type of event (e.g., Visitation, Funeral Service, Burial)"
          },
          "Date": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time of the event"
          },
          "EndDate": {
            "type": "string",
            "format": "date-time",
            "description": "End date and time of the event"
          },
          "Location": {
            "$ref": "#/components/schemas/Location"
          },
          "Description": {
            "type": "string",
            "description": "Additional details about the event"
          }
        }
      },
      "FamilyAdmin": {
        "type": "object",
        "properties": {
          "FirstName": {
            "type": "string",
            "description": "First name of the family admin"
          },
          "LastName": {
            "type": "string",
            "description": "Last name of the family admin"
          },
          "Email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the family admin"
          },
          "Phone": {
            "type": "string",
            "description": "Phone number of the family admin"
          },
          "Relationship": {
            "type": "string",
            "description": "Relationship to the deceased"
          }
        }
      },
      "CaseRequest": {
        "type": "object",
        "required": [
          "AccountExternalId",
          "CaseExternalId",
          "ServingLocation",
          "Cemetery"
        ],
        "properties": {
          "AccountExternalId": {
            "type": "string",
            "description": "External identifier for the account"
          },
          "CaseExternalId": {
            "type": "string",
            "description": "External identifier for the case"
          },
          "FirstName": {
            "type": "string",
            "description": "First name of the deceased"
          },
          "LastName": {
            "type": "string",
            "description": "Last name of the deceased"
          },
          "DateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "Date of birth of the deceased"
          },
          "DateOfDeath": {
            "type": "string",
            "format": "date",
            "description": "Date of death of the deceased"
          },
          "ServingLocation": {
            "$ref": "#/components/schemas/Location"
          },
          "Cemetery": {
            "$ref": "#/components/schemas/Location"
          },
          "Events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            },
            "description": "List of events associated with the case"
          },
          "Locations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Location"
            },
            "description": "Additional locations associated with the case"
          },
          "FamilyAdmins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FamilyAdmin"
            },
            "description": "Family administrators for the case"
          }
        }
      },
      "CaseSummary": {
        "type": "object",
        "properties": {
          "AccountExternalId": {
            "type": "string",
            "description": "External identifier for the account"
          },
          "CaseExternalId": {
            "type": "string",
            "description": "External identifier for the case"
          },
          "FirstName": {
            "type": "string",
            "description": "First name of the deceased"
          },
          "LastName": {
            "type": "string",
            "description": "Last name of the deceased"
          },
          "DateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "Date of birth of the deceased"
          },
          "DateOfDeath": {
            "type": "string",
            "format": "date",
            "description": "Date of death of the deceased"
          }
        }
      },
      "CaseDetails": {
        "type": "object",
        "properties": {
          "AccountExternalId": {
            "type": "string",
            "description": "External identifier for the account"
          },
          "CaseExternalId": {
            "type": "string",
            "description": "External identifier for the case"
          },
          "FirstName": {
            "type": "string",
            "description": "First name of the deceased"
          },
          "LastName": {
            "type": "string",
            "description": "Last name of the deceased"
          },
          "DateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "Date of birth of the deceased"
          },
          "DateOfDeath": {
            "type": "string",
            "format": "date",
            "description": "Date of death of the deceased"
          },
          "ServingLocation": {
            "$ref": "#/components/schemas/Location"
          },
          "Cemetery": {
            "$ref": "#/components/schemas/Location"
          },
          "Events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "Locations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Location"
            }
          },
          "FamilyAdmins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FamilyAdmin"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of specific validation errors"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad Request - The request was invalid or missing required fields",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - Invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Not Found - The specified resource was not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  }
}
