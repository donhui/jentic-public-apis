  "paths": {
    "/groovedigital/plugins/add": {
      "post": {
        "summary": "Add plugins",
        "requestBody": {
          "$ref": "#/components/requestBodies/pluginData"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Success"
          },
          "500": {
            "$ref": "#/components/responses/GeneralError"
          }
        },
        "security": []
      }
    },
    "/groovedigital/plugins/call/{plugin_type}": {
      "post": {
        "summary": "Call a serverside plugin with the default integration",
        "parameters": [
          {
            "$ref": "#/components/parameters/pluginTypeParam"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {}
          }
        },
        "responses": {
          "200": {
            "description": "Plugin response",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "$ref": "#/components/responses/GeneralError"
          }
        },
        "security": []
      },
      "get": {
        "summary": "Call a serverside plugin with the default integration",
        "parameters": [
          {
            "$ref": "#/components/parameters/pluginTypeParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Plugin response",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "$ref": "#/components/responses/GeneralError"
          }
        },
        "security": []
      }
    },
    "/groovedigital/plugins/call/{plugin_type}/{integration_id}": {
      "post": {
        "summary": "Call a serverside plugin with a specific integration",
        "parameters": [
          {
            "$ref": "#/components/parameters/integrationIdParam"
          },
          {
            "$ref": "#/components/parameters/pluginTypeParam"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {}
          }
        },
        "responses": {
          "200": {
            "description": "Plugin response",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "$ref": "#/components/responses/GeneralError"
          }
        },
        "security": []
      },
      "get": {
        "summary": "Call a serverside plugin with a specific integration",
        "parameters": [
          {
            "$ref": "#/components/parameters/integrationIdParam"
          },
          {
            "$ref": "#/components/parameters/pluginTypeParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Plugin response",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "$ref": "#/components/responses/GeneralError"
          }
        },
        "security": []
      }
    },
    "/groovedigital/plugins/delete/{plugin_type}/{integration_id}": {
      "delete": {
        "summary": "Delete any data stored by a plugin",
        "parameters": [
          {
            "$ref": "#/components/parameters/integrationIdParam"
          },
          {
            "$ref": "#/components/parameters/pluginTypeParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "401": {
            "$ref": "#/components/responses/NotLoggedInAuthError"
          },
          "403": {
            "$ref": "#/components/responses/IncorrectUserAuthError"
          },
          "500": {
            "$ref": "#/components/responses/GeneralError"
          }
        }
      }
    },
    "/groovedigital/plugins/call/zapier/{integration_id}": {
      "post": {
        "summary": "Create the zapier integration with a specific integration ID",
        "parameters": [
          {
            "$ref": "#/components/parameters/integrationIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Subscribe/Unsubscribe zapier hook or get latest submission data based on the 'action' value",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "example": "set-webhook"
                  },
                  "hookUrl": {
                    "type": "string",
                    "example": "https://hooks.zapier.com/hooks/catch/7718817/osvr9a1/"
                  }
                },
                "required": [
                  "action"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Plugin response",
            "content": {
              "application/json": {}
            }
          },
          "500": {
            "$ref": "#/components/responses/GeneralError"
          }
        },
        "security": []
      }
    },
    "/groovedigital/plugins/components/list": {
      "get": {
        "summary": "List all component type plugins",
        "responses": {
          "200": {
            "$ref": "#/components/responses/PluginList"
