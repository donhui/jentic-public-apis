        "items": {
          "$ref": "#/components/schemas/Plugin"
        }
      },
      "User": {
        "properties": {
          "id": {
            "description": "Auth0 generated user ID",
            "type": "string"
          },
          "token": {
            "description": "Auth0 access token",
            "type": "string",
            "readOnly": true
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "user_level": {
