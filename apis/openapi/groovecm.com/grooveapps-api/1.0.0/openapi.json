            "readOnly": true
          },
          "markup": {
            "type": "string"
          },
          "thumbnail": {
            "type": "string",
            "readOnly": true
          },
          "screenshotMarkup": {
            "type": "string",
            "writeOnly": true
          }
        }
      },
      "ComponentsList": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "readOnly": true
            },
            "type": {
              "type": "string",
              "readOnly": true
            },
            "category": {
              "type": "string",
              "readOnly": true
            },
            "thumbnail": {
              "type": "string",
              "readOnly": true
            }
