  "paths": {
    "/coupons": {
      "post": {
        "summary": "Create a coupon",
        "description": "Create a coupon code.",
        "operationId": "create",
        "responses": {
          "200": {
            "description": "200",
            "content": {
              "application/json": {
                "examples": {
                  "Result": {
                    "value": "{\n  \"id\": 994,\n  \"name\": \"XL0MJ\",\n  \"amount\": 25,\n  \"exclusives\": 1,\n  \"userId\": 77,\n  \"upgrades\": 0,\n  \"type\": \"rate\",\n  \"neverEnd\": 0,\n  \"active\": 1,\n  \"maxUsage\": 0,\n  \"stopBulkDiscounts\": 0,\n  \"minCartAmount\": 0,\n  \"minCartItems\": 0,\n  \"startDate\": 1668867321,\n  \"endDate\": 1669558521,\n  \"created\": 1668953721,\n  \"amount_off_string\": \"25% OFF\",\n  \"used\": 0,\n  \"conditions\": {\n    \"entityTypes\": {\n      \"list\": [],\n      \"exclude\": 0\n    },\n    \"entities\": {\n      \"list\": [],\n      \"exclude\": 0\n    },\n    \"stores\": {\n      \"list\": [],\n      \"exclude\": 0\n    },\n    \"licenses\": {\n      \"list\": [],\n      \"exclude\": 0\n    }\n  }\n}"
                  }
                },
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "example": 994,
                      "default": 0
                    },
                    "name": {
                      "type": "string",
                      "example": "XL0MJ"
                    },
                    "amount": {
                      "type": "integer",
                      "example": 25,
                      "default": 0
                    },
                    "exclusives": {
                      "type": "integer",
                      "example": 1,
                      "default": 0
                    },
                    "userId": {
                      "type": "integer",
                      "example": 77,
                      "default": 0
                    },
                    "upgrades": {
                      "type": "integer",
                      "example": 0,
                      "default": 0
                    },
                    "type": {
                      "type": "string",
                      "example": "rate"
                    },
                    "neverEnd": {
                      "type": "integer",
                      "example": 0,
                      "default": 0
                    },
                    "active": {
                      "type": "integer",
                      "example": 1,
                      "default": 0
                    },
                    "maxUsage": {
                      "type": "integer",
                      "example": 0,
                      "default": 0
                    },
                    "stopBulkDiscounts": {
                      "type": "integer",
                      "example": 0,
                      "default": 0
                    },
                    "minCartAmount": {
                      "type": "integer",
                      "example": 0,
                      "default": 0
                    },
                    "minCartItems": {
                      "type": "integer",
                      "example": 0,
                      "default": 0
                    },
                    "startDate": {
                      "type": "integer",
                      "example": 1668867321,
                      "default": 0
                    },
                    "endDate": {
                      "type": "integer",
                      "example": 1669558521,
                      "default": 0
                    },
                    "created": {
                      "type": "integer",
                      "example": 1668953721,
                      "default": 0
                    },
                    "amount_off_string": {
                      "type": "string",
                      "example": "25% OFF"
                    },
                    "used": {
                      "type": "integer",
                      "example": 0,
                      "default": 0
                    },
                    "conditions": {
                      "type": "object",
                      "properties": {
                        "entityTypes": {
                          "type": "object",
                          "properties": {
                            "list": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {}
                              }
                            },
                            "exclude": {
                              "type": "integer",
                              "example": 0,
                              "default": 0
                            }
                          }
                        },
                        "entities": {
                          "type": "object",
                          "properties": {
                            "list": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {}
                              }
                            },
                            "exclude": {
                              "type": "integer",
                              "example": 0,
                              "default": 0
                            }
                          }
                        },
                        "stores": {
                          "type": "object",
                          "properties": {
                            "list": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {}
                              }
                            },
                            "exclude": {
                              "type": "integer",
                              "example": 0,
                              "default": 0
                            }
                          }
                        },
                        "licenses": {
                          "type": "object",
                          "properties": {
                            "list": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {}
                              }
                            },
                            "exclude": {
                              "type": "integer",
                              "example": 0,
                              "default": 0
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "400",
            "content": {
              "application/json": {
                "examples": {
