    "/email-captures": {
      "get": {
        "summary": "Get",
        "description": "Get your captured emails.",
        "operationId": "read-2",
        "parameters": [
          {
            "name": "list_type",
            "in": "query",
            "description": "`download` - Gets all email captures by free download requests.  `transaction` - Gets all email captures by transactions.  `store-email-opt-in` - Gets all email captures by opt-ins from your stores.  `exit-intent-opt-in` - Gets all email captures by exit-intent opt-ins.",
            "schema": {
              "type": "string",
              "enum": [
                "download",
                "transaction",
                "store-email-opt-in",
                "exit-intent-opt-in"
              ]
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Search captures by email, first name, last name or phone.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "200",
