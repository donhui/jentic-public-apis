{
  "openapi": "3.0.3",
  "info": {
    "title": "Landrr API",
    "description": "Landrr is an intuitive app designed for business owners to efficiently manage and optimize their marketing campaigns using chatbots and AI. This API provides access to authentication, campaign management, lead retrieval, and Zapier webhook integration.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://landrrapp.io/api/documentation/"
  },
  "servers": [
    {
      "url": "https://api.landrrapp.io/api",
      "description": "Landrr Production API"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "API key verification"
    },
    {
      "name": "Campaigns",
      "description": "Campaign management"
    },
    {
      "name": "Leads",
      "description": "Lead retrieval"
    },
    {
      "name": "Zapier",
      "description": "Zapier webhook integration"
    }
  ],
  "paths": {
    "/auth": {
      "get": {
        "operationId": "verifyAuth",
        "summary": "Verify Authentication",
        "description": "Verifies API key credentials.",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "description": "The API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Authentication successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Missing or invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getCampaigns": {
      "get": {
        "operationId": "getCampaigns",
        "summary": "Get Campaigns",
        "description": "Retrieves a list of campaigns created in Landrr.",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "description": "The API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of campaigns.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getEmailLeadsFromapi": {
      "get": {
        "operationId": "getLeads",
        "summary": "Get Leads",
        "description": "Retrieves leads from campaigns in Landrr.",
        "tags": ["Leads"],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "description": "The API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of leads.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeadListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/zapier/subscribe": {
      "post": {
        "operationId": "zapierSubscribe",
        "summary": "Zap Subscribe",
        "description": "Subscribe API executed from the Zapier platform the first time a user publishes a Zap.",
        "tags": ["Zapier"],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "description": "The API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ZapierSubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZapierSubscribeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/zapier/unsubscribe": {
      "post": {
        "operationId": "zapierUnsubscribe",
        "summary": "Zap Unsubscribe",
        "description": "Unsubscribe API executed when a Zap is disabled.",
        "tags": ["Zapier"],
        "parameters": [
          {
            "name": "apiKey",
            "in": "query",
            "required": true,
            "description": "The API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Unsubscription successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZapierUnsubscribeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "apiKey",
        "description": "API key passed as a query parameter."
      }
    },
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "description": "Whether the API key is valid."
          },
          "message": {
            "type": "string",
            "description": "Authentication status message."
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique campaign identifier."
          },
          "name": {
            "type": "string",
            "description": "Campaign name."
          },
          "status": {
            "type": "string",
            "description": "Campaign status."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp."
          }
        }
      },
      "CampaignListResponse": {
        "type": "object",
        "properties": {
          "campaigns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Campaign"
            }
          }
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique lead identifier."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Lead email address."
          },
          "campaign_id": {
            "type": "string",
            "description": "ID of the campaign the lead belongs to."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the lead was captured."
          }
        }
      },
      "LeadListResponse": {
        "type": "object",
        "properties": {
          "leads": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Lead"
            }
          }
        }
      },
      "ZapierSubscribeRequest": {
        "type": "object",
        "required": ["hookUrl"],
        "properties": {
          "hookUrl": {
            "type": "string",
            "format": "uri",
            "description": "The webhook URL to send events to."
          },
          "type": {
            "type": "string",
            "description": "Optional event type filter."
          }
        }
      },
      "ZapierSubscribeResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Subscription identifier."
          },
          "message": {
            "type": "string",
            "description": "Subscription confirmation message."
          }
        }
      },
      "ZapierUnsubscribeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Unsubscription confirmation message."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message."
          },
          "code": {
            "type": "integer",
            "description": "Error code."
          }
        }
      }
    }
  }
}