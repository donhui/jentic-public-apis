{
  "openapi": "3.0.3",
  "info": {
    "title": "Movebank API",
    "version": "1.0.0",
    "description": "REST API for Movebank, an online database of animal tracking data hosted by the Max Planck Institute for Animal Behavior. Provides access to studies, individuals, tags, deployments, and tracking events. Returns CSV or JSON format.",
    "x-jentic-source-url": "https://github.com/movebank/movebank-api-doc"
  },
  "servers": [
    {
      "url": "https://www.movebank.org/movebank/service"
    }
  ],
  "paths": {
    "/direct-read": {
      "get": {
        "operationId": "queryEntities",
        "summary": "Query entities",
        "description": "Query Movebank entities (studies, individuals, tags, deployments, events, tag types) using the entity_type parameter. Returns CSV or JSON depending on Accept header.",
        "tags": ["Data"],
        "parameters": [
          {
            "name": "entity_type",
            "in": "query",
            "required": true,
            "description": "The type of entity to query: study, individual, tag, deployment, event, tag_type.",
            "schema": { "type": "string", "enum": ["study", "individual", "tag", "deployment", "event", "tag_type"] }
          },
          {
            "name": "study_id",
            "in": "query",
            "description": "Filter by study ID.",
            "schema": { "type": "integer" }
          },
          {
            "name": "individual_id",
            "in": "query",
            "description": "Filter events by individual ID.",
            "schema": { "type": "integer" }
          },
          {
            "name": "sensor_type",
            "in": "query",
            "description": "Filter events by sensor type ID.",
            "schema": { "type": "integer" }
          },
          {
            "name": "timestamp_start",
            "in": "query",
            "description": "Start of timestamp range (ISO 8601).",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "timestamp_end",
            "in": "query",
            "description": "End of timestamp range (ISO 8601).",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "attributes",
            "in": "query",
            "description": "Comma-separated list of attributes to return.",
            "schema": { "type": "string" }
          },
          {
            "name": "i_am_owner",
            "in": "query",
            "description": "Filter studies owned by the authenticated user (true/false).",
            "schema": { "type": "boolean" }
          },
          {
            "name": "i_can_see_data",
            "in": "query",
            "description": "Filter studies where user can see data (true/false).",
            "schema": { "type": "boolean" }
          },
          {
            "name": "i_have_download_access",
            "in": "query",
            "description": "Filter studies where user has download access (true/false).",
            "schema": { "type": "boolean" }
          },
          {
            "name": "license-md5",
            "in": "query",
            "description": "MD5 hash of accepted license terms.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response in CSV or JSON format",
            "content": {
              "text/csv": {
                "schema": { "type": "string" }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Entity" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized - authentication required" }
        }
      }
    },
    "/direct-read?attributes": {
      "get": {
        "operationId": "listAttributes",
        "summary": "List available attributes",
        "description": "List all available attributes for an entity type.",
        "tags": ["Metadata"],
        "parameters": [
          {
            "name": "entity_type",
            "in": "query",
            "description": "The entity type to list attributes for.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of available attributes",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/request-token": {
      "get": {
        "operationId": "requestApiToken",
        "summary": "Request API token",
        "description": "Request an API token for subsequent authenticated requests. Requires Basic authentication.",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "API token returned",
            "content": {
              "text/plain": {
                "schema": { "type": "string", "description": "The API token." }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized - invalid credentials" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Entity": {
        "type": "object",
        "description": "Generic entity object; fields vary by entity_type.",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "study_id": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" },
          "location_lat": { "type": "number" },
          "location_long": { "type": "number" },
          "sensor_type_id": { "type": "integer" },
          "individual_id": { "type": "integer" },
          "tag_id": { "type": "integer" }
        }
      },
      "Study": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "principal_investigator_name": { "type": "string" },
          "number_of_individuals": { "type": "integer" },
          "number_of_tags": { "type": "integer" },
          "study_type": { "type": "string" },
          "license_type": { "type": "string" },
          "timestamp_first_deployed_location": { "type": "string", "format": "date-time" },
          "timestamp_last_deployed_location": { "type": "string", "format": "date-time" }
        }
      },
      "Individual": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "local_identifier": { "type": "string" },
          "nick_name": { "type": "string" },
          "sex": { "type": "string" },
          "taxon_canonical_name": { "type": "string" },
          "study_id": { "type": "integer" }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "event_id": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" },
          "location_lat": { "type": "number" },
          "location_long": { "type": "number" },
          "individual_id": { "type": "integer" },
          "tag_id": { "type": "integer" },
          "sensor_type_id": { "type": "integer" },
          "study_id": { "type": "integer" }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication with Movebank username and password."
      },
      "apiToken": {
        "type": "apiKey",
        "in": "query",
        "name": "api-token",
        "description": "API token obtained via the request-token endpoint."
      }
    }
  },
  "security": [
    { "basicAuth": [] },
    { "apiToken": [] }
  ]
}