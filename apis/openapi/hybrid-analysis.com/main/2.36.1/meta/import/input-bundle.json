            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sample binary",
            "content": {
              "application/gzip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/submit/file": {
      "post": {
        "operationId": "submitFile",
        "tags": [
          "Submit"
        ],
        "summary": "Submit a file for analysis",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "environment_id"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "environment_id": {
                    "type": "integer",
                    "description": "Environment ID (100=Win7 32bit, 120=Win7 64bit, etc.)"
                  },
                  "action_script": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  },
                  "custom_cmd_line": {
                    "type": "string"
                  },
                  "custom_run_time": {
                    "type": "integer"
                  },
                  "document_password": {
                    "type": "string"
                  },
                  "network_settings": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/submit/url": {
      "post": {
        "operationId": "submitUrl",
        "tags": [
