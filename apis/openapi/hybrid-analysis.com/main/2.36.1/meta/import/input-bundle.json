{
  "openapi": "3.0.3",
  "info": {
    "title": "Falcon Sandbox API",
    "version": "2.36.1",
    "description": "Hybrid Analysis / Falcon Sandbox public API for malware analysis. Submit files and URLs for analysis, retrieve reports, search for threats, and access threat intelligence feeds.",
    "x-jentic-source-url": "https://hybrid-analysis.com/docs/api/v2"
  },
  "servers": [
    {
      "url": "https://hybrid-analysis.com/api/v2",
      "description": "Production"
    }
  ],
