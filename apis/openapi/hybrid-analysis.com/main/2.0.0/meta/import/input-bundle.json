{
  "openapi": "3.0.3",
  "info": {
    "title": "Hybrid Analysis API",
    "description": "Hybrid Analysis provides a free malware analysis service powered by CrowdStrike Falcon Sandbox. The API allows submitting files and URLs for analysis, searching for existing reports, and accessing threat intelligence feeds. A User-Agent header (e.g. 'Falcon Sandbox') is recommended. Rate limits are returned in Api-Limits, Submission-Limits, Quick-Scan-Limits, and Sample-Download-Limits response headers. API keys have authorization levels: restricted, default, elevated, and super.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://hybrid-analysis.com/docs/api/v2"
  },
  "servers": [
    {
      "url": "https://www.hybrid-analysis.com/api/v2",
      "description": "Hybrid Analysis API v2"
    }
  ],
  "paths": {
    "/search/hash": {
      "post": {
        "tags": [
          "Search"
        ],
        "summary": "Search by hash (MD5, SHA1, SHA256)",
        "operationId": "searchByHash",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "hash"
                ],
                "properties": {
                  "hash": {
                    "type": "string",
                    "description": "MD5, SHA1, or SHA256 hash"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "apiKeyHeader": []
          }
        ]
      }
    },
    "/search/terms": {
      "post": {
        "tags": [
          "Search"
        ],
        "summary": "Search by various terms",
        "operationId": "searchByTerms",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "filename": {
                    "type": "string"
                  },
                  "filetype": {
                    "type": "string"
                  },
                  "filetype_desc": {
                    "type": "string"
                  },
                  "env_id": {
                    "type": "integer"
                  },
                  "country": {
                    "type": "string"
                  },
                  "verdict": {
                    "type": "integer",
                    "enum": [
                      1,
                      2,
                      3,
                      4,
                      5
                    ]
                  },
                  "av_detect": {
                    "type": "string"
                  },
                  "vx_family": {
                    "type": "string"
                  },
                  "tag": {
                    "type": "string"
                  },
                  "port": {
                    "type": "integer"
                  },
                  "host": {
                    "type": "string"
                  },
                  "domain": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "similar_to": {
                    "type": "string"
                  },
                  "context": {
                    "type": "string"
                  },
                  "imp_hash": {
                    "type": "string"
                  },
                  "ssdeep": {
                    "type": "string"
                  },
                  "authentihash": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "apiKeyHeader": []
          }
        ]
      }
    },
    "/submit/file": {
      "post": {
        "tags": [
          "Submit"
        ],
        "summary": "Submit a file for analysis",
        "operationId": "submitFile",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "environment_id"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "File to analyze"
                  },
                  "environment_id": {
                    "type": "integer",
                    "description": "Environment ID (e.g. 100=Win7 32bit, 110=Win7 64bit, 120=Win10 64bit)"
                  },
                  "no_share_third_party": {
                    "type": "boolean"
                  },
                  "allow_community_access": {
                    "type": "boolean"
                  },
                  "no_hash_lookup": {
                    "type": "boolean"
                  },
                  "action_script": {
                    "type": "string"
                  },
                  "hybrid_analysis": {
                    "type": "boolean"
                  },
                  "experimental_anti_evasion": {
                    "type": "boolean"
                  },
                  "script_logging": {
                    "type": "boolean"
                  },
                  "input_sample_tampering": {
                    "type": "boolean"
                  },
                  "network_settings": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  },
                  "custom_date_time": {
                    "type": "string"
                  },
                  "custom_cmd_line": {
                    "type": "string"
                  },
                  "custom_run_time": {
                    "type": "integer"
                  },
                  "submit_name": {
                    "type": "string"
                  },
                  "document_password": {
                    "type": "string"
                  },
                  "environment_variable": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Submission successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "apiKeyHeader": []
          }
        ]
      }
    },
