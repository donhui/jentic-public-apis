{
  "openapi": "3.0.3",
  "info": {
    "title": "WholeStory Zapier API",
    "version": "1.0.0",
    "description": "API for WholeStory candidate invitation management and session token handling via Zapier integration.",
    "x-jentic-source-url": "https://app.tellyourwholestory.com/apipie"
  },
  "servers": [
    {
      "url": "https://app.tellyourwholestory.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/api/v1/zapier/invitations": {
      "post": {
        "operationId": "createcandidateinvitation",
        "summary": "Create a candidate invitation",
        "description": "Creates a new candidate invitation through the Zapier integration.",
        "tags": [
          "Invitations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CandidateInvitationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invitation created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CandidateInvitationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing session token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "sessionToken": []
          }
        ]
      }
    },
    "/api/v1/zapier/sessions": {
      "get": {
        "operationId": "validatesessiontoken",
        "summary": "Validate a session token",
        "description": "Validates the provided session token and returns session information.",
        "tags": [
          "Sessions"
        ],
        "responses": {
          "200": {
            "description": "Session token is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired session token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "sessionToken": []
          }
        ]
      },
      "post": {
        "operationId": "createsessiontoken",
        "summary": "Create a session token",
        "description": "Creates a new session token for authentication.",
        "tags": [
          "Sessions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session token created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CandidateInvitationRequest": {
        "type": "object",
        "properties": {
          "candidate_email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the candidate to invite"
          },
          "candidate_name": {
            "type": "string",
            "description": "Name of the candidate"
          }
        },
        "required": [
          "candidate_email"
        ]
      },
      "CandidateInvitationResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the invitation"
          },
          "candidate_email": {
            "type": "string",
            "description": "Email address of the invited candidate"
          },
          "status": {
            "type": "string",
            "description": "Status of the invitation"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the invitation was created"
          }
        }
      },
      "SessionCreateRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email for authentication"
          },
          "password": {
            "type": "string",
            "description": "User password for authentication"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SessionResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Session token"
          },
          "valid": {
            "type": "boolean",
            "description": "Whether the session token is valid"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "sessionToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Session token obtained via POST /api/v1/zapier/sessions"
      }
    }
  },
  "security": [
    {
      "sessionToken": []
    }
  ],
  "tags": [
    {
      "name": "Invitations",
      "description": "Operations related to Invitations"
    },
    {
      "name": "Sessions",
      "description": "Operations related to Sessions"
    }
  ]
}