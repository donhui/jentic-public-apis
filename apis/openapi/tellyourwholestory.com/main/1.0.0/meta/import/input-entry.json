{
  "openapi": "3.0.3",
  "info": {
    "title": "WholeStory Zapier API",
    "description": "WholeStory is a technology platform for employers that integrates the candidate's pivotal life experiences into the screening and interview process. This API provides Zapier integration endpoints for session management and candidate invitations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://app.tellyourwholestory.com/apipie"
  },
  "servers": [
    {
      "url": "https://app.tellyourwholestory.com/api/v1/zapier",
      "description": "WholeStory API Server"
    }
  ],
  "paths": {
    "/sessions": {
      "get": {
        "operationId": "validateSessionToken",
        "summary": "Validate a session token",
        "description": "Validates a session token to check if the user is authenticated.",
        "tags": [
          "Sessions"
        ],
        "parameters": [
          {
            "name": "authentication_token",
            "in": "query",
            "description": "A valid session token.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateSessionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad credentials"
          }
        }
      },
      "post": {
        "operationId": "createSessionToken",
        "summary": "Create a session token",
        "description": "Creates a new session token by authenticating with email and password.",
        "tags": [
          "Sessions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session token created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateSessionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad credentials"
          }
        }
      }
    },
    "/invitations": {
      "post": {
        "operationId": "createCandidateInvitation",
        "summary": "Create a candidate invitation",
        "description": "Creates a new candidate invitation.",
        "tags": [
          "Invitations"
        ],
        "parameters": [
          {
            "name": "authentication_token",
            "in": "query",
            "description": "A valid session token.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvitationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invitation created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvitationResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad credentials"
          },
          "422": {
            "description": "Invalid Input Data"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateSessionRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "description": "The user email"
          },
          "password": {
            "type": "string",
            "description": "The user password"
          }
        }
      },
      "CreateSessionResponse": {
        "type": "object",
        "required": [
          "sessionKey",
          "fullName"
        ],
        "properties": {
          "sessionKey": {
            "type": "string",
            "description": "The session token for the authenticated user"
          },
          "fullName": {
            "type": "string",
            "description": "The full name for the authenticated user"
          }
        }
      },
      "ValidateSessionResponse": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "Token is valid response"
          }
        }
      },
      "CreateInvitationRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "email"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "description": "The first name of the user to be invited"
          },
          "last_name": {
            "type": "string",
            "description": "The last name of the user to be invited"
          },
          "email": {
            "type": "string",
            "description": "Email of the user to be invited"
          }
        }
      },
      "InvitationResponse": {
        "type": "object",
        "required": [
          "invitation"
        ],
        "properties": {
          "invitation": {
            "$ref": "#/components/schemas/Invitation"
          }
        }
      },
      "Invitation": {
        "type": "object",
        "required": [
          "id",
          "first_name",
          "last_name",
          "email",
          "zipcode",
          "username",
          "organization_title",
          "requestor_name",
          "uuid",
          "created_at",
          "updated_at",
          "expires_at",
          "status",
          "profile_type"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "zipcode": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "organization_title": {
            "type": "string"
          },
          "requestor_name": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          },
          "expires_at": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "profile_type": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Sessions",
      "description": "Session token management"
    },
    {
      "name": "Invitations",
      "description": "Candidate invitation management"
    }
  ]
}