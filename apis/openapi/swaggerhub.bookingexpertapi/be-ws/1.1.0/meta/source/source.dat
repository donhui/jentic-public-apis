{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/bookingexpertapi/Be-WS/1.1.0"
    },
    {
      "description": "Live environment",
      "url": "https://be.bookingexpert.it/book/ws"
    },
    {
      "description": "Test environment",
      "url": "https://be.ber-dev.bookingexpert.it/book/ws"
    }
  ],
  "info": {
    "version": "1.1.0",
    "title": "BE-WS",
    "description": "API to retrieve information about the booking engine configuration",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/bookingexpertapi/Be-WS/1.1.0/swagger.json"
  },
  "paths": {
    "/rooms": {
      "get": {
        "tags": [
          "Info"
        ],
        "description": "retrieve the information about rooms",
        "operationId": "getRoom",
        "parameters": [
          {
            "in": "query",
            "name": "hotel",
            "required": true,
            "description": "id of the hotel where rooms are defined",
            "schema": {
              "type": "integer",
              "format": "int32",
              "example": 7884
            }
          },
          {
            "in": "query",
            "name": "lang",
            "required": true,
            "description": "lang code of texts in the response",
            "schema": {
              "type": "string",
              "enum": [
                "en",
                "it",
                "fr",
                "es",
                "de"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All thedefined and enabled rooms in the hotel specified",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/rooms"
                  }
                }
              }
            }
          },
          "500": {
            "description": "somthing went wrong. Please check the required parameters"
          }
        }
      }
    },
    "/offers": {
      "get": {
        "tags": [
          "Offers"
        ],
        "description": "returns all offers enabled and flagged as retrievable from this service",
        "operationId": "getOffer",
        "parameters": [
          {
            "in": "query",
            "name": "layout",
            "required": true,
            "description": "id of a layout where sales are enabled",
            "schema": {
              "type": "integer",
              "format": "int32",
              "example": 708
            }
          },
          {
            "in": "query",
            "name": "lang",
            "description": "language of the desired description texts included in the response",
            "schema": {
              "type": "string"
            },
            "example": "it"
          }
        ],
        "responses": {
          "200": {
            "description": "All the offers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Offer"
                  }
                }
              }
            }
          },
          "500": {
            "description": "somthing went wrong. Please check the required parameters"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "rooms": {
        "type": "array",
        "description": "List of room objects returned by the API",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "description": "Unique identifier of the room",
              "example": 1809
            },
            "hotel": {
              "type": "integer",
              "description": "Identifier of the associated hotel",
              "example": 7884
            },
            "code": {
              "type": "string",
              "description": "Code representing the room type",
              "example": "F2T"
            },
            "name": {
              "type": "string",
              "description": "Name of the room",
              "example": "Standard room"
            },
            "beds": {
              "type": "integer",
              "description": "Number of beds (nullable)",
              "nullable": true
            },
            "description": {
              "type": "string",
              "description": "HTML description of the room",
              "example": "Comfortable and smartly furnished room"
            },
            "maxPeople": {
              "type": "integer",
              "description": "maximum number of people occupying the room",
              "nullable": true,
              "example": 2
            },
            "facilities": {
              "type": "array",
              "description": "List of facility categories and their details",
              "items": {
                "type": "object",
                "properties": {
                  "category": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "Unique identifier of the facility category",
                        "example": 5625
                      },
                      "name": {
                        "type": "string",
                        "description": "Name of the facility category",
                        "example": "Services / Extra"
                      },
                      "code": {
                        "type": "string",
                        "description": "Code of the facility category",
                        "example": "Services / Extra"
                      }
                    }
                  },
                  "categoryfacilities": {
                    "type": "array",
                    "description": "List of facilities within the category",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Unique identifier of the facility",
                          "example": 23
                        },
                        "name": {
                          "type": "string",
                          "description": "Name of the facility",
                          "example": "Wake-up service"
                        },
                        "image": {
                          "type": "object",
                          "nullable": true,
                          "properties": {
                            "url": {
                              "type": "string",
                              "description": "URL of the facility image"
                            },
                            "thumb": {
                              "type": "string",
                              "description": "Thumbnail of the facility image"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "gallery": {
              "type": "array",
              "description": "List of room gallery images",
              "items": {
                "$ref": "#/components/schemas/Image"
              }
            },
            "lastavail": {
              "type": "integer",
              "description": "Information about the last availability (nullable)",
              "nullable": true
            },
            "pricefrom": {
              "type": "string",
              "description": "Starting price of the room (nullable)",
              "nullable": true
            },
            "priceview": {
              "type": "object",
              "description": "Pricing details",
              "properties": {
                "code": {
                  "type": "integer",
                  "description": "Pricing code"
                },
                "description": {
                  "type": "string",
                  "description": "Pricing description"
                }
              }
            },
            "size": {
              "type": "string",
              "description": "Room size in square meters"
            },
            "weight": {
              "type": "integer",
              "description": "Weight or priority of the room"
            },
            "bookpref": {
              "type": "boolean",
              "description": "Booking preference indicator"
            }
          }
        }
      },
      "Offer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "offer id"
          },
          "hotel": {
            "type": "integer",
            "description": "hotel id"
          },
          "url": {
            "type": "string",
            "description": "url of the offer detail page"
          },
          "urlchain": {
            "type": "string",
            "description": "URL of the chain offer detail page when the property belongs to a chain, or null otherwise"
          },
          "type": {
            "type": "string",
            "enum": [
              "sale",
              "rate"
            ]
          },
          "category": {
            "$ref": "#/components/schemas/Category"
          },
          "categoryChain": {
            "$ref": "#/components/schemas/Category"
          },
          "orderby": {
            "type": "integer",
            "description": "this is a parameter to set the order of the offers in the presentation page"
          },
          "name": {
            "type": "string",
            "description": "the name of the offer in the specified language"
          },
          "description": {
            "type": "string",
            "description": "the the description of the offer in the specified language"
          },
          "shortdescription": {
            "type": "string",
            "description": "a short text associated with the offer"
          },
          "pricefrom": {
            "type": "number",
            "description": "is a static field associated to the offer"
          },
          "image": {
            "$ref": "#/components/schemas/Image"
          },
          "banner": {
            "$ref": "#/components/schemas/Image"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Image"
            }
          },
          "priceincludes": {
            "type": "string",
            "description": "if present, a text that contains information about what is included in the offer in the specified language"
          },
          "priceexludes": {
            "type": "string",
            "description": "if present, a text that contains information about what is not included in the offer in the specified language"
          },
          "expiredate": {
            "type": "integer",
            "description": "the expire date in millis since January, 1, 1970 if specified, null otherwise"
          }
        },
        "example": {
          "id": 9437,
          "hotel": 7884,
          "url": "https://be.bookingexpert.it/book/offer/details?sale=9437&layout=708&lang=it&currency=EUR",
          "urlchain": null,
          "type": "rate",
          "category": {
            "id": 24179,
            "name": "PROMOZIONI",
            "image": {
              "url": "https://ber.my-cdn.cloud/data/13549/56026eac01241.jpg",
              "thumb": "https://ber.my-cdn.cloud/data/13549/56026eaca1es1.jpg"
            },
            "code": "Promozioni dirette"
          },
          "categorychain": null,
          "orderby": 8,
          "name": "this is an offer",
          "description": "this is the description of the offer",
          "pricefrom": null,
          "image": {
            "url": "https://ber.my-cdn.cloud/data/7884/6026efea-c0fa-4498-aae3-a2ee28esss9.jpg",
            "thumb": "https://ber.my-cdn.cloud/data/7884/6026efea-c0fa-449s8-aae3-a2ee28e905aa9.jpg"
          },
          "banner": {
            "url": "https://ber.my-cdn.cloud/data/7884/6026fea-c0fa-4498-aae3-a2ee28esss9.jpg",
            "thumb": "https://ber.my-cdn.cloud/data/7884/60s26efea-c0fa-4498-aae3-a2ee28e905aa9.jpg"
          },
          "images": [
            {
              "url": "https://ber.my-cdn.cloud/data/7884/6026efea-c0fa-4498-aae3-a2ee28fdsds9.jpg",
              "thumb": "https://ber.my-cdn.cloud/data/7884/6026efea-c0fa-4498-aae3-a2ee28as05aa9.jpg"
            },
            {
              "url": "https://ber.my-cdn.cloud/data/7884/6026efea-c0fa-4498-aae3-a2ee28eiioa9.jpg",
              "thumb": "https://ber.my-cdn.cloud/data/7884/6026efea-c0fa-4498-aae3-a2ee28suas5aa9.jpg"
            }
          ],
          "priceincludes": "<div>what the offer includes</div>",
          "priceexcludes": "<p>what is excluded</p>",
          "expiradate": null
        }
      },
      "Category": {
        "type": "object",
        "description": "if the offer belongs to a category, you can find the corresponding data here",
        "properties": {
          "id": {
            "type": "integer",
            "description": "id of the category"
          },
          "code": {
            "type": "string",
            "description": "the code of the category"
          },
          "name": {
            "type": "string",
            "description": "the category name in the specified language"
          },
          "description": {
            "type": "string",
            "description": "the category description in the specified language"
          },
          "image": {
            "$ref": "#/components/schemas/Image"
          }
        }
      },
      "Image": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "the URL of the image file"
          },
          "thumb": {
            "type": "string",
            "description": "the URL of the thumb file"
          }
        },
        "description": "an image eventually associated to another entity"
      }
    }
  }
}