    },
    "/user/newemail": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "set a new email for a defined user and application",
        "description": "It sets a new user email by username and \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and returns the new user details. Don't be afraid about \"repository id\" request parameter missing because username is unique in all BEBE Access. That means useranme is always related to a single users repository only. So, \"username\" request parameter is enough in order to change the user email. Moreover, the \"BookingExpert application\" request parameter is just used for email sending but it doesn't partecipate in the user selecting procedure.",
        "operationId": "setNewEmail",
        "parameters": [
          {
            "name": "app",
            "in": "query",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "description": "the user username",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "description": "the user new email",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return new user credentials with access details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
