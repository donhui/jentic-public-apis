        "operationId": "checkAnswers",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "description": "the user username",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "question1",
            "in": "query",
            "description": "the first question id",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "question2",
            "in": "query",
            "description": "the second question id",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "answer1",
            "in": "query",
            "description": "the answer to the first question",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "answer2",
            "in": "query",
            "description": "the answer to the second question",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the user or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/recovery/getpolicies": {
      "get": {
        "tags": [
          "recoveries"
        ],
        "summary": "retrieves passwords policy by \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.)",
        "description": "It get passwords policy by \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return that to the client.",
        "operationId": "getPolicies",
        "parameters": [
          {
            "name": "app",
            "in": "query",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return passwords policy or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PasswordPolicyAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/recovery/deletedevice": {
      "get": {
        "tags": [
          "recoveries"
        ],
        "summary": "delete a device by recovery link and its device uuid for a defined application",
        "description": "It deletes a device by recovery link and its device uuid for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return the user details.",
        "operationId": "deleteDevice",
        "parameters": [
          {
            "name": "app",
            "in": "query",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "token",
            "in": "query",
            "description": "the device recovery link",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "dcbafcb9bc2ef59020feaa0444111a357e02788bde15b14e280f47e92f72dbe34fe9ca20da82c38f68d66f18058e15a20e6d70055e72094b9554dbb4f03aecc3"
          },
          {
            "name": "deviceuuid",
            "in": "query",
            "description": "the device UUID",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "f5b8dd51-add4-49ed-913b-66624f909c97"
          }
        ],
        "responses": {
          "200": {
            "description": "return the user details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/version/setpermissions": {
      "post": {
        "tags": [
          "versions"
        ],
        "summary": "It set the hotel version permissions by its id and permissions list",
        "description": "It set the hotel version permissions by its id and permissions list and return the permissions list. It also creates the version entity if missing.",
        "operationId": "setVersionPermissions",
