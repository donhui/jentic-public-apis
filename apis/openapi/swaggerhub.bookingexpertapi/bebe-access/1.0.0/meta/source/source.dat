        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "repository name",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "description",
            "in": "query",
            "description": "repository description",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the new users repository or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepositoriesAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repository/update": {
      "get": {
        "tags": [
          "repositories"
        ],
        "summary": "update a users repository",
        "description": "It updates name and/or description of a users repository by its id",
        "operationId": "updateRepository",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "repository id to update",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "repository name",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "description",
            "in": "query",
            "description": "repository description",
            "required": true,
            "style": "form",
            "explode": true,
