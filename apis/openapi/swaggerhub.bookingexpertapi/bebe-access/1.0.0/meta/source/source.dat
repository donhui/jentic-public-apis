    "/user/getallcredentials": {
      "post": {
        "tags": [
          "users"
        ],
        "summary": "It retrieves all user credentials by a list of username",
        "description": "It searches all users by a list of username and return a list of credentials and theri user details.",
        "operationId": "getAllCredentials",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "example": [
                  "adminfuscosanremo",
                  "unexistent",
                  "diego1",
                  "diego2"
                ],
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "return a list of credentials and their user details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialsListAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/getpermissions": {
