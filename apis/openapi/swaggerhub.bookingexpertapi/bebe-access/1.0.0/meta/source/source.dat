                "schema": {
                  "$ref": "#/components/schemas/RepositoriesListInnerAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/insert": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "insert a user in a users repository for a defined application",
        "description": "It creates a user with his username and email in a specific users repository for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return a \"recovery link\". This \"recovery link\" is sent by email from bebe-access in order to let the user clicks on it and set his password. Username is unique in all the BEBE Access. Instead, email is unique per users repository. This way, people can have more than one BEBE Access user with the same email but different username. Moreover, a user with the same username and the same email can be inserted once per \"BookingExpert application\". For example, firstly, one can insert user \"X\" per BER_UI application and, nextly, one can insert user \"X\" per BER_CC application. That means first endpoint call inserts a row in the \"users\" DB table and a row in the \"recoveries\" DB table, instead, the second call insert just a second row in the \"recoveries\" DB table because the user \"X\" already exists in the \"users\" DB table.",
        "operationId": "createUser",
        "parameters": [
          {
            "name": "app",
            "in": "query",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "description": "the user username",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "description": "the user email",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repo",
            "in": "query",
            "description": "user repository id",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the \"recovery link\" with user and BookingExpert application details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecoveryAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/delete": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "delete a user by his username for a defined application",
        "description": "It deletes a user by his username for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return the deleted user. Since people can have more than one \"BookingExpert application\" related to their users, when one deletes user \"X\" for application \"Y\", BEBE Access removes all involved rows from \"recoveries\" and \"credentials\" DB tables where user is \"X\" and application is \"Y\". Moreover, if the deleted user has no more \"recoveries\" and \"credentials\" rows, then BEBE Access even removes user \"X\" from \"users\" DB table.",
        "operationId": "deleteUser",
        "parameters": [
          {
            "name": "app",
            "in": "query",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "description": "the user username",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the deleted user or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/login": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "check user credentials in a users repository for a defined application",
        "description": "It checks user credentials by his password and \"username or email\" in a specific users repository for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return user credentials with access details. \"filter\" parameter is optional and you can leave empty (as default) if you want to let BEBE Access authenticate users by username or email. Instead you can set \"filter\" to \"U\" or \"E\" in order to let users authentication by username or email respectively. \"ip\" parameter is optional and useful for user access tracking.",
        "operationId": "loginUser",
        "parameters": [
          {
            "name": "app",
            "in": "query",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "description": "the user username",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "password",
            "in": "query",
            "description": "the user password",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repo",
            "in": "query",
            "description": "user repository id",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "the filter to let users authentication by username, email or both. Available values are \"U\" for username authentication only, \"E\" for email authentication only, both authentications otherwise.",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ip",
            "in": "query",
            "description": "the user device IP",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "127.0.0.1"
          }
        ],
        "responses": {
          "200": {
            "description": "return user credentials with access details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/newpassword": {
      "get": {
        "tags": [
          "users"
