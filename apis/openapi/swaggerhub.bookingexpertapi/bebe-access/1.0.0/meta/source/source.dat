    "/creditcard/write": {
      "get": {
        "tags": [
          "creditcards"
        ],
        "summary": "tokenizes a credit card",
        "description": "It tokenizes a credit card and return the related key/token pair with masked credit card number and token expire.",
        "operationId": "writeCreditCard",
        "parameters": [
          {
            "name": "resid",
            "in": "query",
            "description": "reservation id related to the credit card",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "the credit card type",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "number",
            "in": "query",
            "description": "the credit card number",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "owner",
            "in": "query",
            "description": "the credit card owner",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "expire",
            "in": "query",
            "description": "the credit card expire in MM/YYYY format",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cvv",
            "in": "query",
            "description": "the credit card cvv",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cryptoexpire",
            "in": "query",
            "description": "the credit card crypto token expire in DDMMYYYYHHMMSS format",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the key/token pair with masked credit card number and token expire or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CryptedCreditCardAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/creditcard/read": {
      "get": {
        "tags": [
          "creditcards"
        ],
        "summary": "untokenizes a credit card by its key/token pair",
        "description": "It untokenizes a credit card by its key/token pair and return all unencrypted credit card details.",
        "operationId": "readCreditCard",
        "parameters": [
          {
            "name": "resid",
            "in": "query",
            "description": "reservation id related to the tokenized credit card",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return all unencrypted credit card details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditCardAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/creditcard/readbylog": {
      "get": {
        "tags": [
          "creditcards"
        ],
        "summary": "get credit card details by log id",
        "description": "It gets credit card details by log id and return all unencrypted credit card details.",
        "operationId": "readCreditCardByLog",
        "parameters": [
          {
            "name": "logid",
            "in": "query",
            "description": "log id related to the credit card",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return all unencrypted credit card details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreditCardAdapterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/creditcard/update": {
      "get": {
        "tags": [
          "creditcards"
        ],
        "summary": "updates expire credit card related to a reservation id",
        "description": "It updates expire credit card by a reservation id and return all unencrypted credit card details.",
        "operationId": "updateCreditCard",
        "parameters": [
          {
            "name": "resid",
            "in": "query",
            "description": "reservation id related to the tokenized credit card.",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return expire credit card updating outcome or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BooleanAdapterResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorAdapterResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "IDENT_DB_ERROR"
          },
          "entity": {
            "type": "string",
            "example": "Repositories"
          },
          "message": {
            "type": "string",
            "example": "Select repository: unexpected database error"
          },
          "id": {
            "type": "string",
            "example": "1"
          },
          "idItems": {
            "type": "array",
            "example": [
              1,
              2,
              3
            ],
            "items": {
              "type": "integer"
            }
          }
        }
      },
      "RepositoriesAdapterDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "DEFAULT"
          },
          "description": {
            "type": "string",
            "example": "Anagrafica utenti condivisa"
          }
        }
      },
      "ApplicationsAdapterDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "BER_SDA"
          },
          "description": {
            "type": "string",
            "example": "Booking Engine Secure Device Access (OTP device)"
          }
        }
      },
      "UsersAdapterDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "antonellodp"
          },
          "email": {
            "type": "string",
            "example": "antonello.dipeco@zucchetti.it"
          },
          "repository": {
            "$ref": "#/components/schemas/RepositoriesAdapterDto"
          },
          "recoveriesList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecoveriesAdapterDto"
            }
          }
        }
      },
      "RecoveriesAdapterDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "password": {
            "type": "string",
            "description": "the recovery link",
            "example": "e03518fce816c1f674456d5f4e514ca5b492fa78c03fccaaae3698770b8207b05a9a03481c88f3fb69c69e298cd22297793850291641176c395f5e6a79d74748"
          },
          "expire": {
            "type": "string",
            "example": "27/06/2024 11:05:07"
          },
          "email": {
            "type": "string",
            "example": "mail@mail.it"
          },
          "oldEmail": {
            "type": "string",
            "example": "oldmail@mail.it"
          },
          "device": {
            "type": "string",
            "example": "f5b8dd51-add4-49ed-913b-66624f909c97"
          },
          "application": {
            "$ref": "#/components/schemas/ApplicationsAdapterDto"
          },
          "user": {
            "$ref": "#/components/schemas/UsersAdapterDto"
          }
        }
      },
      "CredentialsAdapterDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "active": {
            "type": "boolean",
            "example": true
          },
          "password": {
            "type": "string",
            "example": "e03518fce816c1f674456d5f4e514ca5b492fa78c03fccaaae3698770b8207b05a9a03481c88f3fb69c69e298cd22297793850291641176c395f5e6a79d74748"
          },
          "expire": {
            "type": "string",
            "example": "27/06/2024 11:05:07"
          },
          "lastAccess": {
            "type": "string",
            "example": "25/06/2024 22:48:32"
          },
          "attempt": {
            "type": "integer",
            "format": "int32",
            "example": 3
          },
          "lastAttempt": {
            "type": "string",
            "example": "26/06/2024 08:02:58"
          },
          "daysLeftToExpire": {
            "type": "integer",
            "format": "int32",
            "example": 78
          },
          "application": {
            "$ref": "#/components/schemas/ApplicationsAdapterDto"
          },
          "user": {
            "$ref": "#/components/schemas/UsersAdapterDto"
          },
          "permissions": {
            "type": "array",
            "example": [
              "answers/edit",
              "cancterms/add",
              "guests/index"
            ],
            "items": {
              "type": "string"
            }
          }
        }
      },
      "GroupedQuestionsAdapterDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "group1": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionsAdapterDto"
            }
          },
          "group2": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionsAdapterDto"
            }
          }
        }
      },
      "QuestionsAdapterDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "question": {
            "type": "string",
            "example": "Qual \u00e8 il nome della tua prima auto?"
          }
        }
      },
      "PasswordPoliciesAdapterDto": {
        "type": "object",
        "properties": {
          "algorithm": {
            "type": "string",
            "example": "SHA-256"
          },
          "digits": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "symbols": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "lowercase": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "uppercase": {
            "type": "integer",
            "format": "int32",
            "example": 1
          },
          "length": {
            "type": "integer",
            "format": "int32",
            "example": 8
          },
          "expire": {
            "type": "integer",
            "format": "int32",
            "example": 90
          },
          "recoveryExpire": {
            "type": "integer",
            "format": "int32",
            "example": 1440
          },
          "attemptsNumber": {
            "type": "string",
            "example": "5,10,15,20"
          },
          "attemptsDelay": {
            "type": "string",
            "example": "90,180,300,600"
          },
          "last": {
            "type": "integer",
            "format": "int32",
            "example": 4
          },
          "disableAfter": {
            "type": "integer",
            "format": "int32",
            "example": 90
          }
        }
      },
      "PermissionsAdapterDto": {
        "type": "object",
        "properties": {
          "function": {
            "type": "string",
            "example": "amenities"
          },
          "level": {
            "type": "string",
            "example": "delete"
          }
        }
      },
      "UserPermissionsAdapterDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "testuser1"
          },
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PermissionsAdapterDto"
            }
          }
        }
      },
      "VersionPermissionsAdapterDto": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "format": "int64",
            "example": 123
          },
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PermissionsAdapterDto"
            }
          }
        }
      },
      "VersionPermissionStringsAdapterDto": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "format": "int64",
            "example": 123
          },
          "permissions": {
            "type": "array",
            "example": [
              "answers/edit",
              "cancterms/add",
              "guests/index"
            ],
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SPFResultWrapperDto": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean",
            "example": true
          },
          "shortResponse": {
