                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "adminfuscosanremo",
                  "unexistent",
                  "diego1",
                  "diego2"
                ]
              }
            }
          }
        }
      }
    },
    "/recovery/insertpassword": {
