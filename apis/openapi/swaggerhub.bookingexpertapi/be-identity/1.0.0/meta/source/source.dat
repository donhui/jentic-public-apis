  "tags": [
    {
      "name": "repositories",
      "description": "Operations to manage users repositories"
    },
    {
      "name": "users",
      "description": "Operations to manage users"
    },
    {
      "name": "recoveries",
      "description": "Operations to manage recoveries"
    }
