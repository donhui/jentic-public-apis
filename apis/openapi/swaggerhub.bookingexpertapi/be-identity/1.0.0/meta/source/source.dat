    "/recovery/insertdevice": {
      "get": {
        "tags": [
          "recoveries"
        ],
        "summary": "insert a new device recovery link by user username for a defined application",
        "operationId": "insertDevice",
        "description": "It inserts a new recovery link by user username for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return the user recovery details.",
        "parameters": [
          {
            "in": "query",
            "name": "app",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "username",
            "description": "the user username",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "deviceuuid",
            "description": "the device UUID",
            "example": "f5b8dd51-add4-49ed-913b-66624f909c97",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
