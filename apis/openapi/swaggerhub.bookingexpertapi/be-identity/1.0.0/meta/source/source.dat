  "paths": {
    "/repository/getall": {
      "get": {
        "tags": [
          "repositories"
        ],
        "summary": "get all users repositories",
        "operationId": "getAllRepositories",
        "description": "It retrieves all repositories managed by the api",
        "responses": {
          "200": {
            "description": "return all users repositories or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepositoriesListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repository/read": {
      "get": {
        "tags": [
          "repositories"
        ],
        "summary": "get a single users repository",
        "operationId": "getRepository",
        "description": "It retrieves a single repository by its id",
        "parameters": [
          {
            "in": "query",
            "name": "id",
            "description": "repository id to find",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the users repository or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepositoriesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repository/insert": {
      "get": {
        "tags": [
          "repositories"
        ],
        "summary": "create a users repository",
        "operationId": "insertRepository",
        "description": "It creates a new users repository by its name and description",
        "parameters": [
          {
            "in": "query",
            "name": "name",
            "description": "repository name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "description",
            "description": "repository description",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the new users repository or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepositoriesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repository/update": {
      "get": {
        "tags": [
          "repositories"
        ],
        "summary": "update a users repository",
        "operationId": "updateRepository",
        "description": "It updates name and/or description of a users repository by its id",
        "parameters": [
          {
            "in": "query",
            "name": "id",
            "description": "repository id to update",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "in": "query",
            "name": "name",
            "description": "repository name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "description",
            "description": "repository description",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the new users repository or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepositoriesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repository/delete": {
      "get": {
        "tags": [
          "repositories"
        ],
        "summary": "delete a users repository",
        "operationId": "deleteRepository",
        "description": "It deletes one or more users repositories by their ids",
        "parameters": [
          {
            "in": "query",
            "name": "ids",
            "description": "comma separated repository id list",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the new users repository or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepositoriesListInnerResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/insert": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "insert a user in a users repository for a defined application",
        "operationId": "createUser",
        "description": "It creates a user with his username and email in a specific users repository for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return a \"recovery link\". This \"recovery link\" is sent by email from bebe-access in order to let the user clicks on it and set his password. Username is unique in all the BE Identity. Instead, email is unique per users repository. This way, people can have more than one BE Identity user with the same email but different username. Moreover, a user with the same username and the same email can be inserted once per \"BookingExpert application\". For example, firstly, one can insert user \"X\" per BER_UI application and, nextly, one can insert user \"X\" per BER_CC application. That means first endpoint call inserts a row in the \"users\" DB table and a row in the \"recoveries\" DB table, instead, the second call insert just a second row in the \"recoveries\" DB table because the user \"X\" already exists in the \"users\" DB table.",
        "parameters": [
          {
            "in": "query",
            "name": "app",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "username",
            "description": "the user username",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "email",
            "description": "the user email",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "repo",
            "description": "user repository id",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the \"recovery link\" with user and BookingExpert application details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecoveryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/delete": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "delete a user by his username for a defined application",
        "operationId": "deleteUser",
        "description": "It deletes a user by his username for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return the deleted user. Since people can have more than one \"BookingExpert application\" related to their users, when one deletes user \"X\" for application \"Y\", BE Identity removes all involved rows from \"recoveries\" and \"credentials\" DB tables where user is \"X\" and application is \"Y\". Moreover, if the deleted user has no more \"recoveries\" and \"credentials\" rows, then BE Identity even removes user \"X\" from \"users\" DB table.",
        "parameters": [
          {
            "in": "query",
            "name": "app",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "username",
            "description": "the user username",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return the deleted user or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/login": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "check user credentials in a users repository for a defined application",
        "operationId": "loginUser",
        "description": "It checks user credentials by his password and \"username or email\" in a specific users repository for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return user credentials with access details. \"filter\" parameter is optional and you can leave empty (as default) if you want to let BE Identity authenticate users by username or email. Instead you can set \"filter\" to \"U\" or \"E\" in order to let users authentication by username or email respectively. \"ip\" parameter is optional and useful for user access tracking.",
        "parameters": [
          {
            "in": "query",
            "name": "app",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "username",
            "description": "the user username",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "password",
            "description": "the user password",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "repo",
            "description": "user repository id",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "in": "query",
            "name": "filter",
            "description": "the filter to let users authentication by username, email or both. Available values are \"U\" for username authentication only, \"E\" for email authentication only, both authentications otherwise.",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "ip",
            "description": "the user device IP",
            "example": "127.0.0.1",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return user credentials with access details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/newpassword": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "set a new password for a defined user and application",
        "operationId": "setNewPassword",
        "description": "It sets a new user password by username and \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and returns the new user credentials.",
        "parameters": [
          {
            "in": "query",
            "name": "app",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "username",
            "description": "the user username",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "password",
            "description": "the new user password",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return new user credentials with access details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/newemail": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "set a new email for a defined user and application",
        "operationId": "setNewEmail",
        "description": "It sets a new user email by username and \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and returns the new user details. Don't be afraid about \"repository id\" request parameter missing because username is unique in all BE Identity. That means useranme is always related to a single users repository only. So, \"username\" request parameter is enough in order to change the user email. Moreover, the \"BookingExpert application\" request parameter is just used for email sending but it doesn't partecipate in the user selecting procedure.",
        "parameters": [
          {
            "in": "query",
            "name": "app",
            "description": "BookingExpert application name among BER_UI (beback user interface access), BER_CC (beback credit card access), BER_SDA (beback otp device)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "username",
            "description": "the user username",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "email",
            "description": "the user new email",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "return new user credentials with access details or error if something went wrong",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/enable": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "enable a user by his username for a defined application",
        "operationId": "enableUser",
        "description": "It enables a user by his username for a certain \"BookingExpert application\" (for ex. BER_UI, BER_CC, BER_SDA, etc.) and return the enabled user.",
