  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "IDENT_DB_ERROR"
          },
          "entity": {
            "type": "string",
            "example": "Repositories"
          },
          "message": {
            "type": "string",
            "example": "Select repository: unexpected database error"
          },
          "id": {
            "type": "string",
            "example": 1
          },
          "idItems": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              1,
              2,
              3
            ]
          }
        }
      },
      "RepositoriesDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "DEFAULT"
          },
          "description": {
            "type": "string",
            "example": "Anagrafica utenti condivisa"
          }
        }
      },
      "ApplicationsDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "BER_SDA"
          },
          "description": {
            "type": "string",
            "example": "Booking Engine Secure Device Access (OTP device)"
          }
        }
      },
      "UsersDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "antonellodp"
          },
          "email": {
            "type": "string",
            "example": "antonello.dipeco@zucchetti.it"
          },
          "repository": {
            "$ref": "#/components/schemas/RepositoriesDto"
          },
          "recoveriesList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecoveriesDto"
            }
          }
        }
      },
      "RecoveriesDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "password": {
            "type": "string",
            "description": "the recovery link",
            "example": "e03518fce816c1f674456d5f4e514ca5b492fa78c03fccaaae3698770b8207b05a9a03481c88f3fb69c69e298cd22297793850291641176c395f5e6a79d74748"
          },
          "expire": {
            "type": "string",
            "example": "27/06/2024 11:05:07"
          },
          "email": {
            "type": "string",
            "example": "mail@mail.it"
          },
          "oldEmail": {
            "type": "string",
