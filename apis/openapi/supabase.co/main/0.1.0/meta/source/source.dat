    "/accounts": {
      "post": {
        "summary": "Create a new account",
        "description": "Create a new contact with the provided details. Requires a valid Bearer token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "companyName": {
                    "type": "string"
                  },
                  "website": {
                    "type": "string"
                  },
                  "industry": {
                    "type": "string"
                  },
                  "noOfEmployees": {
                    "type": "number"
                  },
                  "description": {
                    "type": "string"
                  },
                  "headquarters": {
                    "type": "string"
                  },
                  "groupId": {
                    "type": "string"
                  },
                  "typeId": {
                    "type": "string"
                  },
                  "priorityId": {
                    "type": "string"
                  },
                  "labelIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "dealIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
