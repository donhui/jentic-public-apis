                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Account created successfully!"
                    },
                    "accountId": {
                      "type": "string",
                      "format": "uuid",
                      "example": "c056d1e3-62e8-4ec3-b733-7a7485fa48c8"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
