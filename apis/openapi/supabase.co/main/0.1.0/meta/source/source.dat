            "name": "event_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "event-123"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
