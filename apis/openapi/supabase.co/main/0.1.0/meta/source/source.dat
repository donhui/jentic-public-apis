                  },
                  "location": {
                    "type": "string",
                    "example": "Conference Room"
                  },
                  "sendUpdates": {
                    "type": "string",
                    "example": "all"
                  },
                  "entityBaseId": {
                    "type": "string",
                    "example": "entity-123"
                  },
                  "entityTypeId": {
                    "type": "number",
                    "example": 1
                  },
                  "isAllDay": {
