                    "type": "string",
                    "example": "user-123"
                  },
                  "connectionId": {
                    "type": "string",
                    "example": "conn-123"
                  },
                  "calendarId": {
                    "type": "string",
                    "example": "calendar-123"
                  },
                  "subject": {
                    "type": "string",
                    "example": "Meeting with team"
                  },
                  "body": {
                    "type": "object",
                    "properties": {
                      "contentType": {
                        "type": "string",
                        "example": "text/plain"
                      },
                      "content": {
                        "type": "string",
                        "example": "Discuss project updates"
                      }
                    }
                  },
                  "start": {
                    "type": "object",
                    "properties": {
                      "dateTime": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T10:00:00Z"
                      },
                      "timeZone": {
                        "type": "string",
                        "example": "UTC"
                      }
                    }
                  },
                  "end": {
                    "type": "object",
                    "properties": {
                      "dateTime": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T11:00:00Z"
                      },
                      "timeZone": {
                        "type": "string",
                        "example": "UTC"
                      }
                    }
                  },
                  "userAttendees": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "example": "user@example.com"
                    }
                  },
                  "leadAttendees": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "example": "lead@example.com"
                    }
                  },
                  "contactAttendees": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "example": "contact@example.com"
                    }
                  },
                  "otherAttendees": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "example": "other@example.com"
                    }
                  },
                  "isOnlineMeeting": {
                    "type": "boolean",
                    "example": true
                  },
                  "onlineMeetingProvider": {
