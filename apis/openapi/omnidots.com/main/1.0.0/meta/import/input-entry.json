{
  "openapi": "3.0.3",
  "info": {
    "title": "Omnidots Honeycomb API",
    "description": "REST API for the Omnidots Honeycomb vibration monitoring platform. Provides access to measuring points, sensors, and vibration measurement records including peak particle velocity, VDV, and Veff/KB data.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://honeycomb.omnidots.com/api/docs"
  },
  "servers": [
    {
      "url": "https://honeycomb.omnidots.com/api/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/user/authenticate": {
      "get": {
        "operationId": "authenticateuser",
        "summary": "Authenticate user",
        "description": "Authenticate user and return a temporary API token.",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User account username"
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User account password"
          }
        ],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/account": {
      "get": {
        "operationId": "getuseraccount",
        "summary": "Get user account",
        "description": "Retrieve user account information by API token.",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "tokenAuth": []
          }
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API authentication token"
          }
        ],
        "responses": {
