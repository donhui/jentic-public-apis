    "/get_peak_records": {
      "get": {
        "operationId": "getpeakrecords",
        "summary": "Get peak records",
        "description": "Fetch peak particle velocity and acceleration records for a given measuring point within a time range.",
        "tags": [
          "Records"
        ],
        "security": [
          {
            "tokenAuth": []
          }
        ],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API authentication token"
          },
          {
            "name": "measuring_point_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the measuring point"
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start of the time range"
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End of the time range"
          }
        ],
        "responses": {
          "200": {
            "description": "Peak records data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeakRecordsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
