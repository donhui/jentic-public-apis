  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API token passed as a query parameter. Obtain via /user/authenticate or the token list page."
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "description": "Error reason"
          },
          "help": {
            "type": "string",
            "format": "uri",
            "description": "URL to endpoint help documentation"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "token": {
            "type": "string",
            "description": "Temporary API token"
          }
        }
      },
      "UserAccountResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "account": {
            "type": "object",
            "description": "User account details",
            "properties": {
              "username": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              }
            }
          }
        }
      },
      "TokenDetailsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "account": {
            "type": "object",
            "description": "Account information associated with the token"
          }
        }
      },
      "MeasuringPointsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "measuring_points": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MeasuringPoint"
            }
          }
        }
      },
      "MeasuringPoint": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Measuring point identifier"
          },
          "name": {
            "type": "string",
            "description": "Measuring point name"
          },
          "location": {
            "type": "string",
            "description": "Measuring point location"
          }
        }
      },
      "SensorsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "sensors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sensor"
            }
          }
        }
      },
      "Sensor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Sensor identifier"
          },
          "name": {
            "type": "string",
            "description": "Sensor name"
          },
          "type": {
            "type": "string",
            "description": "Sensor type"
          }
        }
      },
      "PeakRecordsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PeakRecord"
            }
          }
        }
      },
      "PeakRecord": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Record timestamp"
          },
          "peak_velocity": {
            "type": "number",
            "format": "double",
            "description": "Peak particle velocity"
          },
          "peak_acceleration": {
            "type": "number",
            "format": "double",
            "description": "Peak acceleration"
          }
        }
      },
      "VdvRecordsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VdvRecord"
            }
          }
        }
      },
      "VdvRecord": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Record timestamp"
          },
          "vdv": {
            "type": "number",
            "format": "double",
            "description": "Vibration Dose Value"
          }
        }
      },
      "VeffRecordsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VeffRecord"
            }
          }
        }
      },
      "VeffRecord": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Record timestamp"
          },
          "veff": {
            "type": "number",
            "format": "double",
            "description": "Veff/KB vibration value"
          }
        }
      },
      "TracesListResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "traces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Trace identifier"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Trace timestamp"
                }
              }
            }
          }
        }
      },
      "TracesResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "traces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Trace identifier"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Trace timestamp"
                },
                "data": {
                  "type": "object",
                  "description": "Detailed trace measurement data"
                }
              }
