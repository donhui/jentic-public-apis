      "MerchantRequest": {
        "properties": {
          "businessId": {
            "description": "RUC",
            "maxLength": 20,
            "type": "string"
          },
          "companyId": {
            "description": "Número de empresa, será '165'",
            "maxLength": 3,
            "type": "string"
          },
          "externalId": {
            "description": "Id de transacción",
            "maxLength": 6,
            "type": "string"
          },
          "functionId": {
            "description": "Id de la función, será '651'",
            "type": "string"
          }
        },
        "required": [
          "businessId",
          "externalId",
          "companyId",
          "functionId"
        ],
        "type": "object"
      },
      "MerchantResponse": {
        "properties": {
          "data": {
            "items": {
              "$ref": "#/components/schemas/MerchantItem"
            },
            "type": "array"
          },
          "header": {
            "$ref": "#/components/schemas/ResponseHeader"
          }
        },
        "type": "object"
      },
      "ResponseHeader": {
        "properties": {
          "errorCode": {
            "type": "string"
          },
          "errorMessage": {
            "type": "string"
          },
          "executionDate": {
            "format": "int64",
            "type": "integer"
          },
          "transactionUUID": {
            "type": "string"
          },
          "userName": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "RetrieveResponse": {
        "properties": {
          "data": {
            "items": {
              "$ref": "#/components/schemas/MerchantItemList"
            },
            "type": "array"
          },
          "header": {
            "$ref": "#/components/schemas/ResponseHeader"
          }
        },
        "type": "object"
      },
      "RetrieveTotalResponse": {
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ResponseHeader"
          },
          "number": {
            "type": "integer"
          }
        },
        "type": "object"
      },
      "UpdateResponse": {
        "properties": {
          "header": {
            "$ref": "#/components/schemas/ResponseHeader"
          },
          "numberUpdate": {
            "description": "cantidad de comercios actualizados",
            "type": "integer"
          }
        },
        "type": "object"
      }
