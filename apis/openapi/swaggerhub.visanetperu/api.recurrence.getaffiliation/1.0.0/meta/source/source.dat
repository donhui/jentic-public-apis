      "description": "Access token obtained from api.security",
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "definitions": {
    "Request": {
      "type": "object",
      "required": [
        "dataMap"
      ],
      "properties": {
        "terminalId": {
          "type": "string",
          "example": "11223344",
          "description": "N\u00famero de terminal"
        },
        "merchantId": {
          "type": "string",
          "example": "341198210",
          "description": "C\u00f3digo de comercio"
        },
        "merchantName": {
          "type": "string",
          "example": "RIPLEY MIRAFLORES",
          "description": "Nombre de comercio"
        },
        "traceNumber": {
          "type": "string",
          "example": "123456",
          "description": "N\u00famero de registro"
        },
        "referenceNumber": {
          "type": "string",
          "example": "123456",
          "description": "N\u00famero de referencia"
        },
        "dateTime": {
          "type": "string",
          "format": "date-time",
          "example": "2018-08-06T23:11:43.878Z",
          "description": "Date time for operation in YYMMDD HH:MM:SS format"
        },
        "dataMap": {
          "type": "object",
          "required": [
            "channelAffiliation",
            "documentTypeCardholder",
            "documentIdCardholder",
            "cardNumber",
            "expirationMonth",
            "expirationYear",
            "beneficiaryId",
            "requestDateFrom",
            "requestDateTo",
            "affiliationDateFrom",
            "affiliationDateTo",
            "status",
            "merchantId",
            "issuerId",
            "channelId"
          ],
          "properties": {
            "channelAffiliation": {
              "type": "string",
              "maxLength": 10,
              "example": 2,
              "description": "Opcional,Canal de afiliacion (Plataforma REC \u2013 0: Plataforma \u2013 1: Homebanking \u2013 2: Comercio \u2013 3: Adquiriente \u2013 4: Emisor \u2013 5: Externo \u2013 6: Comercio Electr\u00f3nico)"
            },
            "documentTypeCardholder": {
              "type": "string",
              "maxLength": 1,
              "example": 1,
              "description": "Opcional. Tipo documento tarjeta habiente (Plataforma REC) Puede ser \u201c0\u201d DNI, \u201c1\u201d Carnet extranjer\u00eda, \u201c2\u201d pasaporte"
            },
            "documentIdCardholder": {
              "type": "string",
              "maxLength": 50,
              "example": 46372811,
              "description": "Opcional. Id documento tarjeta habiente (Plataforma REC)"
            },
            "cardNumber": {
              "type": "string",
              "maxLength": 40,
              "example": "4242424242424242",
              "description": "Opcional"
            },
            "expirationMonth": {
              "type": "string",
              "maxLength": 2,
              "example": "12",
              "description": "Opcional. Mes expiraci\u00f3n tarjeta (Plataforma REC y CE)"
            },
            "expirationYear": {
              "type": "string",
              "maxLength": 4,
              "example": "2018",
              "description": "Opcional. A\u00f1o expiraci\u00f3n tarjeta (Plataforma REC y CE)"
            },
            "beneficiaryId": {
              "type": "string",
              "maxLength": 50,
              "example": "IJFO090",
              "description": "Id beneficiario (Plataforma REC)"
            },
            "requestDateFrom": {
              "type": "string",
              "maxLength": 10,
              "example": "2018-04-19",
              "description": "Fecha de creaci\u00f3n de solicitud desde. Formato (YYYY-MM-DD)"
            },
            "requestDateTo": {
              "type": "string",
              "maxLength": 10,
              "example": "2018-04-19",
              "description": "Fecha de creaci\u00f3n de solicitud hasta. Formato (YYYY-MM-DD)"
            },
            "affiliationDateFrom": {
              "type": "string",
              "maxLength": 10,
              "example": "null",
              "description": "Fecha de creaci\u00f3n de afiliaci\u00f3n desde. Formato (YYYY-MM-DD)"
            },
            "affiliationDateTo": {
              "type": "string",
              "maxLength": 10,
              "example": "null",
              "description": "Fecha de creaci\u00f3n de afiliaci\u00f3n hasta. Formato (YYYY-MM-DD)"
            },
            "status": {
              "type": "string",
              "maxLength": 1,
              "example": "0",
              "description": "Estado de Afiliaci\u00f3n (Plataforma REC \u2013 0: afiliado \u2013 1: desafiliado)"
            },
            "merchantId": {
              "type": "string",
              "maxLength": 40,
              "example": "879346578",
              "description": "C\u00f3digo de Comercio (Plataforma REC)"
            },
            "issuerId": {
              "type": "string",
              "maxLength": 40,
              "example": "null",
              "description": "C\u00f3digo de Emisor"
            },
            "channelId": {
              "type": "string",
              "maxLength": 2,
              "example": "null",
              "description": "Canal por el cual se consume el servicio (2: Comercio \u2013 6: Comercio Electr\u00f3nico)"
            }
          }
        }
      }
    },
