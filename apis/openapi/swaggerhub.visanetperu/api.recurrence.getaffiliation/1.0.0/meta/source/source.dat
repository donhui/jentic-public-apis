          "type": "string",
          "example": "777777777",
          "maxLength": 9,
          "description": "C\u00f3digo del comercio\n"
        },
        "traceNumber": {
          "type": "string",
          "example": "123456",
          "maxLength": 6,
          "description": "N\u00famero de transacci\u00f3n\n"
        },
        "status": {
          "type": "string",
          "example": "000",
          "maxLength": 3,
          "description": "C\u00f3digo de respuesta  000 - Exito  400 - Error\n"
        },
        "dataMap": {
          "type": "object",
          "properties": {
            "MessageResponse": {
              "type": "object"
