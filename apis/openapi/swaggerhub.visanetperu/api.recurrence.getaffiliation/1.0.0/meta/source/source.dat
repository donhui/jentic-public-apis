                    },
                    "correoTarHabiente": {
                      "type": "string",
                      "example": "prueba@gmail.com",
                      "description": "Correo tarjeta habiente (Plataforma REC)"
                    },
                    "idBeneficiario": {
                      "type": "string",
                      "example": "8767564578",
                      "description": "Id Beneficiario (Plataforma REC)"
                    },
                    "nomBeneficiario": {
                      "type": "string",
                      "example": "MARIA",
                      "description": "Nombre beneficiario (Plataforma REC)"
                    },
                    "apePatBeneficiario": {
                      "type": "string",
                      "example": "LOPEZ",
                      "description": "Apellido paterno beneficiario (Plataforma REC)"
                    },
                    "codProducto": {
                      "type": "string",
                      "example": "89843OMK",
                      "description": "C\u00f3digo del Producto (Plataforma REC)"
                    },
                    "nomProducto": {
                      "type": "string",
                      "example": "CUOTAS",
                      "description": "Nombre del Producto (Plataforma REC)"
                    },
                    "canalAfiliacion": {
                      "type": "string",
                      "example": 2,
                      "description": "Canal de la Afiliaci\u00f3n (Plataforma REC)"
                    },
                    "monMaximo": {
                      "type": "string",
                      "example": "100.00",
                      "description": "Monto M\u00e1ximo (Plataforma REC)"
                    },
                    "fecSolicitudAfiliacion": {
                      "type": "string",
                      "example": null,
                      "description": "Fecha de Solicitud de Afiliaci\u00f3n (Plataforma REC)"
                    },
                    "fecAfiliacion": {
                      "type": "string",
                      "example": "2018-04-20",
                      "description": "Fecha de Afiliaci\u00f3n (Plataforma REC)"
                    },
                    "estadoAfiliacion": {
                      "type": "string",
                      "example": "0",
                      "description": "Estado de Afiliaci\u00f3n (Plataforma REC ,0, afiliado \u2013 1, desafiliado)"
                    }
                  }
                }
              }
            }
          }
