                        },
                        "mensajeAccion": {
                          "type": "string",
                          "example": "Proceso correcto",
                          "description": "Mensaje que indica el estado de la solicitud en caso de error o \u00e9xito"
                        },
                        "errorMessage": {
                          "type": "string",
                          "example": "EL CARGO NO EXISTE",
                          "description": "mensaje de error"
                        }
                      }
                    },
                    "idAfiliacion": {
                      "type": "string",
                      "example": null,
                      "description": "Identificador de afiliaci\u00f3n"
                    },
                    "numTarjeta": {
                      "type": "string",
                      "example": "435678******0989",
                      "description": "N\u00famero de tarjeta (Plataforma REC y CE)"
                    },
                    "mesExpTarjeta": {
                      "type": "string",
