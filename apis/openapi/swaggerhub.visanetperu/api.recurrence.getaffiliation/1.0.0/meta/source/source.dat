              "type": "object",
              "description": "C\u00f3digo de respuesta del servicio de negocio.",
              "example": 0
            },
            "srvResponseMessage": {
              "type": "object",
              "description": "Mensaje de respuesta del servicio de negocio.",
              "example": "EJECUCION CON EXITO",
              "properties": {
