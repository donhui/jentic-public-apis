                    "tipDocTarHabiente": {
                      "type": "string",
                      "example": "1",
                      "description": "Tipo documento tarjeta habiente (Plataforma REC) Puede ser, \u201c0\u201d DNI, \u201c1\u201d Carnet Extranjer\u00eda, \u201c2\u201d Pasaporte"
                    },
                    "idDocTarHabiente": {
                      "type": "string",
                      "example": "43523423",
                      "description": "N\u00famero de documento"
                    },
                    "nomTarHabiente": {
                      "type": "string",
                      "example": "MARIA",
                      "description": "Nombre de tarjeta habiente"
                    },
                    "apePatTarHabiente": {
                      "type": "string",
