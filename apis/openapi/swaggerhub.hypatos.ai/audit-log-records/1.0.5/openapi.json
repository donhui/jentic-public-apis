{
  "asyncapi": "2.6.0",
  "info": {
    "title": "Audit logs API",
    "version": "1.0.5",
    "description": "API for publishing audit log record events\n",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/hypatos.ai/audit-log-records/1.0.5/swagger.json"
  },
  "defaultContentType": "application/json",
  "channels": {
    "audit_log.events": {
      "description": "The topic on which audit log records should be published",
      "publish": {
        "summary": "Inform about log event on particular entity.",
        "operationId": "publishAuditLogRecord",
        "message": {
          "$ref": "#/components/messages/auditLogRecord"
        }
      }
    }
  },
  "components": {
    "messages": {
      "auditLogRecord": {
        "name": "record",
        "title": "Audit log record",
        "summary": "New audit log record created upon some action",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/recordPayload"
        }
      }
    },
    "schemas": {
      "actor": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "507f191e810c19729de860ea"
          },
          "type": {
            "type": "string",
            "enum": [
              "user",
              "apiClient",
              "service"
            ]
          }
        }
      },
      "meta": {
        "deprecated": true,
        "type": "object",
        "required": [
          "companyId"
        ],
        "properties": {
          "companyId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "projectId": {
            "type": "string",
            "example": "6592008029c8c3e4dc76256c"
          }
        }
      },
      "labels": {
        "type": "object",
        "required": [
          "source",
          "companyId"
        ],
        "properties": {
          "source": {
            "type": "string",
            "example": "super-secret-service"
          },
          "companyId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "projectId": {
            "type": "string",
            "example": "6592008029c8c3e4dc76256c"
          }
        }
      },
      "operation": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "time",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "PromptUpdated"
          },
          "status": {
            "type": "string",
            "enum": [
              "succeeded",
              "unspecified",
              "failed"
            ]
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "type": {
            "type": "string",
            "enum": [
              "create",
              "read",
              "update",
              "delete"
            ]
          }
        }
      },
      "resource": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "changes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "description": {
                  "type": "string",
                  "example": "Prompt was updated"
                },
                "name": {
                  "type": "string",
                  "example": "Prompt body"
                },
                "newValue": {
                  "$ref": "#/components/schemas/RecordPayloadResourceChangesInnerNewValue"
                },
                "oldValue": {
                  "$ref": "#/components/schemas/RecordPayloadResourceChangesInnerNewValue"
                }
              }
            }
          },
          "type": {
            "type": "string",
            "enum": [
              "compositeEnrichmentWorkflow",
              "document",
              "project",
              "prompt",
              "schema",
              "user"
            ]
          },
          "id": {
            "type": "string",
            "description": "Identifier of the resource",
            "example": "507f191e810c19729de860ea"
          }
        }
      },
      "RecordPayloadResourceChangesInnerNewValue": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      },
      "recordPayload": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actor",
          "labels",
          "operation",
          "resource"
        ],
        "properties": {
          "actor": {
            "$ref": "#/components/schemas/actor"
          },
          "labels": {
            "$ref": "#/components/schemas/labels"
          },
          "operation": {
            "$ref": "#/components/schemas/operation"
          },
          "resource": {
            "$ref": "#/components/schemas/resource"
          },
          "meta": {
            "$ref": "#/components/schemas/meta"
          }
        }
      }
    }
  }
}