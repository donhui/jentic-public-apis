{
  "openapi": "3.0.3",
  "info": {
    "title": "Confluent Cloud API",
    "version": "2.0.0",
    "description": "Confluent Cloud REST API for managing Kafka clusters, topics, connectors, IAM, organizations, and other Confluent Cloud resources.",
    "x-jentic-source-url": "https://docs.confluent.io/cloud/current/api.html"
  },
  "servers": [
    {
      "url": "https://api.confluent.cloud",
      "description": "Confluent Cloud API"
    },
    {
      "url": "https://{kafka_rest_endpoint}",
      "description": "Kafka REST Proxy",
      "variables": {
        "kafka_rest_endpoint": {
          "default": "pkc-xxxxx.region.provider.confluent.cloud:443"
        }
      }
    }
  ],
  "security": [
    {
      "BasicAuth": []
    },
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "IAM",
      "description": "Identity and Access Management"
    },
    {
      "name": "Organization",
      "description": "Organization and Environment management"
    },
    {
      "name": "ClusterManagement",
      "description": "Kafka Cluster management"
    },
    {
      "name": "Kafka",
      "description": "Kafka API v3 (Topics, ACLs, Consumer Groups, Records)"
    },
    {
      "name": "Connect",
      "description": "Confluent Connect connector management"
    }
  ],
  "paths": {
    "/iam/v2/api_keys": {
      "get": {
        "operationId": "listApiKeys",
        "tags": [
          "IAM"
        ],
        "summary": "List ApiKeys",
        "parameters": [
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "page_token",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "spec.owner.id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ApiKey list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
