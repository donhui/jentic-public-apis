  "components": {
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Cloud API Key as username, Cloud API Secret as password"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Confluent Cloud OAuth token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "detail": {
                  "type": "string"
                },
                "source": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "GenericRequest": {
        "type": "object",
        "additionalProperties": true,
        "description": "Request body - structure varies by endpoint"
      },
      "GenericResponse": {
        "type": "object",
        "properties": {
          "api_version": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/ObjectMeta"
          },
          "spec": {
            "type": "object"
          },
          "status": {
            "type": "object"
          }
        }
      },
      "ListResponse": {
        "type": "object",
        "properties": {
          "api_version": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "first": {
                "type": "string"
              },
              "last": {
                "type": "string"
              },
              "prev": {
                "type": "string",
                "nullable": true
              },
              "next": {
                "type": "string",
                "nullable": true
              },
              "total_size": {
                "type": "integer"
              }
            }
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GenericResponse"
            }
          }
        }
      },
      "ObjectMeta": {
        "type": "object",
        "properties": {
          "self": {
            "type": "string"
          },
          "resource_name": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "deleted_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "CreateTopicRequest": {
        "type": "object",
        "required": [
          "topic_name"
        ],
        "properties": {
          "topic_name": {
            "type": "string"
          },
          "partitions_count": {
            "type": "integer",
            "default": 6
          },
          "replication_factor": {
            "type": "integer",
            "default": 3
          },
          "configs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ProduceRecordRequest": {
        "type": "object",
        "properties": {
          "partition_id": {
            "type": "integer"
          },
          "headers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "value": {
                  "type": "string",
                  "format": "byte"
                }
              }
            }
          },
          "key": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "BINARY",
                  "JSON",
                  "STRING",
                  "AVRO",
                  "JSONSCHEMA",
                  "PROTOBUF"
                ]
              },
              "data": {}
            }
          },
          "value": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "BINARY",
                  "JSON",
                  "STRING",
                  "AVRO",
                  "JSONSCHEMA",
                  "PROTOBUF"
                ]
              },
              "data": {}
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}