{
  "openapi": "3.0.3",
  "info": {
    "title": "Katana API",
    "version": "1.0.0",
    "description": "Katana is a manufacturing resource planning (MRP) platform. The API provides access to customers, products, variants, sales orders, tax rates, and locations.",
    "x-jentic-source-url": "https://gist.github.com/fishera123/c7fef304bf475475778578072b449213"
  },
  "servers": [
    { "url": "https://api.katanamrp.com" }
  ],
  "paths": {
    "/oauth/token": {
      "post": {
        "operationId": "getOAuthToken", "summary": "Obtain OAuth access token", "tags": ["Authentication"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OAuthTokenRequest" } } } },
        "responses": {
          "200": { "description": "Token granted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OAuthTokenResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/KatanaUsers/authorize": {
      "get": {
        "operationId": "authorizeUser", "summary": "Authorize and get session token", "tags": ["Authentication"],
        "responses": {
          "200": { "description": "Session token", "content": { "application/json": { "schema": { "type": "object", "properties": { "token": { "type": "string" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/Customers/findOne": {
      "get": {
        "operationId": "findCustomer", "summary": "Find a customer", "tags": ["Customers"],
        "parameters": [
          { "name": "filter[where]", "in": "query", "schema": { "type": "string" }, "description": "Filter by email, phone, or name" },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Customer found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Customer" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/Customers": {
      "post": {
        "operationId": "createCustomer", "summary": "Create a customer", "tags": ["Customers"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateCustomerRequest" } } } },
        "responses": {
          "200": { "description": "Customer created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Customer" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/taxRates": {
      "get": {
        "operationId": "listTaxRates", "summary": "List tax rates", "tags": ["Settings"],
        "responses": {
          "200": { "description": "Tax rates", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TaxRate" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/Locations": {
      "get": {
        "operationId": "listLocations", "summary": "List locations", "tags": ["Settings"],
        "responses": {
          "200": { "description": "Locations", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Location" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/Variants": {
      "get": {
        "operationId": "listVariants", "summary": "List product variants", "tags": ["Products"],
        "parameters": [
          { "name": "filter[where][sku]", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Variants", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Variant" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/sales-orders": {
      "post": {
        "operationId": "createSalesOrder", "summary": "Create a sales order", "tags": ["Sales Orders"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateSalesOrderRequest" } } } },
        "responses": {
          "200": { "description": "Sales order created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SalesOrder" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OAuthTokenRequest": { "type": "object", "required": ["grant_type", "username", "password", "client_id"], "properties": { "grant_type": { "type": "string" }, "username": { "type": "string" }, "password": { "type": "string" }, "audience": { "type": "string" }, "scope": { "type": "string" }, "client_id": { "type": "string" } } },
      "OAuthTokenResponse": { "type": "object", "properties": { "access_token": { "type": "string" }, "token_type": { "type": "string" }, "expires_in": { "type": "integer" } } },
      "Customer": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "email": { "type": "string" }, "phone": { "type": "string" }, "comment": { "type": "string" } } },
      "CreateCustomerRequest": { "type": "object", "properties": { "name": { "type": "string" }, "email": { "type": "string" }, "phone": { "type": "string" }, "comment": { "type": "string" } } },
      "TaxRate": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "rate": { "type": "number" } } },
      "Location": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" } } },
      "Variant": { "type": "object", "properties": { "id": { "type": "string" }, "sku": { "type": "string" }, "name": { "type": "string" } } },
      "SalesOrder": { "type": "object", "properties": { "id": { "type": "string" }, "salesOrderNumber": { "type": "string" }, "customerId": { "type": "string" }, "createdDate": { "type": "string", "format": "date" } } },
      "CreateSalesOrderRequest": { "type": "object", "properties": { "salesOrderNumber": { "type": "string" }, "customerId": { "type": "string" }, "createdDate": { "type": "string", "format": "date" }, "locationId": { "type": "string" }, "deliveryDate": { "type": "string", "format": "date" }, "salesOrderRow": { "type": "array", "items": { "type": "object" } } } },
      "ErrorResponse": { "type": "object", "properties": { "error": { "type": "string" }, "message": { "type": "string" } } }
    },
    "securitySchemes": {
      "BearerAuth": { "type": "http", "scheme": "bearer", "description": "OAuth2 Bearer token" }
    }
  },
  "security": [ { "BearerAuth": [] } ]
}
