{
  "openapi": "3.0.3",
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/charleskoehl/InstantRoofer/1.0.0"
    },
    {
      "description": "Instant Roofer API",
      "url": "https://dashboard-dev-ck.instantroofer.com/api/zapier"
    }
  ],
  "info": {
    "description": "Enables the Instant Roofer Zapier Integration to communicate with Instant Roofer",
    "version": "1.0.0",
    "title": "Instant Roofer Zapier Integration API",
    "contact": {
      "email": "jeff@instantroofer.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://app.swaggerhub.com/apis/charleskoehl/InstantRoofer/1.0.0"
  },
  "paths": {
    "/auth": {
      "get": {
        "summary": "authenticate Zap with contractor account",
        "operationId": "authenticate",
        "description": "The endpoint URL Zapier should access with a contractor's API key to allow them to connect their Zap to their InstantRoofer account.\n",
        "parameters": [
          {
            "in": "query",
            "name": "apiKey",
            "description": "contractor's API key",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "zero or more leads found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "malformed api",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "unknown api key",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "tags": [
          "Authentication"
        ]
      }
    },
    "/leads": {
      "get": {
        "summary": "Perform List",
        "operationId": "performList",
        "description": "The endpoint URL Zapier should check for recent items, to provide sample data in the Zap Editor.\n",
        "parameters": [
          {
            "in": "query",
            "name": "apiKey",
            "description": "contractor's API key",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "zero or more leads found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Lead"
                  }
                }
              }
            }
          },
          "400": {
            "description": "malformed api key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "unknown api key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "500": {
            "description": "internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        },
        "tags": [
          "Leads"
        ]
      },
      "post": {
        "summary": "Subscribe",
        "operationId": "subscribe",
        "description": "Subscribe to new leads, providing a Zapier hook URL to post them to.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscribeParams"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "malformed API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "unknown API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "500": {
            "description": "internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        },
        "tags": [
          "Leads"
        ]
      },
      "put": {
        "summary": "Unsubscribe",
        "operationId": "unsubscribe",
        "description": "Unubscribe from new leads. Removes a specific subscription from the contractor's Subscription array.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscribeParams"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "subscription deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "malformed API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "unknown API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "500": {
            "description": "internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        },
        "tags": [
          "Leads"
        ]
      }
    }
  },
