  "info": {
    "version": "1.0.0",
    "title": "H Plus Sport",
    "description": "An api returning array of articles",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/2023SL93091/Assignment-3/1.0.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/Gayatri/Hplus/1.0.0"
