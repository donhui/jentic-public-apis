  "paths": {
    "/articles": {
      "get": {
        "summary": "Returns an array of Articles",
        "description": "An array of article in which each article consists of Title, Content,Date Posted, Category,Tags",
        "responses": {
          "200": {
            "description": "A JSON array of articles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "created-date": {
                        "type": "string",
                        "format": "date"
                      },
                      "tagline": {
                        "type": "string",
                        "example": "What's the best Exercise ?"
                      },
                      "content": {
                        "type": "string",
                        "example": "Lorem Ipsum Dodem dipsum Lorem Imsomep dipsum Dodem Lorem Ipsum Dodem Dipsum"
                      },
                      "category": {
                        "type": "string",
                        "example": "Exercise"
                      },
                      "tags": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "example": [
                            "walking",
                            "exercise",
                            "treadmill"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Articles not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}