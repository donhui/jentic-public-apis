{
  "openapi": "3.0.3",
  "info": {
    "title": "JotUrl API",
    "description": "JotURL is an all-in-one suite for your marketing links. Shorten, track, and manage URLs with advanced features including QR codes, CTAs, conversions tracking, and more.",
