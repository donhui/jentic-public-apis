  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained via /apis/tokens endpoint"
      },
      "sessionAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "_sid",
        "description": "Session ID obtained via /users/login"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object"
          }
        }
      },
      "StatusObject": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "text": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "rate": {
            "type": "number"
          }
        }
      },
      "DecodeResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "lang": {
                "type": "string"
              }
            }
          }
        }
      },
      "TimestampResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "timestamp": {
                "type": "number",
                "description": "Unix timestamp with microseconds"
              }
            }
          }
        }
      },
      "TranslateResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "lang": {
                "type": "string"
              }
            }
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "description": "HMAC_SHA256 hashed password"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "_sid": {
                "type": "string",
                "description": "Session ID"
              }
            }
          }
        }
      },
      "UserInfoResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "username": {
                "type": "string"
              },
              "email": {
                "type": "string"
              }
            }
          }
        }
      },
      "ApiKeysResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "public": {
                "type": "string"
              },
              "private": {
                "type": "string"
              }
            }
          }
        }
      },
      "ApiLimitsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "primary": {
                "type": "object"
              },
              "secondary": {
                "type": "object"
              }
            }
          }
        }
      },
      "ApiVersionsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "HasAccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusObject"
          },
          "result": {
            "type": "object",
            "properties": {
              "has_access": {
                "type": "integer",
                "enum": [0, 1]
              }
            }
          }
        }
      },
      "ShortenUrlRequest": {
        "type": "object",
        "required": ["long_url"],
        "properties": {
          "long_url": {
            "type": "string",
            "format": "uri",
            "description": "The URL to shorten"
          },
          "alias": {
            "type": "string",
            "description": "Custom alias for the short URL"
          },
          "domain_id": {
            "type": "string",
            "description": "Custom domain ID"
          }
        }
      },
