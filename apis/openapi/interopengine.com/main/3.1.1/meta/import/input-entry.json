            "type": "string",
            "format": "uri",
            "description": "Link URL"
          }
        }
      },
      "BundleEntry": {
        "type": "object",
        "properties": {
          "fullUrl": {
            "type": "string",
            "format": "uri",
            "description": "Full URL for the resource"
          },
