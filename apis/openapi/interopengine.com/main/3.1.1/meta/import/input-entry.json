{
  "openapi": "3.0.3",
  "info": {
    "title": "EMR Direct Open API",
    "description": "EMR Direct Open API providing read-only access to patient health records via HL7 FHIR R4 RESTful endpoints, aligned with US Core profiles (v3.1.1). Supports SMART App Launch Framework scopes and OAuth 2.0 authentication. Only TLS 1.2 connections are accepted.",
    "version": "3.1.1",
    "x-jentic-source-url": "https://www.interopengine.com/2021/open-api-documentation.html"
  },
  "servers": [
    {
      "url": "https://{baseURL}",
      "description": "EMR Direct FHIR R4 server (base URL provided by Data Holder)",
      "variables": {
        "baseURL": {
          "default": "fhir.example.com",
          "description": "The base URL obtained from the Data Holder"
        }
      }
    }
  ],
  "paths": {
    "/Patient": {
      "get": {
        "operationId": "searchpatients",
        "summary": "Search for patients",
        "description": "Search for patient records by identifier, name, gender, or birthdate.",
        "tags": [
          "Patient"
        ],
        "parameters": [
          {
            "name": "identifier",
            "in": "query",
            "description": "Patient identifier (e.g., MRN)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Patient name to search for",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gender",
            "in": "query",
            "description": "Patient gender (male, female, other, unknown)",
            "schema": {
              "type": "string",
              "enum": [
                "male",
                "female",
                "other",
                "unknown"
              ]
            }
          },
          {
            "name": "birthdate",
            "in": "query",
            "description": "Patient birth date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A FHIR Bundle containing matching Patient resources",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/Bundle"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - returns OperationOutcome with issue details",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationOutcome"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing, expired, or invalid access token"
          }
        }
      }
    },
