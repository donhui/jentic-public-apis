    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authentication with SMART App Launch Framework scopes. Supports Authorization Code and Client Credentials flows.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://{baseOAuthURL}/authz",
            "tokenUrl": "https://{baseOAuthURL}/token",
            "scopes": {
              "patient/Patient.read": "Read patient records (patient-level)",
              "patient/AllergyIntolerance.read": "Read allergy records (patient-level)",
              "patient/CarePlan.read": "Read care plans (patient-level)",
              "patient/CareTeam.read": "Read care teams (patient-level)",
              "patient/Condition.read": "Read conditions (patient-level)",
              "patient/Device.read": "Read device records (patient-level)",
              "patient/DiagnosticReport.read": "Read diagnostic reports (patient-level)",
              "patient/DocumentReference.read": "Read document references (patient-level)",
              "patient/Encounter.read": "Read encounters (patient-level)",
              "patient/Goal.read": "Read goals (patient-level)",
              "patient/Immunization.read": "Read immunizations (patient-level)",
              "patient/MedicationRequest.read": "Read medication requests (patient-level)",
              "patient/Observation.read": "Read observations (patient-level)",
              "patient/Procedure.read": "Read procedures (patient-level)",
              "patient/Provenance.read": "Read provenance (patient-level)",
              "user/*.read": "Read all resources (user-level wildcard)",
              "system/*.read": "Read all resources (system-level wildcard)",
              "offline_access": "Request refresh token"
            }
          },
          "clientCredentials": {
            "tokenUrl": "https://{baseOAuthURL}/token",
            "scopes": {
              "system/Patient.read": "Read patient records (system-level)",
              "system/*.read": "Read all resources (system-level wildcard)"
            }
          }
        }
      }
    }
