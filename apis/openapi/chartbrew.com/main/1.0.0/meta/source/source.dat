            "type": "object",
            "properties": {
              "timezone": {
                "type": "string",
                "example": "Asia/Bangkok"
              },
              "frequency": {
                "type": "string",
                "example": "every_x_minutes",
                "enum": [
                  "every_x_minutes",
                  "every_x_hours",
                  "every_x_days",
                  "daily",
                  "weekly"
                ]
              },
              "frequencyNumber": {
                "type": "string",
