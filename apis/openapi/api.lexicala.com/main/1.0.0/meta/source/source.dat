{
  "openapi": "3.0.3",
  "info": {
    "title": "Lexicala Dictionary API",
    "description": "The Lexicala Dictionary API provides access to a multilingual lexical database. It supports searching for headwords, retrieving full dictionary entries and senses, free-text definition search, and RDF/JSON-LD output.",
    "version": "1.0.0",
    "contact": {
      "url": "https://api.lexicala.com/documentation/"
    }
  },
  "servers": [
    {
      "url": "https://lexicala1.p.rapidapi.com",
      "description": "RapidAPI production server"
    }
  ],
  "security": [
    {
      "RapidAPIKey": []
    }
  ],
  "tags": [
    { "name": "Languages", "description": "Language and resource information" },
    { "name": "Search", "description": "Search for lexical entries and definitions" },
    { "name": "Entries", "description": "Retrieve complete dictionary entries" },
    { "name": "Senses", "description": "Retrieve individual word senses" },
    { "name": "RDF", "description": "RDF/JSON-LD formatted data" }
  ],
  "paths": {
    "/languages": {
      "get": {
        "operationId": "getLanguages",
        "summary": "Retrieve available languages and resources",
        "description": "Returns all available language codes, names, and the resources available for each language.",
        "tags": ["Languages"],
        "responses": {
          "200": {
            "description": "Successful response with available languages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LanguagesResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "search",
        "summary": "Search for lexical entries",
        "description": "Search for lexical entries by headword, with optional filters for part of speech, grammatical number, gender, and morphological analysis.",
        "tags": ["Search"],
        "parameters": [
          { "$ref": "#/components/parameters/SourceParam" },
          { "$ref": "#/components/parameters/LanguageParam" },
          { "$ref": "#/components/parameters/TextParam" },
          { "$ref": "#/components/parameters/PosParam" },
          { "$ref": "#/components/parameters/NumberParam" },
          { "$ref": "#/components/parameters/GenderParam" },
          { "$ref": "#/components/parameters/MorphParam" },
          { "$ref": "#/components/parameters/AnalyzedParam" },
          {
            "name": "antonyms",
            "in": "query",
            "description": "Search antonyms of the headword",
            "required": false,
            "schema": { "type": "boolean" }
          },
          {
            "name": "synonyms",
            "in": "query",
            "description": "Search synonyms of the headword",
            "required": false,
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/search-entries": {
      "get": {
        "operationId": "searchEntries",
        "summary": "Search returning complete entry objects",
        "description": "Search for lexical entries and return full entry objects with extended lexical data.",
        "tags": ["Search"],
        "parameters": [
          { "$ref": "#/components/parameters/SourceParam" },
          { "$ref": "#/components/parameters/LanguageParam" },
          { "$ref": "#/components/parameters/TextParam" },
          { "$ref": "#/components/parameters/PosParam" },
          { "$ref": "#/components/parameters/NumberParam" },
          { "$ref": "#/components/parameters/GenderParam" },
          { "$ref": "#/components/parameters/MorphParam" },
          { "$ref": "#/components/parameters/AnalyzedParam" },
          {
            "name": "antonyms",
            "in": "query",
            "description": "Search antonyms of the headword",
            "required": false,
            "schema": { "type": "boolean" }
          },
          {
            "name": "synonyms",
            "in": "query",
            "description": "Search synonyms of the headword",
            "required": false,
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results with full entry objects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchEntriesResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/entries/{entry_id}": {
      "get": {
        "operationId": "getEntry",
        "summary": "Retrieve a complete entry by ID",
        "description": "Retrieve the full dictionary entry for a given entry ID, including headword, senses, related entries, and metadata.",
        "tags": ["Entries"],
        "parameters": [
          {
            "name": "entry_id",
            "in": "path",
            "description": "Unique identifier of the dictionary entry",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with the full entry",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/senses/{sense_id}": {
      "get": {
        "operationId": "getSense",
        "summary": "Retrieve a specific sense by ID",
        "description": "Retrieve a single word sense by its unique sense identifier.",
        "tags": ["Senses"],
        "parameters": [
          {
            "name": "sense_id",
            "in": "path",
            "description": "Unique identifier of the sense",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with the sense",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SenseDetail"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/search-definitions": {
      "get": {
        "operationId": "searchDefinitions",
        "summary": "Free-text search in definitions",
        "description": "Search for entries by matching free text within their definitions.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "description": "Search term to match within definitions",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "lang",
            "in": "query",
            "description": "Target language code for the definitions",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching entries with sense IDs and definitions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchDefinitionsResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/search-rdf": {
      "get": {
        "operationId": "searchRdf",
        "summary": "Search returning RDF (JSON-LD) format",
        "description": "Search for lexical entries and return results in RDF/JSON-LD structured format.",
        "tags": ["RDF"],
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "description": "Headword to search for",
            "required": true,
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/AnalyzedParam" },
          { "$ref": "#/components/parameters/MorphParam" }
        ],
        "responses": {
          "200": {
            "description": "RDF/JSON-LD structured search results",
            "content": {
              "application/ld+json": {
                "schema": {
                  "$ref": "#/components/schemas/RdfResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/rdf/{entry_id}": {
      "get": {
        "operationId": "getRdfEntry",
        "summary": "Retrieve an entry in RDF format",
        "description": "Retrieve a complete dictionary entry in RDF/JSON-LD format by its entry ID.",
        "tags": ["RDF"],
        "parameters": [
          {
            "name": "entry_id",
            "in": "path",
            "description": "Unique identifier of the dictionary entry",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "RDF/JSON-LD structured entry",
            "content": {
              "application/ld+json": {
                "schema": {
                  "$ref": "#/components/schemas/RdfResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/fluky-search": {
      "get": {
        "operationId": "flukySearch",
        "summary": "Return a randomly selected entry",
        "description": "Retrieve a random dictionary entry, optionally filtered by source resource type and language.",
        "tags": ["Search"],
        "parameters": [
          { "$ref": "#/components/parameters/SourceParam" },
          {
            "name": "language",
            "in": "query",
            "description": "Language code to restrict the random selection. If omitted, a random language is used.",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "A randomly selected entry",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "RapidAPIKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-RapidAPI-Key",
        "description": "RapidAPI key for authentication"
      }
    },
    "parameters": {
      "SourceParam": {
        "name": "source",
        "in": "query",
        "description": "Resource to search in (e.g. global, password, multigloss, random)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["global", "password", "multigloss", "random"]
        }
      },
      "LanguageParam": {
        "name": "language",
        "in": "query",
        "description": "Language code (e.g. en, fr, de)",
        "required": true,
        "schema": { "type": "string" }
      },
      "TextParam": {
        "name": "text",
        "in": "query",
        "description": "Headword to search for",
        "required": true,
        "schema": { "type": "string" }
      },
      "PosParam": {
        "name": "pos",
        "in": "query",
        "description": "Part of speech filter (e.g. noun, verb, adjective)",
        "required": false,
        "schema": { "type": "string" }
      },
      "NumberParam": {
        "name": "number",
        "in": "query",
        "description": "Grammatical number filter (e.g. singular, plural)",
        "required": false,
        "schema": { "type": "string" }
      },
      "GenderParam": {
        "name": "gender",
        "in": "query",
        "description": "Grammatical gender filter (e.g. masculine, feminine, neuter)",
        "required": false,
        "schema": { "type": "string" }
      },
      "MorphParam": {
        "name": "morph",
        "in": "query",
        "description": "Include inflected forms in the search",
        "required": false,
        "schema": { "type": "boolean" }
      },
      "AnalyzedParam": {
        "name": "analyzed",
        "in": "query",
        "description": "Apply stemmer algorithm to broaden search",
        "required": false,
        "schema": { "type": "boolean" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid or missing parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing or invalid API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          }
        },
        "required": ["message"]
      },
      "LanguagesResponse": {
        "type": "object",
        "properties": {
          "resources": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/ResourceLanguages"
            },
            "description": "Map of resource names to their available languages"
          }
        }
      },
      "ResourceLanguages": {
        "type": "object",
        "properties": {
          "languages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LanguageInfo"
            }
          }
        }
      },
      "LanguageInfo": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "ISO language code"
          },
          "name": {
            "type": "string",
            "description": "Human-readable language name"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "n_results": {
            "type": "integer",
            "description": "Total number of results"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            }
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Entry ID"
          },
          "language": {
            "type": "string",
            "description": "Language code"
          },
          "headword": {
            "$ref": "#/components/schemas/Headword"
          },
          "pos": {
            "type": "string",
            "description": "Part of speech"
          },
          "senses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sense"
            }
          }
        }
      },
      "SearchEntriesResponse": {
        "type": "object",
        "properties": {
          "n_results": {
            "type": "integer",
            "description": "Total number of results"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Entry"
            }
          }
        }
      },
      "SearchDefinitionsResponse": {
        "type": "object",
        "properties": {
          "n_results": {
            "type": "integer",
            "description": "Total number of results"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DefinitionResult"
            }
          }
        }
      },
      "DefinitionResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Entry ID"
          },
          "language": {
            "type": "string",
            "description": "Language code"
          },
          "headword": {
            "$ref": "#/components/schemas/Headword"
          },
          "senses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sense"
            }
          }
        }
      },
      "Entry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique entry identifier"
          },
          "source": {
            "type": "string",
            "description": "Source resource name"
          },
          "language": {
            "type": "string",
            "description": "Language code"
          },
          "version": {
            "type": "integer",
            "description": "Entry version number"
          },
          "headword": {
            "$ref": "#/components/schemas/Headword"
          },
          "senses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sense"
            }
          },
          "related_entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RelatedEntry"
            },
            "description": "Entries related to this entry"
          }
        }
      },
      "Headword": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "The headword text"
          },
          "pos": {
            "type": "string",
            "description": "Part of speech"
          },
          "gender": {
            "type": "string",
            "description": "Grammatical gender"
          },
          "number": {
            "type": "string",
            "description": "Grammatical number"
          },
          "pronunciation": {
            "$ref": "#/components/schemas/Pronunciation"
          }
        }
      },
      "Pronunciation": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "description": "Phonetic transcription"
          }
        }
      },
      "Sense": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique sense identifier"
          },
          "definition": {
            "type": "string",
            "description": "Definition text"
          },
          "translations": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Translations keyed by language code"
          },
          "synonyms": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of synonyms"
          },
          "antonyms": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of antonyms"
          },
          "examples": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Example"
            },
            "description": "Usage examples"
          }
        }
      },
      "Example": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Example sentence or phrase"
          }
        }
      },
      "RelatedEntry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Related entry ID"
          },
          "relation": {
            "type": "string",
            "description": "Type of relation"
          }
        }
      },
      "SenseDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique sense identifier"
          },
          "source": {
            "type": "string",
            "description": "Source resource name"
          },
          "language": {
            "type": "string",
            "description": "Language code"
          },
          "entry_id": {
            "type": "string",
            "description": "Parent entry identifier"
          },
          "definition": {
            "type": "string",
            "description": "Definition text"
          },
          "translations": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "synonyms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "antonyms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Example"
            }
          }
        }
      },
      "RdfResponse": {
        "type": "object",
        "properties": {
          "@context": {
            "type": "object",
            "description": "JSON-LD context defining namespaces and term mappings",
            "additionalProperties": true
          },
          "@graph": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "description": "Array of RDF graph nodes representing lexical entries and senses"
          }
        }
      }
    }
  }
}