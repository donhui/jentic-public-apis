  "components": {
    "schemas": {
      "Country": {
        "type": "object",
        "required": [
          "loginID",
          "countryID",
          "codeCountry",
          "nameCountry",
          "imgNationalFlag"
        ],
        "properties": {
          "loginID": {
            "type": "string",
            "example": 504312,
            "description": "Um identificador exclusivo e imut\u00e1vel usado para identificar a conta do cliente."
          },
          "countryID": {
            "type": "string",
            "maxLength": 40,
            "example": 9,
            "description": "Um identificador exclusivo e imut\u00e1vel usado para identificar o cadastro do pa\u00eds."
          },
          "codeCountry": {
            "type": "string",
            "format": "(3)",
            "example": "BRA",
            "enum": [
              "AFG;ALB;ALG;AND;ANG;ANT;ASA;ARG;ARM;BRA;..."
            ],
            "description": "C\u00f3digo abreviado do pa\u00eds conforme descri\u00e7\u00e3o do COI."
          },
          "nameCountry": {
            "type": "string",
            "format": "(60)",
            "example": "BRASIL",
            "enum": [
              "Afeganist\u00e3o;Alb\u00e2nia;Arg\u00e9lia;Andorra;Angola;Ant\u00edgua e Barbuda;Samoa Americana;Argentina;Arm\u00eania;Brasil;..."
            ],
            "description": "Nome do pa\u00eds conforme descri\u00e7\u00e3o do COI."
          },
          "imgNationalFlag": {
            "type": "string",
            "format": "binary",
            "example": [
              "(filename=\"files/imgNationalFlag\")"
            ],
            "description": "Possibilita realizar upload da imagem da bandeira referente ao pa\u00eds. (filename=\"files/imgNationalFlag\")."
          }
        }
      },
      "CountryResponse": {
        "type": "object",
        "required": [
          "countryID"
        ],
        "properties": {
          "countryID": {
            "type": "string",
            "maxLength": 40,
            "description": "Um identificador exclusivo e imut\u00e1vel usado para identificar o pa\u00eds."
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "maxLength": 40,
            "description": "Code Message returned."
          },
          "message": {
            "type": "string",
            "maxLength": 400,
            "description": "Message returned."
          },
          "target": {
            "type": "string",
            "maxLength": 400,
            "description": "Message aditional information."
          }
        }
      }
    }
