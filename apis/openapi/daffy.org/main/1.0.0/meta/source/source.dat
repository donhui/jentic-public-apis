{
  "openapi": "3.0.3",
  "info": {
    "title": "Daffy API",
    "version": "1.0.0",
    "description": "Daffy donor-advised fund API for managing balances, donations, causes, contributions, gifts, non-profits, and user profiles.",
    "x-jentic-source-url": "https://docs.daffy.org"
  },
  "servers": [
    {
      "url": "https://public.daffy.org/v1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/users/me/balance": {
      "get": {
        "operationId": "getbalance",
        "summary": "Get your fund balance",
        "tags": [
          "Balance"
        ],
        "responses": {
          "200": {
            "description": "Fund balance details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Balance"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/users/me": {
      "get": {
        "operationId": "getmyprofile",
        "summary": "Get your user profile",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/users/{username}": {
      "get": {
        "operationId": "getuserprofile",
        "summary": "Get user profile by username",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Target user's username"
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/users/{user_id}/causes": {
      "get": {
        "operationId": "getusercauses",
        "summary": "Get causes for a user",
        "tags": [
          "Causes"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of causes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Cause"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/donations": {
      "get": {
        "operationId": "getmydonations",
        "summary": "Get your donations",
        "tags": [
          "Donations"
        ],
        "responses": {
          "200": {
            "description": "Paginated list of donations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DonationList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createdonation",
        "summary": "Create a donation",
        "tags": [
          "Donations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDonationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Donation created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Donation"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/donations/{donation_id}": {
      "delete": {
        "operationId": "canceldonation",
        "summary": "Cancel a donation",
        "tags": [
          "Donations"
        ],
        "parameters": [
          {
            "name": "donation_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Donation ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Donation cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/users/{user_id}/donations": {
      "get": {
        "operationId": "getuserdonations",
        "summary": "Get donations for a user",
        "tags": [
          "Donations"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of donations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DonationList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/users/{user_id}/donations/{donation_id}": {
      "get": {
        "operationId": "getdonation",
        "summary": "Get a specific donation",
        "tags": [
          "Donations"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "User ID"
          },
          {
            "name": "donation_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Donation ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Donation details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Donation"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/contributions": {
      "get": {
        "operationId": "getcontributions",
        "summary": "Get your contributions",
        "tags": [
          "Contributions"
        ],
        "responses": {
          "200": {
            "description": "Paginated list of contributions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContributionList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/gifts": {
      "get": {
        "operationId": "getgifts",
        "summary": "Get your gifts",
        "tags": [
          "Gifts"
        ],
        "responses": {
          "200": {
            "description": "Paginated list of gifts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GiftList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "creategift",
        "summary": "Create a gift",
        "tags": [
          "Gifts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGiftRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gift created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Gift"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/gifts/{code}": {
      "get": {
        "operationId": "getgiftbycode",
        "summary": "Get a gift by code",
        "tags": [
          "Gifts"
        ],
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Gift unique identifier code"
          }
        ],
        "responses": {
          "200": {
            "description": "Gift details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Gift"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/non_profits": {
      "get": {
        "operationId": "searchnonprofits",
        "summary": "Search non-profits",
        "tags": [
          "Non-Profits"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Text to search"
          },
          {
            "name": "cause_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by cause ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/NonProfit"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/non_profits/{ein}": {
      "get": {
        "operationId": "getnonprofitbyein",
        "summary": "Get non-profit by EIN",
        "tags": [
          "Non-Profits"
        ],
        "parameters": [
          {
            "name": "ein",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Non-profit EIN number"
          }
        ],
        "responses": {
          "200": {
            "description": "Non-profit details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NonProfit"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Balance": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "Total fund amount"
          },
          "pending_deposit_balance": {
            "type": "number",
            "description": "Money deposited but not yet accounted"
          },
          "portfolio_balance": {
            "type": "number",
            "description": "Money invested in portfolio"
          },
          "available_balance": {
            "type": "number",
            "description": "Money available for donations"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          },
          "cover_image": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "fund_name": {
            "type": "string"
          },
          "current_fund": {
            "$ref": "#/components/schemas/Fund"
          },
          "follows_user": {
            "type": "boolean"
          },
          "follows_viewer": {
            "type": "boolean"
          },
          "onboarding_status": {
            "type": "string",
            "enum": [
              "none",
              "complete"
            ]
          }
        }
      },
      "Fund": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "causes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Cause"
            }
          },
          "users": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Cause": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "color": {
            "type": "string",
            "description": "Hex color code"
          }
        }
      },
      "Donation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "amount": {
            "type": "number"
          },
          "ein": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "private_memo": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DonationList": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Donation"
            }
          }
        }
      },
      "CreateDonationRequest": {
        "type": "object",
        "required": [
          "amount",
          "ein"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 10,
            "description": "Donation amount (minimum $10)"
          },
          "ein": {
            "type": "string",
            "description": "Non-profit EIN"
          },
          "note": {
            "type": "string",
            "description": "Public message"
          },
          "private_memo": {
            "type": "string",
            "description": "Internal note"
          }
        }
      },
      "Contribution": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "units": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": [
              "bank_account_scheduled_deposit",
              "credit_card_scheduled_deposit",
              "crypto_payment",
              "stock_payment",
              "check_payment",
              "wire_payment",
              "check_daf_transfer",
              "wire_daf_transfer",
              "company_payment",
              "third_party_payment"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "success",
              "waiting_for_funds",
              "failed"
            ]
          },
          "valuation": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "received_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "ContributionList": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contribution"
            }
          }
        }
      },
      "Gift": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "code": {
            "type": "string",
            "format": "uuid"
          },
          "ein": {
            "type": "string",
            "nullable": true
          },
          "seen": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "claimed": {
            "type": "boolean"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "GiftList": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Gift"
            }
          }
        }
      },
      "CreateGiftRequest": {
        "type": "object",
        "required": [
          "name",
          "amount"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Beneficiary name"
          },
          "amount": {
            "type": "number",
            "minimum": 18,
            "description": "Gift amount (minimum $18)"
          }
        }
      },
      "NonProfit": {
        "type": "object",
        "properties": {
          "ein": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "website": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "public_url": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "logo": {
            "type": "string"
          },
          "cause": {
            "$ref": "#/components/schemas/Cause"
          },
          "causes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Cause"
            }
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "last": {
            "type": "integer"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key",
        "description": "Daffy API key"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing or invalid API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Balance",
      "description": "Operations related to Balance"
    },
    {
      "name": "Causes",
      "description": "Operations related to Causes"
    },
    {
      "name": "Contributions",
      "description": "Operations related to Contributions"
    },
    {
      "name": "Donations",
      "description": "Operations related to Donations"
    },
    {
      "name": "Gifts",
      "description": "Operations related to Gifts"
    },
    {
      "name": "Non-Profits",
      "description": "Operations related to Non-Profits"
    },
    {
      "name": "Users",
      "description": "Operations related to Users"
    }
  ]
}