{
  "openapi": "3.0.3",
  "info": {
    "title": "mindburp API",
    "description": "mindburp API for managing burps (tasks) via Zapier integration.",
    "version": "1.0.0",
    "contact": {
      "name": "mindburp",
      "url": "https://docs.mindburp.se/"
    }
  },
  "servers": [
    {
      "url": "https://app.mindburp.se",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/api/zapier/wh-subscribe": {
      "post": {
        "operationId": "subscribe",
        "summary": "Subscribe to Webhook",
        "description": "Trigger subscribe enrollment endpoint.",
        "tags": ["Webhooks"],
        "parameters": [
          {
            "name": "type",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["new_burp", "updated_burp", "completed_burp", "deleted_burp", "reburped_burp"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["hookUrl"],
                "properties": {
                  "hookUrl": { "type": "string", "format": "uri" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription created",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        }
      }
    },
    "/api/zapier/wh-unsubscribe": {
      "delete": {
        "operationId": "unsubscribe",
        "summary": "Unsubscribe from Webhook",
        "description": "Trigger unsubscribe endpoint.",
        "tags": ["Webhooks"],
        "parameters": [
          {
            "name": "type",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["new_burp", "updated_burp", "completed_burp", "deleted_burp", "reburped_burp"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["hookUrl"],
                "properties": {
                  "hookUrl": { "type": "string", "format": "uri" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Unsubscribed" }
        }
      }
    },
    "/api/zapier/performlist": {
      "get": {
        "operationId": "getPerformList",
        "summary": "Get Perform List",
        "description": "Gets last created connected burp if found, else returns a sample burp.",
        "tags": ["Burps"],
        "responses": {
          "200": {
            "description": "Burp object",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Burp" }
              }
            }
          }
        }
      }
    },
    "/api/zapier/getAllMyBurpIds": {
      "get": {
        "operationId": "getAllBurpIds",
        "summary": "Get All Burp IDs",
        "description": "Collects all your Zapier connected burp IDs.",
        "tags": ["Burps"],
        "responses": {
          "200": {
            "description": "Array of burp IDs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/v1/actions": {
      "post": {
        "operationId": "performAction",
        "summary": "Perform Action",
        "description": "Create, find, or update burp records.",
        "tags": ["Actions"],
        "parameters": [
          {
            "name": "type",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["create_burp", "find_burp", "update_burp"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ActionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Burp" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Burp": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "alertDate": { "type": "string", "format": "date-time" },
          "dueDate": { "type": "string", "format": "date-time" },
          "assignedTo": { "type": "string" },
          "categoryId": { "type": "string" },
          "categoryName": { "type": "string" }
        }
      },
      "ActionRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "alertDate": { "type": "string", "format": "date-time" },
          "description": { "type": "string" },
          "dueDate": { "type": "string", "format": "date-time" },
          "assignedTo": { "type": "string" },
          "categoryId": { "type": "string" },
          "categoryName": { "type": "string" },
          "dueDateRecFreq": { "type": "string" },
          "dueDateRecVal": { "type": "string" },
          "id": { "type": "string" }
        }
      }
    }
  }
}