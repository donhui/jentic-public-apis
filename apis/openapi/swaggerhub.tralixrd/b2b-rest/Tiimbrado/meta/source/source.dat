  },
  "paths": {
    "/auth/realms/apiman/protocol/openid-connect/token": {
      "post": {
        "tags": [
          "Seguridad"
        ],
        "summary": "Autenticacion OAUTH2",
        "description": "Regresa el token de autenticaci\u00f3n",
        "responses": {
          "200": {
            "description": "Token obtenido correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "user info to be filled",
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "name"
                ],
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "Nombre de usuario"
                  },
                  "password": {
                    "type": "string",
                    "description": "Password de usuario"
                  },
                  "grant_type": {
                    "type": "string",
                    "description": "Tipo de Acceso. Default: password"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Cliente de la aplicaci\u00f3n"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/apiman-gateway/preproduccion/timbradorprep/1.0": {
      "post": {
        "tags": [
          "Timbrado"
        ],
        "summary": "Timbrado Rest",
        "parameters": [
          {
            "name": "CustomerKey",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "description": "Timbrado Rest del Pac Timbrador\n",
        "requestBody": {
          "$ref": "#/components/requestBodies/Comprobante"
        },
        "responses": {
          "200": {
            "description": "Respuesta de validacion/TFD ante un CFDI v\u00e1lido",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/TimbreFiscalDigital"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "911:[{\"mensaje_sat\":\"El campo Total no corresponde con la suma del subtotal, menos los descuentos aplicables, m\u00e1s las contribuciones recibidas (impuestos trasladados - federales o locales, derechos, productos, aprovechamientos, aportaciones de seguridad social, contribuciones de mejoras) menos los impuestos retenidos.\",\"mensaje\":\"Las listas con los totales 10 y 0 no dan el resultado esperado: equals\",\"codigo_sat\":\"CFDI33118\"},{\"mensaje_sat\":\"Cuando el valor del campo Total se encuentre fuera de los l\u00edmites establecidos, debe existir el campo Confirmaci\u00f3n.\",\"mensaje\":\"El campo //cfdi:Comprobante/@Confirmacion debe estar presente\",\"codigo_sat\":\"CFDI33119\"},{\"mensaje_sat\":\"El valor registrado en el atributo \"Total\" es diferente de cero o el valor del atributo \"TipoDeComprobante\" es diferente de \"T\".\",\"mensaje\":\"Los campos //cfdi:Comprobante/@Total no son equals al valor 0\",\"codigo_sat\":\"CP105\"}]"
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Failed to classify input to Workflow."
                }
              },
              "application/json": {
                "schema": {
                  "type": "string",
                  "example": "[{\"mensaje_sat\":\"El campo Total no corresponde con la suma del subtotal, menos los descuentos aplicables, m\u00e1s las contribuciones recibidas (impuestos trasladados - federales o locales, derechos, productos, aprovechamientos, aportaciones de seguridad social, contribuciones de mejoras) menos los impuestos retenidos.\",\"mensaje\":\"Las listas con los totales 10 y 0 no dan el resultado esperado: equals\",\"codigo_sat\":\"CFDI33118\"},{\"mensaje_sat\":\"Cuando el valor del campo Total se encuentre fuera de los l\u00edmites establecidos, debe existir el campo Confirmaci\u00f3n.\",\"mensaje\":\"El campo //cfdi:Comprobante/@Confirmacion debe estar presente\",\"codigo_sat\":\"CFDI33119\"},{\"mensaje_sat\":\"El valor registrado en el atributo \"Total\" es diferente de cero o el valor del atributo \"TipoDeComprobante\" es diferente de \"T\".\",\"mensaje\":\"Los campos //cfdi:Comprobante/@Total no son equals al valor 0\",\"codigo_sat\":\"CP105\"}]"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "api_key": []
          }
        ]
      }
    }
  },
