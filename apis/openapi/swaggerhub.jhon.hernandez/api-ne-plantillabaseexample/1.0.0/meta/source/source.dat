  "paths": {
    "/personas/{idPersona}": {
      "get": {
        "summary": "Devuelve el documento Persona cuyo idPersona={idPersona} de la colecci\u00f3n personas",
        "operationId": "obtenerPersona",
        "tags": [
          "GestionPersona"
        ],
        "description": "Descripci\u00f3n detallada de la operaci\u00f3n.",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/PacificoSegurosPeru/Domain-Base/1.0.0#/components/parameters/Header-Transaccion-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/PacificoSegurosPeru/Domain-Base/1.0.0#/components/parameters/Header-Aplicacion-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/PacificoSegurosPeru/Domain-Base/1.0.0#/components/parameters/Header-Nombre-Aplicacion"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/PacificoSegurosPeru/Domain-Base/1.0.0#/components/parameters/Header-Usuario-Consumidor-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/PacificoSegurosPeru/Domain-Base/1.0.0#/components/parameters/Header-Nombre-Servicio-Consumidor"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/PacificoSegurosPeru/Domain-Base/1.0.0#/components/parameters/Header-Ocp-Apim-Subscription-Key"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/PacificoSegurosPeru/Domain-Base/1.0.0#/components/parameters/Header-Token-Seguridad"
          },
          {
            "$ref": "#/components/parameters/Path-idPersona"
          }
        ],
        "responses": {
          "200": {
            "description": "La persona ha sido registrada satisfactoriamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatosPersona"
                }
              }
            }
          },
          "204": {
            "description": "No se encontr\u00f3 un documento Persona en la colecci\u00f3n de personas (Sin datos)."
          },
          "400": {
            "description": "Solicitud Incorrecta",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuesta"
                },
                "examples": {
