                  }
                }
              }
            }
          },
          "422": {
            "description": "Entidad No Procesable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuesta"
                },
                "examples": {
                  "ID_Incorrecto": {
                    "$ref": "#/components/examples/ID_Incorrecto"
                  },
                  "Formato_ID": {
                    "$ref": "#/components/examples/Formato_ID"
                  },
                  "ID_Inactivo": {
                    "$ref": "#/components/examples/ID_Inactivo"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error Interno Del Servidor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuesta"
                },
                "examples": {
                  "Internal_Server_Error": {
                    "$ref": "#/components/examples/Internal_Server_Error"
                  }
                }
              }
            }
          }
        }
      },
