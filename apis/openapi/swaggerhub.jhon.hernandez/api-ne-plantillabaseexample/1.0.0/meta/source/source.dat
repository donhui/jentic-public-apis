      },
      "Formato_ID": {
        "summary": "FNE-MS-002 - Formato ID",
        "value": {
          "error": {
            "tipo": "FUNCIONAL",
            "codigo": "FNE-MS-002",
            "mensaje": "El ID de persona debe ser un n\u00famero positivo y entero, pero se recibi\u00f3: -5."
