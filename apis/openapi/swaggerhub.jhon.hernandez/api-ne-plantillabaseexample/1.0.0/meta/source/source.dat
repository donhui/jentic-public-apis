      "QueryNumeroDocumento": {
        "in": "query",
        "name": "numeroDocumento",
        "schema": {
          "type": "string",
          "description": "Numero de documento"
        }
      },
      "Path-idPersona": {
        "in": "path",
        "name": "idPersona",
        "schema": {
          "type": "integer"
        },
        "required": true,
        "description": "Identificador \u00fanico de persona"
      }
    },
    "schemas": {
      "DatosPersonas": {
        "type": "object",
        "properties": {
          "datos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PersonaRecurso"
            }
          }
        }
      },
      "DatosPersona": {
        "type": "object",
        "properties": {
          "datos": {
            "type": "object",
            "$ref": "#/components/schemas/PersonaRecurso"
          }
        }
      },
      "Direccion": {
        "description": "Informaci\u00f3n de direcci\u00f3n f\u00edsica",
        "type": "object",
        "properties": {
          "tipoDireccion": {
            "description": "Tipo de direcci\u00f3nd",
            "properties": {
              "codigo": {
                "description": "C\u00f3digo asociado a la descripci\u00f3n. Este valor es obligatorio.",
                "type": "string",
                "example": 1
              },
              "descripcion": {
                "description": "Descripci\u00f3n asociado al c\u00f3digo. Este valor es opcional",
                "type": "string",
                "example": "DOMICILIO"
              }
            },
            "required": [
              "codigo"
            ]
          }
        }
      },
      "PersonaRecurso": {
        "description": "Informaci\u00f3n de personas",
        "type": "object",
        "properties": {
          "idPersona": {
            "description": "Identificador \u00fanico de persona (Autogenerado)",
            "example": 783928373,
            "type": "string"
          },
          "tipoDocumento": {
            "description": "Tipo de documento del titular de la cuenta. Tipos de documentos soportados:\n<table border=1px>\n  <tr>\n    <th>C\u00f3digo</th>\n    <th>Descripci\u00f3n</th>\n  </tr>\n  <tr>\n    <td>1</td>\n    <td>DNI</td>\n  </tr>\n  <tr>\n    <td>3</td>\n    <td>CARNET DE EXTRANJERIA</td>\n  </tr>\n  <tr>\n    <td>4</td>\n    <td>PASAPORTE</td>\n  </td>\n</table>                  ",
            "type": "object",
            "properties": {
              "codigo": {
                "description": "C\u00f3digo asociado a la descripci\u00f3n. Este valor es obligatorio.",
                "type": "string",
                "example": 1
              },
              "descripcion": {
                "description": "Descripci\u00f3n asociado al c\u00f3digo. Este valor es opcional",
                "type": "string",
                "example": "DNI"
              }
            },
            "required": [
              "codigo"
            ]
          },
          "numeroDocumento": {
            "description": "N\u00famero de documento del titular de la cuenta.",
            "type": "string",
            "example": 44562738
          },
          "nombres": {
            "description": "Nombres de la persona",
            "type": "string",
            "example": "Jhon"
          },
          "apellidoPaterno": {
            "description": "Apellido Paterno de la persona",
            "type": "string",
            "example": "Doe"
          },
          "edad": {
            "description": "Edad de la persona",
            "type": "integer",
            "example": 1
          },
          "telefonos": {
            "description": "telefonos de la persona",
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "9282882829",
              "883828383"
            ]
          },
          "direcciones": {
            "description": "Liste de direcciones informadas por la persona",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Direccion"
            }
          },
          "correos": {
            "description": "correos electr\u00f3nicos de la persona",
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "correo1@juna.com",
              "jlucia@hotmail.com"
            ]
          }
        },
        "required": [
          "tipoDocumento",
          "numeroDocumento",
          "nombres",
          "apellidoPaterno",
          "edad",
          "telefonos",
          "correos"
        ]
      },
      "ErrorRespuesta": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "tipo": {
                "type": "string",
                "enum": [
                  "FUNCIONAL",
                  "SISTEMA"
                ]
              },
              "codigo": {
                "type": "string"
              },
              "mensaje": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Ocp-Apim-Subscription-Key"
      },
      "TokenJWT": {
        "description": "JWT bearer token de autenticaci\u00f3n.",
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}