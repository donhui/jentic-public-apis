{
  "openapi": "3.0.3",
  "info": {
    "title": "Ola Corporate API",
    "description": "Ola Corporate API for managing corporate users, rides, invoices, and expense codes.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://corporate.olacabs.com/docs/view-users"
  },
  "servers": [
    {
      "url": "https://devapi.olacabs.com",
      "description": "Development/API server"
    }
  ],
  "paths": {
    "/v1/api/corporate/users": {
      "get": {
        "operationId": "listusers",
        "summary": "View corporate users",
        "description": "Retrieves a list of corporate users with optional filtering.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by employee status"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of users to fetch"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Pagination offset"
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Unknown error"
          }
        },
        "security": [
          {
            "corporate_token": []
          }
        ]
      }
    },
    "/v1/api/corporate/user": {
      "post": {
        "operationId": "adduser",
        "summary": "Add a corporate user",
        "description": "Creates a new corporate user.",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "406": {
            "description": "User exists, invalid tag values, or missing GST"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "corporate_token": []
          }
        ]
      },
      "put": {
        "operationId": "updateuser",
        "summary": "Update a corporate user",
        "description": "Updates an existing corporate user. The corp_email_id cannot be changed.",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated"
          },
          "201": {
            "description": "User updated with default GST applied"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "User not found"
          },
          "406": {
            "description": "GST or tag validation failure"
          },
          "500": {
            "description": "Unknown error"
          }
        },
        "security": [
          {
            "corporate_token": []
          }
        ]
      },
      "delete": {
        "operationId": "deleteuser",
        "summary": "Delete a corporate user",
        "description": "Deletes a corporate user by email address.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "corp_email_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Employee email address"
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Unknown error"
          }
        },
        "security": [
          {
            "corporate_token": []
          }
        ]
      }
    },
    "/v1/api/corporate/rides": {
      "get": {
        "operationId": "listridesv1",
        "summary": "View rides (v1)",
        "description": "Retrieves corporate ride history.",
        "tags": [
          "Rides"
        ],
        "parameters": [
          {
            "name": "from_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date"
          },
          {
            "name": "to_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of rides to fetch"
          },
          {
            "name": "page_num",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort order by ride start time"
          },
          {
            "name": "user_email_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by user email"
          },
          {
            "name": "employee_code",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by employee code"
          },
          {
            "name": "anchor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "End row anchor ID for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "List of rides",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RidesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "corporate_token": []
          }
        ]
      }
    },
