  "components": {
    "schemas": {
      "UserSummary": {
        "type": "object",
        "properties": {
          "employee_gender": {
            "type": "string"
          },
          "user_type": {
            "type": "string"
          },
          "custom_field1": {
            "type": "string"
          },
          "custom_field2": {
            "type": "string"
          },
          "custom_field3": {
            "type": "string"
          },
          "custom_field4": {
            "type": "string"
          },
          "custom_field5": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "employee_code": {
            "type": "string"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": [
          "corp_email_id",
          "name",
          "groups"
        ],
        "properties": {
          "corp_email_id": {
            "type": "string",
            "maxLength": 255
          },
          "name": {
            "type": "string",
            "maxLength": 255
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 255
            }
          },
          "employee_phone_number": {
            "type": "string",
            "maxLength": 20
          },
          "employee_cost_center": {
            "type": "string",
            "maxLength": 64
          },
          "employee_code": {
            "type": "string",
            "maxLength": 64
          },
          "employee_base_location": {
            "type": "string",
            "maxLength": 255
          },
          "employee_designation": {
            "type": "string",
            "maxLength": 64
          },
          "employee_band": {
            "type": "string",
            "maxLength": 64
          },
          "employee_gender": {
            "type": "string",
            "maxLength": 10
          },
          "manager_name": {
            "type": "string",
            "maxLength": 128
          },
          "manager_email_address": {
            "type": "string",
            "maxLength": 150
          },
          "custom_field_1": {
            "type": "string",
            "maxLength": 64
          },
          "custom_field_2": {
            "type": "string",
            "maxLength": 64
          },
          "custom_field_3": {
            "type": "string",
            "maxLength": 64
          },
          "custom_field_4": {
            "type": "string",
            "maxLength": 255
          },
          "custom_field_5": {
            "type": "string",
            "maxLength": 255
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "required": [
          "corp_email_id",
          "name",
          "groups"
        ],
        "properties": {
          "corp_email_id": {
            "type": "string",
            "maxLength": 255,
            "description": "Cannot be changed, used for identification"
          },
          "name": {
            "type": "string",
            "maxLength": 255
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 255
            }
          },
          "user_status": {
            "type": "string",
            "enum": [
              "inactive"
            ],
            "description": "Set to inactive to deactivate user"
          },
          "employee_phone_number": {
            "type": "string",
            "maxLength": 20
          },
          "employee_cost_center": {
            "type": "string",
            "maxLength": 64
          },
          "employee_code": {
            "type": "string",
            "maxLength": 64
          },
          "employee_base_location": {
            "type": "string",
            "maxLength": 255
          },
          "employee_designation": {
            "type": "string",
            "maxLength": 64
          },
          "employee_band": {
            "type": "string",
            "maxLength": 64
          },
          "employee_gender": {
            "type": "string",
            "maxLength": 10
          },
          "manager_name": {
            "type": "string",
            "maxLength": 128
          },
          "manager_email_address": {
            "type": "string",
            "maxLength": 150
          },
          "custom_field_1": {
            "type": "string",
            "maxLength": 64
          },
          "custom_field_2": {
            "type": "string",
            "maxLength": 64
          },
          "custom_field_3": {
            "type": "string",
            "maxLength": 64
          },
