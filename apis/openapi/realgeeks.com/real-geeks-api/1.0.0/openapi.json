{
  "openapi": "3.0.3",
  "info": {
    "title": "Real Geeks API",
    "version": "1.0.0",
    "description": "Real Geeks Lead Router API for managing real estate leads.",
    "x-jentic-source-url": "https://developers.realgeeks.com/"
  },
  "servers": [
    {
      "url": "https://receivers.leadrouter.realgeeks.com/rest"
    }
  ],
  "paths": {
    "/sites/{site_uuid}/leads": {
      "post": {
        "operationId": "createLead",
        "summary": "Create new lead",
        "tags": [
          "Leads"
        ],
        "parameters": [
          {
            "name": "site_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": ""
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "400": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "201": {
            "description": "Created"
          }
        }
      }
    },
