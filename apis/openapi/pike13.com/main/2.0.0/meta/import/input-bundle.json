{
  "openapi": "3.0.3",
  "info": {
    "title": "Pike13 API",
    "version": "2.0.0",
    "description": "Pike13 is a business management platform for fitness, wellness, and education businesses. The API provides access to accounts, businesses, bookings, events, people, and more.",
    "x-jentic-source-url": "https://developer.pike13.com/docs/api/v2",
    "contact": {
      "name": "Pike13 API Support"
    }
  },
  "servers": [
    {
      "url": "https://{subdomain}.pike13.com/api/v2",
      "variables": {
        "subdomain": {
          "default": "app",
          "description": "Your Pike13 subdomain"
        }
      }
    }
  ],
