{
  "openapi": "3.0.3",
  "info": {
    "title": "Canvas LMS REST API",
    "description": "Canvas is the trusted, open-source learning management system (LMS). This API provides access to courses, users, assignments, enrollments, and other LMS resources.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://canvas.instructure.com/doc/api/"
  },
  "servers": [
    {
      "url": "https://{canvas_domain}",
      "description": "Canvas LMS instance",
      "variables": {
        "canvas_domain": {
          "default": "canvas.instructure.com",
          "description": "Your Canvas instance domain"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "courses",
      "description": "Course management"
    },
    {
      "name": "users",
      "description": "User management"
    },
    {
      "name": "assignments",
      "description": "Assignment management"
    },
    {
      "name": "enrollments",
      "description": "Enrollment management"
    }
  ],
  "paths": {
    "/api/v1/courses": {
      "get": {
        "operationId": "listYourCourses",
        "summary": "List your courses",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "enrollment_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "teacher",
                "student",
                "ta",
                "observer",
                "designer"
              ]
            }
          },
          {
            "name": "enrollment_state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "invited_or_pending",
                "completed"
              ]
            }
          },
          {
            "name": "state[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "unpublished",
                  "available",
                  "completed",
                  "deleted"
                ]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Course"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/{user_id}/courses": {
      "get": {
        "operationId": "listCoursesForUser",
        "summary": "List courses for a user",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "state[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Course"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/courses/{id}": {
      "get": {
        "operationId": "getCourse",
        "summary": "Get a single course",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "include[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateCourse",
        "summary": "Update a course",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "course": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "course_code": {
                        "type": "string"
                      },
                      "start_at": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "end_at": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "license": {
                        "type": "string"
                      },
                      "is_public": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteCourse",
        "summary": "Delete or conclude a course",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "event",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "delete",
                "conclude"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/accounts/{account_id}/courses": {
      "get": {
        "operationId": "listAccountCourses",
        "summary": "List courses in an account",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Course"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCourse",
        "summary": "Create a new course",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "course": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "course_code": {
                        "type": "string"
                      },
                      "start_at": {
                        "type": "string"
                      },
                      "end_at": {
                        "type": "string"
                      },
                      "license": {
                        "type": "string"
                      },
                      "is_public": {
                        "type": "boolean"
                      },
                      "term_id": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateMultipleCourses",
        "summary": "Update multiple courses",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "course_ids",
                  "event"
                ],
                "properties": {
                  "course_ids": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  },
                  "event": {
                    "type": "string",
                    "enum": [
                      "offer",
                      "conclude",
                      "delete",
                      "undelete"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Progress object"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/v1/courses/{course_id}/users": {
      "get": {
        "operationId": "listUsersInCourse",
        "summary": "List users in course",
        "tags": [
          "courses",
          "users"
        ],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "search_term",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "enrollment_type[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/courses/{course_id}/users/{user_id}/progress": {
      "get": {
        "operationId": "getUserProgress",
        "summary": "Get user progress in course",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CourseProgress"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/courses/{course_id}/settings": {
      "get": {
        "operationId": "getCourseSettings",
        "summary": "Get course settings",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Course settings"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "put": {
        "operationId": "updateCourseSettings",
        "summary": "Update course settings",
        "tags": [
          "courses"
        ],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "allow_student_discussion_topics": {
                    "type": "boolean"
                  },
                  "hide_final_grades": {
                    "type": "boolean"
                  },
                  "lock_all_announcements": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated settings"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
