            "type": "string"
          },
          "sortable_name": {
            "type": "string"
          },
          "short_name": {
            "type": "string"
          },
          "login_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "avatar_url": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Assignment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "due_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "points_possible": {
            "type": "number"
          },
          "grading_type": {
            "type": "string"
          },
          "submission_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "course_id": {
            "type": "integer"
          },
          "position": {
            "type": "integer"
          },
          "published": {
            "type": "boolean"
          }
        }
      },
      "Enrollment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "course_id": {
            "type": "integer"
          },
          "user_id": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "enrollment_state": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
