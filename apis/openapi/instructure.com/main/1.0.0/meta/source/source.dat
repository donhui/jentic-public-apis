  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Canvas API token"
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://{canvas_domain}/login/oauth2/auth",
            "tokenUrl": "https://{canvas_domain}/login/oauth2/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
