            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createAssignment",
        "summary": "Create an assignment",
        "tags": [
          "assignments"
        ],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "assignment": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      },
                      "due_at": {
                        "type": "string"
                      },
                      "points_possible": {
                        "type": "number"
                      },
                      "grading_type": {
                        "type": "string"
                      },
                      "submission_types": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "published": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
