{
  "openapi": "3.0.3",
  "info": {
    "title": "Your.Rentals Marketplace API",
    "description": "API for Your.Rentals all-in-one service for managing short term rental businesses",
    "version": "0.0.1",
    "contact": {},
    "x-jentic-source-url": "https://marketplace.your.rentals/swagger"
  },
  "servers": [
    {
      "url": "https://marketplace.your.rentals",
      "description": "Production"
    }
  ],
  "tags": [
    {
      "name": "zapier",
      "description": "Zapier Integration"
    },
    {
      "name": "super-adria",
      "description": "Super Adria Integration"
    },
    {
      "name": "Passepartout Integration",
      "description": "Passepartout Integration"
    },
    {
      "name": "Passepartout Listing Mappings",
      "description": "Passepartout Listing Mappings"
    },
    {
      "name": "Oxygen Integration",
      "description": "Oxygen Integration"
    },
    {
      "name": "Oxygen Listing Settings",
      "description": "Oxygen Listing Settings"
    }
  ],
  "paths": {
    "/zapier/webhooks": {
      "post": {
        "operationId": "createWebhook",
        "summary": "Create webhook subscription",
        "tags": ["zapier"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWebhookDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZapierWebhookSubscription"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "zapier": []
          }
        ]
      }
    },
    "/zapier/webhooks/{id}": {
      "delete": {
        "operationId": "removeWebhook",
        "summary": "Remove webhook subscription",
        "tags": ["zapier"],
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "zapier": []
          }
        ]
      }
    },
    "/zapier/auth/organizations/{organizationId}/api-keys": {
      "post": {
        "operationId": "createApiKey",
        "summary": "Generate API Key for Zapier integration",
        "tags": ["zapier"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateApiKeyDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZapierApiKey"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "get": {
        "operationId": "getApiKeys",
        "summary": "List API keys for organization",
        "tags": ["zapier"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API Keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ZapierApiKey"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/zapier/auth/organizations/{organizationId}/api-keys/{id}": {
      "delete": {
        "operationId": "deleteApiKey",
        "summary": "Delete API key for Zapier integration",
        "tags": ["zapier"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/zapier/auth/validate": {
      "get": {
        "operationId": "validateApiKey",
        "summary": "Validate API Key",
        "tags": ["zapier"],
        "responses": {
          "200": {
            "description": "Key validated"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "zapier": []
          }
        ]
      }
    },
    "/zapier/actions/bookings/list": {
      "post": {
        "operationId": "listBookings",
        "summary": "List bookings",
        "tags": ["zapier"],
        "parameters": [
          {
            "name": "_limit",
            "required": true,
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "_page",
            "required": true,
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "_sort",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ZapierBooking"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "zapier": []
          }
        ]
      }
    },
    "/organizations/{organizationId}/super-adria/{superAdriaIntegrationId}/units": {
      "get": {
        "operationId": "listAllUnits",
        "summary": "List all units",
        "tags": ["super-adria"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "superAdriaIntegrationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/organizations/{organizationId}/super-adria/{superAdriaIntegrationId}/listing-mappings/{listingId}": {
      "put": {
        "operationId": "upsertSuperAdriaListingMapping",
        "summary": "Upsert Super Adria listing mapping",
        "tags": ["super-adria"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "superAdriaIntegrationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "listingId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "number"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertSuperAdriaListingMappingDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "removeSuperAdriaListingMapping",
        "summary": "Remove Super Adria listing mapping",
        "tags": ["super-adria"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "superAdriaIntegrationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "listingId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/organizations/{organizationId}/super-adria": {
      "get": {
        "operationId": "listSuperAdriaIntegrations",
        "summary": "List Super Adria integrations",
        "tags": ["super-adria"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createSuperAdriaIntegration",
        "summary": "Create Super Adria integration",
        "tags": ["super-adria"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSuperAdriaIntegrationDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/organizations/{organizationId}/super-adria/{superAdriaIntegrationId}": {
      "get": {
        "operationId": "getSuperAdriaIntegrationById",
        "summary": "Get Super Adria integration by ID",
        "tags": ["super-adria"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "superAdriaIntegrationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "put": {
        "operationId": "updateSuperAdriaIntegration",
        "summary": "Update Super Adria integration",
        "tags": ["super-adria"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "superAdriaIntegrationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSuperAdriaIntegrationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "removeSuperAdriaIntegration",
        "summary": "Remove Super Adria integration",
        "tags": ["super-adria"],
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "superAdriaIntegrationId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "zapier": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "CreateWebhookDto": {
        "type": "object",
        "required": ["targetUrl", "triggerKey", "triggerData"],
        "properties": {
          "targetUrl": {
            "type": "string",
            "description": "Zapier target URL"
          },
          "triggerKey": {
            "type": "string",
            "description": "Zapier trigger key"
          },
          "triggerData": {
            "type": "string",
            "description": "Zapier trigger data"
          }
        }
      },
      "ZapierWebhookSubscription": {
        "type": "object",
        "required": ["id", "organizationId", "targetUrl", "triggerKey", "triggerData"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Webhook subscription ID"
          },
          "organizationId": {
            "type": "string",
            "description": "Organization ID"
          },
          "targetUrl": {
            "type": "string",
            "description": "Zapier Target URL"
          },
          "triggerKey": {
            "type": "string",
            "description": "Zapier trigger key"
          },
          "triggerData": {
            "type": "object",
            "description": "Zapier trigger data"
          }
        }
      },
      "CreateApiKeyDto": {
        "type": "object",
        "required": ["nickname"],
        "properties": {
          "nickname": {
            "type": "string",
            "description": "API Key Nickname"
          }
        }
      },
      "ZapierApiKey": {
        "type": "object",
        "required": ["id", "apiKey", "organizationId", "nickname"],
        "properties": {
          "id": {
            "type": "string",
            "description": "ID"
          },
          "apiKey": {
            "type": "string",
            "description": "API Key"
          },
          "organizationId": {
            "type": "string",
            "description": "Organization ID"
          },
          "nickname": {
            "type": "string",
            "description": "Nickname"
          }
        }
      },
      "ZapierBooking": {
        "type": "object",
        "required": ["id", "listingId", "accountId", "bookerFirstName", "bookerLastName", "bookerEmail", "bookerPhone", "status", "createdAt", "updatedAt", "checkInDate", "checkOutDate", "salesChannelId"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Booking ID"
          },
          "listingId": {
            "type": "number",
            "description": "Listing ID"
          },
          "accountId": {
            "type": "string",
            "description": "Account ID"
          },
          "bookerFirstName": {
            "type": "string",
            "description": "Booker first name"
          },
          "bookerLastName": {
            "type": "string",
            "description": "Booker last name"
          },
          "bookerEmail": {
            "type": "string",
            "description": "Booker email"
          },
          "bookerPhone": {
            "type": "string",
            "description": "Booker phone number"
          },
          "status": {
            "type": "string",
            "description": "Booking status",
            "enum": ["confirmed", "inProgress", "coolOff", "completed", "disputeByPm", "disputeByGuest", "cancelled", "cancelledByGuest", "cancelledByPm", "cancelledByYR", "pendingCancellation", "pendingCancellationGuest"]
          },
          "createdAt": {
            "type": "string",
            "description": "Booking creation date in ISO-8061 format"
          },
          "updatedAt": {
            "type": "string",
            "description": "Booking creation date in ISO-8061 format"
          },
          "checkInDate": {
            "type": "string",
            "description": "Booking check-in date in YYYY-MM-DD"
          },
          "checkOutDate": {
            "type": "string",
            "description": "Booking check-out date in YYYY-MM-DD"
          },
          "salesChannelId": {
            "type": "string",
            "description": "Sales Channel ID"
          }
        }
      },
      "UpsertSuperAdriaListingMappingDto": {
        "type": "object",
        "properties": {}
      },
      "CreateSuperAdriaIntegrationDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateSuperAdriaIntegrationDto": {
        "type": "object",
        "properties": {}
      },
      "CreatePP2IntegrationDto": {
        "type": "object",
        "properties": {}
      },
      "UpdatePP2IntegrationDto": {
        "type": "object",
        "properties": {}
      },
      "UpsertPP2ListingMappingDto": {
        "type": "object",
        "properties": {}
      },
      "CreateOxygenIntegrationDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateOxygenIntegrationDto": {
        "type": "object",
        "properties": {}
      },
      "UpsertListingSettingsDto": {
        "type": "object",
        "properties": {}
      },
      "BatchSendPdfDto": {
        "type": "object",
        "properties": {}
      }
    }
  },
  "security": [
    {
      "bearer": []
    }
  ]
}
