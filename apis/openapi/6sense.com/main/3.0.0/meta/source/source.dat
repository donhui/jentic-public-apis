{
  "openapi": "3.0.3",
  "info": {
    "title": "6sense API",
    "version": "3.0.0",
    "description": "6sense provides APIs for company identification, firmographics enrichment, lead scoring, people enrichment, and people search. These APIs help identify anonymous website visitors, enrich contact and company records, and score leads.",
    "x-jentic-source-url": "https://api.6sense.com/docs"
  },
  "servers": [
    {
      "url": "https://api.6sense.com",
      "description": "6sense Main API"
    },
    {
      "url": "https://epsilon.6sense.com",
      "description": "6sense Company Identification API"
    },
    {
      "url": "https://scribe.6sense.com",
      "description": "6sense Lead Scoring API"
    }
  ],
  "paths": {
    "/v3/company/details": {
      "get": {
        "operationId": "identifyCompany",
        "summary": "Identify company from IP address",
        "description": "Identifies anonymous website visitors by taking an IP address and matching it to an Account. Returns company data, scores, segments, and confidence level.",
        "tags": ["Company Identification"],
        "parameters": [
          {
            "name": "ip",
            "in": "query",
            "required": true,
            "description": "IP address to identify",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful company identification",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyIdentificationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          }
        }
      }
    },
    "/v1/enrichment/company": {
      "post": {
        "operationId": "enrichCompany",
        "summary": "Enrich company firmographics",
        "description": "Delivers company data using email or domain. Returns company firmographic data and segments.",
        "tags": ["Company Firmographics"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CompanyEnrichmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful company enrichment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyEnrichmentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          },
          "404": {
            "description": "Invalid email or company not found"
          }
        }
      }
    },
    "/v2/people/enrichment": {
      "post": {
        "operationId": "enrichCompanyV2",
        "summary": "Enrich company firmographics (v2)",
        "description": "Version 2 of Company Firmographics API. Delivers company data using email.",
        "tags": ["Company Firmographics"],
        "servers": [
          {
            "url": "https://scribe.6sense.com"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/LeadScoringRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful company enrichment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyEnrichmentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/v2/people/full": {
      "post": {
        "operationId": "getLeadScoringAndFirmographics",
        "summary": "Get lead scoring and firmographics",
        "description": "Combines responses from Company Firmographics and Lead Scoring APIs. Returns company data, scores, and segments.",
        "tags": ["Lead Scoring"],
        "servers": [
          {
            "url": "https://scribe.6sense.com"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/LeadScoringRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful lead scoring and firmographics response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeadScoringFullResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/v2/people/score": {
      "post": {
        "operationId": "scoreLeads",
        "summary": "Score leads",
        "description": "Returns scores for a given lead including intent scores, buying stages, profile fits, and contact grades.",
        "tags": ["Lead Scoring"],
        "servers": [
          {
            "url": "https://scribe.6sense.com"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/LeadScoringRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful lead scoring response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeadScoringResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/v2/enrichment/people": {
      "post": {
        "operationId": "enrichPeople",
        "summary": "Enrich people records",
        "description": "Enhance contact records by returning detailed information about professionals. Supports up to 25 queries per request with a rate limit of 20 queries per second.",
        "tags": ["People Enrichment"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "maxItems": 25,
                "items": {
                  "$ref": "#/components/schemas/PeopleEnrichmentQuery"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful people enrichment",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PersonEnrichmentResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          }
        }
      }
    },
    "/v2/search/people": {
      "post": {
        "operationId": "searchPeople",
        "summary": "Search for people in an organization",
        "description": "Search for people in an organization. Returns list of profiles for a domain. Rate limited to 20 queries per second.",
        "tags": ["People Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PeopleSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful people search",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeopleSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          }
        }
      }
    },
    "/v2/search/dictionary": {
      "get": {
        "operationId": "getSearchDictionary",
        "summary": "Get people search filter options",
        "description": "Returns available filter options including job titles, industries, and locations for use with the People Search API.",
        "tags": ["People Search"],
        "responses": {
          "200": {
            "description": "Successful dictionary retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchDictionary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CompanyIdentificationResponse": {
        "type": "object",
        "properties": {
          "company": {
            "$ref": "#/components/schemas/Company"
          },
          "scores": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Score"
            }
          },
          "segments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Segment"
            }
          },
          "confidence": {
            "type": "string",
            "description": "Confidence level of the identification"
          }
        }
      },
      "Company": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "employeeCount": {
            "type": "string"
          },
          "revenue": {
            "type": "string"
          },
          "sic": {
            "type": "string"
          },
          "naics": {
            "type": "string"
          }
        }
      },
      "Score": {
        "type": "object",
        "properties": {
          "product": {
            "type": "string"
          },
          "intentScore": {
            "type": "integer"
          },
          "profileScore": {
            "type": "integer"
          },
          "buyingStage": {
            "type": "string"
          },
          "contactGrade": {
            "type": "string"
          }
        }
      },
      "Segment": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        }
      },
      "CompanyEnrichmentRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address (mandatory if domain is blank)"
          },
          "domain": {
            "type": "string",
            "description": "Company domain"
          },
          "country": {
            "type": "string",
            "description": "Country"
          },
          "company": {
            "type": "string",
            "description": "Company name"
          },
          "industry": {
            "type": "string",
            "description": "Industry"
          },
          "title": {
            "type": "string",
            "description": "Job title"
          },
          "role": {
            "type": "string",
            "description": "Role"
          },
          "firstname": {
            "type": "string",
            "description": "First name"
          },
          "lastname": {
            "type": "string",
            "description": "Last name"
          },
          "leadsource": {
            "type": "string",
            "description": "Lead source"
          }
        }
      },
      "CompanyEnrichmentResponse": {
        "type": "object",
        "properties": {
          "company": {
            "$ref": "#/components/schemas/Company"
          },
          "segments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Segment"
            }
          }
        }
      },
      "LeadScoringRequest": {
        "type": "object",
        "required": ["email", "country"],
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address (required)"
          },
          "country": {
            "type": "string",
            "description": "Country (required)"
          },
          "website": {
            "type": "string",
            "description": "Website URL"
          },
          "company": {
            "type": "string",
            "description": "Company name"
          },
          "title": {
            "type": "string",
            "description": "Job title"
          },
          "leadsource": {
            "type": "string",
            "description": "Lead source"
          },
          "firstname": {
            "type": "string",
            "description": "First name"
          },
          "lastname": {
            "type": "string",
            "description": "Last name"
          },
          "role": {
            "type": "string",
            "description": "Role"
          },
          "industry": {
            "type": "string",
            "description": "Industry"
          }
        }
      },
      "LeadScoringFullResponse": {
        "type": "object",
        "properties": {
          "company": {
            "$ref": "#/components/schemas/Company"
          },
          "scores": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Score"
            }
          },
          "segments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Segment"
            }
          }
        }
      },
      "LeadScoringResponse": {
        "type": "object",
        "properties": {
          "scores": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Score"
            }
          }
        }
      },
      "PeopleEnrichmentQuery": {
        "type": "object",
        "properties": {
          "peopleId": {
            "type": "string",
            "description": "6sense people ID"
          },
          "email": {
            "type": "string",
            "description": "Email address"
          },
          "linkedinUrl": {
            "type": "string",
            "description": "LinkedIn profile URL"
          },
          "referenceKeys": {
            "type": "object",
            "description": "Custom reference keys for tracking"
          }
        }
      },
      "PersonEnrichmentResult": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "jobTitle": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "linkedinUrl": {
            "type": "string"
          },
          "companyInfo": {
            "$ref": "#/components/schemas/Company"
          }
        }
      },
      "PeopleSearchRequest": {
        "type": "object",
        "required": ["domain"],
        "properties": {
          "domain": {
            "type": "string",
            "description": "Company domain to search"
          },
          "filters": {
            "type": "object",
            "properties": {
              "locations": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "industries": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "jobTitles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "PeopleSearchResponse": {
        "type": "object",
        "properties": {
          "profiles": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "jobTitle": {
                  "type": "string"
                },
                "hasEmail": {
                  "type": "boolean"
                },
                "hasPhone": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "SearchDictionary": {
        "type": "object",
        "properties": {
          "jobTitles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "industries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API Token authentication. Format: Token {api_token}"
      }
    }
  },
  "security": [
    {
      "apiToken": []
    }
  ]
}