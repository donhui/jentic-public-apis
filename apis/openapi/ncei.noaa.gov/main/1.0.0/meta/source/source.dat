{
  "openapi": "3.0.3",
  "info": {
    "title": "NCEI Data Service API",
    "version": "1.0.0",
    "description": "The NCEI (National Centers for Environmental Information) Climate Data Online web service provides access to environmental datasets including weather observations, climate normals, and other data from NOAA's archives.",
    "x-jentic-source-url": "https://www.ncei.noaa.gov/support/access-data-service-api-user-documentation"
  },
  "servers": [
    {
      "url": "https://www.ncei.noaa.gov/access/services/data"
    }
  ],
  "paths": {
    "/v1": {
      "get": {
        "operationId": "getData",
        "summary": "Retrieve environmental data",
        "description": "Retrieves environmental data based on specified dataset, date range, stations, data types, and other filters.",
        "tags": ["Data"],
        "parameters": [
          {
            "name": "dataset",
            "in": "query",
            "required": true,
            "description": "The dataset to query for data (e.g., daily-summaries, global-summary-of-the-day, etc.).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stations",
            "in": "query",
            "required": false,
            "description": "Comma-separated station identifiers to filter results.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "description": "Start date in ISO 8601 format (YYYY-MM-DD or YYYY-MM-DDTHH:mm:ss).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "End date in ISO 8601 format (YYYY-MM-DD or YYYY-MM-DDTHH:mm:ss).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "dataTypes",
            "in": "query",
            "required": false,
            "description": "Comma-separated data type names (case-sensitive).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bbox",
            "in": "query",
            "required": false,
            "description": "Bounding box as N,W,S,E. Latitude range: -90 to 90, Longitude range: -180 to 180.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Response format. Default is csv.",
            "schema": {
              "type": "string",
              "enum": ["csv", "ssv", "json", "pdf", "netcdf"],
              "default": "csv"
            }
          },
          {
            "name": "includeAttributes",
            "in": "query",
            "required": false,
            "description": "Whether to display data type attributes. Default is false.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "includeStationName",
            "in": "query",
            "required": false,
            "description": "Whether to include station name in results. Default is false.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "includeStationLocation",
            "in": "query",
            "required": false,
            "description": "Whether to include station geographic location. Default is false.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "units",
            "in": "query",
            "required": false,
            "description": "Convert output values to specified unit system.",
            "schema": {
              "type": "string",
              "enum": ["metric", "standard"]
            }
          },
          {
            "name": "options",
            "in": "query",
            "required": false,
            "description": "Comma-separated options with colon-separated values for additional data processing.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing the requested environmental data.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataRecord"
                  }
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid parameters or missing required fields.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DataRecord": {
        "type": "object",
        "properties": {
          "DATE": {
            "type": "string",
            "description": "Observation date."
          },
          "STATION": {
            "type": "string",
            "description": "Station identifier."
          },
          "NAME": {
            "type": "string",
            "description": "Station name (if includeStationName is true)."
          },
          "LATITUDE": {
            "type": "number",
            "description": "Station latitude (if includeStationLocation is true)."
          },
          "LONGITUDE": {
            "type": "number",
            "description": "Station longitude (if includeStationLocation is true)."
          }
        },
        "additionalProperties": true
      },
      "Error": {
        "type": "object",
        "properties": {
          "errorMessage": {
            "type": "string",
            "description": "Human-readable error message."
          },
          "errorCode": {
            "type": "string",
            "description": "Error code identifier."
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of specific error details."
          }
        }
      }
    }
  }
}