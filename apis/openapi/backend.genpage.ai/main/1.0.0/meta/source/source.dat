{
  "openapi": "3.0.3",
  "info": {
    "title": "GenPage External API Documentation",
    "description": "GenPage is an AI-personalized landing page generator for B2B sales outreach that helps you cut through the noise and win more deals.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://backend.genpage.ai/docs/openapi.yaml"
  },
  "servers": [
    { "url": "https://backend.genpage.ai" }
  ],
  "tags": [
    { "name": "Audiences", "description": "Audience management" },
    { "name": "Authentication", "description": "Token generation and testing" },
    { "name": "Campaigns", "description": "Campaign management" },
    { "name": "Endpoints", "description": "General API endpoints" },
    { "name": "Leads", "description": "Lead upsert and retrieval" },
    { "name": "Workspaces", "description": "Workspace management" },
    { "name": "Zapier", "description": "Zapier integration endpoints" }
  ],
  "security": [{ "apiKeyAuth": [] }],
  "paths": {
    "/api/external/v1/audiences/get-list": {
      "get": {
        "tags": ["Audiences"],
        "summary": "Get the list of audiences",
        "operationId": "getAudiencesList",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["workspace_id"], "properties": { "workspace_id": { "type": "integer", "example": 16 } } } } }
        },
        "responses": {
          "200": { "description": "List of audiences", "content": { "application/json": { "schema": { "type": "object", "properties": { "audiences": { "type": "array", "items": { "$ref": "#/components/schemas/Audience" } } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/generate-api-token": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Generate an API token",
        "operationId": "generateApiToken",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["name", "workspace_id"], "properties": { "name": { "type": "string", "minLength": 2, "maxLength": 255 }, "workspace_id": { "type": "integer", "example": 16 } } } } }
        },
        "responses": {
          "200": { "description": "Token generated", "content": { "application/json": { "schema": { "type": "object", "properties": { "token": { "type": "string" } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/hello-world": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Test authentication endpoint",
        "operationId": "testAuth",
        "responses": {
          "200": { "description": "Success", "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/campaigns/get-list": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "Get the list of campaigns",
        "operationId": "getCampaignsList",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["workspace_id"], "properties": { "workspace_id": { "type": "integer", "example": 16 } } } } }
        },
        "responses": {
          "200": { "description": "List of campaigns", "content": { "application/json": { "schema": { "type": "object", "properties": { "campaigns": { "type": "array", "items": { "$ref": "#/components/schemas/Campaign" } } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/get-api-tokens": {
      "get": {
        "tags": ["Endpoints"],
        "summary": "Get API tokens",
        "operationId": "getApiTokens",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["workspace_id"], "properties": { "workspace_id": { "type": "integer" } } } } }
        },
        "responses": {
          "200": { "description": "List of tokens" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/api/external/v1/delete-api-token": {
      "delete": {
        "tags": ["Endpoints"],
        "summary": "Delete an API token",
        "operationId": "deleteApiToken",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["token_id"], "properties": { "token_id": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Token deleted" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/api/external/v1/leads/upsert-leads": {
      "post": {
        "tags": ["Leads"],
        "summary": "Upsert multiple leads",
        "operationId": "upsertLeads",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpsertLeadsRequest" } } }
        },
        "responses": {
          "200": { "description": "Job created", "content": { "application/json": { "schema": { "type": "object", "properties": { "job_id": { "type": "string" } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/leads/upsert-lead": {
      "post": {
        "tags": ["Leads"],
        "summary": "Upsert a single lead",
        "operationId": "upsertLead",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpsertLeadRequest" } } }
        },
        "responses": {
          "200": { "description": "Lead upserted", "content": { "application/json": { "schema": { "type": "object", "properties": { "genpage_url": { "type": "string" } } } } } },
          "400": { "description": "Missing required fields", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/leads/get-status": {
      "get": {
        "tags": ["Leads"],
        "summary": "Get job status",
        "operationId": "getLeadJobStatus",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["job_id"], "properties": { "job_id": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Job status", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string", "enum": ["pending", "completed", "failed"] }, "processed_rows": { "type": "integer" }, "total_rows": { "type": "integer" } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/leads/get-leads": {
      "get": {
        "tags": ["Leads"],
        "summary": "Get leads from a job",
        "operationId": "getLeadsByJob",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["job_id"], "properties": { "job_id": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "List of leads", "content": { "application/json": { "schema": { "type": "object", "properties": { "leads": { "type": "array", "items": { "$ref": "#/components/schemas/Lead" } } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/workspaces/get-list": {
      "get": {
        "tags": ["Workspaces"],
        "summary": "Get the list of workspaces",
        "operationId": "getWorkspacesList",
        "responses": {
          "200": { "description": "List of workspaces", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Workspace" } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/workspaces/get-variable-list": {
      "get": {
        "tags": ["Workspaces"],
        "summary": "Get workspace variables",
        "operationId": "getWorkspaceVariables",
        "parameters": [
          { "name": "workspace_id", "in": "query", "required": true, "schema": { "type": "integer", "example": 16 } }
        ],
        "responses": {
          "200": { "description": "List of variables", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object", "properties": { "key": { "type": "string" } } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/api/external/v1/zapier/test": {
      "get": {
        "tags": ["Zapier"],
        "summary": "Test Zapier authentication",
        "operationId": "testZapierAuth",
        "responses": {
          "200": { "description": "Auth test successful", "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" }, "user": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "email": { "type": "string" } } } } } } } },
          "401": { "description": "Unauthenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/external/v1/zapier/upsert-lead": {
      "post": {
        "tags": ["Zapier"],
        "summary": "Create a lead through Zapier",
        "operationId": "zapierUpsertLead",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ZapierUpsertLeadRequest" } } }
        },
        "responses": {
          "200": { "description": "Lead created" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthenticated" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Bearer token for API authentication"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": { "message": { "type": "string" } }
      },
      "Audience": {
        "type": "object",
        "properties": { "id": { "type": "integer" }, "name": { "type": "string" } }
      },
      "Campaign": {
        "type": "object",
        "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "slug": { "type": "string" } }
      },
      "Workspace": {
        "type": "object",
        "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "slug": { "type": "string" } }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "lead_id": { "type": "integer" },
          "genpage_url": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "company_name": { "type": "string" }
        }
      },
      "UpsertLeadsRequest": {
        "type": "object",
        "required": ["from", "campaign_id", "audience_id", "leads"],
        "properties": {
          "from": { "type": "string", "description": "Service name sending the leads" },
          "campaign_id": { "type": "integer" },
          "audience_id": { "type": "integer", "nullable": true },
          "callback_url": { "type": "string", "format": "uri", "nullable": true },
          "is_generate_ai_analysis": { "type": "boolean", "nullable": true },
          "leads": { "type": "array", "items": { "type": "object", "properties": { "lead_id": { "type": "integer" }, "genpage_url": { "type": "string" }, "values": { "type": "object" } } } }
        }
      },
      "UpsertLeadRequest": {
        "type": "object",
        "required": ["from", "campaign_id", "values"],
        "properties": {
          "from": { "type": "string" },
          "campaign_id": { "type": "integer" },
          "callback_url": { "type": "string", "format": "uri", "nullable": true },
          "is_generate_ai_analysis": { "type": "boolean", "nullable": true },
          "lead_id": { "type": "integer", "nullable": true },
          "genpage_url": { "type": "string", "nullable": true },
          "values": { "type": "object", "description": "Key/value pairs with lead data" }
        }
      },
      "ZapierUpsertLeadRequest": {
        "type": "object",
        "required": ["workspace_id", "campaign_id", "callback_url"],
        "properties": {
          "workspace_id": { "type": "integer" },
          "campaign_id": { "type": "integer" },
          "is_test": { "type": "boolean", "nullable": true },
          "linkedin_profile_url": { "type": "string", "nullable": true },
          "company_domain": { "type": "string", "nullable": true },
          "email": { "type": "string", "format": "email", "nullable": true },
          "callback_url": { "type": "string", "format": "uri" },
          "custom_data": { "type": "object", "nullable": true }
        }
      }
    }
  }
}
