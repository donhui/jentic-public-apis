{
  "openapi": "3.0.3",
  "info": {
    "title": "Pushwoosh Messages API",
    "version": "1.3.0",
    "description": "The Pushwoosh Messages API enables creating, managing, and tracking push notifications. It supports multi-platform push delivery (iOS, Android, Web, etc.) with rich customization options including templates, targeting, scheduling, and platform-specific parameters.",
    "x-jentic-source-url": "https://docs.pushwoosh.com/platform-docs/api-reference/messages-api"
  },
  "servers": [
    {
      "url": "https://api.pushwoosh.com/json/1.3"
    }
  ],
  "paths": {
    "/createMessage": {
      "post": {
        "operationId": "createMessage",
        "summary": "Create a push notification",
        "description": "Create and send a new push notification to application subscribers.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "application": {"type": "string", "description": "Pushwoosh application code"},
                      "auth": {"type": "string", "description": "API access token from Pushwoosh Control Panel"},
                      "notifications": {
                        "type": "array",
                        "items": {"$ref": "#/components/schemas/Notification"}
                      }
                    },
                    "required": ["application", "auth", "notifications"]
                  }
                },
                "required": ["request"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status_code": {"type": "integer"},
                    "status_message": {"type": "string"},
                    "response": {
                      "type": "object",
                      "properties": {
                        "Messages": {
                          "type": "array",
                          "items": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/deleteMessage": {
      "post": {
        "operationId": "deleteMessage",
        "summary": "Delete a push notification",
        "description": "Delete a scheduled or sent push notification.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "auth": {"type": "string", "description": "API access token"},
                      "message": {"type": "string", "description": "Message code to delete"}
                    },
                    "required": ["auth", "message"]
                  }
                },
                "required": ["request"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message deleted",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/StatusResponse"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/getMessageDetails": {
      "post": {
        "operationId": "getMessageDetails",
        "summary": "Get message details",
        "description": "Get details of a specific push notification message.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "auth": {"type": "string"},
                      "message": {"type": "string", "description": "Message code"}
                    },
                    "required": ["auth", "message"]
                  }
                },
                "required": ["request"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status_code": {"type": "integer"},
                    "status_message": {"type": "string"},
                    "response": {"type": "object"}
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/createTargetedMessage": {
      "post": {
        "operationId": "createTargetedMessage",
        "summary": "Create a targeted push notification",
        "description": "Create and send a push notification with advanced audience targeting using tag conditions and filters.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "application": {"type": "string"},
                      "auth": {"type": "string"},
                      "content": {
                        "oneOf": [
                          {"type": "string"},
                          {"type": "object", "additionalProperties": {"type": "string"}}
                        ]
                      },
                      "title": {
                        "oneOf": [
                          {"type": "string"},
                          {"type": "object", "additionalProperties": {"type": "string"}}
                        ]
                      },
                      "send_date": {"type": "string"},
                      "target": {
                        "type": "object",
                        "description": "Targeting configuration with sets"
                      }
                    },
                    "required": ["application", "auth"]
                  }
                },
                "required": ["request"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Targeted message created",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/StatusResponse"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/getPushHistory": {
      "post": {
        "operationId": "getPushHistory",
        "summary": "Get push history",
        "description": "Retrieve push notification history for the application.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "auth": {"type": "string"},
                      "application": {"type": "string"},
                      "page": {"type": "integer", "description": "Page number"},
                      "count": {"type": "integer", "description": "Number of results per page"},
                      "source": {"type": "string", "description": "Filter by source"}
                    },
                    "required": ["auth", "application"]
                  }
                },
                "required": ["request"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Push history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status_code": {"type": "integer"},
                    "status_message": {"type": "string"},
                    "response": {
                      "type": "object",
                      "properties": {
                        "rows": {
                          "type": "array",
                          "items": {"type": "object"}
                        },
                        "count": {"type": "integer"}
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/cancelMessage": {
      "post": {
        "operationId": "cancelMessage",
        "summary": "Cancel a scheduled message",
        "description": "Cancel a previously scheduled push notification.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "request": {
                    "type": "object",
                    "properties": {
                      "auth": {"type": "string"},
                      "message": {"type": "string", "description": "Message code to cancel"}
                    },
                    "required": ["auth", "message"]
                  }
                },
                "required": ["request"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message cancelled",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/StatusResponse"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Notification": {
        "type": "object",
        "properties": {
          "send_date": {"type": "string", "description": "YYYY-MM-DD HH:mm or 'now'"},
          "content": {
            "oneOf": [
              {"type": "string"},
              {"type": "object", "additionalProperties": {"type": "string"}}
            ],
            "description": "Push notification content (string or localized object)"
          },
          "title": {
            "oneOf": [
              {"type": "string"},
              {"type": "object", "additionalProperties": {"type": "string"}}
            ],
            "description": "Push notification title"
          },
          "subtitle": {
            "oneOf": [
              {"type": "string"},
              {"type": "object", "additionalProperties": {"type": "string"}}
            ]
          },
          "ignore_user_timezone": {"type": "boolean", "description": "Send immediately regardless of user timezone"},
          "timezone": {"type": "string", "description": "Timezone for send_date (e.g., America/New_York)"},
          "campaign": {"type": "string", "description": "Campaign code"},
          "rich_media": {"type": "string", "description": "Rich media code"},
          "link": {"type": "string", "format": "uri", "description": "URL to open on tap"},
          "minimize_link": {"type": "integer", "description": "0 = do not minimize, 2 = bitly"},
          "data": {"type": "object", "description": "Custom data payload"},
          "transactionId": {"type": "string", "description": "Unique message identifier to prevent duplicates"},
          "platforms": {
            "type": "array",
            "items": {"type": "integer"},
            "description": "Platform IDs: 1=iOS, 3=Android, 7=Mac, 8=Windows, 9=Amazon, 10=Safari, 11=Chrome, 12=Firefox, 17=Huawei"
          },
          "preset": {"type": "string", "description": "Push preset code"},
          "send_rate": {"type": "integer", "description": "Throttle: 100-1000 pushes/second"},
          "devices": {
            "type": "array",
            "items": {"type": "string"},
            "description": "List of device tokens to send to"
          },
          "conditions": {
            "type": "array",
            "description": "Tag-based targeting conditions"
          },
          "geozone": {
            "type": "object",
            "properties": {
              "lat": {"type": "number"},
              "lng": {"type": "number"},
              "range": {"type": "integer"}
            }
          },
          "ios_title": {"type": "string"},
          "ios_subtitle": {"type": "string"},
          "ios_badges": {"type": "integer"},
          "ios_sound": {"type": "string"},
          "ios_category_id": {"type": "string"},
          "android_header": {"type": "string"},
          "android_icon": {"type": "string"},
          "android_sound": {"type": "string"},
          "android_priority": {"type": "integer"}
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status_code": {"type": "integer"},
          "status_message": {"type": "string"},
          "response": {"type": "object"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status_code": {"type": "integer"},
          "status_message": {"type": "string"}
        }
      }
    },
    "securitySchemes": {
      "apiAccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API access token from Pushwoosh Control Panel (passed in request body as 'auth' parameter)"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/ErrorResponse"}
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing auth token",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/ErrorResponse"}
          }
        }
      }
    }
  },
  "security": [
    {"apiAccessToken": []}
  ]
}