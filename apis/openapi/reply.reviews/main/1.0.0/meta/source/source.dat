{
  "openapi": "3.0.3",
  "info": {
    "title": "Reply.Reviews API",
    "description": "Reply.Reviews automates Google review requests after appointments, uses AI agents, and sends personalized human-like replies to reviews.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://reply.reviews/zapier/v1/api"
  },
  "servers": [
    {
      "url": "https://reply.reviews/api",
      "description": "Reply.Reviews API"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/generate-email-template": {
      "post": {
        "operationId": "generateInviteReviewTemplate",
        "summary": "Generate invite review email/SMS template",
        "description": "Generates a personalized review invitation email or SMS template with a unique AI-guided landing page link. Requires an active Pro Subscription.",
        "tags": ["Review Invitations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateTemplateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated template with invite URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateTemplateResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - OAuth2 login required"
          }
        }
      }
    },
    "/genreply": {
      "post": {
        "operationId": "generateReviewReply",
        "summary": "Generate a Google review reply",
        "description": "Uses AI to generate a customized, personalized response to a Google review based on the review content, rating, and desired tone.",
        "tags": ["Review Replies"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateReplyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated review reply",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateReplyResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - OAuth2 login required"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://reply.reviews/oauth/authorize",
            "tokenUrl": "https://reply.reviews/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "GenerateTemplateRequest": {
        "type": "object",
        "required": ["name", "email", "business_name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Customer's full name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Customer's email address"
          },
          "phone": {
            "type": "string",
            "description": "Customer's phone number"
          },
          "business_name": {
            "type": "string",
            "description": "Google Business Name from profile"
          }
        }
      },
      "GenerateTemplateResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "business_name": {
            "type": "string"
          },
          "invite_url": {
            "type": "string",
            "format": "uri",
            "description": "Unique link to AI-guided landing page"
          },
          "review_invite_template": {
            "type": "string",
            "description": "HTML email/SMS template"
          },
          "subject": {
            "type": "string",
            "description": "Email subject line"
          }
        }
      },
      "GenerateReplyRequest": {
        "type": "object",
        "required": ["name", "review", "rating", "business_name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Reviewer's name for personalization"
          },
          "review": {
            "type": "string",
            "description": "Review text to craft response to"
          },
          "rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Star rating given by reviewer"
          },
          "business_name": {
            "type": "string",
            "description": "Business name being reviewed"
          },
          "style": {
            "type": "string",
            "default": "professional",
            "enum": ["professional", "humorous", "warm", "informative", "empathetic", "creative"],
            "description": "Tone of the reply"
          },
          "language": {
            "type": "string",
            "default": "English",
            "description": "Language of the reply"
          }
        }
      },
      "GenerateReplyResponse": {
        "type": "object",
        "properties": {
          "review_reply": {
            "type": "string",
            "description": "Customized response to the Google review"
          }
        }
      }
    }
  }
}