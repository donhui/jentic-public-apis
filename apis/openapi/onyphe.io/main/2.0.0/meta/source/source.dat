{
  "openapi": "3.0.3",
  "info": {
    "title": "ONYPHE API",
    "description": "ONYPHE provides APIs for Attack Surface Discovery (ASD), Attack Surface Management (ASM) and Cyber Threat Intelligence (CTI). Includes search, export, discovery, summary, simple, and scope APIs.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://www.onyphe.io/documentation/api/v2"
  },
  "servers": [
    {
      "url": "https://www.onyphe.io/api/v2",
      "description": "ONYPHE API v2 server"
    }
  ],
  "paths": {
    "/user": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user information",
        "description": "Returns information about the authenticated user including plan details and quota.",
        "tags": ["User"],
        "responses": {
          "200": {
            "description": "User information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/search/{query}": {
      "get": {
        "operationId": "search",
        "summary": "Search ONYPHE data",
        "description": "Search the ONYPHE database using the ONYPHE Query Language (OQL).",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "OQL search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/export/{query}": {
      "get": {
        "operationId": "export",
        "summary": "Export ONYPHE data",
        "description": "Export search results from the ONYPHE database using OQL. Returns all matching results.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "OQL search query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Exported results (JSON Lines format)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/discovery/{query}": {
      "get": {
        "operationId": "discovery",
        "summary": "Discovery search",
        "description": "Perform a discovery search on the ONYPHE database.",
        "tags": ["Discovery"],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "OQL discovery query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Discovery results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/alert/list": {
      "get": {
        "operationId": "listAlerts",
        "summary": "List alerts",
        "description": "List all configured alerts for the authenticated user.",
        "tags": ["Alert"],
        "responses": {
          "200": {
            "description": "List of alerts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/summary/{query}": {
      "get": {
        "operationId": "summary",
        "summary": "Get summary of search results",
        "description": "Returns a summarized view of search results.",
        "tags": ["Summary"],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "OQL search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Summary results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/bulk/summary/{query}": {
      "post": {
        "operationId": "bulkSummary",
        "summary": "Bulk summary query",
        "description": "Perform a bulk summary query on the ONYPHE database.",
        "tags": ["Summary"],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "OQL search query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string",
                "description": "Newline-separated list of values to query"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk summary results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/simple/{category}/{query}": {
      "get": {
        "operationId": "simple",
        "summary": "Simple category query",
        "description": "Query a specific data category in the ONYPHE database.",
        "tags": ["Simple"],
        "parameters": [
          {
            "name": "category",
            "in": "path",
            "required": true,
            "description": "Data category to query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "The value to look up (e.g., IP address, domain)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Simple query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/simple/best/{category}/{query}": {
      "get": {
        "operationId": "simpleBest",
        "summary": "Simple best category query",
        "description": "Query a specific data category and return only the best/most recent result.",
        "tags": ["Simple"],
        "parameters": [
          {
            "name": "category",
            "in": "path",
            "required": true,
            "description": "Data category to query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "The value to look up",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Best result for the query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Number of results returned"
          },
          "error": {
            "type": "integer",
            "description": "Error code (0 means no error)"
          },
          "max_page": {
            "type": "integer",
            "description": "Maximum page number available"
          },
          "myip": {
            "type": "string",
            "description": "Requester's IP address"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "status": {
            "type": "string",
            "description": "Response status (ok or nok)"
          },
          "took": {
            "type": "string",
            "description": "Time taken to process the query"
          },
          "total": {
            "type": "integer",
            "description": "Total number of matching results"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "error": {
            "type": "integer"
          },
          "max_page": {
            "type": "integer"
          },
          "myip": {
            "type": "string"
          },
          "page": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            }
          },
          "status": {
            "type": "string"
          },
          "took": {
            "type": "string"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "@category": {
            "type": "string"
          },
          "@timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "@type": {
            "type": "string"
          },
          "ip": {
            "type": "string"
          },
          "port": {
            "type": "integer"
          },
          "protocol": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "hostname": {
            "type": "string"
          },
          "asn": {
            "type": "string"
          },
          "os": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key passed as: apikey <YOUR_API_KEY>"
      }
    }
  },
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "User",
      "description": "User account information"
    },
    {
      "name": "Search",
      "description": "Search the ONYPHE database"
    },
    {
      "name": "Export",
      "description": "Export search results"
    },
    {
      "name": "Discovery",
      "description": "Discovery search"
    },
    {
      "name": "Alert",
      "description": "Alert management"
    },
    {
      "name": "Summary",
      "description": "Summarized search results"
    },
    {
      "name": "Simple",
      "description": "Simple category-based queries"
    }
  ]
}