{
  "openapi": "3.0.3",
  "info": {
    "title": "isEven API",
    "description": "A humorous RESTful API that checks whether a given number is even or odd. Returns a JSON response indicating the result along with an advertisement on the free tier.",
    "version": "1.0.0",
    "contact": {
      "name": "isEven API",
      "url": "https://isevenapi.xyz"
    },
    "x-jentic-source-url": "https://isevenapi.xyz"
  },
  "servers": [
    {
      "url": "https://api.isevenapi.xyz/api",
      "description": "isEven API server"
    }
  ],
  "paths": {
    "/iseven/{number}/": {
      "get": {
        "operationId": "checkiseven",
        "summary": "Check if a number is even",
        "description": "Returns whether the provided number is even or odd. Free tier responses include an advertisement string.",
        "tags": [
          "Even/Odd Check"
        ],
        "parameters": [
          {
            "name": "number",
            "in": "path",
            "required": true,
            "description": "The number to check. Free tier supports 0 to 999,999. Negative numbers are also supported.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with even/odd result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IsEvenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid number provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - tier access exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IsEvenResponse": {
        "type": "object",
        "properties": {
          "iseven": {
            "type": "boolean",
            "description": "True if the number is even, false if odd."
          },
          "ad": {
            "type": "string",
            "description": "An advertisement string displayed on the free tier."
          }
        },
        "required": [
          "iseven"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message describing what went wrong."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Even/Odd Check",
      "description": "Endpoints for checking if a number is even or odd"
    }
  ]
}