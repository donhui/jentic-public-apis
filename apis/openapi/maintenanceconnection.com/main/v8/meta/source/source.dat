{
  "openapi": "3.0.3",
  "info": {
    "title": "Maintenance Connection API",
    "version": "v8",
    "description": "REST API for Maintenance Connection CMMS (Computerized Maintenance Management System). Provides endpoints for managing assets, work orders, inventory (parts), purchase orders, classifications, companies, labor, logs, lookup values, and specifications.",
    "x-jentic-source-url": "https://api.maintenanceconnection.com/v8/help/docs/SwaggerDocs"
  },
  "servers": [
    {
      "url": "https://api.maintenanceconnection.com/v8"
    }
  ],
  "paths": {
    "/Assets": {
      "get": {
        "operationId": "listAssets",
        "summary": "List all assets",
        "description": "Returns a list of ALL Assets. Can be filtered with an OData style query string.",
        "tags": ["Assets"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Asset" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createAssets",
        "summary": "Create one or more assets",
        "description": "Creates one or more Assets in the system with the details specified in the request body.",
        "tags": ["Assets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/AssetCreate" }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assets created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Asset" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateMultipleAssets",
        "summary": "Update one or more assets",
        "description": "Updates one or more Assets in the system. PK is required for each asset.",
        "tags": ["Assets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Asset" }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assets updated successfully"
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/Assets/{assetPK}": {
      "get": {
        "operationId": "getAsset",
        "summary": "Get asset by PK",
        "description": "Returns the Asset with the specified PK value.",
        "tags": ["Assets"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Asset" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "uploadAssetPhoto",
        "summary": "Upload asset photo",
        "description": "Populate Asset with Photo jpg file.",
        "tags": ["Assets"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Photo uploaded successfully" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateAsset",
        "summary": "Update an asset",
        "description": "Updates the specified Asset with the details specified in the request body.",
        "tags": ["Assets"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Asset" }
            }
          }
        },
        "responses": {
          "200": { "description": "Asset updated successfully" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/Assets/{assetPK}/specifications": {
      "get": {
        "operationId": "listAssetSpecifications",
        "summary": "List specifications for an asset",
        "description": "Returns the Specifications for a specific Asset.",
        "tags": ["Asset Specifications"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
