              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AssetSpecification" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createAssetSpecifications",
        "summary": "Create asset specifications",
        "description": "Creates one or more Asset Specifications. Required: SpecificationPK.",
        "tags": ["Asset Specifications"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/AssetSpecification" }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Specifications created successfully" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/Assets/{assetPK}/specifications/{PK}": {
      "get": {
        "operationId": "getAssetSpecification",
        "summary": "Get a specific asset specification",
        "tags": ["Asset Specifications"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" },
          { "name": "PK", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AssetSpecification" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateAssetSpecification",
        "summary": "Update an asset specification",
        "tags": ["Asset Specifications"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" },
          { "name": "PK", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AssetSpecification" }
            }
          }
        },
        "responses": {
          "200": { "description": "Specification updated successfully" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/AssetSpecifications": {
      "get": {
        "operationId": "listAllAssetSpecifications",
        "summary": "List all asset specifications",
        "description": "Returns a list of ALL Asset Specifications. Supports OData filtering.",
        "tags": ["Asset Specifications"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AssetSpecification" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateMultipleAssetSpecifications",
        "summary": "Update multiple asset specifications",
        "tags": ["Asset Specifications"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/AssetSpecification" }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Specifications updated successfully" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/Assets/{assetPK}/meterhistory": {
      "get": {
        "operationId": "listAssetMeterHistory",
        "summary": "List meter history for an asset",
        "description": "Returns the Meter History for a specific Asset.",
        "tags": ["Asset Meter History"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" },
          { "name": "meterNumber", "in": "query", "schema": { "type": "integer", "enum": [1, 2] }, "description": "Filter by meter number (1 or 2)" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AssetMeterHistory" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createAssetMeterHistory",
        "summary": "Create asset meter history records",
        "description": "Creates one or more Asset Meter History records. Required: AssetPK.",
        "tags": ["Asset Meter History"],
        "parameters": [
          { "$ref": "#/components/parameters/assetPK" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
