{
  "openapi": "3.0.3",
  "info": {
    "title": "Socrata Open Data API (SODA)",
    "description": "The Socrata Open Data API (SODA) provides programmatic access to open government datasets hosted on Socrata-powered data portals. Supports querying via SoQL (Socrata Query Language) with filtering, aggregation, geospatial queries, and multiple export formats.",
    "version": "3.0",
    "contact": {
      "name": "Socrata Developer Support",
      "url": "https://dev.socrata.com/"
    },
    "license": {
      "name": "Varies by dataset"
    },
    "x-jentic-source-url": "https://dev.socrata.com/"
  },
  "servers": [
    {
      "url": "https://{domain}",
      "description": "Socrata-powered open data portal",
      "variables": {
        "domain": {
          "default": "data.cityofnewyork.us",
          "description": "The domain of the Socrata-powered data portal (e.g., data.cityofnewyork.us, data.ct.gov)"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Query",
      "description": "Query dataset records using SoQL"
    },
    {
      "name": "Export",
      "description": "Export dataset records in various formats"
    },
    {
      "name": "Metadata",
      "description": "Retrieve dataset metadata"
    },
    {
      "name": "Discovery",
      "description": "Discover available datasets in a catalog"
    }
  ],
  "paths": {
    "/api/v3/views/{datasetId}/query.json": {
      "get": {
        "operationId": "queryDatasetGet",
        "summary": "Query a dataset (GET)",
        "description": "Execute a SoQL query against a dataset and return results in JSON format. GET method is suitable for shorter queries.",
        "tags": ["Query"],
        "parameters": [
          {
            "$ref": "#/components/parameters/DatasetId"
          },
          {
            "name": "query",
            "in": "query",
            "description": "SoQL query string",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pageNumber",
            "in": "query",
            "description": "Page number for pagination (1-based)",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of rows per page",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "description": "Request timeout in seconds",
            "schema": {
              "type": "integer",
              "default": 600
            }
          },
          {
            "name": "includeSystem",
            "in": "query",
            "description": "Include system columns in response",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "includeSynthetic",
            "in": "query",
            "description": "Include non-explicitly-requested synthetic columns",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful query response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            },
            "headers": {
              "X-Socrata-RequestId": {
                "description": "Unique request identifier",
                "schema": {
                  "type": "string"
                }
              },
              "X-SODA2-Fields": {
                "description": "Array of field names",
                "schema": {
                  "type": "string"
                }
              },
              "X-SODA2-Types": {
                "description": "Array of field data types",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      },
      "post": {
        "operationId": "queryDatasetPost",
        "summary": "Query a dataset (POST)",
        "description": "Execute a SoQL query against a dataset using POST. Preferred for longer queries.",
        "tags": ["Query"],
        "parameters": [
          {
            "$ref": "#/components/parameters/DatasetId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful query response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      }
    },
    "/api/v3/views/{datasetId}/export.csv": {
      "get": {
        "operationId": "exportDatasetCsv",
        "summary": "Export dataset as CSV",
        "description": "Export a dataset in CSV format for human-readable consumption.",
        "tags": ["Export"],
        "parameters": [
          {
            "$ref": "#/components/parameters/DatasetId"
          },
          {
            "name": "query",
            "in": "query",
            "description": "SoQL query to filter exported data",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "description": "Request timeout in seconds",
            "schema": {
              "type": "integer",
              "default": 600
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CSV file download",
            "content": {
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      }
    },
    "/resource/{datasetId}.json": {
      "get": {
        "operationId": "getResourceJson",
        "summary": "Query dataset via SODA 2.1 endpoint",
        "description": "Query a dataset using the legacy SODA 2.1 REST endpoint with SoQL query parameters.",
        "tags": ["Query"],
        "parameters": [
          {
            "$ref": "#/components/parameters/DatasetId"
          },
          {
            "name": "$select",
            "in": "query",
            "description": "Columns to return (comma-separated)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$where",
            "in": "query",
            "description": "Filter condition expression",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$order",
            "in": "query",
            "description": "Column(s) to sort by with ASC/DESC",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$group",
            "in": "query",
            "description": "Column(s) to group by for aggregation",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$having",
            "in": "query",
            "description": "Filter on aggregated values",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$limit",
            "in": "query",
            "description": "Maximum number of rows to return",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          },
          {
            "name": "$offset",
            "in": "query",
            "description": "Number of rows to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "$q",
            "in": "query",
            "description": "Full-text search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$$app_token",
            "in": "query",
            "description": "Application token (alternative to X-App-Token header)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful query response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      }
    },
    "/resource/{datasetId}.geojson": {
      "get": {
        "operationId": "getResourceGeoJson",
        "summary": "Query dataset as GeoJSON",
        "description": "Query a geospatial dataset and return results in GeoJSON format.",
        "tags": ["Query"],
        "parameters": [
          {
            "$ref": "#/components/parameters/DatasetId"
          },
          {
            "name": "$select",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$where",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          },
          {
            "name": "$offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "GeoJSON feature collection",
            "content": {
              "application/vnd.geo+json": {
                "schema": {
                  "$ref": "#/components/schemas/GeoJsonFeatureCollection"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      }
    },
    "/api/views/metadata/v1/{datasetId}": {
      "get": {
        "operationId": "getDatasetMetadata",
        "summary": "Get dataset metadata",
        "description": "Retrieve metadata for a specific dataset including name, description, columns, and update timestamps.",
        "tags": ["Metadata"],
        "parameters": [
          {
            "$ref": "#/components/parameters/DatasetId"
          }
        ],
        "responses": {
          "200": {
            "description": "Dataset metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetMetadata"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      }
    },
    "/api/catalog/v1": {
      "get": {
        "operationId": "searchCatalog",
        "summary": "Search the data catalog",
        "description": "Search for datasets across the portal catalog with filtering and pagination.",
        "tags": ["Discovery"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search query text",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "categories",
            "in": "query",
            "description": "Filter by category",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "in": "query",
            "description": "Filter by tag",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum results to return",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of results to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order (relevance, most_accessed, newest, recently_updated)",
            "schema": {
              "type": "string",
              "enum": ["relevance", "most_accessed", "newest", "recently_updated"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Catalog search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogSearchResults"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        },
        "security": [
          {
            "appToken": []
          }
        ]
      }
    }
  },
  "components": {
    "parameters": {
      "DatasetId": {
        "name": "datasetId",
        "in": "path",
        "required": true,
        "description": "The unique eight-character alphanumeric dataset identifier (e.g., ydr8-5enu)",
        "schema": {
          "type": "string",
          "pattern": "^[a-z0-9]{4}-[a-z0-9]{4}$"
        }
      }
    },
    "securitySchemes": {
      "appToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-App-Token",
        "description": "Application token for higher rate limits and API access. Register at your Socrata profile settings."
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication for write operations and private datasets."
      },
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authentication for third-party applications.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://{domain}/oauth/authorize",
            "tokenUrl": "https://{domain}/oauth/access_token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "QueryRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "SoQL query string"
          },
          "page": {
            "type": "object",
            "properties": {
              "pageNumber": {
                "type": "integer"
              },
              "pageSize": {
                "type": "integer"
              }
            }
          },
          "parameters": {
            "type": "object",
            "additionalProperties": true,
            "description": "User-provided parameter values for parameterized views"
          },
          "timeout": {
            "type": "integer",
            "description": "Request timeout in seconds",
            "default": 600
          },
          "includeSystem": {
            "type": "boolean",
            "default": true
          },
          "includeSynthetic": {
            "type": "boolean",
            "default": true
          },
          "orderingSpecifier": {
            "type": "string",
            "enum": ["total", "discard"],
            "default": "total"
          }
        }
      },
      "DatasetMetadata": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Dataset identifier"
          },
          "name": {
            "type": "string",
            "description": "Dataset name"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ColumnMetadata"
            }
          }
        }
      },
      "ColumnMetadata": {
        "type": "object",
        "properties": {
          "fieldName": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "dataTypeName": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "CatalogSearchResults": {
        "type": "object",
        "properties": {
          "resultSetSize": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CatalogEntry"
            }
          }
        }
      },
      "CatalogEntry": {
        "type": "object",
        "properties": {
          "resource": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "classification": {
            "type": "object",
            "properties": {
              "categories": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "link": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "GeoJsonFeatureCollection": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["FeatureCollection"]
          },
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["Feature"]
                },
                "geometry": {
                  "type": "object"
                },
                "properties": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error classification code"
          },
          "error": {
            "type": "boolean",
            "description": "Always true for error responses"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error explanation"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Machine-readable error details"
          },
          "source": {
            "type": "object",
            "description": "Query context with position and type information"
          }
        },
        "required": ["code", "error", "message"]
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Malformed request or invalid query",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication failed or missing",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Access denied to private dataset",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Dataset not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded. Use an application token for higher limits.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Server error. Contact Socrata support with the X-Socrata-RequestId header value.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "appToken": []
    }
  ]
}
