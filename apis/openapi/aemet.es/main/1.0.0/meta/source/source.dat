  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key obtained from AEMET OpenData portal"
      }
    },
    "schemas": {
      "DataResponse": {
        "type": "object",
        "properties": {
          "descripcion": {
            "type": "string",
            "description": "Response description"
          },
          "estado": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "datos": {
            "type": "string",
            "description": "URL to download the actual data"
          },
          "metadatos": {
            "type": "string",
            "description": "URL to download metadata"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "descripcion": {
            "type": "string",
            "description": "Error description"
          },
          "estado": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    }
  }
}
