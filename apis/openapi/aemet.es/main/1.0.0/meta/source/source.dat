{
  "openapi": "3.0.3",
  "info": {
    "title": "AEMET OpenData API",
    "description": "Weather and forecast data from Spain's national meteorological agency (Agencia Estatal de Meteorologia). Provides access to observations, predictions, alerts, fire risk indices, maps, and climatological data for Spanish municipalities, provinces, and regions.",
    "version": "1.0.0",
    "contact": {
      "name": "AEMET OpenData",
      "url": "https://opendata.aemet.es"
    },
    "x-jentic-source-url": "https://opendata.aemet.es/centrodedescargas/inicio"
  },
  "servers": [
    {
      "url": "https://opendata.aemet.es/opendata",
      "description": "AEMET OpenData Production Server"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Alerts",
      "description": "Adverse weather alerts (avisos CAP)"
    },
    {
      "name": "Fire Risk",
      "description": "Forest fire risk indices and maps"
    },
    {
      "name": "Master Data",
      "description": "Reference data for municipalities and stations"
    },
    {
      "name": "Maps",
      "description": "Analysis maps and significant weather graphics"
    },
    {
      "name": "Observations",
      "description": "Conventional weather station observation data"
    },
    {
      "name": "Municipal Predictions",
      "description": "Weather predictions for specific municipalities"
    },
    {
      "name": "Mountain Predictions",
      "description": "Weather predictions for mountain areas"
    },
    {
      "name": "Beach Predictions",
      "description": "Weather predictions for beaches"
    },
    {
      "name": "UV Index",
      "description": "Ultraviolet radiation index forecasts"
    },
    {
      "name": "Maritime Predictions",
      "description": "High-sea and coastal maritime forecasts"
    },
    {
      "name": "Regional Predictions",
      "description": "Text forecasts for autonomous communities (CCAA)"
    },
    {
      "name": "National Predictions",
      "description": "National-level text weather forecasts"
    },
    {
      "name": "Provincial Predictions",
      "description": "Text forecasts for provinces"
    },
    {
      "name": "Snow Predictions",
      "description": "Nivological (snow) information"
    }
  ],
  "paths": {
    "/api/avisos_cap/ultimoelaborado/area/{area}": {
      "get": {
        "operationId": "getLatestAlertsByArea",
        "summary": "Get latest adverse weather alerts for a region",
        "description": "Returns the latest elaborated adverse weather alerts (CAP format) for the specified area.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "area",
            "in": "path",
            "required": true,
            "description": "Area code (e.g., 'esp' for all Spain, '61' for Andalucia)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with alert data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No data available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/avisos_cap/archivo/fechaini/{fechaIniStr}/fechafin/{fechaFinStr}": {
      "get": {
        "operationId": "getAlertArchive",
        "summary": "Get archived alerts within a date range",
        "description": "Returns archived adverse weather alerts between the specified dates. Data available from 18/06/2018 onwards.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "fechaIniStr",
            "in": "path",
            "required": true,
            "description": "Start date in format YYYY-MM-DDTHH:MM:SSUTC",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fechaFinStr",
            "in": "path",
            "required": true,
            "description": "End date in format YYYY-MM-DDTHH:MM:SSUTC",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with archived alert data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/incendios/mapasriesgo/estimado/area/{area}": {
      "get": {
        "operationId": "getEstimatedFireRisk",
        "summary": "Get current estimated fire risk map",
        "description": "Returns the current estimated forest fire risk map for the specified area.",
        "tags": ["Fire Risk"],
        "parameters": [
          {
            "name": "area",
            "in": "path",
            "required": true,
            "description": "Area code: 'p' for Peninsula/Balearics, 'c' for Canary Islands",
            "schema": {
              "type": "string",
              "enum": ["p", "c"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with fire risk data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/incendios/mapasriesgo/previsto/dia/{dia}/area/{area}": {
      "get": {
        "operationId": "getForecastedFireRisk",
        "summary": "Get forecasted fire risk map",
        "description": "Returns the forecasted forest fire risk map for the specified day and area.",
        "tags": ["Fire Risk"],
        "parameters": [
          {
            "name": "dia",
            "in": "path",
            "required": true,
            "description": "Day ahead (1-7)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 7
            }
          },
          {
            "name": "area",
            "in": "path",
            "required": true,
            "description": "Area code: 'p' for Peninsula/Balearics, 'c' for Canary Islands",
            "schema": {
              "type": "string",
              "enum": ["p", "c"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/maestro/municipios": {
      "get": {
        "operationId": "getAllMunicipalities",
        "summary": "Get all Spanish municipalities",
        "description": "Returns a list of all Spanish municipalities with their codes for use with other AEMET services.",
        "tags": ["Master Data"],
        "responses": {
          "200": {
            "description": "Successful response with municipality list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
