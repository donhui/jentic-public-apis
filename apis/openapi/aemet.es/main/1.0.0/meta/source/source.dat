      "get": {
        "operationId": "getDailyMunicipalForecast",
        "summary": "Get daily forecast for a municipality",
        "description": "Returns the daily weather forecast for the specified municipality.",
        "tags": ["Municipal Predictions"],
        "parameters": [
          {
            "name": "municipio",
            "in": "path",
