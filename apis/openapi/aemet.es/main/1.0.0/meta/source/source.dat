              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/prediccion/especifica/playa/{playa}": {
      "get": {
        "operationId": "getBeachForecast",
        "summary": "Get beach weather forecast",
        "description": "Returns the weather forecast for a specific beach, including cloudiness at 11:00 and 17:00 local time and precipitation risk.",
        "tags": ["Beach Predictions"],
        "parameters": [
          {
            "name": "playa",
            "in": "path",
            "required": true,
            "description": "Beach code",
            "schema": {
              "type": "string"
