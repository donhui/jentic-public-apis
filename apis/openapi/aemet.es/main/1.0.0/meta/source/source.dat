                }
              }
            }
          }
        }
      }
    },
    "/api/prediccion/especifica/uvi/{dia}": {
      "get": {
        "operationId": "getUVIndex",
        "summary": "Get UV index forecast",
        "description": "Returns the ultraviolet radiation index forecast for the specified day.",
        "tags": ["UV Index"],
        "parameters": [
          {
            "name": "dia",
            "in": "path",
            "required": true,
            "description": "Day ahead (0-4)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with UV index data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
