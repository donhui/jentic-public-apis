    "/api/prediccion/especifica/montaña/pasada/area/{area}": {
      "get": {
        "operationId": "getMountainWeatherSummary",
        "summary": "Get past mountain weather summary",
        "description": "Returns the past 24-36 hour mountain weather summary for the specified area.",
        "tags": ["Mountain Predictions"],
        "parameters": [
          {
            "name": "area",
            "in": "path",
            "required": true,
            "description": "Mountain area code (peu1, nav1, arn1, arn2, cat1, rio1, mad2, gre1, nev1)",
            "schema": {
              "type": "string",
              "enum": ["peu1", "nav1", "arn1", "arn2", "cat1", "rio1", "mad2", "gre1", "nev1"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/prediccion/especifica/montaña/pasada/area/{area}/dia/{dia}": {
      "get": {
        "operationId": "getMountainForecastByDay",
        "summary": "Get mountain forecast for a specific day",
        "description": "Returns mountain weather forecast for the specified area and day.",
        "tags": ["Mountain Predictions"],
        "parameters": [
          {
            "name": "area",
            "in": "path",
            "required": true,
            "description": "Mountain area code",
            "schema": {
              "type": "string",
              "enum": ["peu1", "nav1", "arn1", "arn2", "cat1", "rio1", "mad2", "gre1", "nev1"]
            }
          },
          {
            "name": "dia",
            "in": "path",
            "required": true,
            "description": "Day (0=today, 1=tomorrow, 2=day after, 3=three days ahead)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/prediccion/especifica/nivologica/{area}": {
      "get": {
        "operationId": "getSnowInfo",
        "summary": "Get nivological (snow) information",
        "description": "Returns snow information for the specified Pyrenees area.",
        "tags": ["Snow Predictions"],
        "parameters": [
          {
            "name": "area",
            "in": "path",
            "required": true,
            "description": "Area code: '0' for Catalan Pyrenees, '1' for Navarra/Aragon Pyrenees",
            "schema": {
              "type": "string",
              "enum": ["0", "1"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
