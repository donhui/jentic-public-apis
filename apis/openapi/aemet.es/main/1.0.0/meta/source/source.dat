                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/maestro/municipio/{municipio}": {
      "get": {
        "operationId": "getMunicipality",
        "summary": "Get specific municipality information",
        "description": "Returns information for a specific municipality.",
        "tags": ["Master Data"],
        "parameters": [
          {
            "name": "municipio",
            "in": "path",
            "required": true,
            "description": "Municipality code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/mapasygraficos/analisis": {
      "get": {
        "operationId": "getAnalysisMaps",
        "summary": "Get analysis maps",
        "description": "Returns analysis maps showing pressure patterns and fronts, updated every 12 hours at 00:00 and 12:00 UTC.",
        "tags": ["Maps"],
        "responses": {
          "200": {
            "description": "Successful response with map data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/observacion/convencional/todas": {
      "get": {
        "operationId": "getAllObservations",
        "summary": "Get all current observation data",
        "description": "Returns current observation data from all weather stations (last 12 hours).",
        "tags": ["Observations"],
        "responses": {
          "200": {
            "description": "Successful response with observation data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
