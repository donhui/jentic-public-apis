    "/api/prediccion/especifica/municipio/horaria/{municipio}": {
      "get": {
        "operationId": "getHourlyMunicipalForecast",
        "summary": "Get hourly forecast for a municipality",
        "description": "Returns the hourly weather forecast for the specified municipality (48-hour period).",
        "tags": ["Municipal Predictions"],
        "parameters": [
          {
            "name": "municipio",
            "in": "path",
            "required": true,
            "description": "Municipality code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with hourly forecast data",
