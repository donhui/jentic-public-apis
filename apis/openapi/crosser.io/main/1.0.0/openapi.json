{
  "openapi": "3.0.3",
  "info": {
    "title": "Crosser Control Center API",
    "version": "1.0.0",
    "description": "REST API for the Crosser Control Center platform, providing management of authentication, resources, edge nodes, events, flow deployments, and identity providers.",
    "x-jentic-source-url": "https://crosser.io/documentation/user-guide/crosser-control-center/api/"
  },
  "servers": [
    {
      "url": "https://{instance}.crosser.io",
      "description": "Crosser Control Center API",
      "variables": {
        "instance": {
          "default": "app",
          "description": "Crosser instance identifier"
        }
      }
    }
  ],
