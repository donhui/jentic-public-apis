{
  "openapi": "3.0.3",
  "info": {
    "title": "VectorShift API",
    "description": "VectorShift is a designed tool for teams looking to automate tasks with custom generative AI. Provides endpoints for running pipelines, indexing knowledge bases, interacting with chatbots, and running transformations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.vectorshift.ai/api-reference"
  },
  "servers": [
    { "url": "https://api.vectorshift.ai/v1" }
  ],
  "tags": [
    { "name": "Pipelines", "description": "Run and manage pipelines" },
    { "name": "Knowledge Bases", "description": "Index documents in knowledge bases" },
    { "name": "Chatbots", "description": "Interact with chatbots" },
    { "name": "Transformations", "description": "Run arbitrary code transformations" }
  ],
  "paths": {
    "/pipeline/{id}/run": {
      "post": {
        "tags": ["Pipelines"],
        "summary": "Run a pipeline",
        "operationId": "runPipeline",
        "description": "Execute a pipeline with the specified inputs and configuration.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Pipeline identifier" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PipelineRunRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline execution result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PipelineRunResponse" } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication failed" }
        }
      }
    },
    "/knowledge-base/{id}/index": {
      "post": {
        "tags": ["Knowledge Bases"],
        "summary": "Index documents in a knowledge base",
        "operationId": "indexKnowledgeBase",
        "description": "Index documents in a knowledge base from various sources.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Knowledge base identifier" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/IndexRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Documents indexed",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" }, "document_ids": { "type": "array", "items": { "type": "string" } } } } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication failed" }
        }
      }
    },
    "/chatbot/{id}/run": {
      "post": {
        "tags": ["Chatbots"],
        "summary": "Run a chatbot",
        "operationId": "runChatbot",
        "description": "Send a message to a chatbot and get a response.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Chatbot identifier" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChatbotRunRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chatbot response",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChatbotRunResponse" } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication failed" }
        }
      }
    },
    "/transformation/{id}/run": {
      "post": {
        "tags": ["Transformations"],
        "summary": "Run a transformation",
        "operationId": "runTransformation",
        "description": "Run a transformation with the specified inputs.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Transformation identifier" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TransformationRunRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transformation result",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string", "enum": ["success", "failed"] }, "result": { "type": "object" } } } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Authentication failed" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "API key as bearer token"
      }
    },
    "schemas": {
      "PipelineRunRequest": {
        "type": "object",
        "required": ["inputs"],
        "properties": {
          "inputs": { "type": "object", "description": "Key-value pairs of pipeline inputs" },
          "conversation_id": { "type": "string", "description": "Session identifier for multi-turn conversations" },
          "stream": { "type": "boolean", "default": false }
        }
      },
      "PipelineRunResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["success", "failed"] },
          "run_id": { "type": "string" },
          "outputs": { "type": "object" }
        }
      },
      "IndexRequest": {
        "type": "object",
        "properties": {
          "file_data": { "type": "object", "properties": { "data": { "type": "string", "format": "byte" }, "name": { "type": "string" } } },
          "url_data": { "type": "object", "properties": { "url": { "type": "string", "format": "uri" }, "recursive": { "type": "boolean" } } },
          "wikipedia": { "type": "string" },
          "youtube": { "type": "string" },
          "arxiv": { "type": "string" },
          "config": { "type": "object", "properties": { "chunk_size": { "type": "integer" } } }
        }
      },
      "ChatbotRunRequest": {
        "type": "object",
        "properties": {
          "text": { "type": "string", "description": "User message input" },
          "audio": { "type": "string", "format": "byte", "description": "Base64 encoded audio" },
          "conversation_id": { "type": "string" },
          "stream": { "type": "boolean", "default": false },
          "generate_follow_up_questions": { "type": "boolean", "default": false },
          "number_of_follow_up_questions": { "type": "integer" }
        }
      },
      "ChatbotRunResponse": {
        "type": "object",
        "properties": {
          "conversation_id": { "type": "string" },
          "output_message": { "type": "string" },
          "follow_up_questions": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string" }
        }
      },
      "TransformationRunRequest": {
        "type": "object",
        "required": ["inputs"],
        "properties": {
          "inputs": { "type": "object", "description": "Key-value pairs of transformation inputs" }
        }
      }
    }
  }
}
