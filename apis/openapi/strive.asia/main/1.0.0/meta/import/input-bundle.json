        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email2": {
                    "type": "string",
                    "description": "Email address to look up contact"
                  }
                }
              }
            }
