{
  "openapi": "3.0.3",
  "info": {
    "title": "Priority REST API",
    "version": "1.0",
    "description": "The Priority REST API is based on the Open Data Protocol (OData). It provides access to Priority ERP entities for reading, querying, creating, updating, and deleting data. The API supports JSON format and uses OData conventions for filtering, sorting, and pagination.",
    "x-jentic-source-url": "https://prioritysoftware.github.io/restapi/"
  },
  "servers": [
    {
      "url": "https://{server}/odata/Priority/{env}/{company}",
      "description": "Priority OData Service Root",
      "variables": {
        "server": {
          "default": "your-priority-server.com",
          "description": "Your Priority server hostname"
        },
        "env": {
          "default": "tabula.ini",
          "description": "Priority environment name"
        },
        "company": {
          "default": "demo",
          "description": "Company name in Priority"
        }
      }
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getServiceRoot",
        "summary": "Request the service root",
        "description": "Returns a list of all available entity collections in the Priority system.",
        "responses": {
          "200": {
            "description": "List of available entity collections",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "url": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/$metadata": {
      "get": {
        "operationId": "getServiceMetadata",
        "summary": "Request the service metadata",
        "description": "Returns the metadata document describing the data model of the Priority OData service.",
        "responses": {
          "200": {
            "description": "OData metadata document in XML format",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/{entityCollection}": {
      "get": {
        "operationId": "getEntityCollection",
        "summary": "Request an entity collection",
        "description": "Retrieves a collection of entities from the specified form/entity type. Supports OData query options for filtering, sorting, pagination, and field selection.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the entity collection (e.g., ORDERS, CUSTOMERS, INVOICES)"
          },
          {
            "name": "$filter",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "OData filter expression (e.g., CUSTNAME eq 'John')"
          },
          {
            "name": "$orderby",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort expression (e.g., CURDATE desc)"
          },
          {
            "name": "$top",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Limit the number of entities returned"
          },
          {
            "name": "$skip",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Skip a number of entities"
          },
          {
            "name": "$select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to return"
          },
          {
            "name": "$expand",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Related entities to include inline"
          },
          {
            "name": "$since",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Retrieve only records modified since this timestamp"
          }
        ],
        "responses": {
          "200": {
            "description": "Collection of entities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityCollectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Entity collection not found"
          }
        }
      },
      "post": {
        "operationId": "createEntity",
        "summary": "Create an entity",
        "description": "Creates a new entity in the specified collection. The request body should contain the entity properties as JSON.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the entity collection"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entity created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "409": {
            "description": "Conflict - entity already exists"
          }
        }
      }
    },
    "/{entityCollection}('{entityId}')": {
      "get": {
        "operationId": "getEntity",
        "summary": "Request an individual entity by ID",
        "description": "Retrieves a single entity by its unique identifier.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the entity collection"
          },
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier of the entity"
          },
          {
            "name": "$expand",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Related entities to include inline"
          },
          {
            "name": "$select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Entity details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "404": {
            "description": "Entity not found"
          }
        }
      },
      "patch": {
        "operationId": "updateEntity",
        "summary": "Update an entity",
        "description": "Updates an existing entity. Only the fields included in the request body will be updated.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the entity collection"
          },
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier of the entity"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entity updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Entity not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteEntity",
        "summary": "Delete an entity",
        "description": "Deletes the specified entity from the collection.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the entity collection"
          },
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier of the entity"
          }
        ],
        "responses": {
          "201": {
            "description": "Entity deleted successfully"
          },
          "404": {
            "description": "Entity not found"
          }
        }
      }
    },
    "/{entityCollection}('{entityId}')/{relatedEntity}": {
      "get": {
        "operationId": "getRelatedEntities",
        "summary": "Navigate to related entities",
        "description": "Retrieves entities related to the specified parent entity.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the parent entity collection"
          },
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier of the parent entity"
          },
          {
            "name": "relatedEntity",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the related entity collection"
          }
        ],
        "responses": {
          "200": {
            "description": "Collection of related entities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityCollectionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Parent entity or related entity not found"
          }
        }
      },
      "post": {
        "operationId": "createRelatedEntity",
        "summary": "Insert a related entity",
        "description": "Creates a new entity in a sub-level form related to the specified parent entity.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the parent entity collection"
          },
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier of the parent entity"
          },
          {
            "name": "relatedEntity",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Name of the related entity collection"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Related entity created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/{entityCollection}('{entityId}')/{relatedEntity}('{relatedEntityId}')": {
      "patch": {
        "operationId": "updateRelatedEntity",
        "summary": "Update a related entity",
        "description": "Updates an existing related entity in a sub-level form.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "relatedEntity",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "relatedEntityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Related entity updated successfully"
          }
        }
      }
    },
    "/{entityCollection}('{entityId}')/$batch": {
      "post": {
        "operationId": "batchOperation",
        "summary": "Perform batch operations",
        "description": "Perform multiple insert/update operations in a single request for improved performance.",
        "parameters": [
          {
            "name": "entityCollection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch operation completed"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EntityCollectionResponse": {
        "type": "object",
        "properties": {
          "@odata.context": {
            "type": "string",
            "description": "OData context URL"
          },
          "value": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "description": "Array of entity objects"
          },
          "@odata.nextLink": {
            "type": "string",
            "description": "URL to retrieve the next page of results"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication with Priority username and password"
      },
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth2 authentication via External ID",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://{server}/oauth2/authorize",
            "tokenUrl": "https://{server}/oauth2/token",
            "scopes": {}
          }
        }
      },
      "personalAccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Personal Access Token (PAT) for authentication"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    },
    {
      "oauth2": []
    },
    {
      "personalAccessToken": []
    }
  ]
}