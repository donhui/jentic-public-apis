{
  "openapi": "3.0.3",
  "info": {
    "title": "Publons API",
    "description": "Access reviews, academics, publications, and articles from the Publons platform (Web of Science).",
    "version": "2.0.0",
    "x-jentic-source-url": "https://publons.com/api/v2/"
  },
  "servers": [
    {
      "url": "https://publons.com",
      "description": "Publons API Server"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Reviews",
      "description": "Review submission and retrieval"
    },
    {
      "name": "Academics",
      "description": "Academic profiles and details"
    },
    {
      "name": "Publications",
      "description": "Publication records"
    },
    {
      "name": "Articles",
      "description": "Article details"
    }
  ],
  "paths": {
    "/api/v2/review/": {
      "post": {
        "operationId": "createReview",
        "summary": "Submit a review",
        "description": "Allows integrated partners to submit reviews to Publons.",
        "tags": ["Reviews"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReviewSubmission"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Review created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Review"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid review data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/academic/": {
      "get": {
        "operationId": "listAcademics",
        "summary": "List academics",
        "description": "Retrieve a filterable list of academics. Deprecated endpoint.",
        "tags": ["Academics"],
        "deprecated": true,
        "parameters": [
          {
            "name": "paginate_by",
            "in": "query",
            "required": false,
            "description": "Number of results per page (max 10)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 10
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Response format",
            "schema": {
              "type": "string",
              "enum": ["json", "api"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of academics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcademicList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/academic/{identifier}/": {
      "get": {
        "operationId": "getAcademic",
        "summary": "Get academic details",
        "description": "Fetch details for a specific academic by ID, ORCID, ResearcherID, or TRUID. Deprecated endpoint.",
        "tags": ["Academics"],
        "deprecated": true,
        "parameters": [
          {
            "name": "identifier",
            "in": "path",
            "required": true,
            "description": "Academic ID, ORCID, ResearcherID, or TRUID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Academic details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Academic"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/academic/review/": {
      "get": {
        "operationId": "listAcademicReviews",
        "summary": "List academic reviews",
        "description": "List reviews configured for an academic. Deprecated endpoint.",
        "tags": ["Academics"],
        "deprecated": true,
        "parameters": [
          {
            "name": "paginate_by",
            "in": "query",
            "required": false,
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of reviews",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/academic/review/{id}/": {
      "get": {
        "operationId": "getAcademicReview",
        "summary": "Get review details",
        "description": "Retrieve specific review details. Deprecated endpoint.",
        "tags": ["Academics"],
        "deprecated": true,
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Review ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Review details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Review"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/academic/publication/": {
      "get": {
        "operationId": "listAcademicPublications",
        "summary": "List academic publications",
        "description": "List publications for an academic. Deprecated endpoint.",
        "tags": ["Publications"],
        "deprecated": true,
        "parameters": [
          {
            "name": "academic",
            "in": "query",
            "required": true,
            "description": "Academic identifier (ID, ORCID, ResearcherID, or TRUID)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "paginate_by",
            "in": "query",
            "required": false,
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of publications",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicationList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/academic/publication/{id}/": {
      "get": {
        "operationId": "getAcademicPublication",
        "summary": "Get publication details",
        "description": "Retrieve particular publication details. Deprecated endpoint.",
        "tags": ["Publications"],
        "deprecated": true,
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Publication ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Publication details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Publication"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/article/{id}/": {
      "get": {
        "operationId": "getArticle",
        "summary": "Get article details",
        "description": "Fetch details for a specific article. Deprecated endpoint.",
        "tags": ["Articles"],
        "deprecated": true,
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Article ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Article details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Article"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based authentication. Format: Token <your_token>"
      }
    },
    "schemas": {
      "ReviewSubmission": {
        "type": "object",
        "description": "Review data for submission"
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Review ID"
          },
          "academic": {
            "type": "object",
            "description": "Associated academic"
          },
          "article": {
            "type": "object",
            "description": "Associated article"
          }
        }
      },
      "ReviewList": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Review"
            }
          }
        }
      },
      "Academic": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Academic ID"
          },
          "orcid": {
            "type": "string",
            "description": "ORCID identifier"
          },
          "researcher_id": {
            "type": "string",
            "description": "ResearcherID"
          },
          "truid": {
            "type": "string",
            "description": "TRUID identifier"
          },
          "name": {
            "type": "string",
            "description": "Full name"
          }
        }
      },
      "AcademicList": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Academic"
            }
          }
        }
      },
      "Publication": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Publication ID"
          },
          "title": {
            "type": "string"
          },
          "doi": {
            "type": "string"
          }
        }
      },
      "PublicationList": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Publication"
            }
          }
        }
      },
      "Article": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Article ID"
          },
          "title": {
            "type": "string"
          },
          "doi": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}