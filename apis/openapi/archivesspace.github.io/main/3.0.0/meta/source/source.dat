{
  "openapi": "3.0.3",
  "info": {
    "title": "ArchivesSpace API",
    "description": "REST API for ArchivesSpace, an open-source archives information management application for managing and providing web access to archives, manuscripts, and digital objects.",
    "version": "3.0.0",
    "x-jentic-source-url": "http://archivesspace.github.io/archivesspace/api"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "localhost:8089",
          "description": "ArchivesSpace backend server host"
        }
      }
    }
  ],
  "security": [
    {
      "sessionToken": []
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "User authentication" },
    { "name": "Repositories", "description": "Repository management" },
    { "name": "Accessions", "description": "Accession records" },
    { "name": "Resources", "description": "Resource records" },
    { "name": "Agents", "description": "Agent records (people, families, corporate entities, software)" },
    { "name": "Subjects", "description": "Subject records" },
    { "name": "Digital Objects", "description": "Digital object records" },
    { "name": "Enumerations", "description": "Controlled value list management" },
    { "name": "Container Profiles", "description": "Container profile management" },
    { "name": "Batch Operations", "description": "Bulk operations" },
    { "name": "Search", "description": "Search operations" }
  ],
  "paths": {
    "/users/{username}/login": {
      "post": {
        "operationId": "loginUser",
        "tags": ["Authentication"],
        "summary": "Authenticate a user and obtain a session token",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": { "type": "string", "description": "User password" },
                  "expiring": { "type": "boolean", "default": true, "description": "Whether the session should expire" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SessionResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Invalid credentials" }
        },
        "security": []
      }
    },
    "/repositories": {
      "get": {
        "operationId": "listRepositories",
        "tags": ["Repositories"],
        "summary": "List all repositories",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "List of repositories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Repository" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createRepository",
        "tags": ["Repositories"],
        "summary": "Create a new repository",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RepositoryInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Repository created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/repositories/{repo_id}": {
      "get": {
        "operationId": "getRepository",
        "tags": ["Repositories"],
        "summary": "Retrieve a specific repository",
        "parameters": [
          { "name": "repo_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Repository details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Repository" }
