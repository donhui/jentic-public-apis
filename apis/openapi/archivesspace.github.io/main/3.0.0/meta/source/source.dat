        "summary": "Create a digital object",
        "parameters": [
          { "name": "repo_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DigitalObjectInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Digital object created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/config/enumerations": {
      "get": {
        "operationId": "listEnumerations",
        "tags": ["Enumerations"],
        "summary": "List all enumerations",
        "responses": {
          "200": {
            "description": "List of enumerations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Enumeration" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/config/enumerations/{enum_id}": {
      "get": {
        "operationId": "getEnumeration",
        "tags": ["Enumerations"],
        "summary": "Retrieve a specific enumeration",
        "parameters": [
          { "name": "enum_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Enumeration details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Enumeration" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/container_profiles": {
      "get": {
        "operationId": "listContainerProfiles",
        "tags": ["Container Profiles"],
        "summary": "List container profiles",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "List of container profiles",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createContainerProfile",
        "tags": ["Container Profiles"],
        "summary": "Create a container profile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContainerProfileInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Container profile created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/batch_delete": {
      "post": {
        "operationId": "batchDelete",
        "tags": ["Batch Operations"],
        "summary": "Delete multiple records by URI",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "record_uris": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Array of record URIs to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Records deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/repositories/{repo_id}/search": {
      "get": {
        "operationId": "searchRepository",
        "tags": ["Search"],
        "summary": "Search within a repository",
        "parameters": [
          { "name": "repo_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query" },
          { "name": "type", "in": "query", "schema": { "type": "array", "items": { "type": "string" } }, "description": "Record types to filter" },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResults" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/by-external-id": {
      "get": {
        "operationId": "findByExternalId",
        "tags": ["Search"],
        "summary": "Find records by external ID",
        "parameters": [
          { "name": "eid", "in": "query", "required": true, "schema": { "type": "string" }, "description": "External ID" },
          { "name": "type", "in": "query", "schema": { "type": "string" }, "description": "Record type to filter" }
        ],
        "responses": {
          "200": {
            "description": "Matching records",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-ArchivesSpace-Session",
        "description": "Session token obtained from login endpoint"
      }
    },
    "schemas": {
      "SessionResponse": {
        "type": "object",
        "properties": {
          "session": { "type": "string", "description": "Session token" },
          "user": { "$ref": "#/components/schemas/UserRef" }
        }
      },
      "UserRef": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Repository": {
        "type": "object",
        "properties": {
          "uri": { "type": "string" },
          "repo_code": { "type": "string" },
          "name": { "type": "string" },
          "org_code": { "type": "string" },
          "country": { "type": "string" },
          "url": { "type": "string" },
          "created_by": { "type": "string" },
          "create_time": { "type": "string", "format": "date-time" },
          "lock_version": { "type": "integer" }
        }
      },
      "RepositoryInput": {
        "type": "object",
        "required": ["repo_code", "name"],
        "properties": {
          "repo_code": { "type": "string", "description": "Repository code" },
          "name": { "type": "string", "description": "Repository name" },
          "org_code": { "type": "string" },
          "country": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "Accession": {
        "type": "object",
        "properties": {
          "uri": { "type": "string" },
          "id_0": { "type": "string" },
          "id_1": { "type": "string" },
          "id_2": { "type": "string" },
          "id_3": { "type": "string" },
          "title": { "type": "string" },
          "content_description": { "type": "string" },
          "accession_date": { "type": "string", "format": "date" },
          "lock_version": { "type": "integer" }
        }
      },
      "AccessionInput": {
        "type": "object",
        "required": ["id_0", "accession_date"],
        "properties": {
          "id_0": { "type": "string" },
          "id_1": { "type": "string" },
          "id_2": { "type": "string" },
          "id_3": { "type": "string" },
          "title": { "type": "string" },
          "content_description": { "type": "string" },
          "accession_date": { "type": "string", "format": "date" }
        }
      },
      "Resource": {
        "type": "object",
        "properties": {
          "uri": { "type": "string" },
          "title": { "type": "string" },
          "id_0": { "type": "string" },
          "level": { "type": "string" },
          "language": { "type": "string" },
          "finding_aid_title": { "type": "string" },
          "ead_id": { "type": "string" },
          "lock_version": { "type": "integer" }
        }
      },
      "ResourceInput": {
        "type": "object",
        "required": ["title", "id_0", "level"],
        "properties": {
          "title": { "type": "string" },
          "id_0": { "type": "string" },
          "level": { "type": "string", "enum": ["class", "collection", "file", "fonds", "item", "otherlevel", "recordgrp", "series", "subfonds", "subgrp", "subseries"] },
          "language": { "type": "string" },
          "finding_aid_title": { "type": "string" },
          "ead_id": { "type": "string" },
          "extents": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Extent" }
          },
          "dates": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DateRecord" }
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "uri": { "type": "string" },
          "title": { "type": "string" },
          "agent_type": { "type": "string" },
          "names": { "type": "array", "items": { "type": "object" } },
          "lock_version": { "type": "integer" }
        }
      },
      "AgentInput": {
        "type": "object",
        "required": ["names"],
        "properties": {
          "names": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "primary_name": { "type": "string" },
                "rest_of_name": { "type": "string" },
                "sort_name": { "type": "string" },
                "name_order": { "type": "string" },
                "source": { "type": "string" },
                "rules": { "type": "string" }
              }
            }
          }
        }
      },
      "Subject": {
        "type": "object",
        "properties": {
          "uri": { "type": "string" },
          "title": { "type": "string" },
          "terms": { "type": "array", "items": { "type": "object" } },
          "vocabulary": { "type": "string" },
          "lock_version": { "type": "integer" }
        }
      },
      "SubjectInput": {
        "type": "object",
        "required": ["terms", "vocabulary"],
        "properties": {
          "terms": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "term": { "type": "string" },
                "term_type": { "type": "string" },
                "vocabulary": { "type": "string" }
              }
            }
          },
          "vocabulary": { "type": "string" },
          "source": { "type": "string" }
        }
      },
      "DigitalObjectInput": {
        "type": "object",
        "required": ["title", "digital_object_id"],
        "properties": {
          "title": { "type": "string" },
          "digital_object_id": { "type": "string" },
          "digital_object_type": { "type": "string" },
          "file_versions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file_uri": { "type": "string" },
                "use_statement": { "type": "string" },
                "xlink_actuate_attribute": { "type": "string" },
                "xlink_show_attribute": { "type": "string" }
              }
            }
          }
        }
      },
      "Enumeration": {
        "type": "object",
        "properties": {
          "uri": { "type": "string" },
          "name": { "type": "string" },
          "values": { "type": "array", "items": { "type": "string" } },
          "lock_version": { "type": "integer" }
        }
      },
      "ContainerProfileInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "extent_dimension": { "type": "string" },
          "height": { "type": "string" },
          "width": { "type": "string" },
          "depth": { "type": "string" },
          "dimension_units": { "type": "string" }
        }
      },
      "Extent": {
        "type": "object",
        "properties": {
          "portion": { "type": "string" },
          "number": { "type": "string" },
          "extent_type": { "type": "string" }
        }
      },
      "DateRecord": {
        "type": "object",
        "properties": {
          "date_type": { "type": "string" },
          "label": { "type": "string" },
          "begin": { "type": "string" },
          "end": { "type": "string" },
          "expression": { "type": "string" }
        }
      },
      "CreateResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "id": { "type": "integer" },
          "uri": { "type": "string" },
          "warnings": { "type": "array", "items": { "type": "string" } }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "first_page": { "type": "integer" },
          "last_page": { "type": "integer" },
          "this_page": { "type": "integer" },
          "total": { "type": "integer" },
          "results": { "type": "array", "items": { "type": "object" } }
        }
      },
      "SearchResults": {
        "type": "object",
        "properties": {
          "page_size": { "type": "integer" },
          "first_page": { "type": "integer" },
          "last_page": { "type": "integer" },
          "this_page": { "type": "integer" },
          "offset_first": { "type": "integer" },
          "offset_last": { "type": "integer" },
          "total_hits": { "type": "integer" },
          "results": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  }
}