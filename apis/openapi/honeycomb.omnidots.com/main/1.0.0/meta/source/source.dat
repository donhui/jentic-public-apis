{
  "openapi": "3.0.3",
  "info": {
    "title": "Omnidots Honeycomb API",
    "description": "REST API for the Omnidots Honeycomb vibration monitoring platform. Provides access to measuring points, sensors, and vibration measurement records including peak particle velocity, VDV, and Veff data.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://honeycomb.omnidots.com/api/docs"
  },
  "servers": [
    {
      "url": "https://honeycomb.omnidots.com",
      "description": "Omnidots Honeycomb API"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and token management"
    },
    {
      "name": "Measuring Points",
      "description": "Manage and list measuring points"
    },
    {
      "name": "Sensors",
      "description": "List available sensors"
    },
    {
      "name": "Records",
      "description": "Retrieve measurement records (peak, VDV, Veff)"
    },
    {
      "name": "Traces",
      "description": "Retrieve trace data"
    }
  ],
  "paths": {
    "/api/v1/user/authenticate": {
      "get": {
        "operationId": "authenticateUser",
        "summary": "Authenticate user and return a temporary API token",
        "tags": ["Authentication"],
        "security": [],
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User account username"
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User account password"
          }
        ],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/user/account": {
      "get": {
        "operationId": "getUserAccount",
        "summary": "Get user account information by API token",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          }
        ],
        "responses": {
          "200": {
            "description": "Account information retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/token_details": {
      "get": {
        "operationId": "getTokenDetails",
        "summary": "Validate token and return associated account information",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token to validate"
          }
        ],
        "responses": {
          "200": {
            "description": "Token is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenDetailsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/list_measuring_points": {
      "get": {
        "operationId": "listMeasuringPoints",
        "summary": "Get a list of measuring points accessible by the token",
        "tags": ["Measuring Points"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          }
        ],
        "responses": {
          "200": {
            "description": "List of measuring points",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeasuringPointsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/configure_measuring_point": {
      "get": {
        "operationId": "configureMeasuringPoint",
        "summary": "Configure a measuring point",
        "tags": ["Measuring Points"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "measuring_point_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the measuring point to configure"
          }
        ],
        "responses": {
          "200": {
            "description": "Measuring point configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/list_sensors": {
      "get": {
        "operationId": "listSensors",
        "summary": "Get a list of sensors accessible by the token",
        "tags": ["Sensors"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          }
        ],
        "responses": {
          "200": {
            "description": "List of sensors",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SensorsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/get_peak_records": {
      "get": {
        "operationId": "getPeakRecords",
        "summary": "Fetch peak particle velocity/acceleration records for a measuring point",
        "tags": ["Records"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "measuring_point_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the measuring point"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start of the time range"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End of the time range"
          }
        ],
        "responses": {
          "200": {
            "description": "Peak records retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeakRecordsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/get_vdv_records": {
      "get": {
        "operationId": "getVdvRecords",
        "summary": "Fetch VDV records for a measuring point",
        "tags": ["Records"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "measuring_point_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the measuring point"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start of the time range"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End of the time range"
          }
        ],
        "responses": {
          "200": {
            "description": "VDV records retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VdvRecordsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/get_veff_records": {
      "get": {
        "operationId": "getVeffRecords",
        "summary": "Fetch Veff/KB records for a measuring point",
        "tags": ["Records"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "measuring_point_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the measuring point"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start of the time range"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End of the time range"
          }
        ],
        "responses": {
          "200": {
            "description": "Veff records retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VeffRecordsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/get_traces_list": {
      "get": {
        "operationId": "getTracesList",
        "summary": "Get a list of traces for a given time range",
        "tags": ["Traces"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "measuring_point_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the measuring point"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start of the time range"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End of the time range"
          }
        ],
        "responses": {
          "200": {
            "description": "List of traces",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TracesListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/get_traces": {
      "get": {
        "operationId": "getTraces",
        "summary": "Get detailed traces for a given time range",
        "tags": ["Traces"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API token"
          },
          {
            "name": "measuring_point_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the measuring point"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start of the time range"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End of the time range"
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed trace data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TracesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API token obtained via the authenticate endpoint"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "help": {
            "type": "string",
            "description": "Help text for resolving the error"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "token": {
            "type": "string",
            "description": "Temporary API token"
          }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "account": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "username": {
                "type": "string"
              },
              "email": {
                "type": "string"
              }
            }
          }
        }
      },
      "TokenDetailsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "account": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "username": {
                "type": "string"
              }
            }
          }
        }
      },
      "MeasuringPointsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "measuring_points": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MeasuringPoint"
            }
          }
        }
      },
      "MeasuringPoint": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "SensorsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "sensors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sensor"
            }
          }
        }
      },
      "Sensor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "PeakRecordsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PeakRecord"
            }
          }
        }
      },
      "PeakRecord": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "peak_velocity": {
            "type": "number",
            "format": "float"
          },
          "peak_acceleration": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "VdvRecordsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VdvRecord"
            }
          }
        }
      },
      "VdvRecord": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "vdv_value": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "VeffRecordsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VeffRecord"
            }
          }
        }
      },
      "VeffRecord": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "veff_value": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "TracesListResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "traces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      },
      "TracesResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "traces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time"
                },
                "data": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}