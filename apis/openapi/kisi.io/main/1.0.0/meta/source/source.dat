            "schema": {
              "type": "integer"
            },
            "description": "Filter by assignee ID. Must be used with `assignee_type`"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "activated",
                "deactivated"
              ]
            },
            "description": "Filter by status"
          },
          {
            "name": "card_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by card IDs"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          },
          {
            "name": "user_id",
            "in": "query",
            "schema": {
              "type": [
                "integer",
                "string"
              ]
            },
            "description": "Filter by user ID or by current user if value is `me`.",
