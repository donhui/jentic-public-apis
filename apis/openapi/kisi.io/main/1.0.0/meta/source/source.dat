    "/csv_card_imports": {
      "post": {
        "operationId": "createCsvCardImport",
        "summary": "Create CsvCardImport",
        "tags": [
          "CSV card imports"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "title": "Csv Card Import",
                "properties": {
                  "csv_card_import": {
                    "type": "object",
                    "properties": {
                      "file_name": {
                        "type": "string",
                        "description": "The name of the CSV file. The file can be uploaded by first using the\n<a href=\"/operations/createSignedUploadURL\">Signed upload url endpoint</a>\nto generate a signed URL and then using the URL to upload the file.\"\n"
                      }
                    },
                    "required": [
                      "file_name"
                    ]
                  }
                },
                "required": [
                  "csv_card_import"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "Csv Card Import",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "The ID of the csv import"
                    },
                    "name": {
                      "type": "string",
                      "description": "The name of the csv import"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "When the csv import was created"
                    },
                    "updated_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "When the csv import was updated"
                    },
                    "import_errors": {
                      "type": "object",
                      "description": "Imported errors."
                    },
                    "file_name": {
                      "type": "string",
                      "description": "The name of the CSV file. The file can be uploaded by first using the\n<a href=\"/operations/createSignedUploadURL\">Signed upload url endpoint</a>\nto generate a signed URL and then using the URL to upload the file.\"\n"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "waiting",
                        "in_progress",
                        "finished",
                        "failed"
                      ],
                      "description": "The status of the import."
                    },
                    "organization_id": {
                      "type": [
                        "integer",
                        "null"
                      ],
                      "description": "The organization ID of the csv import"
                    },
                    "organization": {
                      "type": "object",
                      "title": "Organization",
                      "description": "The organization of the csv import",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "The ID of the organization"
                        },
                        "resource_type": {
                          "type": "string",
                          "description": "The resource type of the organization",
                          "const": "Organization"
                        },
                        "name": {
                          "type": "string",
                          "description": "The name of the organization"
                        },
                        "domain": {
                          "type": "string",
                          "description": "The domain of the organization."
                        }
                      },
                      "required": [
                        "id",
                        "resource_type",
                        "name",
                        "domain"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "created_at",
                    "updated_at",
                    "import_errors",
                    "file_name",
                    "status",
                    "organization_id"
                  ],
