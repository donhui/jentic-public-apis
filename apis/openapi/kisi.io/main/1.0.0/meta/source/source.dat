    "/controllers": {
      "get": {
        "operationId": "fetchControllers",
        "summary": "Fetch controllers",
        "tags": [
          "Controllers"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by a freetext string. Properties searched: `name`, `device_id`, `token`\n"
          },
          {
            "name": "place_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by place ID"
          },
          {
            "name": "lock_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by lock ID"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "online",
                "offline"
              ]
            },
            "description": "Filter by status"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "-name"
              ]
            },
            "description": "Sort the results. Prepend `-` to sort in reverse order.\n\n`name` - sort by group name, alphabetically\n"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Controller",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the controller"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the controller",
                        "const": "Controller"
                      },
                      "name": {
                        "type": "string",
                        "description": "The name of the controller"
                      },
                      "description": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The description of the controller"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the controller was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the controller was updated"
                      },
                      "broadcast_ip_address": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The broadcast IP address of the controller"
                      },
                      "configured": {
                        "type": "boolean",
                        "description": "Whether the controller is configured"
                      },
                      "device_id": {
                        "type": "string",
                        "pattern": "^[a-fA-F0-9]{16}$",
                        "minLength": 16,
                        "maxLength": 16,
                        "description": "The device ID of the controller\n"
                      },
                      "ethernet_mac": {
                        "type": "string",
                        "description": "The ethernet MAC address of the controller"
                      },
                      "gateway_ip_address": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The gateway IP address of the controller"
                      },
                      "ip_address": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The IP address of the controller"
                      },
                      "model": {
                        "type": "string",
                        "enum": [
                          "router-8.0",
                          "controller-pro-1.1",
                          "controller-pro-2.0"
                        ],
                        "description": "The model of the controller"
                      },
                      "network_interface": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "enum": [
                          "ethernet",
                          "wifi",
                          null
                        ],
                        "description": "The network interface of the controller"
                      },
                      "network": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The network of the controller"
                      },
                      "online": {
                        "type": "boolean",
                        "description": "Whether the controller is online"
                      },
                      "revision": {
                        "type": "string",
                        "description": "The revision of the controller"
                      },
                      "token": {
                        "type": "string",
                        "description": "The token of the controller"
                      },
                      "wifi_mac": {
                        "type": "string",
                        "description": "The wifi MAC address of the controller"
                      },
                      "zone_controller": {
                        "type": "boolean",
                        "description": "Whether the controller is a zone_controller"
                      },
                      "place_id": {
                        "type": "integer",
                        "description": "The place ID of the controller"
                      },
                      "place": {
                        "type": "object",
                        "title": "Place",
                        "description": "The place of the controller",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the place"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the place",
                            "const": "Place"
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the place"
                          }
                        },
                        "required": [
                          "id",
                          "resource_type",
                          "name"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "required": [
                      "id",
                      "resource_type",
                      "name",
                      "description",
                      "created_at",
                      "updated_at",
                      "broadcast_ip_address",
                      "configured",
                      "device_id",
                      "ethernet_mac",
                      "gateway_ip_address",
                      "ip_address",
                      "model",
                      "network_interface",
                      "network",
                      "online",
                      "revision",
                      "token",
                      "wifi_mac",
                      "zone_controller",
                      "place_id",
                      "place"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            },
            "headers": {
              "X-Collection-Range": {
                "description": "Pagination information for offset based pagination. `start-end` represents the range\nof items requested. `total` represents the total count of items. If there is a total\nof 15 items and an offset of 10 and limit of 10 is used, the resulting header is:\n`10-19/15`.\n",
                "schema": {
                  "type": "string",
                  "pattern": "^(?<start>\\d+)-(?<end>\\d+)/(?<total>\\d+)$"
                },
                "example": "0-9/200"
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
