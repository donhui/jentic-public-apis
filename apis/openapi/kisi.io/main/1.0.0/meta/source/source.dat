                          "de",
                          null
                        ],
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The preferred language of the user"
                      },
                      "current_password": {
                        "type": "string",
                        "description": "The current password of the user. Required when updating password.",
                        "minLength": 8,
                        "maxLength": 128
                      },
                      "password": {
                        "type": "string",
                        "minLength": 8,
                        "maxLength": 128,
                        "description": "The new password of the user. Required when updating password.\nUsers of organizations with sso flow enabled won't be able to update this field.\n"
                      },
                      "password_confirmation": {
