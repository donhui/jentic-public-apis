                      }
                    },
                    "required": [
                      "id",
                      "resource_type",
                      "created_at",
                      "updated_at",
                      "team_id",
                      "team",
                      "member_type",
                      "member_id",
                      "member"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            },
            "headers": {
              "X-Collection-Range": {
                "description": "Pagination information for offset based pagination. `start-end` represents the range\nof items requested. `total` represents the total count of items. If there is a total\nof 15 items and an offset of 10 and limit of 10 is used, the resulting header is:\n`10-19/15`.\n",
                "schema": {
                  "type": "string",
                  "pattern": "^(?<start>\\d+)-(?<end>\\d+)/(?<total>\\d+)$"
