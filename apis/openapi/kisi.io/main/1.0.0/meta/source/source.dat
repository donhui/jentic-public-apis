    "/scheduled_reports": {
      "get": {
        "operationId": "fetchScheduledReports",
        "summary": "Fetch scheduled reports",
        "tags": [
          "Scheduled reports"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Scheduled Report",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the scheduled report"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the scheduled report",
                        "const": "ScheduledReport"
                      },
                      "name": {
                        "type": "string",
                        "description": "The name of the scheduled report"
                      },
                      "period": {
                        "type": "string",
                        "enum": [
                          "day",
                          "week",
                          "month"
                        ],
                        "description": "The period of the scheduled report. \nIf the reporter has a minimum interval days, the frequency, together with the period, can't be shorter than that \nvalue. Current minimum interval days: no limit\nIf the reporter has a maximum interval days, the frequency, together with the period, can't be longer than that \nvalue. Current maximum interval days: 180\n"
                      },
                      "frequency": {
                        "type": "integer",
                        "description": "The frequency of the scheduled report. \nIf the reporter has a minimum interval days, the frequency, together with the period, can't be shorter than that \nvalue. Current minimum interval days: no limit\nIf the reporter has a maximum interval days, the frequency, together with the period, can't be longer than that \nvalue. Current maximum interval days: 180\n"
                      },
                      "scheduled_at": {
                        "type": "string",
                        "format": "date",
                        "description": "The date at which the schedule will start"
                      },
                      "time_zone": {
                        "type": [
                          "string"
                        ],
                        "example": "Europe/London",
                        "description": "The time zone of the scheduled report.\nIt should be a <a href=\"https://en.wikipedia.org/wiki/Tz_database#Names_of_time_zones\"> valid IANA time zone name.</a>\n"
                      },
                      "enabled": {
                        "type": "boolean",
                        "default": false,
                        "description": "Whether the scheduled report is enabled"
                      },
                      "emails": {
                        "type": "array",
                        "minItems": 1,
                        "maxItems": 5,
                        "items": {
                          "type": "string",
                          "format": "email"
                        },
                        "description": "The emails to send the reports to"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the scheduled report was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the scheduled report was updated"
                      },
                      "organization_id": {
                        "type": "integer",
                        "description": "The organization ID of the scheduled report"
                      },
                      "organization": {
                        "type": "object",
                        "title": "Organization",
                        "description": "The organization of the scheduled report",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the organization"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the organization",
                            "const": "Organization"
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the organization"
                          },
                          "domain": {
                            "type": "string",
                            "description": "The domain of the organization."
                          }
                        },
                        "required": [
                          "id",
                          "resource_type",
                          "name",
                          "domain"
                        ],
                        "additionalProperties": false
                      },
                      "place_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The place ID of the scheduled report"
                      },
                      "reporter_id": {
                        "type": "integer",
                        "description": "The reporter ID of the scheduled report"
                      }
                    },
                    "required": [
                      "id",
                      "resource_type",
                      "name",
                      "period",
                      "frequency",
                      "scheduled_at",
                      "time_zone",
                      "enabled",
                      "emails",
                      "created_at",
                      "updated_at",
                      "organization_id",
                      "organization",
                      "place_id",
                      "reporter_id"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            },
            "headers": {
              "X-Collection-Range": {
                "description": "Pagination information for offset based pagination. `start-end` represents the range\nof items requested. `total` represents the total count of items. If there is a total\nof 15 items and an offset of 10 and limit of 10 is used, the resulting header is:\n`10-19/15`.\n",
                "schema": {
                  "type": "string",
                  "pattern": "^(?<start>\\d+)-(?<end>\\d+)/(?<total>\\d+)$"
                },
                "example": "0-9/200"
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createScheduledReport",
        "summary": "Create scheduled report",
        "tags": [
          "Scheduled reports"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "title": "Scheduled Report",
                "properties": {
                  "scheduled_report": {
                    "type": "object",
                    "properties": {
                      "name": {
