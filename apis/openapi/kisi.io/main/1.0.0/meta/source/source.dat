                            "ZA",
                            "JP",
                            "VI",
                            "SG",
                            "MY",
                            "TH",
                            "NG"
                          ],
                          "description": "https://en.wikipedia.org/wiki/ISO_3166-1_alpha-2"
                        },
                        "alpha3": {
                          "type": "string",
                          "enum": [
                            "ARG",
                            "AUT",
                            "AUS",
                            "BRA",
                            "BGR",
                            "CAN",
                            "USA",
                            "CHE",
                            "CHL",
                            "COL",
                            "CRI",
                            "CZE",
