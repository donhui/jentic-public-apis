                        "type": "integer",
                        "description": "The team ID of the team membership"
                      },
                      "team": {
                        "type": "object",
                        "title": "Team",
                        "description": "The team of the team membership",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the team"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the team",
                            "const": "Team"
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the team"
                          }
                        },
                        "required": [
                          "id",
                          "resource_type",
                          "name"
                        ],
                        "additionalProperties": false
                      },
                      "member_type": {
                        "type": "string",
                        "enum": [
                          "User",
                          "Guest"
                        ],
                        "description": "The member type of the team membership"
                      },
                      "member_id": {
                        "type": "integer",
                        "description": "The member ID of the team membership"
                      },
                      "member": {
                        "type": "object",
                        "description": "The member of the team membership",
                        "oneOf": [
                          {
                            "type": "object",
                            "title": "User",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "The ID of the user"
                              },
                              "resource_type": {
                                "type": "string",
                                "description": "The resource type of the user",
                                "const": "User"
                              },
                              "email": {
                                "type": "string",
                                "format": "email",
                                "description": "The email of the user."
                              },
                              "name": {
                                "type": "string",
                                "description": "The name of the user"
                              }
                            },
                            "required": [
                              "id",
                              "resource_type",
                              "email",
                              "name"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "title": "Guest",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "The ID of the guest"
                              },
                              "resource_type": {
                                "type": "string",
                                "description": "The resource type of the guest",
                                "const": "Guest"
                              },
                              "name": {
                                "type": "string",
                                "description": "The name of the guest"
                              },
                              "email": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "format": "email",
                                "description": "The email of the guest."
                              },
                              "phone_number": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "description": "The phone number of the guest. Only US, Canadian and Puerto Rican numbers in the format +11234567890 (E.164) are accepted.\n"
                              }
                            },
                            "required": [
                              "id",
                              "resource_type",
                              "name",
                              "email",
                              "phone_number"
                            ],
                            "additionalProperties": false
                          }
