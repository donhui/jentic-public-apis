            },
            "required": true,
            "description": "The ID of the object"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "Controller",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "The ID of the controller"
                    },
                    "resource_type": {
                      "type": "string",
                      "description": "The resource type of the controller",
                      "const": "Controller"
                    },
                    "name": {
                      "type": "string",
                      "description": "The name of the controller"
                    },
                    "description": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "The description of the controller"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "When the controller was created"
                    },
                    "updated_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "When the controller was updated"
                    },
                    "broadcast_ip_address": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "The broadcast IP address of the controller"
                    },
                    "configured": {
                      "type": "boolean",
                      "description": "Whether the controller is configured"
                    },
                    "device_id": {
                      "type": "string",
                      "pattern": "^[a-fA-F0-9]{16}$",
                      "minLength": 16,
                      "maxLength": 16,
                      "description": "The device ID of the controller\n"
                    },
                    "ethernet_mac": {
                      "type": "string",
                      "description": "The ethernet MAC address of the controller"
                    },
                    "gateway_ip_address": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "The gateway IP address of the controller"
                    },
                    "ip_address": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "The IP address of the controller"
                    },
                    "model": {
                      "type": "string",
                      "enum": [
                        "router-8.0",
                        "controller-pro-1.1",
                        "controller-pro-2.0"
                      ],
                      "description": "The model of the controller"
                    },
                    "network_interface": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "enum": [
                        "ethernet",
                        "wifi",
                        null
                      ],
                      "description": "The network interface of the controller"
                    },
                    "network": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "The network of the controller"
                    },
                    "online": {
                      "type": "boolean",
                      "description": "Whether the controller is online"
                    },
                    "revision": {
                      "type": "string",
                      "description": "The revision of the controller"
                    },
                    "token": {
                      "type": "string",
                      "description": "The token of the controller"
                    },
                    "wifi_mac": {
                      "type": "string",
                      "description": "The wifi MAC address of the controller"
                    },
                    "zone_controller": {
                      "type": "boolean",
                      "description": "Whether the controller is a zone_controller"
                    },
                    "place_id": {
                      "type": "integer",
                      "description": "The place ID of the controller"
                    },
                    "place": {
                      "type": "object",
                      "title": "Place",
                      "description": "The place of the controller",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "The ID of the place"
                        },
                        "resource_type": {
                          "type": "string",
                          "description": "The resource type of the place",
                          "const": "Place"
                        },
                        "name": {
                          "type": "string",
                          "description": "The name of the place"
                        }
                      },
                      "required": [
                        "id",
                        "resource_type",
                        "name"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "id",
                    "resource_type",
                    "name",
                    "description",
                    "created_at",
                    "updated_at",
                    "broadcast_ip_address",
                    "configured",
                    "device_id",
                    "ethernet_mac",
                    "gateway_ip_address",
                    "ip_address",
                    "model",
                    "network_interface",
                    "network",
                    "online",
                    "revision",
                    "token",
                    "wifi_mac",
                    "zone_controller",
                    "place_id",
                    "place"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
