    "/organization/request_transfer": {
      "post": {
        "operationId": "requestTransfer",
        "summary": "Request transfer",
        "description": "Request transfer of the organization ownership to another user",
        "tags": [
          "Organizations"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "title": "Organization",
                "properties": {
                  "organization": {
                    "type": "object",
                    "properties": {
                      "transfer_to_id": {
                        "type": "integer",
                        "description": "The ID of the user to whom the organization will be transfered(if user accepts the transfer). Not required if `transfer_to_email` is provided."
                      },
                      "transfer_to_email": {
                        "type": "string",
                        "format": "email",
                        "description": "The email of the user to whom the organization will be transfered(if user accepts the transfer). Not required if `transfer_to_id` is provided."
                      }
                    },
                    "required": []
                  }
                },
                "required": [
                  "organization"
                ]
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
