    "/cards": {
      "get": {
        "operationId": "fetchCards",
        "summary": "Fetch cards",
        "tags": [
          "Cards"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "activated",
                "deactivated",
                "unassigned"
              ]
            },
            "description": "Filter by status"
          },
          {
            "name": "token",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by the token of the card."
          },
          {
            "name": "data_block_value",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by the data_block_value of the card. Only relevant for Mifare Classic cards."
          },
          {
            "name": "uid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by the uid of the card."
          },
          {
            "name": "user_id",
            "in": "query",
            "schema": {
              "type": [
                "integer",
                "string"
              ]
            },
            "description": "Filter by user ID or by current user if value is `me`.",
            "deprecated": true
          },
          {
            "name": "facility_code",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by the facility code of the record. Only relevant for LF cards."
          },
          {
            "name": "activated",
            "in": "query",
            "deprecated": true,
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by the activation status of the card."
          },
          {
            "name": "card_number",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by the card number of the record. Only relevant for LF cards."
          },
          {
            "name": "card_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by the card id of the record. Only relevant for LF cards."
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "last_used_at",
                "-last_used_at"
              ]
            },
            "description": "Sort the results. Prepend `-` to sort in reverse order.\n\n`last_used_at` - sort by when the card was last used\n"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "oneOf": [
                      {
                        "type": "object",
                        "title": "Mifare Desfire Card",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the card"
                          },
                          "last_used_at": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "date-time",
                            "description": "When the Card was last used."
                          },
                          "created_at": {
                            "type": "string",
                            "format": "date-time",
                            "description": "When the card was created"
                          },
                          "updated_at": {
                            "type": "string",
                            "format": "date-time",
                            "description": "When the card was updated"
                          },
                          "assigned": {
                            "deprecated": true,
                            "type": "boolean",
                            "description": "Whether the Card is assigned."
                          },
                          "assigned_at": {
                            "deprecated": true,
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "date-time",
                            "description": "When the Card was assigned."
                          },
                          "activated_at": {
                            "deprecated": true,
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "date-time",
                            "description": "When the Card was activated."
                          },
                          "deactivated_at": {
                            "deprecated": true,
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "date-time",
                            "description": "When the Card was deactivated."
                          },
                          "activated": {
                            "deprecated": true,
                            "type": "boolean",
                            "description": "Whether the Card is activated."
                          },
                          "assigned_by_id": {
                            "type": [
                              "integer",
                              "null"
                            ],
                            "description": "The assigned_by ID of the card",
                            "deprecated": true
                          },
                          "assigned_by": {
                            "type": "object",
                            "title": "User",
                            "description": "The assigned_by of the card",
                            "deprecated": true,
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "The ID of the user"
                              },
                              "resource_type": {
                                "type": "string",
                                "description": "The resource type of the user",
                                "const": "User"
                              },
                              "email": {
                                "type": "string",
                                "format": "email",
                                "description": "The email of the user."
                              },
                              "name": {
                                "type": "string",
                                "description": "The name of the user"
                              }
