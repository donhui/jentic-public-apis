    "/role_assignments": {
      "get": {
        "operationId": "fetchRoleAssignments",
        "summary": "Fetch role assignments",
        "tags": [
          "Role assignments"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by a freetext string. Properties searched: `user.email`, `user.name`\n"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          },
          {
            "name": "role_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by role ID"
