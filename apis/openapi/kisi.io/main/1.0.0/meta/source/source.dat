    "/invites": {
      "post": {
        "operationId": "createInvite",
        "summary": "Create invite",
        "tags": [
          "Invites"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "title": "Place Invite",
                    "properties": {
                      "invite": {
                        "type": "object",
                        "properties": {
                          "notify": {
                            "type": "boolean",
                            "description": "Whether to notify the invitee",
                            "default": true
                          },
                          "invites_to_type": {
                            "type": "string",
                            "const": "Place"
                          },
                          "invites_to_id": {
                            "type": "integer",
                            "description": "The ID of the place"
                          },
                          "invitee": {
                            "type": "object",
                            "description": "The resource invited",
                            "oneOf": [
                              {
                                "type": "object",
                                "title": "User",
                                "properties": {
                                  "resource_type": {
                                    "type": "string",
                                    "description": "The resource type of the user",
                                    "const": "User"
                                  },
                                  "email": {
                                    "type": "string",
                                    "format": "email",
                                    "description": "The email of the user."
                                  },
                                  "name": {
                                    "type": "string",
                                    "description": "The name of the user"
                                  }
                                },
                                "required": [
                                  "resource_type",
                                  "email",
                                  "name"
                                ],
                                "additionalProperties": false
                              },
                              {
                                "type": "object",
                                "title": "Guest",
                                "properties": {
                                  "resource_type": {
                                    "type": "string",
                                    "description": "The resource type of the guest",
                                    "const": "Guest"
                                  },
                                  "name": {
                                    "type": "string",
                                    "description": "The name of the guest"
                                  },
                                  "email": {
                                    "type": [
                                      "string",
                                      "null"
                                    ],
                                    "format": "email",
                                    "description": "The email of the guest."
                                  },
                                  "phone_number": {
                                    "type": [
                                      "string",
                                      "null"
                                    ],
                                    "description": "The phone number of the guest. Only US, Canadian and Puerto Rican numbers in the format +11234567890 (E.164) are accepted.\n"
                                  }
                                },
                                "required": [
                                  "resource_type",
                                  "name",
                                  "email",
                                  "phone_number"
                                ],
                                "additionalProperties": false
                              }
                            ]
                          },
                          "access_key": {
                            "properties": {
                              "link_enabled": {
                                "type": "boolean",
                                "default": true,
                                "description": "Will generate a link that can be used for access."
                              },
                              "qr_code_enabled": {
                                "type": "boolean",
                                "default": false,
                                "description": "Will generate a QR code that can be used for access."
                              }
                            },
                            "description": "Access key for the invitee. Only to be used when invitee is a guest."
                          },
                          "role_assignment": {
                            "type": "object",
                            "title": "RoleAssignment",
                            "properties": {
                              "role_id": {
                                "type": "string",
                                "description": "The role ID of the role assignment."
                              }
                            }
                          }
                        },
                        "required": [
                          "invites_to_type",
                          "invites_to_id",
                          "invitee",
                          "role_assignment"
                        ]
                      }
                    },
                    "required": [
                      "invite"
                    ]
                  },
                  {
                    "type": "object",
                    "title": "Group Invite",
                    "properties": {
                      "invite": {
                        "type": "object",
                        "properties": {
                          "notify": {
                            "type": "boolean",
                            "description": "Whether to notify the invitee",
                            "default": true
                          },
                          "invites_to_type": {
                            "type": "string",
                            "const": "Group"
                          },
                          "invites_to_id": {
                            "type": "integer",
                            "description": "The ID of the group"
                          },
                          "invitee": {
                            "type": "object",
                            "description": "The resource invited",
                            "oneOf": [
                              {
                                "type": "object",
                                "title": "User",
                                "properties": {
                                  "resource_type": {
                                    "type": "string",
                                    "description": "The resource type of the user",
                                    "const": "User"
                                  },
                                  "email": {
                                    "type": "string",
                                    "format": "email",
                                    "description": "The email of the user."
                                  },
                                  "name": {
                                    "type": "string",
