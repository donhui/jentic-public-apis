            "schema": {
              "type": "integer"
            },
            "description": "Filter by guest ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Card Assignment",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the card assignment"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the card assignment",
                        "const": "CardAssignment"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the card assignment was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the card assignment was updated"
                      },
                      "status": {
                        "enum": [
                          "activated",
                          "deactivated"
                        ],
                        "type": "string",
                        "description": "The status of the card assignment."
                      },
                      "two_factor_pin": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "pattern": "^[0-9]{4}$",
                        "description": "Pin code used as two factor authentication for the card assignment."
                      },
                      "send_two_factor_pin_notification": {
                        "type": "boolean",
                        "description": "Whether to send a notification to the assignee when the two factor pin is set/changed."
                      },
                      "assignee_type": {
                        "type": "string",
                        "enum": [
                          "User",
                          "Guest"
                        ],
                        "description": "The assignee type of the card assignment"
                      },
                      "assignee_id": {
                        "type": "integer",
                        "description": "The assignee ID of the card assignment"
                      },
                      "card_id": {
                        "type": "integer",
                        "description": "The card ID of the card assignment"
                      },
                      "created_by_type": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "enum": [
                          null,
                          "User"
                        ],
                        "description": "The created_by type of the card assignment"
                      },
                      "created_by_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The created_by ID of the card assignment"
                      },
                      "created_by": {
                        "type": "object",
                        "description": "The created_by of the card assignment",
                        "oneOf": [
                          {
                            "type": "object",
                            "title": "User",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "The ID of the user"
                              },
                              "resource_type": {
                                "type": "string",
                                "description": "The resource type of the user",
                                "const": "User"
                              },
                              "email": {
                                "type": "string",
                                "format": "email",
                                "description": "The email of the user."
                              },
                              "name": {
                                "type": "string",
                                "description": "The name of the user"
                              }
                            },
                            "required": [
                              "id",
                              "resource_type",
                              "email",
                              "name"
                            ],
                            "additionalProperties": false
                          }
                        ]
                      },
                      "guest_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The guest ID of the card assignment",
                        "deprecated": true
                      },
                      "user_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The user ID of the card assignment",
                        "deprecated": true
                      }
                    },
                    "required": [
                      "id",
                      "resource_type",
                      "created_at",
                      "updated_at",
                      "status",
                      "two_factor_pin",
                      "send_two_factor_pin_notification",
                      "assignee_type",
                      "assignee_id",
                      "card_id",
                      "created_by_type",
                      "created_by_id",
                      "guest_id",
                      "user_id"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            },
            "headers": {
              "X-Collection-Range": {
                "description": "Pagination information for offset based pagination. `start-end` represents the range\nof items requested. `total` represents the total count of items. If there is a total\nof 15 items and an offset of 10 and limit of 10 is used, the resulting header is:\n`10-19/15`.\n",
                "schema": {
                  "type": "string",
                  "pattern": "^(?<start>\\d+)-(?<end>\\d+)/(?<total>\\d+)$"
