                            "required": [
                              "id",
                              "resource_type",
                              "email",
                              "name"
                            ],
                            "additionalProperties": false
                          },
                          "user_id": {
                            "type": [
                              "integer",
                              "null"
                            ],
                            "description": "The user ID of the card",
                            "deprecated": true
                          },
                          "user": {
                            "type": "object",
                            "title": "User",
                            "description": "The user of the card",
                            "deprecated": true,
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "The ID of the user"
                              },
                              "resource_type": {
                                "type": "string",
                                "description": "The resource type of the user",
                                "const": "User"
                              },
                              "email": {
                                "type": "string",
                                "format": "email",
                                "description": "The email of the user."
                              },
                              "name": {
                                "type": "string",
                                "description": "The name of the user"
                              }
                            },
                            "required": [
                              "id",
                              "resource_type",
                              "email",
                              "name"
                            ],
                            "additionalProperties": false
                          },
                          "token": {
                            "type": "string",
                            "description": "The token of the Card."
                          },
                          "uid": {
                            "type": "string",
                            "pattern": "^([0-9a-fA-F]){6,16}$",
                            "description": "The UID of the Card."
                          },
                          "type": {
                            "type": "string",
                            "enum": [
                              "mifare_desfire"
                            ],
                            "description": "The type of the Card."
                          },
                          "model": {
                            "type": "string",
                            "enum": [
                              "card-black-1.0",
                              "card-black-1.1",
                              "card-black-2.0",
                              "card-white-1.0",
                              "card-white-1.1",
                              "card-white-2.0",
                              "card-custom-1.1",
                              "fob-1.0",
                              "fob-1.1",
                              "fob-2.0",
                              "tag-1.0",
                              "tag-1.1",
                              "tag-2.0"
                            ],
                            "description": "The model of the Card."
                          },
                          "frequency": {
                            "type": "string",
                            "enum": [
                              "HF"
                            ],
                            "description": "The frequency of the Card."
                          },
                          "color": {
                            "type": "string",
                            "enum": [
                              "white",
                              "black",
                              "custom",
                              "unknown"
                            ],
                            "description": "The color of the Card."
                          },
                          "form_factor": {
                            "type": "string",
                            "enum": [
                              "card",
                              "fob",
                              "tag",
                              "unknown"
                            ],
                            "description": "The form factor of the Card."
                          },
                          "third_party": {
                            "type": "boolean",
                            "enum": [
                              false
                            ],
                            "description": "Whether the Card is manufactured by a third party, and not by Kisi."
                          }
                        },
                        "required": [
                          "id",
                          "last_used_at",
                          "created_at",
                          "updated_at",
                          "assigned",
                          "assigned_at",
                          "activated_at",
                          "deactivated_at",
                          "activated",
                          "assigned_by_id",
                          "user_id",
                          "token",
                          "uid",
                          "type",
                          "model",
                          "frequency",
                          "color",
                          "form_factor",
                          "third_party"
                        ],
                        "additionalProperties": false
