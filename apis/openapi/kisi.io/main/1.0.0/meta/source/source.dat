            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by a freetext string. Properties searched: `user.email`, `user.name`\n"
          },
          {
            "name": "group_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by group ID"
          },
          {
            "name": "member_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by member ID"
          },
          {
