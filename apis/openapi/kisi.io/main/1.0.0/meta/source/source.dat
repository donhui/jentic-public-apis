    "/shares": {
      "get": {
        "operationId": "fetchShares",
        "summary": "Fetch shares",
        "description": "<!-- theme: info -->\n> This API is deprecated.\n> Please read our [documentation](https://docs.kisi.io/api/how_to_guides/manage_access_rights/assign_access_rights/) about how to manage access rights.\n",
