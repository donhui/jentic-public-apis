    "/controller_inputs": {
      "get": {
        "operationId": "fetchControllerInputs",
        "summary": "Fetch controller inputs",
        "tags": [
          "Controller Inputs"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "controller_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Filter by controller ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Controller Input",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the controller input"
                      },
                      "channel": {
                        "type": "number",
                        "description": "The channel of the controller input"
                      },
                      "name": {
                        "type": "string",
                        "description": "The name of the controller input"
                      },
                      "type": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "enum": [
                          "contact_sensor",
                          "request_to_exit",
                          null
                        ],
                        "description": "The type of the controller input. Will only be set for inputs belonging to Controller Pro 1.0 and Controller Pro 1.1 controllers.\n"
                      },
                      "status": {
                        "type": "string",
                        "enum": [
                          "open",
                          "closed",
                          "cut",
                          "short"
                        ],
                        "description": "The status of the controller input.\n"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the controller input was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the controller input was updated"
                      },
                      "controller_id": {
                        "type": "integer",
                        "description": "The controller ID of the controller input"
                      },
                      "controller_input_connection_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The controller_input_connection ID of the controller input"
                      }
                    },
                    "required": [
                      "id",
                      "channel",
                      "name",
                      "type",
                      "status",
                      "created_at",
                      "updated_at",
                      "controller_id",
                      "controller_input_connection_id"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
