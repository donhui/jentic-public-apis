    "/members": {
      "get": {
        "operationId": "fetchMembers",
        "summary": "Fetch members",
        "tags": [
          "Members"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "deprecated": true,
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "place_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filters members that have access to given place.\n"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "-name",
                "unlock",
                "-unlock",
                "access_enabled",
                "-access_enabled"
              ]
            },
            "description": "Sort the results. Prepend `-` to sort in reverse order.\n\n`name` - sort by member name, alphabetically<br>\n`unlock` - sort by last unlock; no unlocks first, then oldest to most recent\n"
          },
          {
            "name": "group_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by group ID"
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by a freetext string. Properties searched: `user.email`, `user.name`, `user.notes`\n"
          },
          {
            "name": "user_id",
            "in": "query",
            "schema": {
              "type": [
                "integer",
                "string"
              ]
            },
            "description": "Filter by user ID or by current user if value is `me`."
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 100
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Member",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the member"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the member",
                        "const": "Member"
                      },
                      "name": {
                        "type": "string",
                        "description": "The name of the member"
                      },
                      "image": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The URL to the profile picture of the member."
                      },
                      "password_flow_enabled": {
                        "type": "boolean",
                        "description": "Whether the member can login with password flow. Only relevant for organizations."
                      },
                      "access_enabled": {
                        "type": "boolean",
                        "description": "Whether the member is allowed to access locks and elevators.\n\nIf the user is managed by SCIM, user access will be disabled\nunless *both* the `access_enabled` field and\n`scim_access_enabled` fields are set to `true`.\n"
                      },
                      "scim_access_enabled": {
                        "type": "boolean",
                        "description": "Whether the member is allowed to access locks and elevators.\n\nThis field is read-only and can only be managed using SCIM. (See `access_enabled`)\n\nIt will always be set to `true` if the member is not managed by SCIM.\n"
                      },
                      "last_accessed_at": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "date-time",
                        "description": "When the user last accessed a door."
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the member was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the member was updated"
                      },
                      "role_id": {
                        "type": "string",
                        "description": "The role ID of the member.",
                        "deprecated": true
                      },
                      "notes": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The notes for the member."
                      },
                      "metadata": {
                        "type": [
                          "object"
                        ],
                        "description": "The metadata for the member.\n- Nested values are not accepted.\n- Keys have a limit of 50 characters.\n- Values have a limit of 500 characters.\n- Keys number is limited to 50.\n"
                      },
                      "organization_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The organization ID of the member"
                      },
                      "user_id": {
                        "type": "integer",
                        "description": "The user ID of the member"
                      },
                      "user": {
                        "type": "object",
                        "title": "User",
                        "description": "The user of the member",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the user"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the user",
                            "const": "User"
                          },
                          "email": {
                            "type": "string",
                            "format": "email",
                            "description": "The email of the user."
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the user"
                          },
                          "otp_required_for_login": {
                            "type": "boolean",
                            "description": "Whether OTP/2FA is required for login."
                          }
                        },
                        "required": [
                          "id",
                          "resource_type",
                          "email",
                          "name",
                          "otp_required_for_login"
                        ],
                        "additionalProperties": false
                      },
                      "place_id": {
                        "deprecated": true,
                        "type": "null"
                      },
                      "shares_count": {
                        "deprecated": true,
                        "type": "integer"
                      },
                      "confirmed": {
                        "deprecated": true,
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "id",
                      "resource_type",
                      "name",
                      "image",
