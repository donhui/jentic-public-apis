                      "type": "boolean",
                      "description": "Whether the user has a primary login."
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "When the user was created"
                    },
                    "updated_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "When the user was updated"
                    },
                    "announcements_last_seen_at": {
                      "deprecated": true,
                      "type": [
                        "string",
                        "null"
                      ],
                      "format": "date-time"
                    },
                    "last_read_at": {
                      "type": [
                        "object",
                        "null"
                      ],
                      "maxProperties": 50,
                      "additionalProperties": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "description": "When the user read various notifications. At most 50 fields can be stored."
                    },
                    "notes": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "The notes for the user."
                    },
                    "organization_id": {
                      "type": "integer",
                      "description": "The organization ID of the user"
                    },
                    "organization": {
                      "type": "object",
                      "title": "Organization",
                      "description": "The organization of the user",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "The ID of the organization"
                        },
                        "resource_type": {
                          "type": "string",
                          "description": "The resource type of the organization",
                          "const": "Organization"
                        },
                        "name": {
                          "type": "string",
                          "description": "The name of the organization"
                        },
                        "domain": {
                          "type": "string",
                          "description": "The domain of the organization."
                        }
                      },
                      "required": [
                        "id",
                        "resource_type",
                        "name",
                        "domain"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "id",
                    "resource_type",
                    "name",
                    "email",
                    "image",
                    "locale",
                    "notifications_unread_count",
                    "otp_required_for_login",
                    "otp_enabled_at",
                    "primary_login_exists",
                    "created_at",
                    "updated_at",
                    "announcements_last_seen_at",
                    "last_read_at",
                    "notes",
                    "organization_id",
                    "organization"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "409": {
