    "/reports": {
      "get": {
        "operationId": "fetchReports",
        "summary": "Fetch reports",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Report",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the report"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the report",
                        "const": "Report"
                      },
                      "name": {
                        "type": "string",
                        "description": "The name of the report"
                      },
                      "status": {
                        "type": "string",
                        "enum": [
                          "waiting",
                          "in_progress",
                          "finished",
                          "failed"
                        ],
                        "description": "The status of the report."
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the report was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the report was updated"
                      },
                      "start_date": {
                        "type": "string",
                        "description": "The start date of the interval used to filter the data for the report.\nThis timestamp is expected to be in date format, YYYY-MM-DD.\nIf provided, it defines the beginning of the reporting period.\nThe interval cannot be shorter than the minimum and cannot be longer than the maximum, as defined by the reporter.\nCurrent minimum interval days: no limit\nCurrent maximum interval days: 180\n",
                        "format": "date",
                        "example": "2024-02-29"
                      },
                      "end_date": {
                        "type": "string",
                        "description": "The end date of the interval used to filter the data for the report.\nThis timestamp is expected to be in date format, YYYY-MM-DD.\nIf provided, it defines the end of the reporting period.\nThe interval cannot be shorter than the minimum and cannot be longer than the maximum, as defined by the reporter.\nCurrent minimum interval days: no limit\nCurrent maximum interval days: 180\n",
                        "format": "date",
                        "example": "2024-03-07"
                      },
                      "time_zone": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The time zone used for interpreting the start and end dates of the report.\nThis should be provided as a valid time zone identifier (e.g., \"America/New_York\").\nIf not provided, it defaults to the organization's time zone.\n",
                        "format": "time-zone",
                        "example": "America/New_York"
                      },
                      "organization_id": {
                        "type": "integer",
                        "description": "The organization ID of the report"
                      },
                      "organization": {
                        "type": "object",
                        "title": "Organization",
                        "description": "The organization of the report",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the organization"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the organization",
                            "const": "Organization"
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the organization"
                          },
                          "domain": {
                            "type": "string",
                            "description": "The domain of the organization."
                          }
                        },
                        "required": [
                          "id",
                          "resource_type",
                          "name",
                          "domain"
                        ],
                        "additionalProperties": false
                      },
                      "place_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The place ID of the report"
                      },
                      "reporter_id": {
                        "type": "integer",
                        "description": "The reporter ID of the report"
                      }
                    },
                    "required": [
                      "id",
                      "resource_type",
                      "name",
                      "status",
                      "created_at",
                      "updated_at",
                      "start_date",
                      "end_date",
                      "time_zone",
                      "organization_id",
                      "organization",
                      "place_id",
                      "reporter_id"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            },
            "headers": {
              "X-Collection-Range": {
                "description": "Pagination information for offset based pagination. `start-end` represents the range\nof items requested. `total` represents the total count of items. If there is a total\nof 15 items and an offset of 10 and limit of 10 is used, the resulting header is:\n`10-19/15`.\n",
                "schema": {
                  "type": "string",
                  "pattern": "^(?<start>\\d+)-(?<end>\\d+)/(?<total>\\d+)$"
                },
                "example": "0-9/200"
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
