            "in": "query",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "The ID of the place to scope by"
          },
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by a freetext string. Properties searched: `name`\n"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Floor",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the floor"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the floor",
                        "const": "Floor"
                      },
                      "name": {
                        "type": "string",
                        "description": "The name of the floor"
                      },
                      "description": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The description of the floor"
                      },
                      "number": {
                        "type": "integer",
                        "description": "The number of the floor"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the floor was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the floor was updated"
                      },
                      "place_id": {
                        "type": "integer",
                        "description": "The place ID of the floor"
                      }
                    },
                    "required": [
                      "id",
                      "resource_type",
                      "name",
                      "description",
                      "number",
                      "created_at",
                      "updated_at",
                      "place_id"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            },
            "headers": {
              "X-Collection-Range": {
                "description": "Pagination information for offset based pagination. `start-end` represents the range\nof items requested. `total` represents the total count of items. If there is a total\nof 15 items and an offset of 10 and limit of 10 is used, the resulting header is:\n`10-19/15`.\n",
                "schema": {
                  "type": "string",
                  "pattern": "^(?<start>\\d+)-(?<end>\\d+)/(?<total>\\d+)$"
                },
                "example": "0-9/200"
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
