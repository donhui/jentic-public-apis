            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Share",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the share"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the share",
                        "const": "Share"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the share was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the share was updated"
                      },
                      "email": {
                        "type": "string",
