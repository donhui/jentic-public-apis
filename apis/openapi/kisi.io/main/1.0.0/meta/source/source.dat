    "/presences": {
      "get": {
        "operationId": "fetchPresences",
        "summary": "Fetch presences",
        "description": "Represents information about the presence of users in a place for a given date.",
        "tags": [
          "Presences"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          },
          {
            "name": "place_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "The ID of the place to scope by"
          },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time",
              "description": "Filters the presences by date. In the place's time zone."
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Presence",
                    "properties": {
                      "actor_type": {
                        "type": "string",
                        "description": "The actor type of the Presence"
                      },
                      "actor_id": {
                        "type": "integer",
                        "description": "The actor id of the Presence"
                      },
                      "actor_name": {
                        "type": "string",
                        "description": "The actor name of the Presence"
                      },
                      "actor_email": {
                        "type": "string",
                        "description": "The actor email of the Presence"
                      },
                      "last_unlocked_lock_name": {
                        "type": "string",
                        "description": "The name of the lock that was unlocked last."
                      },
                      "last_unlocked_lock_id": {
                        "type": "integer",
                        "description": "The ID of the lock that was unlocked last."
                      },
                      "first_unlock_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "The date-time of the member's first unlock for the given date, in UTC."
                      },
                      "last_unlock_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "The date-time of the member's last unlock for the given date, in UTC."
                      },
                      "status": {
                        "type": "string",
                        "enum": [
                          "on_site",
                          "inactive",
                          "checked_out",
                          "expired"
                        ],
                        "description": "The presence status of a user that was present or is currently present at the place on the given date.\n"
                      },
                      "place_id": {
                        "type": "integer",
                        "description": "The place ID of the presence"
                      }
                    },
                    "required": [
                      "actor_type",
                      "actor_id",
                      "actor_name",
                      "actor_email",
                      "last_unlocked_lock_name",
                      "last_unlocked_lock_id",
                      "first_unlock_at",
                      "last_unlock_at",
                      "status",
                      "place_id"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            },
            "headers": {
              "X-Collection-Range": {
                "description": "Pagination information for offset based pagination. `start-end` represents the range\nof items requested. `total` represents the total count of items. If there is a total\nof 15 items and an offset of 10 and limit of 10 is used, the resulting header is:\n`10-19/15`.\n",
                "schema": {
                  "type": "string",
                  "pattern": "^(?<start>\\d+)-(?<end>\\d+)/(?<total>\\d+)$"
                },
                "example": "0-9/200"
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/readers": {
      "get": {
        "operationId": "fetchReaders",
        "summary": "Fetch readers",
        "tags": [
          "Readers"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by a freetext string. Properties searched: `name`, `device_id`, `token`\n"
          },
          {
            "name": "model",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "reader-1.0",
                "reader-2.0",
                "reader-pro-2.1",
                "reader-pro-2.1-hf",
                "reader-pro-3.0"
              ]
            },
            "description": "Filter by model"
          },
          {
            "name": "place_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by place ID"
          },
          {
            "name": "lock_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by lock ID"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "online",
                "offline"
              ]
            },
            "description": "Filter by status"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "-name"
              ]
            },
            "description": "Sort the results. Prepend `-` to sort in reverse order.\n\n`name` - sort by group name, alphabetically\n"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Reader",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the reader"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the reader",
                        "const": "Reader"
                      },
                      "name": {
                        "type": "string",
                        "description": "The name of the reader"
                      },
                      "description": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The description of the reader"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the reader was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the reader was updated"
                      },
                      "broadcast_ip_address": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The broadcast IP address of the reader"
                      },
                      "configured": {
                        "type": "boolean",
                        "description": "Whether the reader is configured"
                      },
                      "device_id": {
                        "type": "string",
                        "pattern": "^[a-fA-F0-9]{16}$",
                        "minLength": 16,
                        "maxLength": 16,
                        "description": "The device ID of the reader\n"
                      },
                      "ethernet_mac": {
                        "type": "string",
                        "description": "The ethernet MAC address of the reader"
                      },
                      "gateway_ip_address": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The gateway IP address of the reader"
                      },
                      "ip_address": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The IP address of the reader"
                      },
                      "model": {
                        "type": "string",
                        "enum": [
                          "reader-1.0",
                          "reader-2.0",
                          "reader-pro-2.1",
                          "reader-pro-2.1-hf",
                          "reader-pro-3.0"
                        ],
                        "description": "The model of the reader"
                      },
                      "network_interface": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "enum": [
                          "ethernet",
                          "wifi",
                          null
                        ],
                        "description": "The network interface of the reader"
                      },
                      "network": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The network of the reader"
                      },
                      "online": {
                        "type": "boolean",
                        "description": "Whether the reader is online"
                      },
                      "revision": {
                        "type": "string",
                        "description": "The revision of the reader"
                      },
                      "token": {
                        "type": "string",
                        "description": "The token of the reader"
                      },
                      "wifi_mac": {
                        "type": "string",
                        "description": "The wifi MAC address of the reader"
                      },
                      "backplate": {
                        "type": "string",
                        "enum": [
                          "standard",
                          "keypad_terminal",
