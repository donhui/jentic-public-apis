                    "type": "object",
                    "oneOf": [
                      {
                        "type": "object",
                        "title": "Organization - when authenticated by group link",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the organization"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the organization",
                            "const": "Organization"
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the organization"
                          },
                          "domain": {
                            "type": "string",
                            "description": "The domain of the organization."
                          },
                          "logo": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uri",
                            "description": "The URL to the logo of the organization."
                          },
                          "address": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "The address of the organization."
                          },
                          "description": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "The description of the organization"
                          },
                          "time_zone": {
                            "type": [
                              "string"
                            ],
                            "example": "Europe/London",
                            "description": "The time zone of the organization.\nIt should be a <a href=\"https://en.wikipedia.org/wiki/Tz_database#Names_of_time_zones\"> valid IANA time zone name.</a>\n"
                          },
                          "transfer_to_id": {
                            "type": [
                              "integer",
                              "null"
                            ],
                            "description": "The transfer_to ID of the organization"
                          },
                          "transfer_to": {
                            "type": "object",
                            "title": "User",
                            "description": "The transfer_to of the organization",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "The ID of the user"
                              },
                              "resource_type": {
                                "type": "string",
                                "description": "The resource type of the user",
                                "const": "User"
                              },
                              "email": {
                                "type": "string",
                                "format": "email",
                                "description": "The email of the user."
                              },
                              "name": {
                                "type": "string",
                                "description": "The name of the user"
                              }
                            },
                            "required": [
                              "id",
                              "resource_type",
                              "email",
                              "name"
                            ],
                            "additionalProperties": false
                          },
                          "image": {
                            "deprecated": true,
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "color": {
                            "deprecated": true,
                            "type": [
                              "string",
                              "null"
                            ]
                          }
                        },
                        "required": [
                          "id",
                          "resource_type",
                          "name",
                          "domain",
                          "logo",
                          "address",
                          "description",
                          "time_zone",
                          "transfer_to_id",
                          "image",
                          "color"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "title": "Organization",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the organization"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the organization",
                            "const": "Organization"
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the organization"
                          },
                          "domain": {
                            "type": "string",
                            "description": "The domain of the organization."
                          },
                          "logo": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "format": "uri",
                            "description": "The URL to the logo of the organization."
                          },
                          "address": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "The address of the organization."
                          },
                          "description": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "description": "The description of the organization"
                          },
                          "device_logins_expire_after": {
                            "type": [
                              "integer",
                              "null"
                            ],
                            "default": 1209600,
                            "minimum": 0,
                            "maximum": 31536000,
                            "description": "The device login expiration in seconds.\nIf not defined, it defaults to 2 weeks of inactivity.\n"
                          },
                          "places_count": {
                            "type": "integer",
                            "description": "Count of all the places within the organization."
                          },
                          "scim_enabled": {
                            "type": "boolean",
                            "description": "Whether SCIM is enabled for the organization."
                          },
                          "sso_flow_enabled": {
                            "type": "boolean",
                            "description": "Whether the organization has SSO flow enabled. Mutually exclusive with password flow.\n"
                          },
                          "sso_expiration_override_enabled": {
                            "type": "boolean",
                            "description": "Whether the organization should override length of SSO session.\n"
                          },
                          "sso_expiration_override": {
                            "type": [
                              "integer",
                              "null"
                            ],
                            "description": "The length of the SSO session (in seconds) that will override the default passed from Identity Provider.\n"
                          },
                          "metadata": {
                            "type": [
                              "string",
                              "null"
                            ],
