              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "User",
                  "properties": {
                    "otp_secret": {
                      "type": "string",
                      "description": "The OTP secret."
                    },
                    "uri": {
                      "type": "string",
                      "format": "uri",
                      "description": "The OTP provisioning url. Used as a source for QR code.",
                      "example": "otpauth://totp/Kisi:example.com?secret=otp_secret&issuer=Kisi"
                    }
                  },
                  "required": [],
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
