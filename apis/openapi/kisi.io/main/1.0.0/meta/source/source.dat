                            "description": "Defines what happens to the `scheduleable` when the schedule is occuring.\nThe `unlock` value only applies to schedules with `scheduleable_type` set to `Lock`.\nThe `permit` value only applies to schedules with `scheduleable_type` set to `ElevatorStop`.\n"
                          },
                          "scheduleable_type": {
                            "type": "string",
