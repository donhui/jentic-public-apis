        "summary": "Fetch group links",
        "tags": [
          "Group links"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by object IDs"
          },
          {
            "name": "group_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by group ID"
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by the name, email or phone of the record. Also filters on the group's name.\n"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "-name",
                "unlock",
                "-unlock",
                "valid_until",
                "-valid_until",
                "group_name",
                "-group_name"
              ]
            },
            "description": "Sort the results. Prepend `-` to sort in reverse order.\n\n`name` - sort by group link name, alphabetically<br>\n`unlock` - sort by last unlock; no unlocks first, then oldest to most recent<br>\n`valid_until` - Sort by group link valid_until; earliest to final, then no expiration\n"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 250
            },
            "description": "The number of objects to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "maximum": 20000
            },
            "description": "The number of objects to offset"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "title": "Group Link",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The ID of the group link"
                      },
                      "resource_type": {
                        "type": "string",
                        "description": "The resource type of the group link",
                        "const": "GroupLink"
                      },
                      "name": {
                        "type": "string",
                        "description": "The name of the group link"
                      },
                      "email": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "email",
                        "description": "The email to the person who should have access."
                      },
                      "phone": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The phone number of the person who should have access. Only US, Canadian and Puerto Rican numbers in\n    the format +11234567890 (E.164) are accepted."
                      },
                      "last_used_at": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "date-time",
                        "description": "When the group link was last used."
                      },
                      "link_enabled": {
                        "type": "boolean",
                        "default": true,
                        "description": "Will generate a link that can be used for access."
                      },
                      "quick_response_code_type": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "enum": [
                          "online",
                          "offline",
                          null
                        ],
                        "description": "Will generate a QR code (optionally offline capable) that can be scanned with compatible Kisi readers. Will be sent as part of the access link email, if an email address is provided. Will never be sent as part of SMS."
                      },
                      "valid_from": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "date-time"
                      },
                      "valid_until": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "date-time"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the group link was created"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "When the group link was updated"
                      },
                      "group_id": {
                        "type": "integer",
                        "description": "The group ID of the group link"
                      },
                      "group": {
                        "type": "object",
                        "title": "Group",
                        "description": "The group of the group link",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the group"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the group",
                            "const": "Group"
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the group"
                          }
                        },
                        "required": [
                          "id",
                          "resource_type",
                          "name"
                        ],
                        "additionalProperties": false
                      },
                      "created_by_type": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "enum": [
                          null,
                          "User",
                          "MarketplaceInstallation"
                        ],
                        "description": "The created_by type of the group link"
                      },
                      "created_by_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The created_by ID of the group link"
                      },
                      "created_by": {
                        "type": "object",
                        "description": "The created_by of the group link",
                        "oneOf": [
                          {
                            "type": "object",
                            "title": "User",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "The ID of the user"
                              },
                              "resource_type": {
                                "type": "string",
                                "description": "The resource type of the user",
                                "const": "User"
                              },
                              "email": {
                                "type": "string",
                                "format": "email",
                                "description": "The email of the user."
                              },
                              "name": {
                                "type": "string",
                                "description": "The name of the user"
                              }
                            },
                            "required": [
                              "id",
                              "resource_type",
                              "email",
                              "name"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "title": "Marketplace Installation",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "The ID of the marketplace installation"
                              },
                              "resource_type": {
                                "type": "string",
                                "description": "The resource type of the marketplace installation",
                                "const": "MarketplaceInstallation"
                              }
                            },
                            "required": [
                              "id",
                              "resource_type"
                            ],
                            "additionalProperties": false
                          }
                        ]
                      },
                      "issued_by_id": {
                        "type": [
                          "integer",
                          "null"
                        ],
                        "description": "The issued_by ID of the group link",
                        "deprecated": true
                      },
                      "issued_by": {
                        "type": "object",
                        "title": "User",
                        "description": "The issued_by of the group link",
                        "deprecated": true,
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "The ID of the user"
                          },
                          "resource_type": {
                            "type": "string",
                            "description": "The resource type of the user",
                            "const": "User"
                          },
                          "email": {
                            "type": "string",
                            "format": "email",
                            "description": "The email of the user."
                          },
                          "name": {
                            "type": "string",
                            "description": "The name of the user"
                          }
                        },
                        "required": [
                          "id",
                          "resource_type",
                          "email",
                          "name"
                        ],
                        "additionalProperties": false
