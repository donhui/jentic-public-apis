                          "description": "The URI to the image of the place. The image can be uploaded by first using the\n<a href=\"/operations/createSignedUploadURL\">Signed upload url endpoint</a>\nto generate a signed URL and then using the URL to upload the image.\n"
                        },
                        "time_zone": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "example": "Europe/London",
                          "description": "The time zone of the place.\nIt should be a <a href=\"https://en.wikipedia.org/wiki/Tz_database#Names_of_time_zones\"> valid IANA time zone name.</a>\n"
                        },
                        "tz_time_zone": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "example": "Europe/London",
                          "description": "The time zone of the place"
                        },
                        "locks_count": {
                          "type": "integer",
                          "description": "The number of locks in the place"
                        },
                        "integrations_count": {
                          "type": "integer",
                          "description": "The number of integrations in the place"
                        },
                        "locked_down": {
                          "type": "boolean",
                          "description": "Whether the place is locked down. When locked down the place is locked down for everyone.\n"
                        },
                        "locked_down_since": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "format": "date-time",
                          "description": "Since when the place has been locked down.\n"
                        },
                        "occupancy_rate": {
                          "type": [
                            "number",
                            "null"
                          ],
                          "format": "float",
                          "description": "What is the occupancy rate for an associated capacity record.\n"
                        },
                        "favorite": {
                          "type": "boolean",
                          "description": "Whether the place is marked as a favorite by the user. Only shown if requested."
                        },
                        "organization_id": {
                          "type": "integer",
                          "description": "The organization ID of the place"
                        },
                        "organization": {
                          "type": "object",
                          "title": "Organization",
                          "description": "The organization of the place",
                          "properties": {
                            "id": {
                              "type": "integer",
                              "description": "The ID of the organization"
                            },
                            "resource_type": {
                              "type": "string",
                              "description": "The resource type of the organization",
                              "const": "Organization"
                            },
                            "name": {
                              "type": "string",
                              "description": "The name of the organization"
                            },
                            "domain": {
                              "type": "string",
                              "description": "The domain of the organization."
                            }
                          },
                          "required": [
                            "id",
                            "resource_type",
                            "name",
                            "domain"
                          ],
                          "additionalProperties": false
                        },
                        "color": {
                          "deprecated": true,
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "logo": {
                          "deprecated": true,
                          "type": [
                            "string",
                            "null"
                          ]
                        },
                        "user_id": {
                          "deprecated": true,
                          "type": "null"
                        },
                        "members_count": {
                          "deprecated": true,
                          "type": "integer"
                        }
                      },
                      "required": [
                        "id",
                        "resource_type",
                        "name",
                        "description",
                        "created_at",
                        "updated_at",
                        "latitude",
                        "longitude",
                        "address",
                        "image",
                        "time_zone",
                        "tz_time_zone",
                        "locks_count",
                        "integrations_count",
                        "locked_down",
                        "locked_down_since",
                        "occupancy_rate",
                        "organization_id",
                        "organization",
                        "color",
                        "logo",
                        "user_id",
                        "members_count"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updatePlace",
        "summary": "Update place",
        "tags": [
          "Places"
        ],
        "security": [
          {
            "Kisi-Login": []
          },
          {
            "OAuth2": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "The ID of the object"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "title": "Place",
                "properties": {
                  "place": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "The name of the place"
                      },
                      "description": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "The description of the place"
                      },
                      "address": {
                        "type": [
                          "string"
                        ],
                        "maxLength": 500,
                        "description": "The address of the place"
                      },
                      "latitude": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "format": "float",
                        "description": "The latitude of the place"
                      },
                      "longitude": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "format": "float",
                        "description": "The longitude of the place"
                      },
                      "image": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "format": "uri",
                        "description": "The URI to the image of the place. The image can be uploaded by first using the\n<a href=\"/operations/createSignedUploadURL\">Signed upload url endpoint</a>\nto generate a signed URL and then using the URL to upload the image.\n"
                      },
                      "time_zone": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "example": "Europe/London",
                        "description": "The time zone of the place.\nIt should be a <a href=\"https://en.wikipedia.org/wiki/Tz_database#Names_of_time_zones\"> valid IANA time zone name.</a>\n"
                      }
                    },
                    "required": []
                  }
                },
                "required": [
                  "place"
                ]
              }
            }
          }
        },
        "responses": {
