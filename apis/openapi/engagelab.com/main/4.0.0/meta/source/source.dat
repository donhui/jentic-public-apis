{
  "openapi": "3.0.3",
  "info": {
    "title": "EngageLab App Push API",
    "description": "Create and manage push notifications for mobile applications via EngageLab.",
    "version": "4.0.0",
    "x-jentic-source-url": "https://engagelab.com/docs/app-push/rest-api/create-push-api"
  },
  "servers": [
    {
      "url": "https://pushapi.engagelab.cc",
      "description": "EngageLab Push API server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Push",
      "description": "Push notification endpoints"
    }
  ],
  "paths": {
    "/v4/push": {
      "post": {
        "operationId": "createPush",
        "summary": "Create a push notification",
        "description": "Send a push notification to targeted devices. Rate limited to 500 requests per second (standard plan).",
        "tags": ["Push"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PushRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Push notification created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PushResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using base64(appkey:mastersecret)"
      }
    },
    "schemas": {
      "PushRequest": {
        "type": "object",
        "required": ["to", "body"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Service sender identifier"
          },
          "to": {
            "oneOf": [
              { "type": "string" },
              { "type": "object" }
            ],
            "description": "Push destination target"
          },
          "body": { "$ref": "#/components/schemas/PushBody" },
          "request_id": {
            "type": "string",
            "description": "Custom identifier for tracking"
          },
          "custom_args": {
            "type": "object",
            "description": "Custom data returned in callbacks (max 128 characters)"
          }
        }
      },
      "PushBody": {
        "type": "object",
        "required": ["platform"],
        "properties": {
          "platform": {
            "oneOf": [
              { "type": "string", "enum": ["all", "android", "ios", "hmos"] },
              {
                "type": "array",
                "items": { "type": "string", "enum": ["android", "ios", "hmos"] }
              }
            ],
            "description": "Target platforms"
          },
          "notification": {
            "type": "object",
            "description": "Notification content displayed in system notification bar",
            "properties": {
              "alert": { "type": "string", "description": "Notification text" },
              "title": { "type": "string", "description": "Notification title" }
            }
          },
          "message": {
            "type": "object",
            "description": "In-app message content (not displayed in notification bar)",
            "properties": {
              "msg_content": { "type": "string", "description": "Message content" },
              "title": { "type": "string", "description": "Message title" }
            }
          },
          "live_activity": {
            "type": "object",
            "description": "iOS Live Activity content"
          },
          "voip": {
            "type": "object",
            "description": "iOS VoIP push payload"
          },
          "options": {
            "type": "object",
            "description": "Push configuration options",
            "properties": {
              "time_to_live": {
                "type": "integer",
                "description": "Message TTL in seconds"
              },
              "apns_production": {
                "type": "boolean",
                "description": "Use APNs production environment"
              }
            }
          }
        }
      },
      "PushResponse": {
        "type": "object",
        "properties": {
          "msg_id": {
            "type": "string",
            "description": "Unique message identifier"
          },
          "request_id": {
            "type": "string",
            "description": "Echo of submitted request ID"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error description"
          }
        }
      }
    }
  }
}