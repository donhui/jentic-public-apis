{
  "openapi": "3.0.3",
  "info": {
    "title": "Ekklo API",
    "version": "v1",
    "description": "Ekklo is a coaching platform that helps fitness coaches manage their clients, send invitations, and automate client workflows.",
    "x-jentic-source-url": "https://staging.api.ekklo.com/docs/index.html#/External%20-%20Clients"
  },
  "servers": [
    {
      "url": "https://staging.api.ekklo.com",
      "description": "Staging server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "Activities", "description": "Activity management"},
    {"name": "AI", "description": "AI chat and conversations"},
    {"name": "Integrations", "description": "Third-party integrations"},
    {"name": "Auth", "description": "Authentication"},
    {"name": "Programs", "description": "Programs and repetitions"}
  ],
  "paths": {
    "/api/v1/activities": {
      "get": {
        "operationId": "listActivities",
        "summary": "List activities",
        "tags": ["Activities"],
        "responses": {
          "200": {"description": "List of activities", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Activity"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createActivity",
        "summary": "Create an activity",
        "tags": ["Activities"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ActivityCreate"}}}},
        "responses": {
          "200": {"description": "Activity created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Activity"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/activities/sync": {
      "post": {
        "operationId": "syncActivities",
        "summary": "Sync activities",
        "tags": ["Activities"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Sync completed"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/activities/{uuid}": {
      "put": {
        "operationId": "updateActivity",
        "summary": "Update an activity",
        "tags": ["Activities"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ActivityCreate"}}}},
        "responses": {
          "200": {"description": "Activity updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Activity"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteActivity",
        "summary": "Delete an activity",
        "tags": ["Activities"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Activity deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/chat": {
      "post": {
        "operationId": "aiChat",
        "summary": "Send AI chat message",
        "tags": ["AI"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"message": {"type": "string"}}}}}},
        "responses": {
          "200": {"description": "AI chat response"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/conversations": {
      "get": {
        "operationId": "listConversations",
        "summary": "List AI conversations",
        "tags": ["AI"],
        "responses": {
          "200": {"description": "List of conversations", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Conversation"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/conversations/{id}": {
      "get": {
        "operationId": "getConversation",
        "summary": "Get a conversation",
        "tags": ["AI"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Conversation details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Conversation"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteConversation",
        "summary": "Delete a conversation",
        "tags": ["AI"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Conversation deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/feedback": {
      "post": {
        "operationId": "submitAiFeedback",
        "summary": "Submit AI feedback",
        "tags": ["AI"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Feedback submitted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/integrations": {
      "get": {
        "operationId": "listAiIntegrations",
        "summary": "List AI integrations",
        "tags": ["Integrations"],
        "responses": {
          "200": {"description": "List of integrations"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/integrations/available": {
      "get": {
        "operationId": "listAvailableIntegrations",
        "summary": "List available integrations",
        "tags": ["Integrations"],
        "responses": {
          "200": {"description": "Available integrations"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/integrations/{provider}": {
      "delete": {
        "operationId": "deleteIntegration",
        "summary": "Remove an integration",
        "tags": ["Integrations"],
        "parameters": [{"name": "provider", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Integration removed"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/integrations/{provider}/auth": {
      "get": {
        "operationId": "getIntegrationAuth",
        "summary": "Get integration OAuth URL",
        "tags": ["Integrations"],
        "parameters": [{"name": "provider", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Auth URL returned"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/integrations/{provider}/callback": {
      "get": {
        "operationId": "integrationCallback",
        "summary": "Integration OAuth callback",
        "tags": ["Integrations"],
        "parameters": [{"name": "provider", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "OAuth callback processed"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/settings": {
      "get": {
        "operationId": "getAiSettings",
        "summary": "Get AI settings",
        "tags": ["AI"],
        "responses": {
          "200": {"description": "AI settings"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/usage": {
      "get": {
        "operationId": "getAiUsage",
        "summary": "Get AI usage stats",
        "tags": ["AI"],
        "responses": {
          "200": {"description": "Usage statistics"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/ai/usage/history": {
      "get": {
        "operationId": "getAiUsageHistory",
        "summary": "Get AI usage history",
        "tags": ["AI"],
        "responses": {
          "200": {"description": "Usage history"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "operationId": "login",
        "summary": "User login",
        "tags": ["Auth"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LoginRequest"}}}},
        "responses": {
          "200": {"description": "Login successful", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AuthResponse"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Invalid credentials"}
        }
      }
    },
    "/api/v1/auth/login/refresh_token": {
      "post": {
        "operationId": "refreshToken",
        "summary": "Refresh authentication token",
        "tags": ["Auth"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"refresh_token": {"type": "string"}}}}}},
        "responses": {
          "200": {"description": "Token refreshed", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AuthResponse"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Invalid token"}
        }
      }
    },
    "/api/v1/auth/forgot_password": {
      "post": {
        "operationId": "forgotPassword",
        "summary": "Request password reset",
        "tags": ["Auth"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["email"], "properties": {"email": {"type": "string", "format": "email"}}}}}},
        "responses": {
          "200": {"description": "Reset email sent"},
          "400": {"description": "Bad request"}
        }
      }
    },
    "/api/v1/auth/create_password": {
      "post": {
        "operationId": "createPassword",
        "summary": "Create a new password",
        "tags": ["Auth"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["password", "token"], "properties": {"password": {"type": "string"}, "token": {"type": "string"}}}}}},
        "responses": {
          "200": {"description": "Password created"},
          "400": {"description": "Bad request"}
        }
      }
    },
    "/api/v1/auth/programs/repetitions": {
      "get": {
        "operationId": "listRepetitions",
        "summary": "List program repetitions",
        "tags": ["Programs"],
        "responses": {
          "200": {"description": "List of repetitions"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createRepetition",
        "summary": "Create a repetition",
        "tags": ["Programs"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Repetition created"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/auth/programs/repetitions/{uuid}": {
      "put": {
        "operationId": "updateRepetition",
        "summary": "Update a repetition",
        "tags": ["Programs"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Repetition updated"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteRepetition",
        "summary": "Delete a repetition",
        "tags": ["Programs"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Repetition deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Activity": {
        "type": "object",
        "properties": {
          "uuid": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "ActivityCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"}
        }
      },
      "Conversation": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"},
          "messages": {"type": "array", "items": {"type": "object"}}
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {"type": "string", "format": "email"},
          "password": {"type": "string"}
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "access_token": {"type": "string"},
          "refresh_token": {"type": "string"},
          "token_type": {"type": "string"}
        }
      }
    }
  }
}