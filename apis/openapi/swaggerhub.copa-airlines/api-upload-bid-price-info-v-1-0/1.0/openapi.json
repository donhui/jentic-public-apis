{
  "swagger": "2.0",
  "info": {
    "title": "API - Revenue Management BidPrice Upload - v1.0",
    "version": "1.0",
    "description": "Upload a BidPrice record.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Copa-Airlines/api-upload_bid_price_info_v_1_0/1.0/swagger.json"
  },
  "host": "api.copa.com",
  "basePath": "/rms/bidprice/v1.0/bidprice-upload",
  "schemes": [
    "https"
  ],
  "securityDefinitions": {
    "apiKeyHeader": {
      "type": "apiKey",
      "name": "Ocp-Apim-Subscription-Key",
      "in": "header"
    },
    "apiKeyQuery": {
      "type": "apiKey",
      "name": "subscription-key",
      "in": "query"
    }
  },
  "security": [
    {
      "apiKeyHeader": []
    },
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/": {
      "post": {
        "description": "Upload a BidPrice record.\n",
        "operationId": "??",
        "summary": "Revenue Management BidPrice Upload",
        "parameters": [
          {
            "name": "rmaUploadRecord",
            "in": "body",
            "schema": {
              "$ref": "#/definitions/RMSBidPriceUploadRecord"
            },
            "description": "The BidPrice record to upload."
          }
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "BidPrice Status OK Response",
            "schema": {
              "$ref": "#/definitions/RMSBidPriceUploadRecordResponse"
            },
            "examples": {
              "application/json": "{\n  \"Status\": \"Success\"\n}\n"
            }
          },
          "400": {
            "description": "400 - Error response.",
            "schema": {
              "$ref": "#/definitions/RMSBidPriceUploadRecordResponse"
            },
            "examples": {
              "application/json": "{\n  \"Status\": \"Failed\",\n  \"ErrorMessages\": [\n    {\n      \"Code\": \"1001\",\n      \"Description\": \"Field is missing.\",\n      \"Key\": \"CarrierCode\",\n      \"TypeCode\": \"Missing\"\n    }\n  ]\n}\n"
            }
          },
          "500": {
            "description": "500 - System Internal Error response.",
            "schema": {
              "$ref": "#/definitions/RMSBidPriceUploadRecordResponse"
            },
            "examples": {
              "application/json": "{\n  \"Status\": \"Failed\",\n  \"ErrorMessages\": [\n    {\n      \"Code\": \"1000\",\n      \"Description\": \"Internal system error.\",\n      \"Key\": \"SYSERROR\",\n      \"TypeCode\": \"SysInternal\"\n    }\n  ]\n}\n"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "RMSBidPriceUploadRecord": {
      "type": "object",
      "description": "The BidPrice record to upload.",
      "properties": {
        "CarrierCode": {
          "type": "string",
          "description": "IATA two letter airline code for representang the Airlines who is operating the flight.",
          "example": "CM"
        },
        "FlightNumber": {
          "type": "string",
          "description": "The airlines flight number.",
          "example": "357"
        },
        "DepartureDate": {
          "type": "string",
          "description": "Date of departure in date (YYYYMMDD) format.",
          "example": "20201012"
        },
        "UploadRecord": {
          "type": "string",
          "description": "The BidPrice record to upload.",
          "example": "UPG upload_cmapptest1_20190202_20190222_1001_744_20190204044225622 #UFG CM 00123 20190222 ? ? N 0 #ULG AAA BBB 20190222 332 ? 1 #ULC C 34 34 34 0 0 0 34 0 999 0 44.41571 0 #ULB C 1 0 0 1 100 ? ? 0 0 1 0 100 34 ? ? 1.292372 0.958965 C #..#ULB R 0 0 0 0 100 ? ? 0 0 0 0 100 0 ? ? 0.0 0.0 C #ULP 1 7019 #..#ULP 34 7 #ULC Y 205 205 205 0 2 1 208 0 10 0 372.555573 0 #ULB Y 1 0 0 1 101 ? ? 0 0 1 0 96 208 ? ? 0.827366 0.785732 Y #..#ULB W 3 0 0 3 101 ? ? 3 0 3 0 100 3 ? ? 3.0 3.0 Y #ULP 1 3538 #ULP 208 694 #USG AAA BBB 20190222 #USC C #USB C 1 0 0 1 100 ? ? 0 0 1 0 100 34 ? ? 1.292372 0.958965 C #..#USB R 0 0 0 0 100 ? ? 0 0 0 0 100 0 ? ? 0.0 0.0 I #USC Y #USB Y 1 0 0 1 101 ? ? 0 0 1 0 96 208 ? ? 0.827366 0.785732 Y #..#USB W 3 0 0 3 101 ? ? 3 0 3 0 100 3 ? ? 3.0 3.0 Y "
        }
      },
      "required": [
        "CarrierCode",
        "FlightNumber",
        "DepartureDate",
        "UpLoadRecord"
      ],
      "example": {
        "CarrierCode": "CM",
        "FlightNumber": "357",
        "DepartureDate": "20201012",
        "UploadRecord": "UPG upload_cmapptest1_20190202_20190222_1001_744_20190204044225622 #UFG CM 00123 20190222 ? ? N 0 #ULG AAA BBB 20190222 332 ? 1 #ULC C 34 34 34 0 0 0 34 0 999 0 44.41571 0 #ULB C 1 0 0 1 100 ? ? 0 0 1 0 100 34 ? ? 1.292372 0.958965 C #..#ULB R 0 0 0 0 100 ? ? 0 0 0 0 100 0 ? ? 0.0 0.0 C #ULP 1 7019 #..#ULP 34 7 #ULC Y 205 205 205 0 2 1 208 0 10 0 372.555573 0 #ULB Y 1 0 0 1 101 ? ? 0 0 1 0 96 208 ? ? 0.827366 0.785732 Y #..#ULB W 3 0 0 3 101 ? ? 3 0 3 0 100 3 ? ? 3.0 3.0 Y #ULP 1 3538 #ULP 208 694 #USG AAA BBB 20190222 #USC C #USB C 1 0 0 1 100 ? ? 0 0 1 0 100 34 ? ? 1.292372 0.958965 C #..#USB R 0 0 0 0 100 ? ? 0 0 0 0 100 0 ? ? 0.0 0.0 I #USC Y #USB Y 1 0 0 1 101 ? ? 0 0 1 0 96 208 ? ? 0.827366 0.785732 Y #..#USB W 3 0 0 3 101 ? ? 3 0 3 0 100 3 ? ? 3.0 3.0 Y "
      }
    },
    "RMSBidPriceUploadRecordResponse": {
      "type": "object",
      "description": "The BidPrice record to upload response.",
      "properties": {
        "Status": {
          "type": "string",
          "enum": [
            "Success",
            "Failed"
          ],
          "description": "A status describing if upload in was\n  - Success: the BidPrice record was uploaded without exceptions.\n  - Failed: the BidPrice record was not uploaded.",
          "example": "Success"
        },
        "ErrorMessages": {
          "type": "array",
          "description": "Represents an ErrorMessage Array.",
          "items": {
            "$ref": "#/definitions/ErrorMessage"
          }
        }
      },
      "required": [
        "Status"
      ]
    },
    "ErrorMessage": {
      "type": "object",
      "description": "Represents an Error element with Error Code and Description",
      "required": [
        "Code",
        "Description"
      ],
      "properties": {
        "Code": {
          "type": "string",
          "example": "1002",
          "description": "Error code"
        },
        "Description": {
          "type": "string",
          "example": "Error descriptions",
          "description": "Error descriptions"
        },
        "Key": {
          "type": "string",
          "example": "Key",
          "description": "Key"
        },
        "TypeCode": {
          "type": "string",
          "example": "TypeCode",
          "description": "TypeCode"
        }
      }
    }
  },
  "tags": []
}