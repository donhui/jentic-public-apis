{
  "openapi": "3.0.3",
  "info": {
    "title": "PoetryDB API",
    "version": "1.0.0",
    "description": "PoetryDB is a free API for internet encyclopaedia of poetry. Search and retrieve poems by author, title, lines, and linecount.",
    "x-jentic-source-url": "https://github.com/thundercomb/poetrydb"
  },
  "servers": [
    {
      "url": "https://poetrydb.org"
    }
  ],
  "paths": {
    "/author": {
      "get": {
        "operationId": "listAuthors",
        "summary": "List all authors",
        "tags": ["Authors"],
        "responses": {
          "200": {
            "description": "List of all authors",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/author/{author}": {
      "get": {
        "operationId": "getPoemsByAuthor",
        "summary": "Get poems by author (partial match)",
        "tags": ["Authors"],
        "parameters": [
          {
            "name": "author",
            "in": "path",
            "required": true,
            "description": "Author name or partial name to search",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Poems matching author",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Poem" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/author/{author}/{outputFields}": {
      "get": {
        "operationId": "getPoemsByAuthorWithFields",
        "summary": "Get specific fields from poems by author",
        "tags": ["Authors"],
        "parameters": [
          {
            "name": "author",
            "in": "path",
            "required": true,
            "description": "Author name or partial name",
            "schema": { "type": "string" }
          },
          {
            "name": "outputFields",
            "in": "path",
            "required": true,
            "description": "Comma-separated output fields (author, title, lines, linecount)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Filtered poem data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "object" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/title": {
      "get": {
        "operationId": "listTitles",
        "summary": "List all poem titles",
        "tags": ["Titles"],
        "responses": {
          "200": {
            "description": "List of all titles",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TitleList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/title/{title}": {
      "get": {
        "operationId": "getPoemsByTitle",
        "summary": "Search poems by title (partial match)",
        "tags": ["Titles"],
        "parameters": [
          {
            "name": "title",
            "in": "path",
            "required": true,
            "description": "Title or partial title to search",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching poems",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Poem" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/lines/{lines}": {
      "get": {
        "operationId": "getPoemsByLines",
        "summary": "Search poems by line content",
        "tags": ["Lines"],
        "parameters": [
          {
            "name": "lines",
            "in": "path",
            "required": true,
            "description": "Text to search within poem lines",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching poems",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Poem" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/linecount/{linecount}": {
      "get": {
        "operationId": "getPoemsByLinecount",
        "summary": "Get poems with exact line count",
        "tags": ["Lines"],
        "parameters": [
          {
            "name": "linecount",
            "in": "path",
            "required": true,
            "description": "Exact number of lines",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Poems with matching linecount",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Poem" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/random": {
      "get": {
        "operationId": "getRandomPoem",
        "summary": "Get a random poem",
        "tags": ["Random"],
        "responses": {
          "200": {
            "description": "A random poem",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Poem" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/random/{count}": {
      "get": {
        "operationId": "getRandomPoems",
        "summary": "Get multiple random poems",
        "tags": ["Random"],
        "parameters": [
          {
            "name": "count",
            "in": "path",
            "required": true,
            "description": "Number of random poems to return",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Random poems",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Poem" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Poem": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "author": { "type": "string" },
          "lines": {
            "type": "array",
            "items": { "type": "string" }
          },
          "linecount": { "type": "string" }
        }
      },
      "AuthorList": {
        "type": "object",
        "properties": {
          "authors": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "TitleList": {
        "type": "object",
        "properties": {
          "titles": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": { "type": "integer" },
          "reason": { "type": "string" }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}