{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Registration API for storing user-registrations (Backend Recruiting Homework)",
    "description": "The API provides endpoints to store and retrieve user-registrations including their trust-score",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Jaumo/backend-recruiting-homework_registrations/1.0.0/swagger.json"
  },
  "paths": {
    "/registrations": {
      "post": {
        "summary": "Create a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewUser"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created the user",
            "headers": {
              "Location": {
                "schema": {
                  "type": "string",
                  "format": "uri",
                  "description": "The URI of the created registration"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request. Something (invalid json, invalid value, ...) is not ok with the request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Email is already in use",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Unxpected Server Error"
          }
        }
      },
      "get": {
        "summary": "Retrieve list of all users",
        "responses": {
          "200": {
            "description": "List all registrations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "5XX": {
            "description": "Unxpected Server Error"
          }
        }
      }
    },
    "/registration/{id}": {
      "get": {
        "summary": "Retrieve a single user",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Numeric ID of the registration requested"
          }
        ],
        "responses": {
          "200": {
            "description": "Get a registration"
          },
          "404": {
            "description": "Registration not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "5XX": {
            "description": "Unxpected Server Error"
          }
        }
      }
    },
    "/trusted-registrations": {
      "get": {
        "summary": "List all trusted (Scored and score above certain threshold) registrations",
        "responses": {
          "200": {
            "description": "List of trusted users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "5XX": {
            "description": "Unxpected Server Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "NewUser": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john.doe@example.org"
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "example": "1970-01-01"
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female",
              "other"
            ]
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "href": {
            "type": "string",
            "format": "uri",
            "example": "https://example.org/registration/1"
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john.doe@example.org"
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "example": "1970-01-01"
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female",
              "other"
            ]
          },
          "fake_score": {
            "type": "number",
            "description": "A value of -1 marks an unscored user, a value between 0 and 1 is the calculated fake likeness",
            "minimum": -1,
            "maximum": 1,
            "example": 0.5398
          },
          "created": {
            "type": "string",
            "format": "datetime",
            "description": "The date and time when the registration was created",
            "example": "2018-01-01T01:02:03Z"
          },
          "fake_scored": {
            "type": "string",
            "format": "datetime",
            "description": "The date and time when the registration was scored",
            "example": "2018-01-01T01:03:25Z"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Oops, this went terribly wrong"
          }
        }
      }
    }
  }
}