          },
          "uniqueOpened": {
            "type": "integer"
          },
          "totalClicked": {
            "type": "integer"
          },
          "uniqueClicked": {
            "type": "integer"
          },
          "totalBounced": {
            "type": "integer"
          },
          "hardBounced": {
            "type": "integer"
          },
          "softBounced": {
            "type": "integer"
          },
          "totalUnsubscribed": {
            "type": "integer"
          }
        }
      },
      "SocialPreferences": {
        "type": "object",
        "properties": {
