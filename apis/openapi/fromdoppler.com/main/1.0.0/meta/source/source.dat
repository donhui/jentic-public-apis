    "/accounts/{accountEmail}/campaigns/{campaignId}/results": {
      "get": {
        "operationId": "getCampaignResultsSummary",
        "summary": "Get campaign results summary",
        "description": "Retrieve the results and analytics summary for a sent campaign.",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/CampaignId"
          }
        ],
