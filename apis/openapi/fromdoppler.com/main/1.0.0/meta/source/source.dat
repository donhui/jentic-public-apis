  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Use format: token {your-api-key}"
      }
    },
    "parameters": {
      "AccountEmail": {
        "name": "accountEmail",
        "in": "path",
        "required": true,
        "description": "The account email address",
        "schema": {
          "type": "string",
          "format": "email"
        }
      },
      "ListId": {
        "name": "listId",
        "in": "path",
        "required": true,
        "description": "The mailing list ID",
        "schema": {
          "type": "integer"
        }
      },
      "SubscriberEmail": {
        "name": "subscriberEmail",
        "in": "path",
        "required": true,
        "description": "The subscriber's email address",
        "schema": {
          "type": "string",
          "format": "email"
        }
      },
      "CampaignId": {
        "name": "campaignId",
        "in": "path",
        "required": true,
        "description": "The campaign ID",
        "schema": {
          "type": "integer"
        }
      }
    },
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          },
          "_links": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "MailingList": {
        "type": "object",
        "properties": {
          "listId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "currentStatus": {
            "type": "string"
          },
          "subscribersCount": {
            "type": "integer"
          },
          "creationDate": {
            "type": "string",
            "format": "date-time"
          },
          "_links": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "ListCollection": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MailingList"
            }
          },
          "itemsCount": {
            "type": "integer"
          },
          "currentPage": {
            "type": "integer"
          },
          "pagesCount": {
            "type": "integer"
          },
          "_links": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "CreateListRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the mailing list"
          }
        }
      },
      "Subscriber": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SubscriberField"
            }
          },
          "status": {
            "type": "string"
          },
          "score": {
            "type": "integer"
          },
          "_links": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "SubscriberField": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "SubscriberCollection": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subscriber"
            }
          },
          "itemsCount": {
            "type": "integer"
          },
          "currentPage": {
            "type": "integer"
          },
          "pagesCount": {
            "type": "integer"
          },
          "_links": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "ImportSubscribersRequest": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Field names to map the import data"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "format": "email"
                },
                "fields": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SubscriberField"
                  }
                }
              }
            },
            "description": "Array of subscriber data to import"
          },
          "callback": {
            "type": "string",
            "format": "uri",
            "description": "Optional callback URL to notify when import completes"
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "campaignId": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "preheader": {
            "type": "string"
          },
          "fromName": {
            "type": "string"
          },
          "fromEmail": {
            "type": "string",
            "format": "email"
          },
          "replyTo": {
            "type": "string",
            "format": "email"
          },
          "creationDate": {
            "type": "string",
            "format": "date-time"
          },
          "_links": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "CampaignRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "preheader": {
            "type": "string"
          },
          "fromName": {
            "type": "string"
          },
          "fromEmail": {
            "type": "string",
            "format": "email"
          },
          "replyTo": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "CampaignCollection": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Campaign"
            }
          },
          "itemsCount": {
            "type": "integer"
          },
          "currentPage": {
            "type": "integer"
          },
          "pagesCount": {
            "type": "integer"
          },
