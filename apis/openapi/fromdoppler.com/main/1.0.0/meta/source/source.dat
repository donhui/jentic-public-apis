{
  "openapi": "3.0.3",
  "info": {
    "title": "Doppler Email Marketing API",
    "description": "Doppler is an email marketing tool that allows you to reach your clients in a simple, fast and effective way. This API enables management of lists, subscribers, campaigns, custom fields, and more.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://restapi.fromdoppler.com/docs/"
  },
  "servers": [
    {
      "url": "https://restapi.fromdoppler.com",
      "description": "Doppler REST API"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Account",
      "description": "Account management operations"
    },
    {
      "name": "Lists",
      "description": "Mailing list management"
    },
    {
      "name": "Subscribers",
      "description": "Subscriber management operations"
    },
    {
      "name": "Campaigns",
      "description": "Campaign management operations"
    },
    {
      "name": "Fields",
      "description": "Custom field management"
    },
    {
      "name": "Tasks",
      "description": "Async task tracking"
    }
  ],
  "paths": {
    "/accounts/{accountEmail}": {
      "get": {
        "operationId": "getAccountHome",
        "summary": "Get account home",
        "description": "Access the account entry point with navigation links to all resources.",
        "tags": ["Account"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          }
        ],
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/accounts/{accountEmail}/lists": {
      "get": {
        "operationId": "getListCollection",
        "summary": "Get lists collection",
        "description": "Retrieve all mailing lists for an account. Returns paginated results with up to 20 items per page.",
        "tags": ["Lists"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of items per page (max 20)",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of mailing lists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListCollection"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createList",
        "summary": "Create a mailing list",
        "description": "Create a new mailing list for the account.",
        "tags": ["Lists"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateListRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "List created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreationResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/accounts/{accountEmail}/lists/{listId}": {
      "get": {
        "operationId": "getList",
        "summary": "Get a list",
        "description": "Retrieve details of a specific mailing list.",
        "tags": ["Lists"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          }
        ],
        "responses": {
          "200": {
            "description": "List details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MailingList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "List not found"
          }
        }
      },
      "put": {
        "operationId": "editList",
        "summary": "Edit a list",
        "description": "Modify an existing mailing list's properties.",
        "tags": ["Lists"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateListRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "List not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteList",
        "summary": "Delete a list",
        "description": "Remove a mailing list.",
        "tags": ["Lists"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          }
        ],
        "responses": {
          "200": {
            "description": "List deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "List not found"
          }
        }
      }
    },
    "/accounts/{accountEmail}/lists/{listId}/subscribers": {
      "get": {
        "operationId": "getSubscriberCollection",
        "summary": "Get subscribers of a list",
        "description": "Retrieve subscribers for a specific mailing list. Supports date filtering with ISO 8601 format.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          },
          {
            "name": "from",
            "in": "query",
            "description": "Filter subscribers from this date (ISO 8601 with timezone, e.g. 2015-08-15T09:00+04:00)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "Filter subscribers up to this date (ISO 8601 with timezone)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of subscribers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriberCollection"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "associateSubscriber",
        "summary": "Associate a subscriber to a list",
        "description": "Add a new subscriber or update an existing one and associate it with the list. Unspecified fields retain their previous values when updating.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          },
          {
            "name": "X-Doppler-Subscriber-Origin",
            "in": "header",
            "description": "Override subscriber origin. Accepts: Manual, Importado, Formulario, MercadoShops, RestAPI",
            "schema": {
              "type": "string",
              "enum": ["Manual", "Importado", "Formulario", "MercadoShops", "RestAPI"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Subscriber"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscriber associated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/accounts/{accountEmail}/lists/{listId}/subscribers/{subscriberEmail}": {
      "get": {
        "operationId": "getSubscriber",
        "summary": "Get a subscriber",
        "description": "Retrieve details of a specific subscriber from a list.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          },
          {
            "$ref": "#/components/parameters/SubscriberEmail"
          }
        ],
        "responses": {
          "200": {
            "description": "Subscriber details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscriber"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Subscriber not found"
          }
        }
      },
      "put": {
        "operationId": "editSubscriber",
        "summary": "Edit a subscriber",
        "description": "Edit subscriber details. Email addresses are not editable. Fields omitted from the request will have their data removed.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          },
          {
            "$ref": "#/components/parameters/SubscriberEmail"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Subscriber"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscriber updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Subscriber not found"
          }
        }
      },
      "delete": {
        "operationId": "removeFromList",
        "summary": "Remove subscriber from list",
        "description": "Remove a subscriber from a specific mailing list.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          },
          {
            "$ref": "#/components/parameters/SubscriberEmail"
          }
        ],
        "responses": {
          "200": {
            "description": "Subscriber removed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Subscriber not found"
          }
        }
      }
    },
    "/accounts/{accountEmail}/lists/{listId}/subscribers/import": {
      "post": {
        "operationId": "importSubscribers",
        "summary": "Import subscribers",
        "description": "Asynchronous bulk import of subscribers to a list. Returns a task reference for tracking progress.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportSubscribersRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Import task accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreationResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/accounts/{accountEmail}/lists/{listId}/subscribers/{subscriberEmail}/unsubscribe": {
      "put": {
        "operationId": "unsubscribeSubscriber",
        "summary": "Unsubscribe a subscriber",
        "description": "Unsubscribe a subscriber from a list.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "$ref": "#/components/parameters/ListId"
          },
          {
            "$ref": "#/components/parameters/SubscriberEmail"
          }
        ],
        "responses": {
          "200": {
            "description": "Subscriber unsubscribed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResult"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/accounts/{accountEmail}/campaigns": {
      "get": {
        "operationId": "getCampaignCollection",
        "summary": "Get campaigns collection",
        "description": "Retrieve a paginated collection of campaigns.",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignCollection"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createCampaign",
        "summary": "Create a campaign draft",
        "description": "Create a new campaign draft.",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountEmail"
