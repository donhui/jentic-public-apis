{
  "openapi": "3.0.3",
  "info": {
    "title": "Synthesia API",
    "version": "1.0.0",
    "description": "Synthesia is an AI video creation platform. The API allows you to create AI videos from text scripts with avatars, retrieve video status, list templates, and manage avatars.",
    "x-jentic-source-url": "https://docs.synthesia.io/reference"
  },
  "servers": [
    { "url": "https://api.synthesia.io/v2", "description": "Production" }
  ],
  "security": [{ "apiKey": [] }],
  "paths": {
    "/videos": {
      "post": {
        "operationId": "createVideo",
        "tags": ["Videos"],
        "summary": "Create a video",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateVideoRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Video created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Video" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "get": {
        "operationId": "listVideos",
        "tags": ["Videos"],
        "summary": "List all videos",
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10, "maximum": 100 } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VideoList" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/videos/{videoId}": {
      "get": {
        "operationId": "getVideo",
        "tags": ["Videos"],
        "summary": "Get a video by ID",
        "parameters": [
          { "name": "videoId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Video" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "operationId": "updateVideo",
        "tags": ["Videos"],
        "summary": "Update a video",
        "parameters": [
          { "name": "videoId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateVideoRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Video" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteVideo",
        "tags": ["Videos"],
        "summary": "Delete a video",
        "parameters": [
          { "name": "videoId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/templates": {
      "get": {
        "operationId": "listTemplates",
        "tags": ["Templates"],
        "summary": "List all available video templates",
        "parameters": [
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TemplateList" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/templates/{templateId}": {
      "get": {
        "operationId": "getTemplate",
        "tags": ["Templates"],
        "summary": "Get a template by ID",
        "parameters": [
          { "name": "templateId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Template" } } } },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/avatars": {
      "get": {
        "operationId": "listAvatars",
        "tags": ["Avatars"],
        "summary": "List all available avatars",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AvatarList" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key obtained from the Synthesia dashboard"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "errors": { "type": "array", "items": { "type": "string" } }
        }
      },
      "VideoScript": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["audio", "text"] },
          "audioUrl": { "type": "string" },
          "avatar": { "type": "string" },
          "avatarSettings": { "$ref": "#/components/schemas/AvatarSettings" },
          "background": { "type": "string" },
          "slides": { "type": "array", "items": { "$ref": "#/components/schemas/Slide" } }
        }
      },
      "AvatarSettings": {
        "type": "object",
        "properties": {
          "horizontalAlign": { "type": "string" },
          "scale": { "type": "number" },
          "style": { "type": "string" },
          "voice": { "type": "string" }
        }
      },
      "Slide": {
        "type": "object",
        "properties": {
          "script": { "type": "string" },
          "avatar": { "type": "string" },
          "background": { "type": "string" }
        }
      },
      "CreateVideoRequest": {
        "type": "object",
        "required": ["title", "input"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "visibility": { "type": "string", "enum": ["public", "private"] },
          "callbackId": { "type": "string" },
          "input": { "type": "array", "items": { "$ref": "#/components/schemas/VideoScript" } },
          "test": { "type": "boolean", "description": "Set to true for a test render" }
        }
      },
      "UpdateVideoRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "visibility": { "type": "string", "enum": ["public", "private"] }
        }
      },
      "Video": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["in_progress", "complete", "failed"] },
          "visibility": { "type": "string" },
          "createdAt": { "type": "integer", "description": "Unix timestamp" },
          "updatedAt": { "type": "integer" },
          "download": { "type": "string", "description": "Download URL when complete" },
          "duration": { "type": "number" }
        }
      },
      "VideoList": {
        "type": "object",
        "properties": {
          "videos": { "type": "array", "items": { "$ref": "#/components/schemas/Video" } },
          "total": { "type": "integer" },
          "offset": { "type": "integer" },
          "limit": { "type": "integer" }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "thumbnailUrl": { "type": "string" },
          "durationInSeconds": { "type": "number" }
        }
      },
      "TemplateList": {
        "type": "object",
        "properties": {
          "templates": { "type": "array", "items": { "$ref": "#/components/schemas/Template" } },
          "total": { "type": "integer" }
        }
      },
      "Avatar": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "imageUrl": { "type": "string" }
        }
      },
      "AvatarList": {
        "type": "object",
        "properties": {
          "avatars": { "type": "array", "items": { "$ref": "#/components/schemas/Avatar" } }
        }
      }
    }
  }
}
