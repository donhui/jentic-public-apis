{
  "openapi": "3.0.3",
  "info": {
    "title": "Nemonic Zapier API",
    "description": "Nemonic Zapier API using on Nemonic Zapier Integration. Nemonic is a versatile inkless printer for sticky notes and labels.",
    "contact": {
      "name": "Mangoslab",
      "email": "developer@mangoslab.com"
    },
    "license": {
      "name": "Copyright(c) 2023 MANGOSLAB Co.,Ltd. All rights reserved.",
      "url": "https://mangoslab.blob.core.windows.net/zapier/LICENSE"
    },
    "version": "1.0",
    "x-jentic-source-url": "https://zapier.mangoslab.org/swagger/v1/swagger.json"
  },
  "servers": [
    {
      "url": "https://zapier.mangoslab.org",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Action",
      "description": "Actions including authentication test, ping, and print"
    },
    {
      "name": "Printers",
      "description": "Printer management operations"
    }
  ],
  "paths": {
    "/v1/AuthTest": {
      "get": {
        "tags": ["Action"],
        "summary": "Test user authentication",
        "description": "Response includes just user name.",
        "operationId": "testAuth",
        "responses": {
          "200": {
            "description": "It can be accessed normally."
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/Ping": {
      "get": {
        "tags": ["Action"],
        "summary": "Test server accessibility",
        "description": "Responses are random to prevent caching.",
        "operationId": "ping",
        "responses": {
          "200": {
            "description": "It can be accessed normally."
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/Printers": {
      "get": {
        "tags": ["Printers"],
        "summary": "Search for printers registered to authenticated user",
        "description": "Search for printers using authenticated user information.",
        "operationId": "listPrinters",
        "responses": {
          "200": {
            "description": "Printer search was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PrinterModel"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/Print": {
      "post": {
        "tags": ["Action"],
        "summary": "Process request to print",
        "description": "Rather than requesting output directly from the printer, print messages are registered in a message queue service that the printer can access. A printer must be registered to the user, and the user must have permission to access the printer to send a print message.",
        "operationId": "createPrintJob",
        "requestBody": {
          "description": "Request to print.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostPrintRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The output request was successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostPrintResponse"
                }
              }
            }
          },
          "400": {
            "description": "The output request format is incorrect.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "User or printer not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Unable to send output request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CartridgeType": {
        "enum": ["None", "StickyWhite", "StickyYellow", "StickyGreen", "StickyBlue", "StickyReserved", "LabelReserved6", "Label4Inch", "StickyPink", "LabelReserved5", "LabelReserved7", "Label3Inch", "LabelReserved8", "Label2Inch", "Label1Inch", "LabelGeneral"],
        "type": "string"
      },
      "ColorType": {
        "enum": ["Unknown", "White", "Yellow", "Blue", "Pink", "Green"],
        "type": "string"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "HTTP Response state code.",
            "format": "int32"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of error messages.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Error Response."
      },
      "ModelType": {
        "enum": ["Unknown", "Nemonic", "NemonicLabel", "NemonicMini"],
        "type": "string"
      },
      "PostPrintRequest": {
        "required": ["printer"],
        "type": "object",
        "properties": {
          "printer": {
            "minLength": 1,
            "type": "string",
            "description": "Printer ID to send print request to.",
            "example": "96d9e907-6efd-483b-8624-7d6a9504c8e0"
          },
          "dataTypeToPrint": {
            "type": "string",
            "description": "Type of printable data (Text / ImageUrl).",
            "nullable": true,
            "example": "Text"
          },
          "dataToPrint": {
            "type": "string",
            "description": "Message to print or image URL to print.",
            "nullable": true,
            "example": "Printing Test"
          },
          "stickyDirection": {
            "type": "string",
            "description": "Sticky side position.",
            "nullable": true,
            "example": "Right"
          },
          "paperLength": {
            "type": "string",
            "description": "Print length.",
            "nullable": true,
            "example": "Auto"
          },
          "imageFitOption": {
            "type": "string",
            "description": "Image fit option.",
            "nullable": true,
            "example": "ScaleDown"
          }
        },
        "additionalProperties": false,
        "description": "POST /Print request body."
      },
      "PostPrintResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean"
          },
          "lengthOfPaper": {
            "type": "number",
            "format": "double"
          },
          "numberOfPapers": {
            "type": "integer",
            "format": "int32"
          },
          "numberOfCharacters": {
            "type": "integer",
            "format": "int32"
          },
          "errorResponse": {
            "$ref": "#/components/schemas/ErrorResponse"
          }
        },
        "additionalProperties": false
      },
      "PrinterCartridge": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/CartridgeType"
          },
          "isMini": {
            "type": "boolean"
          },
          "isStickyPaper": {
            "type": "boolean",
            "readOnly": true
          },
          "isLabel": {
            "type": "boolean",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "PrinterCoverColor": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ColorType"
          }
        },
        "additionalProperties": false
      },
      "PrinterModel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "isReady": {
            "type": "boolean"
          },
          "type": {
            "$ref": "#/components/schemas/PrinterModelType"
          },
          "cartridge": {
            "$ref": "#/components/schemas/PrinterCartridge"
          },
          "coverColor": {
            "$ref": "#/components/schemas/PrinterCoverColor"
          }
        },
        "additionalProperties": false
      },
      "PrinterModelType": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ModelType"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      },
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "implicit": {
            "authorizationUrl": "https://mangoslabb2c.b2clogin.com/mangoslabb2c.onmicrosoft.com/B2C_1_SignUp_And_SignIn/oauth2/v2.0/authorize",
            "scopes": {
              "https://mangoslabb2c.onmicrosoft.com/4819ddcb-3ceb-4e04-a78d-c8a2150335bc/API.Access/authorize": "authorize"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}