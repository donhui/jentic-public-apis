{
  "openapi": "3.0.3",
  "info": {
    "title": "Kantata OX API",
    "description": "Kantata OX (formerly Mavenlink) is a project collaboration suite that allows you to manage business relationships, share files, and track project activity online. The API provides RESTful access to workspaces, users, time entries, invoices, expenses, and many other resources.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.mavenlink.com/"
  },
  "servers": [
    {
      "url": "https://api.mavenlink.com",
      "description": "Kantata OX API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
