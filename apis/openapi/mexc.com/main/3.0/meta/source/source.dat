          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/tradeFee": {
      "get": {
        "operationId": "getTradeFee",
        "summary": "Get trading fee for a symbol",
        "tags": ["Account"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Trade fee info", "content": { "application/json": { "schema": { "type": "object", "properties": { "symbol": { "type": "string" }, "makerCommission": { "type": "string" }, "takerCommission": { "type": "string" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
