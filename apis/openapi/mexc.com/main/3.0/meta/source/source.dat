{
  "openapi": "3.0.3",
  "info": {
    "title": "MEXC Spot API",
    "version": "3.0",
    "description": "MEXC cryptocurrency exchange Spot API v3. Provides market data, spot trading, account management, sub-account management, and wallet operations for digital asset trading.",
    "x-jentic-source-url": "https://www.mexc.com/api-docs/spot-v3/introduction"
  },
  "servers": [
    {
      "url": "https://api.mexc.com"
    }
  ],
  "paths": {
    "/api/v3/ping": {
      "get": {
        "operationId": "testConnectivity",
        "summary": "Test server connectivity",
        "tags": ["Market Data"],
        "responses": {
          "200": {
            "description": "Server is reachable",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        }
      }
    },
    "/api/v3/time": {
      "get": {
        "operationId": "getServerTime",
        "summary": "Get server time",
        "tags": ["Market Data"],
        "responses": {
          "200": {
            "description": "Server timestamp",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "serverTime": { "type": "integer", "format": "int64" } }
                }
              }
            }
          }
        }
      }
    },
    "/api/v3/defaultSymbols": {
      "get": {
        "operationId": "getDefaultSymbols",
        "summary": "Get default trading symbols",
        "tags": ["Market Data"],
        "responses": {
          "200": {
            "description": "Default symbols list",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "string" } } } }
              }
            }
          }
        }
      }
    },
    "/api/v3/exchangeInfo": {
      "get": {
        "operationId": "getExchangeInfo",
        "summary": "Get exchange trading rules and symbol info",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Trading pair symbol" },
          { "name": "symbols", "in": "query", "required": false, "schema": { "type": "string" }, "description": "Comma-separated symbols" }
        ],
        "responses": {
          "200": {
            "description": "Exchange information",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExchangeInfo" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/depth": {
      "get": {
        "operationId": "getOrderBook",
        "summary": "Get order book depth",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "maximum": 5000 } }
        ],
        "responses": {
          "200": {
            "description": "Order book snapshot",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OrderBook" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/trades": {
      "get": {
        "operationId": "getRecentTrades",
        "summary": "Get recent trades",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "maximum": 1000 } }
        ],
        "responses": {
          "200": {
            "description": "Recent trades list",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Trade" } } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/aggTrades": {
      "get": {
        "operationId": "getAggregatedTrades",
        "summary": "Get aggregated trades",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "startTime", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "endTime", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Aggregated trades",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AggTrade" } } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/klines": {
      "get": {
        "operationId": "getKlines",
        "summary": "Get candlestick/kline data",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "interval", "in": "query", "required": true, "schema": { "type": "string", "enum": ["1m","5m","15m","30m","60m","4h","8h","1d","1W","1M"] } },
          { "name": "startTime", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "endTime", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Kline data",
            "content": { "application/json": { "schema": { "type": "array", "items": { "type": "array", "items": {} } } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/avgPrice": {
      "get": {
        "operationId": "getAveragePrice",
        "summary": "Get current average price",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Average price",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "mins": { "type": "integer" }, "price": { "type": "string" } } } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/ticker/24hr": {
      "get": {
        "operationId": "get24hrTicker",
        "summary": "Get 24-hour price statistics",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "24hr ticker statistics",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Ticker24hr" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/ticker/price": {
      "get": {
        "operationId": "getPriceTicker",
        "summary": "Get latest price ticker",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Price ticker",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PriceTicker" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/ticker/bookTicker": {
      "get": {
        "operationId": "getBookTicker",
        "summary": "Get best bid/ask prices",
        "tags": ["Market Data"],
        "parameters": [
          { "name": "symbol", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Book ticker",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BookTicker" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/order": {
      "post": {
        "operationId": "createOrder",
        "summary": "Place a new order",
        "tags": ["Spot Trading"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "side", "in": "query", "required": true, "schema": { "type": "string", "enum": ["BUY", "SELL"] } },
          { "name": "type", "in": "query", "required": true, "schema": { "type": "string", "enum": ["LIMIT", "MARKET", "LIMIT_MAKER", "IMMEDIATE_OR_CANCEL", "FILL_OR_KILL"] } },
          { "name": "quantity", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "quoteOrderQty", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "price", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "newClientOrderId", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "recvWindow", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Order placed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OrderResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "get": {
        "operationId": "getOrder",
        "summary": "Query an order",
        "tags": ["Spot Trading"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "orderId", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "origClientOrderId", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "recvWindow", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Order details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OrderResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "cancelOrder",
        "summary": "Cancel an order",
        "tags": ["Spot Trading"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "orderId", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "origClientOrderId", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "recvWindow", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Order cancelled", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OrderResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/order/test": {
      "post": {
        "operationId": "testNewOrder",
        "summary": "Test new order creation (no actual order placed)",
        "tags": ["Spot Trading"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "side", "in": "query", "required": true, "schema": { "type": "string", "enum": ["BUY", "SELL"] } },
          { "name": "type", "in": "query", "required": true, "schema": { "type": "string", "enum": ["LIMIT", "MARKET", "LIMIT_MAKER", "IMMEDIATE_OR_CANCEL", "FILL_OR_KILL"] } },
          { "name": "quantity", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "price", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Test passed", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/batchOrders": {
      "post": {
        "operationId": "createBatchOrders",
        "summary": "Place batch orders (max 20)",
        "tags": ["Spot Trading"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "batchOrders", "in": "query", "required": true, "schema": { "type": "string" }, "description": "JSON array of orders (max 20)" },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Batch orders placed", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OrderResponse" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/openOrders": {
      "get": {
        "operationId": "getOpenOrders",
        "summary": "Get current open orders",
        "tags": ["Spot Trading"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "recvWindow", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Open orders", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OrderResponse" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "cancelAllOpenOrders",
        "summary": "Cancel all open orders for symbol(s)",
        "tags": ["Spot Trading"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Up to 5 comma-separated symbols" },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Orders cancelled", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OrderResponse" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/allOrders": {
      "get": {
        "operationId": "getAllOrders",
        "summary": "Get all orders (active, cancelled, filled)",
        "tags": ["Spot Trading"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "startTime", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "endTime", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "maximum": 1000 } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "All orders", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OrderResponse" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/account": {
      "get": {
        "operationId": "getAccountInfo",
        "summary": "Get account information and balances",
        "tags": ["Account"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "recvWindow", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Account info", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AccountInfo" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/myTrades": {
      "get": {
        "operationId": "getMyTrades",
        "summary": "Get account trade history",
        "tags": ["Account"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "symbol", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "orderId", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "startTime", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "endTime", "in": "query", "required": false, "schema": { "type": "integer", "format": "int64" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Trade history", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TradeRecord" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/capital/config/getall": {
      "get": {
        "operationId": "getAllCoinInfo",
        "summary": "Get information for all coins",
        "tags": ["Wallet"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Coin information", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CoinInfo" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v3/capital/withdraw": {
      "post": {
        "operationId": "createWithdrawal",
        "summary": "Submit a withdrawal request",
        "tags": ["Wallet"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "coin", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "address", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "amount", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "netWork", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "memo", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "timestamp", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "signature", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Withdrawal submitted", "content": { "application/json": { "schema": { "type": "object", "properties": { "id": { "type": "string" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "cancelWithdrawal",
        "summary": "Cancel a withdrawal",
