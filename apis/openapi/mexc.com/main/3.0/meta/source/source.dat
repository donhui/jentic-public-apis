        }
      }
    }
  },
  "components": {
    "schemas": {
      "ExchangeInfo": {
        "type": "object",
        "properties": {
          "timezone": { "type": "string" },
          "serverTime": { "type": "integer", "format": "int64" },
          "symbols": { "type": "array", "items": { "$ref": "#/components/schemas/SymbolInfo" } }
        }
      },
      "SymbolInfo": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "status": { "type": "string" },
          "baseAsset": { "type": "string" },
          "baseAssetPrecision": { "type": "integer" },
          "quoteAsset": { "type": "string" },
          "quoteAssetPrecision": { "type": "integer" },
          "orderTypes": { "type": "array", "items": { "type": "string" } },
          "isSpotTradingAllowed": { "type": "boolean" }
        }
      },
      "OrderBook": {
        "type": "object",
        "properties": {
          "lastUpdateId": { "type": "integer", "format": "int64" },
          "bids": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
          "asks": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } }
        }
      },
      "Trade": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "price": { "type": "string" },
          "qty": { "type": "string" },
          "quoteQty": { "type": "string" },
          "time": { "type": "integer", "format": "int64" },
          "isBuyerMaker": { "type": "boolean" },
          "isBestMatch": { "type": "boolean" }
        }
      },
      "AggTrade": {
        "type": "object",
        "properties": {
          "a": { "type": "integer", "description": "Aggregate trade ID" },
          "p": { "type": "string", "description": "Price" },
          "q": { "type": "string", "description": "Quantity" },
          "f": { "type": "integer", "description": "First trade ID" },
          "l": { "type": "integer", "description": "Last trade ID" },
          "T": { "type": "integer", "format": "int64", "description": "Timestamp" },
          "m": { "type": "boolean", "description": "Is buyer maker" },
          "M": { "type": "boolean", "description": "Is best match" }
        }
      },
      "Ticker24hr": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "priceChange": { "type": "string" },
          "priceChangePercent": { "type": "string" },
          "prevClosePrice": { "type": "string" },
          "lastPrice": { "type": "string" },
          "bidPrice": { "type": "string" },
          "bidQty": { "type": "string" },
          "askPrice": { "type": "string" },
          "askQty": { "type": "string" },
          "openPrice": { "type": "string" },
          "highPrice": { "type": "string" },
          "lowPrice": { "type": "string" },
          "volume": { "type": "string" },
          "quoteVolume": { "type": "string" },
          "openTime": { "type": "integer", "format": "int64" },
          "closeTime": { "type": "integer", "format": "int64" },
          "count": { "type": "integer" }
        }
      },
      "PriceTicker": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "price": { "type": "string" }
        }
      },
      "BookTicker": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "bidPrice": { "type": "string" },
          "bidQty": { "type": "string" },
          "askPrice": { "type": "string" },
          "askQty": { "type": "string" }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "orderId": { "type": "string" },
          "orderListId": { "type": "integer" },
          "clientOrderId": { "type": "string" },
          "price": { "type": "string" },
          "origQty": { "type": "string" },
          "executedQty": { "type": "string" },
          "cummulativeQuoteQty": { "type": "string" },
          "status": { "type": "string", "enum": ["NEW", "PARTIALLY_FILLED", "FILLED", "CANCELED", "PENDING_CANCEL", "REJECTED", "EXPIRED"] },
          "type": { "type": "string" },
          "side": { "type": "string", "enum": ["BUY", "SELL"] },
          "time": { "type": "integer", "format": "int64" },
          "updateTime": { "type": "integer", "format": "int64" }
        }
      },
      "AccountInfo": {
        "type": "object",
        "properties": {
          "makerCommission": { "type": "integer" },
          "takerCommission": { "type": "integer" },
          "buyerCommission": { "type": "integer" },
          "sellerCommission": { "type": "integer" },
          "canTrade": { "type": "boolean" },
          "canWithdraw": { "type": "boolean" },
          "canDeposit": { "type": "boolean" },
          "updateTime": { "type": "integer", "format": "int64" },
          "accountType": { "type": "string" },
          "balances": { "type": "array", "items": { "$ref": "#/components/schemas/Balance" } },
          "permissions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Balance": {
        "type": "object",
        "properties": {
          "asset": { "type": "string" },
          "free": { "type": "string" },
          "locked": { "type": "string" }
        }
      },
      "TradeRecord": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "id": { "type": "integer" },
          "orderId": { "type": "string" },
          "price": { "type": "string" },
          "qty": { "type": "string" },
          "quoteQty": { "type": "string" },
          "commission": { "type": "string" },
          "commissionAsset": { "type": "string" },
          "time": { "type": "integer", "format": "int64" },
          "isBuyer": { "type": "boolean" },
          "isMaker": { "type": "boolean" },
          "isBestMatch": { "type": "boolean" }
        }
      },
      "CoinInfo": {
        "type": "object",
        "properties": {
          "coin": { "type": "string" },
          "name": { "type": "string" },
          "networkList": { "type": "array", "items": { "$ref": "#/components/schemas/NetworkInfo" } }
        }
      },
      "NetworkInfo": {
        "type": "object",
        "properties": {
          "coin": { "type": "string" },
          "network": { "type": "string" },
          "isDefault": { "type": "boolean" },
          "depositEnable": { "type": "boolean" },
          "withdrawEnable": { "type": "boolean" },
          "withdrawFee": { "type": "string" },
          "withdrawMin": { "type": "string" },
          "withdrawMax": { "type": "string" }
        }
      },
      "DepositRecord": {
        "type": "object",
        "properties": {
          "amount": { "type": "string" },
          "coin": { "type": "string" },
          "network": { "type": "string" },
          "status": { "type": "integer" },
          "address": { "type": "string" },
          "txId": { "type": "string" },
          "insertTime": { "type": "integer", "format": "int64" },
          "confirmTimes": { "type": "string" }
        }
      },
      "WithdrawRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "amount": { "type": "string" },
          "transactionFee": { "type": "string" },
          "coin": { "type": "string" },
          "status": { "type": "integer" },
          "address": { "type": "string" },
          "txId": { "type": "string" },
          "applyTime": { "type": "string" },
          "network": { "type": "string" }
        }
      },
      "DepositAddress": {
        "type": "object",
        "properties": {
          "coin": { "type": "string" },
          "address": { "type": "string" },
          "tag": { "type": "string" },
          "network": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "msg": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-MEXC-APIKEY",
        "description": "MEXC API key. Signed endpoints also require timestamp and HMAC SHA256 signature query parameters."
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}