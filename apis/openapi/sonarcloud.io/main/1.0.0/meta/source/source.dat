            "schema": {
              "type": "string",
              "example": "2017-10-19 or 2017-10-19T13:00:00+0200"
            }
          },
          {
            "name": "metrics",
            "in": "query",
            "description": "Comma-separated list of metric keys",
            "required": true,
            "schema": {
