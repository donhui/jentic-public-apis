    "/issues/bulk_change": {
      "post": {
        "operationId": "issues_bulk_change",
        "summary": "Bulk change on issues.<br/>Requires authentication.",
        "description": "Bulk change on issues.<br/>Requires authentication.",
        "tags": [
          "issues"
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Insufficient privileges"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "add_tags": {
                    "type": "string",
                    "example": "security,java8",
                    "description": "Add tags"
                  },
                  "assign": {
                    "type": "string",
                    "example": "john.smith",
                    "description": "To assign the list of issues to a specific user (login), or un-assign all the issues"
                  },
                  "comment": {
                    "type": "string",
                    "example": "Here is my comment",
                    "description": "To add a comment to a list of issues"
                  },
                  "do_transition": {
                    "type": "string",
                    "enum": [
                      "confirm",
                      "unconfirm",
                      "reopen",
                      "resolve",
                      "falsepositive",
                      "close",
                      "wontfix",
                      "accept",
                      "resolveasreviewed",
                      "resolveassafe",
                      "resolveasacknowledged",
                      "resetastoreview"
                    ],
                    "example": "reopen",
                    "description": "Transition"
                  },
                  "isFeedback": {
                    "type": "string",
                    "enum": [
                      "true",
                      "false",
                      "yes",
                      "no"
                    ],
                    "default": "false",
                    "example": "false",
                    "description": "Define if the given comment is a feedback"
                  },
                  "issues": {
                    "type": "string",
                    "example": "AU-Tpxb--iU5OvuD2FLy,AU-TpxcA-iU5OvuD2FLz",
                    "description": "Comma-separated list of issue keys"
                  },
                  "remove_tags": {
                    "type": "string",
                    "example": "security,java8",
                    "description": "Remove tags"
                  },
                  "sendNotifications": {
                    "type": "string",
                    "enum": [
                      "true",
                      "false",
                      "yes",
                      "no"
                    ],
                    "default": "false",
                    "description": ""
                  },
                  "set_severity": {
                    "type": "string",
                    "enum": [
                      "INFO",
                      "MINOR",
                      "MAJOR",
                      "CRITICAL",
                      "BLOCKER"
                    ],
                    "example": "BLOCKER",
                    "description": "To change the severity of the list of issues",
                    "deprecated": true
                  },
                  "set_type": {
                    "type": "string",
                    "enum": [
                      "CODE_SMELL",
                      "BUG",
                      "VULNERABILITY",
                      "SECURITY_HOTSPOT"
                    ],
                    "example": "BUG",
                    "description": "To change the type of the list of issues",
                    "deprecated": true
                  }
                },
                "required": [
                  "issues"
                ]
              }
            }
          }
        }
      }
    },
