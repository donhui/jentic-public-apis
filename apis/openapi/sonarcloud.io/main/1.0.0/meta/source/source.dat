                "kubernetes",
                "css",
                "scala",
                "jsp",
                "py",
                "js",
                "plsql",
                "apex",
                "docker",
                "ansible",
                "dart",
                "rust",
                "jcl",
                "java",
                "web",
                "xml",
                "flex",
                "json",
                "ipynb",
                "text",
                "vbnet",
                "azurepipelines",
                "cloudformation",
                "swift",
                "yaml",
                "cpp",
                "c",
                "kotlin",
                "go",
                "rpg",
                "vb",
                "tsql",
                "pli",
                "secrets",
                "ruby",
                "cs",
                "groovy",
                "cobol",
                "shell",
                "php",
                "terraform",
                "azureresourcemanager",
                "abap",
                "objc",
