          },
          {
            "name": "p",
            "in": "query",
            "description": "1-based page number",
            "required": false,
            "schema": {
              "type": "string",
              "default": "1",
              "example": "42"
            }
          },
          {
            "name": "ps",
            "in": "query",
            "description": "Page size. Must be greater than 0 and less or equal than 1000",
            "required": false,
            "schema": {
              "type": "integer",
              "default": "100",
              "example": "20",
              "maximum": 1000
            }
          },
          {
            "name": "pullRequest",
            "in": "query",
            "description": "Pull request id",
            "required": false,
            "schema": {
              "type": "string",
              "example": "5461"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "Filter measures created before the given date (inclusive). <br>Either a date (server timezone) or datetime can be provided",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2017-10-19 or 2017-10-19T13:00:00+0200"
            }
          }
        ]
      }
    },
