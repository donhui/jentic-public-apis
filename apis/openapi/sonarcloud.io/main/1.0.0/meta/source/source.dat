    "/qualitygates/update_condition": {
      "post": {
        "operationId": "qualitygates_update_condition",
        "summary": "Update a condition attached to a quality gate.<br>Requires the 'Administer Quality Gates' permission.",
        "description": "Update a condition attached to a quality gate.<br>Requires the 'Administer Quality Gates' permission. (Deprecated since 16 September, 2025)",
        "tags": [
          "qualitygates"
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Insufficient privileges"
          }
        },
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "error": {
                    "type": "string",
                    "example": "10",
                    "maxLength": 64,
                    "description": "Condition error threshold"
                  },
                  "id": {
                    "type": "string",
                    "example": "10",
                    "description": "Condition ID"
                  },
                  "metric": {
                    "type": "string",
                    "example": "blocker_violations, vulnerabilities, new_code_smells",
                    "description": "Condition metric.<br/> Only metric of the following types are allowed:<ul><li>INT</li><li>MILLISEC</li><li>RATING</li><li>WORK_DUR</li><li>FLOAT</li><li>PERCENT</li><li>LEVEL</li></ul>Following metrics are forbidden:<ul><li>alert_status</li><li>security_hotspots</li><li>new_security_hotspots</li></ul>"
                  },
                  "op": {
                    "type": "string",
                    "enum": [
                      "LT",
                      "GT"
                    ],
                    "example": "GT",
                    "description": "Condition operator:<br/><ul><li>LT = is lower than</li><li>GT = is greater than</li></ul>"
                  },
                  "organization": {
                    "type": "string",
                    "example": "my-org",
                    "description": "Organization key."
                  }
                },
                "required": [
                  "error",
                  "id",
                  "metric",
                  "organization"
                ]
              }
            }
          }
        }
      }
    },
    "/qualityprofiles/activate_rule": {
      "post": {
        "operationId": "qualityprofiles_activate_rule",
        "summary": "Activate a rule on a Quality Profile.<br> Requires one of the following permissions:<ul>  <li>'Administer Quality Profiles'</li>  <li>Edit right on the specified quality profile</li></ul>",
        "description": "Activate a rule on a Quality Profile.<br> Requires one of the following permissions:<ul>  <li>'Administer Quality Profiles'</li>  <li>Edit right on the specified quality profile</li></ul>",
        "tags": [
          "qualityprofiles"
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Insufficient privileges"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string",
                    "example": "AU-Tpxb--iU5OvuD2FLy",
                    "description": "Quality Profile key. Can be obtained through <code>api/qualityprofiles/search</code>"
                  },
                  "params": {
                    "type": "string",
                    "example": "params=key1=v1;key2=v2",
                    "description": "Parameters as semi-colon list of <code>key=value</code>. Ignored if parameter reset is true."
                  },
                  "reset": {
                    "type": "string",
                    "enum": [
                      "true",
                      "false",
                      "yes",
                      "no"
                    ],
                    "description": "Reset severity and parameters of activated rule. Set the values defined on parent profile or from rule default values."
                  },
                  "rule": {
                    "type": "string",
                    "example": "squid:AvoidCycles",
                    "description": "Rule key"
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "INFO",
                      "MINOR",
                      "MAJOR",
                      "CRITICAL",
                      "BLOCKER"
                    ],
                    "description": "Severity. Ignored if parameter reset is true."
                  }
                },
                "required": [
                  "key",
                  "rule"
                ]
              }
            }
          }
        }
      }
    },
    "/qualityprofiles/activate_rules": {
      "post": {
        "operationId": "qualityprofiles_activate_rules",
        "summary": "Bulk-activate rules on one quality profile.<br> Requires one of the following permissions:<ul>  <li>'Administer Quality Profiles'</li>  <li>Edit right on the specified quality profile</li></ul>",
        "description": "Bulk-activate rules on one quality profile.<br> Requires one of the following permissions:<ul>  <li>'Administer Quality Profiles'</li>  <li>Edit right on the specified quality profile</li></ul>",
        "tags": [
          "qualityprofiles"
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Insufficient privileges"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "activation": {
                    "type": "string",
                    "enum": [
                      "true",
                      "false",
                      "yes",
                      "no"
                    ],
                    "description": "Filter rules that are activated or deactivated on the selected Quality profile. Ignored if the parameter 'qprofile' is not set."
                  },
                  "active_severities": {
                    "type": "string",
                    "enum": [
                      "INFO",
                      "MINOR",
                      "MAJOR",
                      "CRITICAL",
                      "BLOCKER"
                    ],
                    "example": "CRITICAL,BLOCKER",
                    "description": "Comma-separated list of activation severities, i.e the severity of rules in Quality profiles."
                  },
                  "asc": {
                    "type": "string",
                    "enum": [
                      "true",
                      "false",
                      "yes",
                      "no"
                    ],
                    "default": "true",
                    "description": "Ascending sort"
                  },
                  "available_since": {
                    "type": "string",
                    "example": "2014-06-22",
                    "description": "Filters rules added since date. Format is yyyy-MM-dd"
                  },
                  "cleanCodeAttributeCategories": {
                    "type": "string",
                    "enum": [
                      "ADAPTABLE",
                      "CONSISTENT",
                      "INTENTIONAL",
                      "RESPONSIBLE"
                    ],
                    "example": "ADAPTABLE,INTENTIONAL",
                    "description": "Comma-separated list of Clean Code Attribute Categories"
                  },
                  "cwe": {
                    "type": "string",
                    "example": "12,125,unknown",
                    "description": "Comma-separated list of CWE identifiers. Use 'unknown' to select rules not associated to any CWE."
                  },
                  "impactSeverities": {
                    "type": "string",
                    "enum": [
                      "INFO",
                      "LOW",
                      "MEDIUM",
                      "HIGH",
                      "BLOCKER"
                    ],
                    "example": "HIGH,MEDIUM",
                    "description": "Comma-separated list of Software Quality Severities"
                  },
                  "impactSoftwareQualities": {
                    "type": "string",
                    "enum": [
                      "MAINTAINABILITY",
                      "RELIABILITY",
                      "SECURITY"
                    ],
                    "example": "MAINTAINABILITY,RELIABILITY",
                    "description": "Comma-separated list of Software Qualities"
                  },
                  "inheritance": {
                    "type": "string",
                    "enum": [
                      "NONE",
                      "INHERITED",
                      "OVERRIDES"
                    ],
                    "example": "INHERITED,OVERRIDES",
                    "description": "Comma-separated list of values of inheritance for a rule within a quality profile. Used only if the parameter 'activation' is set."
                  },
                  "is_template": {
                    "type": "string",
                    "enum": [
                      "true",
                      "false",
                      "yes",
                      "no"
                    ],
                    "description": "Filter template rules"
                  },
                  "languages": {
                    "type": "string",
                    "example": "java,js",
                    "description": "Comma-separated list of languages"
                  },
                  "organization": {
                    "type": "string",
                    "example": "my-org",
                    "description": "Organization key"
                  },
                  "owaspMobileTop10-2024": {
                    "type": "string",
                    "enum": [
                      "m1",
                      "m2",
                      "m3",
                      "m4",
                      "m5",
                      "m6",
                      "m7",
                      "m8",
                      "m9",
                      "m10"
                    ],
                    "description": "Comma-separated list of OWASP Mobile Top 10 (2024) lowercase categories."
                  },
                  "owaspTop10": {
                    "type": "string",
                    "enum": [
                      "a1",
                      "a2",
                      "a3",
                      "a4",
                      "a5",
                      "a6",
                      "a7",
                      "a8",
                      "a9",
                      "a10"
                    ],
                    "description": "Comma-separated list of OWASP Top 10 lowercase categories."
                  },
                  "owaspTop10-2021": {
                    "type": "string",
                    "enum": [
                      "a1",
                      "a2",
                      "a3",
                      "a4",
                      "a5",
                      "a6",
                      "a7",
                      "a8",
                      "a9",
                      "a10"
                    ],
                    "description": "Comma-separated list of OWASP Top 10 (2021) lowercase categories."
                  },
                  "q": {
                    "type": "string",
                    "example": "xpath",
                    "description": "UTF-8 search query"
                  },
                  "qprofile": {
                    "type": "string",
                    "example": "AU-Tpxb--iU5OvuD2FLy",
                    "description": "Quality profile key to filter on. Used only if the parameter 'activation' is set."
                  },
                  "repositories": {
                    "type": "string",
                    "example": "checkstyle,findbugs",
                    "description": "Comma-separated list of repositories"
                  },
                  "rule_key": {
                    "type": "string",
                    "example": "squid:S001",
                    "description": "Key of rule to search for"
                  },
                  "s": {
                    "type": "string",
                    "enum": [
                      "name",
                      "updatedAt",
                      "createdAt",
                      "key"
                    ],
                    "example": "name",
                    "description": "Sort field"
                  },
                  "severities": {
                    "type": "string",
                    "enum": [
                      "INFO",
                      "MINOR",
                      "MAJOR",
                      "CRITICAL",
                      "BLOCKER"
                    ],
                    "example": "CRITICAL,BLOCKER",
                    "description": "Comma-separated list of default severities. Not the same than severity of rules in Quality profiles."
                  },
                  "sonarsourceSecurity": {
                    "type": "string",
                    "enum": [
                      "buffer-overflow",
                      "permission",
                      "sql-injection",
                      "command-injection",
                      "path-traversal-injection",
                      "ldap-injection",
                      "xpath-injection",
                      "rce",
                      "dos",
                      "ssrf",
                      "csrf",
                      "xss",
                      "log-injection",
                      "http-response-splitting",
                      "open-redirect",
                      "xxe",
                      "object-injection",
                      "weak-cryptography",
                      "auth",
                      "insecure-conf",
                      "encrypt-data",
                      "traceability",
                      "file-manipulation",
                      "others"
                    ],
                    "example": "sql-injection,command-injection,others",
                    "description": "Comma-separated list of SonarSource security categories. Use 'others' to select rules not associated with any category"
                  },
                  "statuses": {
                    "type": "string",
                    "enum": [
                      "BETA",
                      "DEPRECATED",
                      "READY",
                      "REMOVED"
                    ],
                    "example": "READY",
                    "description": "Comma-separated list of status codes"
                  },
                  "tags": {
                    "type": "string",
                    "example": "security,java8",
                    "description": "Comma-separated list of tags. Returned rules match any of the tags (OR operator)"
                  },
                  "targetKey": {
                    "type": "string",
                    "example": "AU-TpxcA-iU5OvuD2FL0",
                    "description": "Quality Profile key on which the rule activation is done. To retrieve a quality profile key please see <code>api/qualityprofiles/search</code>"
                  },
                  "targetSeverity": {
                    "type": "string",
                    "enum": [
                      "INFO",
                      "MINOR",
                      "MAJOR",
                      "CRITICAL",
                      "BLOCKER"
                    ],
                    "description": "Severity to set on the activated rules"
                  },
                  "template_key": {
                    "type": "string",
                    "example": "java:S001",
                    "description": "Key of the template rule to filter on. Used to search for the custom rules based on this template."
                  },
                  "types": {
                    "type": "string",
                    "enum": [
                      "CODE_SMELL",
                      "BUG",
                      "VULNERABILITY",
                      "SECURITY_HOTSPOT"
                    ],
                    "example": "BUG",
                    "description": "Comma-separated list of types. Returned rules match any of the tags (OR operator)"
                  }
                },
                "required": [
                  "targetKey"
                ]
              }
            }
          }
        }
      }
    },
    "/qualityprofiles/add_project": {
      "post": {
        "operationId": "qualityprofiles_add_project",
        "summary": "Associate a project with a quality profile.<br> Requires one of the following permissions:<ul>  <li>'Administer Quality Profiles'</li>  <li>Edit right on the specified quality profile</li>  <li>Administer right on the specified project</li></ul>",
        "description": "Associate a project with a quality profile.<br> Requires one of the following permissions:<ul>  <li>'Administer Quality Profiles'</li>  <li>Edit right on the specified quality profile</li>  <li>Administer right on the specified project</li></ul>",
