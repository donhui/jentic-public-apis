    "/permissions/add_group": {
      "post": {
        "operationId": "permissions_add_group",
        "summary": "Add permission to a group.<br /> This service defaults to global permissions, but can be limited to project permissions by providing project id or project key.<br /> The group name or group id must be provided. <br />Requires the permission 'Administer' on the specified project.",
        "description": "Add permission to a group.<br /> This service defaults to global permissions, but can be limited to project permissions by providing project id or project key.<br /> The group name or group id must be provided. <br />Requires the permission 'Administer' on the specified project.",
        "tags": [
          "permissions"
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Insufficient privileges"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "groupId": {
                    "type": "string",
                    "example": "42",
                    "description": "Group id (deprecated). Use 'groupName' and 'organization' instead.",
                    "deprecated": true
                  },
                  "groupName": {
                    "type": "string",
                    "example": "sonar-administrators",
                    "description": "Group name or 'anyone' (case insensitive)"
                  },
                  "organization": {
                    "type": "string",
                    "example": "my-org",
                    "description": "Key of organization, used when group name is set"
                  },
                  "permission": {
                    "type": "string",
                    "description": "Permission<ul><li>Possible values for global permissions: admin, profileadmin, gateadmin, scan, provisioning</li><li>Possible values for project permissions admin, codeviewer, issueadmin, securityhotspotadmin, architectureadmin, scan, user</li></ul>"
                  },
                  "projectId": {
                    "type": "string",
                    "example": "ce4c03d6-430f-40a9-b777-ad877c00aa4d",
                    "description": "Project id"
                  },
                  "projectKey": {
                    "type": "string",
                    "example": "my_project",
                    "description": "Project key"
                  }
                },
                "required": [
                  "permission"
                ]
              }
            }
          }
        }
      }
    },
