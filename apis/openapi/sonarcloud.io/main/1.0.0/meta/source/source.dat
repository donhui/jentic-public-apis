                "properties": {
                  "comment": {
                    "type": "string",
                    "example": "Won't fix because it doesn't apply to the context",
                    "description": "Comment text"
                  },
                  "isFeedback": {
                    "type": "string",
                    "enum": [
                      "true",
                      "false",
                      "yes",
                      "no"
                    ],
                    "default": "false",
                    "description": "Define is the given comment is a feedback"
                  },
                  "issue": {
                    "type": "string",
                    "example": "AU-Tpxb--iU5OvuD2FLy",
                    "description": "Issue key"
                  },
                  "transition": {
                    "type": "string",
                    "enum": [
                      "confirm",
                      "unconfirm",
                      "reopen",
                      "resolve",
                      "falsepositive",
                      "close",
                      "wontfix",
                      "accept",
                      "resolveasreviewed",
                      "resolveassafe",
                      "resolveasacknowledged",
                      "resetastoreview"
