                    "maxLength": 512,
                    "description": "new url to be called by the webhook"
                  },
                  "webhook": {
                    "type": "string",
                    "example": "my_project",
                    "maxLength": 40,
                    "description": "The key of the webhook to be updated, auto-generated value can be obtained through api/webhooks/create or api/webhooks/list"
                  }
                },
                "required": [
                  "name",
                  "url",
                  "webhook"
                ]
              }
            }
          }
        }
      }
    },
