              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/preGuestLogin": {
      "get": {
        "operationId": "preGuestLogin",
        "summary": "Generate guest validation UUID",
        "description": "Generate a temporary validation UUID for guest access.",
        "tags": ["Guest Access"],
        "parameters": [
          {
            "name": "Mi-Customer-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Mi-Ext-Application-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "patient",
            "in": "query",
            "required": true,
            "description": "Patient identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "company",
            "in": "query",
            "required": true,
            "description": "Company identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Temporary validation UUID generated",
            "content": {
              "application/json": {
                "schema": {
