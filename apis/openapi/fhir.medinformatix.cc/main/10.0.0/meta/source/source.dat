    "/arvrequest/schedule": {
      "get": {
        "operationId": "getArvRequestSchedule",
        "summary": "Get available appointment slots",
        "description": "Get available appointment slots for a referral request.",
        "tags": ["Scheduling"],
        "parameters": [
          {
            "name": "Mi-Customer-Id",
