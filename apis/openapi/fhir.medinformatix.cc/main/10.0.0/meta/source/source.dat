                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid verification code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/completeRegistrationStrict": {
      "post": {
        "operationId": "completeRegistration",
