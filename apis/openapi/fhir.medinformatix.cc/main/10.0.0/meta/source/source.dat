{
  "openapi": "3.0.3",
  "info": {
    "title": "MedInformatix HL7 FHIR API",
    "description": "MedInformatix HL7 FHIR API providing access to clinical data, user management, scheduling, and FHIR resources for healthcare applications.",
    "version": "10.0.0",
    "x-jentic-source-url": "https://www.medinformatix.com/ONC/API.html"
  },
  "servers": [
    {
      "url": "https://fhir.medinformatix.co/v10",
      "description": "Production server"
    },
    {
      "url": "https://fhir-staging.medinformatix.cc/v10",
      "description": "Staging server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/users/login": {
      "post": {
        "operationId": "loginUser",
        "summary": "Authenticate user",
        "description": "Authenticate user and receive a JWT token with a 1-hour expiry.",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "Mi-Customer-Id",
            "in": "header",
            "required": true,
            "description": "Customer identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Mi-Ext-Application-Id",
            "in": "header",
            "required": true,
            "description": "External application identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid credentials format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/logout": {
      "post": {
        "operationId": "logoutUser",
        "summary": "Invalidate bearer token",
        "description": "Invalidate the current bearer token to log out the user.",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "Mi-Customer-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Mi-Ext-Application-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Logout successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/renew": {
      "post": {
        "operationId": "renewToken",
        "summary": "Renew bearer token",
        "description": "Request a new bearer token with 60-minute validity.",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "Mi-Customer-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Mi-Ext-Application-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token renewed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "post": {
        "operationId": "registerUser",
        "summary": "Register new user",
        "description": "Register a new user in AWS Cognito. An SMS confirmation code will be sent.",
        "tags": ["User Management"],
        "security": [],
        "parameters": [
          {
            "name": "Mi-Customer-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
