    "/metadata": {
      "get": {
        "operationId": "getCapabilityStatement",
        "summary": "Get FHIR capability statement",
        "description": "Retrieve the FHIR CapabilityStatement describing supported resources and interactions.",
        "tags": ["System"],
        "security": [],
        "parameters": [
          {
            "name": "Mi-Customer-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Mi-Ext-Application-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "FHIR CapabilityStatement",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/FhirBundle"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT bearer token with 1-hour expiry obtained from /users/login"
      },
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for guest access endpoints"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "User phone number"
          },
          "password": {
            "type": "string",
            "description": "User password"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT bearer token"
          },
          "expiresIn": {
            "type": "integer",
            "description": "Token expiry time in seconds"
          },
          "tokenType": {
            "type": "string",
            "description": "Type of token (Bearer)"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Granted scopes"
          },
          "patient": {
            "type": "object",
            "description": "Patient information"
          }
        }
      },
      "RegisterUserRequest": {
        "type": "object",
        "required": ["username"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Phone number with country code"
          }
        }
      },
      "RegisterUserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "username": {
            "type": "string",
            "description": "Username"
          }
        }
      },
      "DeleteUserRequest": {
        "type": "object",
        "required": ["username", "customerId"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Username to delete"
          },
          "customerId": {
            "type": "string",
            "description": "Customer identifier"
          }
        }
      },
      "VerifyUserRequest": {
        "type": "object",
        "required": ["username", "code"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Username"
          },
          "code": {
            "type": "string",
            "description": "SMS verification code"
          }
        }
      },
      "CompleteRegistrationRequest": {
        "type": "object",
        "required": ["lastName", "firstName", "password", "phone", "dob", "id"],
        "properties": {
          "lastName": {
            "type": "string",
            "description": "Last name"
          },
          "firstName": {
            "type": "string",
            "description": "First name"
          },
          "password": {
            "type": "string",
            "description": "User password"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "dob": {
            "type": "string",
            "description": "Date of birth"
          },
          "id": {
            "type": "string",
            "description": "User identifier"
          }
        }
      },
      "PasswordResetRequest": {
        "type": "object",
        "required": ["username", "customerId"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Username"
          },
          "customerId": {
            "type": "string",
            "description": "Customer identifier"
          }
        }
      },
      "CompleteForgotPasswordRequest": {
        "type": "object",
        "required": ["username", "code", "newPassword"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Username"
          },
          "code": {
            "type": "string",
            "description": "Verification code"
          },
          "newPassword": {
            "type": "string",
            "description": "New password"
          }
        }
      },
      "GuestPhoneVerificationRequest": {
        "type": "object",
        "required": ["phone"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Phone number in E.164 format"
          }
        }
      },
      "CompleteGuestLoginRequest": {
        "type": "object",
        "required": ["phone", "code", "patientId", "company"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "code": {
            "type": "string",
            "description": "SMS verification code"
          },
          "patientId": {
            "type": "string",
            "description": "Patient identifier"
          },
          "company": {
            "type": "string",
            "description": "Company identifier"
          }
        }
      },
      "PreGuestLoginResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Temporary validation UUID"
          }
        }
      },
      "IsRegisteredRequest": {
        "type": "object",
        "required": ["customerId", "account", "company"],
        "properties": {
          "customerId": {
            "type": "string",
            "description": "Customer identifier"
          },
          "account": {
            "type": "string",
            "description": "Account identifier"
          },
          "company": {
            "type": "string",
            "description": "Company identifier"
          }
        }
      },
      "IsRegisteredResponse": {
        "type": "object",
        "properties": {
          "isRegistered": {
            "type": "boolean",
            "description": "Whether the user is registered"
          }
        }
      },
      "PatchHistoryEvent": {
        "type": "object",
        "properties": {
          "event_date": {
            "type": "string",
            "description": "Date of the event"
          },
          "event_desc": {
            "type": "string",
            "description": "Description of the event"
          },
          "event": {
            "type": "string",
            "description": "Event name"
          }
        }
      },
      "ArvRequestResponse": {
        "type": "object",
        "properties": {
          "company": {
            "type": "string",
            "description": "Company identifier"
          },
          "account": {
            "type": "string",
            "description": "Account identifier"
          },
          "requests": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "Request details"
            },
            "description": "Array of pending requests"
          }
        }
      },
      "FhirBundle": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string",
            "description": "FHIR resource type (Bundle)"
          },
          "type": {
            "type": "string",
            "description": "Bundle type (e.g., searchset)"
          },
          "total": {
            "type": "integer",
            "description": "Total number of resources"
          },
          "entry": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "resource": {
                  "type": "object",
                  "description": "FHIR resource"
                }
              }
            },
            "description": "Array of bundle entries"
          }
        }
      },
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Success message"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      }
    }
  }
}