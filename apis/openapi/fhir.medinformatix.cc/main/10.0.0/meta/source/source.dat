    "/AllergyIntolerance": {
      "get": {
        "operationId": "getAllergyIntolerances",
        "summary": "Get allergy and intolerance records",
        "description": "Retrieve allergies and intolerances for a patient as a FHIR Bundle.",
        "tags": ["Clinical Data"],
        "parameters": [
          {
            "name": "Mi-Customer-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
