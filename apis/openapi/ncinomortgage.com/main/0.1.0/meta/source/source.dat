{
  "openapi": "3.0.3",
  "info": {
    "title": "SimpleNexus API (SNAPI)",
    "description": "The SimpleNexus API (SNAPI) by nCino Mortgage provides programmatic access to mortgage lending operations including borrowers, loan applications, loans, loan officers, reports, and webhooks.",
    "version": "0.1.0",
    "x-jentic-source-url": "https://developer.ncinomortgage.com/mortgage/v0-SNAPI/docs/getting-started"
  },
  "servers": [
    {
      "url": "https://api.simplenexus.com/sn_api/v1",
      "description": "SimpleNexus API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/borrowers": {
      "get": {
        "operationId": "listBorrowers",
        "summary": "List all borrowers",
        "description": "Retrieve a list of all borrowers.",
        "tags": ["Borrowers"],
        "responses": {
          "200": {
            "description": "List of borrowers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "borrowers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Borrower"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createBorrower",
        "summary": "Create a borrower",
        "description": "Create a new borrower record.",
        "tags": ["Borrowers"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBorrowerRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Borrower created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Borrower"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/borrowers/{borrower_id}": {
      "get": {
        "operationId": "getBorrower",
        "summary": "Get individual borrower",
        "description": "Retrieve a specific borrower by ID.",
        "tags": ["Borrowers"],
        "parameters": [
          {
            "name": "borrower_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Borrower identifier."
          }
        ],
        "responses": {
          "200": {
            "description": "Borrower details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Borrower"
                }
              }
            }
          },
          "404": {
            "description": "Borrower not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteBorrower",
        "summary": "Delete a borrower",
        "description": "Remove a borrower record.",
        "tags": ["Borrowers"],
        "parameters": [
          {
            "name": "borrower_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Borrower identifier."
          }
        ],
        "responses": {
          "200": {
            "description": "Borrower deleted"
          },
          "404": {
            "description": "Borrower not found"
          }
        }
      }
    },
