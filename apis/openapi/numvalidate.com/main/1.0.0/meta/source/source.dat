{
  "openapi": "3.0.3",
  "info": {
    "title": "NumValidate Phone Number Validation API",
    "version": "1.0.0",
    "description": "NumValidate REST API for validating phone numbers and listing supported countries.",
    "x-jentic-source-url": "https://numvalidate.com/numvalidate-docs/index.html"
  },
  "servers": [
    {
      "url": "https://numvalidate.com/api"
    }
  ],
  "paths": {
    "/validate": {
      "get": {
        "operationId": "validatePhoneNumber",
        "summary": "Validate a phone number",
        "tags": ["Validation"],
        "parameters": [
          {
            "name": "number",
            "in": "query",
            "required": true,
            "description": "The phone number to validate",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "countryCode",
            "in": "query",
            "required": false,
            "description": "2-digit country code for local numbers",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful validation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          }
        }
      }
    },
    "/countries": {
      "get": {
        "operationId": "listSupportedCountries",
        "summary": "List supported countries",
        "tags": ["Countries"],
        "responses": {
          "200": {
            "description": "List of supported countries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountriesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ValidationResponse": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "boolean",
            "description": "Indicates number validity"
          },
          "number": {
            "type": "string",
            "description": "Input number provided"
          },
          "e164Format": {
            "type": "string",
            "description": "E.164 formatted number"
          },
          "internationalFormat": {
            "type": "string",
            "description": "International format"
          },
          "nationalFormat": {
            "type": "string",
            "description": "National/local format"
          },
          "countryCode": {
            "type": "string",
            "description": "Country code"
          },
          "countryPrefix": {
            "type": "string",
            "description": "Dialing code"
          },
          "countryName": {
            "type": "string",
            "description": "Country name"
          }
        }
      },
      "CountriesResponse": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "country_name": {
              "type": "string",
              "description": "Full country name"
            },
            "dialling_code": {
              "type": "string",
              "description": "International dialing code"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-token"
      }
    }
  },
  "security": [
    {
      "apiToken": []
    }
  ]
}