          "doctor_id"
        ],
        "properties": {
          "access_token": {
            "type": "string",
            "example": "sookie"
          },
          "doctor_id": {
            "description": "Unique Id of the doctor",
            "type": "integer",
            "format": "int32",
            "example": 3088
          }
        }
      },
      "add_alternate_email": {
