      "name": "Search",
      "description": "Search for electronic parts and components"
    },
    {
      "name": "Parts",
      "description": "Retrieve detailed part information"
    },
    {
      "name": "Categories",
      "description": "Browse and search part categories"
    },
    {
      "name": "Sellers",
      "description": "Seller and distributor information"
    },
    {
      "name": "Brands",
      "description": "Manufacturer brand information"
    }
  ]
}