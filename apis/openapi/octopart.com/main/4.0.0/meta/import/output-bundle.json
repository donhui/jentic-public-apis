{
  "openapi": "3.0.3",
  "info": {
    "title": "Octopart API",
    "description": "Electronic part data API for manufacturing, design, and sourcing. Octopart provides a GraphQL API (v4) for searching and retrieving electronic component data including parts, categories, sellers, pricing, datasheets, and specifications.",
    "version": "4.0.0",
    "contact": {
      "name": "Octopart",
      "url": "https://octopart.com"
    },
    "x-jentic-source-url": "https://octopart.com/api/v4/reference"
  },
  "servers": [
    {
      "url": "https://octopart.com/api/v4",
      "description": "Octopart API v4 Production Server"
    }
  ],
  "paths": {
    "/endpoint": {
      "post": {
        "operationId": "graphqlQuery",
        "summary": "Execute GraphQL Query",
        "description": "Execute a GraphQL query against the Octopart API v4. Supports queries for parts search, part details, categories, sellers, brands, and more.",
        "tags": [
          "Search",
          "Parts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GraphQLRequest"
              },
              "examples": {
                "searchParts": {
                  "summary": "Search for parts by keyword",
                  "value": {
                    "query": "query { search(q: \"ESP32\", limit: 10) { hits total results { part { id name mpn manufacturer { name } short_description best_image { url } median_price_1000 { price currency } specs { attribute { name } display_value } } } } }",
                    "variables": {}
                  }
                },
                "partDetails": {
                  "summary": "Get part details by MPN",
                  "value": {
                    "query": "query ($mpn: String!) { search(q: $mpn, limit: 1) { results { part { id name mpn manufacturer { name } descriptions { text } datasheets { url } specs { attribute { name shortname units } display_value } sellers { company { name homepage_url } offers { sku moq prices { quantity price currency } stock_level factory_lead_days } } } } } }",
                    "variables": {
                      "mpn": "ATmega328P"
                    }
                  }
                },
                "categorySearch": {
                  "summary": "Browse categories",
                  "value": {
                    "query": "query { categories(ids: [\"1\"], include_ancestors: true) { id name parent_id path num_parts children { id name num_parts } } }",
                    "variables": {}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful GraphQL response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphQLResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid GraphQL query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/parts/search": {
      "get": {
        "operationId": "searchParts",
        "summary": "Search Parts",
        "description": "Search for electronic parts by keyword, MPN, or other criteria. Returns matching parts with pricing, availability, and specification data.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query string (part number, keyword, or description)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Result offset for pagination",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          },
          {
            "name": "sortby",
            "in": "query",
            "description": "Sort order for results",
            "schema": {
              "type": "string",
              "enum": [
                "score",
                "avg_price",
                "median_price_1000"
              ]
            }
          },
          {
            "name": "filter[fields][manufacturer.name][]",
            "in": "query",
            "description": "Filter by manufacturer name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[fields][category.id][]",
            "in": "query",
            "description": "Filter by category ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PartsSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/parts/{id}": {
      "get": {
        "operationId": "getPartById",
        "summary": "Get Part Details",
        "description": "Retrieve detailed information about a specific electronic part by its Octopart ID.",
        "tags": [
          "Parts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Octopart part ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include[]",
            "in": "query",
            "description": "Additional data to include",
            "schema": {
              "type": "string",
              "enum": [
                "specs",
                "descriptions",
                "datasheets",
                "imagesets",
                "compliance",
                "sellers"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Part details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Part"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Part not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/parts/match": {
      "post": {
        "operationId": "matchParts",
        "summary": "Match Parts by MPN",
        "description": "Match electronic parts by manufacturer part number (MPN) and optional manufacturer name. Supports batch matching of multiple parts.",
        "tags": [
          "Parts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MatchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Match results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/categories": {
      "get": {
        "operationId": "getCategories",
        "summary": "Get Categories",
        "description": "Retrieve electronic part categories. Can be used to browse the category tree.",
        "tags": [
          "Categories"
        ],
        "parameters": [
          {
            "name": "id[]",
            "in": "query",
            "description": "Category IDs to retrieve",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "parent_id",
            "in": "query",
            "description": "Filter by parent category ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Categories list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoriesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/rest/v1/sellers": {
      "get": {
        "operationId": "getSellers",
        "summary": "Get Sellers",
        "description": "Retrieve information about authorized sellers and distributors.",
        "tags": [
          "Sellers"
        ],
        "parameters": [
          {
            "name": "id[]",
            "in": "query",
            "description": "Seller IDs to retrieve",
            "schema": {
              "type": "array",
