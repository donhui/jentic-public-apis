            }
          }
        }
      },
      "Offer": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "moq": {
            "type": "integer"
          },
          "stock_level": {
            "type": "integer"
          },
          "factory_lead_days": {
            "type": "integer"
          },
          "in_stock_quantity": {
            "type": "integer"
          },
          "on_order_quantity": {
            "type": "integer"
          },
          "prices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PriceBreak"
            }
          },
          "product_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "PriceBreak": {
        "type": "object",
        "properties": {
          "quantity": {
            "type": "integer"
          },
          "price": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "Price": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "Image": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "credit_string": {
            "type": "string"
          },
          "credit_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "parent_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "num_parts": {
            "type": "integer"
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            }
          }
        }
      },
      "CategoriesResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            }
          }
        }
      },
      "SellersResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "homepage_url": {
                  "type": "string",
                  "format": "uri"
                },
                "is_authorized": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "BrandsResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Manufacturer"
            }
          }
        }
      },
      "MatchRequest": {
        "type": "object",
        "required": [
          "queries"
        ],
        "properties": {
          "queries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "mpn"
              ],
              "properties": {
                "mpn": {
                  "type": "string",
                  "description": "Manufacturer part number"
                },
                "manufacturer": {
                  "type": "string",
                  "description": "Manufacturer name"
                },
                "sku": {
                  "type": "string",
                  "description": "Seller SKU"
                },
                "seller": {
                  "type": "string",
                  "description": "Seller name"
                }
              }
            }
          }
        }
      },
      "MatchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "hits": {
                  "type": "integer"
                },
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Part"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
