    "/servers/{serverId}/php/cli": {
      "patch": {
        "operationId": "changePhpCliVersion",
        "summary": "Change PHP-CLI version",
        "tags": [
          "Servers"
        ],
        "parameters": [
          {
            "name": "serverId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phpVersion": {
                    "type": "string"
                  }
                },
                "required": [
                  "phpVersion"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PHP CLI version changed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Server"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/servers/{serverId}/webapps/custom": {
