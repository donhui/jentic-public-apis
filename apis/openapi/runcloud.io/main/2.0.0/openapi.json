  "components": {
    "schemas": {
      "Server": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "ipAddress": {
            "type": "string"
          },
          "os": {
            "type": "string"
          },
          "osVersion": {
            "type": "string",
            "nullable": true
          },
          "connected": {
            "type": "boolean"
          },
          "online": {
            "type": "boolean"
          },
          "agentVersion": {
            "type": "string",
            "nullable": true
          },
          "phpCLIVersion": {
            "type": "string"
          },
          "softwareUpdate": {
            "type": "boolean"
          },
          "securityUpdate": {
            "type": "boolean"
          },
          "transferStatus": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ServerListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Server"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "CreateServerRequest": {
        "type": "object",
        "required": [
          "name",
          "ipAddress"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ipAddress": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          }
        }
      },
      "ServerStats": {
        "type": "object",
        "properties": {
          "stats": {
            "type": "object",
            "properties": {
              "webApplication": {
                "type": "integer"
              },
              "database": {
                "type": "integer"
              },
              "cronJob": {
                "type": "integer"
              },
              "supervisor": {
                "type": "integer"
              }
            }
          },
          "geoRecord": {
            "type": "object",
            "properties": {
              "country": {
                "type": "string"
              },
              "subdivision": {
                "type": "string"
              },
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              }
            }
          }
        }
      },
      "HardwareInfo": {
        "type": "object",
        "properties": {
          "kernelVersion": {
            "type": "string"
          },
          "processorName": {
            "type": "string"
          },
          "totalCPUCore": {
            "type": "integer"
          },
          "totalMemory": {
            "type": "number"
          },
          "freeMemory": {
            "type": "number"
          },
          "diskTotal": {
            "type": "number"
          },
          "diskFree": {
            "type": "number"
          },
          "loadAvg": {
            "type": "number"
          },
          "uptime": {
            "type": "string"
          }
        }
      },
      "WebApp": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "server_user_id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "rootPath": {
            "type": "string"
          },
          "publicPath": {
            "type": "string"
          },
          "phpVersion": {
            "type": "string"
          },
          "stack": {
            "type": "string"
          },
          "stackMode": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "defaultApp": {
            "type": "boolean"
          },
          "alias": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WebAppListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WebApp"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "CreateWebAppRequest": {
        "type": "object",
        "required": [
          "name",
          "domainName",
          "user",
          "phpVersion",
          "stack",
          "stackMode",
          "clickjackingProtection",
          "xssProtection",
          "mimeSniffingProtection",
          "processManager",
          "processManagerMaxChildren",
          "processManagerMaxRequests",
          "timezone",
          "maxExecutionTime",
          "maxInputTime",
          "maxInputVars",
          "memoryLimit",
          "postMaxSize",
          "uploadMaxFilesize",
          "sessionGcMaxlifetime",
          "allowUrlFopen"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "domainName": {
            "type": "string"
          },
          "user": {
            "type": "integer"
          },
          "publicPath": {
            "type": "string",
            "nullable": true
          },
          "phpVersion": {
            "type": "string"
          },
          "stack": {
            "type": "string",
            "enum": [
              "hybrid",
              "nativenginx",
              "customnginx"
            ]
          },
          "stackMode": {
            "type": "string",
            "enum": [
              "production",
              "development"
            ]
          },
          "clickjackingProtection": {
            "type": "boolean"
          },
          "xssProtection": {
            "type": "boolean"
          },
          "mimeSniffingProtection": {
            "type": "boolean"
          },
          "processManager": {
            "type": "string",
            "enum": [
              "dynamic",
              "ondemand",
              "static"
            ]
          },
          "processManagerMaxChildren": {
            "type": "integer"
          },
          "processManagerMaxRequests": {
            "type": "integer"
          },
          "timezone": {
            "type": "string"
          },
          "maxExecutionTime": {
            "type": "integer"
          },
          "maxInputTime": {
            "type": "integer"
          },
          "maxInputVars": {
            "type": "integer"
          },
          "memoryLimit": {
            "type": "integer"
          },
          "postMaxSize": {
            "type": "integer"
          },
          "uploadMaxFilesize": {
            "type": "integer"
          },
          "sessionGcMaxlifetime": {
            "type": "integer"
          },
          "allowUrlFopen": {
            "type": "boolean"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "pagination": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              },
              "count": {
                "type": "integer"
              },
              "per_page": {
                "type": "integer"
              },
              "current_page": {
                "type": "integer"
              },
              "total_pages": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error message"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic Authentication using API Key and API Secret"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ]
}