{
  "openapi": "3.0.0",
  "info": {
    "version": "10.77.1",
    "title": "AuthorizationsCreate",
    "description": "Common AuthorizationsCreate API.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Zipari-Core-Services/AuthorizationsCreate/10.77.1/swagger.json"
  },
  "paths": {
    "/authorizations/": {
      "post": {
        "tags": [
          "authorization maintenance"
        ],
        "operationId": "authorizations_create",
        "description": "This API is used to create a Authorization request.",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/AcceptHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/AuthorizationHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/ContentTypeHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/RefererHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/UserAgentHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/ForwardedForHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/UserNameHeader/10.0.1#/components/parameters/UserNameHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/WebSessionIdHeader/10.0.1#/components/parameters/WebSessionIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/CorrelationIdHeader/10.0.1#/components/parameters/CorrelationIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/IdentitiesHeader/10.0.3#/components/parameters/IdentitiesHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "authorization_request": {
                    "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/AuthorizationModel/10.76.1#/components/schemas/Authorization"
                  },
                  "request_type": {
                    "description": "This is type of request. This will indicate whether the request is for review only or final submission. review - This is for reviewing the authorization only. No data is stored. In case of error, 400 response is expected, otherwise return 204 with no content. submit - This is for final submission of the authorization request. For realtime response use 201, for async response use 202, for error use 400",
                    "type": "string",
                    "enum": [
                      "review",
                      "submit"
                    ],
                    "example": "review"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successfully posted the Authorization data to the payer system. Returns Authorization object with created IDs, status etc.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/AuthorizationModel/10.76.1#/components/schemas/Authorization"
                }
              }
            }
          },
          "202": {
            "description": "Authorization data sent and will be processed asynchronously.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ConfirmationResponseModel/10.2.1#/components/schemas/ConfirmationResponse"
                }
              }
            }
          },
          "204": {
            "description": "This response will be sent back when Payer reviews the Authorization request and does not find any error. This is used in the scenario where there is business validation on Payer end before Providers can submit the Authorization requests."
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  }
}