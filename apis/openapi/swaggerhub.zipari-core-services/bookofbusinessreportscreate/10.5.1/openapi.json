{
  "openapi": "3.0.0",
  "info": {
    "version": "10.5.1",
    "title": "BookOfBusinessReportsCreate",
    "description": "Common BookOfBusinessReports API",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Zipari-Core-Services/BookOfBusinessReportsCreate/10.5.1/swagger.json"
  },
  "paths": {
    "/book-of-business/report/": {
      "post": {
        "tags": [
          "book of business report"
        ],
        "operationId": "bob_report_create",
        "summary": "API to create book of businiess report document",
        "description": "API to create book of businiess report document for the filter criteria provided and return either the metadata of the generated bob report document or the binary of the document.",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/RefererHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/UserAgentHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/ForwardedForHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/UserNameHeader/10.0.1#/components/parameters/UserNameHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/WebSessionIdHeader/10.0.1#/components/parameters/WebSessionIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/CorrelationIdHeader/10.0.1#/components/parameters/CorrelationIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/IdentitiesHeader/10.0.3#/components/parameters/IdentitiesHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "market_segment": {
                    "description": "Filter for book of business associated with the market_segment provided.",
                    "type": "string",
                    "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/MarketSegmentEnum/10.0.1#/components/schemas/MarketSegment"
                  },
                  "broker_id": {
                    "description": "Filter for book of business associated with the broker for the broker_id provided. This filter is only available for Agency Manager or Internal User roles.",
                    "type": "string"
                  },
                  "agency_id": {
                    "description": "Filter for book of business associated with the agency for the agency_id provided. This filter is only available for Agency Manager or Internal User roles.",
                    "type": "string"
                  },
                  "policy_status": {
                    "description": "Filter for book of business with the given status. Payers should handle the data restriction based on the user information on the access token. (logged-in user).",
                    "type": "string"
                  },
                  "product_coverage_type": {
                    "description": "Filter for book of business associated with product coverages for the provided product coverage type. Payers should handle the data restriction based on the user information on the access token. (logged-in user).",
                    "type": "string",
                    "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ProductCoverageTypeEnum/10.5.1#/components/schemas/ProductCoverageType"
                  },
                  "policy_effective_date_gte": {
                    "description": "Filter for book of business with an effective date starting from the date provided. Payers should handle the data restriction based on the user information on the access token. (logged-in user).",
                    "type": "string",
                    "format": "date"
                  },
                  "policy_effective_date_lte": {
                    "description": "Filter for book of business with an effective date up to the date provided. Payers should handle the data restriction based on the user information on the access token. (logged-in user).",
                    "type": "string",
                    "format": "date"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully generated the book of business report for the defined filters",
            "content": {
              "application/json": {
                "schema": {
                  "required": [
                    "document_id"
                  ],
                  "type": "object",
                  "properties": {
                    "document_id": {
                      "type": "string",
                      "description": "Unique document identifier to retrieve the document from the document source"
                    },
                    "document_url": {
                      "type": "string",
                      "description": "URL to access the book of busness report."
                    }
                  }
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  }
}