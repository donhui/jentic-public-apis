{
  "openapi": "3.0.0",
  "info": {
    "title": "BillsList",
    "description": "Common BillsList API",
    "version": "10.19.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Zipari-Core-Services/BillsList/10.19.1/swagger.json"
  },
  "paths": {
    "/bills/": {
      "get": {
        "tags": [
          "bills & invoices"
        ],
        "summary": "Get a list of invoices billed to the Billing Account.",
        "description": "This API returns a list of Invoices billed to the billing account.",
        "operationId": "bills_list",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/AcceptHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/AuthorizationHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/ContentTypeHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/RefererHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/UserAgentHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/ForwardedForHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/UserNameHeader/10.0.1#/components/parameters/UserNameHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/WebSessionIdHeader/10.0.1#/components/parameters/WebSessionIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/CorrelationIdHeader/10.0.1#/components/parameters/CorrelationIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/IdentitiesHeader/10.0.3#/components/parameters/IdentitiesHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/PaginationQueryParameters/10.3.1#/components/parameters/orderingParam"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/PaginationQueryParameters/10.3.1#/components/parameters/pageParam"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/PaginationQueryParameters/10.3.1#/components/parameters/pageSizeParam"
          },
          {
            "name": "member_id",
            "in": "query",
            "description": "This is the unique member identifier, to retrieve the associated bills across all billing accounts.",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bill_status",
            "in": "query",
            "description": "Bill status to retrieve the associated invoices.",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bill_date_from",
            "in": "query",
            "description": "*** DEPRECATED *** see issued_date_gte\nBill date (from) to retrieve the associated invoices.\n",
            "deprecated": true,
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bill_date_to",
            "in": "query",
            "description": "*** DEPRECATED *** see issued_date_lte\nBill date (to) to retrieve the associated invoices.\n",
            "deprecated": true,
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "issued_date_gte",
            "in": "query",
            "description": "Filter invoices whose issued_date is greater than or equal to this date.",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "issued_date_lte",
            "in": "query",
            "description": "Filter invoices whose issued_date is less than or equal to this date.",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "policy_id",
            "in": "query",
            "description": "This is the unique policy identifier.",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "billing_account_name",
            "in": "query",
            "description": "This is the billing account name.\nIt is up to the payer implementation to implement exact or partial match.\nIdeally if there are no exact match results, then partial match results should be included.\n",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "billing_account_id",
            "in": "query",
            "description": "Filter invoices for this billing account.",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "product_coverage_id",
            "in": "query",
            "description": "*** DEPRECATED *** Use account_id \nProduct coverage id to retrieve the associated bills.\n",
            "deprecated": true,
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bill_amount_gte",
            "in": "query",
            "description": "Filter for invoices(bills) with bill amount greater than or equal to specified amount.\nBills with amount greater than or equal to the value passed in this parameter\nwill be listed in the response.\nThe value is a dollar amount. It should be sent with 2 decimal digits.\n",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "bill_amount_lte",
            "in": "query",
            "description": "Filter for invoices(bills) with bill amount less than or equal to specified amount.\nBills with amount less than or equal to the value passed in this parameter\nwill be listed in the response.\nThe value is a dollar amount. It should be sent with 2 decimal digits.\n",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "payment_amount_gte",
            "in": "query",
            "description": "Filter for invoices(bills) with payment amount greater than or equal to specified amount.\nBills with payment amount greater than or equal to the value passed in this parameter\nwill be listed in the response.\nThe value is a dollar amount. It should be sent with 2 decimal digits.\n",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "payment_amount_lte",
            "in": "query",
            "description": "Filter for invoices(bills) with payment amount less than or equal to specified amount.\nBills with payment amount less than or equal to the value passed in this parameter\nwill be listed in the response.\nThe value is a dollar amount. It should be sent with 2 decimal digits.\n",
            "required": false,
            "style": "form",
            "explode": false,
            "schema": {
              "type": "number",
              "format": "float"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Provides list of Bill object associated with the search parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "required": [
                    "count",
                    "results"
                  ],
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer",
                      "description": "Count representing the number of objects returned in the results array."
                    },
                    "next": {
                      "type": "integer",
                      "description": "Query identifier defined by the api developer for getting the next set of records."
                    },
                    "previous": {
                      "type": "integer",
                      "description": "Query identifier defined by the api developer for getting the previous set of records."
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/BillModel/10.12.1#/components/schemas/Bill"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  }
}