{
  "openapi": "3.0.0",
  "info": {
    "version": "10.107.1",
    "title": "ApplicationsIndividualUpdate",
    "description": "Common ApplicationsIndividualUpdate API",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Zipari-Core-Services/ApplicationsIndividualUpdate/10.107.1/swagger.json"
  },
  "paths": {
    "/applications/individual/{id}": {
      "put": {
        "tags": [
          "enrollment"
        ],
        "summary": "Post updated individual application data to payer",
        "description": "Application or Enrollment Submission API is a standard Zipari Product API for submission of the application data captured as part of the enrollment submission workflow to the enrollment system of record. This API schema supports enrollment submissions for Individual & Family, Medicare and Supplemental market segments.",
        "operationId": "update_enrollment",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "unique application identifier for the application to be updated.",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "enrollment object submitted from the product",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/EnrollmentModel/10.109.1#/components/schemas/Enrollment"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sucessfully submitted the application. For real time integrations, response code of 422 can be used for Validation Errors and the EnrollmentStatus retruns all the validation errors to be displayed to the users.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/EnrollmentStatusModel/10.2.1#/components/schemas/EnrollmentStatus"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Data Processing Failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  }
}