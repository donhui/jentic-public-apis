{
  "openapi": "3.0.0",
  "info": {
    "version": "10.76.1",
    "title": "AppealsAndGrievancesSearch",
    "description": "Common AppealsAndGrievancesSearch API",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Zipari-Core-Services/AppealsAndGrievancesSearch/10.76.1/swagger.json"
  },
  "paths": {
    "/appeals-and-grievances/search/": {
      "post": {
        "operationId": "appeals_and_grievances_search",
        "summary": "Get the list of Appeals and Grievances associated with the search filter parameters.",
        "description": "API to retrieve the list of appeals and grievances associated with the defined filter parameters. The method for this API call is POST to support handling personally identifiable data on the request.",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/AcceptHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/AuthorizationHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/ContentTypeHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/RefererHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/UserAgentHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/ForwardedForHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/UserNameHeader/10.0.1#/components/parameters/UserNameHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/WebSessionIdHeader/10.0.1#/components/parameters/WebSessionIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/CorrelationIdHeader/10.0.1#/components/parameters/CorrelationIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/IdentitiesHeader/10.0.3#/components/parameters/IdentitiesHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "allOf": [
                  {
                    "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/PaginationQueryParameters/10.3.1#/components/schemas/PostParameters"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "appealandgrievance_number": {
                        "description": "Filters the AppealsAndGrievances by the given AppealAndGrievance number. Ref: /AppealAndGrievanceModel/10.18.1#/components/schemas/AppealAndGrievance/properties/number",
                        "type": "string"
                      },
                      "member_id": {
                        "description": "Filters the AppealsAndGrievances by the given member's identifier. This is the payer's member internal identifier. ref: /PersonModel/10.20.1#/components/schemas/Person/properties/id",
                        "type": "string"
                      },
                      "subscriber_id": {
                        "description": "Filters the AppealsAndGrievances by the given subscriber's identifier. This is the payer's subscriber internal identifier.",
                        "type": "string"
                      },
                      "appealandgrievance_type": {
                        "description": "Filters the AppealsAndGrievances by type of the AppealAndGrievance. Ref: /AppealAndGrievanceModel/10.18.1#/components/schemas/AppealAndGrievance/properties/type",
                        "type": "string"
                      },
                      "appealandgrievance_status": {
                        "description": "Filters the AppealsAndGrievances by status of the AppealAndGrievance. This parameter can have more than one status to filter on.",
                        "type": "array",
                        "items": {
                          "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/AppealAndGrievanceModel/10.73.1#/components/schemas/AppealAndGrievance/properties/status"
                        }
                      },
                      "appealandgrievance_category": {
                        "description": "Filters the AppealsAndGrievances by category of the AppealAndGrievance. This parameter can have more than one category to filter on.",
                        "type": "array",
                        "items": {
                          "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/AppealAndGrievanceModel/10.73.1#/components/schemas/AppealAndGrievance/properties/category"
                        }
                      },
                      "appealandgrievance_category_reference_number": {
                        "description": "Filters the AppealsAndGrievances by category reference number of the AppealAndGrievance. This can be number of the claim which is associated with the Appeal and Grievance. Ref: /AppealAndGrievanceModel/10.18.1#/components/schemas/AppealAndGrievance/properties/category_reference_number",
                        "type": "string"
                      },
                      "appealandgrievance_received_date_gte": {
                        "description": "Filters the AppealsAndGrievances for the received date greater than or equal to the specific date. This is the received_date on the AppealAndGrievance model.",
                        "type": "string",
                        "format": "date"
                      },
                      "appealandgrievance_received__date_lte": {
                        "description": "Filters the AppealsAndGrievances for the received date less than or equal to the specific date. This is the received_date on the AppealAndGrievance model.",
                        "type": "string",
                        "format": "date"
                      },
                      "policy_id": {
                        "description": "Filters the AppealsAndGrievances by the given policy's identifier. This is the payer's policy internal identifier. Ref: /PolicyModel/10.49.1#/components/schemas/Policy/properties/id",
                        "type": "string"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "An array of AppealAndGrievance objects.",
            "content": {
              "application/json": {
                "schema": {
                  "required": [
                    "count",
                    "results"
                  ],
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer",
                      "description": "Count representing the total number of objects available to be returned in the results array"
                    },
                    "next": {
                      "type": "integer",
                      "description": "query identifier defined by the api developer for getting the next set of records"
                    },
                    "previous": {
                      "type": "integer",
                      "description": "query identifier defined by the api developer for getting the previous set of records"
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/AppealAndGrievanceModel/10.73.1#/components/schemas/AppealAndGrievance"
                      }
                    }
                  }
                },
                "examples": {
                  "Appeal Search": {
                    "value": {
                      "count": 1,
                      "next": null,
                      "previous": null,
                      "results": [
                        {
                          "id": 9021,
                          "number": "AP_101012",
                          "type": "appeal",
                          "category": "claim",
                          "category_reference_number": "CLM_897673",
                          "status": "denied",
                          "member_id": "MID_87902",
                          "subscriber_id": "SID_87780",
                          "policy_id": "PID_87222",
                          "received_date": "2020-09-16",
                          "status_date": "2020-10-16",
                          "document_ids": [
                            "DOC1234"
                          ]
                        }
                      ]
                    }
                  },
                  "Grievance Search": {
                    "value": {
                      "count": 1,
                      "next": null,
                      "previous": null,
                      "results": [
                        {
                          "id": 9022,
                          "number": "GR_101767",
                          "type": "grievance",
                          "category": "coverage_review",
                          "category_reference_number": "CR_897767",
                          "status": "in_review",
                          "member_id": "MID_87911",
                          "subscriber_id": "SID_87723",
                          "policy_id": "PID_87890",
                          "received_date": "2020-10-16",
                          "status_date": "2020-11-16",
                          "document_ids": [
                            "DOC9876"
                          ]
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  }
}