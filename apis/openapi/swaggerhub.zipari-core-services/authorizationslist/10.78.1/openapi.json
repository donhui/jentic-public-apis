          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/RefererHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/UserAgentHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/StandardHeaders/10.0.1/#/components/parameters/ForwardedForHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/UserNameHeader/10.0.1#/components/parameters/UserNameHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/WebSessionIdHeader/10.0.1#/components/parameters/WebSessionIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/CorrelationIdHeader/10.0.1#/components/parameters/CorrelationIdHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/IdentitiesHeader/10.0.3#/components/parameters/IdentitiesHeader"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/PaginationQueryParameters/10.3.1#/components/parameters/orderingParam"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/PaginationQueryParameters/10.3.1#/components/parameters/pageParam"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/PaginationQueryParameters/10.3.1#/components/parameters/pageSizeParam"
          },
          {
            "name": "authorization_reference_number",
            "in": "query",
            "description": "Filters the authorizations by the given authorization number or authorization secondary_number.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "member_first_name",
            "in": "query",
            "description": "Filters the authorizations by the given member's first name.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "member_last_name",
            "in": "query",
            "description": "Filters the authorizations by the given member's last name.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "member_name",
            "in": "query",
            "description": "Filters the authorizations by Member's name fields including first, middle, last, and all name fields.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "member_id",
            "in": "query",
            "description": "Filters the authorizations by the given member's identifier. This is the payer's member internal identifier.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "member_number",
            "in": "query",
            "description": "Filters the authorizations by the given member's number. This can be the member display identifier.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization_status",
            "in": "query",
            "description": "Filters the authorizations by status of the authorization.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "requesting_provider_name",
            "in": "query",
            "description": "Filters the authorizations by the requesting provider's name.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_date_gte",
            "in": "query",
            "description": "Filters the authorizations for the request date greater than or equal to the specific date.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "request_date_lte",
            "in": "query",
            "description": "Filters the authorizations for the request date less than or equal to the specific date.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "effective_date_gte",
            "in": "query",
            "description": "Filters the authorizations for the service date greater than or equal to the specific date. This is the effective_date on the Authorization model.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "effective_date_lte",
            "in": "query",
            "description": "Filters the authorizations for the service date less than or equal to the specific date. This is the effective_date on the Authorization model.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "policy_id",
            "in": "query",
            "description": "unique policy id.",
            "required": false,
            "style": "form",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of Authorization objects.",
            "content": {
              "text/csv": {
                "schema": {
                  "type": "string",
                  "description": "Returns the List of Authorizations as a CSV file"
                }
              },
              "application/json": {
                "schema": {
                  "required": [
                    "count",
                    "results"
                  ],
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer",
                      "description": "Count representing the total number of objects available to be returned in the results array"
                    },
                    "next": {
                      "type": "integer",
                      "description": "query identifier defined by the api developer for getting the next set of records"
                    },
                    "previous": {
                      "type": "integer",
                      "description": "query identifier defined by the api developer for getting the previous set of records"
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/AuthorizationModel/10.76.1#/components/schemas/Authorization"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/Zipari-Core-Services/ErrorModel/10.0.2#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  }
