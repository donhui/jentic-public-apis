  "components": {
    "schemas": {
      "DataResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "CustomerProfile": {
        "type": "object",
        "properties": {
          "customer_profile_id": {
            "type": "integer"
          },
          "network_type": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "native_name": {
            "type": "string"
          },
          "native_id": {
            "type": "string"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "network_metadata": {
            "type": "object"
          }
        }
      },
      "AnalyticsRequest": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filter expressions like customer_profile_id.eq(1234), reporting_period.in(2018-08-01...2018-10-01)"
          },
          "metrics": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Metrics to retrieve (e.g. impressions, reactions)"
          },
          "page": {
            "type": "integer",
            "default": 1
          },
          "limit": {
            "type": "integer",
            "default": 1000
          }
        },
        "required": [
          "filters",
          "metrics"
        ]
      },
      "PostAnalyticsRequest": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metrics": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timezone": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "default": 1
          },
          "limit": {
            "type": "integer",
            "default": 50
          },
          "sort": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "filters"
        ]
      },
      "AnalyticsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "dimensions": {
                  "type": "object"
                },
                "metrics": {
                  "type": "object"
                }
              }
            }
          },
          "paging": {
            "$ref": "#/components/schemas/Paging"
          }
        }
      },
      "MessagesRequest": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limit": {
            "type": "integer",
            "default": 50,
            "maximum": 100
          },
          "timezone": {
            "type": "string"
          },
          "page_cursor": {
            "type": "string"
          },
          "sort": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "filters"
        ]
      },
      "MessagesResponse": {
        "type": "object",
        "properties": {
          "data": {
