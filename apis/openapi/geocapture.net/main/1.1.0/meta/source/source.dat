            "description": "Include orders created or scheduled up to this number of days before today. Default: 0."
          },
          "daysAfter": {
            "type": "integer",
            "description": "Include orders created or scheduled up to this number of days after today. Default: 0."
          },
          "locale": {
            "type": "string",
            "description": "Language code for the response text. Default: de.\n\n| Value | Language |\n| ----- | -------- |\n| de    | German   |\n| en    | English  |\n| es    | Spanish  |\n| fr    | French   |\n| it    | Italian  |\n| nl    | Dutch    |\n| pl    | Polish   |\n| ro    | Romanian |\n| ru    | Russian  |"
          }
        }
