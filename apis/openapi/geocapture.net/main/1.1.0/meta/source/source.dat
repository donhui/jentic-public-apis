          },
          "distanceDriver": {
            "type": "integer",
            "description": "The distance traveled as driver in meters.\n\nTotal distance covered while actively driving the vehicle."
          },
          "durationDriver": {
            "type": "integer",
            "description": "The duration as driver in seconds.\n\nTotal time spent actively driving the vehicle."
          },
          "durationWithinWorktimeDriver": {
            "type": "integer",
