            "$ref": "#/components/schemas/DateTime"
          },
          "worktime": {
            "type": "integer",
            "description": "The work time of the time record."
          },
          "breakDuration": {
            "type": "integer",
            "description": "The break time of the time record."
          },
          "project": {
            "description": "The break time of the time pair.",
            "type": "object",
            "$ref": "#/components/schemas/EmployeeTimeTrackingFetchResponseProjectItem"
          },
          "isApproved": {
            "type": "boolean",
            "description": "Shows if the time pair is approved."
          }
        }
      },
      "EmployeeTimeTrackingFetchResponseProjectItem": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal project ID."
          },
          "reference": {
            "type": "string",
            "description": "The project number."
          },
          "importSource": {
            "type": "string",
            "description": "External data source from which this project originated."
          },
          "importKey": {
            "type": "string",
            "description": "External ID from the respective data source."
