    "/employee_absence/upsert": {
      "post": {
        "tags": [
          "Time Tracking|Absence"
        ],
        "summary": "Create/Update absences.",
        "description": "This method can be used to create and update absences.\n\nAn attempt is made to locate an existing absence based on the selected primary key. If one is found, it will be\nadjusted. Otherwise, a new absence will be created. If the `deleteMissing` flag is activated, all records not\nincluded in the request will be deleted. If the `dryRun` option is enabled, no actual changes will occur. It is\nimportant to note that absences could affect the employees' time account.",
        "operationId": "Time Tracking|Absence_upsertAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
