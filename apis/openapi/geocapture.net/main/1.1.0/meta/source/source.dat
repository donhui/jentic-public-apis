            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ComponentHttpFoundationResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/custom_form_data/log": {
      "get": {
        "tags": [
          "Documents|Form data"
        ],
        "summary": "Request the log for the form data.",
        "description": "This endpoint enables you to retrieve a log of a custom form by specifying its ID. Additionally, you can\nfilter by the date of creation using the payload parameter for additional information. For instance, an entry\nmarked as `SEND` will display the recipient as a property. The payload will include the custom form data upon\ncreation or update.",
        "operationId": "Documents|Form data_fetchLog",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the form data. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Filters the form log data based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "Filters the form log data based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardCustomFormDataLogResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/custom_form_data/media": {
