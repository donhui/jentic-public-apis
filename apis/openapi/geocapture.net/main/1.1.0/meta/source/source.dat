          },
          "durationWithinWorktimePassenger": {
            "type": "integer",
            "description": "The duration as passenger within worktime in seconds.\n\nTime spent as a passenger that counts towards paid working hours."
          },
          "licenseNumber": {
            "type": "string",
            "description": "The license plate of the vehicle."
          },
          "projectReferenceSign": {
            "type": "string",
            "description": "The reference sign of the project."
          }
        }
      },
      "EmployeeTimeTrackingFetchResponseEmployeeAbsenceItem": {
