          }
        }
      },
      "ToolUpsertRequestRecordData": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal id of the tool."
          },
          "name": {
            "type": "string",
            "description": "The name of the tool. (max. 255 characters)"
          },
          "description": {
            "type": "string",
            "description": "The description of the tool."
          },
          "categoryId": {
            "type": "integer",
            "description": "The category of the tool."
          },
          "categoryName": {
            "type": "string",
            "description": "The name of the tools' category (Used if categoryId not provided)."
          },
          "serialNumber": {
            "type": "string",
            "description": "The serial number of the tool. (max. 255 characters)"
          },
          "externalId": {
            "type": "string",
            "description": "The external ID of the tool. (max. 255 characters)"
          },
          "inventoryNumber": {
            "type": "string",
            "description": "The inventory number of the tool. (max. 255 characters)"
          },
          "manufacturerId": {
            "type": "integer",
            "description": "The manufacturer of the tool."
          },
          "manufacturerName": {
            "type": "string",
            "description": "The name of the tools' manufacturer (Used if manufacturerId not provided)."
          },
          "model": {
            "type": "string",
            "description": "The model of the tool. (max. 255 characters)"
          },
          "machineType": {
            "type": "string",
            "description": "The machine type of the tool. (max. 255 characters)"
          },
          "assessory": {
            "type": "string",
            "description": "Additional information for the tool."
          },
          "supplier": {
            "type": "string",
            "description": "The supplier of the tool. (max. 255 characters)"
          },
          "iconName": {
            "type": "string",
            "description": "Filename of the icon with file extension"
          },
          "iconData": {
            "type": "string",
            "description": "base64 encoded icon"
          },
          "purchaseCost": {
            "type": "number",
            "description": "The purchase costs of the tool."
          },
          "purchaseDate": {
            "description": "The purchase date of the tool.",
            "type": "object",
            "$ref": "#/components/schemas/Date"
          },
          "warrantyMonth": {
            "type": "integer",
            "description": "The warranty of the tool in months."
          },
          "yearOfManufacture": {
            "type": "integer",
            "description": "The tools year of manufacture."
          },
          "outgoingDate": {
            "description": "The outgoing date of the tool.",
            "type": "object",
            "$ref": "#/components/schemas/Date"
          },
          "status": {
            "type": "string",
            "description": "The status of the tool.\n\n| status         |\n| -------------- |\n| NEW            |\n| SOLD           |\n| IN_REPAIR      |\n| LOST           |\n| RESERVED       |\n| OK             |\n| BROKEN         |\n| LENT           |"
          },
          "weight": {
            "type": "number",
            "description": "The weight of the tool in kgs."
          },
          "length": {
            "type": "number",
            "description": "The length of the tool in meters."
          },
          "width": {
            "type": "number",
            "description": "The width of the tool in meters."
          },
          "height": {
            "type": "number",
            "description": "The height of the tool in meters."
          },
          "dguvCheckNumber": {
            "type": "string",
            "description": "The dguv check number of the tool. (max. 32 characters)"
          },
          "responsibleEmployeeId": {
            "type": "integer",
            "description": "The id of the employee responsible for the tool."
          },
          "beaconId": {
            "type": "integer",
            "description": "The internal id of the beacon assigned to the tool (Either a tracker or a beacon can be assigned)."
          },
          "trackerId": {
            "type": "integer",
            "description": "The internal id of the tracker assigned to the tool (Either a tracker or a beacon can be assigned)."
          },
          "licenseNumber": {
            "type": "string",
            "description": "The license plate of the tool. (max. 64 characters)"
          },
          "synchronizeBeacon": {
            "type": "boolean",
            "description": "Indicates that the beacon mirrors the device\u2019s metadata. The name, photo, description, and serial number are kept synchronized from the device to the beacon.\nWhenever any of these fields on the device changes, the beacon is automatically updated accordingly (Default false)."
          },
          "costCenter": {
            "type": "string",
            "description": "The cost center."
          }
        }
      },
