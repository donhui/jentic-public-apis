        "tags": [
          "Projects|Bill of quantities"
        ],
        "summary": "Import a bill of quantities file.",
        "description": "This endpoint facilitates the upload of files encoded in base64 format. It supports various file formats\nincluding XML, GAEB2000, and GAEB90, enabling their import into the system. Upon successful upload, a `jobId` is\nprovided in the response, which can be used to inquire about the status of the import job through the\nMiscellaneous|Job endpoint.",
        "operationId": "Projects|Bill of quantities_importAction",
