    "/approval_center/fetch": {
      "get": {
        "tags": [
          "Miscellaneous|Approval"
        ],
        "summary": "Fetch approval list.",
        "description": "This endpoint provides you  a list of requests for various purposes, including vacation, missing time\nstamps, or bookings.  Approvals in geoCapture, for example, are utilized to apply for leave. The individual\noverseeing approvals (either set at the department level or delegated to the employee) may either accept, reject,\nrequest consultation, or provisionally accept the approval. The statuses of `CONSULTATION_REQUIRED` and\n`PROVISIONALLY_ACCEPTED` may be modified to `ACCEPT` or `REJECTED` at a later stage.\n\nIf the holiday request is approved, the absence will be displayed on the staff calendar as a filled color.\nIf the application is not yet approved, it will display in a dashed pattern on the Employee Calendar, which\noffers an overview of absences. If the approval is rejected, it will not be displayed on the calendar. The\nabsence calendar offers an outline of absences and is also employed in other parts of geoCapture, including\nresource planning.\n\nWhen a stamp is approved, the new stamp will be added to the employee at the requested time. A new booking will\nbe created in geoCapture as soon as a booking has been approved.",
        "operationId": "Miscellaneous|Approval_fetchAction",
        "parameters": [
          {
            "name": "logs[byAssignee]",
            "in": "query",
            "required": false,
            "description": "Filters the approvals by the assignee.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "logs[byEmployee]",
            "in": "query",
            "required": false,
            "description": "Filters the approvals by the employee.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "logs[byStatuses][]",
            "in": "query",
            "required": false,
            "description": "Filters the approvals by the status.\n\n| Value                  | Description                     |\n| ---------------------- | ------------------------------- |\n| OPEN                   | Approval open                   |\n| DONE                   | Approval done                   |\n| REJECTED               | Approval rejected               |\n| CONSULTATION_REQUIRED  | Approval requires consultation  |\n| PROVISIONALLY_ACCEPTED | Approval provisionally accepted |",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "logs[byObjectType]",
            "in": "query",
            "required": false,
            "description": "Filters the approvals by the type.\n\n| Value                      | Description                                                             |\n| -------------------------- | ----------------------------------------------------------------------- |\n| APPROVAL_EMPLOYEE_WORKTIME | If working times from stamps must be approved. Configured in Department |\n| EMPLOYEE_APPLICATION       | If the employee submits an application: e.g. absence                    |\n| CUSTOM_FORM_DATA           | If custom forms must be approved: Configured in form definition         |",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "logs[byObjectId]",
            "in": "query",
            "required": false,
            "description": "Filters the approvals by the object. Can be used only in conjunction with the filter \"byObjectType\".",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Number of records to skip.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardApprovalCenterFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/approval_center/update_status": {
      "post": {
        "tags": [
          "Miscellaneous|Approval"
        ],
        "summary": "Update an approval's status.",
        "description": "This endpoint enables you to update the status of approval requests. By making requests to this endpoint,\nyou can modify the status of specific approval entries, such as approving or rejecting an approval. In addition,\nyou can set the status to consultation required and provisionally accepted.",
        "operationId": "Miscellaneous|Approval_updateStatusAction",
        "parameters": [],
        "responses": {
