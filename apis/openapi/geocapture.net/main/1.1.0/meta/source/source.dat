  "components": {
    "schemas": {
      "DateTime": {
        "type": "string",
        "description": "Represents a date and a time. (ISO 8601) ICU-Format: yyyy-MM-dd'T'HH:mm:ssxxx",
        "example": "2015-02-20T12:59:21+01:00"
      },
      "Date": {
        "type": "string",
        "description": "Represents a date. (ISO 8601) ICU-Format: yyyy-MM-dd",
        "example": "2015-02-20"
      },
      "Time": {
        "type": "string",
        "description": "Represents a time. (ISO 8601) ICU-Format: HH:mm:ss",
        "example": "12:59:21"
      },
      "ComponentHttpFoundationResponse": {
        "type": "object",
        "description": "Represents a formless response. (HTML, Text, ...)"
      },
      "ComponentGeocodingAddressInterface": {
        "type": "object",
        "description": "Represents an address",
        "properties": {
          "latLng": {
            "description": "The geo coordinate.",
            "type": "object",
            "$ref": "#/components/schemas/ComponentGeocodingLatLngInterface"
          },
          "name": {
            "type": "string",
            "description": "The address name."
          },
          "street": {
            "type": "string",
            "description": "The complete street."
          },
          "streetName": {
            "type": "string",
            "description": "The street name."
          },
          "streetNumber": {
            "type": "string",
            "description": "The house number."
          },
          "zipCode": {
            "type": "string",
            "description": "The postcode."
          },
          "city": {
            "type": "string",
            "description": "The city."
          },
          "countryCode": {
            "type": "string",
            "description": "The two digit country abbreviation. (ISO-3166 ALPHA-2)"
          },
          "fullAddress": {
            "type": "string",
            "description": "The complete address."
          }
        }
      },
      "DynamicWeekdayTime": {
        "type": "object",
        "description": "Represents dynamic weekday times\n\n~~~\nJSON format:\n~~~\n{\"MO\":[[\"08:00\",\"13:00\"],[\"15:00\",\"18:00\"]],\"WE\":[[\"08:00\",\"13:00\"],[\"15:00\",\"18:00\"]],\"FR\":[[\"08:00\",\"13:00\"],[\"15:00\",\"18:00\"]]}\n~~~",
        "properties": {
          "MO": {
            "description": "monday",
            "type": "object",
            "$ref": "#/components/schemas/StandardCoreTypeDynamicWeekdayTimes"
          },
          "TU": {
            "description": "tuesday",
            "type": "object",
            "$ref": "#/components/schemas/StandardCoreTypeDynamicWeekdayTimes"
          },
          "WE": {
            "description": "wednesday",
            "type": "object",
            "$ref": "#/components/schemas/StandardCoreTypeDynamicWeekdayTimes"
          },
          "TH": {
            "description": "thursday",
            "type": "object",
            "$ref": "#/components/schemas/StandardCoreTypeDynamicWeekdayTimes"
          },
          "FR": {
            "description": "friday",
            "type": "object",
            "$ref": "#/components/schemas/StandardCoreTypeDynamicWeekdayTimes"
          },
          "SA": {
            "description": "saturday",
            "type": "object",
            "$ref": "#/components/schemas/StandardCoreTypeDynamicWeekdayTimes"
          },
          "SU": {
            "description": "sunday",
            "type": "object",
            "$ref": "#/components/schemas/StandardCoreTypeDynamicWeekdayTimes"
          }
        }
      },
      "ComponentGeocodingLatLngInterface": {
        "type": "array",
        "description": "Represents a geo coordinate. An array of two double values, representing the latitude and longitude.",
        "example": [
          52.38127828631681,
          7.594243214018696
        ],
        "items": {
          "type": "number"
        }
      },
      "ComponentGeocodingLatLngBoundsInterface": {
        "type": "object",
        "description": "Represents a rectangle in geo coordinates",
        "properties": {
          "minLatLng": {
            "description": "Min. Latitude/Longitude",
            "type": "object",
            "$ref": "#/components/schemas/ComponentGeocodingLatLngInterface"
          },
          "maxLatLng": {
            "description": "Max. Latitude/Longitude",
            "type": "object",
            "$ref": "#/components/schemas/ComponentGeocodingLatLngInterface"
          }
        }
      },
      "StandardTrackerFetchResponse": {
        "type": "object",
        "description": "",
        "properties": {
          "data": {
            "description": "The vehicles.",
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/TrackerFetchResponseTrackerItem"
                },
                {
                  "description": ""
                }
              ]
            }
          },
          "offset": {
            "type": "integer",
            "description": "Number of skiped records."
          },
          "totalCount": {
            "type": "integer",
            "description": "Total number of available vehicles.\n(Only calculated if offset is 0)"
          }
        }
      },
      "TrackerFetchResponseTrackerItem": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal vehicle ID."
          },
          "identifier": {
            "type": "string",
            "description": "The customer-specific ID. (max. 64 characters)"
          },
          "inventoryNumber": {
            "type": "string",
            "description": "The inventory number. (max. 128 characters)"
          },
          "licenseNumber": {
            "type": "string",
            "description": "The vehicle license plate. (max. 255 characters)"
          },
          "identificationNumber": {
            "type": "string",
            "description": "The vehicle identification number. (max. 24 characters)"
          },
          "importSource": {
            "type": "string",
            "description": "External data source from which this vehicle originates. (max. 64 characters)"
          },
          "importKey": {
            "type": "string",
            "description": "External ID from the respective data source. (max. 64 characters)"
          },
          "name": {
            "type": "string",
            "description": "The vehicle name. (max. 255 characters)"
          },
          "description": {
            "type": "string",
            "description": "The vehicle description."
          },
          "driverName": {
            "type": "string",
            "description": "The driver name. (max. 255 characters)"
          },
          "driverPhoneNumber": {
            "type": "string",
            "description": "The driver phone number. (max. 255 characters)"
          },
          "costCenter": {
            "type": "string",
            "description": "The cost center. (max. 25 characters)"
          },
          "currentLatLng": {
            "description": "The current position.",
            "type": "object",
            "$ref": "#/components/schemas/ComponentGeocodingLatLngInterface"
          },
          "currentProject": {
            "description": "The current project.",
            "type": "object",
            "$ref": "#/components/schemas/TrackerFetchResponseProjectItem"
          },
          "multipleProjectsPossible": {
            "type": "boolean",
            "description": "Indicates if multiple current projects were possible."
          },
          "currentProjectChangedAt": {
            "description": "The time of the last project change.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "trackerSerialNumber": {
            "type": "string",
            "description": "The serial number of the tracker."
          },
          "category": {
            "description": "The tracker category.",
            "type": "object",
            "$ref": "#/components/schemas/StandardTrackerCategoryBaseTrackerCategoryListItem"
          },
          "lastSignalAt": {
            "description": "Time of the last signal.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "model": {
            "type": "string",
            "description": "The tracker model."
          },
          "lastTrackpointId": {
            "type": "integer",
            "description": "ID of the latest trackpoint."
          },
          "imei": {
            "type": "string",
            "description": "IMEI of the tracker."
          }
        }
      },
      "TrackerFetchResponseProjectItem": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal project ID."
          },
          "reference": {
            "type": "string",
            "description": "The project number."
          },
          "importSource": {
            "type": "string",
            "description": "External data source from which this project originated."
          },
          "importKey": {
            "type": "string",
            "description": "External ID from the respective data source."
          }
        }
      },
      "StandardTrackerCategoryBaseTrackerCategoryListItem": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal id of the tracker category."
          },
          "name": {
            "type": "string",
            "description": "The name of the tracker category."
          },
          "description": {
            "type": "string",
            "description": "The description of the tracker category."
          },
          "externalId": {
            "type": "string",
            "description": "The external ID of the tracker category."
          },
          "costCenter": {
            "type": "string",
            "description": "The cost center of the tracker category."
          },
          "createdAt": {
            "description": "Date when the tracker category was created.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          }
        }
      },
      "TrackerFetchRequestTrackerFilter": {
        "type": "object",
        "description": "",
        "properties": {
          "byIds": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Filters the vehicles based on the IDs."
          },
          "byLicenseNumbers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filters the vehicles based on the license plates."
          },
          "byIdentifiers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filters the vehicles based on the customer-specific IDs."
          },
          "byIdentificationNumbers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filters the vehicles based on the VINs."
          },
          "byImportKeys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filters the vehicles based on the external vehicle IDs."
          },
          "byProjectChangedAfter": {
            "description": "Filter the vehicles which projectChangedAt is after the given date.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "importSource": {
            "type": "string",
            "description": "Name of the external data source. (Default is \"*API\")\n\nThis parameter is only required if the external vehicle ID is filtered."
          },
          "byName": {
            "type": "string",
            "description": "Filter the vehicles on their name."
          },
          "byDriver": {
            "type": "string",
            "description": "Filter the vehicles on their driver."
          }
        }
      },
      "StandardTrackerFetchRequest": {
        "type": "object",
        "description": "",
        "properties": {
          "trackers": {
            "description": "The vehicle filter. This Parameter is optional.",
            "type": "object",
            "$ref": "#/components/schemas/TrackerFetchRequestTrackerFilter"
          },
          "normalizedSearch": {
            "type": "boolean",
            "description": "Set this parameter to enable advanced filter methods (normalized license number, phonetic search for names)"
          },
          "offset": {
            "type": "integer",
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set. This Parameter is optional."
          },
          "limit": {
            "type": "integer",
            "description": "Max. number of requested records. This Parameter is optional."
          }
        }
      },
      "StandardTrackerUpsertResponse": {
        "type": "object",
        "description": "",
        "properties": {
          "updatedTrackers": {
            "description": "The changed vehicles.",
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/TrackerUpsertResponseTrackerItem"
                },
                {
                  "description": ""
                }
              ]
            }
          }
        }
      },
      "TrackerUpsertResponseTrackerItem": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal vehicle ID."
          },
          "identifier": {
            "type": "string",
            "description": "The customer-specific ID. (max. 64 characters)"
          },
          "inventoryNumber": {
            "type": "string",
            "description": "The inventory number. (max. 128 characters)"
          },
          "licenseNumber": {
            "type": "string",
            "description": "The vehicle license plate. (max. 255 characters)"
          },
          "identificationNumber": {
            "type": "string",
            "description": "The vehicle identification number. (max. 24 characters)"
          },
          "importSource": {
            "type": "string",
            "description": "External data source from which this vehicle originates. (max. 64 characters)"
          },
          "importKey": {
            "type": "string",
            "description": "External ID from the respective data source. (max. 64 characters)"
          }
        }
      },
      "TrackerUpsertRequestRecord": {
        "type": "object",
        "description": "",
        "properties": {
          "keyField": {
            "type": "string",
            "description": "This parameter specifies the name of the unique key used to distinctly assign each dataset in the API.\n\n| Value                   | Description                 |\n|------------------------|-----------------------------|\n| id                     | The internal vehicle ID     |\n| identifier             | The customer specific ID    |\n| licenseNumber          | The license plate    |\n| identificationNumber   | The vehicle identification number |\n| importKey              | The external record ID    |"
          },
          "data": {
            "description": "The vehicle record.\n\nFor updates, only the updated fields need to be specified.\n\nThe primary key to be used must **always** be specified.",
            "type": "object",
            "$ref": "#/components/schemas/TrackerUpsertRequestRecordData"
          }
        }
      },
      "TrackerUpsertRequestRecordData": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal vehicle ID."
          },
          "identifier": {
            "type": "string",
            "description": "The customer-specific ID. (max. 64 characters)"
          },
          "inventoryNumber": {
            "type": "string",
            "description": "The inventory number. (max. 128 characters)"
          },
          "licenseNumber": {
            "type": "string",
            "description": "The vehicle license plate. (max. 255 characters)"
          },
          "identificationNumber": {
            "type": "string",
            "description": "The vehicle identification number. (max. 24 characters)"
          },
          "importSource": {
            "type": "string",
