      "StandardCoreTypeDynamicWeekdayTimeDay": {
        "example": "[\"08:00\",\"13:00\"]",
        "description": "Represents dynamic weekday times",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "StandardCoreTypeDynamicWeekdayTimes": {
        "type": "array",
        "example": [
          [
            "08:00",
            "13:00"
          ]
        ],
        "items": {
          "example": "[\"08:00\",\"13:00\"]",
          "description": "Represents dynamic weekday times",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "StandardCoreTypeDynamicWeekdayTime": {
        "example": "{\"MO\":[[\"08:00\",\"13:00\"],[\"15:00\",\"18:00\"]],\"WE\":[[\"08:00\",\"13:00\"],[\"15:00\",\"18:00\"]],\"FR\":[[\"08:00\",\"13:00\"],[\"15:00\",\"18:00\"]]}",
        "description": "Represents dynamic weekday times",
        "type": "object",
        "properties": {
          "MO": {
            "type": "array",
            "example": [
              [
                "08:00",
                "13:00"
              ]
            ],
            "items": {
              "example": "[\"08:00\",\"13:00\"]",
              "description": "Represents dynamic weekday times",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "DI": {
            "type": "array",
            "example": [
              [
                "08:00",
                "13:00"
              ]
            ],
            "items": {
              "example": "[\"08:00\",\"13:00\"]",
              "description": "Represents dynamic weekday times",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "MI": {
            "type": "array",
            "example": [
              [
                "08:00",
                "13:00"
              ]
            ],
            "items": {
              "example": "[\"08:00\",\"13:00\"]",
              "description": "Represents dynamic weekday times",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "DO": {
            "type": "array",
            "example": [
              [
                "08:00",
                "13:00"
              ]
            ],
            "items": {
              "example": "[\"08:00\",\"13:00\"]",
              "description": "Represents dynamic weekday times",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "FR": {
            "type": "array",
            "example": [
              [
                "08:00",
                "13:00"
              ]
            ],
            "items": {
              "example": "[\"08:00\",\"13:00\"]",
              "description": "Represents dynamic weekday times",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "SA": {
            "type": "array",
            "example": [
              [
                "08:00",
                "13:00"
              ]
            ],
            "items": {
              "example": "[\"08:00\",\"13:00\"]",
              "description": "Represents dynamic weekday times",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "SO": {
            "type": "array",
            "example": [
              [
                "08:00",
                "13:00"
              ]
            ],
            "items": {
              "example": "[\"08:00\",\"13:00\"]",
              "description": "Represents dynamic weekday times",
              "type": "array",
