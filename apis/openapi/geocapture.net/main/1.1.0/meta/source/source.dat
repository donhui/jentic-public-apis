                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/project/fetch": {
      "get": {
        "tags": [
          "Projects|Project"
        ],
        "summary": "Fetch project list.",
        "description": "This endpoint enables you to obtain a project list, including details such as project address and geo-coordinates.\n\nIn geoCapture, projects are defined as designated sites or locations, including construction sites, company\nbranches, or service areas. These areas are used to complete a variety of tasks and activities. Each project is\ndefined by a unique location, on a map with an address or What3Words address, and has boundaries (either circular\nor polygonal) for accurate GPS tracking. All information captured within these limits, including time worked,\nassigned duties, or machinery operation, is automatically linked to the relevant project, enabling accurate\nsupervision and record-keeping of on-site activities.\n\nA maximum of 500 projects can be fetched at the same time.",
        "operationId": "Projects|Project_fetchAction",
        "parameters": [
          {
            "name": "projects[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters based on the internal project IDs",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "projects[byReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters based on the project numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "projects[byImportKeys][]",
            "in": "query",
            "required": false,
            "description": "Filters based on the external project IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "projects[importSource]",
            "in": "query",
            "required": false,
            "description": "Name of the external data source. (Default is \"*API\")\n\nThis parameter is only required if the external project ID is filtered.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projects[byEmployeeActivities][from]",
            "in": "query",
            "required": false,
            "description": "Start date. This Parameter is optional.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "projects[byEmployeeActivities][to]",
            "in": "query",
            "required": false,
            "description": "End date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "projects[byTrackerWorkActivities][from]",
            "in": "query",
            "required": false,
            "description": "Start date. This Parameter is optional.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "projects[byTrackerWorkActivities][to]",
            "in": "query",
            "required": false,
            "description": "End date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "projects[byProjectCategoryIds][]",
            "in": "query",
            "required": false,
            "description": "Filters projects based on the category ids.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a default value and max set at 500 records. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardProjectFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
