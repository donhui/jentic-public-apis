            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ComponentGeocodingAddressInterface"
                    }
                  ]
                }
              }
            }
          }
        }
      }
