          },
          "byObjectType": {
            "type": "string",
            "description": "Filters the approvals by the type.\n\n| Value                      | Description                                                             |\n| -------------------------- | ----------------------------------------------------------------------- |\n| APPROVAL_EMPLOYEE_WORKTIME | If working times from stamps must be approved. Configured in Department |\n| EMPLOYEE_APPLICATION       | If the employee submits an application: e.g. absence                    |\n| CUSTOM_FORM_DATA           | If custom forms must be approved: Configured in form definition         |"
          },
          "byObjectId": {
            "type": "integer",
            "description": "Filters the approvals by the object. Can be used only in conjunction with the filter \"byObjectType\"."
          }
        }
