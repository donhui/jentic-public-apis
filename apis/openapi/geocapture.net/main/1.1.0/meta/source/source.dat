            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[byFormDefinitionIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the form data based on the form definition IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byExternalReference]",
            "in": "query",
            "required": false,
            "description": "Filters the form data based on the external reference.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[byStatus]",
            "in": "query",
            "required": false,
            "description": "Filters the form data based on the status.\n\n| Value     | Description                  |\n| --------- | ---------------------------- |\n| NEW       | New form data                |\n| FILLED    | Already filled form data     |\n| REVIEW    | Check form data              |\n| APPROVED  | Approved by test distributor |\n| COMPLETED | Completed form data          |\n| RESET     | Resetted form data           |\n| BOOKED    | Booked form data             |",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[byOrderIds][]",
            "in": "query",
