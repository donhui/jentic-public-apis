    "/tracker_counter/fetch": {
      "get": {
        "tags": [
          "Tracking|Counter"
        ],
        "summary": "Fetch counter list.",
        "description": "This method allows you to get counter information from the trackers, such as distance driven or operating hours.\nPlease be aware that the distance travelled as calculated by the GPS signal may differ from the actual mileage\ndisplayed in the vehicle. Be aware that the counter type is not equal to the unit of the `counterValue`. The\ncounter value's unit is provided in the `unitType`. Tracker counters can function as both sensors within the GPS\ntracker and as calculated values from geoCapture for a specific counter.",
        "operationId": "Tracking|Counter_fetchAction",
        "parameters": [
          {
            "name": "trackers[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "trackers[byLicenseNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the license plates.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "trackers[byIdentifiers][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the customer-specific IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "trackers[byIdentificationNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the VINs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "trackers[byImportKeys][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the external vehicle IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "trackers[byProjectChangedAfter]",
            "in": "query",
            "required": false,
            "description": "Filter the vehicles which projectChangedAt is after the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "trackers[importSource]",
            "in": "query",
            "required": false,
            "description": "Name of the external data source. (Default is \"*API\")\n\nThis parameter is only required if the external vehicle ID is filtered.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trackers[byName]",
            "in": "query",
            "required": false,
            "description": "Filter the vehicles on their name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trackers[byDriver]",
            "in": "query",
            "required": false,
            "description": "Filter the vehicles on their driver.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "required": false,
            "description": "Request the counter reading of the respective date.\n\nIf no date is given, the current reading will be requested.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardTrackerCounterFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/event/fetch": {
      "get": {
        "tags": [
          "Tracking|Event"
        ],
        "summary": "Fetch event list.",
        "description": "This method allows the events to be requested with additional filters. It is important to know that Stamp Events\ndo not contain a time stamp object used for time tracking. It is only the event of a triggered time recording\nmodule on a vehicle or a triggered time recording terminal. If you want to use time stamp data, consider using\nthe Employee Stamp endpoint. For timestamp data, it is advised to use the Time Tracking|Employee Stamp endpoint.\nIf you need to request an employee's work time, it is recommended to use the Time Tracking|Employee time tracking\nendpoint. Other events include the ignition, device movement, or stopping tracker.",
        "operationId": "Tracking|Event_fetchAction",
        "parameters": [
          {
            "name": "eventTypes[]",
            "in": "query",
            "required": false,
            "description": "Filter for event type. This paramter is optional.\n\n\n| Value                     | Description                         |\n|--------------------------|--------------------------------------|\n| MOVE                     | Move                                |\n| STOP                     | Stop                                 |\n| STAMP                    | Stamp                           |\n| IGNITION                 | Ignition                              |\n| SENSOR                   | Sensor                              |",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "sensorValueTypeName",
            "in": "query",
            "required": false,
            "description": "Filter for sensor value type name. This paramter is optional.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trackers[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "trackers[byLicenseNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the license plates.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "trackers[byIdentifiers][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the customer-specific IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "trackers[byIdentificationNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the VINs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
