        ],
        "summary": "Delete webhooks.",
        "description": "This endpoint permits the deletion of many webhooks simultaneously with the provision of an array of IDs. You can\nenable the `dryRun` parameter to simulate the execution, without modifying actual data. Note that deleted webhooks\ncannot be restored.",
        "operationId": "Webhook|Webhook_deleteAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
