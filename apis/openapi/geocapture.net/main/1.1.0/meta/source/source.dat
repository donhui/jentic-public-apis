            "description": "The estimated time of arrival (ETA). This value is updated based on the vehicle\u2019s GPS position or after the completion of the previous order.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "navigationStartAt": {
            "description": "The timestamp indicating when navigation to this order location was started.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "realArrivalAt": {
            "description": "The actual arrival time at the order location. Set automatically if the vehicle has a GPS device; otherwise, this field remains empty.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "finishedAt": {
            "description": "The time when the order status was changed to finished.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "estimatedDepartureAt": {
            "description": "The estimated departure time. Updated dynamically if GPS data is available or recalculated after order completion.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "realDepartureAt": {
            "description": "The actual departure time from the order location. Automatically set when the vehicle leaves the site (if GPS data is available).",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "avisSendAt": {
            "description": "The timestamp of the last sent avis (notification message).",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          },
          "avisAt": {
            "description": "The scheduled time included in the avis notification.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          }
        }
