    "/employee/fetch": {
      "get": {
        "tags": [
          "Employees|Employee"
        ],
        "summary": "Fetch employee list.",
        "description": "This endpoint enables you to retrieve a list of employees. Employees may be issued with an RFID or iButton key.\nThe key value is provided in the `iButton` and `iButtonNumber` fields. Additionally, employees may belong to a\ndepartment that determines their time model. Furthermore, essential information such as their name and entry and\nexit date is included in the base data.",
        "operationId": "Employees|Employee_fetchAction",
        "parameters": [
          {
            "name": "employees[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the employee based on the IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "employees[byReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the personal numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[byCardNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the driver card numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[byIbuttonNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the iButton numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "employees[byImportKeys][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the employee import IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[importSource]",
            "in": "query",
            "required": false,
            "description": "Name of the external data source. (Default is \"*API\")\n\nThis parameter is only required if the external employee ID is filtered.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set. This paramter is optional.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
