    "/custom_form_data/mediaData": {
      "get": {
        "tags": [
          "Documents|Form data"
        ],
        "summary": "Request the media file.",
        "description": "This interface enables you to retrieve a file by submitting the formDataId and the desired filename. When\nrequesting the file, it will be provided in response. This function allows users to retrieve files, such as the\nattached images, from a construction report through download.",
        "operationId": "Documents|Form data_fetchMediaData",
        "parameters": [
          {
            "name": "formDataId",
            "in": "query",
            "required": true,
            "description": "The internal id of the form data. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "filename",
            "in": "query",
            "required": true,
            "description": "The filename. This Parameter is required.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ComponentHttpFoundationResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/custom_form_data/status": {
      "get": {
        "tags": [
          "Documents|Form data"
        ],
        "summary": "Set the status of the form data.",
        "description": "This form provides an interface to set the status. The `COMPLETED` status will lock the form for further changes\nand is equivalent to completing the form in geoCapture. `BOOKED` is a status that is exclusively accessible\nthrough the API. When the status is set, an entry will be created in the custom form log with the content:\n\"form booked\". This can help distinguish between custom forms that have been exported and those that have not.",
        "operationId": "Documents|Form data_setStatus",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the form data. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status_text",
            "in": "query",
            "required": true,
            "description": "Status of the form. This Parameter is required.\n\n| Value     |\n| --------- |\n| COMPLETED |\n| BOOKED    |",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardCustomFormDataStatusResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/custom_form_definition/fetch": {
      "get": {
        "tags": [
          "Documents|Form definition"
        ],
        "summary": "Fetch form definition list.",
        "description": "This endpoint enables you to retrieve form definitions. This includes the document name, version, creation date,\nand last update date. Additionally, you can set an offset and a limit. The default limit and maximum limit are\nboth set at 100.",
        "operationId": "Documents|Form definition_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the form definition based on the internal IDs.",
