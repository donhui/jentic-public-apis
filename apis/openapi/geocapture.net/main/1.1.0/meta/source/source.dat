    "/geocoder/reverse_geocode": {
      "get": {
        "tags": [
          "Miscellaneous|Geocoding"
        ],
        "summary": "Search an address.",
        "description": "Reverse geocoding converts geographic coordinates, such as latitude and longitude, into an address format.\nLatitude and longitude coordinates can be inputted into the corresponding parameters, for instance,\n\"52.37652038909364 7.605081948346127\".",
        "operationId": "Miscellaneous|Geocoding_reverseGeocodeAction",
        "parameters": [
          {
            "name": "latLng",
            "in": "query",
            "required": true,
            "description": "The geo coordinate. This Parameter is required.",
            "schema": {
              "type": "string",
              "example": "52.37652038909364 7.605081948346127"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ComponentGeocodingAddressInterface"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/job/fetch_status": {
      "get": {
        "tags": [
          "Miscellaneous|Job"
        ],
        "summary": "Request the status of a job.",
        "description": "This endpoint allows you to retrieve the status of a background job within geoCapture. Jobs are used for\ncalculations or tasks that may last several minutes. When the job status is set to `WAITING`, it will be placed\ninto the queue for execution. When the status is set to `RUNNING` the job is currently being executed. After\nexecution, the status will be set to `SUCCESS` if no errors occurred.\n\nAn example of an endpoint that returns a job id is the import bill of quantities endpoint or the calculate\ntour endpoint. In the `returnValue` field, the job's individual return value is provided.",
        "operationId": "Miscellaneous|Job_fetchStatusAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the job. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardJobFetchStatusResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/order/fetch": {
      "get": {
        "tags": [
          "Orders|Order"
        ],
        "summary": "Fetch order list",
        "description": "geoCapture orders are detailed assignments created within the geoCapture system to manage and coordinate field\noperations such as service visits, maintenance tasks, or deliveries. Each order is a plan that includes important\ndetails like task descriptions, site locations, assigned staff, timelines, and specific activities, which\nensure the accurate execution of field services.\n\nThese orders are crucial in geoCapture's tour planning. Efficient routes are created that optimize the itinerary\nof each field team for travel time, service duration, and client priorities. For instance, a geoCapture order\nmight instruct a team to fit hardware at a new client's office. The order is then used to plot a route for the\nday, integrating other service calls along the way to reduce downtime and travel distance and, therefore, boost\nproductivity whilst decreasing operational expenses. The order ensures that the team brings appropriate equipment\nand knowledge, resulting in a prosperous installation within the allotted timeframe.",
        "operationId": "Orders|Order_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the internal IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byExternalReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the customer order numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[from]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "filter[to]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "filter[byTourIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the tour IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byStatusText]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the status text.\n\n| Value                        |\n| ------------------------     |\n| ARRIVAL                      |\n| ASSIGNED                     |\n| CREATED                      |\n| DEPARTURE                    |\n| FINISHED                     |\n| NEAREST_POSITION             |\n| OPENED_BY_USER               |\n| READ                         |\n| REJECTED                     |\n| SIGNED                       |\n| STARTED                      |",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[byOrderType]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the order type.\n\n| Value                         |\n| ------------------------      |\n| REPEAT                        |\n| ORDER                         |\n| SAVED                         |\n| MACHINE_TRANSPORT             |",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[byBounds]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the given rectangle.",
            "schema": {
              "type": "string",
              "example": "52.37652038909364 7.605081948346127, 52.375099096475545 7.6082684126850175"
            }
          },
          {
            "name": "filter[byUnassigned]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on whether it's assigned to a tour.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "filter[byProjectIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the project IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byTeamIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the team IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardOrderFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/order/fetch_data": {
      "get": {
        "tags": [
          "Orders|Order"
        ],
        "summary": "Request order details.",
        "description": "This endpoint enables the retrieval of comprehensive order information by supplying the internal `id`. This\ninformation includes `performanceFields`, `orderLog`, `tourInfo` and `orderQualification`. Within geoCapture,\nperformance fields denote particular metrics or parameters used for defining and quantifying the output or\nefficiency of tasks and services within the platform. The order log provides details of status changes within the\norder. The `tourInfo` references the tour in which the order is scheduled. The `orderQualification` refers to the\nspecific skills and abilities required for employees or teams to effectively complete assigned tasks or projects,\nensuring that the right expertise is matched to each job requirement. The opening hours in the `orderDetails`\nfield consist of the day of the week as the key and the corresponding start and end times expressed as a string.",
        "operationId": "Orders|Order_fetchDataAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the order. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_log",
            "in": "query",
            "required": false,
            "description": "Show the order log. This Parameter is optional.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "order_qualification",
            "in": "query",
            "required": false,
            "description": "Show the order qualification. This Parameter is optional.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "tour_info",
            "in": "query",
            "required": false,
            "description": "Show the tour info. This Parameter is optional.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardOrderFetchDataResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/order/fetch_delivery_status": {
      "get": {
        "tags": [
          "Orders|Order"
        ],
        "summary": "Request order delivery status.",
        "description": "Retrieves detailed delivery status information for an orders.\nThe request can be filtered by internal order ID, external reference, or delivery address (optionally within a specified radius).\nThe response includes the order ID, the current delivery status text, and the estimated delivery time window.",
        "operationId": "Orders|Order_fetchDeliveryStatus",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": false,
            "description": "Internal unique ID of the order.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "reference",
            "in": "query",
            "required": false,
            "description": "The order reference.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "description": "Address associated with the order. Can be combined with radius to search nearby orders.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "description": "Search radius (in meters) around the specified address. Used only when address is provided. Default: 50.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "dispoTypeId",
            "in": "query",
            "required": false,
            "description": "Internal id of the dispo type used to further narrow down orders when searching by address. Only applies if address is specified.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "dispoTypeName",
            "in": "query",
            "required": false,
            "description": "Name of the dispo type used to further narrow down orders when searching by address. Only applies if address is specified.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "daysBefore",
            "in": "query",
            "required": false,
            "description": "Include orders created or scheduled up to this number of days before today. Default: 0.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "daysAfter",
            "in": "query",
            "required": false,
            "description": "Include orders created or scheduled up to this number of days after today. Default: 0.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "required": false,
            "description": "Language code for the response text. Default: de.\n\n| Value | Language |\n| ----- | -------- |\n| de    | German   |\n| en    | English  |\n| es    | Spanish  |\n| fr    | French   |\n| it    | Italian  |\n| nl    | Dutch    |\n| pl    | Polish   |\n| ro    | Romanian |\n| ru    | Russian  |",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardOrderFetchDeliveryStatusResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/order/delete": {
      "get": {
        "tags": [
          "Orders|Order"
        ],
        "summary": "Delete order.",
        "description": "This endpoint can be used to delete specific orders by providing an array of `id`s. If `dryRun` is enabled, the\nlive system will not undergo any changes, as the request will only be simulated. Note that once an order has been\ndeleted it cannot be restored. If you want to delete multiple orders at once, it will be beneficial to use an\narray of ids as this will improve performance and save resources.",
        "operationId": "Orders|Order_deleteAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
