      "MaintenanceUpsertRequestRecordData": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal id of the maintenance."
          },
          "description": {
            "type": "string",
            "description": "The name of the maintenance. (max. 255 characters)"
          },
          "note": {
            "type": "string",
            "description": "The description of the maintenance."
          },
          "maintenanceTypeId": {
            "type": "integer",
            "description": "The internal id of the maintenance type."
          },
          "trackerId": {
            "type": "integer",
            "description": "The internal of the vehicle for the maintenance. Only one of trackerId or toolId can be used."
          },
          "toolId": {
            "type": "integer",
            "description": "The internal id of the tool for the maintenance. Only one of trackerId or toolId can be used."
          },
          "active": {
            "type": "boolean",
            "description": "Wheather the maintenance shall be active or not."
          },
          "schedulerDefinition": {
            "description": "The scheduler.",
            "type": "object",
            "$ref": "#/components/schemas/MaintenanceUpsertRequestSchedulerDefinition"
          }
        }
      },
      "MaintenanceUpsertRequestSchedulerDefinition": {
        "type": "object",
        "description": "",
        "properties": {
          "type": {
            "type": "string",
            "description": "The scheduler type.\n\n| Values               | Desctiption                                               |\n| -------------------- | --------------------------------------------------------- |\n| performanceInterval  | Schedules the maintenances based on performance intervals |\n| performanceTotal     | Schedules the maintenances based on total performance     |\n| dateScheduler        | Schedules the maintenances based on a timed scheduler     |\n| date                 | Schedules the maintenances on a fixed date                |"
          },
          "performanceType": {
            "type": "string",
            "description": "The performance type. (Used for types performanceInterval or performanteTotal)\n\n| Values   | Desctiption                    |\n| -------- | ------------------------------ |\n| time     | Performance on operating hours |\n| distance | Performance on driven distance in kilometers |"
          },
          "performanceValue": {
            "type": "integer",
            "description": "The performance value according to the performance type. (Used for types performanceInterval or performanteTotal)"
          },
          "maxHits": {
            "type": "integer",
            "description": "The amount of repeats for the maintenance (default NULL) (NULL = no limit). (Used for types performanceInterval, performanteTotal or dateScheduler)"
          },
          "maxDaysAfterLastMaintenance": {
            "type": "integer",
            "description": "The max amount of days after the last maintenance when the next one shall be scheduled.\n(Used for types performanceInterval or performanteTotal)"
          },
          "lastMaintenanceValue": {
            "type": "integer",
            "description": "The performance value according to the performance type from the last maintenance. (Used for types performanceInterval or performanteTotal)"
          },
          "lastMaintenanceDate": {
            "description": "The date when the last maintenance took place. This value is required. (Default today)",
            "type": "object",
            "$ref": "#/components/schemas/Date"
          },
          "nextMaintenanceDate": {
            "description": "The date for the next maintenance. (Only used for type date)",
            "type": "object",
            "$ref": "#/components/schemas/Date"
          },
          "dateSchedulerDefinition": {
            "description": "The definition for type dateScheduler.",
            "type": "object",
            "$ref": "#/components/schemas/OrderCreateRepeatRequestSchedulerDefinition"
          }
        }
      },
      "OrderCreateRepeatRequestSchedulerDefinition": {
        "type": "object",
        "description": "",
        "properties": {
          "type": {
            "type": "string",
            "description": "The scheduler type (See the examples for every type above).\n\n| Values             | Description                                                                           |\n| ------------------ | ------------------------------------------------------------------------------------- |\n| daily              | Every 'd' days                                                                        |\n| dailyEveryWorkday  | Every workday                                                                         |\n| weekly             | Every 'w' weeks on weekdays 'wd'                                                      |\n| monthlyNthDay      | Every 'm' months on the 'dm' day of the month                                         |\n| monthlyNthWeekday  | Every 'm' months on the 'o' occurrence of the day of the week 'wd'                    |\n| yearlyNthDay       | Every 'y' years on the specified date 'dm'.'my'                                       |\n| yearlyNthWeekday   | Every 'y' years on the 'o' occurrence of the day of the week 'wd' in the month 'my'   |"
          },
          "intervalDays": {
            "type": "integer",
            "description": "Every x days. (d)"
          },
          "weekdays": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Only on following weekdays: 1 = Monday, 7 = Sunday. (wd)"
          },
          "intervalWeeks": {
            "type": "integer",
            "description": "Every x weeks. (w)"
          },
          "day": {
            "type": "integer",
            "description": "Day of month. (dm)"
          },
          "intervalMonths": {
            "type": "integer",
            "description": "Every x months. (m)"
          },
          "occurrence": {
            "type": "integer",
            "description": "Every x specified weekday: 1 = first, 4 = fourth, 5 = last. (o)"
          },
          "month": {
            "type": "integer",
            "description": "Month of the year: 1 = January, 12 = December. (my)"
          },
          "intervalYears": {
            "type": "integer",
            "description": "Every x years. (y)"
          }
        }
      },
