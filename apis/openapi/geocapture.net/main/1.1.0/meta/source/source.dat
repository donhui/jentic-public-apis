              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byText]",
            "in": "query",
            "required": false,
            "description": "Filters the form definition based on the text passed.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[byExternalReference]",
            "in": "query",
            "required": false,
            "description": "Filters the form definition based on the external reference.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
