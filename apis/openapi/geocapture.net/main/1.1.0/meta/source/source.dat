    "/custom_form_data/fetch_data": {
      "get": {
        "tags": [
          "Documents|Form data"
        ],
        "summary": "Request detailed form data.",
        "description": "This endpoint enables you to procure detailed information about a custom form by providing the ID.  At the data\nkey, you will receive the values of the various fields from the form. The data will be available in the\ndesignated section of the custom form. Please note that any redundant data will be removed in accordance with\nestablished retention policies. The field name shall serve as the key in the JSON Object, receiving the\ncorresponding data. The form definition can only be altered in geoCapture, not via API.",
        "operationId": "Documents|Form data_fetchDataAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the form data. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "log_access",
            "in": "query",
            "required": false,
            "description": "Log the access in the changelog.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardCustomFormDataFetchDataResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/custom_form_data/pdf": {
      "get": {
        "tags": [
          "Documents|Form data"
        ],
        "summary": "Request a custom form PDF.",
        "description": "This endpoint enables you to obtain a PDF created by providing the `id` of the custom form. You can\ndecide whether this access should be recorded in the log of the form. When making a request to the\nendpoint, you will receive the custom form as a rendered PDF document in response.",
        "operationId": "Documents|Form data_pdfAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal ID of the form data. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "log_access",
            "in": "query",
            "required": false,
