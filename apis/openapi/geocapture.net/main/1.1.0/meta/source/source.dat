          },
          {
            "name": "filter[byExternalReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the customer order numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[from]",
            "in": "query",
            "required": false,
            "description": "Filters the order based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
