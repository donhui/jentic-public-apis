              "allOf": [
                {
                  "$ref": "#/components/schemas/ApprovalCenterFetchResponseApprovalLogItem"
                },
                {
                  "description": ""
                }
              ]
            }
          },
          "offset": {
            "type": "integer",
            "description": "Number of skipped records."
          },
          "totalCount": {
            "type": "integer",
            "description": "Total number of available approvals.\n(Calculated only if the offset is 0)"
          }
        }
      },
      "ApprovalCenterFetchResponseApprovalLogItem": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal ID."
          },
          "assignee": {
            "description": "The assigneed employee.",
            "type": "object",
            "$ref": "#/components/schemas/ApprovalCenterFetchResponseEmployeeItem"
          },
          "employee": {
            "description": "The employee.",
            "type": "object",
            "$ref": "#/components/schemas/ApprovalCenterFetchResponseEmployeeItem"
          },
          "date": {
            "description": "Date of the approval.",
            "type": "object",
            "$ref": "#/components/schemas/Date"
          },
          "objectType": {
            "type": "string",
            "description": "The type of the approval.\n\n| Value                      | Description                                         |\n|----------------------------|-----------------------------------------------------|\n| APPROVAL_EMPLOYEE_WORKTIME | The approval is for verifying work time.            |\n| EMPLOYEE_APPLICATION       | The approval is an application of an employee.      |\n| CUSTOM_FORM_DATA           | The approval is for verifying a form.               |"
          },
          "objectId": {
            "type": "integer",
            "description": "The internal ID of the object to be approved."
          },
          "status": {
            "type": "string",
            "description": "The current status of the approval.\n\n| Value                     | Description                                                                                             |\n|---------------------------|---------------------------------------------------------------------------------------------------------|\n| PENDING                   | The approval is not yet in place and cannot be processed until the previous application is approved.    |\n| OPEN                      | The approval is open and unprocessed.                                                                   |\n| DONE                      | The approval has been approved.                                                                         |\n| DONE_BY_RELATION          | The approval was approved by a dependency.                                                                |\n| REJECTED                  | The approval was rejected. (Only possible for applications)                                             |\n| WITHDRAWN                 | The request for the approval was withdrawn. (Only possible for applications).                           |\n| CONSULTATION_REQUIRED     | The request for the approval requires consultation. (Only possible for applications)                    |\n| PROVISIONALLY_ACCEPTED    | The application for the approval has been provisionally approved. (Only possible for applications)      |"
          },
          "notes": {
            "description": "The notes of the approval.",
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/ApprovalCenterFetchResponseApprovalLogNoteItem"
                },
                {
                  "description": ""
                }
              ]
            }
          },
          "worktimeData": {
            "description": "The data for the work time approval. Filled only for the type APPROVAL_EMPLOYEE_WORKTIME.",
            "type": "object",
            "$ref": "#/components/schemas/ApprovalCenterFetchResponseWorktimeDataItem"
          },
          "applicationData": {
            "description": "The data for the approval of applications. Filled only for the type EMPLOYEE_APPLICATION.",
            "type": "object",
            "$ref": "#/components/schemas/ApprovalCenterFetchResponseApplicationDataItem"
          },
          "formData": {
            "description": "The data for the approval of forms. Filled only for the type EMPLOYEE_APPLICATION.",
            "type": "object",
            "$ref": "#/components/schemas/ApprovalCenterFetchResponseFormDataItem"
          },
          "createdAt": {
            "description": "Creation date of the approval.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          }
        }
      },
