              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardApprovalCenterUpdateStatusRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/approval_center/create": {
      "post": {
        "tags": [
          "Miscellaneous|Approval"
        ],
        "summary": "Create a new approval.",
        "description": "This endpoint allows you to create a new approval. You can create a new approval for an employee with\n`absenceData`, `stampData` or `accountingData`. If you provide stampData, an application for a new stamp will be\ncreated. If you provide `absenceData`, an approval for an absence will be created. This can be used to create a\nvacation application for an employee. If you provide accountingData, an application for bookings will be created.\nFor example, 'accountingData' could be an allowance with a corresponding wage type, such as set-up time.",
        "operationId": "Miscellaneous|Approval_createAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardApprovalCenterCreateResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardApprovalCenterCreateRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
