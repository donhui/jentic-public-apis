    "/geocoder/geocode": {
      "get": {
        "tags": [
          "Miscellaneous|Geocoding"
        ],
        "summary": "Geocode address.",
        "description": "Geocode an address to obtain its geographic coordinates, including the latitude and longitude. Additionally, a\nformatted address will be provided alongside the latitude and longitude. You may input an unformatted address in\nthe `address` parameter, for instance, \"Rheiner Str. 3, 48496 Hopsten\".",
        "operationId": "Miscellaneous|Geocoding_geocodeAction",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "The address. This Parameter is required.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
