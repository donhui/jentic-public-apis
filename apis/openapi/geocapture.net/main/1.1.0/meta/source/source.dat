        }
      }
    },
    "/beacon/fetch": {
      "get": {
        "tags": [
          "Tracking|Beacon"
        ],
        "summary": "Fetch beacon list",
        "description": "This endpoint retrieves a list of beacons with detailed information, including the current latitude and\nlongitude. Beacons are little devices that send a bluetooth signal. This bluetooth signal can be received by GPS\ntrackers or the geoCapture mobile application. If this occurs, the beacon's position will be updated to the\nposition of the tracker. Usually, beacons in geoCapture are affixed to tools or small machines.",
        "operationId": "Tracking|Beacon_fetchAction",
        "parameters": [
          {
            "name": "beacons[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the beacons based on the IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "beacons[byUuids][]",
            "in": "query",
            "required": false,
            "description": "Filters the beacons based on the UUIDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "beacons[byToolIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the beacons based on the tool IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Number of records to skip. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardBeaconFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/beacon/update": {
      "post": {
        "tags": [
          "Tracking|Beacon"
        ],
        "summary": "Update beacon.",
        "description": "This function can be utilized to modify beacons. It is not possible to update the position of beacons through the\nAPI to ensure precise data within geoCapture. In addition, the creation or deletion of beacons is not possible.\n\nAn identified beacon is updated according to the chosen primary key type and the supplied primary key. It is\nimportant to note that creating a new beacon is not possible through this action. You can update the serial\nnumber of the item to which the beacon is attached, along with the `objectIdentifier`.",
        "operationId": "Tracking|Beacon_updateAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardBeaconUpdateResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardBeaconUpdateRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/beacon_map/view": {
      "get": {
        "tags": [
          "Tracking|Beacon Map Embedding"
        ],
        "summary": "Display Beacon map.",
        "description": "Returns an HTML page with an interactive map. It is possible to embed this map in your application using an\niFrame. You need to specify the beacons you wish to view on the map by using either the `beacons[byIds][]` or\n`beacons[byUuids][]` filters.",
        "operationId": "Tracking|Beacon Map Embedding_viewAction",
        "parameters": [
          {
            "name": "controls",
            "in": "query",
            "required": false,
            "description": "Select whether the controls are displayed. This Parameter is optional.",
