            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the VINs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "trackers[byImportKeys][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the external vehicle IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "trackers[byProjectChangedAfter]",
            "in": "query",
            "required": false,
            "description": "Filter the vehicles which projectChangedAt is after the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "trackers[importSource]",
            "in": "query",
            "required": false,
            "description": "Name of the external data source. (Default is \"*API\")\n\nThis parameter is only required if the external vehicle ID is filtered.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trackers[byName]",
            "in": "query",
            "required": false,
            "description": "Filter the vehicles on their name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "trackers[byDriver]",
