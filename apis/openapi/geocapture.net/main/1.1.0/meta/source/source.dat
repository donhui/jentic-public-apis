      "BeaconFetchResponseBeaconItem": {
        "type": "object",
        "description": "",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The internal ID."
          },
          "uuid": {
            "type": "string",
            "description": "The beacon UUID as hexadecimal value."
          },
          "macAddress": {
            "type": "string",
            "description": "The beacon MAC address."
          },
          "name": {
            "type": "string",
            "description": "The name of the beacon. (max. 255 characters)"
          },
          "objectIdentifier": {
            "type": "string",
            "description": "External, customer specific ID of the object the beacon is attached to. (max. 64 characters)"
          },
          "objectSerialNumber": {
            "type": "string",
            "description": "Serial number of object, the beacon is attached to. (max. 128 characters)"
          },
          "protocol": {
            "type": "string",
            "description": "Thee beacon protocol."
          },
          "serialNumber": {
            "type": "string",
            "description": "The serial number of the beacon."
          },
          "batteryPercentage": {
            "type": "integer",
            "description": "The beacon's battery charge in percent."
          },
          "status": {
            "type": "string",
            "description": "The current status of the beacon.\n\n| Value                | Description         |\n|---------------------|---------------------|\n| DEACTIVATED         | The beacon is deactivated.                                                      |\n| LOST                | The Beacon is reported lost.           |\n| FOUND               | The Beacon was reported lost but has now been found.        |\n| DRIVING             | The beacon is transported in a vehicle.                                 |\n| HALT                | The beacon is not connected to any project or gateway                                   |\n| HALT_AT_GATEWAY     | The beacon is at a gateway. The gateway is the currentTracker.              |\n| HALT_AT_PROJECT     | The Beacon is at a project.                                              |"
          },
          "currentLoss": {
            "description": "The current loss of the Beacon.",
            "type": "object",
            "$ref": "#/components/schemas/BeaconFetchResponseBeaconLossItem"
          },
          "currentProject": {
            "description": "The current project.",
            "type": "object",
            "$ref": "#/components/schemas/BeaconFetchResponseProjectItem"
          },
          "multipleProjectsPossible": {
            "type": "boolean",
            "description": "Indicates if multiple current projects were possible."
          },
          "currentTracker": {
            "description": "The current vehicle/gateway of the beacon.",
            "type": "object",
            "$ref": "#/components/schemas/BeaconFetchResponseTrackerItem"
          },
          "latLng": {
            "description": "The current position of the beacon.",
            "type": "object",
            "$ref": "#/components/schemas/ComponentGeocodingLatLngInterface"
          },
          "estimatedLatLng": {
            "description": "The estimated position of the beacon.",
            "type": "object",
            "$ref": "#/components/schemas/ComponentGeocodingLatLngInterface"
          },
          "estimatedTracker": {
            "description": "The vehicle from which the estimated position of the beacon originates.",
