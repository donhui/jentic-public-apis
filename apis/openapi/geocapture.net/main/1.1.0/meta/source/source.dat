    "/map/fetch": {
      "get": {
        "tags": [
          "Tracking|Vehicle Map Embedding"
        ],
        "summary": "Request map information.",
        "description": "This endpoint enables you to retrieve the present and previous locations of trackers. It will provide the data\nutilized by the embedded map. The autoRefresh duration is a parameter utilized for the map view. It is\nnot significant for your application. It's not recommended to regularly fetch the current position, both\nto save resources and avoid hitting API rate limits.",
        "operationId": "Tracking|Vehicle Map Embedding_fetchAction",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Show the trackpoints from this moment on. This Parameter is optional.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "Show the trackpoints till this moment. This Parameter is optional.",
