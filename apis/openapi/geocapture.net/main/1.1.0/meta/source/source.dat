              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "date",
            "in": "query",
            "required": false,
            "description": "Show the trackpoints from this date. This Parameter is optional.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "trackers[byIds][]",
            "in": "query",
