        ],
        "summary": "Fetch project time list.",
        "description": "This method can be used to request the operating hours and working hours for a project.\n\nIn geoCapture, project times record the working hours and activities linked with specific projects. The records\ncontain information such as the start and end times of activities, their duration, and the employees or equipment\n(trackers) that were utilized. This functionality assures precise tracking of labour and resource utilization on\nprojects, facilitating efficient management and billing. All times are in seconds.",
        "operationId": "Projects|Project time_fetchAction",
        "parameters": [
          {
            "name": "projectReference",
            "in": "query",
            "required": false,
            "description": "The project number. Either this parameter or projectImportKey is required.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projectImportKey",
            "in": "query",
            "required": false,
            "description": "The project import key. Either this parameter or projectReference is required.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": true,
            "description": "Start date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "description": "End date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardProjectTimesFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/route/calculate": {
      "get": {
        "tags": [
          "Routing | Route"
        ],
        "summary": "Calculate route between two points.",
        "description": "Calculates the optimal route distance in meters and driving time in seconds between a start and end coordinate.",
        "operationId": "Routing | Route_calculateAction",
        "parameters": [
          {
            "name": "startLatLng",
            "in": "query",
            "required": true,
            "description": "The geo-coordinates of the starting point of the route.",
            "schema": {
              "type": "string",
              "example": "52.37652038909364 7.605081948346127"
            }
          },
          {
            "name": "endLatLng",
            "in": "query",
            "required": true,
            "description": "The geo-coordinates of the end point of the route.",
            "schema": {
              "type": "string",
              "example": "52.37652038909364 7.605081948346127"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardRoutingRouteResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/employee_absence/fetch": {
      "get": {
        "tags": [
          "Time Tracking|Absence"
        ],
        "summary": "Request absences.",
        "description": "This method allows you to fetch a structured list of data that includes various\nabsence records, such as absence dates, types, employee details, and other identifiers.\n\nAbsences within geoCapture are utilized across several aspects of the application, such as resource management.\nAn absence may be for a full day, half day or a specific duration. An absence always has a specific reason, such\nas vacation, illness, or school. Absence categories can be added or modified in geoCapture. Please be aware that\nabsences have the potential to impact the time account of employees.",
        "operationId": "Time Tracking|Absence_fetchAction",
        "parameters": [
          {
            "name": "filter[byEmployeeReference][]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the employee personal number.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[from]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[to]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[byAbsenceTypeId][]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based in the absence types",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byDepartmentIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the given departments",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[updatedFrom]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[updatedTo]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardEmployeeAbsenceFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/employee_absence/delete": {
      "get": {
        "tags": [
          "Time Tracking|Absence"
        ],
        "summary": "Delete absences.",
        "description": "This endpoint enables the deletion of absences based on various filters. Please note that each absence day is a\nunique instance with a distinct ID. In case the `dryRun` flag is enabled, the response will be simulated, and no\nlive data will be altered. Please be aware that absences have the potential to impact the time account of\nemployees.",
        "operationId": "Time Tracking|Absence_deleteAction",
        "parameters": [
          {
            "name": "filter[byEmployeeReference][]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the employee personal number.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[from]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[to]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[byAbsenceTypeId][]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based in the absence types",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byId][]",
            "in": "query",
            "required": false,
            "description": "Filters the absences based on the internal id.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "dryRun",
            "in": "query",
            "required": false,
            "description": "Simulate the operation (default: false).\n(No data will be removed) This Parameter is optional.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
