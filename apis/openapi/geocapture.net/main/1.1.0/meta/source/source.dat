    "/beacon_map/fetch": {
      "get": {
        "tags": [
          "Tracking|Beacon Map Embedding"
        ],
        "summary": "Fetch map information list.",
        "description": "This endpoint enables you to retrieve the present and previous locations of beacons. It will provide the data\nutilized by the embedded map. The autoRefresh duration is a parameter utilized for the map view. It is not\nsignificant for your application. It's not recommended to regularly fetch the current position, both to safe\nresources and avoid hitting API rate limits.",
        "operationId": "Tracking|Beacon Map Embedding_fetchAction",
