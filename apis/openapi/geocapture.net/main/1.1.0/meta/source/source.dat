          "toolCategoryId": {
            "type": "integer",
            "description": "The internal id of the tool category if the setting is meant to be for a tool category."
          },
          "from": {
            "description": "The first date the tool cost setting is valid.",
            "type": "object",
            "$ref": "#/components/schemas/Date"
          },
          "costTypeSource": {
            "type": "string",
            "description": "The source for the cost type.\n\n| Value | Description |\n|------|-------------|\n| TOOL | cost type is defined at this entry |\n| TOOL_CATEGORY | cost type is defined at the tool category |\n\nThe value \"TOOL_CATEGORY\" can only be set if a toolId is given. This will link the settings cost type to the one\nof the tools category.\nIf a toolId is given the value can also be set to \"TOOL\". This will set the cost type for\nthis specific tool. In that case a costTypeId/costTypeReference also has to be given.\nFor a tool category this value is obsolete."
          },
          "costTypeId": {
            "type": "integer",
            "description": "The internal cost type id for this setting.\nValue is needed for settings if a toolCategoryId is given or the costTypeSource is set to \"TOOL\".\nEither costTypeId or costTypeReference can be supplied."
          },
          "costTypeReference": {
            "type": "integer",
            "description": "The cost type reference for this setting.\nValue is needed for settings if a toolCategoryId is given or the costTypeSource is set to \"TOOL\".\nEither costTypeId or costTypeReference can be supplied."
          },
          "dailyRateSource": {
            "type": "string",
            "description": "The source for the daily rate.\n\n| Value | Description |\n|------|-------------|\n| TOOL | daily rate is defined at this entry |\n| TOOL_CATEGORY | daily rate is defined at the tool category |\n\nThe value \"TOOL_CATEGORY\" can only be set if a toolId is given. This will link the settings daily rate to the one\nof the tools category.\nIf a toolId is given the value can also be set to \"TOOL\". This will set the daily rate for\nthis specific tool. In that case a daily rate also has to be given.\nFor a tool category this value is obsolete."
          },
          "dailyRate": {
            "type": "number",
            "description": "The daily rate for this setting.\nValue is can be set for settings if a toolCategoryId is given or the dailyRateSource is set to \"TOOL\"."
          },
          "hourlyRate": {
            "type": "number",
            "description": "The hourly rate for this setting.\nValue is can be set for settings if a toolCategoryId is given or the dailyRateSource is set to \"TOOL\".\n\nThis value is only used for form data bookings."
          },
          "fallbackProjectId": {
            "type": "integer",
            "description": "This project will be used for cost bookings that have no assigned project."
          },
          "automaticBooking": {
            "type": "boolean",
            "description": "This value indicates whether this setting should be used to create automatic bookings.\nCan be set to false if this setting is supposed to be used for form data bookings."
          }
        }
      },
