    "/order/upsert": {
      "post": {
        "tags": [
          "Orders|Order"
        ],
        "summary": "Create/Update orders.",
        "description": "This method can be used to create and update orders.\n\nAn attempt is made to find an existing order based on the selected primary key and value of the key provided.\nIf one is found, it will be adjusted. Otherwise, a new order is created. If you want, you can remove missing\nentries from the upsert request by setting the 'deleteMissing' flag to true.",
        "operationId": "Orders|Order_upsertAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardOrderUpsertResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardOrderUpsertRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/order/create_transport": {
      "post": {
        "tags": [
          "Orders|Order"
        ],
        "summary": "Create transport order.",
        "description": "This endpoint allows you to create a transport order. In addition to an order object you need to provide a\n`pickupLocation` and a `deliveryLocation`. The locations can be an existing project, referred by an id, or a\n`customProject` provided in this request.\n\nIn the geoCapture system, transport orders are specific types of orders focused on the movement of maschines from\none location to another. Unlike regular orders which might encompass a wide range of tasks like installations,\nmaintenance, or inspections, transport orders are specifically tailored for logistics services.\n\nFor example, a transport order in geoCapture could involve delivering an excavator from the depot to the\nconstruction site.",
        "operationId": "Orders|Order_createTransportAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardOrderCreateTransportResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardOrderCreateTransportRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/order/create_repeat": {
      "post": {
        "tags": [
          "Orders|Order"
        ],
        "summary": "Create repeat order.",
        "description": "This endpoint allows you to create a repeating order. To create a repeating order you need to provide an order\nobject and scheduling information. The created order will be repeated according to the scheduling configuration\nprovided.\n\nRecurring orders in geoCapture are tasks scheduled to happen at regular intervals, like weekly, monthly, or\nannually. They are designed for repetitive tasks that need to be done routinely, such as regular maintenance\nchecks or recurring deliveries. To illustrate, a recurring order could be set up for weekly landscape maintenance\nat a specific location, meaning that the task is automatically scheduled at the designated frequency without\nneeding to create a new order every time. This function streamlines ongoing task management, boosting efficiency\nand maintaining consistency in operations.",
        "operationId": "Orders|Order_createRepeatAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardOrderCreateRepeatResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardOrderCreateRepeatRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/order_category/fetch": {
      "get": {
        "tags": [
          "Orders|Order category"
        ],
        "summary": "Fetch order category list",
        "description": "In geoCapture, order categories classify various types of orders into separate groups according to their nature\nor purpose. This helps to efficiently manage various tasks, including deliveries, maintenance, installations,\nand inspections. By grouping all maintenance-related tasks together under one category, resources can be\nallocated more easily, and work can be scheduled more efficiently. This functionality optimizes the workflow by\nenabling users to swiftly discern and handle orders based on their corresponding categories. Additionally, orders\nbelonging to a specific category may inherit certain aspects, including desired or undesired qualifications.",
        "operationId": "Orders|Order category_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the order category based on the internal IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[from]",
            "in": "query",
            "required": false,
            "description": "Filters the order category  based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "filter[to]",
            "in": "query",
            "required": false,
            "description": "Filters the order category based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "filter[byName]",
            "in": "query",
            "required": false,
            "description": "Filters the order category based on the name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardOrderCategoryFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/order_importer/import_file": {
      "post": {
        "tags": [
          "Orders|Order importer"
        ],
        "summary": "Import a file with the order importer.",
        "description": "This method allows you to upload a base64 encoded file. You need to provide the `filename` including the filetype\nand the file as base64 encoded string as `data`.\n\nThe order importer in geoCapture is a feature that facilitates the efficient import of orders into the system.\nThis tool has been optimized to facilitate the addition of multiple orders, including service requests and\ndelivery tasks. This is achieved by its capability to import from a range of file formats such as PDFs, CSVs,\nExcel and .eml, thus reducing administrative tasks and promoting efficiency. This eliminates the need for manual\nentry, resulting in significant time and effort savings and improved data accuracy. For instance, a business can\nutilize the order importer to rapidly upload a week's worth of delivery orders, seamlessly integrating them into\nthe geoCapture system for instant processing and scheduling. The orders will be imported using the regulations\nspecified in an order importer definition that These rules can be adjusted within the geoCapture application. As\na response, you will receive a `jobId`. The job status can be requested at the Miscellaneous|Job endpoint.",
        "operationId": "Orders|Order importer_importFileAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardOrderImporterImportFileResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardOrderImporterImportFileRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/bill_of_quantities/fetch": {
      "get": {
        "tags": [
          "Projects|Bill of quantities"
        ],
        "summary": "Fetch bill of quantities list.",
        "description": "This endpoint enables you to retrieve a list of bills of quantities, with optional filters available, as well as\nan offset and limit parameter.\nIn the context of geoCapture, a bill of quantities is a document commonly utilized in the construction industry\nand service sectors to provide a comprehensive description of all the work needed for a specific project. The\ndocument specifies each task and material, with their respective specifications and quantities. When coordinating\na project, it is essential to provide a clear and detailed overview of all tasks, materials and quantities\nrequired. A bill of quantities acts as a comprehensive outline, similar to a shopping list that specifies the\nexact amount of each item needed. All measurements are in metric units such as metres, square metres, cubic\nmetres, kilograms or litres. In geoCapture, one can customize units to fit specific needs.\n\nFor example, if you are managing the development of a garden area around a corporate building, your bill of\nquantities might include:<br>\nTopsoil (45 cubic meters)<br>\nGrass sod (186 square meters)<br>\nMaple trees (10 trees, approximately 4.5 meters tall)<br>\nLabor for installation (40 man-hours)<br>\nWatering and maintenance services for the initial 30 days",
        "operationId": "Projects|Bill of quantities_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the bills of quantities based on the internal IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byImportKeys][]",
            "in": "query",
            "required": false,
            "description": "Filters the bills of quantities based on the import keys.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[byExternalIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the bills of quantities based on the externalIds.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[from]",
            "in": "query",
            "required": false,
            "description": "Filters the bill of quantities based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[to]",
            "in": "query",
            "required": false,
            "description": "Filters the bill of quantities based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardBillOfQuantitiesFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
