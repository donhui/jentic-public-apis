            }
          },
          {
            "name": "zoom",
            "in": "query",
            "required": false,
            "description": "Set zoom level. This Parameter is optional. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "logo",
            "in": "query",
            "required": false,
            "description": "Display the logo.\n\n| Value            | Description         |\n|-----------------|---------------------|\n| GEOCAPTURE      | geoCapture-Logo     |\n| CUSTOMER        | Customer-Logo       |",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "beacons[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the beacons based on the IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "beacons[byUuids][]",
            "in": "query",
            "required": false,
            "description": "Filters the beacons based on the UUIDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "beacons[byToolIds][]",
            "in": "query",
            "required": false,
