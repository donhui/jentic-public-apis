  "paths": {
    "/container/fetch": {
      "get": {
        "tags": [
          "Containers|Container"
        ],
        "summary": "Fetch container list.",
        "description": "This endpoint enables you to retrieve a list of containers that are under geoCapture's management.",
        "operationId": "Containers|Container_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the containers based on the internal IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters the containers based on the references.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a default value and max set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardContainerFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/container_inquiry/fetch": {
      "get": {
        "tags": [
          "Containers|Container inquiry"
        ],
        "summary": "Fetch container inquiry list.",
        "description": "This endpoint enables you to retrieve a list of container inquirys.",
        "operationId": "Containers|Container inquiry_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the container inquirys based on the internal IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byContainerIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the container inquirys based on the container ids.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byContainerReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters the container inquirys based on the container references.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[byContainerTypeIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the container inquirys based on the container type IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a default value and max set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardContainerInquiryFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/container_inquiry/upsert": {
      "post": {
        "tags": [
          "Containers|Container inquiry"
        ],
        "summary": "Create/Update container inquirys.",
        "description": "This method can be used to create and update container inquirys.\n\nAn effort is made to locate an existing container inquiry using the selected primary key. If found, it will be modified,\nwhereas if no container inquiry is found, a new one is created. If the `deleteMissing` flag is set to true, all container inquirys absent\nfrom the request shall be purged. Please note that removed container inquirys may not be reinstated. You can enable the\n`dryRun` setting to simulate the action without altering any live data.",
        "operationId": "Containers|Container inquiry_upsertAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardContainerInquiryUpsertResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardContainerInquiryUpsertRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/container_type/fetch": {
      "get": {
        "tags": [
          "Containers|Container type"
        ],
        "summary": "Fetch container type list.",
        "description": "This endpoint enables you to retrieve a list of container types that are under geoCapture's management.",
        "operationId": "Containers|Container type_fetchAction",
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a default value and max set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardContainerTypeFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/cost_booking/fetch": {
      "get": {
        "tags": [
          "Cost control|Cost Booking"
        ],
        "summary": "Fetch a list of previous cost exports.",
        "description": "",
        "operationId": "Cost control|Cost Booking_fetchAction",
        "parameters": [
          {
            "name": "filter[fromDate]",
            "in": "query",
            "required": false,
            "description": "Filters the cost exports based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[toDate]",
            "in": "query",
            "required": false,
            "description": "Filters the cost exports based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardCostBookingFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/cost_booking/createExport": {
      "post": {
        "tags": [
          "Cost control|Cost Booking"
        ],
        "summary": "Create an export for cost bookings.",
        "description": "This endpoint allows you to create an export for cost booking data. You will receive a job id which will be used\nto collect the exported data after the job has finished.",
        "operationId": "Cost control|Cost Booking_createExportAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardCostBookingCreateExportResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardCostBookingCreateExportRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/cost_booking/startExport": {
      "get": {
        "tags": [
          "Cost control|Cost Booking"
        ],
        "summary": "Start the export of an already existing cost export.",
        "description": "This export enables you to start a new export for the data that you already exported. This will only include the\ndata that was included in the original export.",
        "operationId": "Cost control|Cost Booking_startExportAction",
        "parameters": [
          {
            "name": "exportId",
            "in": "query",
            "required": false,
            "description": "The cost export ID.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardCostBookingStartExportResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/cost_booking/fetchExportData": {
      "get": {
        "tags": [
          "Cost control|Cost Booking"
        ],
        "summary": "Fetch cost export data.",
        "description": "This endpoint enables you to retrieve the data for a cost export if its job is finished.",
        "operationId": "Cost control|Cost Booking_fetchExportData",
        "parameters": [
          {
            "name": "jobId",
            "in": "query",
            "required": true,
            "description": "The job id for the cost export.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ComponentHttpFoundationResponse"
                    }
