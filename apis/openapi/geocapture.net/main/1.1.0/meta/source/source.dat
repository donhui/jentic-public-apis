      "CostDistributionHistoryUpsertRequestRecord": {
        "type": "object",
        "description": "",
        "properties": {
          "keyField": {
            "type": "string",
            "description": "This parameter specifies the name of the unique key used to distinctly assign each dataset in the API.\n\n| Value           | Description                |\n|----------------|-----------------------------|\n| id             | The internal tracker cost setting ID |"
          },
          "data": {
            "description": "The tracker cost setting record.",
            "type": "object",
            "$ref": "#/components/schemas/CostDistributionHistoryUpsertRequestRecordData"
          }
        }
      },
      "CostDistributionHistoryUpsertRequestRecordData": {
        "type": "object",
        "description": "",
        "properties": {
          "trackerId": {
            "type": "integer",
            "description": "The internal id of the tracker if the setting is meant to be for a tracker."
          },
          "trackerCategoryId": {
            "type": "integer",
            "description": "The internal id of the tracker category if the setting is meant to be for a tracker category."
          },
          "costTypeSource": {
            "type": "string",
            "description": "The source for the cost type.\n\n| Value | Description |\n|------|-------------|\n| COST_TYPE | cost type is defined at this entry |\n| VEHICLE_CATEGORY | cost type is defined at the tracker category |\n\nThe value \"VEHICLE_CATEGORY\" can only be set if a trackerId is given. This will link the settings cost type to\nthe one of the trackers category. If a trackerId is given the value can also be set to \"COST_TYPE\". This will\nset the cost type for this specific tracker. In that case a costTypeId/costTypeReference also has to be given.\nFor a tracker category this value is obsolete."
          },
          "costTypeId": {
            "type": "integer",
            "description": "The internal cost type id for this setting.\nValue is needed for settings if a trackerCategoryId is given or the costTypeSource is set to \"COST_TYPE\".\nEither costTypeId or costTypeReference can be supplied."
          },
          "costTypeReference": {
            "type": "integer",
            "description": "The cost type reference for this setting.\nValue is needed for settings if a trackerCategoryId is given or the costTypeSource is set to \"COST_TYPE\".\nEither costTypeId or costTypeReference can be supplied."
          },
          "costDistribution": {
            "type": "string",
            "description": "The cost distribution.\n\n| Value                    | Description                             |\n|--------------------------|-----------------------------------------|\n| VEHICLE_CATEGORY         | Take the value of the tracker category |\n| LOGISTICS                | Distribute as a logistics vehicle. Supply fields |\n|| costDistributionLogisticsKmToProject, costDistributionLogisticsKm and costDistributionLogisticsOperatingHour |\n| MACHINE                  | Distribute as a machine vehicle. Supply fields costDistributionMachineHour, |\n|| costDistributionMachineDay and costDistributionMachineTransportDay |"
          },
          "logisticsKmDistribution": {
            "type": "string",
            "description": "The distribution of costs to projects for the day.\nOnly supply if costDistribution = LOGISTICS.\n\n| Value                    | Description                             |\n|--------------------------|-----------------------------------------|\n| DURATION                  | Distribution according to the duration of the stops at the projects |\n| AMOUNT                      | Distribution equally for each project |\n| DRIVE                      | Distribute costs by project approached |"
          },
          "logisticsKmRate": {
            "type": "number",
            "description": "The costs per kilometer.\nOnly supply if costDistribution = LOGISTICS."
          },
          "logisticsHourlyRate": {
            "type": "number",
            "description": "The costs per operating hour.\nOnly supply if costDistribution = LOGISTICS."
          },
          "logisticsDailyRate": {
            "type": "number",
            "description": "The costs per day.\nOnly supply if costDistribution = LOGISTICS."
          },
          "machineHourlyRate": {
            "type": "number",
            "description": "The costs per operating hour.\nOnly supply if costDistribution = MACHINE."
          },
          "machineDailyRate": {
            "type": "number",
            "description": "A fixed cost amount per day.\nOnly supply if costDistribution = MACHINE."
          },
          "machineTransportDayDistribution": {
            "type": "string",
            "description": "The cost distribution for transport days.\nOnly supply if costDistribution = MACHINE.\n\n| Value                    | Description                             |\n|--------------------------|-----------------------------------------|\n| IGNORE                   | transport days will be ignored            |\n| FULL_DAY                 | Destination gets full costs            |\n| HALF_DAY                 | Costs will be split between start and destination |"
          },
          "automaticBooking": {
            "type": "boolean",
            "description": "This value indicates whether this setting should be used to create automatic bookings.\nCan be set to false if this setting is supposed to be used for form data bookings."
          },
          "fallbackProjectId": {
            "type": "integer",
            "description": "This project will be used for cost bookings that have no assigned project."
          },
          "releaseOnInactivity": {
            "type": "boolean",
            "description": "This setting will prevent empty bookings for days where this tracker has no events."
          },
          "operatingHourSource": {
            "type": "string",
            "description": "The source for the operating hours.\nOnly supply if costDistribution = LOGISTICS.\n\n| Value | Description |\n|------|-------------|\n| SHIFT_TIME | time from the first till the last event for the day |\n| DRIVE_TIME | Sum of the movement events |"
          },
          "minDuration": {
            "type": "number",
            "description": "The minimum duration (in s) for an event to be used for the calculation."
          },
          "minDistance": {
            "type": "number",
            "description": "The minimum distance (in m) for an event to be used for the calculation.\nOnly supply if costDistribution = LOGISTICS."
          },
          "from": {
            "description": "The first day from which the new cost configuration is valid.",
            "type": "object",
            "$ref": "#/components/schemas/DateTime"
          }
        }
      },
      "StandardCostDistributionHistoryUpsertRequest": {
        "type": "object",
        "description": "",
        "properties": {
          "records": {
            "description": "The tracker cost setting data.",
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/CostDistributionHistoryUpsertRequestRecord"
                },
                {
                  "description": ""
                }
              ]
            }
          },
          "startCostCalculation": {
            "type": "boolean",
            "description": "If true a cost calculation will be started from the start date of this setting on."
          },
          "dryRun": {
            "type": "boolean",
            "description": "Simulate the operation.\n(No records will be created or changed) This Parameter is optional."
          }
        }
      },
