    "/employee_stamp/fetch": {
      "get": {
        "tags": [
          "Time Tracking|Employee Stamp"
        ],
        "summary": "Fetch employee stamp list.",
        "description": "This function retrieves employee stamps, including the `projectId`, the `salaryType` and the position of the\nstamp. Stamps in geoCapture are utilized for time tracking. The stamp can be set to either `S` for stay or `E`\nfor end. Stay stamps can be created at the start of a shift, after a break, if automatic breaks are not enabled\nin geoCapture, or when beginning work on a new project for project-related time tracking. Leave stamps can be\ngenerated at the beginning of a pause or at the conclusion of a shift. For employee work time requests, it is\nrecommended to utilize the `employee_time_tracking/fetch` endpoint.",
        "operationId": "Time Tracking|Employee Stamp_fetchAction",
        "parameters": [
          {
            "name": "employees[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the employee based on the IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "employees[byReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the personal numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[byCardNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the driver card numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[byIbuttonNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the iButton numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "employees[byImportKeys][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the employee import IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[importSource]",
            "in": "query",
            "required": false,
            "description": "Name of the external data source. (Default is \"*API\")\n\nThis parameter is only required if the external employee ID is filtered.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stampId",
            "in": "query",
            "required": false,
            "description": "Internal Id of the stamp. (Ignores other Filters and returns the specific Stamp)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Start date",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "End date",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Number of records to skip.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardEmployeeStampFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/employee_stamp/create": {
      "post": {
        "tags": [
          "Time Tracking|Employee Stamp"
        ],
        "summary": "Create employee stamps.",
        "description": "This endpoint enables the creation of employee stamps. You must carry out this procedure to record an employee's\nworking time. When creating a stamp, you may include a reference to a project to log project-related work time\nand a specified salary type to use a custom salary type for this stamp. The stamp can be set to either 'STAY'\nor 'END'. Stay stamps can be created at the start of a shift, after a break, if automatic breaks are\nnot enabled in geoCapture, or when beginning work on a new project for project-related time tracking. Leave\nstamps can be generated at the beginning of a pause or at the conclusion of a shift.",
        "operationId": "Time Tracking|Employee Stamp_createAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardEmployeeStampCreateResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardEmployeeStampCreateRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/employee_time_tracking/fetch": {
      "get": {
        "tags": [
          "Time Tracking|Employee time tracking"
        ],
        "summary": "Fetch employee time tracking.",
        "description": "This endpoint allows you to retrieve an employee's timesheet using the `employeeReference` and a timeframe from\nwhich to retrieve the timesheet. The time sheet will provide an overview of the `worktime` within the timeframe\nor detailed information on the `worktime` for each day within the specified timeframe. Additionally, the employee\ntimesheet provides comprehensive details, including 'overtime', 'drive duration' or 'drive distance', if\napplicable. Drive data on the timesheet is accessible if the employee is registered as a driver for a vehicle.\nVehicles may have fixed or variable drivers, depending on the stamps created in the vehicle. In addition, you\nwill receive information regarding the balance of the employee's time account. All time durations are provided in\nseconds.",
        "operationId": "Time Tracking|Employee time tracking_fetchAction",
        "parameters": [
          {
            "name": "employeeReference",
            "in": "query",
            "required": false,
            "description": "The personnel number of the employee. The employeeReference or importKey is required.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "importKey",
            "in": "query",
            "required": false,
            "description": "The external id of the employee. The employeeReference or importKey is required.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": true,
            "description": "Start date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "description": "End date",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardEmployeeTimeTrackingFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/salary_type/fetch": {
      "get": {
        "tags": [
          "Time Tracking|Salary type"
        ],
        "summary": "Fetch salary type list.",
        "description": "This endpoint enables you to retrieve a roster of salary classifications within geoCapture. To modify the\ncharacteristics of the salary type, adjustments must be made in geoCapture. You will receive fundamental details\nabout the salary type, including its `name`, `id`, a holiday flag, and its `type`. The salary type serves as the\nidentifier for wage exports and within this API, and the `name` is used in geoCapture to refer to this\ndesignation.",
        "operationId": "Time Tracking|Salary type_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the salary types based on the IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardSalaryTypeFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tool/fetch": {
      "get": {
        "tags": [
          "Tools|Tool"
        ],
        "summary": "Fetch tool list.",
        "description": "This endpoint enables you to retrieve a list of tools that are under geoCapture's management. You will receive\nfundamental details such as the tool's `serialNumber`, `toolCategory` name, and `toolManufacturer` name. You can\nestablish maintenance schedules within a tool to coordinate tool inspections, for instance. The status aims to\nenhance tool management efficiency within the company.",
        "operationId": "Tools|Tool_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the tools based on the internal IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[bySerialNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the tools based on the serial numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[byExternalIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the tools based on the external IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[byBeaconIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the tools based on beacon IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[byProjectChangedAfter]",
            "in": "query",
            "required": false,
            "description": "Filter the tools which projectChangedAt is after the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22 17:15:31"
            }
          },
          {
            "name": "filter[byLicenseNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the vehicles based on the license plates.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a default value and max set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardToolFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tool/fetchData": {
      "get": {
        "tags": [
          "Tools|Tool"
        ],
        "summary": "Request tool details.",
        "description": "This endpoint allows you to gather detailed information about a tool with a specific `id`. This endpoint returns\na tool object and, if available, the linked beacon or tracker and the current known position of the tool.",
        "operationId": "Tools|Tool_fetchDataAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the tool. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardToolFetchDataResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tool/delete": {
      "get": {
        "tags": [
          "Tools|Tool"
        ],
        "summary": "Delete tools.",
        "description": "This endpoint permits the deletion of many tools simultaneously with the provision of an array of IDs. You can\nenable the `dryRun` parameter to simulate the execution, without modifying actual data. Note that deleted tools\ncannot be restored.",
        "operationId": "Tools|Tool_deleteAction",
        "parameters": [
          {
            "name": "ids[]",
            "in": "query",
            "required": false,
            "description": "The internal ids of the tool to be deleted. This Parameter is optional.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "dryRun",
            "in": "query",
            "required": false,
            "description": "Simulate the operation (default: false).\n(No data will be removed) This Parameter is optional.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardToolDeleteResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tool/upsert": {
      "post": {
        "tags": [
          "Tools|Tool"
        ],
        "summary": "Create/Update tools.",
        "description": "This method can be used to create and update tools.\n\nAn effort is made to locate an existing tool using the selected primary key. If found, it will be modified,\nwhereas if no tool is found, a new one is created. If the `deleteMissing` flag is set to true, all tools absent\nfrom the request shall be purged. Please note that removed tools may not be reinstated. You can enable the\n`dryRun` setting to simulate the action without altering any live data.\n\nThe designated employee assigned in the tool will be accountable for the precise upkeep of the equipment.\nYou may also configure `purchaseCost`, `purchaseDate`, `warranty`, and `yearOfManufacture` to facilitate your\ntool management. This data will be shown in geoCapture as tool details.",
        "operationId": "Tools|Tool_upsertAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardToolUpsertResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardToolUpsertRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/tool_category/fetch": {
