      "EmployeeTimeTrackingFetchResponseDriveClassificationItem": {
        "type": "object",
        "description": "",
        "properties": {
          "driveType": {
            "type": "string",
            "description": "The Drive Type.\n\nClassifies the type of drive activity:\n- ARRIVAL: Drive to the work location\n- DEPARTURE: Drive away from the work location\n- MOVE: Drive between locations during working hours"
          },
          "distance": {
            "type": "integer",
            "description": "The driving distance.\n\nTotal distance traveled in meters."
          },
          "worktime": {
            "type": "integer",
            "description": "The working time in hours.\n\nTime spent driving that counts towards working hours."
          },
          "totalWorktime": {
            "type": "integer",
            "description": "The total working time in hours.\n\nAggregate of all working time for this drive classification."
          },
          "drives": {
            "description": "All drive records associated with this classification.\n\nCollection of individual drive instances that belong to this classification.",
            "type": "array",
            "items": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/EmployeeTimeTrackingFetchResponseTimeSheetDriveItem"
                },
                {
                  "description": ""
                }
              ]
            }
          },
          "durationPassenger": {
            "type": "integer",
            "description": "The duration as passenger in seconds.\n\nTotal time spent as a passenger during drives."
          },
          "durationDriver": {
            "type": "integer",
            "description": "The duration as driver in seconds.\n\nTotal time spent actively driving the vehicle."
          },
          "totalDuration": {
            "type": "integer",
            "description": "The total duration of all drives in seconds.\n\nSum of all drive durations including both driver and passenger time."
          },
          "worktimeBySalaryType": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "The working time broken down by salary type for each drive."
          },
          "totalWorktimeBySalaryType": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "The total working time aggregated by salary type."
          },
          "totalSetupTimeBySalaryType": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "The total setup time aggregated by salary type."
          },
          "totalSetupTimeBySalaryTypeAndCostCenter": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "The total setup time aggregated by salary type and cost center."
          },
          "setupTimeDuration": {
            "type": "integer",
            "description": "The total setup time duration in seconds."
          },
          "totalSetupTimeWorktime": {
            "type": "integer",
            "description": "The total setup time working hours."
          }
        }
      },
      "EmployeeTimeTrackingFetchResponseTimeSheetDriveItem": {
        "type": "object",
        "description": "",
        "properties": {
          "startTime": {
            "description": "The start time of the drive.\n\nBeginning timestamp of the drive activity.",
            "type": "object",
