      "DispoTourUpsertStopResponseDispoTourStopItem": {
        "type": "object",
        "description": "",
        "properties": {
          "tourId": {
            "type": "integer",
            "description": "The id of the tour the stop is assigned."
          },
          "id": {
            "type": "integer",
            "description": "The internal id of the stop."
          },
          "sequence": {
            "type": "integer",
            "description": "The sequence of the stop."
          },
          "type": {
            "type": "string",
            "description": "The stop type.\n\n| Value                     | Description                         |\n|--------------------------|--------------------------------------|\n| HOME                     | Home Stop used to identify the start and end of the tour            |\n| ORDER                     | Use this type for a normal stop with orders                               |\n| TBREAK                    | Break Stop                           |\n| HOTEL                 | Used for overnight stays                              |\n| FUEL                 | Used for fueling                              |\n| LOAD                 | Used for pickup and delivery orders.                              |\n| UNLOAD                 | Used for pickup and delivery orders.                     |"
          },
          "name": {
            "type": "string",
            "description": "The name address addition."
          },
          "name2": {
            "type": "string",
            "description": "The name2 address addition."
          },
          "name3": {
            "type": "string",
            "description": "The name3 address addition."
          },
          "street": {
            "type": "string",
            "description": "The street."
          },
          "zipCode": {
            "type": "string",
            "description": "The zip code."
          },
          "city": {
            "type": "string",
            "description": "The city."
          },
          "countryCode": {
            "type": "string",
            "description": "The two-digit ISO 3166 country code."
          },
          "provinceCode": {
            "type": "string",
            "description": "The province code."
          },
          "latLng": {
            "description": "The geo-coordinates of the stop.",
            "type": "object",
            "$ref": "#/components/schemas/ComponentGeocodingLatLngInterface"
          },
          "contactPersonName": {
            "type": "string",
            "description": "The contact person name."
          },
          "contactPersonEmail": {
            "type": "string",
            "description": "The contact person e-mail."
          },
          "contactPersonPhoneNumber": {
            "type": "string",
            "description": "The contact person phone number."
          },
          "contactPersonMobileNumber": {
            "type": "string",
            "description": "The contact person mobile number."
          },
          "noteDriver": {
            "type": "string",
            "description": "A note for the driver. This info is shown to the driver in his app."
          },
          "notePlanner": {
            "type": "string",
            "description": "A note for the planner."
          },
          "additionalCosts": {
            "type": "number",
            "description": "Field for additional costs."
          },
          "duration": {
            "type": "integer",
            "description": "The duration in seconds for the new stop.\nUse this only when the duration is not equal with the work duration of the orders.\nIf the stop is a break it's used as break duration, if not it's the work duration."
          },
          "fixedArrivalDate": {
            "description": "Fixed arrival date.",
            "type": "object",
            "$ref": "#/components/schemas/Date"
          },
          "fixedArrivalTime": {
            "description": "Fixed arrival time.",
            "type": "object",
            "$ref": "#/components/schemas/Time"
          },
          "fixedDepartureDate": {
            "description": "Fixed departure date.",
            "type": "object",
            "$ref": "#/components/schemas/Date"
          },
          "fixedDepartureTime": {
            "description": "Fixed departure time.",
            "type": "object",
            "$ref": "#/components/schemas/Time"
          }
        }
