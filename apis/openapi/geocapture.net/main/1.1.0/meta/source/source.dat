    "/employee/upsert": {
      "post": {
        "tags": [
          "Employees|Employee"
        ],
        "summary": "Create/Update employees.",
        "description": "This method can be used to create and update employees.\n\nAn attempt will be made to find an existing employee based on the selected primary key. If found, adjustments are\nmade accordingly; otherwise, a new employee is created.You have the option to remove any absent employees from\nyour request. Also, you can specify the import source from which the missing employees should be removed. For\nexample, if the import source is tagged with *API, only the entries marked with this flag will be removed.\nEnabling the dry run feature will not make any modifications to the actual system, but you will receive a\nsuccessful response.",
        "operationId": "Employees|Employee_upsertAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardEmployeeUpsertResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardEmployeeUpsertRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/employee/delete": {
      "get": {
        "tags": [
          "Employees|Employee"
        ],
        "summary": "Delete employees.",
        "description": "This functionality permits the deletion of multiple employees concurrently by setting various filters. If the\n`dryRun` flag is enabled, no modifications will be made to the live system, and you will receive a simulated\nsuccess response. If the operation is successful, the list of employees who have been deleted will be provided\nas a response.",
        "operationId": "Employees|Employee_deleteAction",
        "parameters": [
          {
            "name": "employees[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the employee based on the IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "employees[byReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the personal numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[byCardNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the driver card numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[byIbuttonNumbers][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the iButton numbers.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "employees[byImportKeys][]",
            "in": "query",
            "required": false,
            "description": "Filters the employees based on the employee import IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "employees[importSource]",
            "in": "query",
            "required": false,
            "description": "Name of the external data source. (Default is \"*API\")\n\nThis parameter is only required if the external employee ID is filtered.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dryRun",
            "in": "query",
            "required": false,
            "description": "Simulate the operation (default: false).\n(No data will be removed) This Parameter is optional.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardEmployeeDeleteResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
