    "/tour/fetch": {
      "get": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Fetch tour list.",
        "description": "This endpoint enables you to access a list of tours. You may add various filter options to ensure that you\nobtain the desired data. The response will provide you with fundamental details about the tour, including a team\nreference, the number of orders, and the number of stops.\n\n\nA tour comprises various stops determined by the addresses of assigned orders. Through an optimization function,\nstops are sequenced for optimal efficiency, considering distances and travel times. Stops can be manually\nsequenced and calculated or optimized. Tour costs are automatically computed, including any user-adjusted\narrival and departure times, which may result in calculated waiting times for the team. These waiting times are\nalso factored into the cost calculation.\n\n\nIf you require more detailed information, such as the list of the stops, please make use of the\n`/tour/fetch_data` endpoint.",
        "operationId": "Disposition|Tour_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the tour based on the internal IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byDistrict][]",
            "in": "query",
            "required": false,
            "description": "Filters the tour based on the area.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byTeam][]",
            "in": "query",
            "required": false,
            "description": "Filters the tour based on the team.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byStatus]",
            "in": "query",
            "required": false,
            "description": "Filters the tour based on its status.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[from]",
            "in": "query",
            "required": false,
            "description": "Filters the tour based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[to]",
            "in": "query",
            "required": false,
            "description": "Filters the tour based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set. This paramter is optional.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tour/fetch_data": {
      "get": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Fetch tour details.",
        "description": "This endpoint is able to provide you with details of a tour like detailed information for all stops and\nassociated tour costs. In addition to that you will recieve the `teamHeadEmployee` and the executing employee.\nYou recieve the id of a tour from the list tour endpoint.\n\n\nThe Sub-Stop function in tour planning allows for the division of a single work stop among multiple teams,\nensuring efficient task allocation for larger jobs. It involves assigning specific time durations to different\nteams for a shared job, based on the total estimated time required for the stop. If a stop with substops is\nremoved, all substops are also removed.",
        "operationId": "Disposition|Tour_fetchDataAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the tour. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourFetchDataResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tour/delete": {
      "get": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Delete tours.",
        "description": "This endpoint allows you to delete multiple tours simultaneously by submitting multiple tour ids in one\nrequest. Afterward, you will receive a response with an array of deleted tour ids. Keep in mind that you may\ndelete any tours, irrespective of their status. Please note that deleted tours cannot be restored.",
        "operationId": "Disposition|Tour_deleteAction",
        "parameters": [
          {
            "name": "ids[]",
            "in": "query",
            "required": true,
            "description": "The internal ids of the tours to be deleted. This Parameter is required.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourDeleteResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tour/delete_stop": {
      "get": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Delete stops.",
        "description": "This endpoint allows you to delete multiple stops simultaneously by submitting multiple stop ids in one\nrequest. Afterward, you will receive a response with an array of deleted stop ids. Keep in mind that you may\ndelete any stops, irrespective of their status. Please note that deleted stops cannot be restored.",
        "operationId": "Disposition|Tour_deleteStopAction",
        "parameters": [
          {
            "name": "ids[]",
            "in": "query",
            "required": true,
            "description": "The internal ids of the stops to be deleted. This Parameter is required.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourDeleteStopResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tour/set_status": {
      "get": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Set the status of the tour.",
        "description": "This endpoint allows you to set the status of a tour in geoCapture with the ID of the tour and the new status.\nThe `NEW` status describes new tours that have not yet been calculated or tours that have been changed. The\n`FIXED` status of the tour alerts the user if they want to change the tour details. The `CALCULATED` status is\ndesignated for calculated tours. Tours with the status `READY` are displayed to drivers in their app.",
        "operationId": "Disposition|Tour_setStatusAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the tour. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": true,
            "description": "The status to be set. This Parameter is required.\n\n| Values         |\n| -------------- |\n| NEW            |\n| CALCULATED     |\n| FIXED          |\n| READY          |\n| STARTED        |\n| FINISHED       |",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourSetStatusResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tour/optimize": {
      "get": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Optimize a tour.",
        "description": "This endpoint allows you to start a job to optimize a tour by providing an `id`. Upon successful request, a\n`jobId` is provided in the response. geoCapture jobs are tasks that may take some time to calculate, therefore\nthey are executed in the background. You can to inquire about the status of the job through the\nMiscellaneous|Job endpoint. After optimizing the tour, the calculation is performed automatically.\n\nDuring route optimization, the system considers travel times. Additionally, it incorporates team working hours\nand the duration of each order to determine the estimated arrival and departure times at each stop, as well as\nthe distances to and between the stops.\n\nFor optimization purposes, it can be helpful to establish parameters for the sequence that a tour should be\noptimized between. For example, you may want to select a gas station to refuel your vehicle at the end of your\ntour. You can retrieve the sequence of stops for a tour by accessing the `/tour/fetch_data` endpoint.",
        "operationId": "Disposition|Tour_optimizeAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the tour. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "fromSequence",
            "in": "query",
            "required": false,
            "description": "Optimize the tour from this stop sequence on.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "toSequence",
            "in": "query",
            "required": false,
            "description": "Optimize the tour until this stop sequence.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourOptimizeResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tour/calculate": {
      "get": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Calculate a tour.",
        "description": "This endpoint allows you to start a job to calculate a tour by providing its `id`.\nA job in geoCapture is a task executed in the background that may take some time to complete. Jobs may require\nseveral minutes to calculate. Upon a successful request, a `jobId` is provided in the response, which can be used\nto inquire about the status of the job through the Miscellaneous|Job endpoint.\nWhen calculating a tour, the arrival and departure times, along with the driving duration and distances, are\ncomputed in the order they were assigned to the tour. If applicable, the calculation follows the arranged\nsequence of the orders. To adjust the sequence of stops within a tour, utilize the `/tour/upsert_stop` endpoint\nand specify the `beforeStopId` or `afterStopId`.\nTo hand a tour to its driver/team, it must be calculated. Optimization of the tour is optional. Please note that\na calculated tour is not optimized.",
        "operationId": "Disposition|Tour_calculateAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The internal id of the tour. This Parameter is required.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourCalculateResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tour/assign_order": {
      "get": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Assign an order to a tour.",
        "description": "This endpoint allows an order to be associated with a tour. The system will attempt to find a stop at the address\nof the order. If no existing stop is found, a new stop is added to the tour.\n\n\nWhen a new stop is added to the tour, it must be recalculated or optimzed if desired. The status of the tour will\nbe reset to `NEW`. This is because the distances, durations, and departure and arrival times of the jobs may\nchange when a new job is added, and the values need to be calculated for the new stop as well. You must do that\nat the `/tour/calculate` endpoint.",
        "operationId": "Disposition|Tour_assignOrderAction",
        "parameters": [
          {
            "name": "orderId",
            "in": "query",
            "required": false,
            "description": "The internal id of the order to be added to the tour.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "orderExternalReference",
            "in": "query",
            "required": false,
            "description": "The external reference for the order to be added to the tour (Used if orderId not provided).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tourId",
            "in": "query",
            "required": true,
            "description": "The internal id of the tour to be updated. This parameter is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "beforeStopId",
            "in": "query",
            "required": false,
            "description": "The id of the stop before which to insert the new order.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "afterStopId",
            "in": "query",
            "required": false,
            "description": "The id of the stop after which to insert the new order.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourAssignOrderResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tour/upsert_stop": {
      "post": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Create/Update stops for a tour.",
        "description": "This method can be used to create and update tour stops. An attempt is made to find an existing stop based on\nthe\ngiven id. If one is found, it will be adjusted. Otherwise, a new stop is created.\n\nTo share the tour with the driver after a new stop has been added, it must first be calculated. This is made\npossible at the `/tour/calculate` endpoint. To insert the stop at a certain point in the tour, the\n`beforeStopId`\nor `afterStopId` must be set. To share the tour with the driver, calculate the tour and set the status to\n`READY`. The drivers can access the tour details via the orders menu in the geoCapture mobile app.",
        "operationId": "Disposition|Tour_upsertStopAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourUpsertStopResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardDispoTourUpsertStopRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/tour/upsert": {
      "post": {
        "tags": [
          "Disposition|Tour"
        ],
        "summary": "Create/Update tours.",
        "description": "This method can be used to create and update tours. To modify or add stops within tours use the\n`/tour/upsert_stop` endpoint.\n\nAn attempt is made to find an existing tour based on the selected primary key.\nIf one is found, it will be adjusted. Otherwise, a new tour is created.",
        "operationId": "Disposition|Tour_upsertAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardDispoTourUpsertResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardDispoTourUpsertRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/file/fetch": {
      "get": {
        "tags": [
          "Documents|File"
        ],
        "summary": "Fetch file list.",
        "description": "Files in geoCapture are used in different areas of the application. They can be added to employees, vehicles,\nprojects, orders and tools. This endpoint allows you to list uploaded and added files in geoCapture. Not included\nin this endpoint are custom forms. Please use the Custom Form endpoints for interacting with them. Also,\nmiamapo maps are not included. mimapo is a tool for creating sketches on maps. For more information,\nplease click on this link: <a href=\"https://miamapo.de/\" target=\"_blank\">miamapo</a>\n\nIf you want to download a file, you must use the `fetch_file` endpoint.",
        "operationId": "Documents|File_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the file based on the internal IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byExternalIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the file based on the external IDs.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[byTypeId][]",
            "in": "query",
            "required": false,
            "description": "Filters the file based on the file type id.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "filter[byTypeReferences][]",
            "in": "query",
            "required": false,
            "description": "Filters the file based on the file type reference.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "filter[ownerType]",
            "in": "query",
            "required": false,
            "description": "Filters the file based on the object type it is attached to. (required if ownerId is provided)\n\nVEHICLE, ORDER, PROJECT, TOOL or EMPLOYEE",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[ownerId]",
            "in": "query",
            "required": false,
            "description": "Filters the file based on the object id it is attached to. (required if ownerType is provided)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "filter[from]",
            "in": "query",
            "required": false,
            "description": "Filters the file based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "filter[to]",
            "in": "query",
            "required": false,
            "description": "Filters the file based on the given date.",
            "schema": {
              "type": "string",
              "example": "2022-12-22"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single API request, with a\nlimit and default value set at 500 records. This Parameter is optional.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardFileFetchResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/file/fetch_file": {
      "get": {
        "tags": [
          "Documents|File"
        ],
        "summary": "Fetch a file.",
        "description": "This method can be used to download a specific file with the specified `id` parameter. If you want a list of\navailable files to download, use the `/file/fetch` endpoint. The `access_log` flag allows you to specify whether\naccess should be logged in the document access log.",
        "operationId": "Documents|File_fetchFileAction",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": false,
            "description": "The internal ID of the file. This Parameter or the external ID is required.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "externalId",
            "in": "query",
            "required": false,
            "description": "The external ID of the file. This Parameter or the id is required.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "log_access",
            "in": "query",
            "required": false,
            "description": "Log the access in the access log. This Parameter is optional.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ComponentHttpFoundationResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/file/upsert": {
      "post": {
        "tags": [
          "Documents|File"
        ],
        "summary": "Create/Update a file.",
        "description": "This endpoint can be used to create/update files and assign them to an employee, vehicle, project, order or tool. The\nfile must be base64 encoded and provided in the data field. The base64 encoded file can only be up to 256 MB in size.\nThe object type allows you to choose whether to\nassociate the file with an employee or one of the other options provided. You must also provide a `tagId` or\n`targetReference` to associate the document with a target. The filename must be the full filename including the\nextension, for example: document.pdf. You risk corrupting the file if you do not specify the extension. You can\nadd a file type by specifying its id. You can see a list of available file types at the `fetch_type` endpoint.\nIf none is specified, the default file type is used.",
        "operationId": "Documents|File_upsertAction",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardFileUpsertResponse"
                    }
                  ]
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardFileUpsertRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/file/delete": {
      "get": {
        "tags": [
          "Documents|File"
        ],
        "summary": "Delete files.",
        "description": "This endpoint can be used to delete specific files by providing an array of `id`s. If you want to delete multiple\nfiles at once, it will be beneficial to use an array of ids as this will improve performance and save resources.",
        "operationId": "Documents|File_deleteAction",
        "parameters": [
          {
            "name": "ids[]",
            "in": "query",
            "required": true,
            "description": "The internal ids of the files to be deleted. This paramter is required.",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardFileDeleteResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/file/fetch_type": {
      "get": {
        "tags": [
          "Documents|File"
        ],
        "summary": "Fetch file type list.",
        "description": "This method can be used to get a list of file types. File types in geoCapture specify a group of files. In\naddition, the file type provides permission control by specifying who can read, modify and delete a file.",
        "operationId": "Documents|File_fetchTypeAction",
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Use this parameter to specify the number of records you want to skip before starting to collect the data from\nthe result set. This Parameter is optional",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "The limit parameter defines the maximum number of records that can be retrieved in a single\nAPI request, with a max and default value set at 500 records. This Parameter is optional",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success Response:",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/StandardFileFetchTypeResponse"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/custom_form_data/fetch": {
      "get": {
        "tags": [
          "Documents|Form data"
        ],
        "summary": "Fetch form data list.",
        "description": "This endpoint allows you to retrieve a list of custom forms. geoCapture Custom forms can be used to create\nconstruction reports, for instance. geoCapture allows you to create unique form definitions for different use\ncases. In addition, a form can be automatically added to projects, if enabled in the form definition.\nIf employees, tools or vehicles are referenced in the form definition, the completed form can also be added to\nthese targets, if enabled in the form definition.",
        "operationId": "Documents|Form data_fetchAction",
        "parameters": [
          {
            "name": "filter[byIds][]",
            "in": "query",
            "required": false,
            "description": "Filters the form data based on the internal IDs.",
            "schema": {
