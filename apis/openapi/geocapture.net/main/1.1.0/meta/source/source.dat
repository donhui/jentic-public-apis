        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/StandardEmployeeAbsenceUpsertRequest"
                  }
                ]
              }
            }
          }
        }
      }
    },
