  "components": {
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "properties": { "type": "object", "additionalProperties": true }
        }
      },
      "ContactInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "properties": { "type": "object", "additionalProperties": true }
        }
      },
      "ContactProperty": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "ViewedPage": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "title": { "type": "string" },
          "viewedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" },
          "sender": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Operator": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "Department": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Ticket": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "subject": { "type": "string" },
          "status": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "contactId": { "type": "string" }
        }
      },
      "TicketInput": {
        "type": "object",
        "properties": {
          "subject": { "type": "string" },
          "message": { "type": "string" },
          "contactId": { "type": "string" }
        }
      },
      "TicketReply": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "required": ["message"]
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "clientId": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Tidio-Openapi-Client-Id"
      },
      "clientSecret": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Tidio-Openapi-Client-Secret"
      }
    }
  },
  "security": [
    {
      "clientId": [],
      "clientSecret": []
    }
  ]
}