          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "message can contain 3 status messages\n1. success - file has been successfully processed\n2. pending - file is in the queue and will be processed\n3. failure - There was an issue while processing the file. It has been retrried 3 times. It is recommended to reupload the file and if the issue persists, please contact support ",
