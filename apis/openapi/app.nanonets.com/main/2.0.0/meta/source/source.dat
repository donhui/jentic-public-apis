                              "id": "00000000-0000-0000-0000-000000000000X",
                              "input": "filename.jpg",
                              "message": "Success",
                              "page": 55,
                              "prediction": [],
                              "request_file_id": "00000000-0000-0000-0000-000000000000",
                              "request_metadata": "metadata sent during prediction"
                            }
                          ]
                        }
                      ]
                    }
                  }
