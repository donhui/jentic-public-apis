              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Group"
                      }
                    },
                    "has_more": {
                      "type": "boolean",
                      "description": "Whether there are more groups to fetch"
                    }
                  }
