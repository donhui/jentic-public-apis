    "/groups/{id}/users": {
      "post": {
        "operationId": "addUserToGroup",
        "summary": "Add user to group",
        "description": "Add a user to a group by their IDs",
        "tags": ["Groups"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Group ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id"],
                "properties": {
                  "user_id": {
                    "type": "string",
                    "description": "ID of the user to add to the group"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User added to group successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Group"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/events": {
      "post": {
        "operationId": "trackEvent",
        "summary": "Track an event",
        "description": "Track a custom event for a user",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event tracked successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "event_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/flows": {
      "get": {
        "operationId": "listFlows",
        "summary": "List flows",
        "description": "Retrieve a list of all flows (tours, checklists, etc.)",
        "tags": ["Flows"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of flows to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          },
          {
            "name": "starting_after",
            "in": "query",
            "description": "Cursor for pagination, flow ID to start after",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Flow"
                      }
                    },
                    "has_more": {
                      "type": "boolean",
                      "description": "Whether there are more flows to fetch"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/flows/{id}": {
      "get": {
        "operationId": "getFlow",
        "summary": "Get a flow",
        "description": "Retrieve a specific flow by ID",
        "tags": ["Flows"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Flow ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Flow"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/attributes": {
      "get": {
        "operationId": "listAttributes",
        "summary": "List custom attributes",
        "description": "Retrieve a list of custom attribute definitions",
        "tags": ["Attributes"],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "Filter by attribute type (user or group)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["user", "group"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Attribute"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createAttribute",
        "summary": "Create a custom attribute",
        "description": "Create a new custom attribute definition",
        "tags": ["Attributes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AttributeInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attribute created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Attribute"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key authentication using Bearer token. Get your API key from the Userflow dashboard."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the user"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address"
          },
          "name": {
            "type": "string",
            "description": "User's full name"
          },
          "signed_up_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the user signed up"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Custom user attributes"
          },
          "group_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of groups the user belongs to"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the user was created in Userflow"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the user was last updated"
          }
        },
        "required": ["id"]
      },
      "UserInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the user"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address"
          },
          "name": {
            "type": "string",
            "description": "User's full name"
          },
          "signed_up_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the user signed up"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Custom user attributes"
          }
        },
        "required": ["id"]
      },
      "UserUpdateInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address"
          },
          "name": {
            "type": "string",
            "description": "User's full name"
          },
          "signed_up_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the user signed up"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Custom user attributes"
          }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the group"
          },
          "name": {
            "type": "string",
            "description": "Group name"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Custom group attributes"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the group was created"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the group was last updated"
          }
        },
        "required": ["id"]
      },
      "GroupInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the group"
          },
          "name": {
            "type": "string",
            "description": "Group name"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Custom group attributes"
          }
        },
        "required": ["id"]
      },
      "GroupUpdateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Group name"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Custom group attributes"
          }
        }
      },
      "EventInput": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "description": "ID of the user who triggered the event"
          },
          "name": {
            "type": "string",
            "description": "Event name"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Custom event attributes"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When the event occurred (defaults to current time)"
          }
        },
        "required": ["user_id", "name"]
      },
      "Flow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the flow"
          },
          "name": {
            "type": "string",
            "description": "Flow name"
          },
          "type": {
            "type": "string",
            "enum": ["tour", "checklist", "survey", "launcher"],
            "description": "Type of flow"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "published", "archived"],
            "description": "Current status of the flow"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the flow was created"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the flow was last updated"
          },
          "published_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the flow was last published"
          }
        },
        "required": ["id", "name", "type"]
      },
      "Attribute": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the attribute"
          },
          "name": {
            "type": "string",
            "description": "Attribute name"
          },
          "key": {
