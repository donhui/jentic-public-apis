        "schema": {
          "type": "string",
          "enum": [
            "ascending",
            "descending"
          ]
        }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "description": "The number of results to return",
        "required": false,
        "schema": {
          "type": "integer",
          "format": "int32",
          "minimum": 1,
          "maximum": 200,
          "default": 25
        }
      },
      "page": {
        "name": "page",
        "in": "query",
        "description": "The page of results to return",
