    "/accounting/bankFeeds": {
      "post": {
        "summary": "Create a bank feed",
        "description": "### Linking to an existing bank account\n\nA bank feed can be created for an existing Clear Books bank account in one of two ways:\n\n1. By specifying an `accountId` returned from one of the bank accounts endpoints.\n\n2. By providing and `accountNumber` and `sortCode` that match an account which already exists in Clear Books.\n\n### Creating a new bank account\n\nIf a bank account does not already exist in Clear Books for the bank feed you wish to create, then you must provide\nenough information to allow us to create an account for you. The required fields in this case are `name`,\n`accountNumber` and `sortCode`.\n\nIf an existing bank account that matches this information is found, then it will be used and no extra account will be created.\n",
        "operationId": "createBankFeed",
        "tags": [
          "Bank Feeds"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.bank_feeds:write"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/BankFeed"
                    }
                  }
                }
              },
              "examples": {
                "existing_id": {
                  "summary": "Creating a feed for an existing account by ID",
                  "value": {
                    "items": [
                      {
                        "accountId": 123
                      }
                    ]
                  }
                },
                "existing_details": {
                  "summary": "Creating a feed for an existing account by details",
                  "value": {
                    "items": [
                      {
                        "accountNumber": "12345678",
                        "sortCode": "123456"
                      }
                    ]
                  }
                },
                "new_account": {
                  "summary": "Creating a new bank account & feed",
                  "value": {
                    "items": [
                      {
                        "name": "My bank account",
                        "accountNumber": "12345678",
                        "sortCode": "123456",
                        "currency": "GBP"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bank feed created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/BankFeed"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "422": {
            "$ref": "#/components/responses/BusinessRuleError"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/accounting/bankStatements": {
      "post": {
        "summary": "Create a bank statement",
        "description": "### Statement consolidation\n\nClear Books will consolidate statements posted using this API call into monthly statements ready to be explained.\nOne statement in Clear Books will be maintained for each calendar month based on the transaction date.\n\nThe IDs returned by this call represent the statement that the posted transactions were added to, regardless of whether a new\nstatement was created or the transactions were appended to an existing statement.\n\n### Deduplication\n\nClear Books will ignore transactions with a `transactionId` that has already been used for the same bank feed. No attempt is\nmade to deduplicate transactions based on any other properties. Please ensure that each individual transaction you send has\na consistent, unique ID.\n",
        "operationId": "createBankFeedStatement",
        "tags": [
          "Bank Statements"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.bank_statements:write"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/BankStatement"
                    }
                  }
                }
              },
              "examples": {
                "multi_line_statement": {
                  "summary": "Multi line statement",
                  "value": {
                    "items": [
                      {
                        "feedId": "203f768c68fbaa84abb372ec7763038e9297f9e2",
                        "statementLines": [
                          {
                            "transactionId": "40b4fa10e1ea89e1d5254abdd4a1d7c24c308600",
                            "transactionDate": "2019-09-29",
                            "description": "Debit card purchase",
                            "amount": -15.99
                          },
                          {
                            "transactionId": "b44f0db4be45bc9c7c8e7ee0ab37fbf8e0ee011c",
                            "transactionDate": "2019-09-30",
                            "description": "Refund",
                            "amount": 150.76
                          }
                        ]
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Statement created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/BankStatementSummary"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "422": {
            "$ref": "#/components/responses/BusinessRuleError"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/accounting/transactions": {
      "get": {
        "summary": "List transactions",
        "operationId": "listTransactions",
        "tags": [
          "Transactions"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.transactions:read"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          },
          {
            "$ref": "#/components/parameters/accountingDateFrom"
          },
          {
            "$ref": "#/components/parameters/accountingDateTo"
          },
          {
            "$ref": "#/components/parameters/transactionsSortBy"
          },
          {
            "$ref": "#/components/parameters/sortDirection"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "$ref": "#/components/parameters/page"
          }
        ],
        "responses": {
          "200": {
            "description": "An array of transactions",
            "headers": {
              "X-Pagination-Limit": {
                "schema": {
                  "type": "integer"
                },
                "description": "The number of items per page of results"
              },
              "X-Pagination-Current-Page": {
                "schema": {
                  "type": "integer"
                },
                "description": "The current page number"
              },
              "X-Pagination-Total-Pages": {
                "schema": {
                  "type": "integer"
                },
                "description": "The total number of pages available"
              },
              "X-Pagination-Total-Count": {
                "schema": {
                  "type": "integer"
                },
                "description": "The total number of results across all pages"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transactions"
                },
                "example": [
                  {
                    "id": 1,
                    "accountingDate": "2022-02-22",
                    "lines": [
                      {
                        "accountCodeId": 1001001,
                        "amount": 100
                      },
                      {
                        "accountCodeId": 2001001,
                        "amount": -50
                      },
                      {
                        "accountCodeId": 3001001,
                        "amount": -50
                      }
                    ]
                  },
                  {
                    "id": 2,
                    "accountingDate": "2022-02-23",
                    "lines": [
                      {
                        "accountCodeId": 1001001,
                        "amount": 200
                      },
                      {
                        "accountCodeId": 4001001,
                        "amount": -200
                      }
                    ]
                  }
                ]
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/accounting/generalLedger": {
      "get": {
        "summary": "Get general ledger",
        "operationId": "getGeneralLedger",
        "tags": [
          "General Ledger"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.transactions:read"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          },
          {
            "$ref": "#/components/parameters/transactionId"
          },
          {
            "$ref": "#/components/parameters/accountCodeIdSearch"
          },
          {
            "$ref": "#/components/parameters/accountingDateFrom"
          },
          {
            "$ref": "#/components/parameters/accountingDateTo"
          },
          {
            "$ref": "#/components/parameters/generalLedgerSortBy"
          },
          {
            "$ref": "#/components/parameters/sortDirection"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "$ref": "#/components/parameters/page"
          }
        ],
        "responses": {
          "200": {
            "description": "An array of general ledger lines",
            "headers": {
              "X-Pagination-Limit": {
                "schema": {
                  "type": "integer"
                },
                "description": "The number of items per page of results"
              },
              "X-Pagination-Current-Page": {
                "schema": {
                  "type": "integer"
                },
                "description": "The current page number"
              },
              "X-Pagination-Total-Pages": {
                "schema": {
                  "type": "integer"
                },
                "description": "The total number of pages available"
              },
              "X-Pagination-Total-Count": {
                "schema": {
                  "type": "integer"
                },
                "description": "The total number of results across all pages"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeneralLedger"
                },
                "example": [
                  {
                    "transactionId": 1,
                    "accountingDate": "2022-02-22",
                    "accountCodeId": 1001001,
                    "amount": 100
                  },
                  {
                    "transactionId": 1,
                    "accountingDate": "2022-02-22",
                    "accountCodeId": 2001001,
                    "amount": -50
                  },
                  {
                    "transactionId": 1,
                    "accountingDate": "2022-02-22",
                    "accountCodeId": 3001001,
                    "amount": -50
                  },
                  {
                    "transactionId": 2,
                    "accountingDate": "2022-02-23",
                    "accountCodeId": 1001001,
                    "amount": 200
                  },
                  {
                    "transactionId": 2,
                    "accountingDate": "2022-02-23",
                    "accountCodeId": 4001001,
                    "amount": -200
                  }
                ]
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/accounting/trialBalance": {
      "get": {
        "summary": "Get trial balance",
        "operationId": "getTrialBalance",
        "tags": [
          "Trial Balance"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.transactions:read"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          },
          {
            "$ref": "#/components/parameters/compulsoryAccountingDateFrom"
          },
          {
            "$ref": "#/components/parameters/compulsoryAccountingDateTo"
          }
        ],
        "responses": {
          "200": {
            "description": "An array of trial balance lines",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrialBalance"
                },
                "example": [
                  {
                    "accountCodeId": 1001001,
                    "balance": 300
                  },
                  {
                    "accountCodeId": 2001001,
                    "balance": -50
                  },
                  {
                    "accountCodeId": 3001001,
                    "balance": -50
                  },
                  {
                    "accountCodeId": 4001001,
                    "balance": -200
                  }
                ]
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/accounting/journals": {
      "post": {
        "summary": "Create a journal",
        "description": "The sum of amounts of all lines in the journal must add up to 0.",
        "operationId": "createJournal",
        "tags": [
          "Journals"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.journals:write"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          }
        ],
        "requestBody": {
          "description": "Journal object",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Journal"
              },
              "example": {
                "description": "example journal",
                "accountingDate": "2022-02-22",
                "lines": [
                  {
                    "accountCodeId": 1001001,
                    "amount": 100
                  },
                  {
                    "accountCodeId": 2001001,
                    "amount": -50
                  },
                  {
                    "accountCodeId": 3001001,
                    "amount": -50
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Journal created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Journal"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "422": {
            "$ref": "#/components/responses/BusinessRuleError"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://secure.clearbooks.co.uk/account/action/oauth/",
            "tokenUrl": "https://api.clearbooks.co.uk/oauth/token",
            "scopes": {
              "businesses:read": "Read business data",
              "businesses:write": "Update business data",
              "accounting.account_codes:read": "Read account codes",
              "accounting.account_codes:write": "Create, update and delete account codes",
              "accounting.bank_accounts:read": "Read bank accounts",
              "accounting.bank_accounts:write": "Create, update and delete bank accounts",
              "accounting.customers:read": "Read customers",
              "accounting.customers:write": "Create, update and delete customers",
              "accounting.suppliers:read": "Read suppliers",
              "accounting.suppliers:write": "Create, update and delete suppliers",
              "accounting.sales:read": "Read sales documents",
              "accounting.sales:write": "Create, update and delete sales documents",
              "accounting.purchases:read": "Read purchase documents",
              "accounting.purchases:write": "Create, update and delete purchase documents",
              "accounting.payments:read": "Read payments",
              "accounting.payments:write": "Create, update and delete payments",
              "accounting.allocations:read": "Read allocations",
              "accounting.allocations:write": "Create, update and delete allocations",
              "accounting.stock_items:read": "Read stock items",
              "accounting.stock_items:write": "Create, update and delete stock items",
              "accounting.vat:read": "Read VAT information",
              "accounting.bank_feeds:write": "Create bank feeds",
              "accounting.bank_statements:write": "Create bank statements",
              "accounting.transactions:read": "Read transactions",
              "accounting.journals:write": "Create journals"
            }
          }
        }
      }
    },
    "schemas": {
      "Address": {
        "type": "object",
        "properties": {
          "building": {
            "type": "string"
          },
          "line1": {
            "type": "string"
          },
          "line2": {
            "type": "string"
          },
          "town": {
            "type": "string"
          },
          "county": {
            "type": "string"
          },
          "postcode": {
            "type": "string"
          },
          "countryCode": {
            "type": "string"
          }
        }
      },
      "Business": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "LimitedCompany",
              "SoleTrader",
              "Partnership",
              "Charity",
              "Club",
              "Other"
            ]
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "logoUrl": {
            "type": "string",
            "readOnly": true
          }
        }
      },
      "Businesses": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Business"
        }
      },
      "AccountCode": {
        "type": "object",
        "required": [
          "name",
          "heading"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "name": {
            "type": "string"
          },
          "heading": {
            "type": "integer",
            "format": "int32"
          },
          "defaultVatRate": {
            "type": "string"
          },
          "sales": {
            "type": "boolean"
          },
          "purchases": {
            "type": "boolean"
          }
        }
      },
      "AccountCodes": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/AccountCode"
        }
      },
      "BankAccount": {
        "allOf": [
          {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "int32",
                "readOnly": true
              },
              "accountCode": {
                "type": "integer",
                "format": "int32",
                "readOnly": true
              }
            }
          },
          {
            "$ref": "#/components/schemas/BankAccountDetails"
          },
          {
            "type": "object",
            "properties": {
              "paymentMethods": {
                "type": "array",
                "readOnly": true,
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "BankAccountDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BankAccountIdentifiers"
          },
          {
            "type": "object",
            "properties": {
              "currency": {
                "type": "string",
                "description": "ISO 4217 currency code. If omitted the home currency of the account is used."
              }
            }
          }
        ]
      },
      "BankAccountIdentifiers": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "accountNumber": {
            "type": "string"
          },
          "sortCode": {
            "type": "string"
          },
          "iban": {
            "type": "string"
          },
          "swift": {
            "type": "string"
          }
        }
      },
      "BankAccounts": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/BankAccount"
        }
      },
      "ContactName": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "enum": [
              "Mr",
              "Mrs",
              "Mr & Mrs",
              "Miss",
              "Ms",
              "Sir",
              "Rev",
              "Dr",
              "Ven",
              "Father",
              "Prof",
              "Dame",
              "Lord",
              "Lady"
            ]
          },
          "forenames": {
            "type": "string"
          },
          "surname": {
            "type": "string"
          }
        }
      },
      "Contact": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "name": {
            "type": "string"
          },
          "contactName": {
            "$ref": "#/components/schemas/ContactName"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "vatNumber": {
            "type": "string"
          },
          "companyNumber": {
            "type": "string"
          },
          "externalId": {
            "type": "string",
            "description": "Identifier for this contact in an external system. Clear Books does not make use of this value beyond storing it for integrated applications."
          },
          "archived": {
            "type": "boolean"
          }
        }
      },
      "Customer": {
        "$ref": "#/components/schemas/Contact"
      },
      "Customers": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Customer"
        }
      },
      "Supplier": {
        "$ref": "#/components/schemas/Contact"
      },
      "Suppliers": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Supplier"
        }
      },
      "LineItem": {
        "type": "object",
        "required": [
          "description",
          "unitPrice",
          "quantity",
          "accountCode",
          "vatRateKey"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "unitPrice": {
            "type": "number",
            "format": "double"
          },
          "quantity": {
            "type": "number",
            "format": "double"
          },
          "accountCode": {
            "type": "integer",
            "format": "int32"
          },
          "vatRateKey": {
            "type": "string",
            "description": "Must be set to \"Manual\" if vatAmount is provided."
          },
          "vatAmount": {
            "type": "number",
            "format": "double",
            "description": "Must be provided if vatRateKey is set to \"Manual\". May not be provided otherwise."
          },
          "stockItem": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "SalesDocument": {
        "type": "object",
        "required": [
          "date",
          "lineItems",
          "customerId",
          "vatTreatment"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "documentNumber": {
            "type": "string"
          },
          "formattedDocumentNumber": {
            "type": "string",
            "readOnly": true
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "dateAccrual": {
            "type": "string",
            "format": "date"
          },
          "datePaid": {
            "type": "string",
            "format": "date",
            "readOnly": true
          },
          "reference": {
            "type": "string"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code. If omitted the home currency of the account is used."
          },
          "exchangeRate": {
            "type": "double",
            "description": "Exchange rate from the home currency of the account to the specified currency for this document. May only be set if currency is provided. If omitted, will be provided automatically."
          },
          "description": {
            "type": "string",
            "description": "Referred to as \"summary\" in the Clear Books UI."
          },
          "status": {
            "type": "string",
            "readOnly": true
          },
          "gross": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "net": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "vat": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "vatTreatment": {
            "type": "string"
          },
          "lineItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LineItem"
            }
          },
          "customerId": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "SalesDocuments": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/SalesDocument"
        }
      },
      "SalesInvoice": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SalesDocument"
          },
          {
            "type": "object",
            "properties": {
              "dateDue": {
                "type": "string",
                "format": "date"
              },
              "due": {
                "type": "number",
                "format": "double",
                "readOnly": true
              },
              "displayBankAccountId": {
                "type": "integer",
                "description": "ID of a bank account whose details will be displayed on the print-formatted invoice.",
                "format": "int32"
              },
              "internetPaymentAccountIds": {
                "type": "array",
                "description": "List of bank account IDs for internet payment provider accounts. These will be made available for customer payments via the invoice web view. Instant Bank Payments, Stripe and PayPal accounts may be used. No more than one account per payment provider may be included. For Stripe, if the business has additional currency accounts configured, only the parent account ID should be used.",
                "items": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            }
          }
        ]
      },
      "SalesInvoices": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/SalesInvoice"
        }
      },
      "SalesCreditNote": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SalesDocument"
          },
          {
            "type": "object",
            "properties": {
              "due": {
                "type": "number",
                "format": "double",
                "readOnly": true
              }
            }
          }
        ]
      },
      "SalesCreditNotes": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/SalesCreditNote"
        }
      },
      "Quote": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SalesDocument"
          },
          {
            "type": "object",
            "properties": {
              "displayBankAccountId": {
                "type": "integer",
                "format": "int32"
              }
            }
          }
        ]
      },
      "Quotes": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Quote"
        }
      },
      "PurchaseDocument": {
        "type": "object",
        "required": [
          "date",
          "lineItems",
          "supplierId",
          "vatTreatment"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "documentNumber": {
            "type": "string"
          },
          "formattedDocumentNumber": {
            "type": "string",
            "readOnly": true
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "dateAccrual": {
            "type": "string",
