      "Payment": {
        "type": "object",
        "required": [
          "date",
          "description",
          "amount",
          "bankAccountId",
          "contactId"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Bank date of the payment."
          },
          "accountingDate": {
            "type": "string",
            "format": "date",
            "description": "Accounting date of the payment. Only needs to be provided on create if it differs from the bank date. If not provided, it will be automatically populated with the bank date."
          },
          "description": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "Amount of the payment. Should be positive for money received, and negative for money paid out."
          },
          "currency": {
            "type": "string",
            "readOnly": true,
            "description": "ISO 4217 currency code. This is the currency of the bank account and cannot be set on a per-payment level."
          },
          "exchangeRate": {
            "type": "float",
            "description": "Exchange rate from the home currency of the business to the currency of the specified bank account. May only be set if those currencies differ. If omitted on create, will be provided automatically. If omitted on update, the existing rate will be retained, unless you change the bank account to one in a different currency, in which case it will be replaced automatically. Otherwise, to discard the existing rate and have the system repopulate it automatically, set it to NULL."
          },
          "contactId": {
            "type": "integer",
            "format": "int32"
          },
          "paymentMethodId": {
            "type": "integer",
            "format": "int32",
            "description": "ID of a payment method available for the specified bank account. Payment method is recorded for reference only and is only visible when viewing individual Clear Books bank transactions and customer/supplier payments reports."
          },
          "bankAccountId": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "Payments": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Payment"
        }
      },
