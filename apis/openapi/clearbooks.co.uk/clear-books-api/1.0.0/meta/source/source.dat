      "sortBy": {
        "name": "sortBy",
        "in": "query",
        "description": "The field to sort results by",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "generalLedgerSortBy": {
        "name": "sortBy",
        "in": "query",
        "description": "The field to sort results by. Default value 'transactionId'",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "transactionId",
            "accountingDate",
            "accountCodeId",
            "amount"
          ]
