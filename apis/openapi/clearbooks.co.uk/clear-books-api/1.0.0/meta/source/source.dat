    "/accounting/sales/{salesType}/{salesId}": {
      "get": {
        "summary": "Retrieve a single sales document",
        "operationId": "getSalesDocument",
        "description": "Retrieve a sales document. If the provided ID refers to a voided previous revision of a document, a redirect to the current revision will be returned.",
        "tags": [
          "Sales"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.sales:read"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          },
          {
            "$ref": "#/components/parameters/salesType"
          },
          {
            "$ref": "#/components/parameters/salesId"
          }
        ],
        "responses": {
          "200": {
            "description": "A sales document object",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SalesInvoice"
                    },
                    {
                      "$ref": "#/components/schemas/SalesCreditNote"
                    },
                    {
                      "$ref": "#/components/schemas/Quote"
                    }
                  ]
                }
              }
            }
          },
          "308": {
            "description": "Redirect from a previous revision of a document to the current revision"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      },
      "patch": {
        "summary": "Update a sales document",
        "operationId": "updateSalesDocument",
        "description": "Update a sales document. For a non-draft invoice or credit note, the original document will be voided (soft deleted) and a new copy created with a new ID. For a quote or draft invoice, the document will be updated in-place and retain its original ID. You only need to provide the fields you want to update. No fields on the body of the document are required.",
        "tags": [
          "Sales"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.sales:write"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          },
          {
            "$ref": "#/components/parameters/salesType"
          },
          {
            "$ref": "#/components/parameters/salesId"
          }
        ],
        "requestBody": {
          "description": "Sales document object",
          "content": {
            "application/merge-patch+json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/SalesInvoice"
                  },
                  {
                    "$ref": "#/components/schemas/SalesCreditNote"
                  },
                  {
                    "$ref": "#/components/schemas/Quote"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sales document updated",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SalesInvoice"
                    },
                    {
                      "$ref": "#/components/schemas/SalesCreditNote"
                    },
                    {
                      "$ref": "#/components/schemas/Quote"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "422": {
            "$ref": "#/components/responses/BusinessRuleError"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      },
      "delete": {
        "summary": "Delete sales document",
        "operationId": "deleteSalesDocument",
        "description": "Delete a sales document. Non-draft invoices and credit notes will be voided (soft deleted). Quotes and draft invoices will be hard deleted.",
        "tags": [
          "Sales"
        ],
        "security": [
          {
            "OAuth2": [
              "accounting.sales:write"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/businessIdHeader"
          },
          {
            "$ref": "#/components/parameters/salesType"
          },
          {
            "$ref": "#/components/parameters/salesId"
          }
        ],
        "responses": {
          "204": {
            "description": "Sales document deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "422": {
            "$ref": "#/components/responses/BusinessRuleError"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
