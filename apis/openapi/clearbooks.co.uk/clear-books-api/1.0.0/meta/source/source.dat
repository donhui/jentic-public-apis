      "patch": {
        "summary": "Update a purchase document",
        "operationId": "updatePurchaseDocument",
        "description": "Update a purchase document. For a non-draft bill or credit note, the original document will be voided (soft deleted) and a new copy created with a new ID. For a draft bill, the document will be updated in-place. You only need to provide the fields you want to update. No fields on the body of the document are required.",
        "tags": [
