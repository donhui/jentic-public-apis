              }
            }
          },
          "401": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "description": "Widget confirmation"
      }
    }
  },
  "components": {
    "schemas": {
      "AccountInfo": {
        "type": "object",
        "properties": {
          "credits_info": {
            "type": "object"
          },
          "job_counts": {
            "type": "object"
          }
        }
      },
      "SingleCheckResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "valid",
              "invalid",
              "disposable",
              "catchall",
              "unknown"
            ]
          },
          "flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Account"
    },
    {
      "name": "Jobs"
    },
    {
      "name": "Verification"
    },
    {
      "name": "Widget"
    }
  ]
}
