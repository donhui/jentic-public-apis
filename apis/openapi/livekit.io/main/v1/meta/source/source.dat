{
  "openapi": "3.0.3",
  "info": {
    "title": "LiveKit Server API",
    "version": "v1",
    "description": "LiveKit's server-side API for managing rooms, participants, tracks, egress (recording/streaming), and ingress. LiveKit uses Twirp (Protocol Buffers over HTTP) but these endpoints are also accessible via JSON over HTTP POST.",
    "x-jentic-source-url": "https://docs.livekit.io/"
  },
  "servers": [
    {
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "your-livekit-host.livekit.cloud"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Room Service",
      "description": "Manage rooms and participants"
    },
    {
      "name": "Egress",
      "description": "Recording and streaming (egress)"
    },
    {
      "name": "Ingress",
      "description": "Inbound media streaming (ingress)"
    },
    {
      "name": "SIP",
      "description": "SIP trunks, dispatch rules, and SIP participants"
    }
  ],
  "paths": {
    "/twirp/livekit.RoomService/CreateRoom": {
      "post": {
        "operationId": "createRoom",
        "summary": "Create Room",
        "tags": ["Room Service"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoomRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Room created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Room"
                }
              }
            }
          }
        }
      }
    },
    "/twirp/livekit.RoomService/ListRooms": {
      "post": {
