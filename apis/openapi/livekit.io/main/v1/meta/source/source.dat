  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT signed with your LiveKit API key and secret"
      }
    },
    "schemas": {
      "Room": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string",
            "description": "Unique room identifier"
          },
          "name": {
            "type": "string",
            "description": "Room name"
          },
          "empty_timeout": {
            "type": "integer",
            "description": "Seconds to keep the room open after the last participant leaves"
          },
          "max_participants": {
            "type": "integer",
            "description": "Maximum number of participants allowed"
          },
          "creation_time": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of room creation"
          },
          "turn_password": {
            "type": "string",
            "description": "TURN server password"
          },
          "metadata": {
            "type": "string",
            "description": "User-defined metadata for the room"
          },
          "num_participants": {
            "type": "integer",
            "description": "Current number of participants"
          },
          "num_publishers": {
            "type": "integer",
            "description": "Current number of publishing participants"
          },
          "active_recording": {
            "type": "boolean",
            "description": "Whether the room is being actively recorded"
          }
        }
      },
      "ParticipantPermission": {
        "type": "object",
        "properties": {
          "can_subscribe": {
            "type": "boolean",
            "description": "Allow subscribing to tracks"
          },
          "can_publish": {
            "type": "boolean",
            "description": "Allow publishing tracks"
          },
          "can_publish_data": {
            "type": "boolean",
            "description": "Allow publishing data messages"
          },
          "can_publish_sources": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Sources allowed to publish (e.g. camera, microphone, screen_share)"
          },
          "hidden": {
            "type": "boolean",
            "description": "Hide participant from other participants"
          },
          "recorder": {
            "type": "boolean",
            "description": "Indicates this participant is a recorder"
          }
        }
      },
      "TrackInfo": {
        "type": "object",
        "properties": {
          "sid": {
            "type": "string",
            "description": "Track SID"
          },
          "type": {
            "type": "string",
            "enum": ["AUDIO", "VIDEO", "DATA"],
            "description": "Type of track"
          },
          "name": {
            "type": "string",
            "description": "Track name"
          },
          "muted": {
            "type": "boolean",
            "description": "Whether the track is muted"
          },
          "width": {
            "type": "integer",
            "description": "Video width (video tracks only)"
          },
          "height": {
            "type": "integer",
