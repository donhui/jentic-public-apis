{
  "openapi": "3.0.3",
  "info": {
    "title": "AnyMailFinder Email Finder API",
    "version": "v5.1",
    "description": "AnyMailFinder API for finding and verifying email addresses. Supports finding person emails, decision maker emails, email verification, and bad email reporting.",
    "x-jentic-source-url": "https://anymailfinder.com/email-finder-api/docs"
  },
  "servers": [
    {
      "url": "https://api.anymailfinder.com/v5.1",
      "description": "AnyMailFinder API v5.1"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/find-email/person": {
      "post": {
        "operationId": "findPersonEmail",
        "summary": "Find a person's email address",
        "description": "Find an email address for a specific person by providing their name and company domain or company name.",
        "tags": ["Email Finder"],
        "parameters": [
          {
            "name": "x-webhook-url",
            "in": "header",
            "description": "Webhook URL for asynchronous results delivery",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindPersonEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindPersonEmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid formatting or missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment required - insufficient credits",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/find-email/decision-maker": {
      "post": {
        "operationId": "findDecisionMakerEmail",
        "summary": "Find a decision maker's email address",
        "description": "Find email addresses for decision makers at a company by category (e.g., CEO, engineering, marketing).",
        "tags": ["Email Finder"],
        "parameters": [
          {
            "name": "x-webhook-url",
            "in": "header",
            "description": "Webhook URL for asynchronous results delivery",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindDecisionMakerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Decision maker email search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindDecisionMakerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/verify-email": {
      "post": {
        "operationId": "verifyEmail",
        "summary": "Verify an email address",
        "description": "Verify whether an email address is valid, risky, or invalid. Costs 0.2 credits per verification. Repeated verifications within 30 days are free.",
        "tags": ["Email Verification"],
        "parameters": [
          {
            "name": "x-webhook-url",
            "in": "header",
            "description": "Webhook URL for asynchronous results delivery",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyEmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment required - insufficient credits",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/report/bad-email": {
      "post": {
        "operationId": "reportBadEmail",
        "summary": "Report a bad email address",
        "description": "Report an email address as bad. This endpoint is free to use.",
        "tags": ["Reporting"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportBadEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Report received successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportBadEmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "FindPersonEmailRequest": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Company domain (preferred over company_name)",
            "example": "microsoft.com"
          },
          "company_name": {
            "type": "string",
            "description": "Company name (used if domain not provided)",
            "example": "Microsoft"
          },
          "first_name": {
            "type": "string",
            "description": "Person's first name",
            "example": "John"
          },
          "last_name": {
            "type": "string",
            "description": "Person's last name",
            "example": "Doe"
          },
          "full_name": {
            "type": "string",
            "description": "Person's full name (alternative to first_name + last_name)",
            "example": "John Doe"
          }
        }
      },
      "FindPersonEmailResponse": {
        "type": "object",
        "properties": {
          "credits_charged": {
            "type": "number",
            "description": "Number of credits consumed"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "description": "Found email address or null"
          },
          "email_status": {
            "type": "string",
            "enum": ["valid", "risky", "not_found", "blacklisted"],
            "description": "Status of the found email"
          },
          "valid_email": {
            "type": "string",
            "nullable": true,
            "description": "Email only if status is valid, otherwise null"
          }
        }
      },
      "FindDecisionMakerRequest": {
        "type": "object",
        "required": ["decision_maker_category"],
        "properties": {
          "decision_maker_category": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["ceo", "engineering", "finance", "hr", "it", "logistics", "marketing", "operations", "buyer", "sales"]
            },
            "description": "One or more decision maker categories"
          },
          "domain": {
            "type": "string",
            "description": "Company domain (preferred over company_name)",
            "example": "microsoft.com"
          },
          "company_name": {
            "type": "string",
            "description": "Company name",
            "example": "Microsoft"
          }
        }
      },
      "FindDecisionMakerResponse": {
        "type": "object",
        "properties": {
          "credits_charged": {
            "type": "number",
            "description": "Credits consumed (2 if valid email found, 0 otherwise)"
          },
          "decision_maker_category": {
            "type": "string",
            "nullable": true,
            "description": "Matched category"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "description": "Email address found"
          },
          "email_status": {
            "type": "string",
            "enum": ["valid", "risky", "not_found", "blacklisted"],
            "description": "Status of the found email"
          },
          "person_full_name": {
            "type": "string",
            "nullable": true,
            "description": "Decision maker's full name"
          },
          "person_job_title": {
            "type": "string",
            "nullable": true,
            "description": "Decision maker's job title"
          },
          "person_linkedin_url": {
            "type": "string",
            "nullable": true,
            "description": "Decision maker's LinkedIn profile URL"
          },
          "valid_email": {
            "type": "string",
            "nullable": true,
            "description": "Email only when status is valid"
          }
        }
      },
      "VerifyEmailRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "The email address to verify"
          }
        }
      },
      "VerifyEmailResponse": {
        "type": "object",
        "properties": {
          "credits_charged": {
            "type": "number",
            "description": "Credits consumed (0.2 per verification)"
          },
          "email_status": {
            "type": "string",
            "enum": ["valid", "risky", "invalid"],
            "description": "Verification result"
          }
        }
      },
      "ReportBadEmailRequest": {
        "type": "object",
        "required": ["email", "additional_info"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "The email address to report as bad"
          },
          "additional_info": {
            "type": "string",
            "description": "Additional information about why the email is bad"
          },
          "bounce_message": {
            "type": "string",
            "description": "The bounce message received when trying to send to this email"
          }
        }
      },
      "ReportBadEmailResponse": {
        "type": "object",
        "properties": {
          "input": {
            "type": "object",
            "description": "The original input that was reported"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type identifier"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          }
        }
      }
    }
  }
}