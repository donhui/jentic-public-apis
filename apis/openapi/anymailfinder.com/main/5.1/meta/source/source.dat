{
  "openapi": "3.0.3",
  "info": {
    "title": "AnyMailFinder Email Finder API",
    "version": "5.1",
    "description": "AnyMailFinder API for finding and verifying email addresses. Find person emails, decision maker emails, company emails, and verify email addresses.",
    "x-jentic-source-url": "https://anymailfinder.com/email-finder-api/docs"
  },
  "servers": [
    {
      "url": "https://api.anymailfinder.com/v5.1",
      "description": "AnyMailFinder API v5.1"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/find-email/person": {
      "post": {
        "operationId": "findPersonEmail",
        "summary": "Find a person's email address",
        "description": "Find an email address for a specific person by name and company domain or name.",
        "tags": ["Email Finder"],
        "parameters": [
          {
            "name": "x-webhook-url",
            "in": "header",
            "description": "Webhook URL to receive results asynchronously",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindPersonEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindPersonEmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or improperly formatted data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment needed - insufficient credits",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/find-email/decision-maker": {
      "post": {
        "operationId": "findDecisionMakerEmail",
        "summary": "Find a decision maker's email address",
        "description": "Find an email address for a decision maker at a company by category.",
        "tags": ["Email Finder"],
        "parameters": [
          {
            "name": "x-webhook-url",
            "in": "header",
            "description": "Webhook URL to receive results asynchronously",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindDecisionMakerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Decision maker email search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindDecisionMakerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/find-email/company": {
      "post": {
        "operationId": "findCompanyEmails",
        "summary": "Find company email addresses",
        "description": "Find email addresses associated with a company domain or name. Returns up to 20 emails.",
        "tags": ["Email Finder"],
        "parameters": [
          {
            "name": "x-webhook-url",
            "in": "header",
            "description": "Webhook URL to receive results asynchronously",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindCompanyEmailsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Company email search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindCompanyEmailsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/find-email/linkedin-url": {
      "post": {
        "operationId": "findEmailByLinkedInUrl",
        "summary": "Find email by LinkedIn URL",
        "description": "Find an email address for a person using their LinkedIn profile URL.",
        "tags": ["Email Finder"],
        "parameters": [
          {
            "name": "x-webhook-url",
            "in": "header",
            "description": "Webhook URL to receive results asynchronously",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindLinkedInEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "LinkedIn email search result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindLinkedInEmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/verify-email": {
      "post": {
        "operationId": "verifyEmail",
        "summary": "Verify an email address",
        "description": "Verify whether an email address is valid, risky, or invalid. Costs 0.2 credits per verification.",
        "tags": ["Email Verification"],
        "parameters": [
          {
            "name": "x-webhook-url",
            "in": "header",
            "description": "Webhook URL to receive results asynchronously",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyEmailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyEmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "FindPersonEmailRequest": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Company domain (preferred over company_name)",
            "example": "microsoft.com"
          },
          "company_name": {
            "type": "string",
            "description": "Company name; used if domain is unavailable",
            "example": "Microsoft"
          },
          "first_name": {
            "type": "string",
            "description": "Person's first name",
            "example": "John"
          },
          "last_name": {
            "type": "string",
            "description": "Person's last name",
            "example": "Doe"
          },
          "full_name": {
            "type": "string",
            "description": "Alternative to first_name and last_name",
            "example": "John Doe"
          }
        }
      },
      "FindPersonEmailResponse": {
        "type": "object",
        "properties": {
          "credits_charged": {
            "type": "number",
            "description": "Credits consumed (1 if valid email found, 0 otherwise)"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "description": "Located email address or null"
          },
          "email_status": {
            "type": "string",
            "enum": ["valid", "risky", "not_found", "blacklisted"],
            "description": "Status of the email search"
          },
          "valid_email": {
            "type": "string",
            "nullable": true,
            "description": "Email only when status is valid; otherwise null"
          },
          "input": {
            "type": "object",
            "description": "Original request parameters for debugging"
          }
        }
      },
      "FindDecisionMakerRequest": {
        "type": "object",
        "required": ["decision_maker_category"],
        "properties": {
          "decision_maker_category": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["ceo", "engineering", "finance", "hr", "it", "logistics", "marketing", "operations", "buyer", "sales"]
            },
            "description": "Categories of decision makers to search for"
          },
          "domain": {
            "type": "string",
            "description": "Company domain (preferred)",
            "example": "microsoft.com"
          },
          "company_name": {
            "type": "string",
            "description": "Company name; at least one of domain or company_name required"
          }
        }
      },
      "FindDecisionMakerResponse": {
        "type": "object",
        "properties": {
          "credits_charged": {
            "type": "number",
            "description": "Credits consumed (2 for valid email, 0 otherwise)"
          },
          "decision_maker_category": {
            "type": "string",
            "nullable": true,
            "description": "Matched category or null"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "description": "Email address found or null"
          },
          "email_status": {
            "type": "string",
            "enum": ["valid", "risky", "not_found", "blacklisted"]
          },
          "person_full_name": {
            "type": "string",
            "nullable": true,
            "description": "Decision maker's name"
          },
          "person_job_title": {
            "type": "string",
            "nullable": true,
            "description": "Job title"
          },
          "person_linkedin_url": {
            "type": "string",
            "nullable": true,
            "description": "LinkedIn profile URL"
          },
          "valid_email": {
            "type": "string",
            "nullable": true,
            "description": "Email only when status is valid"
          }
        }
      },
      "FindCompanyEmailsRequest": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "Company domain (preferred)",
            "example": "microsoft.com"
          },
          "company_name": {
            "type": "string",
            "description": "Company name"
          },
          "email_type": {
            "type": "string",
            "enum": ["any", "generic", "personal"],
            "default": "any",
            "description": "Filter results by email type"
          }
        }
      },
      "FindCompanyEmailsResponse": {
        "type": "object",
        "properties": {
          "credits_charged": {
            "type": "number",
            "description": "Credits consumed (1 if valid emails found, 0 otherwise)"
          },
          "email_status": {
            "type": "string",
            "enum": ["valid", "risky", "not_found", "blacklisted"]
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Up to 20 email addresses discovered"
          },
          "valid_emails": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Subset containing only verified valid emails"
          }
        }
      },
      "FindLinkedInEmailRequest": {
        "type": "object",
        "required": ["linkedin_url"],
        "properties": {
          "linkedin_url": {
            "type": "string",
            "format": "uri",
            "description": "LinkedIn profile URL of the target person"
          }
        }
      },
      "FindLinkedInEmailResponse": {
        "type": "object",
        "properties": {
          "credits_charged": {
            "type": "number",
            "description": "Credits consumed (1 if valid email found, 0 otherwise)"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "description": "Discovered email address or null"
          },
          "email_status": {
            "type": "string",
            "enum": ["valid", "risky", "not_found", "blacklisted"]
          },
          "valid_email": {
            "type": "string",
            "nullable": true,
            "description": "Email only when status is valid"
          },
          "person_full_name": {
            "type": "string",
            "nullable": true,
            "description": "Extracted full name"
          },
          "person_job_title": {
            "type": "string",
            "nullable": true,
            "description": "Job title from profile"
          },
          "person_company_name": {
            "type": "string",
            "nullable": true,
            "description": "Company affiliation"
          }
        }
      },
      "VerifyEmailRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "The email address to verify",
            "example": "john.doe@microsoft.com"
          }
        }
      },
      "VerifyEmailResponse": {
        "type": "object",
        "properties": {
          "credits_charged": {
            "type": "number",
            "description": "0.2 credit charged per verification"
          },
          "email_status": {
            "type": "string",
            "enum": ["valid", "risky", "invalid"],
            "description": "Verification result"
          },
          "input": {
            "type": "string",
            "description": "Original email input"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}