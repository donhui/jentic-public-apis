{
  "openapi": "3.0.3",
  "info": {
    "title": "ParkWhiz Parking API",
    "description": "ParkWhiz Transactional API v4 for searching parking availability, booking parking spots, managing accounts, vehicles, and payment methods.",
    "version": "4.0.0",
    "x-jentic-source-url": "https://partners.parkwhiz.com/docs/"
  },
  "servers": [
    {
      "url": "https://api.parkwhiz.com/v4",
      "description": "Production"
    },
    {
      "url": "https://api-sandbox.parkwhiz.com/v4",
      "description": "Sandbox"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/oauth/token": {
      "post": {
        "operationId": "createToken",
        "summary": "Generate access token",
        "description": "Generate access tokens using various OAuth grant flows.",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id", "client_secret"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["client_credentials", "password", "authorization_code", "refresh_token"]
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Authorization scope (internal, mobile, partner, public)"
                  },
                  "customer_email": {
                    "type": "string",
                    "description": "Required for password grant"
                  },
                  "customer_password": {
                    "type": "string",
                    "description": "Required for password grant"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Required for refresh_token grant"
                  },
                  "code": {
                    "type": "string",
                    "description": "Required for authorization_code grant"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "description": "Required for authorization_code grant"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/oauth/authorize": {
      "post": {
        "operationId": "authorizeUser",
        "summary": "Obtain authorization code",
        "description": "Obtain authorization code for user authorization token.",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["response_type", "client_id", "client_secret", "redirect_uri", "scope"],
                "properties": {
                  "response_type": {
                    "type": "string",
                    "enum": ["code"]
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "redirect_uri": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "customer_email": {
                    "type": "string"
                  },
                  "customer_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "Redirect to redirect_uri with code parameter"
          }
        }
      }
    },
    "/oauth/public_token": {
      "post": {
        "operationId": "createPublicToken",
        "summary": "Generate public token",
        "description": "Generate public client credentials token without exposing secret.",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["client_id"],
                "properties": {
                  "client_id": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string",
                    "default": "public"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Public token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/quotes": {
      "get": {
        "operationId": "searchQuotes",
        "summary": "Search parking quotes",
        "description": "Search for parking price and availability.",
        "tags": ["Quotes"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Query string with search parameters (event_id, venue_id, location_id, coordinates, bounds, seller_id, distance, search_type)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_time",
            "in": "query",
            "description": "Start time in ISO 8601 format (required for non-event searches)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "description": "End time in ISO 8601 format (required for non-event searches)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "option_types",
            "in": "query",
            "description": "Filter by option type: bookable, non_bookable, on_demand",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "capabilities",
            "in": "query",
            "description": "Key:value capability filters",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pricing_access_codes",
            "in": "query",
            "description": "Comma-separated pricing access codes",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_id",
            "in": "query",
            "description": "Partner user identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recommendations_only",
            "in": "query",
            "description": "Return only recommended results",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Comma-separated field names to include",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "zoom",
            "in": "query",
            "description": "Related resource keys to expand",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Quote results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Quote"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "No quotes found"
          }
        }
      }
    },
    "/locations": {
      "get": {
        "operationId": "searchLocations",
        "summary": "Search parking locations",
        "description": "Search for parking facilities in a geographic area.",
        "tags": ["Locations"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Query string (venue_id, coordinates, bounds, beacon)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "zoom",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Location results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Location"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/locations/{location_id}": {
      "get": {
        "operationId": "getLocation",
        "summary": "Get location details",
        "description": "Retrieve a single parking facility's details.",
        "tags": ["Locations"],
        "parameters": [
          {
            "name": "location_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Location details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "404": {
            "description": "Location not found"
          }
        }
      }
    },
    "/locations/{location_id}/reviews": {
      "get": {
        "operationId": "listLocationReviews",
        "summary": "List location reviews",
        "description": "Retrieve reviews for a parking facility.",
        "tags": ["Locations"],
        "parameters": [
          {
            "name": "location_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reviews list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Review"
                  }
                }
              }
            }
          },
          "404": {
            "description": "No reviews found"
          }
        }
      },
      "post": {
        "operationId": "createLocationReview",
        "summary": "Create location review",
        "description": "Create a review for a parking facility.",
        "tags": ["Locations"],
        "parameters": [
          {
            "name": "location_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["booking_id", "rating"],
                "properties": {
                  "booking_id": {
                    "type": "string"
                  },
                  "rating": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Review created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Review"
                }
              }
            }
          }
        }
      }
    },
    "/locations/{location_id}/reviews/{review_id}": {
      "get": {
        "operationId": "getLocationReview",
        "summary": "Get specific review",
        "description": "Retrieve a specific review for a parking facility.",
        "tags": ["Locations"],
        "parameters": [
          {
            "name": "location_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "review_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Review details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Review"
                }
              }
            }
          },
          "404": {
            "description": "Review not found"
          }
        }
      }
    },
    "/bookings": {
      "get": {
        "operationId": "listBookings",
        "summary": "List bookings",
        "description": "Retrieve a list of bookings for the authenticated user.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "zoom",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bookings list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Booking"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createBooking",
        "summary": "Create booking",
        "description": "Book parking based on a quote.",
        "tags": ["Bookings"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["final_price"],
                "properties": {
                  "final_price": {
                    "type": "number",
                    "description": "Purchase price from preview"
                  },
                  "quote_id": {
                    "type": "string",
                    "description": "Purchase option UUID"
                  },
                  "booking_hold_id": {
                    "type": "string",
                    "description": "Partner booking hold ID"
                  },
                  "add_on_ids": {
                    "type": "string",
                    "description": "Comma-separated add-on UUIDs"
                  },
                  "customer_id": {
                    "type": "string"
                  },
                  "customer_email": {
                    "type": "string"
                  },
                  "customer_first_name": {
                    "type": "string"
                  },
                  "customer_last_name": {
                    "type": "string"
                  },
                  "payment_method_nonce": {
                    "type": "string",
                    "description": "Braintree payment nonce"
                  },
                  "saved_payment_token": {
                    "type": "string",
                    "description": "Braintree saved payment token"
                  },
                  "save_credit_card": {
                    "type": "boolean"
                  },
                  "coupon_code": {
                    "type": "string"
                  },
                  "device_data": {
                    "type": "string",
                    "description": "Braintree fraud data"
                  },
                  "partner_booking_id": {
                    "type": "string"
                  },
                  "send_email_confirmation": {
                    "type": "boolean"
                  },
                  "plate_number": {
                    "type": "string"
                  },
                  "vehicle_id": {
                    "type": "string"
                  },
                  "enterprise_account_id": {
                    "type": "string"
                  },
                  "invoice": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Booking created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Booking"
                }
              }
            }
          },
          "400": {
            "description": "Validation or booking error"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/bookings/previews": {
      "post": {
        "operationId": "previewBooking",
        "summary": "Preview booking price",
        "description": "Get price preview before purchasing a booking.",
        "tags": ["Bookings"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["quote_id"],
                "properties": {
                  "quote_id": {
                    "type": "string"
                  },
                  "add_on_ids": {
                    "type": "string"
                  },
                  "coupon_code": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Booking preview",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookingPreview"
                }
              }
            }
          }
        }
      }
    },
    "/bookings/{booking_id}": {
      "get": {
        "operationId": "getBooking",
        "summary": "Get booking details",
        "description": "Retrieve a specific booking's details.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization_code",
            "in": "query",
            "description": "Parking pass authorization code for public access",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "zoom",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Booking"
                }
              }
            }
          },
          "404": {
            "description": "Booking not found"
          }
        }
      },
      "delete": {
        "operationId": "cancelBooking",
        "summary": "Cancel booking",
        "description": "Cancel a booking.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking cancelled"
          },
          "400": {
            "description": "Cannot cancel"
          },
          "404": {
            "description": "Booking not found"
          }
        }
      }
    },
    "/bookings/{booking_id}/parking_pass": {
      "get": {
        "operationId": "getBookingParkingPass",
        "summary": "Get parking pass",
        "description": "Retrieve parking pass for a booking.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization_code",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Parking pass details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParkingPass"
                }
              }
            }
          }
        }
      }
    },
    "/bookings/{booking_id}/vehicle": {
      "get": {
        "operationId": "getBookingVehicle",
        "summary": "Get booking vehicle",
        "description": "Retrieve vehicle associated with a booking.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Vehicle details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Vehicle"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "setBookingVehicle",
        "summary": "Set booking vehicle",
        "description": "Set the vehicle associated with a booking.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["vehicle_id"],
                "properties": {
                  "vehicle_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Vehicle set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Vehicle"
                }
              }
            }
          }
        }
      }
    },
    "/bookings/{booking_id}/extend_preview": {
      "post": {
        "operationId": "previewBookingExtension",
        "summary": "Preview booking extension",
        "description": "Preview extended parking for a booking.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["end_time"],
                "properties": {
                  "end_time": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extension preview"
          }
        }
      }
    },
    "/bookings/{booking_id}/extend": {
      "post": {
        "operationId": "extendBooking",
        "summary": "Extend booking",
        "description": "Extend parking duration for a booking.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["end_time", "final_price"],
                "properties": {
                  "end_time": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "final_price": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Booking extended",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Booking"
                }
              }
            }
          }
        }
      }
    },
    "/bookings/{booking_id}/tickets": {
      "get": {
        "operationId": "listBookingTickets",
        "summary": "Get booking tickets",
        "description": "Get tickets associated with a booking.",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tickets list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Ticket"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/monthly_bookings": {
      "get": {
        "operationId": "listMonthlyBookings",
