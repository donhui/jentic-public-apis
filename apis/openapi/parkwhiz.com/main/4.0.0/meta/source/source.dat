{
  "openapi": "3.0.3",
  "info": {
    "title": "ParkWhiz Partner API",
    "description": "The ParkWhiz Partner API v4 provides comprehensive parking search, booking, and management capabilities. Features include parking availability search, location details, booking creation and management, account management, and review functionality. Supports OAuth 2.0 authentication with multiple grant flows.",
    "version": "4.0.0",
    "x-jentic-source-url": "https://developer.parkwhiz.com/v4/"
  },
  "servers": [
    {
      "url": "https://api.parkwhiz.com/v4",
      "description": "Production server"
    },
    {
      "url": "https://api-sandbox.parkwhiz.com/v4",
      "description": "Sandbox server"
    }
  ],
  "security": [
    {
      "OAuth2": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "OAuth 2.0 authentication endpoints"
    },
    {
      "name": "Quotes",
      "description": "Parking availability and pricing search"
    },
    {
      "name": "Locations",
      "description": "Parking facility search and details"
    },
    {
      "name": "Bookings",
      "description": "Parking booking creation and management"
    },
    {
      "name": "Accounts",
      "description": "User account management"
    },
    {
      "name": "Reviews",
      "description": "Facility reviews"
    },
    {
      "name": "Tickets",
      "description": "Support ticket management"
    },
    {
      "name": "Vehicles",
      "description": "Vehicle management"
    },
    {
      "name": "Events",
      "description": "Event search and details"
    },
    {
      "name": "Venues",
      "description": "Venue search and details"
    },
    {
      "name": "Payment Methods",
      "description": "Payment method management"
    }
  ],
  "paths": {
    "/oauth/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Obtain OAuth access token",
        "description": "Get an access token using OAuth 2.0 grant flows (client_credentials, password, authorization_code, refresh_token)",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["client_credentials", "password", "authorization_code", "refresh_token"],
                    "description": "OAuth 2.0 grant type"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Client ID"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Client secret"
                  },
                  "username": {
                    "type": "string",
                    "description": "User email (for password grant)"
                  },
                  "password": {
                    "type": "string",
                    "description": "User password (for password grant)"
                  },
                  "code": {
                    "type": "string",
                    "description": "Authorization code (for authorization_code grant)"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token (for refresh_token grant)"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Requested scope (internal, mobile, partner, public)"
                  }
                },
                "required": ["grant_type"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token granted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/public_token": {
      "post": {
        "operationId": "getPublicToken",
        "summary": "Obtain public token",
        "description": "Get a public scope token for mobile/public applications without exposing client secret",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Client ID"
                  }
                },
                "required": ["client_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Public token granted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/quotes": {
      "get": {
        "operationId": "searchQuotes",
        "summary": "Search parking availability and pricing",
        "description": "Search for parking quotes by location coordinates, event/venue, or address with date/time parameters",
        "tags": ["Quotes"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Latitude coordinate"
          },
          {
            "name": "lng",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Longitude coordinate"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Parking start time in ISO 8601 format"
          },
          {
            "name": "end",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Parking end time in ISO 8601 format"
          },
          {
            "name": "event_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Event identifier"
          },
          {
            "name": "venue_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Venue identifier"
          },
          {
            "name": "distance",
            "in": "query",
            "schema": {
              "type": "number",
              "default": 0.5
            },
            "description": "Search radius in miles (default: 0.5)"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100
            },
            "description": "Results per page (max 100)"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort field and direction (e.g., 'price:asc')"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to include"
          },
          {
            "name": "zoom",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Embed related resources (e.g., 'pw:location')"
          }
        ],
        "responses": {
          "200": {
            "description": "Quotes retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Quote"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/locations": {
      "get": {
        "operationId": "searchLocations",
        "summary": "Search parking facilities",
