{
  "openapi": "3.0.3",
  "info": {
    "title": "Careerjet Job Search API",
    "description": "The Careerjet API provides access to Careerjet's job search engine, allowing partners to search and display job listings from thousands of websites. Supports multiple locales, filtering by contract type, work hours, salary sorting, and radius-based location search.",
    "version": "4.0.0",
    "contact": {
      "name": "Careerjet",
      "url": "https://www.careerjet.com/partners/"
    },
    "x-jentic-source-url": "https://www.careerjet.com/partners/api/"
  },
  "servers": [
    {
      "url": "https://search.api.careerjet.net",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Job Search",
      "description": "Search for job listings across multiple job boards"
    }
  ],
  "paths": {
    "/v4/query": {
      "get": {
        "operationId": "searchJobs",
        "summary": "Search for job listings",
        "description": "Search Careerjet's aggregated job listings using keywords, location, and various filters. Requires the end-user's IP address and user agent for proper attribution.",
        "tags": ["Job Search"],
        "parameters": [
          {
            "name": "user_ip",
            "in": "query",
            "required": true,
            "description": "The IP address of the end-user whose action triggered the API call",
            "schema": { "type": "string" }
          },
          {
            "name": "user_agent",
            "in": "query",
            "required": true,
            "description": "The user agent string of the end-user whose action triggered the API call",
            "schema": { "type": "string" }
          },
          {
            "name": "locale_code",
            "in": "query",
            "description": "Locale code in format language_COUNTRY (e.g., en_GB, de_DE, fr_FR)",
            "schema": {
              "type": "string",
              "default": "en_GB"
            }
          },
          {
            "name": "keywords",
            "in": "query",
            "description": "Job search keywords (URL-encoded)",
            "schema": { "type": "string" }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Location filter. If omitted, searches country-wide.",
            "schema": { "type": "string" }
          },
          {
            "name": "contract_type",
            "in": "query",
            "description": "Contract type filter: p=permanent, c=contract, t=temporary, i=internship, v=voluntary",
            "schema": {
              "type": "string",
              "enum": ["p", "c", "t", "i", "v"]
            }
          },
          {
            "name": "work_hours",
            "in": "query",
            "description": "Work hours filter: f=full-time, p=part-time",
            "schema": {
              "type": "string",
              "enum": ["f", "p"]
            }
          },
          {
            "name": "fragment_size",
            "in": "query",
            "description": "Maximum character length for job description fragments",
            "schema": {
              "type": "integer",
              "default": 120
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order for results",
            "schema": {
              "type": "string",
              "enum": ["relevance", "date", "salary"],
              "default": "relevance"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Result offset (0-999)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 999,
              "default": 0
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (1-10)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Number of results per page (1-100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          {
            "name": "radius",
            "in": "query",
            "description": "Search radius from location in km or miles (depends on locale)",
            "schema": {
              "type": "integer",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - unsupported locale code or invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - missing required user_ip or user_agent parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication using API key as username with an empty password. Encode as Base64(api_key:)."
      }
    },
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Response type (JOBS for job results, LOCATIONS for location disambiguation)",
            "enum": ["JOBS", "LOCATIONS"]
          },
          "hits": {
            "type": "integer",
            "description": "Total number of matching jobs"
          },
          "message": {
            "type": "string",
            "description": "Human-readable result message"
          },
          "pages": {
            "type": "integer",
            "description": "Total number of pages available"
          },
          "response_time": {
            "type": "number",
            "format": "float",
            "description": "Query response time in seconds"
          },
          "jobs": {
            "type": "array",
            "description": "Array of job listings",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          },
          "locations": {
            "type": "array",
            "description": "Array of location choices when multiple locations match",
            "items": {
              "$ref": "#/components/schemas/Location"
            }
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Job title"
          },
          "company": {
            "type": "string",
            "description": "Company name"
          },
          "date": {
            "type": "string",
            "description": "Publication date"
          },
          "description": {
            "type": "string",
            "description": "Job description fragment"
          },
          "locations": {
            "type": "string",
            "description": "Job location(s)"
          },
          "salary": {
            "type": "string",
            "description": "Salary information"
          },
          "salary_min": {
            "type": "number",
            "description": "Minimum salary value"
          },
          "salary_max": {
            "type": "number",
            "description": "Maximum salary value"
          },
          "salary_type": {
            "type": "string",
            "description": "Salary period type (e.g., yearly, monthly, hourly)"
          },
          "salary_currency_code": {
            "type": "string",
            "description": "ISO 4217 currency code for salary"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the full job listing"
          },
          "site": {
            "type": "string",
            "description": "Source website domain"
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Location name"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Error type"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}
