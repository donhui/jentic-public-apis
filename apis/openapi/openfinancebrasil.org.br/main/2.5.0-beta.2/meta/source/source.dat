        ],
        "properties": {
          "data": {
            "type": "array",
            "description": "Lista dos lan\u00e7amentos referentes \u00e0s transa\u00e7\u00f5es realizadas e de lan\u00e7amentos futuros para as contas de: dep\u00f3sito \u00e0 vista, poupan\u00e7a e de pagamento pr\u00e9-paga\n",
            "minItems": 0,
