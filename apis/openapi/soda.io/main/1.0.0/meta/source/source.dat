{
  "openapi": "3.0.3",
  "info": {
    "title": "Soda Cloud REST API",
    "description": "Soda Cloud REST API for managing datasets and retrieving check results. Supports two cloud regions: EU (cloud.soda.io) and US (cloud.us.soda.io).",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.soda.io/reference/rest-api"
  },
  "servers": [
    {
      "url": "https://cloud.soda.io",
      "description": "Soda Cloud EU region"
    },
    {
      "url": "https://cloud.us.soda.io",
      "description": "Soda Cloud US region"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/api/v1/datasets/{datasetId}": {
      "post": {
        "operationId": "createorupdatedataset",
        "summary": "Create or update dataset data",
        "description": "Create or update data for the specified dataset.",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "datasetId",
            "in": "path",
            "required": true,
            "description": "The dataset identifier.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Key-value pairs of data to create or update.",
                "additionalProperties": true,
                "example": {
                  "key": "value",
                  "key2": "value2"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dataset data created or updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Response object."
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "Unauthorized - invalid or missing credentials."
          },
          "404": {
            "description": "Dataset not found."
          }
        }
      }
    },
    "/api/v1/checks": {
      "get": {
        "operationId": "getchecks",
        "summary": "Retrieve check results",
        "description": "Retrieve check results or details, optionally filtered by check IDs.",
        "tags": [
          "Checks"
        ],
        "parameters": [
          {
            "name": "checkIds",
            "in": "query",
            "description": "Array of check identifiers to filter results.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Check results retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CheckResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication using a base64-encoded token from your Soda Cloud API credentials."
      }
    },
    "schemas": {
      "CheckResult": {
        "type": "object",
        "properties": {
          "checkId": {
            "type": "string",
            "description": "The check identifier."
          },
          "status": {
            "type": "string",
            "description": "The check result status."
          },
          "details": {
            "type": "object",
            "description": "Additional check result details."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Checks",
      "description": "Operations related to Checks"
    },
    {
      "name": "Datasets",
      "description": "Operations related to Datasets"
    }
  ]
}