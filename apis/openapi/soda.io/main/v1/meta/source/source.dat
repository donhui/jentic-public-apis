{
  "openapi": "3.0.3",
  "info": {
    "title": "Soda Cloud REST API",
    "description": "REST API for interacting with Soda Cloud, enabling programmatic access to create/update datasets and retrieve check results.",
    "version": "v1",
    "x-jentic-source-url": "https://docs.soda.io/reference/rest-api"
  },
  "servers": [
    {
      "url": "https://cloud.us.soda.io",
      "description": "Soda Cloud US"
    },
    {
      "url": "https://cloud.soda.io",
      "description": "Soda Cloud EU"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Datasets",
      "description": "Operations related to dataset management"
    },
    {
      "name": "Checks",
      "description": "Operations related to data quality checks"
    }
  ],
  "paths": {
    "/api/v1/datasets/{datasetId}": {
      "post": {
        "operationId": "createOrUpdateDataset",
        "summary": "Create or update dataset data",
        "description": "Create or update data for a specified dataset in Soda Cloud.",
        "tags": ["Datasets"],
        "parameters": [
          {
            "name": "datasetId",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the dataset",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DatasetInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dataset created or updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/checks": {
      "get": {
        "operationId": "getCheckResults",
        "summary": "Retrieve check results",
        "description": "Retrieve data quality check results or details from Soda Cloud.",
        "tags": ["Checks"],
        "parameters": [
          {
            "name": "checkIds",
            "in": "query",
            "required": false,
            "description": "Array of check IDs to filter results",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Check results retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckResultsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication using base64-encoded API_KEY_ID:API_KEY_SECRET"
      }
    },
    "schemas": {
      "DatasetInput": {
        "type": "object",
        "description": "Dataset data as key-value pairs",
        "additionalProperties": true,
        "example": {
          "key1": "value1",
          "key2": "value2"
        }
      },
      "DatasetResponse": {
        "type": "object",
        "description": "Response from creating or updating a dataset",
        "properties": {
          "datasetId": {
            "type": "string",
            "description": "The unique identifier of the dataset"
          },
          "status": {
            "type": "string",
            "description": "The status of the operation"
          }
        }
      },
      "CheckResultsResponse": {
        "type": "object",
        "description": "Response containing check results",
        "properties": {
          "checks": {
            "type": "array",
            "description": "List of check results",
            "items": {
              "$ref": "#/components/schemas/CheckResult"
            }
          }
        }
      },
      "CheckResult": {
        "type": "object",
        "description": "Individual check result",
        "properties": {
          "checkId": {
            "type": "string",
            "description": "The unique identifier of the check"
          },
          "status": {
            "type": "string",
            "description": "The status of the check"
          },
          "result": {
            "type": "object",
            "description": "The check result details"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Error response",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  }
}