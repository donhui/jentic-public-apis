{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/SUPPORT_86/ListShot-Zapier-API/1.0.0"
    },
    {
      "description": "ListShot API for Zapier Integration",
      "url": "https://listshot.ai"
    }
  ],
  "info": {
    "description": "ListShot-Zapier API",
    "version": "1.0.0",
    "title": "ListShot-Zapier Integration API",
    "contact": {
      "email": "support@listshot.ai"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://app.swaggerhub.com/apis-docs/SUPPORT_86/ListShot-Zapier-API/1.0.0"
  },
  "paths": {
    "/zapier": {
      "post": {
        "summary": "Test Zapier Authentication",
        "description": "This URL is used to Test Zapier Authentication and get example output",
        "responses": {
          "200": {
            "description": "Authentication success and Template result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/exportProperty"
                  }
                }
              }
            }
          },
          "404": {
            "description": "user not found"
          },
          "401": {
            "description": "apikey not valid/unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/authItem"
              }
            }
          },
          "description": "Authentication data"
        }
      }
    },
    "/zapier/subscription": {
      "get": {
        "summary": "Get Listshot Export Example",
        "description": "This URL is used to get a ListShot Property export example",
        "responses": {
          "200": {
            "description": "ListShot Property Export Template result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/exportProperty"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Zapier user subscription to ListShot",
        "description": "This URL is used to subscribe the user to Zapier Export",
        "responses": {
          "200": {
            "description": "Subscription success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/subscribeResult"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/subscribeResult"
                  }
                }
              }
            }
          },
          "401": {
            "description": "apikey not valid/unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/subscribeResult"
                  }
                }
              }
            }
          },
          "404": {
            "description": "missing params/user not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/subscribeResult"
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/authItem"
                  },
                  {
                    "properties": {
                      "hookUrl": {
                        "type": "string",
                        "example": "Zapier Hook URL to get Triggers"
                      }
                    }
                  }
                ]
              }
            }
          },
          "description": "Authentication data"
        }
      },
      "delete": {
        "summary": "Zapier user unsubscription to ListShot",
        "description": "This URL is used to unsubscribe the user to Zapier Export",
        "responses": {
          "200": {
            "description": "Authentication success and Template result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/subscribeResult"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/subscribeResult"
                  }
                }
              }
            }
          },
          "401": {
            "description": "apikey not valid/unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/subscribeResult"
                  }
                }
              }
            }
          },
          "404": {
            "description": "missing params/user not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/subscribeResult"
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/authItem"
              }
            }
          },
          "description": "Authentication data"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "authItem": {
        "type": "object",
        "required": [
          "email",
          "apikey"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "example@example.com"
          },
          "apikey": {
            "type": "string",
            "example": "Apikey string provided by listshot App for user"
          }
        }
      },
      "subscribeResult": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "Params Missing / user not found / Unauthorized / success / ERROR"
          }
        }
      },
      "exportProperty": {
        "properties": {
          "name": {
            "type": "string",
            "example": "Property Name,"
          },
          "type": {
            "type": "string",
            "example": "Type of Property example,"
          },
          "sqm": {
            "type": "string",
            "example": "Total Square meters example,"
          },
          "price": {
            "type": "string",
            "example": "Price example,"
          },
          "address": {
            "type": "string",
            "example": "Property Address example,"
          },
          "description": {
            "type": "string",
            "example": "Property Description example,"
          },
          "bedroomsNum": {
            "type": "string",
            "example": "number of bedrooms,"
          },
          "bathroomsNum": {
            "type": "string",
            "example": "number of bathrooms,"
          },
          "latitude": {
            "type": "string",
            "example": "Property Position Latitude,"
          },
          "longitude": {
            "type": "string",
            "example": "Property Position Longitude,"
          },
          "condtion": {
            "type": "string",
            "example": "Condition of the Proeprty,"
          },
          "features": {
            "type": "string",
            "example": "feature1,feature2,...,featureN"
          },
          "featureList": {
            "type": "array",
            "items": {
              "type": "string",
              "example": [
                "feature1",
                "feature2",
                "featureN"
              ]
            }
          },
          "priceVisibility": {
            "type": "string",
            "example": "Price Visibility,"
          },
          "constructionYear": {
            "type": "string",
            "example": "Property Construction Year"
          },
          "elevator": {
            "type": "string",
            "example": "if elevator present"
          },
          "exposure": {
            "type": "string",
            "example": "N-NE"
          },
          "energyClass": {
            "type": "string",
            "example": "Property Energy Class"
          },
          "energyIndex": {
            "type": "string",
            "example": "Property Energy Index"
          },
          "energyIndexMq": {
            "type": "string",
            "example": "Property Energy Index per square meter"
          },
          "gardenSqm": {
            "type": "string",
            "example": "Total Garden Footage"
          },
          "landSqm": {
            "type": "string",
            "example": "Total Land Footage"
          },
          "garageSqm": {
            "type": "string",
            "example": "Total Garage Footage"
          },
          "cellarSqm": {
            "type": "string",
            "example": "Total Cellar Footage"
          },
          "terraceSqm": {
            "type": "string",
            "example": "Total Terrace Footage"
          },
          "ownerFirstName": {
            "type": "string",
            "example": "Property Owner's First Name"
          },
          "ownerLastName": {
            "type": "string",
            "example": "Property Owner's Last Name,"
          },
          "ownerPhone": {
            "type": "string",
            "example": "Property Owner's Phone Number"
          },
          "ownerEmail": {
            "type": "string",
            "example": "Property Owner's email address"
          },
          "ownerFiscalCode": {
            "type": "string",
            "example": "Property Owner's Fiscal Code"
          },
          "ownerBirthCity": {
            "type": "string",
            "example": "Birth Place of the Property Owner"
          },
          "ownerBirthDate": {
            "type": "string",
            "example": "Birth Date of the Property Owner"
          },
          "ownerAddress": {
            "type": "string",
            "example": "Property Owner's Address"
          },
          "ownerAddressNumer": {
            "type": "string",
            "example": "Property Owner's Address Number"
          },
          "ownerCity": {
            "type": "string",
            "example": "City of the Property Owner's"
          },
          "ownerZipCode": {
            "type": "string",
            "example": "Zip Code of Property Owner's"
          },
          "ownerProvince": {
            "type": "string",
            "example": "Province of the Property Owner"
          },
          "ownerNation": {
            "type": "string",
            "example": "Nation of the Property Owner"
          },
          "pictures": {
            "type": "string",
            "example": "URL picture1, URL picture2, URL pictureN"
          },
          "picturesList": {
            "type": "array",
            "items": {
              "type": "string",
              "example": [
                "picture1",
                "picture2",
                "pictureN"
              ]
            }
          }
        }
      }
    }
  }
}