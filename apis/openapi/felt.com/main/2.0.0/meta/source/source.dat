{
  "openapi": "3.0.3",
  "info": {
    "title": "Felt REST API",
    "version": "2.0.0",
    "description": "Felt REST API for creating maps, uploading layers, managing styles, and working with annotations.",
    "x-jentic-source-url": "https://developers.felt.com/"
  },
  "servers": [
    {
      "url": "https://felt.com/api/v2"
    }
  ],
  "paths": {
    "/maps": {
      "post": {
        "operationId": "createMap",
        "summary": "Create a new map",
        "tags": ["Maps"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMapRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Map created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MapResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized - invalid or missing bearer token" }
        }
      }
    },
    "/maps/{mapId}/upload": {
      "post": {
        "operationId": "uploadLayer",
        "summary": "Upload a layer from URL",
        "tags": ["Layers"],
        "parameters": [
          { "name": "mapId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadLayerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Layer uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadLayerResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/maps/{mapId}/layers/{layerId}/update_style": {
      "post": {
        "operationId": "updateLayerStyle",
        "summary": "Update a layer's style",
        "tags": ["Layers"],
        "parameters": [
          { "name": "mapId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "layerId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "style": {
                    "type": "object",
                    "description": "Felt Style Language JSON object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Style updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/maps/{mapId}/layers/{layerId}/refresh": {
      "post": {
        "operationId": "refreshLayer",
        "summary": "Refresh a live data layer",
        "tags": ["Layers"],
        "parameters": [
          { "name": "mapId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "layerId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Layer refreshed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/maps/{mapId}/elements": {
      "get": {
        "operationId": "listAnnotations",
        "summary": "List all annotations on a map",
        "tags": ["Annotations"],
        "parameters": [
          { "name": "mapId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "GeoJSON FeatureCollection of annotations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeoJSONFeatureCollection"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createOrUpdateAnnotations",
        "summary": "Create or update annotations on a map",
        "tags": ["Annotations"],
        "parameters": [
          { "name": "mapId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeoJSONFeatureCollection"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Annotations created or updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeoJSONFeatureCollection"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/maps/{mapId}/element_groups": {
      "get": {
        "operationId": "listAnnotationGroups",
        "summary": "List annotation groups on a map",
        "tags": ["Annotations"],
        "parameters": [
          { "name": "mapId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of GeoJSON FeatureCollections per group",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GeoJSONFeatureCollection"
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/maps/{mapId}/elements/{elementId}": {
      "delete": {
        "operationId": "deleteAnnotation",
        "summary": "Delete an annotation",
        "tags": ["Annotations"],
        "parameters": [
          { "name": "mapId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "elementId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Annotation deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateMapRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "lat": { "type": "number" },
          "lon": { "type": "number" },
          "public_access": { "type": "string" }
        }
      },
      "MapResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Map unique identifier" },
          "url": { "type": "string", "description": "Map URL" }
        }
      },
      "UploadLayerRequest": {
        "type": "object",
        "required": ["import_url"],
        "properties": {
          "import_url": { "type": "string", "description": "URL of the data to import" },
          "name": { "type": "string", "description": "Name for the layer" }
        }
      },
      "UploadLayerResponse": {
        "type": "object",
        "properties": {
          "layer_id": { "type": "string", "description": "Layer unique identifier" }
        }
      },
      "GeoJSONFeatureCollection": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["FeatureCollection"] },
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["Feature"] },
                "geometry": { "type": "object" },
                "properties": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}