{
  "openapi": "3.0.3",
  "info": {
    "title": "Felt REST API",
    "description": "Felt REST API allows editors to interact with the Felt platform via code, performing actions such as creating maps, adding data layers, styling layers, and refreshing live data.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://developers.felt.com/"
  },
  "servers": [
    {
      "url": "https://felt.com/api/v2",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Maps", "description": "Create and manage maps" },
    { "name": "Layers", "description": "Manage map layers, uploads, and styling" }
  ],
  "paths": {
    "/maps": {
      "post": {
        "operationId": "createMap",
        "summary": "Create a map",
        "description": "Creates a new map within the Felt platform.",
        "tags": ["Maps"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMapRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Map created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Map"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/maps/{mapId}/upload": {
      "post": {
        "operationId": "uploadLayerFromUrl",
        "summary": "Upload a layer from URL",
        "description": "Adds a data layer to a map by importing from a URL.",
        "tags": ["Layers"],
        "parameters": [
          {
            "name": "mapId",
            "in": "path",
            "required": true,
            "description": "The map ID",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadLayerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Layer uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LayerUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/maps/{mapId}/layers/{layerId}/update_style": {
      "post": {
        "operationId": "updateLayerStyle",
        "summary": "Update layer style",
        "description": "Applies styling using Felt Style Language (FSL) to a layer.",
        "tags": ["Layers"],
        "parameters": [
          {
            "name": "mapId",
            "in": "path",
            "required": true,
            "description": "The map ID",
            "schema": { "type": "string" }
          },
          {
            "name": "layerId",
            "in": "path",
            "required": true,
            "description": "The layer ID",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateStyleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Style updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LayerStyleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/maps/{mapId}/layers/{layerId}/refresh": {
      "post": {
        "operationId": "refreshLayer",
        "summary": "Refresh live data layer",
        "description": "Refreshes data for URL-based layers with live sources.",
        "tags": ["Layers"],
        "parameters": [
          {
            "name": "mapId",
            "in": "path",
            "required": true,
            "description": "The map ID",
            "schema": { "type": "string" }
          },
          {
            "name": "layerId",
            "in": "path",
            "required": true,
            "description": "The layer ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Layer refreshed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "CreateMapRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Name of the map"
          },
          "lat": {
            "type": "number",
            "description": "Latitude for initial view"
          },
          "lon": {
            "type": "number",
            "description": "Longitude for initial view"
          },
          "public_access": {
            "type": "string",
            "description": "Privacy setting for the map",
            "enum": ["private", "view", "edit"]
          }
        }
      },
      "Map": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "lat": { "type": "number" },
          "lon": { "type": "number" },
          "public_access": { "type": "string" }
        }
      },
      "UploadLayerRequest": {
        "type": "object",
        "required": ["import_url", "name"],
        "properties": {
          "import_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the data source"
          },
          "name": {
            "type": "string",
            "description": "Layer name"
          }
        }
      },
      "LayerUploadResponse": {
        "type": "object",
        "properties": {
          "layer_id": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "UpdateStyleRequest": {
        "type": "object",
        "required": ["style"],
        "properties": {
          "style": {
            "type": "object",
            "description": "FSL specification object",
            "properties": {
              "type": { "type": "string" },
              "version": { "type": "string" },
              "paint": { "type": "object" },
              "legend": { "type": "object" }
            }
          }
        }
      },
      "LayerStyleResponse": {
        "type": "object",
        "properties": {
          "layer_id": { "type": "string" },
          "style": { "type": "object" }
        }
      },
      "RefreshResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "layer_id": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}