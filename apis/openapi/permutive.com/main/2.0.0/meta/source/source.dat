{
  "openapi": "3.0.3",
  "info": {
    "title": "Permutive Audience API",
    "description": "Permutive API for audience segmentation, cohort management, event tracking, identity resolution, contextual signals, and taxonomy management.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://developer.permutive.com/docs"
  },
  "servers": [
    {
      "url": "https://api.permutive.app",
      "description": "Permutive API server"
    },
    {
      "url": "https://api.permutive.com",
      "description": "Permutive Contextual API server"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {"name": "Cohorts", "description": "Programmatically view and maintain cohort definitions"},
    {"name": "Events", "description": "Track user events for segmentation and insights"},
    {"name": "Identity", "description": "User identity creation, identification, and alias management"},
    {"name": "Segmentation", "description": "Real-time user segmentation (CCS)"},
    {"name": "Contextual", "description": "Contextual signals and cohort matching"},
    {"name": "Taxonomy", "description": "Second-party data import and segment management"}
  ],
  "paths": {
    "/cohorts-api/v2/cohorts": {
      "get": {
        "operationId": "listCohorts",
        "summary": "Retrieve all cohorts",
        "description": "Retrieve all cohorts with optional child workspace inclusion.",
        "tags": ["Cohorts"],
        "parameters": [
          {"name": "k", "in": "query", "required": true, "schema": {"type": "string"}, "description": "API key"}
        ],
        "responses": {
          "200": {
            "description": "List of cohorts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Cohort"}
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "500": {"$ref": "#/components/responses/InternalError"}
        }
      },
      "post": {
        "operationId": "createCohort",
        "summary": "Create a new cohort",
        "description": "Create a new cohort with a query definition. The cohort belongs to the workspace associated with the API key.",
        "tags": ["Cohorts"],
        "parameters": [
          {"name": "k", "in": "query", "required": true, "schema": {"type": "string"}, "description": "API key"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "query"],
                "properties": {
                  "name": {"type": "string", "description": "Cohort name"},
                  "description": {"type": "string", "description": "Cohort description"},
                  "query": {"type": "object", "description": "Query definition in Cohort API JSON format"},
                  "tags": {"type": "array", "items": {"type": "string"}, "description": "Label tags"},
                  "segment_type": {"type": "string", "enum": ["real_time", "offline"], "description": "Segment type"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cohort created successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Cohort"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "409": {"description": "Conflict - duplicate resource exists"}
        }
      }
    },
    "/cohorts-api/v2/cohorts/{cohortId}": {
      "get": {
        "operationId": "getCohort",
        "summary": "Fetch individual cohort details",
        "tags": ["Cohorts"],
        "parameters": [
          {"name": "cohortId", "in": "path", "required": true, "schema": {"type": "string"}, "description": "Cohort ID"},
          {"name": "k", "in": "query", "required": true, "schema": {"type": "string"}, "description": "API key"}
        ],
        "responses": {
          "200": {
            "description": "Cohort details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Cohort"}
              }
            }
          },
          "404": {"description": "Cohort not found"}
        }
      },
      "patch": {
        "operationId": "updateCohort",
        "summary": "Update an existing cohort",
        "tags": ["Cohorts"],
        "parameters": [
          {"name": "cohortId", "in": "path", "required": true, "schema": {"type": "string"}, "description": "Cohort ID"},
          {"name": "k", "in": "query", "required": true, "schema": {"type": "string"}, "description": "API key"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "description": {"type": "string"},
                  "query": {"type": "object"},
                  "tags": {"type": "array", "items": {"type": "string"}},
                  "segment_type": {"type": "string", "enum": ["real_time", "offline"]}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cohort updated",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Cohort"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "404": {"description": "Cohort not found"}
        }
      },
      "delete": {
        "operationId": "deleteCohort",
        "summary": "Remove a cohort",
        "description": "Delete a cohort. Excludes lookalike-based cohort types.",
        "tags": ["Cohorts"],
        "parameters": [
          {"name": "cohortId", "in": "path", "required": true, "schema": {"type": "string"}, "description": "Cohort ID"},
          {"name": "k", "in": "query", "required": true, "schema": {"type": "string"}, "description": "API key"}
        ],
        "responses": {
          "200": {"description": "Cohort deleted successfully"},
          "404": {"description": "Cohort not found"}
        }
      }
    },
    "/v2.0/events": {
      "post": {
        "operationId": "trackEvent",
        "summary": "Track an event",
        "description": "Creates a new event for a user, persisting it in Permutive for segmentation, insights, or data lake routing. Validates against defined schemas and optionally enriches with geo/ISP data.",
        "tags": ["Events"],
        "parameters": [
          {"name": "enrich", "in": "query", "schema": {"type": "boolean", "default": true}, "description": "Enrich the event with geo, ISP, and NLP data"},
          {"name": "sdkp", "in": "query", "schema": {"type": "boolean", "default": true}, "description": "Indicates event origin: true for SDK, false for direct API"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {"type": "string", "pattern": "^[a-zA-Z0-9_]+$", "description": "Event collection name"},
                  "user_id": {"type": "string", "format": "uuid", "description": "Permutive user identifier"},
                  "aliases": {
                    "type": "array",
                    "items": {"$ref": "#/components/schemas/Alias"},
                    "description": "Prioritized aliases for user identification"
                  },
                  "view_id": {"type": "string", "format": "uuid", "description": "Groups events within a page/screen view"},
                  "session_id": {"type": "string", "format": "uuid", "description": "Groups events within a user session"},
                  "properties": {"type": "object", "description": "Event data (max 950 KB)"},
                  "segments": {"type": "array", "items": {"type": "integer"}, "description": "Segment codes at event time"},
                  "cohorts": {"type": "array", "items": {"type": "string"}, "description": "Cohort IDs at event time"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Event created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user_id": {"type": "string", "format": "uuid"},
                    "name": {"type": "string"},
                    "time": {"type": "string", "format": "date-time"},
                    "view_id": {"type": "string", "format": "uuid"},
                    "session_id": {"type": "string", "format": "uuid"},
                    "properties": {"type": "object"},
                    "segments": {"type": "array", "items": {"type": "integer"}},
                    "cohorts": {"type": "array", "items": {"type": "string"}}
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/v2.0/users": {
      "post": {
        "operationId": "createUserId",
        "summary": "Create a new user ID",
        "description": "Generates a new user ID that can be used to identify a user within Permutive.",
        "tags": ["Identity"],
        "responses": {
          "200": {
            "description": "User ID created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string", "format": "uuid", "description": "Generated user ID"}
                  }
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/v2.0/identify": {
      "post": {
        "operationId": "identifyUser",
        "summary": "Associate identities with a user",
        "description": "Associate one or more identities with a Permutive user, allowing identification across multiple systems.",
        "tags": ["Identity"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id", "aliases"],
                "properties": {
                  "user_id": {"type": "string", "format": "uuid", "description": "The Permutive user ID"},
                  "aliases": {
                    "type": "array",
                    "items": {"$ref": "#/components/schemas/Alias"},
                    "description": "List of prioritized aliases"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User identified successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user_id": {"type": "string", "format": "uuid", "description": "Resolved user ID"}
                  }
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/v2.0/users/{userId}/aliases": {
      "get": {
        "operationId": "retrieveIdentities",
        "summary": "Retrieve user identities",
        "description": "Retrieves all identities available for a given user.",
        "tags": ["Identity"],
        "parameters": [
          {"name": "userId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Permutive user ID"}
        ],
        "responses": {
          "200": {
            "description": "List of user identities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "Identity value"},
                      "tag": {"type": "string", "description": "Identity type tag"},
                      "permutive_id": {"type": "string", "format": "uuid", "description": "Resolved Permutive user ID"}
                    }
                  }
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "403": {"description": "Forbidden - insufficient permissions"}
        }
      }
    },
    "/ccs/v1/segmentation": {
      "post": {
        "operationId": "segmentUser",
        "summary": "Segment a user",
        "description": "Process user events combined with existing state to determine cohort membership. Events are published to the Events API.",
        "tags": ["Segmentation"],
        "parameters": [
          {"name": "activations", "in": "query", "schema": {"type": "boolean", "default": false}, "description": "Return activated cohorts in response"},
          {"name": "synchronous-validation", "in": "query", "schema": {"type": "boolean", "default": false}, "description": "Validate events against schema before segmentation"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["events"],
                "properties": {
                  "user_id": {"type": "string", "format": "uuid"},
                  "alias": {
                    "type": "object",
                    "properties": {
                      "tag": {"type": "string"},
                      "id": {"type": "string"}
                    }
                  },
                  "aliases": {
                    "type": "array",
                    "items": {"$ref": "#/components/schemas/Alias"}
                  },
                  "events": {
                    "type": "array",
                    "maxItems": 10,
                    "items": {
                      "type": "object",
                      "required": ["name", "time", "properties"],
                      "properties": {
                        "name": {"type": "string"},
                        "time": {"type": "string", "format": "date-time"},
                        "properties": {"type": "object"},
                        "view_id": {"type": "string", "format": "uuid"},
                        "session_id": {"type": "string", "format": "uuid"}
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Segmentation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user_id": {"type": "string", "format": "uuid"},
                    "cohorts": {"type": "array", "items": {"type": "string"}},
                    "activations": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {"type": "string"}
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/ccs/v1/segmentation/stateless": {
      "post": {
        "operationId": "segmentUserStateless",
        "summary": "Stateless user segmentation",
        "description": "Segment user based on provided events and state only, without persisting state to a database.",
        "tags": ["Segmentation"],
        "parameters": [
          {"name": "synchronous-validation", "in": "query", "schema": {"type": "boolean", "default": false}, "description": "Enable schema validation before segmentation"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["events"],
                "properties": {
                  "user_id": {"type": "string", "format": "uuid"},
                  "alias": {
                    "type": "object",
                    "properties": {
                      "tag": {"type": "string"},
                      "id": {"type": "string"}
                    }
                  },
                  "aliases": {
                    "type": "array",
                    "items": {"$ref": "#/components/schemas/Alias"}
                  },
                  "events": {
                    "type": "array",
                    "maxItems": 10,
                    "items": {
                      "type": "object",
                      "required": ["name", "time", "properties"],
                      "properties": {
                        "name": {"type": "string"},
                        "time": {"type": "string", "format": "date-time"},
                        "properties": {"type": "object"},
                        "view_id": {"type": "string", "format": "uuid"},
                        "session_id": {"type": "string", "format": "uuid"}
                      }
                    }
                  },
                  "state": {"type": "object", "description": "Previous user state for continuity"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stateless segmentation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user_id": {"type": "string", "format": "uuid"},
                    "state": {
                      "type": "object",
                      "properties": {
                        "internal_state": {"type": "object"},
                        "external_state": {"type": "object"},
                        "cohorts": {"type": "array", "items": {"type": "string"}}
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/ctx/v1/segment": {
      "post": {
        "operationId": "getContextualSegments",
        "summary": "Get contextual segments",
        "description": "Retrieves contextual cohort codes for a given URL and page properties, formatted for ad platform integration.",
        "tags": ["Contextual"],
        "servers": [
          {"url": "https://api.permutive.com", "description": "Contextual API server"}
        ],
        "parameters": [
          {"name": "k", "in": "query", "required": true, "schema": {"type": "string"}, "description": "API key"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url", "page_properties"],
                "properties": {
                  "url": {"type": "string", "description": "Target page URL"},
                  "page_properties": {
                    "type": "object",
                    "description": "Page classification data excluding user identifiers",
                    "properties": {
                      "client": {
                        "type": "object",
                        "properties": {
                          "url": {"type": "string"},
                          "domain": {"type": "string"},
                          "referrer": {"type": "string"},
                          "type": {"type": "string", "enum": ["web", "ios", "android"]},
                          "user_agent": {"type": "string"},
                          "title": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contextual segments matched",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cohorts": {"type": "array", "items": {"type": "string"}},
                    "activations": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {"type": "string"}
                      }
                    },
                    "contextual_data": {
                      "type": "object",
                      "properties": {
                        "categories": {"type": "array", "items": {"type": "string"}},
                        "keywords": {"type": "array", "items": {"type": "string"}},
                        "entities": {"type": "array", "items": {"type": "string"}},
                        "sentiment": {"type": "object"},
                        "emotion": {"type": "object"},
                        "concepts": {"type": "array", "items": {"type": "string"}}
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"}
        }
      }
    },
    "/audience-api/v1/imports": {
      "get": {
        "operationId": "listImports",
        "summary": "Get all imports",
        "description": "Get all 2nd party data imports.",
        "tags": ["Taxonomy"],
        "responses": {
          "200": {
            "description": "List of imports",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "elements": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Import"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/audience-api/v1/imports/{importId}/segments": {
      "get": {
        "operationId": "listSegmentsForImport",
        "summary": "Get all segments for an import",
        "description": "Retrieves all segments for an import. Supports pagination.",
        "tags": ["Taxonomy"],
        "parameters": [
          {"name": "importId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Import ID"},
          {"name": "pagination_token", "in": "query", "schema": {"type": "string"}, "description": "Pagination token for subsequent pages"}
        ],
        "responses": {
          "200": {
            "description": "List of segments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "elements": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/TaxonomySegment"}
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "nextToken": {"type": "string"},
                        "totalCount": {"type": "integer"}
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"}
        }
      },
      "post": {
        "operationId": "createSegmentForImport",
        "summary": "Create a segment for an import",
        "tags": ["Taxonomy"],
        "parameters": [
          {"name": "importId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Import ID"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "code"],
                "properties": {
                  "name": {"type": "string"},
                  "code": {"type": "string"},
                  "description": {"type": "string"},
                  "cpm": {"type": "number", "format": "double"},
                  "categories": {"type": "array", "items": {"type": "string"}}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Segment created",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/TaxonomySegment"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"}
        }
      }
    },
    "/audience-api/v1/imports/{importId}/segments/{segmentId}": {
      "get": {
        "operationId": "getSegmentById",
        "summary": "Get segment by ID",
        "description": "Retrieves a single segment identified by its globally unique public ID.",
        "tags": ["Taxonomy"],
        "parameters": [
          {"name": "importId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Import ID"},
          {"name": "segmentId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Segment ID"}
        ],
        "responses": {
          "200": {
            "description": "Segment details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/TaxonomySegment"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"}
        }
      },
      "patch": {
        "operationId": "updateSegmentById",
        "summary": "Update segment by ID",
        "tags": ["Taxonomy"],
        "parameters": [
          {"name": "importId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Import ID"},
          {"name": "segmentId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Segment ID"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "description": {"type": "string"},
                  "cpm": {"type": "number", "format": "double"},
                  "categories": {"type": "array", "items": {"type": "string"}}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Segment updated",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/TaxonomySegment"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"}
        }
      },
      "delete": {
        "operationId": "deleteSegmentById",
        "summary": "Delete segment by ID",
        "tags": ["Taxonomy"],
        "parameters": [
          {"name": "importId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Import ID"},
          {"name": "segmentId", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}, "description": "Segment ID"}
        ],
        "responses": {
          "200": {
            "description": "Segment deleted",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/TaxonomySegment"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "k",
        "description": "API key passed as query parameter"
      },
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key passed as header"
      }
    },
    "schemas": {
      "Cohort": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "code": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "query": {"type": "object"},
          "tags": {"type": "array", "items": {"type": "string"}},
          "state": {"type": "string"},
          "segment_type": {"type": "string", "enum": ["real_time", "offline"]},
          "created_at": {"type": "string", "format": "date-time"},
          "last_updated_at": {"type": "string", "format": "date-time"},
          "workspace_id": {"type": "string"}
        }
      },
      "Alias": {
        "type": "object",
        "required": ["priority", "tag", "id"],
        "properties": {
          "priority": {"type": "integer", "description": "Alias priority (0 is highest)"},
          "tag": {"type": "string", "description": "Alias type identifier (e.g., email_sha256)"},
          "id": {"type": "string", "description": "Identifier value"}
        }
      },
      "Import": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "code": {"type": "string"},
          "relation": {"type": "string"},
          "identifiers": {"type": "array", "items": {"type": "string"}},
          "source": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "state": {"type": "string"},
              "type": {"type": "string"}
            }
          }
        }
      },
      "TaxonomySegment": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "code": {"type": "string"},
          "name": {"type": "string"},
          "importId": {"type": "string", "format": "uuid"},
          "description": {"type": "string"},
          "cpm": {"type": "number", "format": "double"},
          "categories": {"type": "array", "items": {"type": "string"}},
          "updatedAt": {"type": "string", "format": "date-time"}
        }
      },
      "HttpErrorResponse": {
        "type": "object",
        "properties": {
          "request_id": {"type": "string", "format": "uuid"},
          "error": {
            "type": "object",
            "properties": {
              "status": {"type": "integer"},
              "code": {"type": "string"},
              "message": {"type": "string"},
              "docs": {"type": "string", "format": "uri"}
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters or body",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/HttpErrorResponse"}
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/HttpErrorResponse"}
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/HttpErrorResponse"}
          }
        }
      }
    }
  }
}