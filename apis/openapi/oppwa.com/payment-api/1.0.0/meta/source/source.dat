{
  "openapi": "3.0.3",
  "info": {
    "title": "HyperPay Open Payment Platform API",
    "description": "The Open Payment Platform (OPP) API by HyperPay provides a server-to-server payment integration supporting credit/debit cards, digital wallets, bank transfers, and various alternative payment methods. Supports pre-authorization, debit, credit, capture, reversal, and refund operations.",
    "version": "1.0.0",
    "contact": {
      "name": "HyperPay Developer Support",
      "url": "https://wordpresshyperpay.docs.oppwa.com/"
    },
    "x-jentic-source-url": "https://wordpresshyperpay.docs.oppwa.com/"
  },
  "servers": [
    {
      "url": "https://eu-test.oppwa.com",
      "description": "Test environment"
    },
    {
      "url": "https://eu-prod.oppwa.com",
      "description": "Production environment"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Payments",
      "description": "Payment operations including debit, pre-authorization, credit, capture, reversal, and refund"
    },
    {
      "name": "Checkout",
      "description": "Checkout/widget preparation operations"
    }
  ],
  "paths": {
    "/v1/checkouts": {
      "post": {
        "operationId": "prepareCheckout",
        "summary": "Prepare Checkout",
        "description": "Create a checkout session to collect payment details using COPYandPAY widget integration. Returns a checkout ID that can be used with the payment widget.",
        "tags": [
          "Checkout"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CheckoutRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Checkout prepared successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid authorization header",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/checkouts/{checkoutId}/payment": {
      "get": {
        "operationId": "getCheckoutPaymentStatus",
        "summary": "Get Checkout Payment Status",
        "description": "Retrieve the payment status for a given checkout ID after the customer has completed the payment form.",
        "tags": [
          "Checkout"
        ],
        "parameters": [
          {
            "name": "checkoutId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The checkout ID returned from prepareCheckout"
          },
          {
            "name": "entityId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The channel entity identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment status retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/payments": {
      "post": {
        "operationId": "createPayment",
        "summary": "Create Payment (Server-to-Server)",
        "description": "Submit a payment directly via server-to-server integration. Supports Debit (DB), Pre-authorization (PA), Credit (CD) payment types with card, bank account, virtual account, or token payment methods.",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/PaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment processed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request or payment declined",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/payments/{paymentId}": {
      "get": {
        "operationId": "getPaymentStatus",
        "summary": "Get Payment Status",
        "description": "Retrieve the status and details of a previously submitted payment by its ID.",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The payment ID returned from the initial payment request"
          },
          {
            "name": "entityId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The channel entity identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createBackofficePayment",
        "summary": "Backoffice Operation (Capture/Reversal/Refund/Rebill)",
        "description": "Perform backoffice operations on an existing payment: Capture (CP), Reversal (RV), or Refund (RF). Reference the original payment ID in the path.",
        "tags": [
          "Payments"
        ],
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The payment ID of the original transaction"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/BackofficeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Backoffice operation processed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request or operation declined",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Authorization Bearer header with access token obtained from the backend UI."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/Result"
          },
          "buildNumber": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "ndc": {
            "type": "string"
          }
        }
      },
      "Result": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Result code (e.g. 000.100.110 for success)"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the result"
          }
        }
      },
      "CheckoutRequest": {
        "type": "object",
        "required": [
          "entityId",
          "amount",
          "currency",
          "paymentType"
        ],
        "properties": {
          "entityId": {
            "type": "string",
            "description": "Channel entity identifier"
          },
          "amount": {
            "type": "string",
            "pattern": "^[0-9]{1,10}(\\.[0-9]{2})?$",
            "description": "Payment amount with two decimal places"
          },
          "currency": {
            "type": "string",
            "pattern": "^[A-Z]{3}$",
            "description": "ISO 4217 currency code"
          },
          "paymentType": {
            "type": "string",
            "enum": [
              "PA",
              "DB",
              "CD"
            ],
            "description": "Payment type: PA (Pre-auth), DB (Debit), CD (Credit)"
          },
          "integrity": {
            "type": "string",
            "enum": [
              "true",
              "false"
            ],
            "description": "Whether to return SRI hash for PCI compliance"
          },
          "merchantTransactionId": {
            "type": "string",
            "description": "Merchant reference number"
          },
          "testMode": {
            "type": "string",
            "enum": [
              "INTERNAL",
              "EXTERNAL"
            ],
            "description": "Test mode (only for test environment)"
          }
        }
      },
      "CheckoutResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Checkout ID to use with the payment widget"
          },
          "result": {
            "$ref": "#/components/schemas/Result"
          },
          "buildNumber": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "ndc": {
            "type": "string"
          }
        }
      },
      "PaymentRequest": {
        "type": "object",
        "required": [
          "entityId",
          "amount",
          "currency",
          "paymentType"
        ],
        "properties": {
          "entityId": {
            "type": "string",
            "description": "Channel entity identifier"
          },
          "amount": {
            "type": "string",
            "pattern": "^[0-9]{1,10}(\\.[0-9]{2})?$",
            "description": "Payment amount"
          },
          "currency": {
            "type": "string",
            "pattern": "^[A-Z]{3}$",
            "description": "ISO 4217 currency code"
          },
          "paymentBrand": {
            "type": "string",
            "description": "Payment brand (e.g. VISA, MASTER, AMEX, PAYPAL)"
          },
          "paymentType": {
            "type": "string",
            "enum": [
              "PA",
              "DB",
              "CD"
            ],
            "description": "PA=Pre-auth, DB=Debit, CD=Credit"
          },
          "card.number": {
            "type": "string",
            "description": "Card PAN"
          },
          "card.holder": {
            "type": "string",
            "description": "Cardholder name"
          },
          "card.expiryMonth": {
            "type": "string",
            "pattern": "^(0[1-9]|1[0-2])$",
            "description": "Card expiry month (01-12)"
          },
          "card.expiryYear": {
            "type": "string",
            "pattern": "^(19|20)[0-9]{2}$",
            "description": "Card expiry year (4 digits)"
          },
          "card.cvv": {
            "type": "string",
            "description": "Card CVV/CVC"
          },
          "bankAccount.holder": {
            "type": "string",
            "description": "Bank account holder name"
          },
          "bankAccount.iban": {
            "type": "string",
            "description": "Bank account IBAN"
          },
          "bankAccount.bic": {
            "type": "string",
            "description": "Bank BIC/SWIFT code"
          },
          "bankAccount.country": {
            "type": "string",
            "description": "Bank account country (ISO 3166-1)"
          },
          "merchantTransactionId": {
            "type": "string",
            "description": "Merchant transaction reference"
          },
          "descriptor": {
            "type": "string",
            "description": "Statement descriptor"
          },
          "testMode": {
            "type": "string",
            "enum": [
              "INTERNAL",
              "EXTERNAL"
            ]
          }
        }
      },
      "BackofficeRequest": {
        "type": "object",
        "required": [
          "entityId",
          "amount",
          "currency",
          "paymentType"
        ],
        "properties": {
          "entityId": {
            "type": "string",
            "description": "Channel entity identifier"
          },
          "amount": {
            "type": "string",
            "description": "Amount for the operation"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "paymentType": {
            "type": "string",
            "enum": [
              "CP",
              "RV",
              "RF"
            ],
            "description": "CP=Capture, RV=Reversal, RF=Refund"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Payment transaction ID"
          },
          "paymentType": {
            "type": "string"
          },
          "paymentBrand": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "descriptor": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/Result"
          },
          "resultDetails": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "card": {
            "type": "object",
            "properties": {
              "bin": {
                "type": "string"
              },
              "last4Digits": {
                "type": "string"
              },
              "holder": {
                "type": "string"
              },
              "expiryMonth": {
                "type": "string"
              },
              "expiryYear": {
                "type": "string"
              }
            }
          },
          "risk": {
            "type": "object",
            "properties": {
              "score": {
                "type": "string"
              }
            }
          },
          "buildNumber": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "ndc": {
            "type": "string"
          }
        }
      }
    }
  }
}
