  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key for authentication. Add as query parameter: key=<api_key>"
      }
    },
    "parameters": {
      "url": {
        "name": "url",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uri"
        },
        "description": "The webpage URL to capture"
      },
      "instance_id": {
        "name": "instance_id",
        "in": "query",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Browser instance identifier"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Authentication failure",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ScreenshotResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "finished",
              "in_process",
              "error"
            ],
            "description": "Screenshot status"
          },
          "id": {
            "type": "integer",
            "description": "Screenshot identifier"
          },
          "screenshot_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the screenshot image"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Original page URL"
          },
          "instance_id": {
            "type": "integer",
            "description": "Browser instance used"
          },
          "cost": {
            "type": "integer",
            "description": "Credit cost of the screenshot"
          }
        }
      },
      "ScreenshotInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Screenshot identifier"
          },
          "status": {
            "type": "string",
            "enum": [
              "finished",
              "in_process",
              "error"
            ],
            "description": "Screenshot status"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Original page URL"
          },
          "response_code": {
            "type": "integer",
            "description": "HTTP response code from the page"
          },
          "content_type": {
            "type": "string",
            "description": "Content type of the page"
          },
          "cost": {
            "type": "integer",
            "description": "Credit cost"
          },
          "screenshot_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the screenshot image"
          },
          "width": {
            "type": "integer",
            "description": "Screenshot width"
          },
          "height": {
            "type": "integer",
            "description": "Screenshot height"
          },
          "instance_id": {
            "type": "integer",
            "description": "Browser instance used"
          },
          "error": {
            "type": "string",
            "description": "Error description if status is error"
          },
          "started": {
            "type": "integer",
            "description": "Unix timestamp when processing started"
          },
          "finished": {
            "type": "integer",
            "description": "Unix timestamp when processing finished"
          },
          "load": {
            "type": "integer",
            "description": "Unix timestamp when page loaded"
          },
          "content": {
            "type": "integer",
            "description": "Unix timestamp when content was ready"
          },
          "request_time": {
            "type": "integer",
            "description": "Unix timestamp when request was made"
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of images on the page (detail level 3)"
          },
          "scripts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of scripts on the page (detail level 3)"
          },
          "stylesheets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of stylesheets on the page (detail level 3)"
          },
          "iframes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of iframes on the page (detail level 3)"
          }
        }
      },
      "BatchResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Batch status"
          },
          "id": {
            "type": "integer",
            "description": "Batch identifier"
          }
        }
      },
      "BatchInfo": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Batch status"
          },
          "id": {
            "type": "integer",
            "description": "Batch identifier"
          },
          "count": {
            "type": "integer",
            "description": "Total number of screenshots in batch"
          },
          "failed": {
            "type": "integer",
            "description": "Number of failed screenshots"
          },
          "urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "Array of download URLs (may contain multiple if split into 100MB files)"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ],
            "description": "Error status"
          },
          "error": {
            "type": "string",
            "description": "Error description"
          },
          "id": {
            "type": "integer",
            "description": "Request identifier (typically 0 for errors)"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Screenshots",
      "description": "Screenshot creation and management operations"
    },
    {
      "name": "Batch",
      "description": "Batch screenshot processing operations"
    },
    {
      "name": "Crawl",
      "description": "Web crawling operations"
    },
    {
      "name": "Account",
      "description": "Account information and management"
    },
    {
      "name": "Instances",
      "description": "Browser instance information"
    },
    {
      "name": "Browsers",
      "description": "Browser information"
    }
  ]
}