          }
        }
      }
    },
    "/api/v1/batch/create": {
      "post": {
        "summary": "Create batch screenshots",
        "description": "Submit a text file with URLs (one per line) for batch screenshot processing.",
        "operationId": "createBatch",
        "tags": [
          "Batch"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "instance_id"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Text file with URLs (one per line)"
                  },
                  "instance_id": {
                    "type": "integer",
                    "description": "Browser instance identifier"
                  },
                  "split": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "default": 0,
                    "description": "Set to 1 to split the ZIP archive into 100MB files"
                  },
                  "name": {
                    "type": "string",
                    "description": "Batch identifier label"
                  },
                  "size": {
                    "type": "string",
                    "enum": [
                      "screen",
                      "page"
                    ],
                    "description": "Screenshot scope"
                  },
                  "width": {
                    "type": "integer",
                    "description": "Thumbnail width"
                  },
                  "height": {
                    "type": "integer",
                    "description": "Thumbnail height"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "jpeg",
                      "png"
                    ],
                    "default": "png",
                    "description": "Output image format"
                  },
                  "screen_width": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5000,
                    "description": "Browser window width"
                  },
                  "screen_height": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10000,
                    "description": "Browser window height"
                  },
                  "delay": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 20,
                    "default": 5,
                    "description": "Post-load pause duration"
                  },
                  "referer": {
                    "type": "string",
                    "description": "Custom referrer (paid only)"
                  },
                  "headers": {
                    "type": "string",
                    "description": "Custom HTTP headers"
                  },
                  "post_data": {
                    "type": "string",
                    "description": "POST body (paid only)"
                  },
                  "cookie": {
                    "type": "string",
                    "description": "Cookie data (paid only)"
                  },
                  "script": {
                    "type": "string",
                    "format": "uri",
                    "description": "JavaScript file URL"
                  },
                  "script_inline": {
                    "type": "string",
                    "description": "Inline JavaScript"
                  },
                  "details": {
                    "type": "integer",
                    "enum": [
                      1,
                      2,
                      3
                    ],
                    "default": 2,
                    "description": "Response detail level"
                  },
                  "html": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "default": 0,
                    "description": "HTML capture flag"
                  },
                  "hide_popups": {
                    "type": "boolean",
                    "description": "Popup suppression"
                  },
                  "hosting": {
                    "type": "string",
                    "enum": [
                      "s3"
                    ],
                    "description": "Hosting provider"
                  },
                  "hosting_height": {
                    "type": "integer",
                    "description": "Maximum thumbnail height"
                  },
                  "hosting_width": {
                    "type": "integer",
                    "description": "Maximum thumbnail width"
                  },
                  "hosting_scale": {
                    "type": "integer",
                    "description": "Scaling factor"
                  },
                  "hosting_bucket": {
                    "type": "string",
                    "description": "S3 bucket name"
                  },
                  "hosting_file": {
                    "type": "string",
                    "description": "Object filename"
                  },
                  "hosting_headers": {
                    "type": "string",
                    "description": "Additional headers"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/v1/batch/info": {
      "get": {
        "summary": "Get batch information",
        "description": "Check the status of a batch screenshot request.",
        "operationId": "getBatchInfo",
        "tags": [
          "Batch"
        ],
        "parameters": [
          {
            "name": "id",
