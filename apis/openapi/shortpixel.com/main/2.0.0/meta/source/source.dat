{
  "openapi": "3.0.3",
  "info": {
    "title": "ShortPixel Image Optimization API",
    "version": "2.0.0",
    "description": "ShortPixel API for image optimization, compression, resizing, format conversion, and background removal. Supports lossy, lossless, and glossy compression modes.",
    "x-jentic-source-url": "https://shortpixel.com/api-docs"
  },
  "servers": [
    {
      "url": "https://api.shortpixel.com/v2",
      "description": "ShortPixel API v2"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/reducer.php": {
      "post": {
        "operationId": "optimizeImagesByUrl",
        "summary": "Optimize images by URL",
        "description": "Optimizes images accessible via URL. Accepts up to 100 image URLs per request. Returns optimization result URLs and metadata.",
        "tags": ["Image Optimization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReducerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Optimization result with status and URLs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReducerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters or URLs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reducer-sync.php": {
      "post": {
        "operationId": "optimizeImageSync",
        "summary": "Optimize a single image synchronously",
        "description": "Returns optimized image directly with image content-type header instead of metadata. Only accepts a single image URL.",
        "tags": ["Image Optimization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReducerSyncRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Optimized image binary data",
            "content": {
              "image/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/post-reducer.php": {
      "post": {
        "operationId": "optimizeImageByUpload",
        "summary": "Optimize images by file upload",
        "description": "Optimizes images via file upload for non-publicly-accessible files. Uses multipart form data.",
        "tags": ["Image Optimization"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/PostReducerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Optimization result with status and URLs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReducerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "ShortPixel API key (20-character key from control panel), passed in request body"
      }
    },
    "schemas": {
      "ReducerRequest": {
        "type": "object",
        "required": ["key", "plugin_version", "urllist"],
        "properties": {
          "key": {
            "type": "string",
            "description": "API authentication key"
          },
          "plugin_version": {
            "type": "string",
            "maxLength": 5,
            "description": "Client identifier, max 5 alphanumeric characters"
          },
          "lossy": {
            "type": "integer",
            "enum": [0, 1, 2],
            "description": "Compression type: 0=lossless, 1=lossy, 2=glossy"
          },
          "wait": {
            "type": "integer",
            "minimum": 0,
            "maximum": 30,
            "description": "Wait time in seconds before returning. 0 returns immediately."
          },
          "upscale": {
            "type": "integer",
            "enum": [0, 2, 3, 4],
            "description": "Upscale factor: 0=none, 2/3/4=multiplier"
          },
          "resize": {
            "type": "integer",
            "enum": [0, 1, 3, 4],
            "description": "Resize type: 0=none, 1=outer, 3=inner, 4=smart crop"
          },
          "resize_width": {
            "type": "integer",
            "description": "Target width in pixels"
          },
          "resize_height": {
            "type": "integer",
            "description": "Target height in pixels"
          },
          "cmyk2rgb": {
            "type": "integer",
            "enum": [0, 1],
            "default": 1,
            "description": "Convert CMYK to RGB"
          },
          "keep_exif": {
            "type": "integer",
            "enum": [0, 1],
            "default": 0,
            "description": "Retain EXIF data"
          },
          "convertto": {
            "type": "string",
            "description": "Format conversion target: +webp, +avif, webp|avif, etc."
          },
          "bg_remove": {
            "type": "string",
            "description": "Background removal options"
          },
          "refresh": {
            "type": "integer",
            "enum": [0, 1],
            "description": "Re-fetch image from source"
          },
          "urllist": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 100,
            "description": "Array of image URLs to optimize"
          },
          "paramlist": {
            "type": "object",
            "description": "Custom parameters per URL"
          },
          "returndatalist": {
            "type": "object",
            "description": "Custom data returned unchanged"
          }
        }
      },
      "ReducerSyncRequest": {
        "type": "object",
        "required": ["key", "plugin_version", "url"],
        "properties": {
          "key": {
            "type": "string",
            "description": "API authentication key"
          },
          "plugin_version": {
            "type": "string",
            "maxLength": 5,
            "description": "Client identifier"
          },
          "lossy": {
            "type": "integer",
            "enum": [0, 1, 2],
            "description": "Compression type"
          },
          "wait": {
            "type": "integer",
            "minimum": 0,
            "maximum": 30
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Single image URL to optimize"
          },
          "resize": {
            "type": "integer",
            "enum": [0, 1, 3, 4]
          },
          "resize_width": {
            "type": "integer"
          },
          "resize_height": {
            "type": "integer"
          },
          "convertto": {
            "type": "string"
          }
        }
      },
      "PostReducerRequest": {
        "type": "object",
        "required": ["key"],
        "properties": {
          "key": {
            "type": "string",
            "description": "API authentication key"
          },
          "lossy": {
            "type": "integer",
            "enum": [0, 1, 2]
          },
          "wait": {
            "type": "integer"
          },
          "upscale": {
            "type": "integer",
            "enum": [0, 2, 3, 4]
          },
          "resize": {
            "type": "integer",
            "enum": [0, 1, 3, 4]
          },
          "cmyk2rgb": {
            "type": "integer",
            "enum": [0, 1]
          },
          "keep_exif": {
            "type": "integer",
            "enum": [0, 1]
          },
          "convertto": {
            "type": "string"
          },
          "file_paths": {
            "type": "string",
            "description": "JSON-encoded key-value array of local file paths"
          },
          "file_urls": {
            "type": "string",
            "description": "Temporary URLs from previous calls"
          }
        }
      },
      "ReducerResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "Status": {
              "type": "object",
              "properties": {
                "Code": {
                  "type": "integer",
                  "description": "Status code: 1=scheduled, 2=complete, negative=error"
                },
                "Message": {
                  "type": "string"
                }
              }
            },
            "OriginalURL": {
              "type": "string"
            },
            "LossyURL": {
              "type": "string"
            },
            "LosslessURL": {
              "type": "string"
            },
            "OriginalSize": {
              "type": "integer"
            },
            "LossySize": {
              "type": "integer"
            },
            "LosslessSize": {
              "type": "integer"
            },
            "WebPLossyURL": {
              "type": "string"
            },
            "WebPLosslessURL": {
              "type": "string"
            },
            "WebPLossySize": {
              "type": "integer"
            },
            "WebPLoselessSize": {
              "type": "integer"
            },
            "AVIFLossyURL": {
              "type": "string"
            },
            "AVIFLosslessURL": {
              "type": "string"
            },
            "AVIFPLossySize": {
              "type": "integer"
            },
            "AVIFLoselessSize": {
              "type": "integer"
            },
            "Timestamp": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "Status": {
            "type": "object",
            "properties": {
              "Code": {
                "type": "integer",
                "description": "Negative error code"
              },
              "Message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}