{
  "openapi": "3.0.3",
  "info": {
    "title": "Ontario 511 Transportation API",
    "version": "1.0",
    "description": "REST API providing access to Ontario 511 transportation data including traffic events, construction, cameras, road conditions, transit hubs, carpool lots, ferries, service centres, travel info centres, HOT/HOV lanes, truck rest areas, inspection stations, roundabouts, seasonal loads, rest areas, and alerts. Rate limited to 10 calls per 60 seconds.",
    "x-jentic-source-url": "https://511on.ca/developers/doc"
  },
  "servers": [
    {
      "url": "https://511on.ca/api/v2",
      "description": "Ontario 511 API"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {"name": "Events", "description": "Traffic events"},
    {"name": "Construction", "description": "Construction projects"},
    {"name": "Cameras", "description": "Traffic cameras"},
    {"name": "RoadConditions", "description": "Current road conditions"},
    {"name": "TransitHubs", "description": "Transit hub information"},
    {"name": "CarpoolLots", "description": "Carpool lot locations"},
    {"name": "Ferries", "description": "Ferry terminal information"},
    {"name": "ServiceCentres", "description": "Service centre locations"},
    {"name": "TravelInfoCentres", "description": "Travel information centres"},
    {"name": "HotHov", "description": "HOT/HOV lane information"},
    {"name": "TruckRestAreas", "description": "Truck rest area locations"},
    {"name": "InspectionStations", "description": "Inspection station locations"},
    {"name": "Roundabouts", "description": "Roundabout locations"},
    {"name": "SeasonalLoads", "description": "Seasonal load restrictions"},
    {"name": "RestAreas", "description": "Rest area locations"},
    {"name": "Alerts", "description": "Alert notifications"}
  ],
  "paths": {
    "/get/events": {
      "get": {
        "operationId": "getEvents",
        "summary": "Get Traffic Events",
        "description": "Returns all traffic events.",
        "tags": ["Events"],
        "responses": {
          "200": {"description": "List of traffic events", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Event"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/get/construction": {
      "get": {
        "operationId": "getConstruction",
        "summary": "Get Construction Projects",
        "description": "Returns all construction projects.",
        "tags": ["Construction"],
        "responses": {
          "200": {"description": "List of construction projects", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Construction"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/get/cameras": {
      "get": {
        "operationId": "getCameras",
        "summary": "Get Cameras",
        "description": "Returns all traffic cameras.",
        "tags": ["Cameras"],
        "responses": {
          "200": {"description": "List of cameras", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Camera"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/get/roadconditions": {
      "get": {
        "operationId": "getRoadConditions",
        "summary": "Get Road Conditions",
        "description": "Returns current road conditions.",
        "tags": ["RoadConditions"],
        "responses": {
          "200": {"description": "Current road conditions", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/RoadCondition"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/get/transithubs": {
      "get": {
        "operationId": "getTransitHubs",
        "summary": "Get Transit Hubs",
        "description": "Returns all transit hubs.",
        "tags": ["TransitHubs"],
        "responses": {
          "200": {"description": "List of transit hubs"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/carpoollots": {
      "get": {
        "operationId": "getCarpoolLots",
        "summary": "Get Carpool Lots",
        "description": "Returns all carpool lots.",
        "tags": ["CarpoolLots"],
        "responses": {
          "200": {"description": "List of carpool lots"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/ferries": {
      "get": {
        "operationId": "getFerries",
        "summary": "Get Ferries",
        "description": "Returns all ferry terminals.",
        "tags": ["Ferries"],
        "responses": {
          "200": {"description": "List of ferry terminals"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/servicecentres": {
      "get": {
        "operationId": "getServiceCentres",
        "summary": "Get Service Centres",
        "description": "Returns all service centres.",
        "tags": ["ServiceCentres"],
        "responses": {
          "200": {"description": "List of service centres"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/travelinfocentres": {
      "get": {
        "operationId": "getTravelInfoCentres",
        "summary": "Get Travel Info Centres",
        "description": "Returns all travel information centres.",
        "tags": ["TravelInfoCentres"],
        "responses": {
          "200": {"description": "List of travel info centres"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/hothov": {
      "get": {
        "operationId": "getHotHov",
        "summary": "Get HOT/HOV Lanes",
        "description": "Returns all HOT/HOV lanes.",
        "tags": ["HotHov"],
        "responses": {
          "200": {"description": "List of HOT/HOV lanes"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/truckrestareas": {
      "get": {
        "operationId": "getTruckRestAreas",
        "summary": "Get Truck Rest Areas",
        "description": "Returns all truck rest areas.",
        "tags": ["TruckRestAreas"],
        "responses": {
          "200": {"description": "List of truck rest areas"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/inspectionstations": {
      "get": {
        "operationId": "getInspectionStations",
        "summary": "Get Inspection Stations",
        "description": "Returns all inspection stations.",
        "tags": ["InspectionStations"],
        "responses": {
          "200": {"description": "List of inspection stations"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/roundabouts": {
      "get": {
        "operationId": "getRoundabouts",
        "summary": "Get Roundabouts",
        "description": "Returns all roundabouts.",
        "tags": ["Roundabouts"],
        "responses": {
          "200": {"description": "List of roundabouts"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/seasonalloads": {
      "get": {
        "operationId": "getSeasonalLoads",
        "summary": "Get Seasonal Loads",
        "description": "Returns all seasonal load restrictions.",
        "tags": ["SeasonalLoads"],
        "responses": {
          "200": {"description": "List of seasonal loads"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/restareas": {
      "get": {
        "operationId": "getRestAreas",
        "summary": "Get Rest Areas",
        "description": "Returns all rest areas.",
        "tags": ["RestAreas"],
        "responses": {
          "200": {"description": "List of rest areas"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/get/alerts": {
      "get": {
        "operationId": "getAlerts",
        "summary": "Get Alerts",
        "description": "Returns all alert notifications.",
        "tags": ["Alerts"],
        "responses": {
          "200": {"description": "List of alerts"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key obtained through registration"
      }
    },
    "schemas": {
      "Event": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "severity": {"type": "string"},
          "description": {"type": "string"},
          "road": {"type": "string"},
          "direction": {"type": "string"},
          "latitude": {"type": "number"},
          "longitude": {"type": "number"},
          "startDate": {"type": "string", "format": "date-time"},
          "endDate": {"type": "string", "format": "date-time"},
          "lastUpdated": {"type": "string", "format": "date-time"}
        }
      },
      "Construction": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "road": {"type": "string"},
          "direction": {"type": "string"},
          "latitude": {"type": "number"},
          "longitude": {"type": "number"},
          "startDate": {"type": "string", "format": "date-time"},
          "endDate": {"type": "string", "format": "date-time"}
        }
      },
      "Camera": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "road": {"type": "string"},
          "direction": {"type": "string"},
          "latitude": {"type": "number"},
          "longitude": {"type": "number"},
          "imageUrl": {"type": "string", "format": "uri"}
        }
      },
      "RoadCondition": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "road": {"type": "string"},
          "direction": {"type": "string"},
          "condition": {"type": "string"},
          "latitude": {"type": "number"},
          "longitude": {"type": "number"},
          "lastUpdated": {"type": "string", "format": "date-time"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    }
  }
}