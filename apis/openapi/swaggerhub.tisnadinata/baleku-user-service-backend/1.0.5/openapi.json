    "components": {
        "schemas": {
            "ShowAPIVersion": {
                "type": "object",
                "properties": {
                    "meta": {
                        "type": "object",
                        "properties": {
                            "code": {
                                "type": "integer",
                                "format": "http_status_code",
                                "example": 200
                            },
                            "status": {
                                "type": "boolean",
                                "format": "boolean",
                                "example": true
                            },
                            "messages": {
                                "type": "string",
                                "format": "string",
                                "example": "Success"
                            }
                        }
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "version": {
                                "type": "string",
                                "format": "version",
                                "example": "1.0.0"
                            }
                        }
                    }
                }
            },
            "GeneralSuccessMeta": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "format": "http_response_code",
                        "example": "200 (ok)"
                    },
                    "success": {
                        "type": "boolean",
                        "format": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string",
                        "format": "message",
                        "example": "Success"
                    }
                }
            },
            "GeneralSuccessResponse": {
                "type": "object",
                "properties": {
                    "meta": {
                        "$ref": "#/components/schemas/GeneralSuccessMeta"
                    },
                    "data": {
                        "$ref": "#/components/schemas/UserData"
                    }
                }
            },
            "UserData": {
                "type": "object",
                "properties": {
                    "user_id": {
                        "type": "string",
                        "format": "uuid",
                        "example": "d2dbcc1f-e635-42c6-a540-55458b2e294c"
                    },
                    "phone_no": {
                        "type": "string",
                        "format": "phone",
                        "example": "087876362923"
                    },
                    "role": {
                        "type": "string",
                        "format": "string",
                        "example": "User"
                    },
                    "address_street": {
                        "type": "string",
                        "format": "string",
                        "example": "Jalan"
                    },
                    "address_postal": {
                        "type": "string",
                        "format": "postal code",
                        "example": 40375
                    },
                    "address_province": {
                        "type": "string",
                        "format": "string",
                        "example": "Jawa Barat"
                    },
                    "address_city": {
                        "type": "string",
                        "format": "string",
                        "example": "Kota Bandung"
                    },
                    "address_district": {
                        "type": "string",
                        "format": "string",
                        "example": "Kecamatan Baleendah"
                    },
                    "address_village": {
                        "type": "string",
                        "format": "string",
                        "example": "Desa Cigado"
                    },
                    "ktp_no": {
                        "type": "string",
                        "format": "string",
                        "example": 1234567891478523
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "cs@intouch.id"
                    },
                    "photo": {
                        "type": "string",
                        "format": "url photo",
                        "example": "https://baleku-itx.apps.playcourt.id/intouch/089655440395_photo"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "datetime",
                        "example": "2017-12-04T13:49:47.958+07:00"
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "datetime",
                        "example": "2017-12-04T13:49:47.958+07:00"
                    }
                }
            },
            "UserLoginRequestBody": {
                "type": "object",
                "properties": {
                    "phone_no": {
                        "type": "string",
                        "format": "phone_no",
                        "example": "087876362923"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "123455555"
                    }
                }
            },
            "UserLogoutRequestBody": {
                "type": "object",
                "properties": {
                    "phone_no": {
                        "type": "string",
                        "format": "phone_no",
                        "example": "087876362923"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "123455555"
                    }
                }
            },
            "UserChangePasswordRequestBody": {
                "type": "object",
                "properties": {
                    "phone_no": {
                        "type": "string",
                        "format": "phone_no",
                        "example": "087876362923"
                    },
                    "oldpassword": {
                        "type": "string",
                        "format": "password",
                        "example": "123455555"
                    },
                    "newpassword": {
                        "type": "string",
                        "format": "password",
                        "example": "123455555"
                    }
                }
            },
            "UserRegisterRequestBody": {
                "type": "object",
                "properties": {
                    "phone_no": {
                        "type": "string",
                        "format": "phone_no",
                        "example": "087876362923"
                    },
                    "first_name": {
                        "type": "string",
                        "format": "first_name",
                        "example": "Customer"
                    },
                    "last_name": {
                        "type": "string",
                        "format": "last_name",
                        "example": "Intouch"
                    }
                }
            },
            "uploadData": {
                "type": "object",
                "properties": {
                    "url": {
                        "type": "string",
                        "format": "url from minio aws s3",
                        "example": "https://baleku-itx.apps.playcourt.id/intouch/089655440395_photo"
                    }
                }
            },
            "UserRegisterOtpRequestBody": {
                "type": "object",
                "properties": {
                    "phone_no": {
                        "type": "string",
                        "format": "phone_no",
                        "example": "087876362923"
                    },
                    "first_name": {
                        "type": "string",
                        "format": "first_name",
                        "example": "Customer"
                    },
                    "last_name": {
                        "type": "string",
                        "format": "last_name",
                        "example": "Intouch"
                    },
                    "role": {
                        "type": "string",
                        "format": "role",
                        "example": "User"
                    },
                    "otp": {
                        "type": "string",
                        "format": "4 digit number",
                        "example": "1234"
                    }
                }
            },
            "UploadSuccessResponse": {
                "type": "object",
                "properties": {
                    "meta": {
                        "$ref": "#/components/schemas/GeneralSuccessMeta"
                    },
                    "data": {
                        "$ref": "#/components/schemas/uploadData"
                    }
                }
            },
            "GeneralErrorMeta": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "format": "http_response_code",
                        "example": "404 (not found), 400 (bad request), 401 (unauthorized), 500 (internal server error)"
                    },
                    "success": {
                        "type": "boolean",
                        "format": "boolean",
                        "example": false
                    },
                    "message": {
                        "type": "string",
                        "format": "message",
                        "example": "Not found"
                    }
                }
            },
            "ErrorResponse": {
                "type": "object",
                "properties": {
                    "meta": {
                        "$ref": "#/components/schemas/GeneralErrorMeta"
                    },
                    "data": {
                        "type": "object",
                        "example": null
                    }
                }
            }
        }
