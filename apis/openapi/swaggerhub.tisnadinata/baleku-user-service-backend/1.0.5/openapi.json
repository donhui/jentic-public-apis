              "format": "http_status_code",
              "example": 200
            },
            "status": {
              "type": "boolean",
              "format": "boolean",
              "example": true
            },
            "messages": {
              "type": "string",
              "format": "string",
              "example": "Success"
            }
          }
        },
        "data": {
          "type": "object",
          "properties": {
