        "tags": [
          "User Service"
        ],
        "summary": "Manage User Data",
        "description": "Update User Profile",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "phone_no",
            "description": "User phone number",
            "required": true
