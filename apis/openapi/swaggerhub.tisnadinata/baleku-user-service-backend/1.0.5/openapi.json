        "/user/upload/{phone_no}": {
            "post": {
                "tags": [
                    "User Service"
                ],
                "summary": "Manage User Data",
                "description": "Get User Profile",
                "parameters": [
                    {
                        "in": "path",
                        "name": "phone_no",
                        "description": "User phone number",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "form",
                        "name": "file",
                        "description": "file yang akan di upload",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "form",
                        "name": "type",
                        "description": "type file yang diupload (photo, dokumen, etc)",
                        "required": true,
