        "responses": {
          "200": {
            "description": "Returning user data",
            "schema": {
              "$ref": "#/definitions/GeneralSuccessResponse"
            }
          },
          "error": {
            "description": "Returning error response",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
