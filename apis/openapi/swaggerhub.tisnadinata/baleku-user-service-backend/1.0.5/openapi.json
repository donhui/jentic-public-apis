        "/user/profile/{phone_no}": {
            "get": {
                "tags": [
                    "User Service"
                ],
                "summary": "Manage User Data",
                "description": "Get User Profile",
                "parameters": [
                    {
                        "in": "path",
                        "name": "phone_no",
                        "description": "User phone number",
                        "required": true,
                        "schema": {
                            "type": "string"
