                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "tags": [
                    "User Service"
                ],
                "summary": "Manage User Data",
                "description": "Update User Profile",
                "parameters": [
                    {
                        "in": "path",
                        "name": "phone_no",
                        "description": "User phone number",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserData"
                            }
                        }
                    },
                    "description": "User Data who want updated.",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Returning user data",
                        "content": {
                            "*/*": {
