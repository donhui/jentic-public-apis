{
  "openapi": "3.0.3",
  "info": {
    "title": "Crypto APIs Blockchain REST API",
    "version": "2.0.0",
    "description": "Crypto APIs provides unified blockchain REST APIs for multiple blockchains including address data, transaction data, block data, HD wallets, and token operations.",
    "x-jentic-source-url": "https://developers.cryptoapis.io/openapi.json",
    "contact": {
      "name": "Crypto APIs",
      "url": "https://cryptoapis.io"
    }
  },
  "servers": [
    {
      "url": "https://rest.cryptoapis.io",
      "description": "Crypto APIs Production Server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {"name": "Addresses", "description": "Blockchain address operations"},
    {"name": "Transactions", "description": "Transaction operations"},
    {"name": "Blocks", "description": "Block data operations"},
    {"name": "HD Wallets", "description": "Hierarchical Deterministic wallet operations"},
    {"name": "Tokens", "description": "Token operations"},
    {"name": "Callbacks", "description": "Webhook and callback subscriptions"}
  ],
  "paths": {
    "/blockchain-data/{blockchain}/{network}/addresses/{address}": {
      "get": {
        "operationId": "getAddressDetails",
        "summary": "Get Address Details",
        "description": "Retrieves details about a specific blockchain address including balance information.",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "blockchain",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Blockchain name (e.g., bitcoin, ethereum)"
          },
          {
            "name": "network",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Network name (e.g., mainnet, testnet)"
          },
          {
            "name": "address",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "The blockchain address"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with address details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/AddressDetails"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/blockchain-data/{blockchain}/{network}/addresses/{address}/transactions": {
      "get": {
        "operationId": "listAddressTransactions",
        "summary": "List Address Transactions",
        "description": "Lists transactions for a specific blockchain address.",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "blockchain",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "network",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "address",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "default": 50}
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {"type": "integer", "default": 0}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with transactions list",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/TransactionsList"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/blockchain-data/{blockchain}/{network}/transactions/{transactionId}": {
      "get": {
        "operationId": "getTransactionDetails",
        "summary": "Get Transaction Details",
        "description": "Retrieves details about a specific blockchain transaction.",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "blockchain",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "network",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "The transaction hash/ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with transaction details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/TransactionDetails"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/blockchain-data/{blockchain}/{network}/blocks/{blockId}": {
      "get": {
        "operationId": "getBlockDetails",
        "summary": "Get Block Details",
        "description": "Retrieves details about a specific blockchain block.",
        "tags": ["Blocks"],
        "parameters": [
          {
            "name": "blockchain",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "network",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "blockId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Block hash or block height"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with block details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/BlockDetails"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/blockchain-data/{blockchain}/{network}/blocks/last": {
      "get": {
        "operationId": "getLatestBlock",
        "summary": "Get Latest Mined Block",
        "description": "Retrieves the latest mined block on the specified blockchain.",
        "tags": ["Blocks"],
        "parameters": [
          {
            "name": "blockchain",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "network",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with latest block",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/BlockDetails"}
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/wallet-as-a-service/wallets/{walletId}/{blockchain}/{network}/addresses": {
      "post": {
        "operationId": "generateDepositAddress",
        "summary": "Generate Deposit Address",
        "description": "Generates a new deposit address for an HD wallet.",
        "tags": ["HD Wallets"],
        "parameters": [
          {
            "name": "walletId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "blockchain",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "network",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "label": {"type": "string", "description": "Label for the address"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "item": {
                          "type": "object",
                          "properties": {
                            "address": {"type": "string"},
                            "label": {"type": "string"},
                            "createdTimestamp": {"type": "integer"}
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/blockchain-events/{blockchain}/{network}/subscriptions/address-coins-transactions-confirmed": {
      "post": {
        "operationId": "subscribeAddressCoinsConfirmed",
        "summary": "Subscribe to Confirmed Coin Transactions",
        "description": "Creates a callback subscription for confirmed coin transactions on an address.",
        "tags": ["Callbacks"],
        "parameters": [
          {
            "name": "blockchain",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "network",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["data"],
                "properties": {
                  "data": {
                    "type": "object",
                    "required": ["item"],
                    "properties": {
                      "item": {
                        "type": "object",
                        "required": ["address", "callbackUrl"],
                        "properties": {
                          "address": {"type": "string"},
                          "callbackUrl": {"type": "string", "format": "uri"},
                          "receiveCallbackOn": {"type": "integer"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "item": {
                          "type": "object",
                          "properties": {
                            "referenceId": {"type": "string"},
                            "address": {"type": "string"},
                            "callbackUrl": {"type": "string"}
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    },
    "/blockchain-tools/{blockchain}/{network}/addresses/validate": {
      "post": {
        "operationId": "validateAddress",
        "summary": "Validate Address",
        "description": "Validates whether a blockchain address is valid.",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "blockchain",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "network",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["data"],
                "properties": {
                  "data": {
                    "type": "object",
                    "required": ["item"],
                    "properties": {
                      "item": {
                        "type": "object",
                        "required": ["address"],
                        "properties": {
                          "address": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "item": {
                          "type": "object",
                          "properties": {
                            "isValid": {"type": "boolean"}
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Error"}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication via x-api-key header"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "apiVersion": {"type": "string"},
          "requestId": {"type": "string"},
          "error": {
            "type": "object",
            "properties": {
              "code": {"type": "string"},
              "message": {"type": "string"}
            }
          }
        }
      },
      "AddressDetails": {
        "type": "object",
        "properties": {
          "apiVersion": {"type": "string"},
          "data": {
            "type": "object",
            "properties": {
              "item": {
                "type": "object",
                "properties": {
                  "transactionsCount": {"type": "integer"},
                  "confirmedBalance": {
                    "type": "object",
                    "properties": {
                      "amount": {"type": "string"},
                      "unit": {"type": "string"}
                    }
                  },
                  "totalReceived": {
                    "type": "object",
                    "properties": {
                      "amount": {"type": "string"},
                      "unit": {"type": "string"}
                    }
                  },
                  "totalSpent": {
                    "type": "object",
                    "properties": {
                      "amount": {"type": "string"},
                      "unit": {"type": "string"}
                    }
                  }
                }
              }
            }
          }
        }
      },
      "TransactionsList": {
        "type": "object",
        "properties": {
          "apiVersion": {"type": "string"},
          "data": {
            "type": "object",
            "properties": {
              "limit": {"type": "integer"},
              "offset": {"type": "integer"},
              "total": {"type": "integer"},
              "items": {
                "type": "array",
                "items": {"$ref": "#/components/schemas/TransactionDetails"}
              }
            }
          }
        }
      },
      "TransactionDetails": {
        "type": "object",
        "properties": {
          "transactionId": {"type": "string"},
          "minedInBlockHash": {"type": "string"},
          "minedInBlockHeight": {"type": "integer"},
          "timestamp": {"type": "integer"},
          "fee": {
            "type": "object",
            "properties": {
              "amount": {"type": "string"},
              "unit": {"type": "string"}
            }
          },
          "isConfirmed": {"type": "boolean"}
        }
      },
      "BlockDetails": {
        "type": "object",
        "properties": {
          "apiVersion": {"type": "string"},
          "data": {
            "type": "object",
            "properties": {
              "item": {
                "type": "object",
                "properties": {
                  "hash": {"type": "string"},
                  "height": {"type": "integer"},
                  "previousBlockHash": {"type": "string"},
                  "timestamp": {"type": "integer"},
                  "transactionsCount": {"type": "integer"},
                  "blockSize": {"type": "integer"}
                }
              }
            }
          }
        }
      }
    }
  }
}