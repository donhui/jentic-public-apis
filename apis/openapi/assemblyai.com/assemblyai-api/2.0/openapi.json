          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "audio_url": {
                    "type": "string"
                  },
                  "language_code": {
                    "type": "string"
                  },
                  "speaker_labels": {
                    "type": "boolean"
                  },
                  "auto_chapters": {
                    "type": "boolean"
                  },
                  "entity_detection": {
                    "type": "boolean"
                  },
                  "sentiment_analysis": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transcript"
