  "components": {
    "schemas": {
      "UploadResponse": {
        "type": "object",
        "properties": {
          "upload_url": {
            "type": "string"
          }
        }
      },
      "Transcript": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "processing",
              "completed",
              "error"
            ]
          },
          "text": {
            "type": "string"
          },
          "audio_url": {
            "type": "string"
          },
          "language_model": {
            "type": "string"
          }
        }
      },
      "TranscriptList": {
        "type": "object",
        "properties": {
          "page_details": {
            "type": "object"
          },
          "transcripts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transcript"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "authorization"
      }
    }
  },
  "security": [
