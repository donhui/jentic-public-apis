    "/v2/realtime/token": {
      "post": {
        "operationId": "createRealtimeToken",
        "summary": "Create realtime streaming token",
        "tags": [
          "Streaming"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expires_in": {
