{
  "openapi": "3.0.3",
  "info": {
    "title": "AssemblyAI API",
    "version": "2.0",
    "description": "Speech-to-text and audio intelligence API.",
    "x-jentic-source-url": "https://www.assemblyai.com/docs/"
  },
  "servers": [
    {
      "url": "https://api.assemblyai.com"
    }
