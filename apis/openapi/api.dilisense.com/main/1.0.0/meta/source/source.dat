{
  "openapi": "3.0.3",
  "info": {
    "title": "dilisense AML Screening API",
    "description": "dilisense is a Sanctions and AML screenings service to support compliance with national and international compliance regulations. Provides individual, entity, and name screening against sanctions lists.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developers.dilisense.com/"
  },
  "servers": [
    {
      "url": "https://api.dilisense.com/v1",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Screening",
      "description": "AML and sanctions screening operations"
    },
    {
      "name": "Reports",
      "description": "Generate PDF screening reports"
    },
    {
      "name": "Sources",
      "description": "Manage and retrieve source lists"
    }
  ],
  "paths": {
    "/checkIndividual": {
      "get": {
        "tags": ["Screening"],
        "summary": "Check individual against sanctions lists",
        "description": "Screen an individual against sanctions, PEP, and other watchlists. A maximum of 1,000 hits are returned per call.",
        "operationId": "checkIndividual",
        "parameters": [
          {
            "name": "names",
            "in": "query",
            "description": "Name(s) to search for. Mutually exclusive with search_all.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search_all",
            "in": "query",
            "description": "Search all fields. Mutually exclusive with names.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fuzzy_search",
            "in": "query",
            "description": "Fuzzy search level (1 = light fuzzy, 2 = heavy fuzzy).",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [1, 2]
            }
          },
          {
            "name": "dob",
            "in": "query",
            "description": "Date of birth filter in dd/mm/yyyy format.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gender",
            "in": "query",
            "description": "Gender filter.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["male", "female"]
            }
          },
          {
            "name": "includes",
            "in": "query",
            "description": "Comma-separated source IDs to restrict search to specific sources.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful screening response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndividualScreeningResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/generateIndividualReport": {
      "get": {
        "tags": ["Reports"],
        "summary": "Generate individual screening PDF report",
        "description": "Generate a base64-encoded PDF report for an individual screening.",
        "operationId": "generateIndividualReport",
        "parameters": [
          {
            "name": "names",
            "in": "query",
            "description": "Name(s) to search for.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dob",
            "in": "query",
            "description": "Date of birth filter in dd/mm/yyyy format.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gender",
            "in": "query",
            "description": "Gender filter.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["male", "female"]
            }
          },
          {
            "name": "includes",
            "in": "query",
            "description": "Comma-separated source IDs to restrict search.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Base64-encoded PDF report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/checkEntity": {
      "get": {
        "tags": ["Screening"],
        "summary": "Check entity against sanctions lists",
        "description": "Screen a company or organization against sanctions and watchlists. A maximum of 1,000 hits are returned per call.",
        "operationId": "checkEntity",
        "parameters": [
          {
            "name": "names",
            "in": "query",
            "description": "Entity name(s) to search for. Mutually exclusive with search_all.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search_all",
            "in": "query",
            "description": "Search all fields. Mutually exclusive with names.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fuzzy_search",
            "in": "query",
            "description": "Fuzzy search level (1 = light fuzzy, 2 = heavy fuzzy).",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [1, 2]
            }
          },
          {
            "name": "includes",
            "in": "query",
            "description": "Comma-separated source IDs to restrict search.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful entity screening response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityScreeningResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/generateEntityReport": {
      "get": {
        "tags": ["Reports"],
        "summary": "Generate entity screening PDF report",
        "description": "Generate a base64-encoded PDF report for an entity screening.",
        "operationId": "generateEntityReport",
        "parameters": [
          {
            "name": "names",
            "in": "query",
            "description": "Entity name(s) to search for.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includes",
            "in": "query",
            "description": "Comma-separated source IDs to restrict search.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Base64-encoded PDF report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/checkName": {
      "get": {
        "tags": ["Screening"],
        "summary": "Check name against all entity types",
        "description": "Screen a name against all entity types including INDIVIDUAL, ENTITY, VESSEL, AIRCRAFT, OBJECT, and UNKNOWN. A maximum of 1,000 hits are returned per call.",
        "operationId": "checkName",
        "parameters": [
          {
            "name": "names",
            "in": "query",
            "description": "Name(s) to search for. Mutually exclusive with search_all.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search_all",
            "in": "query",
            "description": "Search all fields. Mutually exclusive with names.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fuzzy_search",
            "in": "query",
            "description": "Fuzzy search level (1 = light fuzzy, 2 = heavy fuzzy).",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [1, 2]
            }
          },
          {
            "name": "includes",
            "in": "query",
            "description": "Comma-separated source IDs to restrict search.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful name screening response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NameScreeningResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getSourceList": {
      "get": {
        "tags": ["Sources"],
        "summary": "Get list of available screening sources",
        "description": "Retrieve the full list of available sanctions and watchlist sources with their metadata.",
        "operationId": "getSourceList",
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of available sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Source"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "IndividualScreeningResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "Timestamp of the screening"
          },
          "total_hits": {
            "type": "integer",
            "description": "Total number of matches found"
          },
          "found_records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IndividualRecord"
            }
          }
        }
      },
      "IndividualRecord": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of the individual"
          },
          "dob": {
            "type": "string",
            "description": "Date of birth"
          },
          "citizenship": {
            "type": "string",
            "description": "Citizenship information"
          },
          "positions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Political or organizational positions"
          },
          "source_id": {
            "type": "string",
            "description": "ID of the source list"
          },
          "entity_type": {
            "type": "string",
            "description": "Type of entity (INDIVIDUAL)"
          }
        }
      },
      "EntityScreeningResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "Timestamp of the screening"
          },
          "total_hits": {
            "type": "integer",
            "description": "Total number of matches found"
          },
          "found_records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EntityRecord"
            }
          }
        }
      },
      "EntityRecord": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the entity"
          },
          "addresses": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Known addresses"
          },
          "source_id": {
            "type": "string",
            "description": "ID of the source list"
          },
          "entity_type": {
            "type": "string",
            "description": "Type of entity (ENTITY)"
          },
          "sanction_info": {
            "type": "string",
            "description": "Sanction details"
          }
        }
      },
      "NameScreeningResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "description": "Timestamp of the screening"
          },
          "total_hits": {
            "type": "integer",
            "description": "Total number of matches found"
          },
          "found_records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NameRecord"
            }
          }
        }
      },
      "NameRecord": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the matched record"
          },
          "entity_type": {
            "type": "string",
            "description": "Type: INDIVIDUAL, ENTITY, VESSEL, AIRCRAFT, OBJECT, or UNKNOWN",
            "enum": ["INDIVIDUAL", "ENTITY", "VESSEL", "AIRCRAFT", "OBJECT", "UNKNOWN"]
          },
          "source_id": {
            "type": "string",
            "description": "ID of the source list"
          }
        }
      },
      "ReportResponse": {
        "type": "object",
        "properties": {
          "report": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded PDF report"
          }
        }
      },
      "Source": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Source identifier"
          },
          "name": {
            "type": "string",
            "description": "Source name"
          },
          "description": {
            "type": "string",
            "description": "Source description"
          },
          "type": {
            "type": "string",
            "description": "Source type"
          },
          "region": {
            "type": "string",
            "description": "Geographic region"
          },
          "country": {
            "type": "string",
            "description": "Country of the source"
          },
          "size": {
            "type": "integer",
            "description": "Number of entries in the source"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}