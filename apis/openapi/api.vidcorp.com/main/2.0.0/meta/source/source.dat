{
  "openapi": "3.0.3",
  "info": {
    "title": "Vidcorp (Tall Bob) API",
    "description": "The official API for Vidcorp/Tall Bob. Provides SMS, MMS, chat messaging, contact management, campaign management, and webhook functionality.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://docs.vidcorp.com/"
  },
  "servers": [
    {
      "url": "https://api.vidcorp.com/v2",
      "description": "Production"
    },
    {
      "url": "https://api-testing.vidcorp.com/v2",
      "description": "Sandbox for Testing"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    { "name": "Chat", "description": "Chat SMS messaging" },
    { "name": "Contacts", "description": "Contact management" },
    { "name": "ContactGroups", "description": "Contact group management" },
    { "name": "MMS", "description": "MMS messaging" },
    { "name": "SMS", "description": "SMS messaging" },
    { "name": "Campaigns", "description": "SMS campaign management" },
    { "name": "Webhooks", "description": "Webhook management" }
  ],
  "paths": {
    "/chat/send/sms": {
      "post": {
        "tags": ["Chat"],
        "summary": "Send Chat SMS",
        "description": "Send a chat SMS message.",
        "operationId": "sendChatSms",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatSmsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat SMS sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatSmsResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts": {
      "post": {
        "tags": ["Contacts"],
        "summary": "Create new contact",
        "description": "Create a new contact in the system.",
        "operationId": "createContact",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "get": {
        "tags": ["Contacts"],
        "summary": "List contacts",
        "description": "Retrieve a list of contacts, optionally filtered by email or mobile.",
        "operationId": "listContacts",
        "parameters": [
          { "name": "email", "in": "query", "description": "Filter by email address", "schema": { "type": "string" } },
          { "name": "mobile", "in": "query", "description": "Filter by mobile number", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedContactList" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/{contact_id}": {
      "get": {
        "tags": ["Contacts"],
        "summary": "View contact details",
        "description": "Retrieve details of a specific contact.",
        "operationId": "getContact",
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Contact details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "tags": ["Contacts"],
        "summary": "Update contact",
        "description": "Update an existing contact.",
        "operationId": "updateContact",
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactRequest" } } }
        },
        "responses": {
          "200": { "description": "Contact updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Contacts"],
        "summary": "Delete contact",
        "description": "Delete a contact.",
        "operationId": "deleteContact",
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Contact deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/{contact_id}/metadata": {
      "put": {
        "tags": ["Contacts"],
        "summary": "Upsert contact metadata",
        "description": "Add or update metadata on a contact.",
        "operationId": "upsertContactMetadata",
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } }
        },
        "responses": {
          "204": { "description": "Metadata updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Contacts"],
        "summary": "Remove contact metadata",
        "description": "Remove metadata from a contact.",
        "operationId": "removeContactMetadata",
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Metadata removed" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/{contact_id}/campaigns": {
      "get": {
        "tags": ["Contacts"],
        "summary": "List contact campaigns",
        "description": "List campaigns associated with a contact.",
        "operationId": "listContactCampaigns",
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of campaigns", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/find": {
      "post": {
        "tags": ["Contacts"],
        "summary": "Find contact by external ID",
        "description": "Find a contact using their external identifier.",
        "operationId": "findContactByExternalId",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "external_id": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Contact found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/groups": {
      "post": {
        "tags": ["ContactGroups"],
        "summary": "Create new group",
        "description": "Create a new contact group.",
        "operationId": "createContactGroup",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactGroupRequest" } } } },
        "responses": {
          "200": { "description": "Group created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactGroup" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "get": {
        "tags": ["ContactGroups"],
        "summary": "List contact groups",
        "description": "Retrieve a list of contact groups.",
        "operationId": "listContactGroups",
        "parameters": [
          { "name": "name", "in": "query", "description": "Filter by group name", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of groups", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedGroupList" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/groups/attach": {
      "post": {
        "tags": ["ContactGroups"],
        "summary": "Add contact to group",
        "description": "Add a contact to a group.",
        "operationId": "addContactToGroup",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "contact_id": { "type": "string" }, "group_id": { "type": "string" } } } } } },
        "responses": {
          "204": { "description": "Contact added to group" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/groups/detach": {
      "delete": {
        "tags": ["ContactGroups"],
        "summary": "Remove contact from group",
        "description": "Remove a contact from a group.",
        "operationId": "removeContactFromGroup",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "contact_id": { "type": "string" }, "group_id": { "type": "string" } } } } } },
        "responses": {
          "204": { "description": "Contact removed from group" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/groups/{group_id}/members": {
      "get": {
        "tags": ["ContactGroups"],
        "summary": "List group members",
        "operationId": "listGroupMembers",
        "parameters": [ { "name": "group_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "responses": {
          "200": { "description": "List of group members", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Contact" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contacts/groups/{group_id}": {
      "put": {
        "tags": ["ContactGroups"],
        "summary": "Update contact group",
        "operationId": "updateContactGroup",
        "parameters": [ { "name": "group_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactGroupRequest" } } } },
        "responses": {
          "200": { "description": "Group updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactGroup" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["ContactGroups"],
        "summary": "Delete contact group",
        "operationId": "deleteContactGroup",
        "parameters": [ { "name": "group_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "responses": {
          "204": { "description": "Group deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sms/send": {
      "post": {
        "tags": ["SMS"],
        "summary": "Send single SMS",
        "description": "Send a single SMS message.",
        "operationId": "sendSms",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SmsRequest" } } } },
        "responses": {
          "200": { "description": "SMS sent", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SmsResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sms/list_send": {
      "post": {
        "tags": ["SMS"],
        "summary": "Send SMS to list",
        "description": "Send SMS to a list of mobile numbers.",
        "operationId": "sendSmsList",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SmsListRequest" } } } },
        "responses": {
          "200": { "description": "SMS sent to list", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sms/price": {
      "post": {
        "tags": ["SMS"],
        "summary": "Calculate SMS price",
        "description": "Calculate the price for an SMS message.",
        "operationId": "calculateSmsPrice",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SmsRequest" } } } },
        "responses": {
          "200": { "description": "Price calculated", "content": { "application/json": { "schema": { "type": "object", "properties": { "price": { "type": "number" }, "num_segments": { "type": "integer" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sms/receipts": {
      "get": {
        "tags": ["SMS"],
        "summary": "List SMS receipts",
        "operationId": "listSmsReceipts",
        "parameters": [
          { "name": "to", "in": "query", "schema": { "type": "integer" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "SMS receipts", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sms/replies": {
      "get": {
        "tags": ["SMS"],
        "summary": "List SMS replies",
        "operationId": "listSmsReplies",
        "parameters": [
          { "name": "to", "in": "query", "schema": { "type": "integer" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": { "description": "SMS replies", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/mms/send": {
      "post": {
        "tags": ["MMS"],
        "summary": "Send single MMS",
        "operationId": "sendMms",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MmsRequest" } } } },
        "responses": {
          "200": { "description": "MMS sent", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/mms/send_list": {
      "post": {
        "tags": ["MMS"],
        "summary": "Send MMS to list",
        "operationId": "sendMmsList",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": {
          "200": { "description": "MMS sent to list", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/mms/receipts": {
      "get": {
        "tags": ["MMS"],
        "summary": "List MMS receipts",
        "operationId": "listMmsReceipts",
        "parameters": [
          { "name": "to", "in": "query", "schema": { "type": "integer" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "MMS receipts", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/mms/inbound": {
      "get": {
        "tags": ["MMS"],
        "summary": "List inbound MMS messages",
        "operationId": "listInboundMms",
        "parameters": [
          { "name": "to", "in": "query", "schema": { "type": "integer" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": { "description": "Inbound MMS messages", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/campaigns/send": {
      "post": {
        "tags": ["Campaigns"],
        "summary": "Send SMS campaign",
        "operationId": "sendCampaign",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": {
          "200": { "description": "Campaign sent", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/campaigns": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "List SMS campaigns",
        "operationId": "listCampaigns",
        "parameters": [
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": { "description": "List of campaigns", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/campaigns/{campaign_id}": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "View campaign details",
        "operationId": "getCampaign",
        "parameters": [ { "name": "campaign_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "responses": {
          "200": { "description": "Campaign details", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/campaigns/{campaign_id}/contacts": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "List campaign recipients",
        "operationId": "listCampaignRecipients",
        "parameters": [ { "name": "campaign_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "responses": {
          "200": { "description": "Campaign recipients", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Contact" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/campaigns/templates": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "List campaign templates",
        "operationId": "listCampaignTemplates",
        "responses": {
          "200": { "description": "List of templates", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/campaigns/templates/{template_id}": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "View template details",
        "operationId": "getCampaignTemplate",
        "parameters": [ { "name": "template_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "responses": {
          "200": { "description": "Template details", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/webhooks": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Create new webhook",
        "operationId": "createWebhook",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebhookRequest" } } } },
        "responses": {
          "200": { "description": "Webhook created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Webhook" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "get": {
        "tags": ["Webhooks"],
        "summary": "List webhooks",
        "operationId": "listWebhooks",
        "parameters": [
          { "name": "enabled", "in": "query", "schema": { "type": "boolean" } },
          { "name": "url", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of webhooks", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Webhook" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/webhooks/{webhook_id}": {
      "get": {
        "tags": ["Webhooks"],
        "summary": "View webhook details",
        "operationId": "getWebhook",
        "parameters": [ { "name": "webhook_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "responses": {
          "200": { "description": "Webhook details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Webhook" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "tags": ["Webhooks"],
        "summary": "Update webhook",
        "operationId": "updateWebhook",
        "parameters": [ { "name": "webhook_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebhookRequest" } } } },
        "responses": {
          "200": { "description": "Webhook updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Webhook" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Webhooks"],
        "summary": "Delete webhook",
        "operationId": "deleteWebhook",
        "parameters": [ { "name": "webhook_id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "responses": {
          "204": { "description": "Webhook deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic HTTP authentication using your API username and API key from the Vidcorp platform."
      }
    },
    "schemas": {
      "ChatSmsRequest": {
        "type": "object",
        "properties": {
          "to": { "type": "string", "description": "Recipient mobile number" },
          "message": { "type": "string", "description": "Message content" }
        }
      },
      "ChatSmsResponse": {
        "type": "object",
        "properties": {
          "chat_id": { "type": "string" },
          "to": { "type": "string" },
          "status": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "price": { "type": "number" },
          "num_segments": { "type": "integer" }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "mobile": { "type": "string" },
          "email": { "type": "string" },
          "external_id": { "type": "string" }
        }
      },
      "ContactRequest": {
        "type": "object",
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "mobile": { "type": "string" },
          "email": { "type": "string" },
          "external_id": { "type": "string" }
        }
      },
      "PaginatedContactList": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "item_count": { "type": "integer" },
          "current_page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Contact" } }
        }
      },
      "ContactGroup": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "external_id": { "type": "string" },
          "membership": { "type": "integer" }
        }
      },
      "ContactGroupRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "external_id": { "type": "string" }
        }
      },
      "PaginatedGroupList": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "item_count": { "type": "integer" },
          "current_page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/ContactGroup" } }
        }
      },
      "SmsRequest": {
        "type": "object",
        "properties": {
          "to": { "type": "string" },
          "from": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "SmsListRequest": {
        "type": "object",
        "properties": {
          "to": { "type": "array", "items": { "type": "string" } },
          "from": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "SmsResponse": {
        "type": "object",
        "properties": {
          "message_id": { "type": "string" },
          "to": { "type": "string" },
          "status": { "type": "string" },
          "price": { "type": "number" },
          "num_segments": { "type": "integer" }
        }
      },
      "MmsRequest": {
        "type": "object",
        "properties": {
          "to": { "type": "string" },
          "from": { "type": "string" },
          "subject": { "type": "string" },
          "message": { "type": "string" },
          "media_url": { "type": "string", "format": "uri" }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "enabled": { "type": "boolean" },
          "events": { "type": "array", "items": { "type": "string" } }
        }
      },
      "WebhookRequest": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "enabled": { "type": "boolean" },
          "events": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    }
  }
}