            "description": "Delete"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SellersDeleteByIdResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SellersDeleteById500Response"
                }
              }
            }
          }
        }
      }
    },
    "/v1/flows": {
      "get": {
