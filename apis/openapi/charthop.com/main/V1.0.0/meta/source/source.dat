          "orgId",
          "userId",
          "type",
          "params"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "globally unique id for query token",
            "example": "588f7ee98f138b19220041a7"
          },
          "token": {
            "type": "string",
            "description": "globally unique random token string"
          },
          "orgId": {
            "type": "string",
            "description": "id of org",
            "example": "588f7ee98f138b19220041a7"
          },
          "userId": {
            "type": "string",
            "description": "id of user",
            "example": "588f7ee98f138b19220041a7"
          },
          "label": {
            "type": "string",
