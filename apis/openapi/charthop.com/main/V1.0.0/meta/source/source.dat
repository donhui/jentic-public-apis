        ],
        "properties": {
          "guidelineId": {
            "type": "string",
            "example": "588f7ee98f138b19220041a7"
          },
          "jobId": {
            "type": "string",
            "example": "588f7ee98f138b19220041a7"
          },
          "compReviewId": {
            "type": "string",
            "example": "588f7ee98f138b19220041a7"
          },
          "budgetPoolId": {
            "type": "string",
            "example": "588f7ee98f138b19220041a7"
          },
          "guidelineLabel": {
            "type": "string"
          },
          "min": {
            "type": "object"
          },
          "max": {
            "type": "object"
          },
          "target": {
            "type": "object"
          },
          "appliedField": {
            "type": "string"
          },
          "flagMode": {
            "type": "string",
            "enum": [
