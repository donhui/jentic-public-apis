            "type": "boolean",
            "description": "Enable goal-setting features in the org"
          },
          "enableAiMemory": {
            "type": "boolean",
            "description": "Enable AI agent persistent memory in the org"
          },
          "enableLegacyBands": {
            "type": "boolean",
            "description": "Enable bands V1 feature in the org"
          },
          "useImporterV3": {
            "type": "boolean",
            "description": "Whether to use the v3 job importer"
          },
          "logImportErrorsUsingJavaLogger": {
            "type": "boolean",
            "description": "Whether the v3 job importer should log errors to the java logger in addition to the log file"
          },
