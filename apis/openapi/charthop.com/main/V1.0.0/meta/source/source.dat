            "type": "string"
          },
          "allowMultiple": {
            "type": "boolean"
          },
          "eligibilityFilter": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "example": "588f7ee98f138b19220041a7"
          }
        }
      },
      "GroupPositionAssignments": {
        "type": "object",
        "required": [
          "values"
        ],
        "properties": {
          "values": {
            "type": "object",
