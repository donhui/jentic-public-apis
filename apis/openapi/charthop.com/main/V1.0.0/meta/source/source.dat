          },
          "endDatePartialDay": {
            "type": "number"
          },
          "endDatePartialDayPeriod": {
            "type": "string",
            "enum": [
              "AM",
              "PM"
            ]
          },
          "personId": {
            "type": "string",
            "example": "588f7ee98f138b19220041a7"
          },
