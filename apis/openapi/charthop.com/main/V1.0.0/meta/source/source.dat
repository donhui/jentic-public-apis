            }
          },
          {
            "name": "entityType",
            "in": "query",
            "description": "entity type (if not passed, defaults to user)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fieldId",
            "in": "query",
            "description": "field id - can leave blank for a general upload",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sensitive",
            "in": "query",
            "description": "file sensitivity level - defaults to PERSONAL",
