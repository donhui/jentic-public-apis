              "GOAL_TARGET",
              "GOAL_TYPE",
              "GUIDELINE",
              "JOB",
              "JOB_CODE",
              "JOB_LEVEL",
              "MEDIA",
              "MESSAGE",
              "MULTIPLIER",
              "ORG",
              "ORG_CONFIG",
              "PERSON",
              "PROFILE_TAB",
