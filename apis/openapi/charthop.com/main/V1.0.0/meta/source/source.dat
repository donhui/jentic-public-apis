      "EmailTemplate": {
        "type": "object",
        "required": [
          "id",
          "name",
          "category"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "globally unique id",
            "example": "588f7ee98f138b19220041a7"
          },
          "name": {
            "type": "string",
            "description": "name of the email template",
            "example": "self_serve_welcome"
          },
          "category": {
            "type": "string",
