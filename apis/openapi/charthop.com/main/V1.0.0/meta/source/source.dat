              "SHOW_OPEN_JOBS",
              "STEP",
              "SUBMIT",
              "SYNC",
              "TEST",
              "TOKEN",
              "UNINSTALL",
              "UPDATE",
              "UPDATE_PASSWORD",
              "UPLOAD_CSV",
              "WRITE",
              "VIEW_AS"
            ]
          },
          "entityType": {
            "type": "string",
            "description": "type of target entity",
            "enum": [
              "ACTION",
              "AGREEMENT",
              "AI_AGENT",
              "AI_AGENT_MEMORY",
              "AI_CHAT",
              "AI_CONFIG",
              "AI_HINT",
              "AI_PROMPT",
              "APP",
              "APP_CONFIG",
