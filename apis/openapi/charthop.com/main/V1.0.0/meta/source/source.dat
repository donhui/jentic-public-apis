            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "JobTierFieldSchema": {
        "type": "object",
        "required": [
          "values"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Field code (e.g., department)"
          },
          "values": {
            "type": "array",
