            "description": "person created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "bad request"
          },
          "401": {
            "description": "not authorized"
          },
          "404": {
            "description": "not found"
          }
        }
      }
    },
