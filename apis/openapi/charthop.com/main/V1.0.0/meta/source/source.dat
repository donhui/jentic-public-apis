          }
        }
      },
      "CombineScenarioRequest": {
        "type": "object",
        "required": [
          "scenarioIds"
        ],
        "properties": {
          "scenarioIds": {
            "type": "array",
            "description": "scenarios to combine",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "example": "588f7ee98f138b19220041a7"
            }
          },
          "copyOnly": {
            "type": "boolean"
          },
          "useScenarioDateForChanges": {
            "type": "boolean"
          }
        }
