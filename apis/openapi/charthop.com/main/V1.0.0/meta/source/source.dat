            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keepFilename",
            "in": "formData",
            "description": "whether the file should be renamed to the field name",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "file",
            "in": "formData",
            "required": true,
            "schema": {
              "type": "file"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "File created",
