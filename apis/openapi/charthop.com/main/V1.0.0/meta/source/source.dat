          },
          "value": {
            "type": "object",
            "description": "value"
          },
          "userId": {
            "type": "string",
            "description": "user who changed the value",
            "example": "588f7ee98f138b19220041a7"
          }
        }
      },
      "GroupParent": {
        "type": "object",
        "required": [
          "id",
          "type"
        ],
        "properties": {
