{
  "openapi": "3.0.3",
  "info": {
    "title": "Blockchain Data API",
    "version": "1.0.0",
    "description": "Blockchain.com Data API provides access to Bitcoin blockchain data including blocks, transactions, addresses, exchange rates, charts, and statistics.",
    "x-jentic-source-url": "https://www.blockchain.com/api"
  },
  "servers": [
    {
      "url": "https://blockchain.info",
      "description": "Blockchain.com Data API"
    }
  ],
  "tags": [
    { "name": "Blocks", "description": "Block data endpoints" },
    { "name": "Transactions", "description": "Transaction data endpoints" },
    { "name": "Addresses", "description": "Address data endpoints" },
    { "name": "ExchangeRates", "description": "Exchange rate endpoints" },
    { "name": "Charts", "description": "Charts and statistics endpoints" },
    { "name": "Query", "description": "Simple query endpoints" }
  ],
  "paths": {
    "/rawblock/{hash}": {
      "get": {
        "operationId": "getBlockByHash",
        "summary": "Get a single block by hash",
        "tags": ["Blocks"],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "description": "Block hash",
            "schema": { "type": "string" }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Response format (hex for raw hex encoding)",
            "schema": { "type": "string", "enum": ["hex"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Block data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Block" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/rawtx/{hash}": {
      "get": {
        "operationId": "getTransactionByHash",
        "summary": "Get a single transaction by hash",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "description": "Transaction hash",
            "schema": { "type": "string" }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Response format (hex for raw hex encoding)",
            "schema": { "type": "string", "enum": ["hex"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/block-height/{height}": {
      "get": {
        "operationId": "getBlockByHeight",
        "summary": "Get block at a specific height",
        "tags": ["Blocks"],
        "parameters": [
          {
            "name": "height",
            "in": "path",
            "required": true,
            "description": "Block height",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Block data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Block" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/rawaddr/{address}": {
      "get": {
        "operationId": "getAddressInfo",
        "summary": "Get address data with transaction history",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "Bitcoin address",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of transactions to return (default 50)",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Transaction offset for pagination",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Address data with transactions",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Address" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/multiaddr": {
      "get": {
        "operationId": "getMultipleAddresses",
        "summary": "Get data for multiple addresses",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "required": true,
            "description": "Addresses separated by pipe (|)",
            "schema": { "type": "string" }
          },
          {
            "name": "n",
            "in": "query",
            "required": false,
            "description": "Number of transactions per address (default 50)",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Transaction offset for pagination",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Multiple address data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "addresses": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Address" }
                    },
                    "txs": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Transaction" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/unspent": {
      "get": {
        "operationId": "getUnspentOutputs",
        "summary": "Get unspent outputs for an address",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "required": true,
            "description": "Address or addresses separated by pipe (|)",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Limit number of unspent outputs",
            "schema": { "type": "integer" }
          },
          {
            "name": "confirmations",
            "in": "query",
            "required": false,
            "description": "Minimum confirmations required",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Unspent outputs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "unspent_outputs": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/UnspentOutput" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/balance": {
      "get": {
        "operationId": "getAddressBalance",
        "summary": "Get balance summary for one or more addresses",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "required": true,
            "description": "Address or addresses separated by pipe (|)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Balance data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/BalanceSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/latestblock": {
      "get": {
        "operationId": "getLatestBlock",
        "summary": "Get the latest block on the blockchain",
        "tags": ["Blocks"],
        "responses": {
          "200": {
            "description": "Latest block info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LatestBlock" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/unconfirmed-transactions": {
      "get": {
        "operationId": "getUnconfirmedTransactions",
        "summary": "Get unconfirmed transactions from the mempool",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Response format",
            "schema": { "type": "string", "enum": ["json"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Unconfirmed transactions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "txs": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Transaction" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/blocks/{timeOrPool}": {
      "get": {
        "operationId": "getBlocksByTimeOrPool",
        "summary": "Get blocks by timestamp (milliseconds) or mining pool name",
        "tags": ["Blocks"],
        "parameters": [
          {
            "name": "timeOrPool",
            "in": "path",
            "required": true,
            "description": "Timestamp in milliseconds or mining pool name",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of blocks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "blocks": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/BlockSummary" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ticker": {
      "get": {
        "operationId": "getExchangeRates",
        "summary": "Get currency exchange rates with 15-min delayed market prices",
        "tags": ["ExchangeRates"],
        "responses": {
          "200": {
            "description": "Exchange rates by currency",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/CurrencyTicker"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/tobtc": {
      "get": {
        "operationId": "convertToBtc",
        "summary": "Convert a currency value to BTC",
        "tags": ["ExchangeRates"],
        "parameters": [
          {
            "name": "currency",
            "in": "query",
            "required": true,
            "description": "Currency code (e.g., USD, EUR)",
            "schema": { "type": "string" }
          },
          {
            "name": "value",
            "in": "query",
            "required": true,
            "description": "Value to convert",
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "BTC value",
            "content": {
              "text/plain": {
                "schema": { "type": "number" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/charts/{chartName}": {
      "get": {
        "operationId": "getChartData",
        "summary": "Get chart data by chart name",
        "tags": ["Charts"],
        "parameters": [
          {
            "name": "chartName",
            "in": "path",
            "required": true,
            "description": "Chart name (e.g., total-bitcoins, market-price, trade-volume)",
            "schema": { "type": "string" }
          },
          {
            "name": "timespan",
            "in": "query",
            "required": false,
            "description": "Duration (e.g., 1year, 3months, 1week)",
            "schema": { "type": "string" }
          },
          {
            "name": "rollingAverage",
            "in": "query",
            "required": false,
            "description": "Rolling average duration (e.g., 8hours, 1week)",
            "schema": { "type": "string" }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Start datetime (YYYY-MM-DDThh:mm:ss or YYYY-MM-DD)",
            "schema": { "type": "string" }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Response format (json or csv)",
            "schema": { "type": "string", "enum": ["json", "csv"] }
          },
          {
            "name": "sampled",
            "in": "query",
            "required": false,
            "description": "Whether to return sampled data",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "Chart data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChartData" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/stats": {
      "get": {
        "operationId": "getBlockchainStats",
        "summary": "Get blockchain statistics",
        "tags": ["Charts"],
        "responses": {
          "200": {
            "description": "Blockchain statistics",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BlockchainStats" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/pools": {
      "get": {
        "operationId": "getMiningPools",
        "summary": "Get mining pool hashrate distribution",
        "tags": ["Charts"],
        "parameters": [
          {
            "name": "timespan",
            "in": "query",
            "required": false,
            "description": "Duration in days (max 10, default 4)",
            "schema": { "type": "integer", "default": 4, "maximum": 10 }
          }
        ],
        "responses": {
          "200": {
            "description": "Mining pool data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "type": "integer" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/q/getdifficulty": {
      "get": {
        "operationId": "getDifficulty",
        "summary": "Get current mining difficulty",
        "tags": ["Query"],
        "responses": {
          "200": {
            "description": "Current difficulty as plain text",
            "content": {
              "text/plain": {
                "schema": { "type": "number" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/q/getblockcount": {
      "get": {
        "operationId": "getBlockCount",
        "summary": "Get current block height",
        "tags": ["Query"],
        "responses": {
          "200": {
            "description": "Current block height as plain text",
            "content": {
              "text/plain": {
                "schema": { "type": "integer" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/q/latesthash": {
      "get": {
        "operationId": "getLatestHash",
        "summary": "Get the hash of the latest block",
        "tags": ["Query"],
        "responses": {
          "200": {
            "description": "Latest block hash as plain text",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/q/addressbalance/{address}": {
      "get": {
        "operationId": "getAddressBalanceSimple",
        "summary": "Get address balance in satoshi",
        "tags": ["Query"],
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "Bitcoin address",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Balance in satoshi as plain text",
            "content": {
              "text/plain": {
                "schema": { "type": "integer" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/q/getreceivedbyaddress/{address}": {
      "get": {
        "operationId": "getTotalReceivedByAddress",
        "summary": "Get total BTC received by an address",
        "tags": ["Query"],
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "Bitcoin address",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Total received in satoshi",
            "content": {
              "text/plain": {
                "schema": { "type": "integer" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/q/getsentbyaddress/{address}": {
      "get": {
        "operationId": "getTotalSentByAddress",
        "summary": "Get total BTC sent by an address",
        "tags": ["Query"],
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "Bitcoin address",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Total sent in satoshi",
            "content": {
              "text/plain": {
                "schema": { "type": "integer" }
              }
            }
