                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateMention",
        "summary": "Update a mention",
        "description": "Update mention properties such as read status, favorite, or folder.",
        "tags": [
          "Mention"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mention_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateMentionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mention updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MentionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/alerts/{alert_id}/mentions/{mention_id}/tags": {
      "post": {
        "operationId": "addTagToMention",
        "summary": "Add a tag to a mention",
        "description": "Add a tag to a specific mention.",
        "tags": [
          "MentionTag"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mention_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "tag"
                ],
                "properties": {
                  "tag": {
                    "type": "string",
                    "description": "Tag name to add"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tag added successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/alerts/{alert_id}/statistics": {
      "get": {
        "operationId": "getAlertStatistics",
        "summary": "Get alert statistics",
        "description": "Retrieve analytics and statistics for a specific alert.",
        "tags": [
          "Statistics"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatisticsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccountResponse": {
        "type": "object",
        "properties": {
          "account": {
            "$ref": "#/components/schemas/Account"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique account identifier"
          },
          "name": {
            "type": "string",
            "description": "Account holder name"
          },
          "email": {
            "type": "string",
            "description": "Account email address"
          },
          "language_code": {
            "type": "string",
            "description": "Language preference"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "grouped_email_notification": {
            "type": "boolean",
            "description": "Whether notifications are grouped in a single email"
          },
          "default_email_notification_frequency": {
            "type": "string",
            "description": "Notification frequency (e.g., daily)"
          },
          "permissions": {
            "type": "object",
            "properties": {
              "create_alert": {
                "type": "boolean"
              },
              "read_teammembers": {
                "type": "boolean"
              }
            }
          },
          "email_subscriptions": {
            "type": "object"
          }
        }
      },
      "AlertListResponse": {
        "type": "object",
        "properties": {
          "alerts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AlertWrapper"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/PaginationLinks"
          }
        }
      },
      "AlertWrapper": {
        "type": "object",
        "properties": {
          "alert": {
            "$ref": "#/components/schemas/Alert"
          }
        }
      },
      "AlertResponse": {
        "type": "object",
        "properties": {
          "alert": {
            "$ref": "#/components/schemas/Alert"
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "query": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "basic",
                  "advanced"
                ]
              },
              "included_keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "excluded_keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "required_keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "languages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "noise_detection": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateAlertRequest": {
        "type": "object",
        "required": [
          "name",
          "query",
          "languages"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable name for the alert"
          },
          "query": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "basic",
                  "advanced"
                ]
              },
              "included_keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "excluded_keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "required_keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "languages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 5,
            "description": "Language codes (max 5)"
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_sites": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "noise_detection": {
            "type": "boolean"
          },
          "color": {
            "type": "string"
          },
          "connection_type": {
            "type": "string",
            "enum": [
              "main",
              "related",
              "independent"
            ]
          },
          "connection_id": {
            "type": "string"
          }
        }
      },
      "MentionListResponse": {
        "type": "object",
