                            }
                          }
                        },
                        "title": {
                          "type": "object",
                          "properties": {
                            "before": {
                              "type": "string",
                              "description": "Title before name.",
                              "example": null
                            },
                            "after": {
                              "type": "string",
                              "description": "Title after name.",
                              "example": null
                            }
                          }
                        },
                        "user_img": {
                          "type": "string",
                          "description": "User image path."
                        },
                        "rating": {
                          "type": "integer",
                          "description": "User rating, 0-5.",
                          "enum": [
                            0,
                            1,
                            2,
                            3,
                            4,
                            5
                          ]
                        },
                        "ratings": {
