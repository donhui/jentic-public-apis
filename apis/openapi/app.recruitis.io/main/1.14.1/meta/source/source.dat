    "/jobs/{id}/channel/{channel_id}": {
      "put": {
        "tags": [
          "Jobs"
        ],
        "summary": "Publish job",
        "description": "Publishing an active job advertisement on one of the presentation channels. \nIf the job ad is already published on the given channel, the settings will be updated.\n\nFor correct functionality, the position for which you set `channel_id` must be published \nin the Recruitis ATS (i.e., not just in draft).\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n  * The token must have the `api.position.write` permission.\n* Old token type:\n  * Token type: `full_access`: publishing a job ad requires full access\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer",
              "example": 363098
            },
            "required": true
          },
          {
            "name": "channel_id",
            "in": "path",
            "schema": {
              "oneOf": [
                {
                  "type": "integer",
                  "example": 1,
                  "description": "number of channel"
                },
                {
                  "type": "string",
                  "example": "NqgIskDnNc54P",
                  "description": "hash of own channel"
                }
              ]
            },
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "date_from": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2022-02-22 17:45:15",
                    "description": "Format YYYY-mm-dd HH:mm:ss\nDate from which the job advertisement should be published on the given channel. If not specified, the current date and time will be used.\n"
                  },
                  "date_to": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2023-02-22 17:45:15",
                    "description": "Format YYYY-mm-dd HH:mm:ss\nDate to which the job advertisement should be published on the given channel.\n"
                  }
                },
                "required": [
                  "date_from",
                  "date_to"
                ]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Succesfully published.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "oneOf": [
                              {
                                "type": "integer",
                                "example": 2
                              },
                              {
                                "type": "string",
                                "example": "NqgIskDnNc54P"
                              }
                            ]
                          },
                          "name": {
                            "type": "string",
                            "example": "Jobs.cz"
                          },
                          "date_from": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Format YYYY-mm-dd HH:mm:ss",
                            "example": "2022-02-22 17:45:15"
                          },
                          "date_to": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Format YYYY-mm-dd HH:mm:ss",
                            "example": "2023-02-22 17:45:15"
                          },
                          "paused": {
                            "type": "boolean",
                            "example": false
                          }
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.updated"
                        },
                        "duration": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string",
                          "example": "Job was successfully published on channel"
                        },
                        "entries_from": {
                          "type": "integer",
                          "example": 0
                        },
                        "entries_to": {
                          "type": "integer",
                          "example": 1
                        },
                        "entries_total": {
                          "type": "integer",
                          "example": 1
                        },
                        "entries_sum": {
                          "type": "integer",
                          "example": 1
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Response400"
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          }
        }
      },
      "delete": {
        "tags": [
          "Jobs"
        ],
        "summary": "Unpublish job",
        "description": "Unpublishing a job advertisement from a presentation channel.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n  * The token must have the `api.position.write` permission.\n* Old token type:\n  * Token type: `full_access`\n",
        "parameters": [
