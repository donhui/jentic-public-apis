                                },
                                "note": {
                                  "type": "string"
                                },
                                "type": {
                                  "type": "string"
                                }
                              }
                            }
                          },
                          "example": {
                            "date_employment": null,
                            "preffered_location": null,
                            "salary": null
                          }
                        },
                        "job_details": {
                          "type": "object",
                          "properties": {
                            "job_title": {
                              "type": "string",
                              "description": "Job title to which the answer is assigned.",
                              "example": "IT support"
                            },
                            "job_id": {
                              "type": "integer",
                              "description": "Job ID to which the answer is assigned.",
                              "example": 13457
