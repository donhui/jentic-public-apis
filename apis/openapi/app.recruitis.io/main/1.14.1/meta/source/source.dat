                            "date_employment": {
                              "type": "string",
                              "format": "date-time"
                            },
                            "preffered_location": {
                              "type": "string"
                            },
                            "salary": {
                              "type": "object",
                              "properties": {
                                "amount": {
                                  "type": "integer"
