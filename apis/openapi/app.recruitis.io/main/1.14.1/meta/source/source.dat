    "/enums/flows": {
      "get": {
        "tags": [
          "Enumerations"
        ],
        "summary": "Get Flows",
        "description": "This call returns a list of all flow templates and their statuses when no parameter is provided. \nIf both parameters are specified at the same time, `jobId` takes precedence in the search \u2014 \nthe `name` parameter is ignored.\n\n#### Requirements\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.enums.read` permission.\n* Old token types:\n    * Token type: `public_access`, `full_access`\n",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "Basic classification"
            },
            "description": "Name of the flow template. Returns the statuses of this recruitment flow."
          },
          {
            "name": "jobId",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 138798
            },
            "description": "Position ID. From the specified position, it determines the flow template and returns its statuses. If the jobID parameter is provided, the name parameter is ignored."
          }
