    "/answer/{answer_id}": {
      "patch": {
        "tags": [
          "Candidates"
        ],
        "summary": "Reject answer",
        "description": "This call rejects a specific answer with the requested rejection reason and communication. \nIf neither the communication method nor the rejection reason is provided, \nthe answer is rejected by default without a rejection method and without communication.  \nIn case of `isRejected = true`, the answer is moved back from rejected to active.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Not compatible with the company token.\n* New token type:\n    * The token must have the `api.candidates.write` permission.\n* Original token types:\n    * Token type: `public_access`: if it concerns a public job ad (published on company websites, XML, or job portals).\n    * Token type: `full_access`: if it concerns an internal job ad.\n",
        "parameters": [
          {
            "name": "answer_id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reject": {
                    "type": "object",
                    "properties": {
                      "isRejected": {
                        "type": "boolean"
                      },
                      "rejectReasonId": {
                        "type": "integer"
                      },
                      "communicationType": {
                        "type": "string",
                        "enum": [
                          "no_communication",
                          "phone",
                          "email"
                        ]
                      }
                    },
                    "required": [
                      "isRejected"
                    ]
                  }
                },
                "required": [
                  "reject"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Answer was updated.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "array"
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 60
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 150
                        },
                        "code": {
                          "type": "string",
                          "example": "api.found"
                        },
                        "message": {
                          "type": "string",
                          "example": "Answer was updated."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Response400"
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          }
        }
      }
    },
    "/answers/{answer_id}/export": {
      "put": {
        "tags": [
          "Candidates"
        ],
        "summary": "Export answer",
        "description": "Marks an answer in Recruitis as exported. It does not have a fixed value list. \nThis functionality is not intended for normal use. For a more detailed description, please contact us.\n\n#### Important information:\nThe `status` value does not have a fixed value list; each company defines it on their side.  \nUse a bitmask to define the values.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.candidates.write` permission.\n* Original token type:\n    * Token type: `full_access`.\n",
        "parameters": [
          {
            "name": "answer_id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "integer",
                    "description": "Bitmask, values 1,2,4,8,16,.."
                  }
                },
                "required": [
                  "status"
                ]
              }
            }
