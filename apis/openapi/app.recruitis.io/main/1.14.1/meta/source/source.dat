    "/tasks/table": {
      "get": {
        "tags": [
          "Tasks"
        ],
        "summary": "Get all tasks",
        "description": "Lists all tasks.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Token type: `full_access`\n* New token type:\n    * The token must have the `api.candidates.read` permission.\n* Old token type:\n    * Token type: `full_access`\n",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Current page. 1 page is limited to 10 tasks.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "tblForToday",
            "in": "query",
            "description": "Tasks due today.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "tblAfterDeadline",
            "in": "query",
            "description": "Unresolved tasks past their deadline.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "tblAll",
            "in": "query",
            "description": "All tasks.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "tab",
            "in": "query",
            "description": "Tasks: `1 = To solve`, `2 = Solved`.",
            "schema": {
              "type": "int",
              "enum": [
                1,
                2
              ],
              "default": 1
            }
          },
          {
            "name": "tblRadio",
            "in": "query",
            "description": "Show tasks: `1 = By task`, `2 = By candidate`.",
            "schema": {
              "type": "int",
              "enum": [
                1,
                2
              ],
              "default": 1
            }
          },
          {
            "name": "tblTaskType",
            "in": "query",
            "description": "Task assignment filter: `0 = All`, `1 = Me to others`, `2 = To me`, `3 = Me to me`.",
            "schema": {
              "type": "int",
              "enum": [
                0,
                1,
                2,
                3
              ],
              "default": 0
            }
          },
          {
            "name": "withInitialData",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
