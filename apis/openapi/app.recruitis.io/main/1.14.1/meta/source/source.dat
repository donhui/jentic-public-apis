                            "job_detail_url": {
                              "type": "string",
                              "description": "Job detail URL.",
                              "example": "https://dev.recruitis.io/zadavatel/inzeraty/detail/13457"
                            },
                            "job_contact_name": {
                              "type": "string",
                              "description": "Contact person's full name.",
                              "example": "Stepan Bartyzal"
                            },
