                              }
                            ]
                          },
                          "name": {
                            "type": "string",
                            "example": "Jobs.cz"
                          },
                          "date_from": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Format YYYY-mm-dd HH:mm:ss",
                            "example": "2022-02-22 17:45:15"
                          },
                          "date_to": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Format YYYY-mm-dd HH:mm:ss",
                            "example": "2023-02-22 17:45:15"
                          },
                          "paused": {
                            "type": "boolean",
                            "example": false
                          }
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.updated"
                        },
                        "duration": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string",
