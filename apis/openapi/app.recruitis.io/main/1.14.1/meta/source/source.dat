                        "duration": {
                          "type": "integer",
                          "example": 150
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 340
                        },
                        "code": {
                          "type": "string",
                          "example": "api.error.property.wrong_value"
                        },
                        "message": {
                          "type": "string",
                          "example": "Date from must be lower than date to."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
