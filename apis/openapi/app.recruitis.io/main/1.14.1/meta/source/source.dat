    "/jobs/{id}/recommend/applicant": {
      "post": {
        "tags": [
          "Jobs"
        ],
        "summary": "Create candidate recommendation",
        "description": "This endpoint creates a candidate referral for a given position.  \nThe candidate will then receive an email asking for confirmation whether they are truly interested in the position.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.candidates.write` permission.\n* Old token type:\n    * Token type: `public_access`.\n",
        "parameters": [
