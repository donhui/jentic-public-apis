    "/enums/reject_reasons": {
      "get": {
        "tags": [
          "Enumerations"
        ],
        "summary": "Get Reject reasons",
        "description": "Returns all reject reasons.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.enums.read` permission.\n* Old token types:\n    * Token type: `public_access`, `full_access`\n",
        "responses": {
          "200": {
            "description": "Reject reasons were returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "candidate": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "date_added": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "date_modified": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "reason": {
                                "type": "string"
                              },
                              "type": {
                                "type": "string"
                              },
                              "is_hidden": {
                                "type": "boolean"
                              }
                            }
                          }
                        },
                        "company": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "date_added": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "date_modified": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "reason": {
                                "type": "string"
                              },
                              "type": {
                                "type": "string"
                              },
                              "is_hidden": {
                                "type": "boolean"
                              }
                            }
                          }
                        }
                      },
                      "example": {
                        "candidate": [
                          {
                            "id": 1,
                            "date_added": "2020-08-05 12:32:41",
                            "date_modified": null,
                            "reason": "counter offer",
                            "type": "candidate",
                            "is_hidden": false
                          },
                          {
                            "id": null,
                            "date_added": "2020-12-05 12:32:41",
                            "date_modified": null,
                            "reason": "stopped communicating",
                            "type": "candidate",
                            "is_hidden": false
                          }
                        ],
                        "company": [
                          {
                            "id": 5,
                            "date_added": "2020-08-05 12:33:34",
                            "date_modified": null,
                            "reason": "Was good, but we gave chance to another",
                            "type": "company",
                            "is_hidden": false
                          },
                          {
                            "id": null,
                            "date_added": "2020-12-05 12:32:41",
                            "date_modified": null,
                            "reason": "no experience",
                            "type": "company",
                            "is_hidden": false
                          }
                        ]
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 2405
                        },
                        "code": {
                          "type": "string",
                          "example": "api.found"
                        },
                        "message": {
                          "type": "string",
                          "example": "Reject reasons returned."
                        }
                      }
                    }
                  }
                }
              }
            }
