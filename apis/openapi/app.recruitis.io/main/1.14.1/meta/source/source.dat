                          "items": {
                            "type": "object"
                          },
                          "example": []
                        },
                        "sign_job": {
                          "type": "object",
                          "properties": {
                            "job_title": {
                              "type": "string",
                              "description": "The title of the job advertisement to which the answer is assigned.",
                              "example": "Bookmaster"
                            },
                            "job_source_site": {
                              "type": "string",
                              "deprecated": true,
                              "description": "Job source site, on which was the job advert created.",
                              "example": "Recruitis.io"
                            }
                          }
                        },
                        "source_site": {
                          "type": "string",
                          "example": "manually added"
                        },
                        "phone": {
                          "type": "string",
                          "example": "+420773631234"
                        },
                        "email": {
                          "type": "string",
                          "format": "email",
                          "example": "test@test.test"
                        },
                        "flow_id": {
                          "type": "integer",
                          "description": "Flow ID in which the answer is currently located.",
                          "example": 1
                        },
                        "share_status": {
                          "type": "integer",
                          "description": "If the answer is recycled (copied from another job advertisement), we are waiting for the candidate\u2019s reply.\nNULL \u2013 no reply,\n1 \u2013 The candidate approved the answer,\n0 \u2013 The candidate rejected the answer.\n",
                          "nullable": true,
                          "example": null
                        },
                        "share_status_detail": {
                          "type": "string",
                          "description": "Reason for rejecting the recycled answer.",
                          "example": null
                        },
                        "rejected": {
                          "type": "boolean",
                          "description": "Indicates whether the answer is rejected.",
                          "nullable": true,
                          "example": true
                        },
                        "reject_reason": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "description": "Reject reason ID"
                              },
                              "type": {
                                "type": "string",
                                "enum": [
                                  "candidate",
                                  "company",
                                  "agency"
                                ],
                                "description": "Type of rejection reason (candidate \u2013 on the candidate\u2019s side, company \u2013 company reason, agency \u2013 agency reason)\n",
                                "example": "candidate"
                              },
                              "name": {
                                "type": "string",
                                "description": "Reject reason",
                                "example": "Was not hardworking."
                              }
                            }
                          }
                        },
                        "answer_created": {
                          "type": "string",
                          "format": "date-time",
                          "description": "Date of the answer creation, in format YYYY-mm-dd HH:mm:ss",
                          "example": "2022-09-12 14:38:04"
