                          "example": 92
                        },
                        "message": {
                          "type": "string",
                          "example": "Custom fields values were found."
                        },
                        "entries_from": {
                          "type": "integer",
                          "example": 0
                        },
                        "entries_to": {
                          "type": "integer",
                          "example": 4
                        },
                        "entries_total": {
                          "type": "integer",
                          "example": 4
                        },
                        "entries_sum": {
                          "type": "integer",
                          "example": 4
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          }
        }
      }
    },
    "/filters": {
      "get": {
        "tags": [
          "Job filters"
        ],
        "summary": "Get filters",
        "description": "Retrieves all our professions and fields, including their IDs.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.filters.read` permission.\n* Old token type:\n    * Token type: `public_access`\n",
        "parameters": [
          {
            "name": "group[]",
            "in": "query",
            "description": "Filters only the list of filters for the given group.",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filters were found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer"
                          },
                          "name": {
                            "type": "string"
                          },
                          "group": {
                            "type": "string"
                          },
                          "group_id": {
                            "type": "integer"
                          },
                          "group_settings": {
                            "type": "object",
                            "properties": {
                              "is_required": {
                                "type": "boolean"
                              },
                              "is_multiselect": {
                                "type": "boolean"
                              }
                            }
                          }
                        }
                      },
                      "example": [
                        {
                          "id": 6,
                          "name": "Infirmary",
                          "group": "Department",
                          "group_id": 1,
                          "group_settings": {
                            "is_required": false,
                            "is_multiselect": true
                          }
                        },
                        {
                          "id": 7,
                          "name": "Gynecology",
                          "group": "Department",
                          "group_id": 1,
                          "group_settings": {
                            "is_required": false,
                            "is_multiselect": true
                          }
                        },
                        {
                          "id": 8,
                          "name": "ENT",
                          "group": "Department",
                          "group_id": 1,
                          "group_settings": {
                            "is_required": false,
                            "is_multiselect": true
                          }
                        },
                        {
                          "id": 9,
                          "name": "Two-shift",
                          "group": "Shift operation",
                          "group_id": 5,
                          "group_settings": {
                            "is_required": false,
                            "is_multiselect": true
                          }
                        },
                        {
                          "id": 12,
                          "name": "Continuous",
                          "group": "Shift operation",
                          "group_id": 5,
                          "group_settings": {
                            "is_required": false,
                            "is_multiselect": true
                          }
                        }
                      ]
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 300
                        },
                        "code": {
                          "type": "string",
                          "example": "api.found"
                        },
                        "message": {
                          "type": "string",
                          "example": "Filter enumeration is returned."
                        },
                        "entries_from": {
                          "type": "integer",
                          "example": 1
                        },
                        "entries_to": {
                          "type": "integer",
                          "example": 17
                        },
                        "entries_total": {
                          "type": "integer",
                          "example": 5
                        },
                        "entries_sum": {
                          "type": "integer",
                          "example": 5
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          }
        }
      },
      "post": {
        "tags": [
          "Job filters"
        ],
        "summary": "Create new filter",
        "description": "Create a new filter.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.filters.write` permission.\n* Old token type:\n    * Token type: `public_access`\n",
        "requestBody": {
          "$ref": "#/components/requestBodies/JobFilter"
        },
        "responses": {
          "201": {
            "description": "Filter was created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1250
                        },
                        "group_id": {
                          "type": "integer",
                          "example": 250
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.created"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 120
                        },
                        "message": {
                          "type": "string",
                          "example": "Filter was created."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          }
        }
      }
    },
    "/filters/{id}": {
      "put": {
        "tags": [
          "Job filters"
        ],
        "summary": "Update existing filter",
        "description": "Edit a filter by ID in the URI parameter.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.filters.write` permission.\n* Old token type:\n    * Token type: `public_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/JobFilter"
        },
        "responses": {
          "201": {
            "description": "Filter was modified.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "nullable": true
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 123
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 320
                        },
                        "code": {
                          "type": "string",
                          "example": "api.modified"
                        },
                        "message": {
                          "type": "string",
                          "example": "Filter was modified."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          }
        }
      },
      "delete": {
        "tags": [
          "Job filters"
        ],
        "summary": "Delete existing filter",
        "description": "Delete a filter by ID.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.filters.write` permission.\n* Old token type:\n    * Token type: `public_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Filter was deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "count": {
                          "type": "integer",
                          "example": 1
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 120
                        },
                        "code": {
                          "type": "string",
                          "example": "api.deleted"
                        },
                        "message": {
                          "type": "string",
                          "example": "Filter was deleted."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          }
        }
      }
    },
    "/files/{hash}": {
      "get": {
        "tags": [
          "Files"
        ],
        "summary": "Download a file",
        "description": "### Warning!\n**For security reasons, when calling this function ALWAYS verify that the given URL address contains the domain https://api.recruitis.io/api2/**\n\nFile downloading works in such a way that the API returns a payload with a base64 string, \nwhich you can then convert into the corresponding file.\nThe given hash is currently returned by the `GET /answers` function, which returns the full URL address \nincluding the hash (e.g., \"https://api.recruitis.io/api2/files/YXdQMmRtWWprNXBTY042M1hFOTdvZz09\").\n\nIf the file does not exist, or does not belong to your company, the API returns HTTP status `404` \nwith meta code `api.error.not_found`.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.files.read` permission.\n* Old token type:\n    * Token type: `full_access`\n\n**If requesting multiple attachments, the total size of all attachments must be less than 30MB. \nIf the total exceeds this limit, the API returns HTTP status `413` with meta code `api.error.response.too_big`.**\n",
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "description": "The hash is an identifying string that tells the system which file to return.\nIf the hash parameter is provided as a single-element array, the payload is returned as an object. Otherwise, the payload is returned as an array.\n",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "example": "YXdQMmRtWWprNXBTY042M1hFOTdvZz09"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "File was found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "oneOf": [
                        {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string",
                                "description": "File name and it's extension."
                              },
                              "hash": {
                                "type": "string",
                                "example": "MSHRr56dsTXd1cUI1UGxNZmdXQT09"
                              },
                              "size": {
                                "type": "number",
                                "format": "float",
                                "description": "File size in kB (to 2 decimal places)."
                              },
                              "content": {
                                "type": "string",
                                "format": "byte",
                                "description": "Content of the file in Base64."
                              }
                            }
                          },
                          "example": [
                            {
                              "name": "CV.txt",
                              "hash": "MSHRr56dsTXd1cUI1UGxNZmdXQT09",
                              "size": 0.03,
                              "content": "TW9qZSBDVjoNCm5lbcOhbSB0dSBuaWMsIHNtxa9sYS4uLg==\\r\\n"
                            },
                            {
                              "name": "favicon.png",
                              "hash": "LrPe7sET75I1UGxNZmdXQT09",
                              "size": 35.74,
                              "content": "/9j/4AAQSkZJRgABAQAAAQABAAD/2wBDAAgGBgcGBQgHBwcJCQgKDBQNDAsLDBkSEw8UHRofHh0a\\r\\nHBwgJC4nICIsIxwcKDcpLDAxNDQ0Hyc5PTgyPC4zNDL/2wBDAQkJCQwLDBgNDRgyIRwhMjIyMjIy\\r\\nMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjL/wAARCAGkAtMDASIA\\r\\nAhEBAxEB/8QAHwAAAQUBAQEBAQEAAAAAAAAAAAECAwQFBgcICQoL/8QAtRAAAgEDAwIEAwUFBAQA\\r\\nAAF9AQIDAAQRBRIhMUEGE1FhByJxFDKBkaEII0KxwRVS0fAkM2JyggkKFhcYGRolJicoKSo0NTY3\\r\\nODk6Q0RFRkdISUpTVFVWV1hZWmNkZWZnaGlqc3R1dnd4eXqDhIWGh4iJipKTlJWWl5iZmqKjpKWm\\r\\np6ipqrKztLW2t7i5usLDxMXGx8jJytLT1NXW19jZ2uHi4+Tl5ufo6erx8vP09fb3+Pn6/8QAHwEA\\r\\nAwEBAQEBAQEBAQAAAAAAAAECAwQFBgcICQoL/8QAtREAAgECBAQDBAcFBAQAAQJ3AAECAxEEBSEx\\r\\nBhJBUQdhcRMiMoEIFEKRobHBCSMzUvAVYnLRChYkNOEl8RcYGRomJygpKjU2Nzg5OkNERUZHSElK\\r\\nU1RVVldYWVpjZGVmZ2hpanN0dXZ3eHl6goOEhYaHiImKkpOUlZaXmJmaoqOkpaanqKmqsrO0tba3\\r\\nuLm6wsPExcbHyMnK0tPU1dbX2Nna4uPk5ebn6Onq8vP09fb3+Pn6/9oADAMBAAIRAxEAPwD0vQdB\\r\\nttZs7u9vb3WWnbU79P3esXcShUupUUBUkCgBVAwAOlX28LaIlzHbNqOsLcSKzpEfEF4GZRjJA87J\\r\\nAyMn3FUbCLUZ/h/rUWkSeXqL3uqi3YMFIf7ZPjBPAPoe1ZmoaLrjra3emaTfJJDpt5EsV9qhkmEj\\r\\nvEVBlExbnYxG2TAwBuXPB1GdN/whul/8/Wuf+D29/wDj1V77w54f0y0e7v8AVdVtLZMb5rjxFeRo\\r\\nuTgZYzYHNcppmleN4P7K+1RanL5E9x5iteAKIXbKFj9pJZ1HAV/NXsSPvVeTSPEb/DxbO6sbq41C\\r\\nDUIJljlug000ccyOWYvM6qxCt8okI9MZwBai6m5Y+HfD2qWi3en6tqt3bPkLNb+IryRGwcHDCYjr\\r\\nVn/hDdL/AOfrXP8Awe3v/wAerk59D8Ryand6sunX8Fhf6gJrnSrK9SC6KLBsVzIsiqCXAJCycgDr\\r\\nyKjHhvxnNbwm6vtSM8MGnqph1IoCwlb7RuAYBiIyoJI5IyMmjf8AD8f8gOw/4Q3S/wDn61z/AMHt\\r\\n7"
                            }
                          ]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string",
                              "description": "File name and it's extension.",
                              "example": "favicon.png"
                            },
                            "hash": {
                              "type": "string",
                              "example": "LrPe7sET75I1UGxNZmdXQT09"
                            },
                            "size": {
                              "type": "number",
                              "format": "float",
                              "description": "File size in kB (to 2 decimal places).",
                              "example": 35.74
                            },
                            "content": {
                              "type": "string",
                              "format": "byte",
                              "description": "Content of the file in Base64.",
                              "example": "/9j/4AAQSkZJRgABAQAAAQABAAD/2wBDAAgGBgcGBQgHBwcJCQgKDBQNDAsLDBkSEw8UHRofHh0a\\r\\nHBwgJC4nICIsIxwcKDcpLDAxNDQ0Hyc5PTgyPC4zNDL/2wBDAQkJCQwLDBgNDRgyIRwhMjIyMjIy\\r\\nMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjIyMjL/wAARCAGkAtMDASIA\\r\\nAhEBAxEB/8QAHwAAAQUBAQEBAQEAAAAAAAAAAAECAwQFBgcICQoL/8QAtRAAAgEDAwIEAwUFBAQA\\r\\nAAF9AQIDAAQRBRIhMUEGE1FhByJxFDKBkaEII0KxwRVS0fAkM2JyggkKFhcYGRolJicoKSo0NTY3\\r\\nODk6Q0RFRkdISUpTVFVWV1hZWmNkZWZnaGlqc3R1dnd4eXqDhIWGh4iJipKTlJWWl5iZmqKjpKWm\\r\\np6ipqrKztLW2t7i5usLDxMXGx8jJytLT1NXW19jZ2uHi4+Tl5ufo6erx8vP09fb3+Pn6/8QAHwEA\\r\\nAwEBAQEBAQEBAQAAAAAAAAECAwQFBgcICQoL/8QAtREAAgECBAQDBAcFBAQAAQJ3AAECAxEEBSEx\\r\\nBhJBUQdhcRMiMoEIFEKRobHBCSMzUvAVYnLRChYkNOEl8RcYGRomJygpKjU2Nzg5OkNERUZHSElK\\r\\nU1RVVldYWVpjZGVmZ2hpanN0dXZ3eHl6goOEhYaHiImKkpOUlZaXmJmaoqOkpaanqKmqsrO0tba3\\r\\nuLm6wsPExcbHyMnK0tPU1dbX2Nna4uPk5ebn6Onq8vP09fb3+Pn6/9oADAMBAAIRAxEAPwD0vQdB\\r\\nttZs7u9vb3WWnbU79P3esXcShUupUUBUkCgBVAwAOlX28LaIlzHbNqOsLcSKzpEfEF4GZRjJA87J\\r\\nAyMn3FUbCLUZ/h/rUWkSeXqL3uqi3YMFIf7ZPjBPAPoe1ZmoaLrjra3emaTfJJDpt5EsV9qhkmEj\\r\\nvEVBlExbnYxG2TAwBuXPB1GdN/whul/8/Wuf+D29/wDj1V77w54f0y0e7v8AVdVtLZMb5rjxFeRo\\r\\nuTgZYzYHNcppmleN4P7K+1RanL5E9x5iteAKIXbKFj9pJZ1HAV/NXsSPvVeTSPEb/DxbO6sbq41C\\r\\nDUIJljlug000ccyOWYvM6qxCt8okI9MZwBai6m5Y+HfD2qWi3en6tqt3bPkLNb+IryRGwcHDCYjr\\r\\nVn/hDdL/AOfrXP8Awe3v/wAerk59D8Ryand6sunX8Fhf6gJrnSrK9SC6KLBsVzIsiqCXAJCycgDr\\r\\nyKjHhvxnNbwm6vtSM8MGnqph1IoCwlb7RuAYBiIyoJI5IyMmjf8AD8f8gOw/4Q3S/wDn61z/AMHt\\r\\n7"
                            }
                          }
                        }
                      ]
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.found"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 50
                        },
                        "message": {
                          "type": "string",
                          "example": "File was found."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          },
          "413": {
            "description": "The request is too large and cannot be processed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "nullable": true
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 2150
                        },
                        "code": {
                          "type": "string",
                          "example": "api.error.response.too_big"
                        },
                        "message": {
                          "type": "string",
                          "example": "Response is too big to be sent."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/enums/workfields": {
      "get": {
        "tags": [
          "Enumerations"
        ],
        "summary": "Get Workfields",
        "description": "If the `channel_assignation[]` parameter is provided, authorization is required. \nOtherwise, no authorization is required.\n\n### Without the `channel_assignation[]` parameter:\n* Retrieves all our professions and fields, including their IDs.\n\n#### Requirements\n* No authorization required\n\n---\n\n### With the `channel_assignation[]` parameter:\n* Retrieves all professions that are included in the job advertisements of the given company. \nSometimes the total number (`count`) of fields may not match the sum of the `count` values of the subordinate professions. \nThis is because job advertisements may be linked only to a field, not necessarily also to a profession.\n\n*For clarification: Professions are a subset of individual fields.*\n\n#### Requirements\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.enums.read` permission.\n* Old token types:\n    * Token type: `public_access`, `full_access`\n",
        "parameters": [
          {
            "name": "channel_assignation[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "cs",
              "enum": [
                "cs"
              ]
            },
            "description": "The language in which the workfields should be returned (currently only Czech is supported)."
          }
        ],
        "responses": {
          "200": {
            "description": "Workfields were found.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "payload": {
                          "type": "array",
                          "description": "This is what the payload looks like without the channel_assignation[] parameter.",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "name": {
                                "type": "string"
                              },
                              "professions": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "id": {
                                      "type": "integer"
                                    },
                                    "name": {
                                      "type": "string"
                                    }
                                  }
                                }
                              }
                            }
                          },
                          "example": [
                            {
                              "id": 1,
                              "name": "Administration",
                              "professions": [
                                {
                                  "id": 101,
                                  "name": "Administrative worker."
                                },
                                {
                                  "id": 103,
                                  "name": "Assistant"
                                }
                              ]
                            },
                            {
                              "id": 3,
                              "name": "Tourism and Recreational Services",
                              "professions": [
                                {
                                  "id": 301,
                                  "name": "Leisure Time Animator"
                                },
                                {
                                  "id": 305,
                                  "name": "Croupier"
                                }
                              ]
                            }
                          ]
                        },
                        "meta": {
                          "type": "object",
                          "properties": {
                            "duration": {
                              "type": "integer",
                              "example": 2560
                            },
                            "code": {
                              "type": "string",
                              "example": "api.found"
                            },
                            "message": {
                              "type": "string",
                              "example": "Workfields were returned."
                            },
                            "entries_from": {
                              "type": "integer",
                              "example": 2
                            },
                            "entries_to": {
                              "type": "integer",
                              "example": 17
                            },
                            "entries_total": {
                              "type": "integer",
                              "example": 4
                            },
