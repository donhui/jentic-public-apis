                                      "example": 50.7
                                    },
                                    "hash": {
                                      "type": "string",
                                      "description": "File ID (hash).",
                                      "example": "sft6F68M84fdfjR"
                                    },
                                    "download_url": {
                                      "type": "string",
                                      "description": "REST API URL address for downloading the file.\nYou must be authorized with a full_access token when calling. See the files section.\n",
                                      "example": "https://api.recruitis.io/api2/files/sft6F68M84fdfjR"
                                    }
                                  }
                                }
                              }
                            }
                          }
                        },
                        "meta": {
                          "type": "object",
                          "properties": {
                            "code": {
                              "type": "string",
                              "example": "api.found"
                            },
                            "duration": {
                              "type": "integer",
                              "example": 3542
                            },
                            "message": {
                              "type": "string",
                              "example": "Answers were found."
                            },
                            "entries_from": {
                              "type": "integer",
                              "example": 1
                            },
                            "entries_to": {
                              "type": "integer",
                              "example": 20
                            },
                            "entries_total": {
                              "type": "integer",
                              "example": 7
                            },
                            "entries_sum": {
                              "type": "integer",
                              "example": 7
                            }
                          }
