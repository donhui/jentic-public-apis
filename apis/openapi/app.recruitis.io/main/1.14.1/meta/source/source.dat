              "schema": {
                "type": "object",
                "properties": {
                  "referral_id": {
                    "type": "string",
                    "example": "e4rkq1im8"
                  },
                  "firstname": {
                    "type": "string",
                    "example": "Ted"
                  },
                  "lastname": {
                    "type": "string",
                    "example": "Test"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "nullable": true,
                    "example": "test@mail.cz"
                  },
                  "phone": {
                    "type": "string",
                    "example": "+420773631234"
                  },
                  "linkedin": {
                    "type": "string",
                    "nullable": true,
                    "example": "https://linkedin.com/in/ABCDXYZ"
                  },
                  "note": {
                    "type": "string",
                    "example": "note"
                  },
                  "attachments": {
                    "$ref": "#/components/schemas/Attachments"
                  }
                },
                "required": [
                  "refferal_id",
                  "firstname",
                  "lastname",
                  "email"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Candidate was recommended.",
