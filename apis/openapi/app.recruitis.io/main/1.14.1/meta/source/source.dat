      "Communication": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "integer",
            "example": 1
          },
          "employee_id": {
            "type": "integer",
            "example": 123
          },
          "author_id": {
            "type": "integer",
            "example": 123
          },
          "candidate_id": {
            "type": "integer",
            "example": 1122
          },
          "answer_id": {
            "type": "integer",
            "example": 3344
          },
          "sender": {
            "type": "string",
            "example": "Pavel"
          },
          "sender_avatar": {
            "type": "string",
            "example": "https://dev.recruitis.io/upload/initials_avatars/ff9c072d42a94d0a5112613019b54eae.png"
          },
          "recipient": {
            "type": "string",
            "example": "Ted Med"
          },
          "recipient_avatar": {
            "type": "string",
            "example": "https://dev.recruitis.io/images/5112613019b54eae.png"
          },
          "type": {
            "type": "string",
            "example": "sms"
          },
          "subject": {
            "type": "string",
            "example": "Subject..."
          },
          "content": {
            "type": "string",
            "example": "Here comes the content."
          },
          "date_created": {
            "type": "string",
            "format": "date-time",
            "example": "2022-10-27 16:35:15"
          },
          "date_of_action": {
            "type": "string",
            "format": "date-time",
            "example": "2022-10-27 16:35:00"
          },
          "html_preview": {
            "type": "string"
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "example": 32467
                },
                "path": {
                  "type": "string",
                  "example": "https://url.source.com"
                },
                "url": {
                  "type": "string",
                  "example": "https://url.source.com"
                },
                "name": {
                  "type": "string",
                  "example": "NameOfAttachment.txt"
                },
                "hash": {
                  "type": "string",
                  "example": "sfj5rJHd9fjgf4djMgoSAE"
                },
                "size": {
                  "type": "number",
                  "format": "float",
                  "example": 57.4
                },
                "size_unit": {
                  "type": "string",
                  "example": "kB"
                }
              }
            }
          }
        }
      },
      "Attachments": {
        "type": "array",
        "description": "The file size must not exceed 4MB.\n\n#### You can find all attachment types in the section [\"Additional Notes on API Calls - Attachment Types\"](#attachment-types)\n",
        "items": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "description": "The path attribute is required. Make sure the file is accessible from another domain."
                },
                "filename": {
                  "type": "string",
                  "description": "File name. Must include an extension and readable characters. Spaces will be replaced with underscores."
                },
                "type": {
                  "type": "integer"
                }
              },
              "required": [
                "path",
                "filename"
              ]
            },
            {
              "type": "object",
              "properties": {
                "base64": {
                  "type": "string",
                  "format": "byte",
                  "description": "The base64 attribute is required. File data in base64 format."
                },
                "filename": {
                  "type": "string",
                  "description": "File name. Must include an extension and readable characters. Spaces will be replaced with underscores."
                },
                "type": {
                  "type": "integer"
                }
              },
              "required": [
                "base64",
                "filename"
              ]
            }
          ]
        },
        "example": [
          {
            "path": "http://www.example.com/upload/coverLetter.pdf",
            "filename": "coverLetter.pdf",
            "type": 1
          },
          {
            "path": "http://www.example.com/upload/cv.txt",
            "filename": "cv.txt",
            "type": 2
          },
          {
            "base64": "",
            "filename": "logo.jpg",
            "type": 6
          }
        ]
      },
      "GDPR": {
        "description": "When creating a candidate without a response (for example, obtaining a candidate through a collection form to be stored in the candidate database),\nwe highly recommend attaching GDPR consent.\nOtherwise, Recruitis will not allow you to work with the candidate until consent is obtained.\nAs a parameter, you can provide a simple boolean \u2014 if set to \"true\", the consent will be added automatically,\nor you can provide an object, see the table above.\n",
        "oneOf": [
          {
            "type": "boolean"
          },
          {
            "type": "object",
            "properties": {
              "date_expiration": {
                "type": "string",
                "format": "date",
                "description": "Format YYYY-MM-DD."
              },
              "source": {
                "type": "string",
                "description": "String label indicating where the GDPR consent was obtained.",
                "default": "manual"
              }
            }
          }
        ],
        "example": {
          "date_expiration": "2022-02-22",
          "source": "manual"
        }
      },
      "Extra": {
        "type": "array",
        "description": "An array of objects that assign a note or a tag to the response.",
        "items": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "note": {
                  "type": "string",
                  "description": "If specified, the value will be stored as a note. The maximum length of a note is 800 characters.",
                  "maxLength": 800
                }
              },
              "required": [
                "note"
              ]
            },
            {
              "type": "object",
              "properties": {
                "tag": {
                  "type": "string",
                  "description": "If specified, the value will be stored as a candidate tag. The maximum length is 100 characters.",
                  "maxLength": 100
                }
              },
              "required": [
                "tag"
              ]
            },
            {
              "type": "object",
              "properties": {
                "answer_tag": {
                  "type": "string",
                  "description": "If specified, the value will be stored as a tag bound to the response. The maximum length is 100 characters.",
                  "maxLength": 100
                }
              },
              "required": [
                "answer_tag"
              ]
            },
            {
              "type": "object"
            }
          ]
        },
        "example": [
          {
            "note": "This is the text that will be stored as a note for the given candidate."
          },
          {
            "tag": "Candidates_Tag."
          },
          {
            "answer_tag": "Answer_Tag."
          }
        ]
      },
      "Referral": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
