    "/reports": {
      "get": {
        "tags": [
          "Report"
        ],
        "summary": "Export data",
        "description": "Data export from the system, an alternative to exporting reports into Excel \u2013 the data is in the same format. \nThis API is useful when using other reporting systems, such as Keboola.  \nNote: When using a large date range, the query may take a long time.  \n**We recommend filtering for specific sheets to speed up the report.**\n\nDescription of individual sheets, see the `lists` parameter:\n\n- **answers**: Contains all answers created within the given time range. \n- **jobs**: Contains all open job ads within the given time range.\n- **timeline**: Returns chronologically ordered records by individual candidates within the given time range.\n- **offices**: Returns a list of all offices. The `date_from` and `date_to` parameters do not apply to this section.\n- **personalists**: Returns a list of all recruiters. The `date_from` and `date_to` parameters do not apply to this section.\n- **personalists-answers**: Returns all answers and the recruiters who have access to them.\n- **custom-fields**: Returns all custom fields. If `AnswerID: null`, it refers to custom fields for the candidate.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.reports.read` permission.\n* Old token type:\n    * Token type: `full_access`\n    \n",
        "parameters": [
          {
            "name": "lists[]",
            "in": "query",
            "description": "Filtering of individual export groups: answers, jobs, offices, personalists-answers, personalists, timeline, custom-fields.  \nIf not specified, all groups will be selected.\n",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "date_from",
            "in": "query",
            "description": "Date from which the data should be exported. If not specified, the current day will be used.",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date_to",
            "in": "query",
            "description": "Date to which the data should be exported. If not specified, the current day will be used.",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "version",
            "in": "query",
            "description": "Report version, according to the enumeration, currently only '1'.",
            "schema": {
              "type": "integer",
              "enum": [
                1
              ]
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Report was done.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "answers": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "ID": {
                                "type": "integer"
                              },
                              "AnswerID": {
                                "type": "integer"
                              },
                              "ApplicantName": {
                                "type": "string"
                              },
                              "DateCreated": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "Source": {
                                "type": "string"
                              },
                              "AdditionalSource": {
                                "type": "string"
                              },
                              "Status": {
                                "type": "string"
                              },
                              "Rejected": {
                                "type": "integer"
                              },
                              "RejectReason": {
                                "type": "string"
                              },
                              "OfferAcceptationStatus": {
                                "type": "string"
                              },
                              "Sex": {
                                "type": "string"
                              },
                              "Nationality": {
                                "type": "string"
                              },
                              "JobID": {
                                "type": "integer"
                              },
                              "JobTitle": {
                                "type": "string"
                              },
                              "Salary": {
                                "type": "object",
                                "properties": {
                                  "Amount": {
                                    "type": "integer"
                                  },
                                  "Currency": {
                                    "type": "string"
                                  },
                                  "Unit": {
                                    "type": "string"
                                  },
                                  "Type": {
                                    "type": "string"
                                  }
                                },
                                "nullable": true
                              },
                              "HiringProposal": {
                                "type": "object",
                                "properties": {
                                  "Amount": {
                                    "type": "integer"
                                  },
                                  "Currency": {
                                    "type": "string"
                                  },
                                  "Unit": {
                                    "type": "string"
                                  },
                                  "Type": {
                                    "type": "string"
                                  }
                                },
                                "nullable": true
                              },
                              "Interviews": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "Strengths": {
