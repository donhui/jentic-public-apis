    "/referrals": {
      "post": {
        "tags": [
          "Referrals"
        ],
        "summary": "Create new referal",
        "description": "Procedure for saving a new referral. The response returns the referral ID.  \nIf the given referral already exists, the server returns header status `409`.\n\n#### Important information:\n**When testing a POST request on the production server: the default token points to a test account \nthat is accessible to other users. Do not send your personal data through this token, \nor change the token to your own.**\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.referral.write` permission.\n* Old token type:\n    * Token type: `full_access`\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Jan Novak",
                    "description": "Referral name."
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "jan@Novak.net",
                    "description": "Referral email."
                  },
                  "phone": {
                    "type": "string",
                    "example": "+420773631234",
                    "description": "Referral phone number."
                  },
                  "external_id": {
                    "type": "string",
                    "example": "9D97W5-75D2"
                  },
                  "email_text": {
                    "type": "string",
                    "example": "contents of the email",
                    "description": "If specified, this email will be sent directly to the given address when the referral is created.\nVariables are also supported, see the email templates in Recruitis.\n"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Referral was created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "31gsshd"
                        },
                        "public_id": {
                          "type": "string",
                          "example": "1dhfhdf5jjdjd65shjs"
                        },
                        "url": {
                          "type": "string",
                          "example": "https://app.recruitis.io/referral/1dhfhdf5jjdjd65shjs"
                        },
                        "name": {
                          "type": "string",
                          "example": "Jan Novak"
                        },
                        "email": {
                          "type": "string",
                          "format": "email",
                          "example": "jan@Novak.net"
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.created"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 70
                        },
                        "message": {
                          "type": "string",
                          "example": "Referral was created."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "This referral already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 12345
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.error.referral.already_created"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 70
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 150
                        },
                        "message": {
                          "type": "string",
                          "example": "This referral already exists."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Referrals"
        ],
        "summary": "Get referral list",
        "description": "This call returns all referrals associated with the given company. \nPagination applies to the listing, with a maximum of 100 entities per page.  \nIf no referral matches the filter (or the company has no referrals), \nthe system returns header status `200` with `meta.code` `api.response.null`.\n\nIt is also currently possible to explicitly specify which parameter you want to search in. \nFor this method, you can use search in JSON format, where the parameter name matches the referral parameter.\n\nPossible options:\n* {\"external_id\" : \"9D96W3-66D2\"}\n* {\"external_id\" : \"9D96W3-66D2\",\"name\":\"Pepa\",\"email\":\"xx@xxx.com\"} (external_id = 9D96W3-66D2 OR name = Pepa OR email = xx....)\n* {\"phone\" : \"+420773631234\"}\n* \"pavel novak\" \u2013 searches everywhere.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.referral.read` permission.\n* Old token type:\n    * Token type: `full_access`\n",
        "parameters": [
          {
            "name": "id[]",
            "in": "query",
            "description": "Referral ID, or the referral `access_id`. The ID can also be provided as an array.  \nNote: do not combine referral ID and referral `access_id`.\n",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "The maximum number of entities the server should return. The maximum limit is 100.\n",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100,
              "minimum": 0
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page with entities.",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Returns referrals with the given name or email.\n",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "string",
                      "example": "Pepa Novak"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "external_id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "email": {
                          "type": "string"
                        },
                        "phone": {
                          "type": "string"
                        }
                      }
                    }
                  ],
                  "example": {
                    "external_id": "356GR46-86D8",
                    "name": "Pepa Novak",
                    "email": "pepa@zdepa.cz",
                    "phone": "+420773631234"
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "payload": {
                          "type": "object",
                          "nullable": true,
                          "example": null
                        },
                        "meta": {
                          "type": "object",
                          "properties": {
                            "code": {
                              "type": "string",
                              "example": "api.response.null"
                            },
                            "duration": {
                              "type": "integer",
                              "example": 3542
                            },
                            "message": {
                              "type": "string",
                              "example": "Referrals were not found."
                            },
                            "entries_from": {
                              "type": "integer",
                              "example": 2
                            },
                            "entries_to": {
                              "type": "integer",
                              "example": 17
                            },
                            "entries_total": {
                              "type": "integer",
                              "example": 0
                            },
                            "entries_sum": {
                              "type": "integer",
                              "example": 0
                            }
                          }
                        }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "payload": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Referral"
                          }
                        },
                        "meta": {
                          "type": "object",
                          "properties": {
                            "code": {
                              "type": "string",
                              "example": "api.found"
                            },
                            "duration": {
                              "type": "integer",
                              "example": 92
                            },
                            "message": {
                              "type": "string",
                              "example": "Referrals were returned."
                            },
                            "entries_from": {
                              "type": "integer",
                              "example": 1
                            },
                            "entries_to": {
                              "type": "integer",
                              "example": 100
                            },
                            "entries_total": {
                              "type": "integer",
                              "example": 7
                            },
                            "entries_sum": {
                              "type": "integer",
                              "example": 7
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          }
        }
      }
    },
    "/referrals/{id}": {
      "get": {
        "tags": [
          "Referrals"
        ],
        "summary": "Get referral",
        "description": "Returns a specific referral. If a single ID is provided and not passed as an array in GET parameters, \nit will be returned as a single entity, i.e., the payload will not contain an array.  \nIf the given referral does not exist, a `404` response is returned. \n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.referral.read` permission.\n* Old token type:\n    * Token type: `full_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Referral was found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "$ref": "#/components/schemas/Referral"
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.found"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 92
                        },
                        "message": {
                          "type": "string",
                          "example": "Referral is returned."
                        },
                        "entries_from": {
                          "type": "integer",
                          "example": 1
                        },
                        "entries_to": {
                          "type": "integer",
                          "example": 100
                        },
                        "entries_total": {
                          "type": "integer",
                          "example": 7
                        },
                        "entries_sum": {
                          "type": "integer",
                          "example": 7
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          }
        }
      }
    },
