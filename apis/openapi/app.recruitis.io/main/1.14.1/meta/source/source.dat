    "/jobs/{id}/access_state/{state}": {
      "put": {
        "tags": [
          "Jobs"
        ],
        "summary": "Change job access state",
        "description": "Change access to a position. This includes closing, opening, and archiving positions. \nMore details are described in the [access_state](#parameter-access_state) parameter.\n\nFor correct functionality, the position for which you set `access_state` must be published \nin the Recruitis ATS (i.e., not just in draft).\n\nIf you create a position via the API (see [Create new job](#tag/Jobs/paths/~1jobs/post)), \nit must always be completed and published in the ATS Recruitis UI before calling other actions through the API.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n  * The token must have the `api.position.write` permission.\n* Old token type:\n  * Token type: `full_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer",
              "example": 363098
            },
            "required": true
          },
          {
            "name": "state",
            "in": "path",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2,
                3,
                4,
                5
              ]
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Succesfully changed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 363098
                        },
                        "accessState": {
                          "type": "integer",
                          "example": 2
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.updated"
                        },
                        "duration": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string",
                          "example": "Job access was changed into closed state."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          }
        }
      }
    },
    "/jobs/{id}/access": {
      "put": {
        "tags": [
          "Jobs"
        ],
        "summary": "Add new visit count",
        "description": "The endpoint increments the job advertisement view count. Thanks to this, Recruitis can track \nhow many times the job ad was displayed, for example, on your intranet pages.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.position.write` permission.\n* Old token types:\n    * Token type: `public_access`, `full_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "referral": {
                    "type": "string",
                    "description": "Referral ID to which the job advertisement view will be added.",
                    "example": "e4rkq1im"
                  },
                  "ip": {
                    "type": "string",
                    "description": "IP address, which visited the job advertisement.",
                    "example": "192.168.0.1"
                  },
                  "useragent": {
                    "type": "string",
                    "example": "Mozzila/5.0"
                  },
                  "token": {
                    "type": "string",
                    "description": "A random hash that is generated once, then stored in a site cookie and always sent along with the other information.",
                    "example": "MjOshDciF3Gr46qI9K0wAeeEt7OqVBCkjHk9yQZT5zE"
                  },
                  "referer": {
                    "type": "string",
                    "description": "URL address from which the visitor came.",
                    "example": "https://facebook.com"
                  }
                },
                "required": [
                  "ip",
                  "token"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job ad was marked.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 200
                        },
                        "code": {
                          "type": "string",
                          "example": "api.ok"
                        },
                        "message": {
                          "type": "string",
                          "example": "Job ad access marked."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          }
        }
      }
    },
