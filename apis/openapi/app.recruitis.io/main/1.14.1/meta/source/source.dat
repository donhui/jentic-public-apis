    "responses": {
      "Response401": {
        "description": "Authorization error.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "payload": {
                  "type": "object",
                  "nullable": true,
                  "example": null
                },
                "meta": {
                  "type": "object",
                  "properties": {
                    "duration": {
                      "type": "integer",
                      "example": 30
                    },
                    "code": {
                      "type": "string",
                      "example": "api.error.unauthorized"
                    },
                    "message": {
                      "type": "string",
                      "example": "Bearer authorization failed."
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Response400": {
        "description": "Cannot be done.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "payload": {
                  "type": "object",
                  "nullable": true,
                  "example": null
                },
                "meta": {
                  "type": "object",
                  "properties": {
                    "duration": {
                      "type": "integer",
                      "example": 60
                    },
                    "total_duration": {
                      "type": "integer",
                      "example": 150
                    },
                    "code": {
                      "type": "string",
                      "example": "api.error.generic"
                    },
                    "message": {
                      "type": "string",
                      "example": "Cannot be done."
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Response404": {
        "description": "Not found.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "payload": {
                  "type": "object",
                  "nullable": true,
                  "example": null
                },
                "meta": {
                  "type": "object",
                  "properties": {
                    "duration": {
                      "type": "integer"
                    },
                    "code": {
                      "type": "string",
                      "example": "api.error.not_found"
                    },
                    "message": {
                      "type": "string",
                      "example": "Does not exist."
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Response403": {
        "description": "Quota exceeded.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "payload": {
                  "type": "object",
                  "nullable": true,
                  "example": null
                },
                "meta": {
                  "type": "object",
                  "properties": {
                    "duration": {
                      "type": "integer",
                      "example": 60
                    },
                    "total_duration": {
                      "type": "integer",
                      "example": 150
                    },
                    "code": {
                      "type": "string",
                      "example": "api.error.quota.exceeded"
                    },
                    "message": {
                      "type": "string",
                      "example": "Daily quota has been exceeded."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}