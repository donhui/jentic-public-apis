      "post": {
        "tags": [
          "Calendar"
        ],
        "summary": "Share reservation link to candidate",
        "description": "This call shares a reservation link for a meeting with the candidate.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reservation_link_id": {
                    "type": "integer",
                    "example": 24
                  },
                  "answer_id": {
                    "type": "integer",
                    "example": 3512
                  }
                },
                "required": [
                  "reservation_link_id",
                  "answer_id"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The reservation link was created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "event": {
                          "type": "string",
                          "nullable": true,
                          "example": null
                        },
                        "reservation_link": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "integer",
                              "example": 335
                            },
                            "reservation_link_id": {
                              "type": "integer",
                              "example": 24
                            },
                            "url": {
                              "type": "string",
                              "example": "https://app.recruitis.io/meetings/oprhzuzmff/introductory-meeting"
                            }
                          }
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 60
                        },
                        "code": {
                          "type": "string",
                          "example": "api.created"
                        },
                        "message": {
                          "type": "string",
                          "example": "Reservation link was created."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Response400"
          }
        }
      }
    },
