    "/checklists/{answer_id}/item/{item_id}/state": {
      "put": {
        "tags": [
          "Checklists"
        ],
        "summary": "Update item state",
        "description": "Change the status of a specific checklist item for the given answer.  \nThe `flowId` parameter in the request body specifies in which flow the status should be changed. \nIf it is not provided, the current flow in which the answer is located will be used.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Not compatible with the company token.\n",
        "parameters": [
          {
            "name": "answer_id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          },
          {
            "name": "item_id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "state": {
                    "type": "integer",
                    "enum": [
                      1,
                      2,
                      3
                    ],
                    "description": "Status code list:\n1 = UNCHECKED\n2 = CHECKED\n3 = REJECTED\n",
                    "example": 1
                  },
                  "flowId": {
                    "type": "integer"
                  }
                },
                "required": [
                  "state"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The checklist item status has been saved.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 17
                        },
                        "title_recruiter": {
                          "type": "string",
                          "example": "Check candidate mail"
                        },
                        "title_candidate": {
                          "type": "string",
                          "example": "Check name"
                        },
                        "sort": {
                          "type": "integer",
                          "example": 0
                        },
                        "text": {
                          "type": "string",
                          "example": "Check name"
                        },
                        "state": {
                          "type": "integer",
                          "example": 3
                        },
                        "flowState": {
                          "type": "integer",
                          "example": 2
                        },
                        "author": {
                          "type": "string",
                          "example": "Tester Cypress"
                        },
                        "date": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2023-02-22 17:45:15"
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.modified"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 210
                        },
                        "message": {
                          "type": "string",
                          "example": "Checklist item status saved."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          }
        }
      }
    },
    "/calendar/reservation-links": {
      "get": {
        "tags": [
          "Calendar"
        ],
        "summary": "Get reservation links",
        "description": "This request returns all available reservation link templates.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n",
        "responses": {
          "200": {
            "description": "The reservation links were found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "example": 101
                          },
                          "title": {
                            "type": "string",
                            "example": "Introductory meeting"
                          },
                          "description": {
                            "type": "string",
                            "example": "Please select from the offered time slots in the recruiter\u2019s calendar the one that suits you best."
                          },
                          "type": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "enum": [
                                "personal",
                                "google",
                                "outlook",
                                "phone-call"
                              ]
                            },
                            "example": [
                              "personal",
                              "google"
                            ]
                          },
                          "system_name": {
                            "type": "string",
                            "enum": [
                              "imp",
                              "uvn",
                              "snps",
                              "todvp"
                            ],
                            "nullable": true,
                            "example": null
                          },
                          "address": {
                            "type": "object",
                            "description": "Only if the type 'personal' is available",
                            "properties": {
                              "street": {
                                "type": "string",
                                "nullable": true,
                                "example": "Tylova 123"
                              },
                              "city": {
                                "type": "string",
                                "nullable": true,
                                "example": "Hradec Kralove"
                              },
                              "region": {
