                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.created"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 354
                        },
                        "message": {
