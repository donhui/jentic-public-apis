    "/answers/{answer_id}": {
      "get": {
        "tags": [
          "Candidates"
        ],
        "summary": "Get answer",
        "description": "This request returns a specific answer. Compared to the list of answers, the payload is not an array,\nbut directly a specific answer object with a slightly different (more detailed) structure.  \nIf the request does not find the specific answer, it returns HTTP status `404` with meta code `api.error.not_found`.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.candidates.read` permission.\n* Original token type:\n    * Token type: `full_access`: Working with the list of answers requires a `full_access` token.\n",
        "parameters": [
          {
            "name": "answer_id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          },
          {
            "name": "view",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "basic",
                "extended"
              ],
              "default": "basic"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Answer was found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "candidate_id": {
                          "type": "integer",
                          "description": "Candidate's ID to which the answer is assigned.",
                          "example": 507642
                        },
