    "/calendar/reservation-links/{id}": {
      "delete": {
        "tags": [
          "Calendar"
        ],
        "summary": "Delete reservation link",
        "description": "This call deletes the reservation link only if the request `GET /calendar/interviews/{answer_id}` \nreturns `\"event\": null` for the requested `id` (the sub-attribute `id` within the attribute `reservation_link`).\nOtherwise, the server will return `409 Conflict`.\n\nThe reservation link can only be deleted if the logged-in user is the owner of this link.\n\n#### Requirements\n\n* The call must include an authorization token.\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer",
              "example": 101
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "The reservation link was deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "string",
                      "example": 101
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.modified"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 121
                        },
                        "message": {
                          "type": "string",
                          "example": "Reservation link deleted."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Cannot delete the reservation link.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "nullable": true,
                      "example": null
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer"
                        },
                        "code": {
                          "type": "string",
                          "example": "api.error.forbidden"
                        },
                        "message": {
                          "type": "string",
                          "example": "Reservation link has confirmed event."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
