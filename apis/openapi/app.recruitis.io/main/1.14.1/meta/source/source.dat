  "components": {
    "requestBodies": {
      "JobFilter": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Filter name.",
                  "example": "Pediatrie"
                },
                "group": {
                  "type": "string",
                  "description": "Name of the group to which the filter is automatically assigned.",
                  "example": "department"
                }
              },
              "required": [
                "name",
                "group"
              ]
            }
          }
        }
      }
    },
    "securitySchemes": {
      "auth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Employee": {
        "type": "object",
        "nullable": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "surname": {
            "type": "string",
            "nullable": true
          },
          "initials": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "photo_url": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "linkedin": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "initials": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "employee": {
            "$ref": "#/components/schemas/Employee"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "office_id": {
            "type": "integer"
          },
          "city": {
            "type": "string"
          },
          "postcode": {
            "type": "string"
          },
          "street": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "is_primary": {
            "type": "boolean"
          }
        }
      },
      "Automation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "event_name": {
            "type": "string"
          },
          "event_params": {
            "type": "object",
            "properties": {
              "offerId": {
                "type": "integer"
              },
              "flowId": {
                "type": "integer"
              }
            }
          },
          "pipeline": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "field": {
                        "type": "string"
                      },
                      "operator": {
                        "type": "string"
                      },
                      "value": {
                        "type": "integer"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "employeeIds": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "message": {
                        "type": "string"
                      }
                    }
                  }
                ]
              }
            }
          },
          "stopped": {
            "type": "boolean"
          },
          "author_id": {
            "type": "integer"
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "job_id": {
            "type": "integer",
            "description": "Job advertisement ID."
          },
          "secured_id": {
            "type": "string"
          },
          "public_id": {
            "type": "string",
            "description": "Internal identifier of the job advertisement. It may not be filled.",
            "nullable": true
          },
          "access_state": {
            "type": "integer",
            "description": "Indicates the type of position. See the access_state parameter.",
            "enum": [
              1,
              2,
              3,
              4,
              5
            ]
          },
          "draft": {
            "type": "boolean",
            "description": "Indicates whether the job advertisement is published or only in draft."
          },
          "active": {
            "type": "boolean",
