                                    "example": "test@test.test"
                                  },
                                  "job_contact_phone": {
                                    "type": "string",
                                    "description": "Contact person's phone number.",
                                    "example": "+420773631234"
                                  }
                                }
                              },
                              "answer_created": {
                                "type": "string",
                                "format": "date-time",
                                "description": "Date of the answer creation, in format YYYY-mm-dd HH:mm:ss",
                                "example": "2022-09-12 14:38:04"
                              },
                              "source": {
                                "type": "object",
                                "properties": {
                                  "name": {
                                    "type": "string",
                                    "description": "Source name to which the answer is assigned.",
                                    "example": "personal"
                                  },
                                  "type": {
                                    "type": "string",
                                    "description": "Source type. System email, api,...",
                                    "example": "Manually added"
