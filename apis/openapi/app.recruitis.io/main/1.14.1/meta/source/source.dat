    "/jobs/{id}/form": {
      "get": {
        "summary": "Load a job answer form",
        "description": "Load of a job answer form for the given job ad.",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Answer form was found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "type": "string",
                          "example": "Answer form template"
                        },
                        "attributes": {
                          "type": "array",
                          "description": "Array of HTML attributes.",
                          "items": {
                            "properties": {
                              "name": {
                                "type": "string"
                              },
                              "value": {
                                "type": "string"
                              }
                            }
                          },
                          "example": []
                        },
                        "fields": {
                          "type": "array",
                          "description": "Field of HTML inputs for form.",
                          "items": {
                            "properties": {
                              "name": {
                                "type": "string",
                                "description": "`name` attribute value."
                              },
                              "type": {
                                "type": "string",
                                "description": "Value of the HTML type attribute.\nIf the value is \"select\", it\u2019s a select box (dropdown); if \"select:m\", it\u2019s a multi-select dropdown.\nIf the value is \"textarea\", it\u2019s a text area.\nemail and url are HTML5 inputs that provide built-in validation; otherwise, you can replace them with text.\n",
                                "enum": [
                                  "text",
                                  "textarea",
                                  "date",
                                  "file",
                                  "hidden",
                                  "select",
                                  "select:m",
                                  "checkbox",
                                  "email",
                                  "url"
                                ]
                              },
                              "label": {
                                "type": "string",
                                "description": "HTML input label."
                              },
                              "value": {
                                "type": "string",
                                "nullable": true,
                                "description": "Input default. Always as a single value."
                              },
                              "inputOptions": {
                                "type": "object",
                                "nullable": true,
                                "description": "Additional HTML input attributes, which may include predefined data attributes. Multidimensional array/object.\nFor example, [data => [cf => date]] must be transformed into data-cf=date.\n"
                              },
                              "required": {
                                "type": "boolean",
                                "description": "Specifies whether the input is required."
                              },
                              "hidden": {
                                "type": "boolean",
                                "description": "Specifies whether the element is hidden."
                              },
                              "options": {
                                "type": "object",
                                "nullable": true,
                                "description": "An object with values for the select box, i.e., individual options, in the format label => value.\n"
                              },
                              "order": {
                                "type": "integer",
                                "description": "The order of the input in the form."
                              }
                            }
                          },
                          "example": [
                            {
                              "name": "name",
                              "type": "text",
                              "label": "Name and surname",
                              "value": null,
                              "inputOptions": {},
                              "required": true,
                              "hidden": false,
                              "options": null,
                              "order": 0
                            },
                            {
                              "name": "employment_date",
                              "type": "date",
                              "label": "Employment date",
                              "value": null,
                              "inputOptions": {
                                "data": {
                                  "cf": "date"
                                }
                              },
                              "required": true,
                              "hidden": false,
                              "options": null,
                              "order": 1
                            },
                            {
                              "name": "email",
                              "type": "text",
                              "label": "E-mail",
                              "value": null,
                              "inputOptions": {},
                              "required": true,
                              "hidden": false,
                              "options": null,
                              "order": 2
                            },
                            {
                              "name": "offer_id",
                              "type": "hidden",
                              "label": "Job advert",
                              "value": 123456,
                              "required": true,
                              "hidden": true,
                              "options": null,
                              "order": 998
                            }
                          ]
                        },
                        "gdpr": {
                          "type": "array",
                          "description": "Array of GDPR consents.\nType = 1 is an informational obligation \u2014 such consent must be displayed to the candidate, ideally at the beginning of the form.\nType = 2 must be rendered as checkboxes and submitted for validation.\nThe \"text_short\" attribute is recommended to be displayed as the checkbox label, while \"text_long\" can be collapsible/expandable.\n",
                          "items": {
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "title": {
                                "type": "string"
                              },
                              "text_short": {
                                "type": "string"
                              },
                              "text_long": {
                                "type": "string"
                              },
                              "type": {
                                "type": "integer",
                                "enum": [
                                  1,
                                  2
                                ]
                              },
                              "source": {
                                "type": "string"
                              }
                            }
                          },
                          "example": [
                            {
                              "id": 33,
                              "title": "agreement t-kariera",
                              "text_short": "Replace your notebooks and printed documents",
                              "text_long": "Replace your notebooks and printed documents with the only tablet that feels like paper.",
                              "type": 1,
                              "source": "pracevcr.cz"
                            }
                          ]
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.found"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 356
                        },
                        "message": {
                          "type": "string",
                          "example": "Job answer form found."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          },
          "500": {
            "description": "Unexpected error."
          }
        }
      }
    },
    "/jobs/{id}/form/validate": {
      "post": {
        "summary": "Validate a job answer form",
        "description": "Validation of a job answer form.",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "header",
            "name": "Accept-Language",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "cs",
                "sk",
                "en",
                "de",
                "ro",
                "bg",
                "hu",
                "pl"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Values from the answer form in the format field => value.\nSince this is a JSON API, not a multipart form, attachments (CVs) must be sent as an array of objects according to the schema.\n",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Ted Test"
                  },
                  "email": {
                    "type": "string",
                    "example": "testAPI@email.cz"
                  },
                  "offer_id": {
                    "type": "integer",
                    "example": 123456
                  },
                  "referral_id": {
                    "type": "string",
                    "example": null
                  },
                  "source_id": {
                    "type": "integer",
                    "example": 1041
                  },
                  "linkedin": {
                    "type": "string",
                    "example": "https://linkedin.com/in/ABCDXYZ"
                  },
                  "cv": {
                    "type": "array",
                    "items": {
                      "description": "The required field is filename. If you do not send either base64 or path, these must be provided after validation before sending to POST /answers.\n",
                      "properties": {
                        "filename": {
                          "type": "string",
                          "example": "codeception.txt"
                        },
                        "base64": {
                          "type": "string",
                          "nullable": true,
                          "example": null,
                          "description": "Base64-encoded file content. To reduce data transfer, it is not necessary to send it for validation.\nIn that case, it must be attached to the given object after receiving the validation response.\n"
                        },
                        "path": {
                          "type": "string",
                          "nullable": true,
                          "example": null,
                          "description": "Public location (URL address) of the file from which Recruitis can download it.\nThe data load during validation is minimal, but the same rules apply to this attribute as for base64.\n"
                        }
                      }
                    }
                  },
                  "gdpr_34": {
                    "description": "This refers to a custom gdpr_agreement. The ID (the number after the \u201c_\u201d) may vary.",
                    "type": "boolean",
                    "example": true
                  },
                  "salary": {
                    "type": "integer",
                    "example": 30000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The form is valid.\nThe validated object, which is accepted by the POST /answers endpoint, is located in the \"payload\".\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "job_id": {
                          "type": "integer",
                          "example": 123456
                        },
                        "name": {
                          "type": "string",
                          "example": "Ted Test"
                        },
                        "email": {
                          "type": "string",
                          "format": "email",
                          "nullable": true,
                          "example": "testAPI@email.cz"
                        },
                        "linkedin": {
                          "type": "string",
                          "nullable": true,
                          "example": "https://linkedin.com/in/ABCDXYZ"
                        },
                        "phone": {
                          "type": "string",
                          "example": "+420773631234"
                        },
                        "source_id": {
                          "type": "integer",
                          "example": 1041
                        },
                        "refferal_id": {
                          "type": "integer",
                          "example": null
                        },
                        "employment_date": {
                          "type": "string",
                          "format": "date",
                          "example": "2023-07-14"
                        },
                        "extra_agreements": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "example": 34
                              }
                            }
                          }
                        },
                        "send_notification": {
                          "type": "boolean",
                          "example": true
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.ok"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 356
                        },
                        "message": {
                          "type": "string",
                          "example": "Form is valid."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Job ad was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "nullable": true,
                      "description": "In the case of a non-OK HTTP status, it is always null."
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer"
                        },
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        },
                        "additional_output": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "message": {
                                "type": "string",
                                "description": "Error message in case of failed validation."
                              },
                              "status": {
                                "type": "string",
                                "enum": [
                                  "OK",
                                  "DEBUG",
                                  "WARNING",
                                  "ERROR",
                                  "INFO"
                                ],
                                "description": "Always ERROR in case of failed validation."
                              },
                              "code": {
                                "type": "string",
                                "description": "Name of the form element (input.name)."
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Entity does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "nullable": true,
                      "description": "In the case of a non-OK HTTP status, it is always null."
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer"
                        },
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string",
                          "description": "Error description."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "nullable": true,
                      "description": "In the case of a non-OK HTTP status, it is always null."
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer"
                        },
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string",
                          "description": "Error description."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/candidates": {
      "post": {
        "tags": [
          "Candidates"
        ],
        "summary": "Create new candidate",
        "description": "Procedure for saving a new candidate. The candidate ID is returned as the result. \nCreating a candidate without an answer is useful, for example, if you want to allow a candidate to contact you \nbut currently have no suitable job advertisement for them. \n\nIf a candidate is inserted who already exists in the system based on their email or phone number, \ntheir information is updated and the corresponding user ID is returned. \nYou are informed about this via the meta field `additional_output`.\n\n#### Important information:\n**When testing a POST request on the production server: The default token points to a test account \nthat is accessible to other users as well. Do not send your personal data through this token; \nalternatively, replace the token with your own.**\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.candidates.write` permission.\n* Old token types:\n    * Token type: `public_access`\n\n#### GDPR when adding a candidate\nWhen creating a candidate without an answer (for example, obtaining a candidate via a collection form \nto be stored in the candidate database), we highly recommend attaching GDPR consent. \nOtherwise, Recruitis will not allow you to work with the candidate until consent is obtained. \nAs a parameter, you can provide a simple boolean \u2014 if set to \"true\", the consent will be added automatically \u2014 \nor you can provide an object, see the table above.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Ted Test"
                  },
                  "email": {
                    "type": "string",
                    "description": "Candidates are merged based on email.",
                    "format": "email",
                    "nullable": true,
                    "example": "testAPI@email.cz"
                  },
                  "www": {
                    "type": "string",
                    "nullable": true,
                    "description": "Link to the candidate's web. **MUST contain http:// or https://**",
                    "example": "https://www.webpage.com/candidate"
                  },
                  "skype": {
                    "type": "string",
                    "nullable": true,
                    "example": "https://www.skype.com/recruitisio"
                  },
                  "linkedin": {
                    "type": "string",
                    "nullable": true,
                    "example": "https://linkedin.com/in/ABCDXYZ"
                  },
                  "facebook": {
                    "type": "string",
                    "nullable": true,
                    "example": "https://www.facebook.com/recruitis.io"
                  },
                  "twitter": {
                    "type": "string",
                    "nullable": true,
                    "example": "https://twitter.com/recruitisio"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Candidates are merged based on phone number.",
                    "example": "+420773631234"
                  },
                  "strict": {
                    "type": "boolean",
                    "description": "If set to the value 1, the entire process will stop and an error will be returned if the attachment upload fails.\nOtherwise, the candidate will be saved with information that not everything was uploaded correctly (see [Meta - additional output](#meta-information---additional_output)).\n",
                    "default": false
                  },
                  "im_author": {
                    "type": "boolean",
                    "description": "If set to true, the given recruiter is designated as the author of the answer, including notes. Otherwise, the notes will have no author and will be considered system notes.\n",
                    "default": false
                  },
                  "gdpr_agreement": {
                    "$ref": "#/components/schemas/GDPR"
                  },
                  "extra": {
                    "$ref": "#/components/schemas/Extra"
                  },
                  "attachments": {
                    "$ref": "#/components/schemas/Attachments"
                  }
                },
                "required": [
                  "name",
                  "gdpr_agreement"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Candidate was created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 2384
                        },
                        "email": {
                          "type": "string",
                          "example": "testAPI@email.cz",
                          "nullable": true
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 60
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 150
                        },
                        "code": {
                          "type": "string",
                          "example": "api.created"
                        },
                        "message": {
                          "type": "string",
                          "example": "Candidate was created."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Response400"
          }
        }
      }
    },
    "/candidates/{id}": {
      "delete": {
        "tags": [
          "Candidates"
        ],
        "summary": "Delete candidate",
        "description": "This call completely deletes the given candidate and all information associated with them. \nAll their answers, interviews, notes, attachments, GDPR consents, etc. \n**A candidate deleted in this way cannot be restored in any way.**\n\nThis call is subject to a daily quota. If the daily quota is exceeded, \nthe response will be `403 - forbidden` with `meta.code` `api.error.quota.exceeded`.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Token type: `full_access`\n* New token type:\n    * The token must have the `api.candidates.write` permission.\n* Old token type:\n    * Token type: `public_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Candidate deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "nullable": true
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 60
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 150
                        },
                        "code": {
                          "type": "string",
                          "example": "api.deleted"
                        },
                        "message": {
                          "type": "string",
                          "example": "Candidate was deleted."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Response403"
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          }
        }
      }
    },
    "/candidates/{id}/{answer_id}/communication": {
      "get": {
        "tags": [
          "Candidates"
        ],
        "summary": "List candidate communication",
        "description": "Listing of communication with the candidate. Displays communication linked to the given answer.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.candidates.read` permission.\n* Old token type:\n    * Token type: `public_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          },
          {
            "name": "answer_id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "linkedin",
                "email",
                "sms",
                "note"
              ]
            }
          },
          {
            "name": "sender_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "candidate",
                "employee",
                "system",
                "other"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 10
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 1
            }
          },
          {
            "name": "author_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Communication found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Communication"
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.found"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 3542
                        },
                        "message": {
                          "type": "string",
                          "example": "Candidate communication was found."
                        },
                        "entries_from": {
                          "type": "integer",
                          "example": 2
                        },
                        "entries_to": {
                          "type": "integer",
                          "example": 17
                        },
                        "entries_total": {
                          "type": "integer",
                          "example": 4
                        },
                        "entries_sum": {
                          "type": "integer",
                          "example": 4
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          }
        }
      },
      "post": {
        "tags": [
          "Candidates"
        ],
        "summary": "Create new communication record",
        "description": "Creating a new communication record (message) with the client.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Token type: `full_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          },
          {
            "name": "answer_id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "employee_id": {
                    "type": "integer",
                    "description": "ID of an employee, who sends the message.",
                    "example": 123
                  },
                  "author_id": {
                    "type": "integer",
                    "description": "User ID \u2014 fill in if the author is a different user than the one sending the message. If not provided, employee_id will be used.\n",
                    "example": 456
                  },
                  "sender": {
                    "type": "string",
                    "description": "Text representation of the sender (name, email, phone number (SMS)). If not provided, the data linked to author_id will be used.\n",
                    "example": "Pavel"
                  },
                  "sender_type": {
                    "type": "string",
                    "enum": [
                      "candidate",
                      "employee",
                      "system",
                      "other"
                    ],
                    "description": "Indicates who the communication comes from. Allowed values: candidate, employee, system, other\n",
                    "example": "employee"
                  },
                  "recipient": {
                    "type": "string",
                    "description": "Dtto. sender",
                    "example": "Ted"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Message subject.",
                    "example": "..Message subject.."
                  },
                  "content": {
                    "type": "string",
                    "description": "Message content.",
                    "example": "...Message content..."
                  },
                  "direction": {
                    "type": "string",
                    "description": "One of the values: in = incoming, out = outgoing, linked to the candidate/answer. That is, incoming to the candidate and outgoing from the candidate.\n",
                    "enum": [
                      "in",
                      "out"
                    ],
                    "example": "in"
                  },
                  "date_action": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Date of the communication creation.",
                    "example": "2022-02-22 17:45:15"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "linkedin",
                      "call",
                      "email",
                      "sysemail",
                      "sms",
                      "note"
                    ]
                  },
                  "strict": {
                    "type": "boolean",
                    "default": true,
                    "description": "Specifies the upload behavior in case of an error: if set to 1, then either everything is saved or nothing. If set to 0, the meta tag will contain information about unsaved attachments.\n"
                  },
                  "attachments": {
                    "$ref": "#/components/schemas/Attachments"
                  }
                },
                "required": [
                  "employee_id",
                  "subject",
                  "content",
                  "direction",
                  "sender_type",
                  "type"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Communication record was created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 2384
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 60
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 150
                        },
                        "code": {
                          "type": "string",
                          "example": "api.created"
                        },
                        "message": {
                          "type": "string",
                          "example": "Communication record was created."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Response400"
          }
        }
      }
    },
    "/candidates/{id}/communication": {
      "get": {
        "tags": [
          "Candidates"
        ],
        "summary": "List candidate communication",
        "description": "Listing of communication with the candidate. Displays communication linked directly to the candidate.\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.candidates.read` permission.\n* Old token type:\n    * Token type: `public_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "linkedin",
                "email",
                "sms",
                "note"
              ]
            }
          },
          {
            "name": "sender_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "candidate",
                "employee",
                "system",
                "other"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "example": 10
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "example": 1
          },
          {
            "name": "author_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Communication found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Communication"
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "example": "api.found"
                        },
                        "duration": {
                          "type": "integer",
                          "example": 3542
                        },
                        "message": {
                          "type": "string",
                          "example": "Candidate communication found."
                        },
                        "entries_from": {
                          "type": "integer",
                          "example": 2
                        },
                        "entries_to": {
                          "type": "integer",
                          "example": 17
                        },
                        "entries_total": {
                          "type": "integer",
                          "example": 4
                        },
                        "entries_sum": {
                          "type": "integer",
                          "example": 4
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Response401"
          }
        }
      },
      "post": {
        "tags": [
          "Candidates"
        ],
        "summary": "Create new communication record",
        "description": "Creating a new communication record (message) with the client.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Token type: `full_access`\n",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "employee_id": {
                    "type": "integer",
                    "description": "ID of an employee, who sends the message.",
                    "example": 123
                  },
                  "author_id": {
                    "type": "integer",
                    "description": "User ID \u2014 fill in if the author is a different user than the one sending the message. If not provided, employee_id will be used.\n",
                    "example": 456
                  },
                  "sender": {
                    "type": "string",
                    "description": "Text representation of the sender (name, email, phone number (SMS)). If not provided, the data linked to author_id will be used.\n",
                    "example": "Pavel"
                  },
                  "sender_type": {
                    "type": "string",
                    "enum": [
                      "candidate",
                      "employee",
                      "system",
                      "other"
                    ],
                    "description": "Indicates who the communication comes from. Allowed values: candidate, employee, system, other\n",
                    "example": "employee"
                  },
                  "recipient": {
                    "type": "string",
                    "description": "viz. parametr `sender`",
                    "example": "Ted"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Message subject.",
                    "example": "..Message subject.."
                  },
                  "content": {
                    "type": "string",
                    "description": "Message content.",
                    "example": "...Message content..."
                  },
                  "direction": {
                    "type": "string",
                    "description": "One of the values: in = incoming, out = outgoing, linked to the candidate/answer. That is, incoming to the candidate and outgoing from the candidate.\n",
                    "enum": [
                      "in",
                      "out"
                    ],
                    "example": "in"
                  },
                  "date_action": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Date of the communication creation.",
                    "example": "2022-02-22 17:45:15"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "linkedin",
                      "call",
                      "email",
                      "sysemail",
                      "sms",
                      "note"
                    ]
                  },
                  "strict": {
                    "type": "boolean",
                    "default": true,
                    "description": "Specifies the upload behavior in case of an error: if set to 1, then either everything is saved or nothing. If set to 0, the meta tag will contain information about unsaved attachments.\n"
                  },
                  "attachments": {
                    "$ref": "#/components/schemas/Attachments"
                  }
                },
                "required": [
                  "employee_id",
                  "subject",
                  "content",
                  "direction",
                  "sender_type",
                  "type"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Communication record was created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 2384
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 60
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 150
                        },
                        "code": {
                          "type": "string",
                          "example": "api.created"
                        },
                        "message": {
                          "type": "string",
                          "example": "Communication record was created."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Response400"
          }
        }
      }
    },
    "/candidates/form/{id}": {
      "get": {
        "summary": "Load a landing page",
        "description": "Loading the landing page. The landing page is used for collecting candidates into the talent pool.\n",
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "example": "c4ca4238a0b923820dcc509a6f75849c",
            "description": "32-character-long hash",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Landing page was found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "form": {
                          "type": "object",
                          "properties": {
                            "label": {
                              "type": "string",
                              "example": "Answer form template"
                            },
                            "attributes": {
                              "type": "array",
                              "description": "Array of HTML attributes.",
                              "items": {
                                "properties": {
                                  "name": {
                                    "type": "string"
                                  },
                                  "value": {
                                    "type": "string"
                                  }
                                }
                              },
                              "example": []
                            },
                            "fields": {
                              "type": "array",
                              "description": "Field of HTML inputs for form.",
                              "items": {
                                "properties": {
                                  "name": {
                                    "type": "string",
                                    "description": "`name` attribute value."
                                  },
                                  "type": {
                                    "type": "string",
                                    "description": "Value of the HTML type attribute.\nIf the value is \"select\", it\u2019s a select box (dropdown); if \"select:m\", it\u2019s a multi-select dropdown.\nIf the value is \"textarea\", it\u2019s a text area.\nemail and url are HTML5 inputs that provide built-in validation; otherwise, you can replace them with text.\n",
                                    "enum": [
                                      "text",
                                      "textarea",
                                      "date",
                                      "file",
                                      "hidden",
                                      "select",
                                      "select:m",
                                      "checkbox",
                                      "email",
                                      "url"
                                    ]
                                  },
                                  "label": {
                                    "type": "string",
                                    "description": "HTML input label."
                                  },
                                  "value": {
                                    "type": "string",
                                    "nullable": true,
                                    "description": "Input default. Always as a single value."
                                  },
                                  "inputOptions": {
                                    "type": "object",
                                    "nullable": true,
                                    "description": "Additional HTML input attributes, which may include predefined data attributes. Multidimensional array/object.\nFor example, [data => [cf => date]] must be transformed into data-cf=date.\n"
                                  },
                                  "required": {
                                    "type": "boolean",
                                    "description": "Specifies whether the input is required."
                                  },
                                  "hidden": {
                                    "type": "boolean",
                                    "description": "Specifies whether the element is hidden."
                                  },
                                  "options": {
                                    "type": "object",
                                    "nullable": true,
                                    "description": "An object with values for the select box, i.e., individual options, in the format label => value.\n"
                                  },
                                  "order": {
                                    "type": "integer",
                                    "description": "The order of the input in the form."
                                  }
                                }
                              },
                              "example": [
                                {
                                  "name": "name",
                                  "type": "text",
                                  "label": "Name and surname",
                                  "value": null,
                                  "inputOptions": {},
                                  "required": true,
                                  "hidden": false,
                                  "options": null,
                                  "order": 0
                                },
                                {
                                  "name": "employment_date",
                                  "type": "date",
                                  "label": "Employment date",
                                  "value": null,
                                  "inputOptions": {
                                    "data": {
                                      "cf": "date"
                                    }
                                  },
                                  "required": true,
                                  "hidden": false,
                                  "options": null,
                                  "order": 1
                                },
                                {
                                  "name": "email",
                                  "type": "text",
                                  "label": "E-mail",
                                  "value": null,
                                  "inputOptions": {},
                                  "required": true,
                                  "hidden": false,
                                  "options": null,
                                  "order": 2
                                },
                                {
                                  "name": "offer_id",
                                  "type": "hidden",
                                  "label": "Job advert",
                                  "value": 123456,
                                  "required": true,
                                  "hidden": true,
                                  "options": null,
                                  "order": 998
                                }
                              ]
                            },
                            "gdpr": {
                              "type": "array",
                              "description": "Array of GDPR consents.\nType = 1 is an informational obligation \u2014 such consent must be displayed to the candidate, ideally at the beginning of the form.\nType = 2 must be rendered as checkboxes and submitted for validation.\nThe \"text_short\" attribute is recommended to be displayed as the checkbox label, while \"text_long\" can be collapsible/expandable.\n",
                              "items": {
                                "properties": {
                                  "id": {
                                    "type": "integer"
                                  },
                                  "title": {
                                    "type": "string"
                                  },
                                  "text_short": {
                                    "type": "string"
                                  },
                                  "text_long": {
                                    "type": "string"
                                  },
                                  "type": {
                                    "type": "integer",
                                    "enum": [
                                      1,
                                      2
                                    ]
                                  },
                                  "source": {
                                    "type": "string"
                                  }
                                }
                              },
                              "example": [
                                {
                                  "id": 33,
                                  "title": "agreement t-kariera",
                                  "text_short": "Replace your notebooks and printed documents",
                                  "text_long": "Replace your notebooks and printed documents with the only tablet that feels like paper.",
                                  "type": 1,
                                  "source": "pracevcr.cz"
                                }
                              ]
                            }
                          }
                        },
                        "landing_page": {
                          "type": "object",
                          "properties": {
                            "title": {
                              "type": "string",
                              "example": "Short title"
                            },
                            "description": {
                              "type": "string",
                              "example": "<div>some html</div>",
                              "description": "HTML content for landing page"
                            },
                            "footer": {
                              "type": "string",
                              "example": "Powered by Recruitis.io, sro",
                              "description": "HTML footer for landing page"
                            }
                          }
                        }
                      }
                    },
                    "meta": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/Response404"
          },
          "500": {
            "description": "Unexpected error."
          }
        }
      }
    },
    "/answers": {
      "post": {
        "tags": [
          "Candidates"
        ],
        "summary": "Create new answer",
        "description": "Procedure for saving a new answer. As a result, the ID of the answer is returned. \nWhen creating an answer, a new candidate is also created if one with the given contact details \n(email, phone) does not already exist. Otherwise, it is linked to the existing candidate.\n\nNote: Consent to personal data processing is automatically granted to such an answer. \nBy default, its validity is 1 year. If you wish to change this setting, please contact us. \n\n#### Important information:\n**When testing a POST request on the production server: The default token points to a test account \nthat is accessible to other users as well. Do not send your personal data through this token; \nalternatively, replace the token with your own.**\n\n#### Requirements\n\n* The call must include an authorization token.\n* New token type:\n    * The token must have the `api.candidates.write` permission.\n* Original token types:\n    * Token type: `public_access`: if it concerns a public job ad (published on company websites, XML, or job portals).\n    * Token type: `full_access`: if it concerns an internal job ad.\n* Compatible with the company token.\n\n**GDPR and consent to the processing of personal data for the given position:**\nIf GDPR consent is not specified, the candidate always receives consent to personal data processing \nfor the given position automatically for one year, or until the position ends. The source of consent \nis marked as \"api\".  \nIf GDPR consent is specified, then the answer inherits its source and expiration date \n(but for a maximum of one year).\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "job_id": {
                    "type": "integer",
                    "example": 123456
                  },
                  "name": {
                    "type": "string",
                    "example": "Ted Test"
                  },
                  "email": {
                    "type": "string",
                    "description": "Candidates are merged based on email.",
                    "format": "email",
                    "nullable": true,
                    "example": "testAPI@email.cz"
                  },
                  "www": {
                    "type": "string",
                    "nullable": true,
                    "description": "Link to candidate's web. **MUST contain http:// or https://**\n",
                    "example": "https://www.webpage.com/person"
                  },
                  "skype": {
                    "type": "string",
                    "nullable": true,
                    "description": "Link to candidate's Skype.",
                    "example": "https://www.skype.com/recruitisio"
                  },
                  "linkedin": {
                    "type": "string",
                    "nullable": true,
                    "description": "Link to candidate's LinkedIn.",
                    "example": "https://linkedin.com/in/ABCDXYZ"
                  },
                  "facebook": {
                    "type": "string",
                    "nullable": true,
                    "description": "Link to candidate's Facebook.",
                    "example": "https://www.facebook.com/recruitis.io"
                  },
                  "twitter": {
                    "type": "string",
                    "nullable": true,
                    "description": "Link to candidate's Twitter.",
                    "example": "https://twitter.com/recruitisio"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Candidates are merged based on phone.",
                    "example": "+420773631234"
                  },
                  "source_id": {
                    "type": "integer",
                    "description": "Source, where the answer came from. V\u00edce v [Enumerations - Company sources](#tag/Enumerations/paths/~1enums~1sources/get).",
                    "default": -1
                  },
                  "source": {
                    "type": "string",
                    "description": "String. The source of the answer, which is created automatically (therefore, it is not necessary to know its ID).  \nIf the source already exists, it is linked to the existing one.  \nThis field is ignored if the `source_id` value is provided.\n"
                  },
                  "refferal_id": {
                    "type": "integer",
                    "description": "Referral ID (ID obtained from the Recruitis referral page, API for referrals is planned)."
                  },
                  "cover_letter": {
                    "type": "string",
                    "description": "Cover letter."
                  },
                  "salary": {
                    "type": "object",
                    "description": "Desired salary.",
                    "properties": {
                      "amount": {
                        "type": "integer"
                      },
                      "currency": {
                        "type": "string",
                        "enum": [
                          "CZK",
                          "USD",
                          "EUR",
                          "BGN",
                          "RON",
                          "HUF"
                        ]
                      },
                      "unit": {
                        "type": "string",
                        "enum": [
                          "month",
                          "manday",
                          "hour",
                          "year"
                        ]
                      },
                      "type": {
                        "type": "integer",
                        "description": "| X | Typ pracovn\u00edho pom\u011bru      |\n| - |  ------------------------  |\n| 0 | Full-time job              |\n| 1 | Part-time job              |\n| 2 | Freelance (self-employed)  |\n| 3 | Remote work (online)       |\n| 4 | Work from home             |\n| 5 | Short-term job             |\n| 6 | Temporary job              |\n",
                        "enum": [
                          0,
                          1,
                          2,
                          3,
                          4,
                          5,
                          6
                        ]
                      },
                      "note": {
                        "type": "string"
                      }
                    },
                    "example": {
                      "amount": 55000,
                      "currency": "CZK",
                      "unit": "month",
                      "type": 0,
                      "note": "note"
                    }
                  },
                  "gdpr_agreement": {
                    "$ref": "#/components/schemas/GDPR"
                  },
                  "extra": {
                    "$ref": "#/components/schemas/Extra"
                  },
                  "attachments": {
                    "$ref": "#/components/schemas/Attachments"
                  },
                  "send_notification": {
                    "type": "boolean",
                    "description": "If enabled, when a new answer is added, a notification about the new candidate will be sent to all associated email addresses.\n",
                    "default": false
                  }
                },
                "required": [
                  "job_id",
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Answer was created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "payload": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1
                        },
                        "user_id": {
                          "type": "integer",
                          "example": 33035
                        },
                        "user_email": {
                          "type": "string",
                          "example": "testAPI@email.cz",
                          "nullable": true
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "duration": {
                          "type": "integer",
                          "example": 60
                        },
                        "total_duration": {
                          "type": "integer",
                          "example": 150
                        },
                        "code": {
                          "type": "string",
                          "example": "api.created"
                        },
                        "message": {
                          "type": "string",
                          "example": "Answer was created."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Response400"
          }
        }
      },
      "get": {
        "tags": [
          "Candidates"
        ],
        "summary": "Get all answers",
        "description": "This request returns a list of all **NON-REJECTED** answers. They can be filtered by specific job ads, flows, \nor by applying a search based on the candidate\u2019s name.\n\nIf the request does not find any matching answers, it returns HTTP status `200` with meta code `api.response.null`.\n\n#### Requirements\n\n* The call must include an authorization token.\n* Compatible with the company token.\n* New token type:\n    * The token must have the `api.candidates.read` permission.\n* Original token type:\n    * Token type: `full_access`: Working with the list of answers requires a `full_access` token.\n",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "The maximum limit for the paginator is 50. If not specified, it returns 10 items.\n",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Current page.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "job_id",
            "in": "query",
            "description": "Filtering answers by job ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "flow_id",
            "in": "query",
            "description": "Filtering answers by Flow ID.\nTo filter only REJECTED answers, use flow_id = -1.\n",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Filtering by the IDs of individual filter items assigned to the job advertisement. See more in [Filter items](#tag/Job-filters/paths/~1filters/get).",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "date_from",
            "in": "query",
            "description": "Date in the format \"YYYY-MM-DD\". Restriction specifying from which date (inclusive) the answers will be listed.",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "date_to",
            "in": "query",
            "description": "Date in the format \"YYYY-MM-DD\". Restriction specifying up to which date (inclusive) the answers will be listed.",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "flow",
                "date_created"
              ],
              "default": "date_created"
            }
          },
          {
            "name": "exported",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Answers were found.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
