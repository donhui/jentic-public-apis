{
  "openapi": "3.0.3",
  "info": {
    "title": "Biron Nexus API",
    "version": "1.0.0",
    "description": "Biron is a data platform providing a full ETL stack and semantic layer. The Nexus API enables users to execute NexusQL queries and manage workspaces.",
    "contact": {
      "url": "https://biron-analytics.com"
    },
    "x-jentic-source-url": "https://docs.biron-analytics.com/"
  },
  "servers": [
    {
      "url": "https://nexus.biron-analytics.com",
      "description": "Biron Nexus API Server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Queries",
      "description": "Execute NexusQL queries"
    },
    {
      "name": "Workspaces",
      "description": "Workspace management"
    }
  ],
  "paths": {
    "/sql": {
      "post": {
        "operationId": "executeNexusQlQuery",
        "summary": "Execute NexusQL Query",
        "description": "Execute a NexusQL query and return the result in the requested format.",
        "tags": ["Queries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NexusQlQueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query or parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workspaces/{code}": {
      "get": {
        "operationId": "getWorkspace",
        "summary": "Get Workspace",
        "description": "Retrieve workspace information by its code.",
        "tags": ["Workspaces"],
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "description": "The workspace code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workspace details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workspace"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your Biron API key or PAT (Personal Access Token) via HTTP Basic Authentication"
      }
    },
    "schemas": {
      "NexusQlQueryRequest": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {
            "type": "string",
            "description": "The NexusQL query to execute"
          },
          "format": {
            "type": "string",
            "description": "Desired response format",
            "enum": ["json", "csv"],
            "default": "json"
          },
          "workspace": {
            "type": "string",
            "description": "Workspace code to execute the query against"
          }
        }
      },
      "QueryResult": {
        "type": "object",
        "properties": {
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Column name"
                },
                "type": {
                  "type": "string",
                  "description": "Column data type"
                }
              }
            },
            "description": "Column definitions"
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            },
            "description": "Result rows"
          },
          "row_count": {
            "type": "integer",
            "description": "Number of rows returned"
          }
        }
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Workspace code"
          },
          "name": {
            "type": "string",
            "description": "Workspace name"
          },
          "description": {
            "type": "string",
            "description": "Workspace description"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  }
}