  "components": {
    "schemas": {
      "accountListRequest": {
        "required": [
          "requestId",
          "timestamp",
          "mobileNumber",
          "customerType",
          "customerReference",
          "authenticationRequestId"
        ],
        "type": "object",
        "properties": {
          "requestId": {
            "maxLength": 36,
            "minLength": 36,
            "type": "string",
            "description": "Unique request ID for each request",
            "example": "EBC1e608143ae054e07ac58d4a2ec3ca22c"
          },
          "timestamp": {
            "maxLength": 23,
            "minLength": 23,
            "type": "string",
            "description": "Time stamp of the request. YYYY-MM-DD hh:mm:ss:ttt",
            "example": "2020-03-15 01:01:01:123"
          },
          "settlementCycleId": {
            "maxLength": 11,
            "minLength": 9,
            "type": "string",
            "description": "Settlement cycle ID generated from IPN",
            "example": "2510201012A"
          },
          "mobileNumber": {
            "maxLength": 14,
            "minLength": 14,
            "type": "string",
            "description": "Mobile number of the customer",
            "example": 201012345678.0
          },
          "customerType": {
            "type": "string",
            "description": "Valid Values CONSUMER|MERCHANT",
            "example": "CONSUMER",
            "enum": [
              "CONSUMER",
              "MERCHANT"
            ]
          },
          "customerReference": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "description": "Unique Customer Reference number(echo from the authentication call bank\u2019s response).",
            "example": "J66012589"
          },
          "authenticationRequestId": {
            "maxLength": 36,
            "minLength": 36,
            "type": "string",
            "description": "Shall be echoed from the bank authentication request call.",
            "example": "700aeab1d037470d864d08adf24e5218"
          },
          "authenticationApprovalToken": {
            "maxLength": 36,
            "minLength": 1,
            "type": "string",
            "description": "Shall be echoed from the authentication call bank\u2019s response, if exists.",
            "example": "7470d864d08"
          }
        },
        "xml": {
          "name": "accountListRequest"
        }
      },
      "accountListResponse": {
        "required": [
          "requestId",
          "timestamp",
          "respCode",
          "respDesc",
          "customerReference",
          "customerIdType",
          "customerIdValue"
        ],
        "type": "object",
        "properties": {
          "requestId": {
            "maxLength": 36,
            "minLength": 36,
            "type": "string",
            "description": "Unique request ID for each request",
            "example": "EBC1e608143ae054e07ac58d4a2ec3ca22c"
          },
          "timestamp": {
            "maxLength": 23,
            "minLength": 23,
            "type": "string",
            "description": "Time stamp of the request. YYYY-MM-DD hh:mm:ss:ttt",
            "example": "2020-03-15 01:01:01:123"
          },
          "respCode": {
            "maxLength": 5,
            "minLength": 5,
            "type": "string",
            "description": "Response Code",
            "example": "00000"
          },
          "respDesc": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "description": "Response Description",
            "example": "SUCCESS"
          },
          "customerReference": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "description": "Unique Customer Reference number generated from Bank for each customer.",
            "example": "J66012589"
          },
          "customerIdType": {
            "type": "string",
            "description": "d type of the customer. Valid values NID|PASSPORT",
            "example": "NID",
            "enum": [
              "NID",
              "PASSPORT"
            ]
          },
          "customerIdValue": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "Id value of the customer",
            "example": 27308030102537
          },
          "accountList": {
            "type": "object",
            "description": "Shall be echoed from the authentication call bank\u2019s response, if exists.",
            "properties": {
              "ac": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/acObj"
                }
              }
            }
          }
        },
        "xml": {
          "name": "accountListResponse"
        }
      },
      "acObj": {
        "required": [
          "type",
          "subType",
          "accountId",
          "name",
          "authType",
          "authPINLen"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Account Type.ACCOUNT | WALLET | CARD",
            "example": "ACCOUNT",
            "enum": [
              "ACCOUNT",
              "WALLET",
              "CARD"
            ]
          },
          "subType": {
            "type": "string",
            "description": "Account subtype.SAVING | CHECKING | PREPAID |OVERDRAFT",
            "example": "SAVING",
            "enum": [
              "SAVING",
              "CHECKING",
              "PREPAID",
              "OVERDRAFT"
            ]
          },
          "accountId": {
            "maxLength": 36,
            "minLength": 4,
            "type": "string",
            "description": "Account ID (account number to be authenticated in case of Reset IPN PIN)",
            "example": "123456789"
          },
          "maskedaccountId": {
            "maxLength": 36,
            "minLength": 4,
            "type": "string",
            "description": "Account ID (account number to be authenticated in case of Reset IPN PIN)",
            "example": "123****890"
          },
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "description": "Account holder name",
            "example": "Hari Danda"
          },
          "authType": {
            "type": "string",
            "description": "Authentication PIN type.ATMPIN | M_PIN | IBC",
            "example": "ATMPIN",
            "enum": [
              "ATMPIN",
              "M_PIN",
              "IBC"
            ]
          },
          "authPINLen": {
            "type": "string",
            "description": "Authentication PIN Length.Values: 4 | 6| 8",
            "example": "6",
            "enum": [
              "4",
              "6",
              "8"
            ]
          },
          "accDesc": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "description": "account description",
            "example": "account description"
          },
          "schemeId": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string",
            "description": "Wallet scheme id",
            "example": "id value"
          }
        }
      },
      "errorResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Invalid - Request did not confirm to the specification and was unprocessed and rejected. Please fix the value and try again",
            "enum": [
              "error",
              "warn",
              "invalid",
              "fatal"
            ]
          },
          "code": {
            "description": "Error code which qualifies the error",
            "type": "string"
          },
          "details": {
            "description": "Human readable explanation specific to the occurrence of the problem",
            "type": "string"
          },
          "moreInfo": {
            "type": "string",
            "description": "URI to human readable documentation of the error"
          }
        },
        "required": [
          "type",
          "code"
        ],
        "xml": {
          "name": "errorResponse"
        }
      }
    },
    "securitySchemes": {
      "client_secret": {
        "type": "apiKey",
        "description": "",
        "name": "Client-Secret",
        "in": "header"
      },
      "client_id": {
        "type": "apiKey",
        "description": "",
        "name": "Client-Id",
        "in": "header"
      },
      "PSUOAuth2Security": {
        "type": "oauth2",
        "description": "OAuth flow, it is required when the consumer needs to access a resource owned by the AUB with the help of token.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://$(aub-authorize-url)",
            "tokenUrl": "https://$(aub-token-url)",
            "scopes": {
              "accounts": "Ability to read Accounts information",
              "openid": ""
            }
          }
        },
        "x-tokenIntrospect": {
          "url": "https://$(aub-introspect-url)"
        }
      },
      "TPPOAuth2Security": {
        "type": "oauth2",
        "description": "TPP client credential authorisation flow with the ASPSP",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://$(aub-token-url)",
            "scopes": {
              "tpp_client_credential": "TPP Client Credential Scope"
            }
          }
        },
        "x-tokenIntrospect": {
          "url": "https://$(aub-introspect-url)"
        }
      }
    }
  }
}