  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://{deployment}.api.accelo.com/oauth2/v0/authorize",
            "tokenUrl": "https://{deployment}.api.accelo.com/oauth2/v0/token",
            "scopes": {}
          }
        }
      }
    },
    "parameters": {
      "FieldsParam": {
        "name": "_fields",
        "in": "query",
        "required": false,
        "schema": { "type": "string" },
        "description": "Comma-separated list of field names to include in the response."
      },
      "FiltersParam": {
        "name": "_filters",
        "in": "query",
        "required": false,
        "schema": { "type": "string" },
        "description": "Filter expression to narrow results."
      },
      "SearchParam": {
        "name": "_search",
        "in": "query",
        "required": false,
        "schema": { "type": "string" },
        "description": "Search term to filter results."
      },
      "LimitParam": {
        "name": "_limit",
        "in": "query",
        "required": false,
        "schema": { "type": "integer" },
        "description": "Maximum number of results per page."
      },
      "PageParam": {
        "name": "_page",
        "in": "query",
        "required": false,
        "schema": { "type": "integer" },
        "description": "Page number for pagination."
      },
      "OffsetParam": {
        "name": "_offset",
        "in": "query",
        "required": false,
        "schema": { "type": "integer" },
        "description": "Number of results to skip."
      }
    },
    "schemas": {
      "MetaResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "The status of the response."
          },
          "message": {
            "type": "string",
            "description": "A human-readable message about the response."
          },
          "more_info": {
            "type": "string",
            "description": "A URL with more information about the response status."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/MetaResponse" },
          "response": {
            "type": "object",
            "nullable": true,
            "description": "Null or empty on error."
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The access token."
          },
          "token_type": {
            "type": "string",
            "description": "The token type, typically 'Bearer'."
          },
          "expires_in": {
            "type": "integer",
            "description": "Token lifetime in seconds."
          },
          "refresh_token": {
            "type": "string",
            "description": "The refresh token."
          }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the activity."
          },
          "subject": {
            "type": "string",
            "description": "The subject of the activity."
          },
          "body": {
            "type": "string",
            "description": "The body content of the activity."
          },
          "date_created": {
            "type": "string",
            "description": "The date the activity was created (Unix timestamp)."
          },
          "date_modified": {
            "type": "string",
            "description": "The date the activity was last modified (Unix timestamp)."
          },
          "owner_id": {
            "type": "integer",
            "description": "The ID of the activity owner."
          },
          "owner_type": {
            "type": "string",
            "description": "The type of the activity owner."
          },
          "medium": {
            "type": "string",
            "description": "The medium of the activity (e.g., email, note)."
          },
          "visibility": {
            "type": "string",
            "description": "The visibility level of the activity."
          },
          "staff": {
            "type": "integer",
            "description": "The staff member ID associated with the activity."
          }
        }
      },
      "ActivityCreate": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string",
            "description": "The subject of the activity."
          },
          "body": {
            "type": "string",
            "description": "The body content of the activity."
          },
          "owner_id": {
            "type": "integer",
            "description": "The ID of the object the activity is against."
          },
          "owner_type": {
            "type": "string",
            "description": "The type of the object the activity is against."
          },
          "medium": {
            "type": "string",
            "description": "The medium of the activity."
          },
          "visibility": {
            "type": "string",
            "description": "The visibility level of the activity."
          }
        }
      },
      "Company": {
        "type": "object",
        "properties": {
