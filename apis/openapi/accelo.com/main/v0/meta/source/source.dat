            "description": "The contact's email address."
          },
          "phone": {
            "type": "string",
            "description": "The contact's phone number."
          },
          "company_id": {
            "type": "integer",
            "description": "The ID of the associated company."
          },
          "status": {
            "type": "string",
            "description": "The status of the contact."
          },
          "date_created": {
            "type": "string",
