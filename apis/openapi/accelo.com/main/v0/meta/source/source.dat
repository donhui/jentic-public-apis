          "phone": {
            "type": "string",
            "description": "The company phone number."
          },
          "status": {
            "type": "string",
            "description": "The status of the company."
          },
          "date_created": {
            "type": "string",
            "description": "The date the company was created (Unix timestamp)."
          },
          "date_modified": {
            "type": "string",
            "description": "The date the company was last modified (Unix timestamp)."
          }
        }
      },
      "CompanyCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "The company name."
          },
          "website": {
            "type": "string",
            "description": "The company website URL."
          },
          "phone": {
            "type": "string",
            "description": "The company phone number."
          }
        }
