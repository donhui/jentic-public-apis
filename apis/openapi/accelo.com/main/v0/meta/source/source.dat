{
  "openapi": "3.0.3",
  "info": {
    "title": "Accelo API",
    "description": "The Accelo API provides programmatic access to Accelo's professional services automation platform, including activities, companies, contacts, and staff management.",
    "version": "v0",
    "x-jentic-source-url": "https://api.accelo.com/docs/"
  },
  "servers": [
    {
      "url": "https://{deployment}.api.accelo.com",
      "description": "Accelo API server",
      "variables": {
        "deployment": {
          "description": "Your Accelo deployment name",
          "default": "example"
        }
      }
    }
  ],
  "security": [
    {
      "OAuth2": []
    }
  ],
  "tags": [
    { "name": "OAuth", "description": "OAuth 2.0 authorization endpoints" },
    { "name": "Activities", "description": "Manage activities" },
    { "name": "Companies", "description": "Manage companies" },
    { "name": "Contacts", "description": "Manage contacts" },
    { "name": "Staff", "description": "Manage staff members" }
  ],
  "paths": {
    "/oauth2/v0/authorize": {
      "get": {
        "tags": ["OAuth"],
        "operationId": "getAuthorization",
        "summary": "Request authorization",
        "description": "Initiates the OAuth 2.0 authorization flow.",
        "security": [],
        "parameters": [
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The response type, typically 'code'."
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The client application ID."
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The URI to redirect back to after authorization."
          },
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Requested permission scope."
          }
        ],
        "responses": {
          "200": {
            "description": "Authorization page or redirect."
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["OAuth"],
        "operationId": "postAuthorization",
        "summary": "Request authorization via POST",
        "description": "Initiates the OAuth 2.0 authorization flow using POST.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["response_type", "client_id", "redirect_uri"],
                "properties": {
                  "response_type": { "type": "string", "description": "The response type, typically 'code'." },
                  "client_id": { "type": "string", "description": "The client application ID." },
                  "redirect_uri": { "type": "string", "description": "The URI to redirect back to after authorization." },
                  "scope": { "type": "string", "description": "Requested permission scope." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authorization page or redirect."
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/oauth2/v0/token": {
      "post": {
        "tags": ["OAuth"],
        "operationId": "createAccessToken",
        "summary": "Get access token",
        "description": "Exchanges an authorization code for an access token.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "code", "redirect_uri", "client_id", "client_secret"],
                "properties": {
                  "grant_type": { "type": "string", "description": "The grant type, e.g. 'authorization_code'." },
                  "code": { "type": "string", "description": "The authorization code received from the authorize endpoint." },
                  "redirect_uri": { "type": "string", "description": "The redirect URI used in the authorization request." },
                  "client_id": { "type": "string", "description": "The client application ID." },
                  "client_secret": { "type": "string", "description": "The client application secret." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Invalid credentials.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/oauth2/v0/revoke": {
      "post": {
        "tags": ["OAuth"],
        "operationId": "revokeToken",
        "summary": "Revoke token",
        "description": "Revokes an existing access or refresh token.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["token"],
                "properties": {
                  "token": { "type": "string", "description": "The token to revoke." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token successfully revoked."
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v0/activities": {
      "get": {
        "tags": ["Activities"],
        "operationId": "listActivities",
        "summary": "List activities",
        "description": "Returns a paginated list of activities.",
        "parameters": [
          { "$ref": "#/components/parameters/FieldsParam" },
          { "$ref": "#/components/parameters/FiltersParam" },
          { "$ref": "#/components/parameters/SearchParam" },
          { "$ref": "#/components/parameters/LimitParam" },
          { "$ref": "#/components/parameters/PageParam" },
          { "$ref": "#/components/parameters/OffsetParam" }
        ],
        "responses": {
          "200": {
            "description": "A list of activities.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/MetaResponse" },
                    "response": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Activity" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      },
      "post": {
        "tags": ["Activities"],
        "operationId": "createActivity",
        "summary": "Create activity",
        "description": "Creates a new activity.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ActivityCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The created activity.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/MetaResponse" },
                    "response": { "$ref": "#/components/schemas/Activity" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/v0/activities/{activity_id}": {
      "get": {
        "tags": ["Activities"],
        "operationId": "getActivity",
        "summary": "Get activity",
        "description": "Returns a single activity by ID.",
        "parameters": [
          {
            "name": "activity_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "The unique ID of the activity."
          },
          { "$ref": "#/components/parameters/FieldsParam" }
        ],
        "responses": {
          "200": {
            "description": "The requested activity.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/MetaResponse" },
                    "response": { "$ref": "#/components/schemas/Activity" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      },
      "put": {
        "tags": ["Activities"],
        "operationId": "updateActivity",
        "summary": "Update activity",
        "description": "Updates an existing activity.",
        "parameters": [
          {
            "name": "activity_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "The unique ID of the activity."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ActivityCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated activity.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/MetaResponse" },
                    "response": { "$ref": "#/components/schemas/Activity" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      },
      "delete": {
        "tags": ["Activities"],
        "operationId": "deleteActivity",
        "summary": "Delete activity",
        "description": "Deletes an activity by ID.",
        "parameters": [
          {
            "name": "activity_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "The unique ID of the activity."
          }
        ],
        "responses": {
          "200": {
            "description": "Activity deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/MetaResponse" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
