        "operationId": "getContact",
        "summary": "Get contact",
        "description": "Returns a single contact by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "The unique ID of the contact."
          },
          { "$ref": "#/components/parameters/FieldsParam" }
        ],
        "responses": {
          "200": {
            "description": "The requested contact.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/MetaResponse" },
                    "response": { "$ref": "#/components/schemas/Contact" }
