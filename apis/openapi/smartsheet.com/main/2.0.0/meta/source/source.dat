            "description": "User object containing name and email of the creator of this comment.",
            "allOf": [
              {
                "$ref": "#/components/schemas/NameAndEmail"
              }
            ]
          },
          "discussionId": {
            "description": "Discussion Id of discussion that contains comment.",
            "allOf": [
              {
                "$ref": "#/components/schemas/Int64"
              }
            ]
          },
          "id": {
            "description": "Comment Id.",
            "allOf": [
              {
                "$ref": "#/components/schemas/Int64"
              }
            ]
          },
          "modifiedAt": {
            "$ref": "#/components/schemas/Datetime"
          },
          "text": {
            "description": "Comment body.",
            "type": "string"
          }
        }
      },
      "CommentAndFile": {
        "type": "object",
        "properties": {
          "comment": {
            "description": "Comment.",
            "type": "object",
            "properties": {
              "text": {
                "description": "Comment text.",
                "type": "string"
              }
            }
          },
          "file": {
            "description": "File to attach to the new comment. Only used with an attachment.",
            "type": "string",
            "format": "binary"
          }
        }
      },
      "CommentAndTitle": {
        "type": "object",
        "description": "Discussion.",
        "properties": {
