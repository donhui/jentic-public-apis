            "type": "boolean",
            "deprecated": true
          },
          "folders": {
            "$ref": "#/components/schemas/FolderArray"
          },
          "name": {
            "description": "Folder name.",
            "type": "string",
            "maxLength": 50
          },
          "permalink": {
            "description": "URL that represents a direct link to the folder in Smartsheet.",
            "type": "string"
          },
          "reports": {
            "$ref": "#/components/schemas/ReportArray"
          },
          "sheets": {
            "$ref": "#/components/schemas/SheetArray"
          },
          "sights": {
            "$ref": "#/components/schemas/SightArray"
          },
          "templates": {
            "$ref": "#/components/schemas/TemplateArray"
          }
        }
      },
      "FolderArray": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Folder"
        }
      },
      "FolderBrief": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Folder Id.",
            "allOf": [
              {
                "$ref": "#/components/schemas/Int64"
              }
