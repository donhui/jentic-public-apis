          },
          "required": true,
          "description": "Summary Field Id of the sheet summary field being accessed."
        }
      ],
      "post": {
        "summary": "Add Image to Sheet Summary",
        "description": "Adds an image to the summary field.",
        "operationId": "add-image-summaryField",
        "tags": [
          "sheetSummary"
        ],
        "security": [
          {
            "APIToken": []
          },
          {
            "OAuth2": [
              "WRITE_SHEETS"
            ]
