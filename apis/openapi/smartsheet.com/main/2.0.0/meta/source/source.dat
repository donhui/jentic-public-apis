      "Comment": {
        "type": "object",
        "properties": {
          "attachments": {
            "description": "Array of attachments on comments.",
            "allOf": [
              {
                "$ref": "#/components/schemas/AttachmentArray"
              }
            ]
          },
          "createdAt": {
            "$ref": "#/components/schemas/Datetime"
          },
