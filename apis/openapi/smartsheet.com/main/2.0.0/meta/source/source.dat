                  "type": "string",
                  "enum": [
                    "AREA",
                    "BAR",
                    "COLUMN",
                    "LINE",
                    "PIE",
                    "SCATTER"
                  ]
                },
                "dataLabels": {
                  "type": "object",
                  "properties": {
                    "labelType": {
                      "type": "string",
                      "enum": [
                        "NONE",
                        "PERCENT",
                        "VALUE"
                      ]
                    }
                  }
                },
                "tooltips": {
                  "type": "object",
