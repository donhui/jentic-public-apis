        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Comment"
        }
      },
      "CommentBrief": {
        "type": "object",
        "properties": {
          "comment": {
            "description": "Comment.",
            "allOf": [
              {
                "$ref": "#/components/schemas/CommentText"
              }
            ]
          }
        }
      },
      "CommentText": {
