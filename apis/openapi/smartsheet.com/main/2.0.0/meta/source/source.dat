              "paperSize": {
                "$ref": "#/components/schemas/PaperSize"
              }
            }
          }
        }
      },
      "SheetEmailFormat": {
        "description": "One of the following values: **EXCEL**, **PDF**, or **PDF_GANTT**.\n",
        "type": "string",
        "enum": [
          "EXCEL",
          "PDF",
          "PDF_GANTT"
        ]
      },
      "SheetExclude": {
        "type": "string",
        "enum": [
