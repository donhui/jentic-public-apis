      "get": {
        "summary": "Get Contact",
        "description": "Gets the specified contact.",
        "operationId": "get-contact",
        "tags": [
          "contacts"
        ],
        "security": [
          {
            "APIToken": []
          },
          {
            "OAuth2": [
              "READ_CONTACTS"
            ]
          }
        ],
        "parameters": [
          {
            "name": "include",
            "in": "query",
            "style": "simple",
            "description": "A comma-separated list of optional elements to include in the response:\n  * **profileImage**\n",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/GetContactInclude"
              }
            }
          }
        ],
        "responses": {
