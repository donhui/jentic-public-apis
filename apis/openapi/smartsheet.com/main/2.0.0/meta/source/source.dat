      "URLAttachmentRequest": {
        "type": "object",
        "properties": {
          "attachmentSubType": {
            "description": "Attachment sub type. Note--Folder type is for EGNYTE values and the rest are GOOGLE_DRIVE values.",
            "type": "string",
            "enum": [
