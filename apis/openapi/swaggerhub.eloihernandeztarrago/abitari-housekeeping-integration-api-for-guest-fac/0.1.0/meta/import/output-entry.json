  "components": {
    "schemas": {
      "ConnectionRequest": {
        "properties": {
          "code": {
            "description": "Unique identifier representing a connection",
            "type": "string"
          },
          "service": {
            "$ref": "#/components/schemas/ConnectionServiceType"
          }
        },
        "required": [
          "code",
          "service"
        ],
        "type": "object"
      },
      "ConnectionResponse": {
        "properties": {
          "code": {
            "description": "Unique identifier representing a connection",
            "type": "string"
          },
          "service": {
            "$ref": "#/components/schemas/ConnectionServiceType"
          },
          "status": {
            "$ref": "#/components/schemas/ConnectionStatusType"
          }
        },
        "required": [
          "code",
          "service"
        ],
        "type": "object"
      },
      "ConnectionServiceType": {
        "description": "Service to be used when connecting to the system",
        "enum": [
          "AbitariService"
        ],
        "type": "string"
      },
      "ConnectionStatusType": {
        "description": "Status of the connection",
        "enum": [
          "setup_pending",
          "setup_auth_ok",
          "setup_auth_failed",
          "setup_started",
          "setup_finished",
          "online",
          "offline"
        ],
        "type": "string"
      },
      "Error": {
        "properties": {
          "code": {
            "format": "int32",
            "type": "integer"
          },
          "fields": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code"
        ],
        "type": "object"
      },
      "GuestPetitionRequest": {
        "properties": {
          "expires_at": {
            "description": "Datetime in which petition is no longer applied (although optional, mainly used in non disturb).",
            "type": "string"
          },
          "guest_id": {
            "description": "Unique identifier representing the guest making the petition.",
            "type": "string"
          },
          "id": {
            "description": "Unique identifier representing a specific guest petition.",
            "type": "string"
          },
          "message": {
            "description": "Some observations regarding the petition.",
            "type": "string"
          },
          "place_id": {
            "description": "The id of your IntegratedProperty where the guest petition originates.",
            "type": "string"
          },
          "room_id": {
            "description": "Unique identifier representing the specific room where the request takes place.",
            "type": "string"
          },
          "starts_at": {
            "description": "Datetime in which petition starts applying (required for non disturb).",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/GuestPetitionStatus"
          },
          "type": {
            "$ref": "#/components/schemas/GuestPetitionType"
          }
        },
        "required": [
          "id",
          "type",
          "room_id",
          "place_id"
        ],
        "type": "object"
      },
      "GuestPetitionResponse": {
        "properties": {
          "expires_at": {
            "description": "Datetime in which petition is no longer applied (although optional, mainly used in non disturb).",
            "type": "string"
          },
          "guest_id": {
            "description": "Unique identifier representing the guest making the petition.",
            "type": "string"
          },
          "id": {
            "description": "Unique identifier representing a specific guest petition.",
            "type": "string"
          },
          "message": {
            "description": "Some observations regarding the petition.",
            "type": "string"
          },
          "pms_id": {
            "description": "Unique identifier representing the pms the property works with.",
            "type": "string"
          },
          "room_id": {
            "description": "Unique identifier representing the specific room where the request takes place.",
            "type": "string"
          },
          "starts_at": {
            "description": "Datetime in which petition starts applying (required for non disturb).",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/GuestPetitionStatus"
          },
          "type": {
            "$ref": "#/components/schemas/GuestPetitionType"
          }
        },
        "required": [
          "id",
          "pms_id",
          "room_id",
          "type",
          "status"
        ],
        "type": "object"
      },
      "GuestPetitionStatus": {
        "description": "Petition done status",
        "enum": [
          "pending",
          "done"
        ],
        "type": "string"
      },
      "GuestPetitionType": {
        "description": "Type of Petition",
        "enum": [
          "incidence-type",
          "make-cleaning-type",
          "notifiable-event-type",
          "non-disturb-type",
          "extra-cleaning-type"
        ],
        "type": "string"
      },
      "StartConnectionRequest": {
        "properties": {
          "code": {
            "description": "Unique identifier representing a connection",
            "type": "string"
          },
          "property_callback_url": {
            "description": "Url to send the notification of a new IntegratedPropertyNotificationType",
            "type": "string"
          },
          "property_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "code",
          "property_ids"
        ],
        "type": "object"
      },
      "UpdateWebhookRequest": {
        "properties": {
          "url": {
            "description": "Consumer endpoint that processes the notification.",
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "type": "object"
      },
      "WebhookEventType": {
        "description": "Topic that triggers the notification",
        "enum": [
          "healthcheck",
          "guestpetition",
          "room"
        ],
        "type": "string"
      },
      "WebhookRequest": {
        "properties": {
          "topic": {
            "$ref": "#/components/schemas/WebhookEventType"
          },
          "url": {
            "description": "Consumer endpoint that processes the notification.",
            "type": "string"
          }
        },
        "required": [
          "topic",
          "url"
        ],
        "type": "object"
      },
      "WebhookResponse": {
        "properties": {
          "id": {
            "type": "string"
          },
          "topic": {
            "description": "Event that triggers the notification (typicaly resource name, for example room.",
            "type": "string"
          },
          "url": {
            "description": "Consumer endpoint that processes the notification.",
            "type": "string"
          }
        },
        "required": [
          "id",
          "topic",
          "url"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "accessCode": {
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://identity.abitari.com/o/token",
            "scopes": {
              "read": "allows reading resources",
              "write": "allows modifying resources"
            },
            "tokenUrl": "https://identity.abitari.com/o/authorize"
          }
        },
        "type": "oauth2"
      }
    }
  },
  "security": [
    {
      "accessCode": [
        "read",
        "write"
      ]
    }
  ],
  "tags": [
    {
      "name": "Messaging"
    },
    {
      "name": "Setup"
    }
  ]
}