                }
              }
            },
            "description": "Unexpected error"
          }
        },
        "tags": [
          "Setup"
        ],
        "description": "Setting up a Connection allows you to establish a bridge (not working until started) between your external application and the hotelier's account that corresponds to your access token. If this account belongs to Abitari (only possibility right now), you should use AbitariService to connect to it. The creation of the Connection will return a list of the available properties to be integrated.\n",
        "operationId": "post-autoinstall-connect",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConnectionRequest"
              }
            }
          },
          "description": "Connection request",
          "required": true
        },
        "summary": "Create a new connection to the API"
      }
    },
    "/autoinstall/connect/start": {
      "post": {
        "responses": {
          "204": {
