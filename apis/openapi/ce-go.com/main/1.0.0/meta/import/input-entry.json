          "registered_users_count": {
            "type": "integer",
            "description": "Number of registered users"
          }
        }
      },
      "EventUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Registration ID"
          },
          "user_id": {
            "type": "integer",
            "description": "User ID"
          },
          "name": {
            "type": "string",
            "description": "User full name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          },
          "evaluation": {
            "type": "string",
            "description": "Evaluation status"
          },
          "status": {
            "type": "string",
