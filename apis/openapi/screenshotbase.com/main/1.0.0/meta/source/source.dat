{
  "openapi": "3.0.3",
  "info": {
    "title": "Screenshotbase API",
    "description": "Screenshotbase is an API to capture full-page website screenshots as PNG, JPEG, or WEBP. Check API status and quota, and take website screenshots with extensive customization options.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://screenshotbase.com/docs"
  },
  "servers": [
    {
      "url": "https://api.screenshotbase.com/v1",
      "description": "Screenshotbase Production API"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    { "name": "Screenshots", "description": "Capture website screenshots" },
    { "name": "Account", "description": "Account status and quota information" }
  ],
  "paths": {
    "/status": {
      "get": {
        "operationId": "getApiStatus",
        "summary": "Check API status and quota",
        "description": "Returns quota information for the authenticated account. Requests to this endpoint do not count against your quota or rate limit.",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "API status and quota information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiStatus" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/take": {
      "get": {
        "operationId": "takeScreenshot",
        "summary": "Take a website screenshot",
        "description": "Capture a screenshot of a website with customizable options including format, viewport size, delays, and content blocking.",
        "tags": ["Screenshots"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "The URL of the website you want to render",
            "schema": { "type": "string", "format": "uri" }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Image format for the screenshot",
            "schema": {
              "type": "string",
              "enum": ["jpg", "jpeg", "png", "gif", "webp"],
              "default": "png"
            }
          },
          {
            "name": "quality",
            "in": "query",
            "description": "Image quality for jpg/jpeg format only",
            "schema": {
              "type": "integer",
              "default": 80
            }
          },
          {
            "name": "full_page",
            "in": "query",
            "description": "Set to 1 to take a full page screenshot",
            "schema": {
              "type": "integer",
              "enum": [0, 1],
              "default": 0
            }
          },
          {
            "name": "viewport_width",
            "in": "query",
            "description": "Browser viewport width in pixels",
            "schema": {
              "type": "integer",
              "default": 1280
            }
          },
          {
            "name": "viewport_height",
            "in": "query",
            "description": "Browser viewport height in pixels",
            "schema": {
              "type": "integer",
              "default": 800
            }
          },
          {
            "name": "ip_country_code",
            "in": "query",
            "description": "ISO 3166-1 alpha-2 country code for IP simulation",
            "schema": { "type": "string" }
          },
          {
            "name": "delay",
            "in": "query",
            "description": "Delay in seconds before taking the screenshot (0-30)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 30,
              "default": 0
            }
          },
          {
            "name": "timeout",
            "in": "query",
            "description": "Page load timeout in seconds (5-60)",
            "schema": {
              "type": "integer",
              "minimum": 5,
              "maximum": 60,
              "default": 60
            }
          },
          {
            "name": "wait_until",
            "in": "query",
            "description": "Page load state to wait for before taking the screenshot",
            "schema": {
              "type": "string",
              "enum": ["load", "domcontentloaded", "networkidle0", "networkidle2"],
              "default": "load"
            }
          },
          {
            "name": "block_cookie_banners",
            "in": "query",
            "description": "Block cookie banners (1 to enable, 0 to disable)",
            "schema": {
              "type": "integer",
              "enum": [0, 1],
              "default": 0
            }
          },
          {
            "name": "block_ads",
            "in": "query",
            "description": "Block advertisements (1 to enable, 0 to disable)",
            "schema": {
              "type": "integer",
              "enum": [0, 1],
              "default": 0
            }
          },
          {
            "name": "block_chats",
            "in": "query",
            "description": "Block chat widgets (1 to enable, 0 to disable)",
            "schema": {
              "type": "integer",
              "enum": [0, 1],
              "default": 0
            }
          },
          {
            "name": "hide_selectors",
            "in": "query",
            "description": "CSS selectors to hide (max 255 characters per selector)",
            "schema": {
              "type": "array",
              "items": { "type": "string", "maxLength": 255 }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "styles",
            "in": "query",
            "description": "Custom CSS to inject into the page (max 10,000 characters)",
            "schema": {
              "type": "string",
              "maxLength": 10000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Screenshot image binary data",
            "content": {
              "image/png": {
                "schema": { "type": "string", "format": "binary" }
              },
              "image/jpeg": {
                "schema": { "type": "string", "format": "binary" }
              },
              "image/webp": {
                "schema": { "type": "string", "format": "binary" }
              },
              "image/gif": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "apikey",
        "description": "API key passed via the apikey header"
      }
    },
    "schemas": {
      "ApiStatus": {
        "type": "object",
        "properties": {
          "account_id": {
            "type": "integer",
            "description": "Account identifier"
          },
          "quotas": {
            "type": "object",
            "properties": {
              "month": {
                "$ref": "#/components/schemas/QuotaInfo"
              },
              "grace": {
                "$ref": "#/components/schemas/QuotaInfo"
              }
            }
          }
        }
      },
      "QuotaInfo": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Total quota allowance"
          },
          "used": {
            "type": "integer",
            "description": "Quota used so far"
          },
          "remaining": {
            "type": "integer",
            "description": "Quota remaining"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  }
}