{
  "openapi": "3.0.3",
  "info": {
    "title": "Everyware API",
    "description": "Everyware is a Pay by Text platform providing a JSON-based asynchronous REST API for managing businesses, contacts, messages, payments, invoices, subscriptions, and merchant onboarding. The API supports SMS/MMS messaging, payment processing, invoice management, and identity verification.",
    "version": "1.0.0",
    "contact": {
      "name": "Everyware",
      "url": "https://www.everyware.com"
    },
    "x-jentic-source-url": "https://docs.everyware.com"
  },
  "servers": [
    {
      "url": "https://rest.everyware.com",
      "description": "Production API server"
    }
  ],
  "paths": {
    "/api/Default/GetBusiness": {
      "get": {
        "operationId": "getBusinesses",
        "summary": "Get all businesses linked to master site ID",
        "description": "Retrieves an array of all businesses linked under your master site ID.",
        "tags": [
          "Businesses"
        ],
        "responses": {
          "200": {
            "description": "Businesses retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetBusinessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
