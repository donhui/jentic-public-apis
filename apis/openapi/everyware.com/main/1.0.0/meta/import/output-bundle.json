                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/onboarding/status/{applicationId}": {
      "get": {
        "operationId": "getOnboardingStatus",
        "summary": "Get onboarding application status",
        "description": "Check the status of a merchant onboarding application. Returns 0 (Pending), 1 (Successful), or 2 (Failed).",
        "tags": [
          "Onboarding"
        ],
        "parameters": [
          {
            "name": "applicationId",
            "in": "path",
            "required": true,
            "description": "The application ID returned from the onboarding submission",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "enum": [
                    0,
                    1,
                    2
                  ],
                  "description": "0=Pending, 1=Successful, 2=Failed"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic HTTP authentication using API credentials"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "IsSuccess": {
            "type": "boolean",
            "description": "Whether the operation was successful"
          },
          "Message": {
            "type": "string",
            "description": "Status or error message"
          },
          "Data": {
            "description": "Response data (varies by endpoint)"
          },
          "OrderNumber": {
            "type": "string",
            "nullable": true
          },
          "SMSID": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "GetBusinessResponse": {
        "type": "object",
        "properties": {
          "IsSuccess": {
            "type": "boolean"
          },
          "Message": {
            "type": "string"
          },
          "businesses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Business"
            }
          }
        }
      },
      "Business": {
        "type": "object",
        "properties": {
          "MobileNumber": {
            "type": "string"
          },
          "SalesSiteID": {
            "type": "string"
          },
          "APIKey": {
            "type": "string"
          },
          "UserName": {
            "type": "string"
          },
          "FirstName": {
            "type": "string"
          },
          "LastName": {
            "type": "string"
          },
          "Email": {
            "type": "string"
          },
          "Phone": {
            "type": "string"
          },
          "Address1": {
            "type": "string"
          },
          "Address2": {
            "type": "string"
          },
          "City": {
            "type": "string"
          },
          "State": {
            "type": "string"
          },
          "PostalCode": {
            "type": "string"
          },
          "BusinessName": {
            "type": "string"
          },
          "URL": {
            "type": "string"
          }
        }
      },
      "UpdateCustomerRequest": {
        "type": "object",
        "properties": {
          "ExternalID": {
            "type": "string",
            "description": "External system customer ID (required if IndividualID not provided)"
          },
          "IndividualID": {
            "type": "string",
            "description": "Everyware customer ID (required if ExternalID not provided)"
          },
          "FirstName": {
            "type": "string"
          },
          "LastName": {
            "type": "string"
          },
          "Email": {
            "type": "string"
          },
          "MobilePhone": {
            "type": "string",
            "description": "10 digits max"
          },
          "SecondaryPhone": {
            "type": "string",
            "description": "10 digits max"
          },
          "Title": {
            "type": "string"
          },
          "CompanyName": {
            "type": "string"
          },
          "Address1": {
            "type": "string"
          },
          "Address2": {
            "type": "string"
          },
          "City": {
            "type": "string"
          },
          "CountryCode": {
            "type": "string",
            "description": "e.g. US"
          },
          "StateCode": {
            "type": "string",
            "description": "2-letter format"
          },
          "PostalCode": {
            "type": "string"
          },
          "ListID": {
            "type": "string"
          },
          "CustomField1": {
            "type": "string"
          },
          "CustomField2": {
            "type": "string"
          },
          "CustomField3": {
            "type": "string"
          },
          "CustomField4": {
            "type": "string"
          },
          "CustomField5": {
            "type": "string"
          },
          "CustomField6": {
            "type": "string"
          },
          "CustomField7": {
            "type": "string"
          }
        }
      },
      "GetMessagesRequest": {
        "type": "object",
        "required": [
          "NewOnly",
          "DateFrom",
          "DateTo"
        ],
        "properties": {
          "NewOnly": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "0=All messages, 1=Unread only"
          },
          "DateFrom": {
            "type": "string",
            "description": "Start date (MM-DD-YYYY format)"
          },
          "DateTo": {
            "type": "string",
            "description": "End date (MM-DD-YYYY format)"
          }
        }
      },
      "FetchSmsMessagesRequest": {
        "type": "object",
        "properties": {
          "MessageID": {
            "type": "string",
            "description": "Everyware message identifier"
          },
          "FirstName": {
            "type": "string"
          },
          "LastName": {
            "type": "string"
          },
          "MobilePhone": {
            "type": "string",
            "description": "10 digits max, unformatted"
          },
          "IndividualID": {
            "type": "string"
          },
          "MessageExternalID": {
            "type": "string"
          },
          "StartDate": {
            "type": "string"
