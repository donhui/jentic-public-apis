            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "description": "Page of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 9999,
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "description": "Maximum number of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100,
              "default": 100
            }
          },
          {
            "in": "path",
            "name": "playerId",
            "description": "User ID of member to retrieve bounties for",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bounty progress for specified member",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groupId": {
                      "type": "string",
                      "description": "ID of the creator group"
                    },
                    "groupName": {
                      "type": "string",
                      "description": "Name of the creator group"
                    },
                    "currentPage": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Page number of response records returned",
                      "example": 1
                    },
                    "currentPageSize": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Page size used for this operation",
                      "example": 100
                    },
                    "totalCount": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Total number of progress records",
                      "example": 1
                    },
                    "memberId": {
                      "type": "string",
                      "example": "9jd7RBR_B2BZ0uWO3_lgv"
                    },
                    "playerId": {
                      "type": "string",
                      "example": "55d57cffaa074cc6b8d332f5d77661f2",
                      "description": "Unique identifier for this member's in-game user, set when linking with their Nexus account or generating the code"
                    },
                    "progress": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/BountyProgress"
                      },
                      "example": {
                        "id": "Hff_Zps6FFF0MZzmCsTr4",
                        "completed": false,
                        "completionCount": 1,
                        "lastProgressCheck": null,
                        "currentObjectiveGroupId": "adafsddggg",
                        "currentObjectives": [
                          {
                            "id": "XD3Xj13ss4Evkgyq7csCL",
                            "completed": false,
                            "count": 1,
                            "objective": {
                              "id": "m-OWRxs8qnSSny4THjT1R",
                              "name": "Refer a player that reaches level 20",
                              "count": 5,
                              "condition": "AND"
                            }
                          }
                        ],
                        "completedObjectives": [
                          {
                            "objectiveGroupId": "R2vbVWNC4SHhC2lk_QHsq",
                            "objectives": [
                              {
                                "id": "XD3Xj13ss4Evkgyq7csCT",
                                "completed": true,
                                "count": 5,
                                "objective": {
                                  "id": "m-OWRxs8qnSSny4THjT1R",
                                  "name": "Refer a player that reaches level 20",
                                  "count": 5,
                                  "condition": "AND"
                                }
                              }
                            ]
                          }
                        ],
                        "rewards": [
                          {
                            "id": "kCxr7lst7Ghk8n1o6DKEF",
                            "name": "In game Title",
                            "externalId": "dalfjka;sdlgjkda;l",
                            "rewardCompleted": true,
                            "rewardReferenceId": "adbda"
                          }
                        ],
                        "bounty": {
                          "id": "zaYan69O7icpHF0t2y0ul",
                          "name": "5 Referals reach level 20",
                          "limit": null
                        },
                        "member": {
                          "id": "9jd7RBR_B2BZ0uWO3_lgv",
                          "playerId": "55d57cffaa074cc6b8d332f5d77661f2",
                          "name": "PopcornFrog",
                          "codes": [
                            {
                              "code": "Popcornfrog",
                              "isPrimary": true,
                              "isGenerated": false,
                              "isManaged": false
                            }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BountyError"
                }
              }
            }
          }
        }
      }
    },
    "/complete-reward/{rewardId}": {
      "post": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "creator bounty rewards"
        ],
        "summary": "Mark a bounty reward as completed",
        "description": "If a referenceId is supplied, it will be included on the creator reward and visible to the creator. This is intended for them to use in a case where they need to contact the group owner about a given reward.",
        "operationId": "completeReward",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "rewardId",
            "description": "ID of the creator reward to mark as completed",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application-x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "referenceId": {
                    "type": "string",
                    "description": "The code representing the event to be logged",
                    "example": "55d57cffaa074cc6b8d332f5d77661f2"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bounty Reward marked completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BountyProgressReward"
                }
              }
            }
          },
          "404": {
            "description": "Bounty Reward not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BountyError"
                }
              }
            }
          }
        }
      }
    },
