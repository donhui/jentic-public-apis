      },
      "BountyError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "InvalidGroup",
              "CodeNotInGroup",
              "InvalidAuthCode",
              "ExpiredAuthCode",
              "ReferralNexusNotFound",
              "BountyNotFound",
              "MemberNotFound",
              "InvalidEventCode",
              "UnknownError"
            ],
            "description": "CodeNotInGroup: Creator group is private, and specified code is not linked to it<br/>\nInvalidGroup: No creator group was found with the specified groupId<br/>\nInvalidAuthCode: AuthCode provided is not valid<br/>\nExpiredAuthCode: AuchCode provided has expired<br/>\nReferralNexusNotFound: No Nexus was found to match the provided referral code<br/>\nBountyNotFound: No bounty was found with the specified bountyId<br/>\nCreatorNotFound: No creator found with the specified creatorId<br/>\nInvalidEventCode: No event found with the specifed event code\n"
          },
          "message": {
            "type": "string",
            "example": "Bounty Not found"
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "security": [
          {
            "PublicApiKeyAuth": []
          }
        ],
        "tags": [
          "monitor"
        ],
        "summary": "List bounties",
        "operationId": "getBounties",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "description": "Page of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 9999,
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "description": "Maximum number of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100,
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of bounties",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groupId": {
                      "type": "string",
                      "description": "ID of the creator group"
                    },
                    "groupName": {
                      "type": "string",
                      "description": "Name of the creator group"
                    },
                    "currentPage": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Page number of response records returned",
                      "example": 1
                    },
                    "currentPageSize": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Page size used for this operation",
                      "example": 100
                    },
                    "totalCount": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Total number of referrals",
                      "example": 1
                    },
                    "bounties": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Bounty"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BountyError"
                }
              }
            }
          }
        }
      }
    },
    "/{bountyId}": {
      "get": {
        "security": [
          {
            "VariableApiKeyAuth": []
          }
        ],
        "tags": [
          "monitor"
        ],
        "summary": "Retrieve information on a bounty. Progress information will only be included when using private key auth",
        "operationId": "getBounty",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "includeProgress",
            "description": "If false, bounty progress will not be included in the response. Ignored when using public key auth",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "in": "query",
            "name": "page",
            "description": "Page of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 9999,
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "description": "Maximum number of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100,
              "default": 100
            }
          },
          {
            "in": "path",
            "name": "bountyId",
            "description": "ID of bounty to retrieve",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Details of specified bounty",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groupId": {
                      "type": "string",
                      "description": "ID of the creator group"
                    },
                    "groupName": {
                      "type": "string",
                      "description": "Name of the creator group"
                    },
                    "bounty": {
                      "$ref": "#/components/schemas/Bounty"
                    },
                    "progress": {
                      "type": "object",
                      "properties": {
                        "currentPage": {
                          "type": "integer",
                          "format": "int32",
                          "description": "Page number of response records returned",
                          "example": 1
                        },
                        "currentPageSize": {
                          "type": "integer",
                          "format": "int32",
                          "description": "Page size used for this operation",
                          "example": 100
                        },
                        "totalCount": {
                          "type": "integer",
                          "format": "int32",
                          "description": "Total number of referrals",
                          "example": 1
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "allOf": [
                              {
                                "$ref": "#/components/schemas/BountyProgress"
                              },
                              {
                                "type": "object",
                                "properties": {
                                  "creator": {
                                    "$ref": "#/components/schemas/Creator"
                                  }
                                }
                              }
                            ]
                          }
                        }
