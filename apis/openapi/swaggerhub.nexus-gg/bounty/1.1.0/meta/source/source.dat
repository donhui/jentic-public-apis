    "/event/bulk/{bulkOperationId}": {
      "get": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "creator group events"
        ],
        "summary": "Get the status of a Create Event bulk operation",
        "operationId": "BulkPostEventStatus",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "bulkOperationId",
            "description": "ID of the bulk operation to check the status of",
