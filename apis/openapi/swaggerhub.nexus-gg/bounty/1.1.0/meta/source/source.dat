    "/event": {
      "post": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "creator group events"
        ],
        "summary": "Log an event occurence, by the event code",
        "description": "If a referralCode is supplied, this event will be counted toward completion of any bounty objectives requiring a referral event type. If the playerId matches the playerId of any creators that are in your referral program, this event will be counted toward completion of any bounty objective with a creator event type.",
        "operationId": "postEvent",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application-x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CreatorGroupEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "ID of the generated event",
                      "example": "yUFNyGTjrqJXokP13SFP_"
                    },
                    "referralCode": {
                      "type": "string",
                      "description": "Referral code the event was associated with"
                    },
                    "playerId": {
                      "type": "string",
                      "description": "Player ID the event was associated with"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Event has already been logged and is not repeatable"
          },
          "400": {
            "description": "bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BountyError"
                },
                "example": {
                  "code": "InvalidEventCode",
                  "message": "PlayerId is required"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Get all events for a creator group",
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "creator group events"
        ],
        "operationId": "getAllEvents",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "description": "Page of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 9999,
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "description": "Maximum number of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100,
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Results matching criteria",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groupId": {
                      "type": "string",
                      "description": "ID of the creator group"
                    },
                    "groupName": {
                      "type": "string",
                      "description": "Name of the creator group"
                    },
                    "currentPage": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Page number of response records returned",
                      "example": 1
                    },
                    "currentPageSize": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Page size used for this operation",
                      "example": 100
                    },
                    "totalCount": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Total number of events",
                      "example": 15
                    },
                    "events": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "description": "ID of the event"
                              },
                              "eventDate": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "eventCode": {
                                "type": "string",
                                "description": "Event code"
                              },
                              "playerId": {
                                "type": "string",
                                "description": "Unique identier of the in game user that triggered this event"
                              },
                              "referralCode": {
                                "type": "string",
                                "description": "Referral code used by the player that triggered this event"
                              },
                              "memberId": {
                                "type": "string",
                                "description": "ID of the member that this referralCode is associated with"
                              },
                              "memberPlayerId": {
                                "type": "string",
                                "description": "Unique identifier of the in game user that the referral code is associated with"
                              }
                            }
                          }
                        ]
                      },
                      "example": [
                        {
                          "id": "2ixlNNFdJh-9scoXek80w",
                          "eventDate": "2022-09-29T21:30:25.400Z",
                          "eventCode": "lvl20",
                          "playerId": "dt9NDZHcxwCXgo2fcmY4I",
                          "referralCode": "popcornfrog",
                          "memberId": "9jd7RBR_B2BZ0uWO3_lgv",
                          "memberPlayerId": "2ixlNNFdJh-9scoXek80w"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BountyError"
                }
              }
            }
          }
        }
      }
    },
