                      "type": "string"
                    },
                    "status": {
                      "type": "string",
                      "example": "complete, pending, or inProgress"
                    },
                    "startedAt": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "completedAt": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "message": {
                            "type": "string"
                          },
                          "operation": {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string"
                              },
                              "data": {
                                "$ref": "#/components/schemas/CreatorGroupEvent"
                              }
                            }
                          }
                        }
                      }
                    },
                    "log": {
                      "type": "array",
                      "items": {
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "ID of the generated event",
                            "example": "yUFNyGTjrqJXokP13SFP_"
                          },
                          "referralCode": {
                            "type": "string",
                            "description": "Referral code the event was associated with"
                          },
                          "playerId": {
                            "type": "string",
                            "description": "Player ID the event was associated with"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Bulk Operation not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BountyError"
                },
                "example": {
                  "code": "BulkOperationNotFound",
                  "message": "Bulk Event Operation with id: 491;daflkjgadj not found"
                }
              }
            }
          }
        }
      }
    },
