{
  "openapi": "3.0.0",
  "info": {
    "version": "1.1.0",
    "title": "Nexus.gg Bounty API",
    "description": "Nexus bounties allow you to reward your creators for their participation in the referral program",
    "contact": {
      "email": "engineering@nexus.gg"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/nexus-gg/Bounty/1.1.0/swagger.json"
  },
  "components": {
    "securitySchemes": {
      "PublicApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-SHARED-SECRET"
      },
      "PrivateApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-SHARED-SECRET"
      },
      "VariableApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-SHARED-SECRET",
        "description": "Can be either private or public key. Response will vary based upon the key used."
      }
    },
    "schemas": {
      "Bounty": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "XrEeF3CrtiSuz2xu8Y6O1"
          },
          "name": {
            "type": "string",
            "example": "Refer 5 players that reach level 20"
          },
          "description": {
            "type": "string",
            "example": "Refer 5 players that reach level 20 in Great Game and receive 200 IGC"
          },
          "imageSrc": {
            "type": "string",
            "example": "https://cdn.nexus.gg/CsRKC8uD0NLtyQ0LOt8Ru/images/profile-image.jpg"
          },
          "rewardDescription": {
            "type": "string",
            "example": "200 IGC",
            "description": "Text describing the reward for this bounty"
          },
          "limit": {
            "type": "number",
            "example": 5,
            "description": "How many time a creator can complete this bounty"
          },
          "startsAt": {
            "type": "string",
            "format": "date-time",
            "example": "2023-01-02T16:24:22.931Z"
          },
          "endsAt": {
            "type": "string",
            "format": "date-time",
            "example": "2023-01-02T16:24:22.931Z"
          },
          "lastProgressCheck": {
            "type": "string",
            "format": "date-time",
            "example": "2023-01-02T16:24:22.931Z"
          },
          "objectives": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BountyObjective"
            }
          },
          "rewards": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BountyReward"
            }
          },
          "dependants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "TAMiHCZtHaAle78ArHJva"
                },
                "name": {
                  "type": "string",
                  "example": "Refer 5 Players"
                }
              }
            }
          },
          "prerequisites": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "Ev-vRz88frq0RSxp51VP3"
                },
                "name": {
                  "type": "string",
                  "example": "Refer 5 Players"
                }
              }
            }
          }
        }
      },
      "BountySku": {
        "type": "object",
        "description": "Sku",
        "properties": {
          "id": {
            "type": "string",
            "example": "b5ajhvFLV4icmACR9KeG1"
          },
          "name": {
            "type": "string",
            "example": "Great Game 200 IGC"
          },
          "slug": {
            "type": "string",
            "example": "great-game-200-igc"
          }
        }
      },
      "BountyObjective": {
        "type": "object",
        "description": "A requirement for completing a bounty",
        "properties": {
          "id": {
            "type": "string",
            "example": "CsRKC8uD0NLtyQ0LOt8Ru"
          },
          "name": {
            "type": "string",
            "example": "Refer a player that reaches level 20"
          },
          "type": {
            "type": "string",
            "enum": [
              "Event",
              "Referral",
              "NexusPurchase"
            ],
            "example": "Event"
          },
          "condition": {
            "type": "string",
            "enum": [
              "AND",
              "OR"
            ],
            "example": "AND",
            "description": "All objectives with \"AND\" are required for bounty completion. Only one objective with \"OR\" is required. If objective 1, 2, and 3 are all \"AND\" condition and objective 4 and 5 are \"OR\" condition, the bounty will be considered complete when 1, 2, 3, and either 4 or 5 are completed."
          },
          "count": {
            "type": "number",
            "example": 5
          },
          "eventType": {
            "type": "string",
            "enum": [
              "Referral",
              "Creator"
            ],
            "example": "Referral",
            "description": "Only applies to objectives with type \"Event\". This field specifies whether an event counted toward this objective should originate from the creator's in game user or from a user that is a referral of the creator."
          },
          "eventCode": {
            "type": "string",
            "example": "reachLevel20",
            "description": "Event code that is counted toward this bounty."
          },
          "nexusPurchaseObjectiveType": {
            "type": "string",
            "enum": [
              "Category",
              "Publisher",
              "Sku"
            ],
            "example": "Publisher",
            "description": "Only applies to objectives with type \"NexusPurchase\". This field specifies is used to determine which purchases will count toward the objective. \"Category\" means that any sku purchased with a specific will count (all microtransactions for a specific game would have the same category, for example). \"Publisher\" means that any skus belonging to a specific publisher will count. \"Sku\" means that a specific list of skus will apply to this objective."
          },
          "skus": {
            "type": "array",
            "description": "Only applies to objectives with the type \"NexusPurchase\" and nexusPurchaseObjectiveType \"Sku\"",
            "items": {
              "$ref": "#/components/schemas/BountySku"
            }
          },
          "category": {
            "description": "Only applies to objectives with the type \"NexusPurchase\" and nexusPurchaseObjectiveType \"Category\"",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "DYxdHsSLsVziD1dJ_TR0w"
              },
              "name": {
                "type": "string",
                "example": "Great Game"
              },
              "slug": {
                "type": "string",
                "example": "great-game"
              }
            }
          },
          "publisher": {
            "description": "Only applies to objectives with the type \"NexusPurchase\" and nexusPurchaseObjectiveType \"Publisher\"",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "sRee30J5v6cXNYqsyTfbb"
              },
              "name": {
                "type": "string",
                "example": "Great Game Publishing"
              }
            }
          }
        }
      },
      "BountyReward": {
        "type": "object",
        "description": "A reward to be granted upon completion of a bounty",
        "properties": {
          "id": {
            "type": "string",
            "example": "2Qw7VPSYk1Me7o6huoXwl"
          },
          "name": {
            "type": "string",
            "example": "200 In-Game currency"
          },
          "type": {
            "type": "string",
            "enum": [
              "Sku",
              "Payment",
              "External"
            ],
            "example": "Sku",
            "description": "A reward of type \"Sku\" will provide the creator with a key that can be redeemed in steam, in game, etc. \"Payment\" will result in the creator being paid a specified amount of currency. \"External\" means the reward should be not be provided by nexus. When a bounty is completed with an \"External\" reward, a message is sent to the bounty webhook. This API also may be used to mark a \"External\" reward as completed and associate it with a reference ID."
          },
          "sku": {
            "description": "Only applies to rewards with type \"Sku\"",
            "$ref": "#/components/schemas/BountySku"
          },
          "amount": {
            "type": "number",
            "example": 5,
            "description": "Amount of currency to be applied to a \"Payment\" type or the quantity of a \"Sku\""
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "externalId": {
            "type": "string",
            "description": "Unique identifier intended to map this reward to something in the external reward provider's system"
          }
        }
      },
      "BountyProgress": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "ePIWtwm6XnH1lqSpXeKo_"
          },
          "completed": {
            "type": "boolean",
            "example": false,
            "description": "Whether the creator has completed this bounty. Bounties will not be considered completed until the completion limit has been reached"
          },
          "completionCount": {
            "type": "number",
            "example": 3
          },
          "lastProgressCheck": {
            "type": "string",
            "format": "date-time"
          },
          "currentObjectiveGroupId": {
            "type": "string",
            "example": "Hd6zrUid8ulc0boV5Z5ws"
          },
          "currentObjectives": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BountyObjectiveProgress"
            }
          },
          "completedObjectives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "objectiveGroupId": {
                  "type": "string",
                  "example": "R2vbVWNC4SHhC2lk_QHsq"
                },
                "objectives": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BountyObjectiveProgress"
                  }
                },
                "rewards": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BountyProgressReward"
                  }
                }
              }
            }
          },
          "member": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "9jd7RBR_B2BZ0uWO3_lgv"
              },
              "playerId": {
                "type": "string",
                "example": "55d57cffaa074cc6b8d332f5d77661f2",
                "description": "Unique identifier for this member's in-game user, set when linking with their Nexus account or generating the code"
              },
              "name": {
                "type": "string",
                "example": "PopcornFrog"
              },
              "codes": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Code"
                }
              }
            }
          }
        }
      },
      "Code": {
        "type": "object",
        "description": "A group member's code which is used as their storefront URL and when creating transactions or referrals",
        "properties": {
          "code": {
            "type": "string",
            "example": "samzorz"
          },
          "isPrimary": {
            "type": "boolean",
            "description": "Indicates whether or not this is the primary code for this member.",
            "example": true
          },
          "isGenerated": {
            "type": "boolean",
            "description": "Indicates whether or not this is a code that you generated.",
            "example": false
          },
          "isManaged": {
            "type": "boolean",
            "description": "Indicates whether or not this is a code that you manage. Once a code that you generated has been linked to a Nexus account, it will no longer be considered managed.",
            "example": false
          }
        }
      },
      "BountyObjectiveProgress": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "T4h8O0p2aOakYG0WhBTEN"
          },
          "completed": {
            "type": "boolean",
            "example": false
          },
          "count": {
            "type": "number",
            "example": 1
          },
          "objective": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "U3NIDcqNIgiG9S9mfmN4H"
              },
              "name": {
                "type": "string",
                "example": "Refer a player that reaches level 20"
              },
              "count": {
                "type": "number",
                "example": 5
              },
              "condition": {
                "type": "string",
                "enum": [
                  "AND",
                  "OR"
                ],
                "example": "AND"
              }
            }
          }
        }
      },
      "BountyProgressReward": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "XD3Xj13ss4Evkgyq7csCL"
          },
          "name": {
            "type": "string",
            "example": "Great Game 200 IGC"
          },
          "externalId": {
            "type": "string"
          },
          "rewardCompleted": {
            "type": "boolean"
          },
          "rewardReferenceId": {
            "type": "string",
            "description": "Reference ID that was provided when this reward was marked as completed by the external provider"
          }
        }
      },
      "Creator": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "9jd7RBR_B2BZ0uWO3_lgv"
          },
          "playerId": {
            "type": "string",
            "example": "55d57cffaa074cc6b8d332f5d77661f2",
            "description": "Unique identifier for this creator's in-game user, set when linking with their Nexus account or generating the Referral code"
          },
          "name": {
            "type": "string",
            "example": "PopcornFrog"
          },
          "slugs": {
            "type": "array",
            "items": {
              "type": "string",
              "example": [
                "popcornfrog",
                "dlfkjab-do"
              ]
            }
          }
        }
      },
      "CreatorGroupEvent": {
        "type": "object",
        "properties": {
          "eventCode": {
            "type": "string",
            "description": "The code representing the event to be logged",
            "example": "reachLevel20"
          },
          "playerId": {
            "type": "string",
            "description": "Unique id of the player that the event pertains to"
          },
          "referralCode": {
            "type": "string",
            "description": "Optional code for the creator that referred this user",
            "example": "popcornfrog"
          }
        },
        "required": [
          "eventCode",
          "playerId"
        ]
      },
      "Currency": {
        "type": "string",
        "enum": [
          "AED",
          "AFN",
          "ALL",
          "AMD",
          "ANG",
          "AOA",
          "ARS",
          "AUD",
          "AWG",
          "AZN",
          "BAM",
          "BBD",
          "BDT",
          "BGN",
          "BHD",
          "BIF",
          "BMD",
          "BND",
          "BOB",
          "BRL",
          "BSD",
          "BTC",
          "BTN",
          "BWP",
          "BYN",
