                            "description": "Whether the creator has been paid for this transaction"
                          },
                          "subtotal": {
                            "type": "number",
                            "format": "cents",
                            "example": 999
                          },
                          "currency": {
                            "type": "string"
                          },
                          "total": {
                            "type": "number",
                            "format": "cents",
                            "example": 999
                          },
                          "totalCurrency": {
                            "type": "string"
                          },
                          "memberShareAmount": {
                            "type": "number",
                            "description": "Amount of the transaction that went to the member"
                          },
                          "memberSharePercent": {
