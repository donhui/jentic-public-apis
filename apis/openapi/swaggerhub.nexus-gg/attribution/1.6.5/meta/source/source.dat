{
  "openapi": "3.0.0",
  "components": {
    "securitySchemes": {
      "PublicApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-SHARED-SECRET"
      },
      "PrivateApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-SHARED-SECRET"
      }
    },
    "schemas": {
      "Code": {
        "type": "object",
        "description": "A group member's code which is used as their storefront URL and when creating transactions or referrals",
        "properties": {
          "code": {
            "type": "string",
            "example": "samzorz"
          },
          "isPrimary": {
            "type": "boolean",
            "description": "Indicates whether or not this is the primary code for this member.",
            "example": true
          },
          "isGenerated": {
            "type": "boolean",
            "description": "Indicates whether or not this is a code that you generated.",
            "example": false
          },
          "isManaged": {
            "type": "boolean",
            "description": "Indicates whether or not this is a code that you manage. Once a code that you generated has been linked to a Nexus account, it will no longer be considered managed.",
            "example": false
          }
        }
      },
      "Currency": {
        "type": "string",
        "enum": [
          "AED",
          "AFN",
          "ALL",
          "AMD",
          "ANG",
          "AOA",
          "ARS",
          "AUD",
          "AWG",
          "AZN",
          "BAM",
          "BBD",
          "BDT",
          "BGN",
          "BHD",
          "BIF",
          "BMD",
          "BND",
          "BOB",
          "BRL",
          "BSD",
          "BTC",
          "BTN",
          "BWP",
          "BYN",
          "BYR",
          "BZD",
          "CAD",
          "CDF",
          "CHF",
          "CLF",
          "CLP",
          "CNY",
          "COP",
          "CRC",
          "CUC",
          "CUP",
          "CVE",
          "CZK",
          "DJF",
          "DKK",
          "DOP",
          "DZD",
          "EGP",
          "ERN",
          "ETB",
          "EUR",
          "FJD",
          "FKP",
          "GBP",
          "GEL",
          "GGP",
          "GHS",
          "GIP",
          "GMD",
          "GNF",
          "GTQ",
          "GYD",
          "HKD",
          "HNL",
          "HRK",
          "HTG",
          "HUF",
          "IDR",
          "ILS",
          "IMP",
          "INR",
          "IQD",
          "IRR",
          "ISK",
          "JEP",
          "JMD",
          "JOD",
          "JPY",
          "KES",
          "KGS",
          "KHR",
          "KMF",
          "KPW",
          "KRW",
          "KWD",
          "KYD",
          "KZT",
          "LAK",
          "LBP",
          "LKR",
          "LRD",
          "LSL",
          "LTL",
          "LVL",
          "LYD",
          "MAD",
          "MDL",
          "MGA",
          "MKD",
          "MMK",
          "MNT",
          "MOP",
          "MRO",
          "MUR",
          "MVR",
          "MWK",
          "MXN",
          "MYR",
          "MZN",
          "NAD",
          "NGN",
          "NIO",
          "NOK",
          "NPR",
          "NZD",
          "OMR",
          "PAB",
          "PEN",
          "PGK",
          "PHP",
          "PKR",
          "PLN",
          "PYG",
          "QAR",
          "RON",
          "RSD",
          "RUB",
          "RWF",
          "SAR",
          "SBD",
          "SCR",
          "SDG",
          "SEK",
          "SGD",
          "SHP",
          "SLL",
          "SOS",
          "SRD",
          "STD",
          "SVC",
          "SYP",
          "SZL",
          "THB",
          "TJS",
          "TMT",
          "TND",
          "TOP",
          "TRY",
          "TTD",
          "TWD",
          "TZS",
          "UAH",
          "UGX",
          "USD",
          "UYU",
          "UZS",
          "VEF",
          "VND",
          "VUV",
          "WST",
          "XAF",
          "XAG",
          "XAU",
          "XCD",
          "XDR",
          "XOF",
          "XPF",
          "YER",
          "ZAR",
          "ZMK",
          "ZMW",
          "ZWL"
        ],
        "example": "USD"
      },
      "Metrics": {
        "type": "object",
        "description": "Metrics are optional but will allow Nexus to provide useful statistics about your program",
        "properties": {
          "joinDate": {
            "type": "string",
            "format": "date-time",
            "example": "2017-07-22T17:32:28Z",
            "description": "The date that the player joined your game"
          },
          "conversion": {
            "description": "Conversion metrics are used for calculationg the conversion rate of your customers. Only one of lastPurchaseDate or totalSpendToDate are required. lastPurchaseDate is preferred, but totalSpendToDate can be used if not available",
            "type": "object",
            "properties": {
              "lastPurchase": {
                "type": "object",
                "properties": {
                  "date": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2017-07-22T17:32:28Z"
                  },
                  "platform": {
                    "type": "string",
                    "example": "Android",
                    "description": "The platform where the last purchase was made"
                  }
                }
              },
              "totalSpendToDate": {
                "type": "object",
                "properties": {
                  "total": {
                    "type": "number",
                    "example": 129.99
                  },
                  "currency": {
                    "$ref": "#/components/schemas/Currency",
                    "example": "USD"
                  }
                },
                "required": [
                  "total",
                  "currency"
                ]
              }
            }
          }
        }
      },
      "Transaction": {
        "type": "object",
        "required": [
          "code",
          "currency",
          "description",
          "subtotal",
          "transactionDate",
          "transactionId"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "2ixlNNFdJh-9scoXek80w"
          },
          "code": {
            "type": "string",
            "example": "popcornfrog",
            "description": "The code this transaction should be attributed to"
          },
          "memberPlayerId": {
            "type": "string",
            "example": "yourUniqueIdentifier1",
            "description": "Your internal identifier for this member, which is set when generating a code or through linking a Nexus account."
          },
          "description": {
            "type": "string",
            "example": "1000 gems"
          },
          "status": {
            "type": "string",
            "enum": [
              "Normal",
              "Fraud",
              "Refund",
              "Chargeback"
            ]
          },
          "subtotal": {
            "type": "number",
            "format": "cents",
            "example": 999
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "total": {
            "type": "number",
            "format": "cents",
            "example": 999
          },
          "totalCurrency": {
            "$ref": "#/components/schemas/Currency"
          },
          "transactionId": {
            "type": "string",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0851"
          },
          "transactionDate": {
            "type": "string",
            "format": "date-time",
            "example": "2017-07-22T17:32:28Z"
          },
          "platform": {
            "type": "string",
            "enum": [
              "PC",
              "PlayStation",
              "Xbox",
              "Switch",
              "Apple",
              "Android",
              "VR"
            ]
          },
          "playerId": {
            "type": "string",
            "example": "12345"
          },
          "playerName": {
            "type": "string",
            "example": "dustywusty"
          },
          "metrics": {
            "$ref": "#/components/schemas/Metrics"
          },
          "memberShareAmount": {
            "description": "The amount that the member received for this transaction. This will not be specified upon initial transaction creation, as the calculation happens in a separate process.",
            "type": "number",
            "example": 1
          },
          "memberSharePercent": {
            "description": "The percent of the subtotal for this transaction that the member received. if a memberSharePercent is provided upon transaction creation, it will always be used. Otherwise, the percent a member receives will be influenced by factors such as the default group setting, member tier, scheduled revenue shares, spcific skus",
            "type": "number",
            "example": 10,
            "minimum": 1,
            "maximum": 100
          },
          "memberPaid": {
            "type": "boolean",
            "example": false
          },
          "skuId": {
            "type": "string",
            "example": "Hv98bvRCSm1jDDPhls1qC",
            "description": "Your internal ID for the item that was purchased"
          }
        }
      },
      "Member": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "CsRKC8uD0NLtyQ0LOt8Ru"
          },
          "name": {
            "type": "string",
            "example": "samzorz"
          },
          "playerId": {
            "type": "string",
            "description": "Your unique identifier for this user or player, provided when the code was created or when an existing nexus was linked to one of your user accounts"
          },
          "playerMetadata": {
            "$ref": "#/components/schemas/PlayerMetadata"
          },
          "logoImage": {
            "type": "string",
            "example": "https://cdn.nexus.gg/CsRKC8uD0NLtyQ0LOt8Ru/images/logo-image.jpg"
          },
          "profileImage": {
            "type": "string",
            "example": "https://cdn.nexus.gg/CsRKC8uD0NLtyQ0LOt8Ru/images/profile-image.jpg"
          },
          "codes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Code"
            }
          }
        }
      },
      "PlayerMetadata": {
        "type": "object",
        "description": "Additional player information to be applied to this member (such as their in game display name)",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "The players in game display name",
            "example": "Popcorn Frog"
          }
        }
      },
      "CreatorGroup": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "My Super Cool Game 2"
          },
          "id": {
            "type": "string",
            "example": "AJ9OPrEFt4AAVJcA"
          },
          "isDefault": {
            "type": "boolean",
            "example": true,
            "description": "Specifies whether this is the default group for your creator program. The default group will be used in all API requests unless a groupId query parameter is specified"
          }
        }
      },
      "ScheduledRevShare": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "dc5_phCpboQM8bnJel9Nj"
          },
          "revShare": {
            "type": "number",
            "example": 20
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "example": "2023-06-21T15:00:00.000Z"
          },
          "endDate": {
            "type": "string",
            "format": "date-time",
            "example": "2023-06-23T15:00:00.000Z"
          },
          "groupId": {
            "type": "string",
            "example": "AJ9OPrEFt4AAVJcA"
          },
          "groupName": {
            "type": "string",
            "example": "My Super Cool Game 2"
          },
          "tierRevenueShares": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TierRevenueShare"
            }
          }
        }
      },
      "CreatorGroupTier": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "PGUeDx1h9dB5_-Or-CtJO"
          },
          "name": {
            "type": "string",
            "example": "Silver"
          },
          "revShare": {
            "type": "number",
            "example": 20
          },
          "memberCount": {
            "type": "number",
            "example": 10
          }
        }
      },
      "TierRevenueShare": {
        "type": "object",
        "properties": {
          "revShare": {
            "type": "number",
            "example": 20
          },
          "tierId": {
            "type": "string",
            "example": "PGUeDx1h9dB5_-Or-CtJO"
          },
          "tierName": {
            "type": "string",
            "example": "Silver"
          }
        }
      },
      "APIError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "InvalidGroup",
              "CodeNotInGroup",
              "InvalidAuthCode",
              "ExpiredAuthCode",
              "NexusNotFound",
              "PlayerNotInGroup",
              "UnknownError",
              "PlayerAlreadyLinked",
              "MemberAlreadyLinked"
            ],
            "description": "CodeNotInGroup: Creator group is private, and specified code is not linked to it<br />\nInvalidGroup: No creator group was found with the specified groupId<br/>\nInvalidAuthCode: AuthCode provided is not valid or the nexus it represents is not a member of your program<br/>\nExpiredAuthCode: AuchCode provided has expired<br/>\nNexusNotFound: No Nexus was found to match the provided code<br/>\nPlayerNotInGroup: No group member found for the given playerId<br/>\nPlayerAlreadyLinked: The playerId provided has already been linked with a group member<br/>\nMemberAlreadyLinked: The nexus represented by the auth code specified is already a member of your group and has been linked with a different playerId.\n"
          },
          "message": {
            "type": "string",
            "example": "Invalid Group ID"
          }
        }
      }
    }
  },
  "info": {
    "description": "Seamlessly integrate the Nexus creator program into your native checkout process",
    "version": "1.6.5",
    "title": "Nexus.gg Creator Program API",
    "contact": {
      "email": "engineering@nexus.gg"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/nexus-gg/Attribution/1.6.5/swagger.json"
  },
  "paths": {
    "/manage/groups": {
      "get": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "group management"
        ],
        "summary": "Get creator groups and their group ids",
        "description": "**NOTE**: This method uses **private authentication** API keys and should never be called from or embedded into the gaming client. These routes should ONLY be accessed from your back-end services.<br/><br/>**NOTE**: Groups are used in cases where a publisher may have multiple titles w/ different groups of creators for each title.",
        "operationId": "getCreatorGroups",
        "responses": {
          "200": {
            "description": "search results matching criteria",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groups": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CreatorGroup"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/manage/members": {
      "get": {
        "security": [
          {
            "PublicApiKeyAuth": []
          }
        ],
        "tags": [
          "member management"
        ],
        "summary": "Return all members of a group and their member details, including unique id and code",
        "description": "**NOTE**: This method uses **public authentication** API keys and can be called from and embedded into game clients.",
        "operationId": "getMembers",
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "description": "page of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 9999
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "description": "maximum number of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "in": "query",
            "name": "groupId",
            "description": "Return members from a specific group. If not specified, the default group will be used",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "search results matching criteria",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groupId": {
                      "type": "string",
                      "description": "ID of the creator group"
                    },
                    "groupName": {
                      "type": "string",
                      "description": "Name of the creator group"
                    },
                    "groupDefaultRevShare": {
                      "type": "number",
                      "description": "Default revenue share percent for the creator group",
                      "example": 10
                    },
                    "codeTTLInDays": {
                      "type": "number",
                      "description": "TTL defined for the creator group",
                      "example": 90
                    },
                    "currentPage": {
                      "type": "integer",
                      "format": "int32",
                      "example": 1
                    },
                    "currentPageSize": {
                      "type": "integer",
                      "format": "int32",
                      "example": 100
                    },
                    "totalCount": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Total number of referrals",
                      "example": 15
                    },
                    "members": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Member"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      },
      "post": {
        "summary": "Generate a code for a player. If the playerId specified has already been linked with a nexus in your group, a code will be generated for that nexus. Otherwise, the generated code will be managed by you until claimed by a nexus user, through the link workflow.",
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "member management"
        ],
        "operationId": "generateMember",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "playerId": {
                    "type": "string",
                    "description": "Unique identifier for user the code will be associated with"
                  }
                },
                "required": [
                  "code"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Code that was created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groupId": {
                      "type": "string",
                      "description": "ID of the creator group"
                    },
                    "groupName": {
                      "type": "string",
                      "description": "Name of the creator group"
                    },
                    "playerId": {
                      "type": "string",
                      "description": "Unique Identifier provided when this code was created"
                    },
                    "code": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIError"
                }
              }
            }
          }
        }
      }
    },
    "/manage/members/{memberCode}": {
      "get": {
        "security": [
          {
            "PublicApiKeyAuth": []
          }
        ],
        "tags": [
          "member management"
        ],
        "summary": "Get a member and their details by code",
        "description": "**NOTE**: This method uses **public authentication** API keys and can be called from and embedded into game clients.",
        "operationId": "getMemberByCode",
        "parameters": [
          {
            "name": "memberCode",
            "in": "path",
            "description": "Member's code",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "member object for given code",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "properties": {
                        "groupId": {
                          "type": "string",
                          "description": "ID of the creator group"
                        },
                        "groupName": {
                          "type": "string",
                          "description": "Name of the creator group"
                        },
                        "groupDefaultRevShare": {
                          "type": "number",
                          "description": "Default revenue share percent for the creator group",
                          "example": 10
                        },
                        "codeTTLInDays": {
                          "type": "number",
                          "description": "TTL defined for the creator group",
                          "example": 90
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/Member"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "not found"
          }
        }
      }
    },
    "/manage/members/id/{memberId}": {
      "get": {
        "security": [
          {
            "PublicApiKeyAuth": []
          }
        ],
        "tags": [
          "member management"
        ],
        "summary": "Get a member and their details by member id",
        "description": "**NOTE**: This method uses **public authentication** API keys and can be called from and embedded into game clients.",
        "operationId": "getMemberById",
        "parameters": [
          {
            "name": "memberId",
            "in": "path",
            "description": "Member's Id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "member object for given id",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "properties": {
                        "groupId": {
                          "type": "string",
                          "description": "ID of the creator group"
                        },
                        "groupName": {
                          "type": "string",
                          "description": "Name of the creator group"
                        },
                        "groupDefaultRevShare": {
                          "type": "number",
                          "description": "Default revenue share percent for the creator group",
                          "example": 10
                        },
                        "codeTTLInDays": {
                          "type": "number",
                          "description": "TTL defined for the creator group",
                          "example": 90
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/Member"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "not found"
          }
        }
      }
    },
    "/manage/members/player/{playerId}": {
      "get": {
        "security": [
          {
            "PublicApiKeyAuth": []
          }
        ],
        "tags": [
          "member management"
        ],
        "summary": "Get a member and their details by your internal playerId",
        "description": "**NOTE**: This method uses **public authentication** API keys and can be called from and embedded into game clients.",
        "operationId": "getMemberByPlayerId",
        "parameters": [
          {
            "name": "playerId",
            "in": "path",
            "description": "Member player id. This is your internal unique identifier that was used to create this code or when linking to a Nexus.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "groupId",
            "description": "Creator group to use for this operation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "member object for given playerId",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "properties": {
                        "groupId": {
                          "type": "string",
                          "description": "ID of the creator group"
                        },
                        "groupName": {
                          "type": "string",
                          "description": "Name of the creator group"
                        },
                        "groupDefaultRevShare": {
                          "type": "number",
                          "description": "Default revenue share percent for the creator group",
                          "example": 10
                        },
                        "codeTTLInDays": {
                          "type": "number",
                          "example": 90
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/Member"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "not found"
          }
        }
      }
    },
