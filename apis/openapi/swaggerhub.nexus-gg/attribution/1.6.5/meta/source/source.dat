    "/manage/scheduled-rev-shares": {
      "get": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "scheduled revenue share management"
        ],
        "summary": "Get scheduled rev shares for a group.",
        "description": "**NOTE**: This method uses **private authentication** API keys and should never be called from or embedded into the gaming client. These routes should ONLY be accessed from your back-end services.<br/><br/>**NOTE**: Between the dates specified, a scheduled rev share will be used in place of the default rev share for a group.",
        "operationId": "getScheduledRevShares",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "ID of the group for which to retrieve scheduled rev shares. If not specified, the default group will be used",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "description": "page of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 9999
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "description": "maximum number of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "list of scheduled rev shares for the specified group",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "groupId": {
                      "type": "string",
                      "example": "AJ9OPrEFt4AAVJcA"
                    },
                    "groupName": {
                      "type": "string",
                      "example": "My Super Cool Game 2"
                    },
                    "currentPage": {
                      "type": "integer",
                      "format": "int32",
                      "example": 1
                    },
                    "currentPageSize": {
                      "type": "integer",
                      "format": "int32",
                      "example": 100
                    },
                    "totalCount": {
                      "type": "integer",
                      "format": "int32",
                      "example": 1
                    },
                    "scheduledRevShares": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          {
                            "$ref": "#/components/schemas/ScheduledRevShare"
                          },
                          {
                            "properties": {
                              "status": {
                                "type": "string",
                                "description": "Current status of the scheduled rev share (Active, Scheduled, or Ended)",
                                "example": "Active"
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      },
      "post": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "scheduled revenue share management"
        ],
        "summary": "Schedule a temporary rev share change for a group",
        "description": "**NOTE**: This method uses **private authentication** API keys and should never be called from or embedded into the gaming client. These routes should ONLY be accessed from your back-end services.<br/><br/>**NOTE**:  Between the dates specified, a scheduled rev share will be used in place of the default rev share for a group.",
        "operationId": "createScheduledRevShare",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "ID of the group for which to retrieve scheduled rev shares. If not specified, the default group will be used",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "revShare": {
                    "type": "number",
                    "example": 15
                  },
                  "startDate": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2023-06-21T15:00:00.000Z",
                    "description": "NOTE: Start Date should be in UTC"
                  },
                  "endDate": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2023-06-23T15:00:00.000Z",
                    "description": "NOTE: End Date should be in UTC"
                  },
                  "tierRevenueShares": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "revShare": {
                          "type": "number",
                          "example": 20
                        },
                        "tierId": {
                          "type": "string",
                          "example": "PGUeDx1h9dB5_-Or-CtJO"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scheduled rev share that was created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduledRevShare"
                }
              }
            }
          },
          "404": {
            "description": "Creator group not found"
          },
          "400": {
            "description": "Invalid request body or end date is before start date"
          },
          "409": {
            "description": "There is a conflicting scheduled rev share (only one schedule may be active at a time)"
          }
        }
      }
    },
    "/manage/scheduled-rev-shares/{scheduledRevShareId}": {
      "put": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "scheduled revenue share management"
        ],
        "summary": "Edit a scheduled rev share",
        "description": "**NOTE**: This method uses **private authentication** API keys and should never be called from or embedded into the gaming client. These routes should ONLY be accessed from your back-end services.",
        "operationId": "updateScheduledRevShare",
        "parameters": [
          {
            "in": "path",
            "name": "scheduledRevShareId",
            "description": "ID of the scheduled rev share to edit",
