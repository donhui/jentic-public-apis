    "/attributions/transactions": {
      "post": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "attribution transactions"
        ],
        "summary": "Create a new sale attributed to a member",
        "description": "**NOTE**: This method uses **private authentication** API keys and should never be called from or embedded into the gaming client. These routes should ONLY be accessed from your back-end services.<br/><br />**NOTE**: The subtotal passed for a transaction will be in the smallest denomination of the currency. For example, cents would be used for USD. $9.99 would be a subtotal of 999 cents.<br /><br />Multiple transactions with the same transactionId may only be created within the same POST (in the case of attributing the same purchase to multiple group members).",
        "operationId": "creatorAttribution",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Attribute to a specific group",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "This route accepts a single transaction or an array of transactions.",
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "allOf": [
                      {
                        "properties": {
                          "playerName": {
                            "type": "string",
                            "example": "dustywusty"
                          }
                        }
                      },
                      {
                        "$ref": "#/components/schemas/Transaction"
                      }
                    ]
                  },
                  {
                    "type": "array",
                    "items": {
                      "allOf": [
                        {
                          "properties": {
                            "playerName": {
                              "type": "string",
                              "example": "dustywusty"
                            }
                          }
                        },
                        {
                          "$ref": "#/components/schemas/Transaction"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction created. Returns either a single transaction or an array if more than one was included in the request body.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "transaction": {
                          "$ref": "#/components/schemas/Transaction"
                        }
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "transaction": {
                            "$ref": "#/components/schemas/Transaction"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid input, object invalid, code not found in group members"
          },
          "409": {
            "description": "A transaction with this transactionId already exists"
          }
        }
      },
      "get": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "attribution transactions"
        ],
        "summary": "Retrieve Transactions",
        "description": "If multiple member filters are included, only one will be used. If multiple are passed the following order precedence will be used: playerId -> memberId -> providerId -> code.<br/><br/>**NOTE**: This method uses **private authentication** API keys and should never be called from or embedded into the gaming client. These routes should ONLY be accessed from your back-end services.",
        "operationId": "getBulkAttributions",
        "parameters": [
          {
            "in": "query",
            "name": "groupId",
            "description": "Group to retrieve transactions for",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "description": "Maximum number of records to return",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "default": 500,
              "maximum": 1000
            }
          },
          {
            "in": "query",
            "name": "cursor",
            "description": "Cursor for the page of transactions to be returned. Changing query parameters when using a cursor will result in an error.",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "description": "Page of records to return. Not recommended, as it disables cursor pagination when specified.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 9999
            }
          },
          {
            "in": "query",
            "name": "startDate",
            "description": "NOTE: Start Date should be in UTC",
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2023-06-23T15:00:00.000Z"
            }
          },
          {
            "in": "query",
            "name": "endDate",
            "description": "NOTE: End Date should be in UTC",
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2023-07-23T15:00:00.000Z"
            }
          },
          {
            "in": "query",
            "name": "origin",
            "description": "Origin(s) to include.",
            "example": "origin=api&origin=webshopCode or origin=api,webshopCode",
            "schema": {
              "type": "string",
              "enum": [
                "api",
                "webshopCode",
                "storefrontCode"
              ]
            }
          },
          {
            "in": "query",
            "name": "status",
            "description": "Transaction statuses to include.",
            "schema": {
              "type": "string",
              "enum": [
                "normal",
                "refund",
                "fraud",
                "chargeback",
                "test"
              ]
            }
          },
          {
            "in": "query",
            "name": "code",
            "description": "Filter transactions by creator code",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "codeScope",
            "description": "Only used when code filtering is used. Member scope will return all transactions for the member associated with the specified code (even if they have multiple codes). Code scope will return only transactions with the specified code.",
            "schema": {
              "type": "string",
              "enum": [
                "member",
                "code"
              ]
            }
          },
          {
            "in": "query",
            "name": "memberId",
            "description": "Filter by member ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "playerId",
            "description": "Filter by your internal user/player ID for this member",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "providerId",
            "description": "Filter a member with a specific OAUTH provider ID, such as twitch or youtube",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "sort",
            "description": "Property and sort direction. Format: { property }:{ asc or desc }. Valid properties: transactionDate.",
            "example": "sort=transactionDate:desc",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns all transactions within the specified filters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "currentPage": {
                      "description": "Current page of the returned response (only included when cursor pagination is disabled)",
                      "type": "number"
                    },
                    "currentPageSize": {
                      "description": "Page size used in this request",
                      "type": "number"
                    },
                    "totalCount": {
                      "description": "Total number of records found",
                      "type": "number"
                    },
                    "nextCursor": {
                      "description": "Cursor used to retrieve the next set of records from this query",
                      "type": "string"
                    },
                    "transactions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Nexus's generated id for this transaction"
                          },
                          "code": {
                            "type": "string",
                            "description": "Code provided for this transaction"
                          },
                          "transactionId": {
                            "type": "string",
                            "description": "TransactionId provided for this transaction"
                          },
                          "transactionDate": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "transactionStatus": {
                            "type": "string",
                            "enum": [
                              "Normal",
                              "Fraud",
                              "Refund",
                              "Chargeback"
                            ]
                          },
                          "creatorPaid": {
                            "type": "boolean",
                            "description": "Whether the creator has been paid for this transaction"
                          },
                          "subtotal": {
                            "type": "number",
                            "format": "cents",
                            "example": 999
                          },
                          "currency": {
                            "type": "string"
                          },
                          "total": {
                            "type": "number",
                            "format": "cents",
                            "example": 999
                          },
                          "totalCurrency": {
                            "type": "string"
                          },
                          "memberShareAmount": {
                            "type": "number",
                            "description": "Amount of the transaction that went to the member"
                          },
                          "memberSharePercent": {
                            "type": "number",
                            "description": "Percent of this transaction subtotal that the member recieved"
                          },
                          "memberShareOverride": {
                            "type": "number",
                            "description": "memberSharePercent received on transaction creation."
                          },
                          "memberShareDetails": {
                            "type": "object",
                            "properties": {
                              "defaultSharePercent": {
                                "type": "number",
                                "description": "Default share percent for this group"
                              },
                              "tier": {
                                "type": "object",
                                "description": "Tier share details",
                                "properties": {
                                  "name": {
                                    "type": "string",
                                    "description": "Name of the tier this member was in when this transaction was processed"
                                  },
                                  "sharePercent": {
                                    "type": "number",
                                    "description": "Share percent for this tier when this transaction was processed"
                                  }
                                }
                              },
                              "sku": {
                                "type": "object",
                                "description": "Sku share details",
                                "properties": {
                                  "id": {
                                    "type": "string",
                                    "description": "skuId included for this transaction"
                                  },
                                  "sharePercent": {
                                    "type": "number",
                                    "description": "Sku share percent at the time this transaction was processed"
                                  }
                                }
                              },
                              "scheduled": {
                                "type": "object",
                                "properties": {
                                  "group": {
                                    "type": "object",
                                    "description": "Scheduled revenue share for the group that was active when this transaction was processed",
                                    "properties": {
                                      "sharePercent": {
                                        "type": "number"
                                      }
                                    }
                                  },
                                  "sku": {
                                    "type": "object",
                                    "description": "Sku specific scheduled revenue share for the group that was active when this transaction was processed",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "sharePercent": {
                                          "type": "number"
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          },
                          "description": {
                            "type": "string"
                          },
                          "skuId": {
                            "type": "string"
                          },
                          "playerId": {
                            "type": "string"
                          },
                          "playerName": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "not found"
          }
        }
      }
    },
    "/attributions/transactions/{transactionId}": {
      "get": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "attribution transactions"
        ],
        "summary": "Return a sale transaction by transaction id",
        "description": "**NOTE**: This method uses **private authentication** API keys and should never be called from or embedded into the gaming client. These routes should ONLY be accessed from your back-end services.",
        "operationId": "getAttribution",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "description": "Transaction ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "groupId",
            "description": "Group to search for the specified transaction",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns all transactions with the given transactionId",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "transaction": {
                        "$ref": "#/components/schemas/Transaction"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "not found"
          }
        }
      },
      "patch": {
        "security": [
          {
            "PrivateApiKeyAuth": []
          }
        ],
        "tags": [
          "attribution transactions"
        ],
        "summary": "Correct a sale due to refunds, chargebacks, fraud, etc",
        "description": "**NOTE**: This method uses **private authentication** API keys and should never be called from or embedded into the gaming client. These routes should ONLY be accessed from your back-end services.",
        "operationId": "updateAttribution",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "description": "Transaction ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "groupId",
            "description": "Attribute to a specific group",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "description": "Refund, Fraud, or Chargeback",
                    "enum": [
                      "Refund",
                      "Fraud",
                      "Chargeback"
                    ]
                  },
                  "playerId": {
                    "type": "string",
                    "description": "Unique player id"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns the transactions that were updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "transaction": {
                        "$ref": "#/components/schemas/Transaction"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
