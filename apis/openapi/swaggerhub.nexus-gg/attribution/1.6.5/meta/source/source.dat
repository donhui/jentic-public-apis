                                    "description": "Name of the tier this member was in when this transaction was processed"
                                  },
                                  "sharePercent": {
                                    "type": "number",
                                    "description": "Share percent for this tier when this transaction was processed"
                                  }
                                }
                              },
                              "sku": {
                                "type": "object",
                                "description": "Sku share details",
                                "properties": {
                                  "id": {
                                    "type": "string",
                                    "description": "skuId included for this transaction"
                                  },
