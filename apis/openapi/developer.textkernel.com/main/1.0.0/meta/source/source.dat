{
  "openapi": "3.0.3",
  "info": {
    "title": "Textkernel CV/Resume Parser API",
    "version": "1.0.0",
    "description": "Textkernel parsing API for extracting structured data from CVs/resumes and job postings.",
    "x-jentic-source-url": "https://developer.textkernel.com/Parser/master/quickstart/"
  },
  "servers": [
    {
      "url": "https://{dataCenterUrl}",
      "description": "Textkernel regional data center",
      "variables": {
        "dataCenterUrl": {
          "default": "eu-rest.textkernel.com",
          "description": "Data center URL varies by region"
        }
      }
    }
  ],
  "paths": {
    "/match/extract.do": {
      "post": {
        "operationId": "parseDocument",
        "summary": "Parse a CV/Resume or Job document",
        "description": "Uploads a document for parsing and returns structured extracted data.",
        "tags": ["Parsing"],
        "parameters": [
          {
            "name": "useJsonErrorMsg",
            "in": "query",
            "schema": { "type": "boolean", "default": true },
            "description": "Return error messages in JSON format"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["account", "username", "password", "uploaded_file"],
                "properties": {
                  "account": {
                    "type": "string",
                    "description": "Account name"
                  },
                  "username": {
                    "type": "string",
                    "description": "Username"
                  },
                  "password": {
                    "type": "string",
                    "description": "Password"
                  },
                  "uploaded_file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The document file to parse"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully parsed document",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Resume": {
                      "type": "object",
                      "description": "Parsed resume/CV data"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  }
}