{
  "openapi": "3.0.3",
  "info": {
    "title": "Caspio REST API",
    "version": "3.0.0",
    "description": "The Caspio REST API provides programmatic access to your Caspio database, tables, views, records, files, and more. Requires OAuth 2.0 authentication with your Caspio application credentials.",
    "x-jentic-source-url": "https://howto.caspio.com/integrate-your-apps/web-services-api/"
  },
  "servers": [
    {
      "url": "https://{accountID}.caspio.com/integrations/rest/v3",
      "description": "Caspio API v3",
      "variables": {
        "accountID": {
          "default": "demo",
          "description": "Your Caspio account ID"
        }
      }
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/tables": {
      "get": {
        "operationId": "listTables",
        "tags": [
          "Tables"
        ],
        "summary": "Get all tables",
        "description": "Retrieve a list of all tables.",
        "responses": {
          "200": {
            "description": "Tables list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TablesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createTable",
        "tags": [
          "Tables"
        ],
        "summary": "Create a table",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTableRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Table created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TableResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tables/{tableName}/records": {
      "get": {
        "operationId": "selectRecords",
        "tags": [
          "Records"
        ],
        "summary": "Select records from a table",
        "parameters": [
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q.select",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Fields to return"
          },
          {
            "name": "q.where",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "WHERE clause"
          },
          {
            "name": "q.orderby",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q.limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "q.offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "insertRecord",
        "tags": [
          "Records"
        ],
        "summary": "Insert a record into a table",
        "parameters": [
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordData"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Record inserted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InsertRecordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "bulkUpdateRecords",
        "tags": [
          "Records"
        ],
        "summary": "Update records in a table",
        "parameters": [
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q.where",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordData"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Records updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteRecords",
        "tags": [
          "Records"
        ],
        "summary": "Delete records from a table",
        "parameters": [
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q.where",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Records deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tables/{tableName}/fields": {
      "get": {
        "operationId": "getTableFields",
        "tags": [
          "Tables"
        ],
        "summary": "Get table fields",
        "parameters": [
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Table fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FieldsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/views": {
      "get": {
        "operationId": "listViews",
        "tags": [
          "Views"
        ],
        "summary": "Get all views",
        "responses": {
          "200": {
            "description": "Views list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ViewsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/views/{viewName}/records": {
      "get": {
        "operationId": "selectViewRecords",
        "tags": [
          "Views"
        ],
        "summary": "Select records from a view",
        "parameters": [
          {
            "name": "viewName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q.where",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q.limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "q.offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "View records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/files": {
      "get": {
        "operationId": "listFiles",
        "tags": [
          "Files"
        ],
        "summary": "Get all files",
        "responses": {
          "200": {
            "description": "Files list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{accountID}.caspio.com/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "Table": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string"
          },
          "Note": {
            "type": "string"
          }
        }
      },
      "TablesResponse": {
        "type": "object",
        "properties": {
          "Result": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Table"
            }
          },
          "Message": {
            "type": "string"
          },
          "Status": {
            "type": "string"
          }
        }
      },
      "TableResponse": {
        "type": "object",
        "properties": {
          "Result": {
            "$ref": "#/components/schemas/Table"
          }
        }
      },
      "CreateTableRequest": {
        "type": "object",
        "required": [
          "Name"
        ],
        "properties": {
          "Name": {
            "type": "string"
          },
          "Fields": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "RecordsResponse": {
        "type": "object",
        "properties": {
          "Result": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "Record fields depend on the table schema"
            }
          },
          "RecordCount": {
            "type": "integer"
          },
          "TotalRecords": {
            "type": "integer"
          },
          "Message": {
            "type": "string"
          }
        }
      },
      "RecordData": {
        "type": "object",
        "description": "Record field data. Keys are field names.",
        "additionalProperties": true
      },
      "InsertRecordResponse": {
        "type": "object",
        "properties": {
          "Result": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "Message": {
            "type": "string"
          }
        }
      },
      "UpdateResponse": {
        "type": "object",
        "properties": {
          "RecordsAffected": {
            "type": "integer"
          },
          "Message": {
            "type": "string"
          }
        }
      },
      "DeleteResponse": {
        "type": "object",
        "properties": {
          "RecordsAffected": {
            "type": "integer"
          },
          "Message": {
            "type": "string"
          }
        }
      },
      "Field": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string"
          },
          "Type": {
            "type": "string"
          },
          "Required": {
            "type": "boolean"
          },
          "Unique": {
            "type": "boolean"
          }
        }
      },
      "FieldsResponse": {
        "type": "object",
        "properties": {
          "Result": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Field"
            }
          }
        }
      },
      "ViewsResponse": {
        "type": "object",
        "properties": {
          "Result": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Name": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "FilesResponse": {
        "type": "object",
        "properties": {
          "Result": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "File metadata"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}