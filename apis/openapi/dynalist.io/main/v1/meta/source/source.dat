{
  "openapi": "3.0.3",
  "info": {
    "title": "Dynalist",
    "version": "v1",
    "description": "Dynalist API provides programmatic access to documents, folders, nodes, inbox, file uploads, and preferences in Dynalist.",
    "x-jentic-source-url": "https://apidocs.dynalist.io/"
  },
  "servers": [
    {
      "url": "https://dynalist.io/api/v1",
      "description": "Dynalist API v1"
    }
  ],
  "paths": {
    "/file/list": {
      "post": {
        "operationId": "listFiles",
        "summary": "Get all documents and folders",
        "tags": ["Files"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of files",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/file/edit": {
      "post": {
        "operationId": "editFiles",
        "summary": "Make changes to documents and folders",
        "tags": ["Files"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API secret token"
                  },
                  "changes": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/FileChange"
                    }
                  }
                },
                "required": ["token", "changes"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Changes applied",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_code": {
                      "type": "string"
                    },
                    "_msg": {
                      "type": "string"
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "created": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/doc/read": {
      "post": {
        "operationId": "readDocument",
        "summary": "Get content of a document",
        "tags": ["Documents"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API secret token"
                  },
                  "file_id": {
                    "type": "string",
                    "description": "Document file ID"
                  }
                },
                "required": ["token", "file_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentReadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/doc/check_for_updates": {
      "post": {
        "operationId": "checkDocumentUpdates",
        "summary": "Check if documents have been updated",
        "tags": ["Documents"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API secret token"
                  },
                  "file_ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of file IDs to check"
                  }
                },
                "required": ["token", "file_ids"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Version info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_code": {
                      "type": "string"
                    },
                    "versions": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/doc/edit": {
      "post": {
        "operationId": "editDocument",
        "summary": "Make changes to document content",
        "tags": ["Documents"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API secret token"
                  },
                  "file_id": {
                    "type": "string",
                    "description": "Document file ID"
                  },
                  "changes": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/DocumentChange"
                    }
                  }
                },
                "required": ["token", "file_id", "changes"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Changes applied",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_code": {
                      "type": "string"
                    },
                    "_msg": {
                      "type": "string"
                    },
                    "new_node_ids": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/inbox/add": {
      "post": {
        "operationId": "addToInbox",
        "summary": "Send item to inbox",
        "tags": ["Inbox"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API secret token"
                  },
                  "index": {
                    "type": "integer",
                    "description": "Position index (0 for top, -1 for bottom)"
                  },
                  "content": {
                    "type": "string",
                    "description": "Content to add"
                  },
                  "note": {
                    "type": "string",
                    "description": "Note for the item"
                  },
                  "checked": {
                    "type": "boolean",
                    "description": "Whether the item is checked"
                  },
                  "checkbox": {
                    "type": "boolean",
                    "description": "Whether the item has a checkbox"
                  },
                  "heading": {
                    "type": "integer",
                    "description": "Heading level (0 = none, 1-3)"
                  },
                  "color": {
                    "type": "integer",
                    "description": "Label color (0-6)"
                  }
                },
                "required": ["token", "content"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item added to inbox",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_code": {
                      "type": "string"
                    },
                    "file_id": {
                      "type": "string"
                    },
                    "node_id": {
                      "type": "string"
                    },
                    "index": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/upload": {
      "post": {
        "operationId": "uploadFile",
        "summary": "Upload a file (Pro only)",
        "tags": ["Files"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API secret token"
                  },
                  "filename": {
                    "type": "string",
                    "description": "Name of the file"
                  },
                  "content_type": {
                    "type": "string",
                    "description": "MIME type of the file"
                  },
                  "data": {
                    "type": "string",
                    "description": "Base64-encoded file data"
                  }
                },
                "required": ["token", "filename", "content_type", "data"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_code": {
                      "type": "string"
                    },
                    "_msg": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/pref/get": {
      "post": {
        "operationId": "getPreference",
        "summary": "Get a user preference",
        "tags": ["Preferences"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API secret token"
                  },
                  "key": {
                    "type": "string",
                    "description": "Preference key"
                  }
                },
                "required": ["token", "key"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Preference value",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_code": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/pref/set": {
      "post": {
        "operationId": "setPreference",
        "summary": "Set a user preference",
        "tags": ["Preferences"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API secret token"
                  },
                  "key": {
                    "type": "string",
                    "description": "Preference key"
                  },
                  "value": {
                    "type": "string",
                    "description": "Preference value"
                  }
                },
                "required": ["token", "key", "value"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Preference set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid token"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "API secret token"
          }
        },
        "required": ["token"]
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "_code": {
            "type": "string",
            "description": "Response code (e.g., 'Ok', 'InvalidToken')"
          },
          "_msg": {
            "type": "string",
            "description": "Response message"
          }
        }
      },
      "FileListResponse": {
        "type": "object",
        "properties": {
          "_code": {
            "type": "string"
          },
          "_msg": {
            "type": "string"
          },
          "root_file_id": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/File"
            }
          }
        }
      },
      "File": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["document", "folder"]
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Child file IDs (for folders)"
          }
        }
      },
      "FileChange": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["create", "edit", "move"],
            "description": "Type of change"
          },
          "type": {
            "type": "string",
            "enum": ["document", "folder"]
          },
          "file_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "parent_id": {
            "type": "string"
          },
          "index": {
            "type": "integer"
          }
        },
        "required": ["action"]
      },
      "DocumentReadResponse": {
        "type": "object",
        "properties": {
          "_code": {
            "type": "string"
          },
          "file_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "nodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Node"
            }
          }
        }
      },
      "Node": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "checked": {
            "type": "boolean"
          },
          "checkbox": {
            "type": "boolean"
          },
          "heading": {
            "type": "integer"
          },
          "color": {
            "type": "integer"
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created": {
            "type": "integer",
            "description": "Unix timestamp of creation"
          },
          "modified": {
            "type": "integer",
            "description": "Unix timestamp of last modification"
          }
        }
      },
      "DocumentChange": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["insert", "edit", "move", "delete"],
            "description": "Type of change"
          },
          "node_id": {
            "type": "string"
          },
          "parent_id": {
            "type": "string"
          },
          "index": {
            "type": "integer"
          },
          "content": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "checked": {
            "type": "boolean"
          },
          "checkbox": {
            "type": "boolean"
          },
          "heading": {
            "type": "integer"
          },
          "color": {
            "type": "integer"
          }
        },
        "required": ["action"]
      }
    },
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Token",
        "description": "API secret token passed in request body (token field). Listed as header for spec compliance but actually sent in JSON body."
      }
    }
  },
  "security": [
    {
      "apiToken": []
    }
  ]
}