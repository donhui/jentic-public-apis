{
  "openapi": "3.0.3",
  "info": {
    "title": "ComplyAdvantage AML API",
    "version": "1.0",
    "description": "The ComplyAdvantage API enables integration with AML (Anti-Money Laundering) services for automated sanctions screening, PEP checks, adverse media monitoring, and search management. Supports creating, retrieving, updating, and deleting searches, managing monitored searches, and webhook notifications.",
    "x-jentic-source-url": "https://docs.complyadvantage.com/"
  },
  "servers": [
    {
      "url": "https://api.complyadvantage.com",
      "description": "EU Region"
    },
    {
      "url": "https://api.us.complyadvantage.com",
      "description": "US Region"
    },
    {
      "url": "https://api.ap.complyadvantage.com",
      "description": "APAC Region"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {"name": "Users", "description": "User management"},
    {"name": "Searches", "description": "Search creation and retrieval"},
    {"name": "MonitoredSearches", "description": "Monitored search management"},
    {"name": "Comments", "description": "Search comments"},
    {"name": "Tags", "description": "Search tag management"},
    {"name": "References", "description": "Search references"}
  ],
  "paths": {
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "Get Users",
        "description": "Get a list of users in your account.",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {"type": "string", "example": "success"},
                    "content": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/User"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "429": {"description": "Too many requests", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches": {
      "post": {
        "operationId": "createSearch",
        "summary": "Create Search",
        "description": "Create a new AML search with filters for sanctions, PEP, adverse media, and more.",
        "tags": ["Searches"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchSuccessResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "429": {"description": "Too many requests"}
        }
      },
      "get": {
        "operationId": "listSearches",
        "summary": "Get Searches",
        "description": "Get a list of previous searches with optional filtering, sorting, and pagination.",
        "tags": ["Searches"],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer"}, "description": "Page number for pagination"},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}, "description": "Results per page"},
          {"name": "created_at_from", "in": "query", "schema": {"type": "string", "format": "date-time"}, "description": "Filter by creation date from"},
          {"name": "created_at_to", "in": "query", "schema": {"type": "string", "format": "date-time"}, "description": "Filter by creation date to"},
          {"name": "updated_at_from", "in": "query", "schema": {"type": "string", "format": "date-time"}, "description": "Filter by update date from"},
          {"name": "updated_at_to", "in": "query", "schema": {"type": "string", "format": "date-time"}, "description": "Filter by update date to"},
          {"name": "search_term", "in": "query", "schema": {"type": "string"}, "description": "Filter by search term"},
          {"name": "status", "in": "query", "schema": {"type": "string"}, "description": "Filter by status"},
          {"name": "assignee_id", "in": "query", "schema": {"type": "integer"}, "description": "Filter by assignee"},
          {"name": "sort_by", "in": "query", "schema": {"type": "string"}, "description": "Sort field"},
          {"name": "sort_dir", "in": "query", "schema": {"type": "string", "enum": ["asc", "desc"]}, "description": "Sort direction"}
        ],
        "responses": {
          "200": {
            "description": "List of searches",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchListResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}": {
      "get": {
        "operationId": "getSearch",
        "summary": "Get Search Overview",
        "description": "Get an overview of a specific search.",
        "tags": ["Searches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {
            "description": "Search overview",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchSuccessResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "patch": {
        "operationId": "updateSearch",
        "summary": "Update Search",
        "description": "Update details of a search such as assigned user or status.",
        "tags": ["Searches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Search updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchSuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "delete": {
        "operationId": "deleteSearch",
        "summary": "Delete Search",
        "description": "Delete a search by ID.",
        "tags": ["Searches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Search deleted", "content": {"application/json": {"schema": {"type": "object", "properties": {"status": {"type": "string"}}}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/details": {
      "get": {
        "operationId": "getSearchDetails",
        "summary": "Get Full Search Results",
        "description": "Get full search results including all entity details.",
        "tags": ["Searches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Full search results", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchSuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/entities": {
      "patch": {
        "operationId": "updateSearchEntities",
        "summary": "Update Search Entities",
        "description": "Update entity details such as is_whitelisted, risk_level, or match_status.",
        "tags": ["Searches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EntityUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Entities updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchSuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{ref}/entities/{entityProvider}": {
      "get": {
        "operationId": "getSearchEntitiesByRef",
        "summary": "Get Search Entities by Reference",
        "description": "Get entities for a search by reference and entity provider.",
        "tags": ["Searches"],
        "parameters": [
          {"name": "ref", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "entityProvider", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Entity data", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchSuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/certificate": {
      "get": {
        "operationId": "getSearchCertificate",
        "summary": "Get Search Certificate",
        "description": "Get the certificate for a search.",
        "tags": ["Searches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Search certificate"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/monitors": {
      "get": {
        "operationId": "getMonitoredSearch",
        "summary": "Get Monitored Search Details",
        "description": "Get details of a monitored search.",
        "tags": ["MonitoredSearches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Monitored search details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchSuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "patch": {
        "operationId": "updateMonitoredSearch",
        "summary": "Update Monitored Search",
        "description": "Start or stop monitoring for a search.",
        "tags": ["MonitoredSearches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "is_monitored": {"type": "boolean"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Monitor updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchSuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/monitor/differences": {
      "get": {
        "operationId": "getMonitorDifferences",
        "summary": "Get Monitor Differences",
        "description": "Get differences detected by monitoring.",
        "tags": ["MonitoredSearches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Monitor differences"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/monitor/acknowledge": {
      "post": {
        "operationId": "acknowledgeMonitorChanges",
        "summary": "Acknowledge Monitor Changes",
        "description": "Acknowledge changes to a monitored search.",
        "tags": ["MonitoredSearches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Changes acknowledged", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchSuccessResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/search-profile": {
      "patch": {
        "operationId": "updateSearchProfile",
        "summary": "Update Search Profile",
        "description": "Update the Search Profile associated with a monitored search.",
        "tags": ["MonitoredSearches"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Search profile updated"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/comments": {
      "post": {
        "operationId": "createSearchComment",
        "summary": "Create Search Comment",
        "description": "Create a comment on a search or entity.",
        "tags": ["Comments"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["body"],
                "properties": {
                  "body": {"type": "string"},
                  "entity_id": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Comment created"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "get": {
        "operationId": "getSearchComments",
        "summary": "Get Search Comments",
        "description": "Retrieve comments for a specific search.",
        "tags": ["Comments"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Search comments"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/{id}/tags/{tagName}": {
      "delete": {
        "operationId": "detachSearchTag",
        "summary": "Detach Tag from Search",
        "description": "Detach a tag from a search.",
        "tags": ["Tags"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}},
          {"name": "tagName", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Tag detached"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/searches/references": {
      "post": {
        "operationId": "searchByReferences",
        "summary": "Search by References",
        "description": "Search using reference identifiers.",
        "tags": ["References"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "references": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Search results"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key with format: Token YOUR_API_KEY"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {"type": "integer"},
          "message": {"type": "string"},
          "status": {"type": "string", "example": "failure"}
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "email": {"type": "string", "format": "email"},
          "name": {"type": "string"}
        }
      },
      "SearchCreateRequest": {
        "type": "object",
        "required": ["search_term"],
        "properties": {
          "search_term": {"type": "string", "description": "Name or term to search"},
          "client_ref": {"type": "string", "description": "Client reference ID"},
          "fuzziness": {"type": "number", "description": "Fuzziness level 0-1"},
          "filters": {
            "type": "object",
            "properties": {
              "birth_year": {"type": "integer"},
              "country_codes": {"type": "array", "items": {"type": "string"}},
              "entity_type": {"type": "string", "enum": ["person", "company", "organisation", "vessel", "aircraft"]},
              "remove_deceased": {"type": "integer"},
              "types": {"type": "array", "items": {"type": "string"}, "description": "sanction, pep, adverse-media, etc."}
            }
          },
          "tags": {"type": "object", "additionalProperties": {"type": "string"}},
          "share_url": {"type": "integer", "description": "Set to 1 to generate a share URL"}
        }
      },
      "SearchUpdateRequest": {
        "type": "object",
        "properties": {
          "assignee_id": {"type": "integer"},
          "status": {"type": "string"},
          "risk_level": {"type": "string"},
          "tags": {"type": "object", "additionalProperties": {"type": "string"}}
        }
      },
      "EntityUpdateRequest": {
        "type": "object",
        "properties": {
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "entity_id": {"type": "string"},
                "match_status": {"type": "string", "enum": ["true_positive", "false_positive", "unknown", "potential_match"]},
                "is_whitelisted": {"type": "boolean"},
                "risk_level": {"type": "string"}
              }
            }
          }
        }
      },
      "Entity": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "entity_type": {"type": "string"},
          "last_updated_utc": {"type": "string", "format": "date-time"},
          "name": {"type": "string"},
          "first_name": {"type": "string"},
          "last_name": {"type": "string"},
          "sources": {"type": "array", "items": {"type": "string"}},
          "types": {"type": "array", "items": {"type": "string"}},
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "tag": {"type": "string"},
                "value": {"type": "string"},
                "source": {"type": "string"}
              }
            }
          },
          "aka": {"type": "array", "items": {"type": "object", "properties": {"name": {"type": "string"}}}},
          "associates": {"type": "array", "items": {"type": "object", "properties": {"name": {"type": "string"}, "association": {"type": "string"}}}},
          "media": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {"type": "string", "format": "date-time"},
                "snippet": {"type": "string"},
                "title": {"type": "string"},
                "url": {"type": "string", "format": "uri"}
              }
            }
          }
        }
      },
      "SearchSuccessResponse": {
        "type": "object",
        "properties": {
          "status": {"type": "string", "example": "success"},
          "content": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "id": {"type": "integer"},
                  "search_term": {"type": "string"},
                  "total_hits": {"type": "integer"},
                  "entities": {
                    "type": "array",
                    "items": {"$ref": "#/components/schemas/Entity"}
                  }
                }
              }
            }
          }
        }
      },
      "SearchListResponse": {
        "type": "object",
        "properties": {
          "status": {"type": "string"},
          "content": {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "search_term": {"type": "string"},
                    "total_hits": {"type": "integer"},
                    "created_at": {"type": "string", "format": "date-time"},
                    "updated_at": {"type": "string", "format": "date-time"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}