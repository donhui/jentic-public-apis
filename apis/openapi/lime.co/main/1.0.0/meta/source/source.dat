{
  "openapi": "3.0.3",
  "info": {
    "title": "Lime Trader REST API",
    "description": "Lime Financial trading API providing account management, order placement, and market data functionality for stocks and options.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.lime.co/trader"
  },
  "servers": [
    {
      "url": "https://api.lime.co",
      "description": "Lime Trader API Server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Accounts",
      "description": "Account balance and information endpoints"
    },
    {
      "name": "Trading",
      "description": "Order placement and management"
    },
    {
      "name": "Market Data",
      "description": "Real-time market data endpoints"
    }
  ],
  "paths": {
    "/accounts": {
      "get": {
        "operationId": "getAccountBalances",
        "summary": "Get account balances for all user accounts",
        "description": "Get balance information for all user accounts as an array of account objects.",
        "tags": ["Accounts"],
        "responses": {
          "200": {
            "description": "Account balances retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AccountBalance"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/orders/place": {
      "post": {
        "operationId": "placeOrder",
        "summary": "Place a new order",
        "description": "Submit a new order for stocks or options. Supports single-leg and multi-leg orders.",
        "tags": ["Trading"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order placed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaceOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid order parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/marketdata/quote": {
      "get": {
        "operationId": "getCurrentQuote",
        "summary": "Get current quote for a security",
        "description": "Retrieve real-time quote data for a security symbol including bid, ask, last trade, volume, and options Greeks.",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "The security symbol (stocks in CQS/CMS format, options in OCC format)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Quote data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid symbol",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer token. Obtain via Password Flow or Authorization Code Flow at https://myaccount.lime.co"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      },
      "AccountBalance": {
        "type": "object",
        "properties": {
          "account_number": {
            "type": "string",
            "description": "Account identifier"
          },
          "trade_platform": {
            "type": "string",
            "description": "Trading platform name"
          },
          "margin_type": {
            "type": "string",
            "description": "Margin account type",
            "enum": ["cash", "marginx1", "marginx2", "daytrader"]
          },
          "restriction": {
            "type": "string",
            "description": "Account restriction status",
            "enum": ["none", "restricted", "disabled", "closed"]
          },
          "restriction_reason": {
            "type": "string",
            "description": "Reason for restriction, if applicable"
          },
          "daytrades_count": {
            "type": "number",
            "description": "Number of day trades"
          },
          "account_value_total": {
            "type": "number",
            "description": "Total account value"
          },
          "cash": {
            "type": "number",
            "description": "Cash balance"
          },
          "day_trading_buying_power": {
            "type": "number",
            "description": "Day trading buying power"
          },
          "margin_buying_power": {
            "type": "number",
            "description": "Margin buying power"
          },
          "non_margin_buying_power": {
            "type": "number",
            "description": "Non-margin buying power"
          },
          "position_market_value": {
            "type": "number",
            "description": "Market value of positions"
          },
          "unsettled_cash": {
            "type": "number",
            "description": "Unsettled cash amount"
          },
          "cash_to_withdraw": {
            "type": "number",
            "description": "Cash available for withdrawal"
          }
        }
      },
      "PlaceOrderRequest": {
        "type": "object",
        "required": ["account_number", "symbol", "quantity", "price"],
        "properties": {
          "account_number": {
            "type": "string",
            "description": "Account identifier in format 123456578@vision",
            "example": "123456578@vision"
          },
          "symbol": {
            "type": "string",
            "description": "Security symbol (stocks in CQS/CMS format, options in OCC format)"
          },
          "quantity": {
            "type": "number",
            "description": "Number of shares or contracts (positive integer)"
          },
          "price": {
            "type": "number",
            "description": "Price for limit orders (positive decimal)"
          },
          "time_in_force": {
            "type": "string",
            "description": "Time in force for the order",
            "enum": ["day", "ext", "on-open", "on-close", "ioc", "fok"],
            "default": "day"
          },
          "order_type": {
            "type": "string",
            "description": "Order type",
            "enum": ["market", "limit"],
            "default": "market"
          },
          "side": {
            "type": "string",
            "description": "Order side",
            "enum": ["buy", "sell"],
            "default": "buy"
          },
          "exchange": {
            "type": "string",
            "description": "Routing instructions",
            "default": "auto"
          },
          "client_order_id": {
            "type": "string",
            "description": "Unique client identifier, max 32 alphanumeric characters",
            "maxLength": 32
          },
          "tag": {
            "type": "string",
            "description": "Comment, max 32 characters",
            "maxLength": 32
          },
          "legs": {
            "type": "array",
            "description": "Required for multi-leg orders",
            "items": {
              "$ref": "#/components/schemas/OrderLeg"
            }
          }
        }
      },
      "OrderLeg": {
        "type": "object",
        "required": ["symbol", "quantity", "side"],
        "properties": {
          "symbol": {
            "type": "string",
            "description": "Security symbol for this leg"
          },
          "quantity": {
            "type": "number",
            "description": "Number of shares or contracts"
          },
          "side": {
            "type": "string",
            "description": "Order side for this leg",
            "enum": ["buy", "sell"]
          }
        }
      },
      "PlaceOrderResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the order was accepted"
          },
          "data": {
            "type": "string",
            "description": "Assigned order identifier"
          }
        }
      },
      "Quote": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "description": "Security identifier"
          },
          "ask": {
            "type": "number",
            "description": "Ask price"
          },
          "ask_size": {
            "type": "number",
            "description": "Ask size"
          },
          "bid": {
            "type": "number",
            "description": "Bid price"
          },
          "bid_size": {
            "type": "number",
            "description": "Bid size"
          },
          "last": {
            "type": "number",
            "description": "Last trade price"
          },
          "last_size": {
            "type": "number",
            "description": "Last trade size"
          },
          "volume": {
            "type": "number",
            "description": "Today's total volume"
          },
          "date": {
            "type": "number",
            "description": "Last trade time as Unix timestamp"
          },
          "high": {
            "type": "number",
            "description": "Today's high price"
          },
          "low": {
            "type": "number",
            "description": "Today's low price"
          },
          "open": {
            "type": "number",
            "description": "Open price"
          },
          "close": {
            "type": "number",
            "description": "Yesterday's close price"
          },
          "week52_high": {
            "type": "number",
            "description": "52-week high"
          },
          "week52_low": {
            "type": "number",
            "description": "52-week low"
          },
          "change": {
            "type": "number",
            "description": "Today's price change"
          },
          "change_pc": {
            "type": "number",
            "description": "Today's percent price change"
          },
          "open_interest": {
            "type": "number",
            "description": "Open interest (options)"
          },
          "implied_volatility": {
            "type": "number",
            "description": "Implied volatility (options)"
          },
          "theoretical_price": {
            "type": "number",
            "description": "Theoretical price (options)"
          },
          "delta": {
            "type": "number",
            "description": "Delta value (options)"
          },
          "gamma": {
            "type": "number",
            "description": "Gamma value (options)"
          },
          "theta": {
            "type": "number",
            "description": "Theta value (options)"
          },
          "vega": {
            "type": "number",
            "description": "Vega value (options)"
          },
          "rho": {
            "type": "number",
            "description": "Rho value (options)"
          }
        }
      }
    }
  }
}