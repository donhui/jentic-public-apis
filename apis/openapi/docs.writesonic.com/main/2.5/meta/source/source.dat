{
  "openapi": "3.0.3",
  "info": {
    "title": "Writesonic API",
    "version": "2.5",
    "description": "Writesonic API provides programmatic access to ChatSonic (AI chat), Photosonic (image generation), and 100+ content generation tools. Generate blog posts, social media content, ad copy, product descriptions, and more using AI.",
    "x-jentic-source-url": "https://docs.writesonic.com/reference"
  },
  "servers": [
    {
      "url": "https://api.writesonic.com",
      "description": "Writesonic API Server"
    }
  ],
  "paths": {
    "/v2/business/content/chatsonic": {
      "post": {
        "operationId": "chatsonic",
        "summary": "ChatSonic (Like ChatGPT)",
        "description": "Send a message to ChatSonic AI with optional real-time Google search, memory management, and multi-language support.",
        "tags": ["ChatSonic"],
        "parameters": [
          {
            "name": "engine",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["premium", "economy"],
              "default": "premium"
            },
            "description": "AI engine to use"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatSonicRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatSonicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/v1/business/photosonic/generate_image": {
      "post": {
        "operationId": "generateImage",
        "summary": "Generate Image with Photosonic",
        "description": "Generate AI art and images from text prompts using Photosonic.",
        "tags": ["Photosonic"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PhotosonicRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful image generation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhotosonicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
