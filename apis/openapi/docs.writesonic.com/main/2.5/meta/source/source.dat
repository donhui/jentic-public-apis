  },
  "components": {
    "schemas": {
      "ChatSonicRequest": {
        "type": "object",
        "required": ["enable_google_results", "enable_memory", "input_text"],
        "properties": {
          "enable_google_results": {
            "type": "boolean",
            "description": "Enable real-time Google search for up-to-date information"
          },
          "enable_memory": {
            "type": "boolean",
            "description": "Enable conversation memory across requests"
          },
          "input_text": {
            "type": "string",
            "description": "The user message or prompt to send to ChatSonic"
          },
          "history_data": {
            "type": "array",
            "description": "Conversation history for context",
            "items": {
              "type": "object",
              "properties": {
                "is_sent": {
                  "type": "boolean",
                  "description": "Whether the message was sent by user (true) or AI (false)"
                },
                "message": {
                  "type": "string",
                  "description": "The message content"
                }
              }
            }
          }
        }
      },
      "ChatSonicResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "The AI-generated response text"
          },
          "image_urls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "URLs of any generated images"
          }
        }
      },
      "PhotosonicRequest": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Text description of the image to generate"
          },
          "num_images": {
            "type": "integer",
            "description": "Number of images to generate",
            "default": 1
          }
        }
      },
      "PhotosonicResponse": {
        "type": "object",
        "properties": {
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "description": "URL of the generated image"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}