          }
        }
      },
      "put": {
        "operationId": "updateCampaign",
        "summary": "Edit an unsent campaign",
        "description": "Allows editing of existing campaigns in draft or scheduled states only.",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "brand_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
