  "components": {
    "schemas": {
      "Brand": {
        "type": "object",
        "properties": {
          "brand_id": { "type": "string" },
          "legal_name": { "type": "string" },
          "address": { "type": "string" },
          "industry": { "type": "string" },
          "use_case": { "type": "string" },
          "attribution_model": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "updated": { "type": "string", "format": "date-time" }
        }
      },
      "CreditUsage": {
        "type": "object",
        "properties": {
          "brand_id": { "type": "string" },
          "brand_name": { "type": "string" },
          "total_credits": { "type": "integer" },
          "credits_used": { "type": "integer" },
          "credits_available": { "type": "integer" },
          "message_credit_limit": { "type": "integer" }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "contact_id": { "type": "integer" },
          "_brand_id": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "mobile_number": { "type": "string" },
          "email": { "type": "string" },
          "birthdate": { "type": "string", "format": "date" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" },
          "timezone": { "type": "string" },
          "language": { "type": "string" },
          "opt_in_status": { "type": "string", "enum": ["not subscribed", "subscribed", "unsubscribed", "blocked"] },
          "created": { "type": "string", "format": "date-time" },
          "updated": { "type": "string", "format": "date-time" }
        }
      },
      "ContactList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Contact" }
          },
          "total": { "type": "integer" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" }
        }
      },
      "CreateContactRequest": {
        "type": "object",
        "required": ["mobile_number"],
        "properties": {
          "mobile_number": { "type": "string", "minLength": 10 },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "birthdate": { "type": "string", "format": "date" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" },
          "timezone": { "type": "string", "enum": ["America/New_York", "America/Chicago", "America/Denver", "America/Los_Angeles"] },
          "language": { "type": "string", "default": "en" },
          "opt_in_status": { "type": "string", "enum": ["not subscribed", "subscribed", "unsubscribed", "blocked"], "default": "not subscribed" },
          "force_double_opt_in": { "type": "boolean" }
        }
      },
      "UpdateContactRequest": {
        "type": "object",
        "properties": {
          "mobile_number": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "birthdate": { "type": "string", "format": "date" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" },
          "timezone": { "type": "string" },
          "language": { "type": "string" },
          "opt_in_status": { "type": "string", "enum": ["not subscribed", "subscribed", "unsubscribed", "blocked"] }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "campaign_id": { "type": "string" },
          "_brand_id": { "type": "string" },
          "name": { "type": "string" },
          "body": { "type": "string" },
          "media_url": { "type": "string" },
          "status": { "type": "string" },
          "scheduled": { "type": "string", "format": "date-time" },
          "audience": { "type": "object" },
          "created": { "type": "string", "format": "date-time" },
          "updated": { "type": "string", "format": "date-time" }
        }
      },
      "CampaignList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Campaign" }
          },
          "total": { "type": "integer" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" }
        }
      },
      "CreateCampaignRequest": {
        "type": "object",
        "required": ["name", "body", "status", "audience"],
        "properties": {
          "name": { "type": "string" },
          "body": { "type": "string" },
          "media_url": { "type": "string" },
          "status": { "type": "string", "enum": ["send", "draft", "scheduled"] },
          "scheduled": { "type": "string", "format": "date-time" },
          "audience": { "type": "object" }
        }
      },
      "UpdateCampaignRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "body": { "type": "string" },
          "media_url": { "type": "string" },
          "status": { "type": "string", "enum": ["send", "draft", "scheduled"] },
          "scheduled": { "type": "string", "format": "date-time" },
          "audience": { "type": "object" }
        }
      },
      "ContactListItem": {
        "type": "object",
        "properties": {
          "contact_list_id": { "type": "integer" },
          "_brand_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "created": { "type": "string", "format": "date-time" }
        }
      },
      "ContactListCollection": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
