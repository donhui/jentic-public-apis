          "description": { "type": "string" }
        }
      },
      "UpdateListRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
