    "/v1/brands/{brandId}/lists/{listId}": {
      "get": {
        "operationId": "getList",
        "summary": "Retrieve a specific list",
        "description": "Retrieves details for a single list by its ID.",
        "tags": ["Lists"],
        "parameters": [
          {
            "name": "brandId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Brand identifier"
          },
          {
