                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteList",
        "summary": "Delete a specific list",
        "description": "Removes a list from the brand. Associated contacts are preserved.",
        "tags": ["Lists"],
        "parameters": [
          {
            "name": "brandId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
