    "/v1/brands/{brandId}/messages": {
      "get": {
        "operationId": "listMessages",
        "summary": "Retrieve all messages",
        "description": "Retrieves all messages associated with a brand. Supports filtering by status, source, source ID, and direction.",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "brandId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Brand identifier"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["delivered", "undelivered", "processed"]
            },
            "description": "Filter by message status"
          },
          {
            "name": "source",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["Campaign", "Keyword", "InboxThread", "API"]
            },
            "description": "Filter by message origin"
          },
          {
            "name": "source_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by source entity ID"
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["incoming", "outgoing"]
            },
            "description": "Filter by message direction"
          }
        ],
        "responses": {
          "200": {
            "description": "Messages retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token via API key"
      }
    },
    "schemas": {
      "Brand": {
        "type": "object",
        "properties": {
          "brand_id": { "type": "integer" },
          "_account_id": { "type": "integer" },
          "tax_id": { "type": "integer" },
          "legal_name": { "type": "string" },
          "name": { "type": "string" },
          "short_name": { "type": "string" },
          "logo": { "type": "string", "nullable": true },
          "website": { "type": "string" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" },
          "contact_first_name": { "type": "string" },
          "contact_last_name": { "type": "string" },
          "contact_email": { "type": "string" },
          "contact_phone": { "type": "string" },
          "industry": { "type": "string" },
          "use_case": { "type": "string" },
          "prohibited_content": { "type": "integer" },
          "message_credit_limit": { "type": "integer", "nullable": true },
          "message_credit_limit_percentage": { "type": "integer" },
          "age_requirement": { "type": "integer" },
          "force_double_opt_in": { "type": "integer" },
          "inbox_enabled": { "type": "integer" },
          "created": { "type": "string", "format": "date-time" },
          "last_updated": { "type": "string", "format": "date-time" }
        }
      },
      "CreditUsage": {
        "type": "object",
        "properties": {
          "brand_id": { "type": "integer" },
          "brand_name": { "type": "string" },
          "total_credits": { "type": "integer" },
          "credits_used": { "type": "integer" },
          "credits_available": { "type": "integer" },
          "message_credit_limit": { "type": "integer", "nullable": true },
          "message_credit_limit_percentage": { "type": "integer" }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "contact_id": { "type": "integer" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "mobile_number": { "type": "string" },
          "email": { "type": "string" },
          "birthdate": { "type": "string", "format": "date" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" },
          "timezone": { "type": "string" },
          "language": { "type": "string" },
          "opt_in_status": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "last_updated": { "type": "string", "format": "date-time" }
        }
      },
      "ContactListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Contact" }
          },
          "pagingData": { "$ref": "#/components/schemas/PagingData" }
        }
      },
      "CreateContactRequest": {
        "type": "object",
        "required": ["mobile_number"],
        "properties": {
          "mobile_number": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "birthdate": { "type": "string", "format": "date" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" },
          "timezone": { "type": "string" },
          "language": { "type": "string" },
          "opt_in_status": { "type": "string", "default": "not subscribed" },
          "force_double_opt_in": { "type": "boolean" }
        }
      },
      "UpdateContactRequest": {
        "type": "object",
        "properties": {
          "mobile_number": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "birthdate": { "type": "string", "format": "date" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" },
          "timezone": { "type": "string" },
          "language": { "type": "string" },
          "opt_in_status": { "type": "string" }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "campaign_id": { "type": "integer" },
          "_brand_id": { "type": "integer" },
          "_created_by_user_id": { "type": "integer" },
          "name": { "type": "string" },
          "body": { "type": "string" },
          "media_url": { "type": "string" },
          "status": { "type": "string", "enum": ["sent", "draft", "scheduled", "queued"] },
          "completion_percentage": { "type": "integer" },
          "audience_size": { "type": "integer" },
          "audience": {
            "type": "array",
            "items": { "type": "object" }
          },
          "created": { "type": "string", "format": "date-time" },
          "scheduled": { "type": "string", "format": "date-time" },
          "started": { "type": "string", "format": "date-time" },
          "finished": { "type": "string", "format": "date-time" }
        }
      },
      "CampaignListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Campaign" }
          },
          "pagingData": { "$ref": "#/components/schemas/PagingData" }
        }
      },
      "CreateCampaignRequest": {
        "type": "object",
        "required": ["name", "body"],
        "properties": {
          "name": { "type": "string" },
          "body": { "type": "string" },
          "media_url": { "type": "string" },
          "status": { "type": "string", "enum": ["send", "draft", "scheduled"] },
          "scheduled": { "type": "string", "format": "date-time" },
          "audience": {
            "type": "object",
            "properties": {
              "segments": { "type": "array", "items": { "type": "integer" } },
              "contact_lists": { "type": "array", "items": { "type": "integer" } }
            }
          }
        }
      },
      "UpdateCampaignRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "body": { "type": "string" },
          "media_url": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "scheduled", "send"] },
          "scheduled": { "type": "string", "format": "date-time" },
          "audience": {
            "type": "object",
            "properties": {
              "segments": { "type": "array", "items": { "type": "integer" } },
              "contact_lists": { "type": "array", "items": { "type": "integer" } }
            }
          }
        }
      },
      "Keyword": {
        "type": "object",
        "properties": {
          "keyword_id": { "type": "integer" },
          "_brand_id": { "type": "integer" },
          "word": { "type": "string" },
          "description": { "type": "string" },
          "create_contacts": { "type": "integer" },
          "use_alternate_responses": { "type": "integer" },
          "double_opt_in": { "type": "integer" },
          "auto_response_message": { "type": "string" },
          "auto_response_message_media_url": { "type": "string" },
          "opt_in_exists_message": { "type": "string" },
          "re_opt_in_message": { "type": "string" },
          "double_opt_in_message": { "type": "string" },
          "active": { "type": "integer" },
          "contact_list_ids": { "type": "array", "items": { "type": "integer" } },
          "created": { "type": "string", "format": "date-time" },
          "last_updated": { "type": "string", "format": "date-time" },
          "deleted": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "KeywordListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Keyword" }
          },
          "pagingData": { "$ref": "#/components/schemas/PagingData" }
        }
      },
      "ContactList": {
        "type": "object",
        "properties": {
          "contact_list_id": { "type": "integer" },
          "_brand_id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "created": { "type": "string", "format": "date-time" }
        }
      },
      "ListListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContactList" }
          },
          "pagingData": { "$ref": "#/components/schemas/PagingData" }
        }
      },
      "CreateListRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "UpdateListRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "ListContactAssignment": {
        "type": "object",
        "properties": {
          "contact_id": { "type": "integer" },
          "lists": {
            "type": "array",
            "items": { "type": "integer" }
          }
        }
      },
      "ListContactAssignmentResponse": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "to": { "type": "string" },
          "from": { "type": "string" },
          "body": { "type": "string" },
          "direction": { "type": "string" },
          "channel": { "type": "string" },
          "source": { "type": "string" },
          "_source_id": { "type": "integer" },
          "is_gsm": { "type": "integer" },
          "message_credits": { "type": "integer" },
          "campaign_completion_percentage": { "type": "integer" },
          "text_number": { "type": "object" },
          "brand": { "type": "object" },
          "contact": { "type": "object" },
          "user": { "type": "object" },
          "status": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "created_micro": { "type": "number" },
          "updated": { "type": "string", "format": "date-time" }
        }
      },
      "MessageListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Message" }
          },
          "pagingData": { "$ref": "#/components/schemas/PagingData" }
        }
      },
      "PagingData": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total": { "type": "integer" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}