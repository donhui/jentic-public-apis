                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "writeKeyValuePair",
        "summary": "Write Key-Value Pair with Metadata",
        "description": "Write a value identified by a key, with optional metadata and expiration.",
        "tags": [
          "Key-Value Pairs"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          },
          {
            "$ref": "#/components/parameters/KeyName"
          },
          {
            "name": "expiration",
            "in": "query",
            "description": "Unix epoch timestamp for key expiration.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "expiration_ttl",
            "in": "query",
            "description": "Seconds until key expiration. Must be at least 60.",
            "schema": {
              "type": "number",
              "minimum": 60
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary",
                "description": "The value to store."
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string",
                    "format": "binary",
                    "description": "The value to store."
                  },
                  "metadata": {
                    "type": "string",
                    "description": "JSON-encoded metadata object."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
