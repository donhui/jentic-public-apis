          },
          "title": {
            "type": "string",
            "description": "A human-readable string name for a Namespace."
          },
          "supports_url_encoding": {
            "type": "boolean",
            "description": "True if keys written to the namespace are URL-decoded prior to storing."
          }
        }
      },
      "ResultInfo": {
        "type": "object",
        "properties": {
          "count": {
            "type": "number",
