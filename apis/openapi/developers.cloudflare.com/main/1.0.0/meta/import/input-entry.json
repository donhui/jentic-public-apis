    "/accounts/{account_id}/storage/kv/namespaces/{namespace_id}/values/{key_name}": {
      "get": {
        "operationId": "readKeyValuePair",
        "summary": "Read Key-Value Pair",
        "description": "Returns the value associated with the given key in the given namespace.",
        "tags": [
          "Key-Value Pairs"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          },
          {
            "$ref": "#/components/parameters/KeyName"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response - returns the value as a binary stream",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
