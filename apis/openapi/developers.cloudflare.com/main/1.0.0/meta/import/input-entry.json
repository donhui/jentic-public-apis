        "name": "account_id",
        "in": "path",
        "required": true,
        "description": "Account identifier.",
        "schema": {
          "type": "string"
        }
      },
      "NamespaceId": {
        "name": "namespace_id",
        "in": "path",
        "required": true,
        "description": "Namespace identifier tag.",
        "schema": {
          "type": "string"
        }
      },
      "KeyName": {
        "name": "key_name",
        "in": "path",
        "required": true,
        "description": "A key's name. The name may be at most 512 bytes.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Namespace": {
        "type": "object",
