          },
          "page": {
            "type": "number",
            "description": "Current page number."
          },
          "per_page": {
            "type": "number",
            "description": "Number of results per page."
          },
          "total_count": {
            "type": "number",
            "description": "Total number of results available."
          }
        }
      },
      "ResponseInfo": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error or message code."
          },
          "message": {
            "type": "string",
