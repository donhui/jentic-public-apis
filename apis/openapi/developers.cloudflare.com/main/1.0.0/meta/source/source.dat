{
  "openapi": "3.0.3",
  "info": {
    "title": "Cloudflare Pages API",
    "description": "Cloudflare Pages is a JAMstack platform for frontend developers to collaborate and deploy websites. This API manages Pages projects and deployments.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developers.cloudflare.com/api/operations/pages-project-get-projects"
  },
  "servers": [
    {
      "url": "https://api.cloudflare.com/client/v4",
      "description": "Cloudflare API v4"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/accounts/{account_id}/pages/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "Get Projects",
        "description": "Fetch a list of all user projects.",
        "tags": ["Projects"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of projects per page.",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Project"
                          }
                        },
                        "result_info": {
                          "$ref": "#/components/schemas/ResultInfo"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create Project",
        "description": "Create a new project.",
        "tags": ["Projects"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/Project"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/pages/projects/{project_name}": {
      "get": {
        "operationId": "getProject",
        "summary": "Get Project",
        "description": "Fetch a project by name.",
        "tags": ["Projects"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/ProjectName"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/Project"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteProject",
        "summary": "Delete Project",
        "description": "Delete a project by name.",
        "tags": ["Projects"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/ProjectName"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/pages/projects/{project_name}/deployments": {
      "get": {
        "operationId": "listDeployments",
        "summary": "Get Deployments",
        "description": "Fetch a list of project deployments.",
        "tags": ["Deployments"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/ProjectName"
          },
          {
            "name": "env",
            "in": "query",
            "description": "Filter by deployment environment.",
            "schema": {
              "type": "string",
              "enum": ["production", "preview"]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number.",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page.",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Deployment"
                          }
                        },
                        "result_info": {
                          "$ref": "#/components/schemas/ResultInfo"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createDeployment",
        "summary": "Create Deployment",
        "description": "Start a new deployment.",
        "tags": ["Deployments"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/ProjectName"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "branch": {
                    "type": "string",
                    "description": "The branch to build the new deployment from."
                  },
                  "commit_hash": {
                    "type": "string",
                    "description": "The commit hash for the deployment."
                  },
                  "commit_message": {
                    "type": "string",
                    "description": "The commit message for the deployment."
                  },
                  "commit_dirty": {
                    "type": "boolean",
                    "description": "Whether the commit was dirty."
                  },
                  "manifest": {
                    "type": "string",
                    "description": "File manifest mapping."
                  },
                  "pages_build_output_dir": {
                    "type": "string",
                    "description": "Build output directory path."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/Deployment"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/pages/projects/{project_name}/deployments/{deployment_id}": {
      "delete": {
        "operationId": "deleteDeployment",
        "summary": "Delete Deployment",
        "description": "Delete a deployment by ID.",
        "tags": ["Deployments"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/ProjectName"
          },
          {
            "name": "deployment_id",
            "in": "path",
            "required": true,
            "description": "Deployment identifier.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Cloudflare API Token"
      }
    },
    "parameters": {
      "AccountId": {
        "name": "account_id",
        "in": "path",
        "required": true,
        "description": "Account identifier.",
        "schema": {
          "type": "string"
        }
      },
      "ProjectName": {
        "name": "project_name",
        "in": "path",
        "required": true,
        "description": "Name of the project.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Project identifier."
          },
          "name": {
            "type": "string",
            "description": "Project name."
          },
          "created_on": {
            "type": "string",
            "format": "date-time",
            "description": "When the project was created."
          },
          "subdomain": {
            "type": "string",
            "description": "The Cloudflare subdomain."
          },
          "domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Associated custom domains."
          },
          "framework": {
            "type": "string",
            "description": "Framework used."
          },
          "framework_version": {
            "type": "string",
            "description": "Framework version."
          },
          "production_branch": {
            "type": "string",
            "description": "Production branch name."
          },
          "uses_functions": {
            "type": "boolean",
            "description": "Whether the project uses Pages Functions."
          },
          "canonical_deployment": {
            "$ref": "#/components/schemas/Deployment"
          },
          "latest_deployment": {
            "$ref": "#/components/schemas/Deployment"
          },
          "build_config": {
            "$ref": "#/components/schemas/BuildConfig"
          },
          "deployment_configs": {
            "type": "object",
            "properties": {
              "preview": {
                "type": "object",
                "description": "Preview deployment configuration."
              },
              "production": {
                "type": "object",
                "description": "Production deployment configuration."
              }
            }
          },
          "source": {
            "type": "object",
            "description": "Source control configuration.",
            "properties": {
              "type": {
                "type": "string",
                "description": "Source type (e.g., github, gitlab)."
              },
              "config": {
                "type": "object",
                "description": "Source configuration."
              }
            }
          }
        }
      },
      "ProjectInput": {
        "type": "object",
        "required": ["name", "production_branch"],
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the project."
          },
          "production_branch": {
            "type": "string",
            "description": "The production branch for deployments."
          },
          "build_config": {
            "$ref": "#/components/schemas/BuildConfig"
          },
          "deployment_configs": {
            "type": "object",
            "properties": {
              "preview": {
                "type": "object"
              },
              "production": {
                "type": "object"
              }
            }
          },
          "source": {
            "type": "object",
            "description": "Source control configuration."
          }
        }
      },
      "Deployment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Deployment identifier."
          },
          "short_id": {
            "type": "string",
            "description": "Short deployment identifier."
          },
          "project_id": {
            "type": "string",
            "description": "Associated project identifier."
          },
          "project_name": {
            "type": "string",
            "description": "Associated project name."
          },
          "environment": {
            "type": "string",
            "description": "The deployment environment (production or preview)."
          },
          "url": {
            "type": "string",
            "description": "The live URL of the deployment."
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Alias URLs."
          },
          "created_on": {
            "type": "string",
            "format": "date-time"
          },
          "modified_on": {
            "type": "string",
            "format": "date-time"
          },
          "build_config": {
            "$ref": "#/components/schemas/BuildConfig"
          },
          "deployment_trigger": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "metadata": {
                "type": "object",
                "properties": {
                  "branch": {
                    "type": "string"
                  },
                  "commit_hash": {
                    "type": "string"
                  },
                  "commit_message": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "stages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Stage"
            }
          }
        }
      },
      "BuildConfig": {
        "type": "object",
        "properties": {
          "build_caching": {
            "type": "boolean",
            "description": "Whether build caching is enabled."
          },
          "build_command": {
            "type": "string",
            "description": "The build command."
          },
          "destination_dir": {
            "type": "string",
            "description": "Output directory for the build."
          },
          "root_dir": {
            "type": "string",
            "description": "Root directory for the build."
          },
          "web_analytics_tag": {
            "type": "string",
            "description": "Web analytics tag."
          },
          "web_analytics_token": {
            "type": "string",
            "description": "Web analytics token."
          }
        }
      },
      "Stage": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Stage name."
          },
          "status": {
            "type": "string",
            "description": "Stage status."
          },
          "started_on": {
            "type": "string",
            "format": "date-time"
          },
          "ended_on": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ResultInfo": {
        "type": "object",
        "properties": {
          "count": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "per_page": {
            "type": "number"
          },
          "total_count": {
            "type": "number"
          },
          "total_pages": {
            "type": "number"
          }
        }
      },
      "ResponseInfo": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "documentation_url": {
            "type": "string"
          }
        },
        "required": ["code", "message"]
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResponseInfo"
            }
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResponseInfo"
            }
          }
        },
        "required": ["success", "errors", "messages"]
      }
    }
  }
}