{
  "openapi": "3.0.3",
  "info": {
    "title": "Cloudflare Workers KV",
    "description": "Cloudflare Workers KV is a global, low-latency, key-value data store. It stores data in a small number of centralized data centers, then caches that data in Cloudflare's data centers after access.",
    "version": "4.0.0",
    "x-jentic-source-url": "https://developers.cloudflare.com/kv/api/"
  },
  "servers": [
    {
      "url": "https://api.cloudflare.com/client/v4"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/accounts/{account_id}/storage/kv/namespaces": {
      "get": {
        "operationId": "listNamespaces",
        "summary": "List Namespaces",
        "description": "Returns the namespaces owned by an account.",
        "tags": ["Namespaces"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "name": "direction",
            "in": "query",
            "description": "Direction to order namespaces.",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"]
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Field to order results by.",
            "schema": {
              "type": "string",
              "enum": ["id", "title"]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number of paginated results.",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Maximum number of results per page.",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Namespace"
                          }
                        },
                        "result_info": {
                          "$ref": "#/components/schemas/ResultInfo"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createNamespace",
        "summary": "Create a Namespace",
        "description": "Creates a namespace under the given title. A 400 is returned if the account already owns a namespace with this title. A namespace must be explicitly deleted to be replaced.",
        "tags": ["Namespaces"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "A human-readable string name for a Namespace."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/Namespace"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/storage/kv/namespaces/{namespace_id}": {
      "put": {
        "operationId": "renameNamespace",
        "summary": "Rename a Namespace",
        "description": "Modifies a namespace's title.",
        "tags": ["Namespaces"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "A human-readable string name for a Namespace."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/Namespace"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "removeNamespace",
        "summary": "Remove a Namespace",
        "description": "Deletes the namespace corresponding to the given ID.",
        "tags": ["Namespaces"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/storage/kv/namespaces/{namespace_id}/values/{key_name}": {
      "get": {
        "operationId": "readKeyValuePair",
        "summary": "Read key-value pair",
        "description": "Returns the value associated with the given key in the given namespace. If the KV pair has an expiration set, the expiration is returned in the expiration response header.",
        "tags": ["Key-Value Pairs"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          },
          {
            "$ref": "#/components/parameters/KeyName"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with value as body",
            "headers": {
              "expiration": {
                "description": "Unix timestamp of key expiration, if set.",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "writeKeyValuePairWithMetadata",
        "summary": "Write key-value pair with metadata",
        "description": "Write a value identified by a key. Use URL-encoding to use special characters (for example, :, !, %) in the key name. Body should be the value to be stored along with JSON metadata via multipart/form-data.",
        "tags": ["Key-Value Pairs"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          },
          {
            "$ref": "#/components/parameters/KeyName"
          },
          {
            "name": "expiration",
            "in": "query",
            "description": "The time, measured in number of seconds since the UNIX epoch, at which the key should expire.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "expiration_ttl",
            "in": "query",
            "description": "The number of seconds for which the key should be visible before it expires. Must be at least 60.",
            "schema": {
              "type": "integer",
              "minimum": 60
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["value"],
                "properties": {
                  "value": {
                    "type": "string",
                    "description": "The value to store."
                  },
                  "metadata": {
                    "type": "string",
                    "description": "JSON metadata to associate with the key-value pair."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteKeyValuePair",
        "summary": "Delete key-value pair",
        "description": "Remove a KV pair from the namespace. Use URL-encoding to use special characters (for example, :, !, %) in the key name.",
        "tags": ["Key-Value Pairs"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          },
          {
            "$ref": "#/components/parameters/KeyName"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/storage/kv/namespaces/{namespace_id}/metadata/{key_name}": {
      "get": {
        "operationId": "readKeyMetadata",
        "summary": "Read the metadata for a key",
        "description": "Returns the metadata associated with the given key in the given namespace.",
        "tags": ["Key-Value Pairs"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          },
          {
            "$ref": "#/components/parameters/KeyName"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "type": "object",
                          "description": "Arbitrary JSON metadata associated with the key."
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/storage/kv/namespaces/{namespace_id}/bulk": {
      "put": {
        "operationId": "writeMultipleKeyValuePairs",
        "summary": "Write multiple key-value pairs",
        "description": "Write multiple keys and values at once. Body should be an array of up to 10,000 key-value pairs. The entire request size must be 100 megabytes or less.",
        "tags": ["Bulk Operations"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "maxItems": 10000,
                "items": {
                  "$ref": "#/components/schemas/BulkWriteItem"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/BulkResult"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/storage/kv/namespaces/{namespace_id}/bulk/delete": {
      "post": {
        "operationId": "deleteMultipleKeyValuePairs",
        "summary": "Delete multiple key-value pairs",
        "description": "Remove multiple KV pairs from the namespace. Body should be an array of up to 10,000 keys to be removed.",
        "tags": ["Bulk Operations"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "$ref": "#/components/parameters/NamespaceId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "maxItems": 10000,
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/BulkResult"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Cloudflare API Token"
      }
    },
    "parameters": {
      "AccountId": {
        "name": "account_id",
        "in": "path",
        "required": true,
        "description": "Account identifier.",
        "schema": {
          "type": "string"
        }
      },
      "NamespaceId": {
        "name": "namespace_id",
        "in": "path",
        "required": true,
        "description": "Namespace identifier tag.",
        "schema": {
          "type": "string"
        }
      },
      "KeyName": {
        "name": "key_name",
        "in": "path",
        "required": true,
        "description": "A key's name. The name may be at most 512 bytes. All printable, non-whitespace characters are valid.",
        "schema": {
          "type": "string",
          "maxLength": 512
        }
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiMessage"
            }
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiMessage"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiMessage"
            }
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiMessage"
            }
          }
        }
      },
      "ApiMessage": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "documentation_url": {
            "type": "string"
          }
        }
      },
      "Namespace": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Namespace identifier tag."
          },
          "title": {
            "type": "string",
            "description": "A human-readable string name for a Namespace."
          },
          "supports_url_encoding": {
            "type": "boolean",
            "description": "True if keys written on the URL will be URL-decoded before storing."
          }
        }
      },
      "ResultInfo": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "total_count": {
            "type": "integer"
          }
        }
      },
      "BulkWriteItem": {
        "type": "object",
        "required": ["key", "value"],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 512,
            "description": "A key's name."
          },
          "value": {
            "type": "string",
            "description": "A UTF-8 encoded string to be stored, up to 25 MiB in length."
          },
          "base64": {
            "type": "boolean",
            "description": "Whether or not the server should base64 decode the value before storing it."
          },
          "expiration": {
            "type": "integer",
            "description": "The time, measured in number of seconds since the UNIX epoch, at which the key should expire."
          },
          "expiration_ttl": {
            "type": "integer",
            "minimum": 60,
            "description": "The number of seconds for which the key should be visible before it expires."
          },
          "metadata": {
            "type": "object",
            "description": "Arbitrary JSON to be associated with a key/value pair."
          }
        }
      },
      "BulkResult": {
        "type": "object",
        "properties": {
          "successful_key_count": {
            "type": "integer",
            "description": "Number of keys successfully updated."
          },
          "unsuccessful_keys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Keys that failed and should be retried."
          }
        }
      }
    }
  }
}