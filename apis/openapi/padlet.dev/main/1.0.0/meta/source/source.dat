{
  "openapi": "3.0.3",
  "info": {
    "title": "Padlet API",
    "description": "Padlet is an online platform for collaboration and learning. The API allows you to manage boards, posts, comments, reactions, organizations, and users programmatically.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.padlet.dev/reference/introduction"
  },
  "servers": [
    {
      "url": "https://api.padlet.dev/v1",
      "description": "Padlet API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Boards",
      "description": "Manage boards"
    },
    {
      "name": "Posts",
      "description": "Manage posts on boards"
    },
    {
      "name": "Comments",
      "description": "Manage comments on posts"
    },
    {
      "name": "Reactions",
      "description": "Manage reactions on posts"
    },
    {
      "name": "AI Recipe Boards",
      "description": "AI-powered board creation"
    },
    {
      "name": "Users",
      "description": "User information"
    },
    {
      "name": "Organizations",
      "description": "Organization management"
    }
  ],
  "paths": {
    "/boards/{board_id}": {
      "get": {
        "operationId": "getBoardById",
        "summary": "Retrieve a board",
        "description": "Retrieves a board by its ID, including its metadata and configuration.",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "name": "board_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the board",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Board retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Board"
                }
              }
            }
          },
          "404": {
            "description": "Board not found"
          }
        }
      }
    },
    "/boards/{board_id}/posts": {
      "post": {
        "operationId": "addPost",
        "summary": "Add a post to a board",
        "description": "Creates a new post on the specified board.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "board_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the board",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Post created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          }
        }
      }
    },
    "/posts/{post_hashid}/comments": {
      "post": {
        "operationId": "createComment",
        "summary": "Create a comment on a post",
        "description": "Adds a new comment to the specified post.",
        "tags": [
          "Comments"
        ],
        "parameters": [
          {
            "name": "post_hashid",
            "in": "path",
            "required": true,
            "description": "The hash ID of the post",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CommentCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          }
        }
      }
    },
    "/posts/{post_id}/reactions": {
      "post": {
        "operationId": "createReaction",
        "summary": "Create a reaction on a post",
        "description": "Adds a reaction to the specified post.",
        "tags": [
          "Reactions"
        ],
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the post",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReactionCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reaction created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Reaction"
                }
              }
            }
          }
        }
      }
    },
    "/posts/{post_id}/attachmentData": {
      "get": {
        "operationId": "getPostAttachmentData",
        "summary": "Get post attachment data",
        "description": "Retrieves the attachment data for a specific post.",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "post_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the post",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attachment data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentData"
                }
              }
            }
          }
        }
      }
    },
    "/ai-recipe-boards": {
      "post": {
        "operationId": "createAiRecipeBoard",
        "summary": "Create an AI recipe board",
        "description": "Initiates the creation of a board using an AI recipe. Returns a status key to track creation progress.",
        "tags": [
          "AI Recipe Boards"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiRecipeBoardCreate"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "AI recipe board creation initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiRecipeBoardCreationStatus"
                }
              }
            }
          }
        }
      }
    },
    "/ai-recipe-boards/status/{status_key}": {
      "get": {
        "operationId": "getAiRecipeBoardStatus",
        "summary": "Get AI recipe board creation status",
        "description": "Checks the status of an AI recipe board creation process.",
        "tags": [
          "AI Recipe Boards"
        ],
        "parameters": [
          {
            "name": "status_key",
            "in": "path",
            "required": true,
            "description": "The status key returned from the create AI recipe board request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiRecipeBoardCreationStatus"
                }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user",
        "description": "Retrieves information about the currently authenticated user.",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Current user info retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{org_id}": {
      "get": {
        "operationId": "getOrganizationById",
        "summary": "Get organization by ID",
        "description": "Retrieves an organization by its unique identifier.",
        "tags": [
          "Organizations"
        ],
        "parameters": [
          {
            "name": "org_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the organization",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Organization retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Organization"
                }
              }
            }
          }
        }
      }
    },
    "/organizations/{org_id}/users/{user_id}": {
      "get": {
        "operationId": "getUserInfoInOrg",
        "summary": "Get user info in organization",
        "description": "Retrieves information about a specific user within an organization.",
        "tags": [
          "Organizations"
        ],
        "parameters": [
          {
            "name": "org_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the organization",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the user",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User info retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Obtain an API token from your Padlet account settings."
      }
    },
    "schemas": {
      "Board": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique board identifier"
          },
          "title": {
            "type": "string",
            "description": "Board title"
          },
          "description": {
            "type": "string",
            "description": "Board description"
          },
          "privacy": {
            "type": "string",
            "description": "Privacy setting of the board"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the board"
          },
          "thumbnail_url": {
            "type": "string",
            "format": "uri",
            "description": "Thumbnail image URL"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Post": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique post identifier"
          },
          "body": {
            "type": "string",
            "description": "Post body content"
          },
          "subject": {
            "type": "string",
            "description": "Post subject/title"
          },
          "attachment": {
            "type": "string",
            "description": "Attachment URL"
          },
          "color": {
            "type": "string",
            "description": "Post color"
          },
          "status": {
            "type": "string",
            "description": "Post status"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PostCreate": {
        "type": "object",
        "properties": {
          "body": {
            "type": "string",
            "description": "Post body content"
          },
          "subject": {
            "type": "string",
            "description": "Post subject/title"
          },
          "attachment": {
            "type": "string",
            "description": "Attachment URL"
          },
          "color": {
            "type": "string",
            "description": "Post color"
          }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique comment identifier"
          },
          "body": {
            "type": "string",
            "description": "Comment body"
          },
          "author": {
            "$ref": "#/components/schemas/User"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CommentCreate": {
        "type": "object",
        "required": [
          "body"
        ],
        "properties": {
          "body": {
            "type": "string",
            "description": "Comment body text"
          }
        }
      },
      "Reaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique reaction identifier"
          },
          "value": {
            "type": "integer",
            "description": "Reaction value"
          },
          "author": {
            "$ref": "#/components/schemas/User"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ReactionCreate": {
        "type": "object",
        "properties": {
          "value": {
            "type": "integer",
            "description": "Reaction value"
          }
        }
      },
      "AttachmentData": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Attachment URL"
          },
          "content_type": {
            "type": "string",
            "description": "MIME type of the attachment"
          },
          "filename": {
            "type": "string",
            "description": "Original filename"
          }
        }
      },
      "AiRecipeBoardCreate": {
        "type": "object",
        "properties": {
          "recipe": {
            "type": "string",
            "description": "The AI recipe to use for board creation"
          },
          "title": {
            "type": "string",
            "description": "Optional title for the board"
          }
        }
      },
      "AiRecipeBoardCreationStatus": {
        "type": "object",
        "properties": {
          "status_key": {
            "type": "string",
            "description": "Key to check creation status"
          },
          "status": {
            "type": "string",
            "description": "Current status of the creation process"
          },
          "board_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the created board (when complete)"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique user identifier"
          },
          "name": {
            "type": "string",
            "description": "User display name"
          },
          "username": {
            "type": "string",
            "description": "Username"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          },
          "avatar_url": {
            "type": "string",
            "format": "uri",
            "description": "Avatar image URL"
          }
        }
      },
      "Organization": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique organization identifier"
          },
          "name": {
            "type": "string",
            "description": "Organization name"
          },
          "domain": {
            "type": "string",
            "description": "Organization domain"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Section": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique section identifier"
          },
          "title": {
            "type": "string",
            "description": "Section title"
          },
          "position": {
            "type": "integer",
            "description": "Section position in the board"
          }
        }
      }
    }
  }
}