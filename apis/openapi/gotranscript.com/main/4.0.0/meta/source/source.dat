{
  "openapi": "3.0.3",
  "info": {
    "title": "GoTranscript API",
    "version": "4.0.0",
    "description": "Transcription, captions, translation, and related services API. Supports human and AI transcription, proofreading, forced alignment, translation, captions, and subtitles.",
    "x-jentic-source-url": "https://gotranscript.com/api"
  },
  "servers": [
    {
      "url": "https://gotranscript.com/api/v4"
    }
  ],
  "paths": {
    "/transcriptions": {
      "post": {
        "operationId": "createTranscription",
        "summary": "Create a transcription order",
        "tags": ["Transcription"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transcription order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid API token"
          }
        }
      }
    },
    "/ai-transcriptions": {
      "post": {
        "operationId": "createAiTranscription",
        "summary": "Create an AI transcription and captions order",
        "tags": ["Transcription"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiTranscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI transcription order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/transcription-proofreading": {
      "post": {
        "operationId": "createTranscriptionProofreading",
        "summary": "Create a transcription proofreading order",
        "tags": ["Proofreading"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProofreadingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Proofreading order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/forced-alignment": {
      "post": {
        "operationId": "createForcedAlignment",
        "summary": "Create a forced alignment order",
        "tags": ["Alignment"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForcedAlignmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Forced alignment order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/translations": {
      "post": {
        "operationId": "createTranslation",
        "summary": "Create a translation order",
        "tags": ["Translation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Translation order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/captions": {
      "post": {
        "operationId": "createCaptions",
        "summary": "Create a captions order",
        "tags": ["Captions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaptionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Captions order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/subtitles": {
      "post": {
        "operationId": "createSubtitles",
        "summary": "Create a subtitles order",
        "tags": ["Captions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaptionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subtitles order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "Get list of all orders",
        "tags": ["Orders"],
        "responses": {
          "200": {
            "description": "List of orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OrderSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/orders/{order_id}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get a specific order by ID",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The order identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "api_token",
        "description": "API token for authentication. Included in the request body as api_token field."
      }
    },
    "schemas": {
      "TranscriptionRequest": {
        "type": "object",
        "required": ["api_token", "mode", "url", "language"],
        "properties": {
          "api_token": {
            "type": "string",
            "description": "Your API token"
          },
          "mode": {
            "type": "string",
            "enum": ["test", "live"],
            "description": "Test mode (no charge) or live mode"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the audio/video file"
          },
          "language": {
            "type": "string",
            "description": "Language of the content"
          },
          "comment": {
            "type": "string"
          },
          "from": {
            "type": "string",
            "description": "Start timestamp"
          },
          "till": {
            "type": "string",
            "description": "End timestamp"
          },
          "text_format": {
            "type": "string",
            "enum": ["docx", "doc", "pdf", "text", "html", "json", "json2"],
            "description": "Output text format"
          },
          "timestamping": {
            "type": "string",
            "description": "Timestamping preference"
          },
          "turnaround_time": {
            "type": "string",
            "description": "Desired turnaround time"
          },
          "number_of_speakers": {
            "type": "integer",
            "description": "Number of speakers in the audio"
          },
          "callback_url": {
            "type": "string",
            "format": "uri",
            "description": "URL for delivery callback notification"
          }
        }
      },
      "AiTranscriptionRequest": {
        "type": "object",
        "required": ["api_token", "mode", "url", "language"],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": ["test", "live"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "language": {
            "type": "string"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "ProofreadingRequest": {
        "type": "object",
        "required": ["api_token", "mode", "audio_url", "transcription_url", "language"],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": ["test", "live"]
          },
          "audio_url": {
            "type": "string",
            "format": "uri"
          },
          "transcription_url": {
            "type": "string",
            "format": "uri"
          },
          "language": {
            "type": "string"
          },
          "text_format": {
            "type": "string"
          },
          "timestamping": {
            "type": "string"
          },
          "turnaround_time": {
            "type": "string"
          },
          "captions": {
            "type": "boolean"
          },
          "auto_retranscribe": {
            "type": "boolean"
          },
          "comment": {
            "type": "string"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "ForcedAlignmentRequest": {
        "type": "object",
        "required": ["api_token", "mode", "audio_url", "transcription_url", "language"],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": ["test", "live"]
          },
          "audio_url": {
            "type": "string",
            "format": "uri"
          },
          "transcription_url": {
            "type": "string",
            "format": "uri"
          },
          "language": {
            "type": "string"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "TranslationRequest": {
        "type": "object",
        "required": ["api_token", "mode", "url", "translate_from", "translate_to"],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": ["test", "live"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "translate_from": {
            "type": "string",
            "description": "Source language"
          },
          "translate_to": {
            "type": "string",
            "description": "Target language"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "CaptionsRequest": {
        "type": "object",
        "required": ["api_token", "mode", "url", "language"],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": ["test", "live"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "language": {
            "type": "string"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "order_id": {
            "type": "string"
          },
          "order_total": {
            "type": "number"
          },
          "seconds": {
            "type": "number"
          },
          "in_wallet": {
            "type": "number"
          },
          "delivery_estimate": {
            "type": "string"
          }
        }
      },
      "AiOrderResponse": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "order_id": {
            "type": "string"
          },
          "order_total": {
            "type": "number"
          },
          "seconds": {
            "type": "number"
          },
          "in_wallet": {
            "type": "number"
          },
          "ai_transcripts_minutes_left": {
            "type": "number"
          },
          "delivery_estimate": {
            "type": "string"
          }
        }
      },
      "OrderSummary": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OrderDetail": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "order_total": {
            "type": "number"
          },
          "delivery_estimate": {
            "type": "string"
          },
          "transcription_url": {
            "type": "string",
            "format": "uri"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiToken": []
    }
  ]
}