{
  "openapi": "3.0.3",
  "info": {
    "title": "GoTranscript Transcription API",
    "description": "GoTranscript API allows you to submit files for transcription, AI transcription, translation, captioning, subtitling, and forced alignment. Orders are placed via POST requests and results are delivered via callbacks.",
    "version": "4.0.0",
    "x-jentic-source-url": "https://gotranscript.com/transcription-api"
  },
  "servers": [
    {
      "url": "https://gotranscript.com/api/v4",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiTokenBody": []
    }
  ],
  "tags": [
    {
      "name": "Transcription",
      "description": "Human and AI transcription endpoints"
    },
    {
      "name": "Translation",
      "description": "Translation and subtitle endpoints"
    },
    {
      "name": "Captions",
      "description": "Captioning endpoints"
    },
    {
      "name": "Orders",
      "description": "Order management endpoints"
    },
    {
      "name": "Languages",
      "description": "Language listing endpoints"
    }
  ],
  "paths": {
    "/transcriptions": {
      "post": {
        "operationId": "createTranscription",
        "summary": "Order a human transcription",
        "description": "Submit a file for human transcription. In test mode, the price is calculated but not charged.",
        "tags": [
          "Transcription"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid api_token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ai-transcriptions": {
      "post": {
        "operationId": "createAiTranscription",
        "summary": "Order an AI transcription with captions",
        "description": "Submit a file for AI-powered transcription. Returns both transcription and caption files.",
        "tags": [
          "Transcription"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiTranscriptionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiTranscriptionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transcription-proofreading": {
      "post": {
        "operationId": "createTranscriptionProofreading",
        "summary": "Order transcription proofreading",
        "description": "Submit audio and AI transcription for proofreading. Low-quality transcriptions will be refunded.",
        "tags": [
          "Transcription"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProofreadingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forced-alignment": {
      "post": {
        "operationId": "createForcedAlignment",
        "summary": "Order forced alignment",
        "description": "Align spoken words from audio files with timestamps for accurate word-level segmentation.",
        "tags": [
          "Transcription"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForcedAlignmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/translations": {
      "post": {
        "operationId": "createTranslation",
        "summary": "Order a translation",
        "description": "Submit a file for translation from one language to another.",
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslationOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/captions": {
      "post": {
        "operationId": "createCaptions",
        "summary": "Order captions",
        "description": "Submit a file for human captioning.",
        "tags": [
          "Captions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaptionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/subtitles": {
      "post": {
        "operationId": "createSubtitles",
        "summary": "Order subtitles",
        "description": "Submit a file for subtitle creation with translation.",
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubtitlesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslationOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/languages": {
      "get": {
        "operationId": "listLanguages",
        "summary": "List supported languages",
        "description": "Retrieve supported languages for all GoTranscript products.",
        "tags": [
          "Languages"
        ],
        "security": [],
        "parameters": [
          {
            "name": "product",
            "in": "query",
            "description": "Filter languages by product.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "transcription",
                "ai_transcription",
                "transcription_proofreading",
                "forced_alignment",
                "translation",
                "captions",
                "subtitles"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Languages retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LanguagesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "Get list of orders",
        "description": "Retrieve a paginated list of orders.",
        "tags": [
          "Orders"
        ],
        "parameters": [
          {
            "name": "api_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API token."
          },
          {
            "name": "mode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "test",
                "live"
              ]
            },
            "description": "Test or live mode."
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Pagination cursor."
          }
        ],
        "responses": {
          "200": {
            "description": "Orders retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrdersListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/orders/{orderId}": {
      "get": {
        "operationId": "getOrderById",
        "summary": "Get order by ID",
        "description": "Retrieve a specific order by its ID.",
        "tags": [
          "Orders"
        ],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The order ID."
          },
          {
            "name": "api_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API token."
          },
          {
            "name": "mode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "test",
                "live"
              ]
            },
            "description": "Test or live mode."
          }
        ],
        "responses": {
          "200": {
            "description": "Order retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiTokenBody": {
        "type": "apiKey",
        "in": "query",
        "name": "api_token",
        "description": "API token passed as a body parameter or query parameter."
      }
    },
    "schemas": {
      "TranscriptionRequest": {
        "type": "object",
        "required": [
          "api_token",
          "mode",
          "url",
          "language"
        ],
        "properties": {
          "api_token": {
            "type": "string",
            "description": "Your API token."
          },
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ],
            "description": "Test mode calculates price without charging. Live mode places the order."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the file to transcribe."
          },
          "language": {
            "type": "string",
            "description": "Language of the file (e.g., english, french, german)."
          },
          "comment": {
            "type": "string",
            "description": "Names of speakers or other information for transcribers."
          },
          "from": {
            "type": "integer",
            "description": "Start transcription from this number of seconds."
          },
          "till": {
            "type": "integer",
            "description": "Finish transcription at this number of seconds."
          },
          "text_format": {
            "type": "string",
            "enum": [
              "clean_verbatim",
              "full_verbatim"
            ],
            "default": "clean_verbatim"
          },
          "timestamping": {
            "type": "string",
            "enum": [
              "not_required",
              "every_10_seconds",
              "every_30_seconds",
              "every_2_minutes",
              "change_of_speaker"
            ],
            "default": "not_required"
          },
          "turnaround_time": {
            "type": "string",
            "enum": [
              "12_hours",
              "1_days",
              "3_days",
              "5_days"
            ],
            "default": "5_days"
          },
          "number_of_speakers": {
            "type": "string",
            "enum": [
              "1_or_2",
              "3_or_more"
            ],
            "default": "1_or_2"
          },
          "callback_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to receive callback when order is finished."
          }
        }
      },
      "AiTranscriptionRequest": {
        "type": "object",
        "required": [
          "api_token",
          "mode",
          "url",
          "language"
        ],
        "properties": {
          "api_token": {
            "type": "string",
            "description": "Your API token."
          },
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Audio URL to transcribe."
          },
          "language": {
            "type": "string",
            "description": "Language of audio file."
          },
          "callback_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to receive callback when order is finished."
          }
        }
      },
      "ProofreadingRequest": {
        "type": "object",
        "required": [
          "api_token",
          "mode",
          "audio_url",
          "transcription_url",
          "language"
        ],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ]
          },
          "audio_url": {
            "type": "string",
            "format": "uri",
            "description": "Audio file URL."
          },
          "transcription_url": {
            "type": "string",
            "format": "uri",
            "description": "Transcription file URL to correct. Supported formats: doc, docx, rtf, pdf, txt."
          },
          "language": {
            "type": "string",
            "description": "Language of the file."
          },
          "captions": {
            "type": "boolean",
            "default": false,
            "description": "Order captions along with proofreading."
          },
          "auto_retranscribe": {
            "type": "boolean",
            "default": false,
            "description": "Create human transcription if AI quality is too low."
          },
          "comment": {
            "type": "string"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "ForcedAlignmentRequest": {
        "type": "object",
        "required": [
          "api_token",
          "mode",
          "audio_url",
          "transcription_url",
          "language"
        ],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ]
          },
          "audio_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the audio file for forced alignment."
          },
          "transcription_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the transcription file to align."
          },
          "language": {
            "type": "string",
            "enum": [
              "english",
              "french",
              "spanish"
            ],
            "description": "Language of the audio and transcript."
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "TranslationRequest": {
        "type": "object",
        "required": [
          "api_token",
          "mode",
          "url",
          "translate_from",
          "translate_to"
        ],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "File URL to translate."
          },
          "translate_from": {
            "type": "string",
            "description": "Source language."
          },
          "translate_to": {
            "type": "string",
            "description": "Target language."
          },
          "additional_review": {
            "type": "boolean",
            "default": false,
            "description": "Enable final review by expert translator."
          },
          "comment": {
            "type": "string"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "CaptionsRequest": {
        "type": "object",
        "required": [
          "api_token",
          "mode",
          "url",
          "language"
        ],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "File URL to caption."
          },
          "language": {
            "type": "string",
            "description": "Language of the file."
          },
          "comment": {
            "type": "string"
          },
          "from": {
            "type": "integer"
          },
          "till": {
            "type": "integer"
          },
          "text_format": {
            "type": "string",
            "enum": [
              "clean_verbatim",
              "full_verbatim"
            ],
            "default": "clean_verbatim"
          },
          "timestamping": {
            "type": "string",
            "enum": [
              "not_required",
              "every_10_seconds",
              "every_30_seconds",
              "every_2_minutes",
              "change_of_speaker"
            ],
            "default": "not_required"
          },
          "turnaround_time": {
            "type": "string",
            "enum": [
              "12_hours",
              "1_days",
              "3_days",
              "5_days"
            ],
            "default": "5_days"
          },
          "number_of_speakers": {
            "type": "string",
            "enum": [
              "1_or_2",
              "3_or_more"
            ],
            "default": "1_or_2"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "SubtitlesRequest": {
        "type": "object",
        "required": [
          "api_token",
          "mode",
          "url",
          "translate_from",
          "translate_to"
        ],
        "properties": {
          "api_token": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "File URL to create subtitles for."
          },
          "translate_from": {
            "type": "string",
            "description": "Source language."
          },
          "translate_to": {
            "type": "string",
            "description": "Target language."
          },
          "additional_review": {
            "type": "boolean",
            "default": false
          },
          "comment": {
            "type": "string"
          },
          "callback_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ]
          },
          "status": {
            "type": "string",
            "example": "success"
          },
          "order_id": {
            "type": "integer",
            "description": "Order ID, set only when wallet is charged (live mode)."
          },
          "order_total": {
            "type": "number",
            "format": "float",
            "description": "Order total in USD."
          },
          "seconds": {
            "type": "integer",
            "description": "Order duration in seconds."
          },
          "in_wallet": {
            "type": "number",
            "format": "float",
            "description": "Remaining wallet balance."
          },
          "delivery_estimate": {
            "type": "string",
            "description": "Estimated delivery time in UTC."
          }
        }
      },
      "AiTranscriptionResponse": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "test",
              "live"
            ]
          },
          "status": {
            "type": "string"
          },
          "order_id": {
