{
  "openapi": "3.0.3",
  "info": {
    "title": "Lightspeed Retail X-Series API",
    "version": "2026-01",
    "description": "Lightspeed Retail (X-Series) REST API for managing products, brands, customers, sales, consignments, inventory, and more. Uses date-based versioning (YYYY-MM) with quarterly releases and 12-month support lifecycles.",
    "x-jentic-source-url": "https://x-series-api.lightspeedhq.com/"
  },
  "servers": [
    {
      "url": "https://{domain_prefix}.retail.lightspeed.app/api/2026-01",
      "description": "Lightspeed Retail X-Series API",
      "variables": {
        "domain_prefix": {
          "default": "example",
          "description": "Store-specific domain prefix"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Brands", "description": "Manage product brands" },
    { "name": "Products", "description": "Manage products" },
    { "name": "Sales", "description": "Manage sales and returns" },
    { "name": "Consignments", "description": "Manage consignments (purchase orders, stock transfers)" },
    { "name": "ConsignmentProducts", "description": "Manage products within consignments" },
    { "name": "Audit", "description": "Audit events and security" },
    { "name": "Channels", "description": "Channel and request logging" },
    { "name": "Search", "description": "Cross-entity search" }
  ],
  "paths": {
    "/brands": {
      "get": {
        "operationId": "listBrands",
        "summary": "List brands",
        "tags": ["Brands"],
        "responses": {
          "200": {
            "description": "List of brands",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Brand" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createBrand",
        "summary": "Create a brand",
        "tags": ["Brands"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BrandInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Brand created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Brand" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/brands/{id}": {
      "get": {
        "operationId": "getBrandById",
        "summary": "Get a single brand",
        "tags": ["Brands"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Brand details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Brand" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateBrand",
        "summary": "Update a single brand",
        "tags": ["Brands"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BrandInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Brand updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Brand" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteBrand",
        "summary": "Delete a single brand",
        "tags": ["Brands"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Brand deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "List products",
        "tags": ["Products"],
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/consignments": {
      "get": {
        "operationId": "listConsignments",
        "summary": "List consignments",
        "tags": ["Consignments"],
        "responses": {
          "200": {
            "description": "List of consignments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Consignment" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createConsignment",
        "summary": "Create a consignment",
        "tags": ["Consignments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConsignmentInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Consignment created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Consignment" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/consignments/{id}": {
      "get": {
        "operationId": "getConsignmentById",
        "summary": "Get a single consignment",
        "tags": ["Consignments"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Consignment details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Consignment" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateConsignment",
        "summary": "Update a consignment",
        "tags": ["Consignments"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConsignmentInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Consignment updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Consignment" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteConsignment",
        "summary": "Delete a consignment",
        "tags": ["Consignments"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Consignment deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/consignments/{id}/products": {
      "get": {
        "operationId": "listConsignmentProducts",
        "summary": "List all products for a specific consignment",
        "tags": ["ConsignmentProducts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Consignment products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ConsignmentProduct" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "addConsignmentProduct",
        "summary": "Add a product to a consignment",
        "tags": ["ConsignmentProducts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConsignmentProductInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product added to consignment",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConsignmentProduct" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/consignments/{id}/products/{productId}": {
      "put": {
        "operationId": "updateConsignmentProduct",
        "summary": "Update a product in a consignment",
        "tags": ["ConsignmentProducts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConsignmentProductInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Consignment product updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConsignmentProduct" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteConsignmentProduct",
        "summary": "Delete an item from a consignment",
        "tags": ["ConsignmentProducts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Product removed from consignment" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/sales": {
      "get": {
        "operationId": "listSales",
        "summary": "List sales",
        "tags": ["Sales"],
        "responses": {
          "200": {
            "description": "List of sales",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Sale" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/sales/{id}": {
      "get": {
        "operationId": "getSaleById",
        "summary": "Get a single sale",
        "tags": ["Sales"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Sale details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sale" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/sales/{id}/actions/return": {
      "put": {
        "operationId": "processSaleReturn",
        "summary": "Process a sale return",
        "tags": ["Sales"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "lineItems": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "productId": { "type": "string" },
                        "quantity": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Return processed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sale" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/audit": {
      "get": {
        "operationId": "listAuditEvents",
        "summary": "List audit events",
        "tags": ["Audit"],
        "responses": {
          "200": {
            "description": "List of audit events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AuditEvent" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/security-events": {
      "get": {
        "operationId": "listSecurityEvents",
        "summary": "List security events for current user",
        "tags": ["Audit"],
        "responses": {
          "200": {
            "description": "List of security events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/SecurityEvent" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/channels": {
      "get": {
        "operationId": "listChannels",
        "summary": "List channel records",
        "tags": ["Channels"],
        "responses": {
          "200": {
            "description": "List of channels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Channel" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/requests": {
      "get": {
        "operationId": "listRequestLogs",
        "summary": "List request records",
        "tags": ["Channels"],
        "responses": {
          "200": {
            "description": "List of request logs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/RequestLog" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/requests/{id}": {
      "get": {
        "operationId": "getRequestLog",
        "summary": "Get a single request log",
        "tags": ["Channels"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Request log details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RequestLog" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/requests/{id}/text": {
      "get": {
        "operationId": "getRequestLogAsText",
        "summary": "Get a single request log as text",
        "tags": ["Channels"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Request log as text",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "searchEntities",
        "summary": "Search across entities",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Search query"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer token with scope-based authorization"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" },
          "statusCode": { "type": "integer" }
        }
      },
      "Brand": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "BrandInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["name"]
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "sku": { "type": "string" },
          "description": { "type": "string" },
          "retailPrice": { "type": "number" },
          "supplyPrice": { "type": "number" },
          "brandId": { "type": "string" },
          "active": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Consignment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "outletId": { "type": "string" },
          "supplierId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ConsignmentInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "outletId": { "type": "string" },
          "supplierId": { "type": "string" }
        },
        "required": ["name", "type"]
      },
      "ConsignmentProduct": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "count": { "type": "integer" },
          "cost": { "type": "number" },
          "received": { "type": "integer" }
        }
      },
      "ConsignmentProductInput": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "count": { "type": "integer" },
          "cost": { "type": "number" }
        },
        "required": ["productId", "count"]
      },
      "Sale": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "outletId": { "type": "string" },
          "customerId": { "type": "string" },
          "totalPrice": { "type": "number" },
          "totalTax": { "type": "number" },
          "status": { "type": "string" },
          "lineItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "productId": { "type": "string" },
                "quantity": { "type": "integer" },
                "price": { "type": "number" }
              }
            }
          },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "AuditEvent": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "action": { "type": "string" },
