{
  "openapi": "3.0.3",
  "info": {
    "title": "Lightspeed Retail (X-Series) API",
    "version": "1.0.0",
    "description": "Lightspeed Retail (X-Series, formerly Vend) API for managing retail operations including products, brands, customers, consignments, sales, outlets, registers, and more.",
    "x-jentic-source-url": "https://x-series-api.lightspeedhq.com/"
  },
  "servers": [
    {
      "url": "https://{domain_prefix}.retail.lightspeed.app/api/2.0",
      "description": "Lightspeed Retail X-Series API",
      "variables": {
        "domain_prefix": {
          "default": "store",
          "description": "Your store's domain prefix"
        }
      }
    }
  ],
  "paths": {
    "/auditlog_events": {
      "get": {
        "operationId": "listAuditLogEvents",
        "summary": "List audit log events",
        "description": "List all audit log events matching the given filters.",
        "tags": ["Audit"],
        "parameters": [
          {"name": "page_size", "in": "query", "schema": {"type": "integer"}},
          {"name": "offset", "in": "query", "schema": {"type": "integer"}},
          {"name": "from", "in": "query", "schema": {"type": "string", "format": "date-time"}},
          {"name": "to", "in": "query", "schema": {"type": "string", "format": "date-time"}},
          {"name": "order", "in": "query", "schema": {"type": "string"}},
          {"name": "user_id", "in": "query", "schema": {"type": "string"}},
          {"name": "type", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Audit log events", "content": {"application/json": {"schema": {"type": "object", "properties": {"data": {"type": "array", "items": {"type": "object"}}}}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/brands": {
      "get": {
        "operationId": "listBrands",
        "summary": "List all brands",
        "tags": ["Brands"],
        "parameters": [
          {"name": "after", "in": "query", "schema": {"type": "string"}},
          {"name": "before", "in": "query", "schema": {"type": "string"}},
          {"name": "page_size", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "List of brands", "content": {"application/json": {"schema": {"type": "object", "properties": {"data": {"type": "array", "items": {"$ref": "#/components/schemas/Brand"}}}}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "post": {
        "operationId": "createBrand",
        "summary": "Create a new brand",
        "tags": ["Brands"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BrandInput"}}}},
        "responses": {
          "200": {"description": "Brand created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Brand"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/brands/{brand_id}": {
      "get": {
        "operationId": "getBrand",
        "summary": "Retrieve a single brand",
        "tags": ["Brands"],
        "parameters": [{"name": "brand_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Brand details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Brand"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "put": {
        "operationId": "updateBrand",
        "summary": "Update a brand",
        "tags": ["Brands"],
        "parameters": [{"name": "brand_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {"content": {"application/json": {"schema": {"$ref": "#/components/schemas/BrandInput"}}}},
        "responses": {
          "200": {"description": "Brand updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Brand"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "delete": {
        "operationId": "deleteBrand",
        "summary": "Delete a brand",
        "tags": ["Brands"],
        "parameters": [{"name": "brand_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Brand deleted"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/button_layouts": {
      "get": {
        "operationId": "listButtonLayouts",
        "summary": "List button layouts for a register",
        "tags": ["Registers"],
        "responses": {
          "200": {"description": "Button layouts", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/button_layouts/{button_layout_id}": {
      "get": {
        "operationId": "getButtonLayout",
        "summary": "Get a single button layout",
        "tags": ["Registers"],
        "parameters": [{"name": "button_layout_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Button layout details", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/channels": {
      "get": {
        "operationId": "listChannels",
        "summary": "List configured channels",
        "tags": ["Channels"],
        "responses": {
          "200": {"description": "List of channels", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/consignments": {
      "get": {
        "operationId": "listConsignments",
        "summary": "List consignments",
        "tags": ["Consignments"],
        "responses": {
          "200": {"description": "List of consignments", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "post": {
        "operationId": "createConsignment",
        "summary": "Create a consignment",
        "tags": ["Consignments"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Consignment created", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/consignments/{consignment_id}": {
      "get": {
        "operationId": "getConsignment",
        "summary": "Get a single consignment",
        "tags": ["Consignments"],
        "parameters": [{"name": "consignment_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Consignment details", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "put": {
        "operationId": "updateConsignment",
        "summary": "Update a consignment",
        "tags": ["Consignments"],
        "parameters": [{"name": "consignment_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Consignment updated", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "delete": {
        "operationId": "deleteConsignment",
        "summary": "Delete a consignment",
        "tags": ["Consignments"],
        "parameters": [{"name": "consignment_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Consignment deleted"},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/consignments/{consignment_id}/products": {
      "get": {
        "operationId": "listConsignmentProducts",
        "summary": "List products in a consignment",
        "tags": ["Consignments"],
        "parameters": [{"name": "consignment_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Consignment products", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "post": {
        "operationId": "addConsignmentProduct",
        "summary": "Add a product to a consignment",
        "tags": ["Consignments"],
        "parameters": [{"name": "consignment_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Product added", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/consignments/{consignment_id}/bulk": {
      "post": {
        "operationId": "bulkUpdateConsignmentProducts",
        "summary": "Bulk update products in a consignment",
        "tags": ["Consignments"],
        "parameters": [{"name": "consignment_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Bulk update completed", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/consignments/{consignment_id}/totals": {
      "get": {
        "operationId": "getConsignmentTotals",
        "summary": "Get consignment totals",
        "tags": ["Consignments"],
        "parameters": [{"name": "consignment_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Consignment totals", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/customer_groups": {
      "get": {
        "operationId": "listCustomerGroups",
        "summary": "List customer groups",
        "tags": ["Customers"],
        "responses": {
          "200": {"description": "Customer groups", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      },
      "post": {
        "operationId": "createCustomerGroup",
        "summary": "Create a customer group",
        "tags": ["Customers"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {
          "200": {"description": "Customer group created", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/channel_requests": {
      "get": {
        "operationId": "listChannelRequests",
        "summary": "List channel request logs",
        "tags": ["Channels"],
        "responses": {
          "200": {"description": "Channel requests", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/channel_requests/{request_log_id}": {
      "get": {
        "operationId": "getChannelRequest",
        "summary": "Get a single channel request log",
        "tags": ["Channels"],
        "parameters": [{"name": "request_log_id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Channel request details", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://secure.retail.lightspeed.app/connect/authorize",
            "tokenUrl": "https://secure.retail.lightspeed.app/connect/token",
            "scopes": {
              "products:read": "Read products",
              "products:write": "Write products",
              "customers:read": "Read customers",
              "customers:write": "Write customers",
              "consignments:read": "Read consignments",
              "consignments:write": "Write consignments",
              "audit:read": "Read audit logs",
              "channels:read": "Read channels",
              "registers:read": "Read registers"
            }
          }
        }
      }
    },
    "schemas": {
      "Brand": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"}
        }
      },
      "BrandInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {"type": "string"},
          "details": {"type": "string"}
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {"name": "Audit", "description": "Audit log events"},
    {"name": "Brands", "description": "Product brands"},
    {"name": "Registers", "description": "Register and button layout management"},
    {"name": "Channels", "description": "Sales channels"},
    {"name": "Consignments", "description": "Stock consignment management"},
    {"name": "Customers", "description": "Customer and customer group management"}
  ]
}