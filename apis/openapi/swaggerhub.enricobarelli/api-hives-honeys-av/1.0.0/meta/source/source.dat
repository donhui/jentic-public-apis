        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/ENRICOBARELLI/API_HIVES_HONEYS_AV/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "developers",
            "description": "Operations available to regular developers"
        }
    ],
    "paths": {
        "/default/API_HIVES_HONEYS_AV": {
            "get": {
                "tags": [
                    "developers"
                ],
                "summary": "gets a json with honey category and count of all beekeepers that harvest it",
                "operationId": "getHoneysTotal",
                "description": "gets a json with plant name and count of all beekepers that harvest it\n",
                "responses": {
                    "200": {
                        "description": "list of plant name -> count"
                    },
                    "400": {
                        "description": "bad input parameter"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://kt9egdxo9a.execute-api.us-east-1.amazonaws.com"
        }
    ]
}