{
    "openapi": "3.0.0",
    "info": {
        "description": "This is a simple API to query an endpoint of beekepers to geta json with honey category and count of all beekeepers that harvest it",
        "version": "1.0.0",
        "title": "Simple honey info getter API",
        "contact": {
            "email": "enrico.barelli@gmail.com"
        },
        "license": {
