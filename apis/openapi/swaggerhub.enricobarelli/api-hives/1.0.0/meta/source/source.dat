{
    "openapi": "3.0.0",
    "info": {
        "description": "This is a simple API to query an endpoint of beekeepers and get all the hives sorted by rank ",
        "version": "1.0.0",
        "title": "Simple hive info getter API",
        "contact": {
            "email": "enrico.barelli@gmail.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/ENRICOBARELLI/API_HIVES/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "developers",
            "description": "Operations available to regular developers"
        }
    ],
    "paths": {
        "/default/API_HIVES": {
            "get": {
                "tags": [
                    "developers"
                ],
                "summary": "gets all hives sorted by ranking",
                "operationId": "getHives",
                "description": "gets all hives sorted by ranking\n",
                "responses": {
                    "200": {
                        "description": "all hives sorted by ranking",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Hive"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "bad input parameter"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://h8f8x1qgz4.execute-api.us-east-1.amazonaws.com"
        }
    ],
    "components": {
        "schemas": {
            "Hive": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "name": {
                        "type": "string"
                    },
                    "user_id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "queen_name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "latitude": {
                        "type": "number",
                        "format": "double"
                    },
                    "longitude": {
                        "type": "number",
                        "format": "double"
                    },
                    "published": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "race": {
                        "type": "string"
                    },
                    "weight": {
                        "type": "number",
                        "format": "double"
                    },
                    "sound": {
                        "type": "number",
                        "format": "double"
                    },
                    "rare": {
                        "type": "boolean"
                    },
                    "special": {
                        "type": "boolean"
                    },
                    "main_image": {
                        "type": "string"
                    },
                    "beekeeper_id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "beekeeper_ranking": {
                        "type": "integer",
                        "format": "int64"
                    }
                }
            }
        }
    }
}