  "components": {
    "schemas": {
      "FoodImageResponse": {
        "type": "object",
        "required": [
          "image"
        ],
        "properties": {
          "image": {
            "type": "string",
            "format": "uri",
            "description": "URL of the random food image",
            "example": "https://foodish-api.com/images/burger/burger101.jpg"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {}
  },
