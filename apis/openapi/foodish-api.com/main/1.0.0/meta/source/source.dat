{
  "openapi": "3.0.3",
  "info": {
    "title": "Foodish API",
    "description": "A free and open-source API that provides random food images from various categories. Perfect for restaurant website placeholders, food-guessing games, and random food discovery applications.",
    "version": "1.0.0",
    "contact": {
      "name": "Foodish API",
      "url": "https://foodish-api.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://github.com/surhud004/Foodish/blob/master/LICENSE"
    },
    "x-jentic-source-url": "https://foodish-api.com"
  },
  "servers": [
    {
      "url": "https://foodish-api.com",
      "description": "Production server"
    }
  ],
  "x-jentic-source-url": "https://foodish-api.com",
  "paths": {
    "/api/": {
      "get": {
        "summary": "Get random food image",
        "description": "Returns a random food dish image from any category",
        "operationId": "getRandomFood",
        "tags": [
          "Food Images"
        ],
        "responses": {
          "200": {
            "description": "Successful response with random food image URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FoodImageResponse"
                },
                "examples": {
                  "randomFood": {
                    "summary": "Random food image",
                    "value": {
                      "image": "https://foodish-api.com/images/burger/burger101.jpg"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
