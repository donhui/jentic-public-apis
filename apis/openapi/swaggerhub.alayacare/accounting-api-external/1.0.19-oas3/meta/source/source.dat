    "/service_codes": {
      "get": {
        "tags": [
          "Service Codes"
        ],
        "summary": "Get a list of service codes",
        "description": "Get a list of service codes\n",
        "parameters": [
          {
            "name": "query",
            "description": "A query string to filter service codes. The query string can be used to filter by service code name, or description.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "strict",
            "description": "If true, return only those service codes with bill codes related to the specified funders. If false, the search will find service codes not specifically related to the funders provided if any.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "funder",
            "description": "A comma separated list of funder IDs to filter service codes by. If `strict` is true, only service codes with bill codes related to the specified funders will be returned. If `strict` is false, the search will find service codes not specifically related to the funders provided if any.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "client_id",
            "description": "A client ID to filter service codes by.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "branch_id",
            "description": "A branch ID to filter service codes by.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "department_id",
            "description": "A department ID to filter service codes by.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "is_disabled",
            "description": "A boolean to filter service codes by.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sort_by",
            "description": "A field to sort service codes by.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "description",
                "branch_id"
              ]
            }
          },
          {
            "name": "sort_order",
            "description": "A field to order service codes by.\n",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          },
          {
            "name": "related_branches",
