            "type": "string",
            "example": "Mileage KMs"
          },
          "override_locked_visit": {
            "type": "boolean",
            "example": false,
            "description": "Flag to override a locked visit. A visit is considered \"locked\" in AlayaCare when it is included in a billing or payroll run.\n\nOnly users with the correct permissions enabled may edit a \"locked\" visit.\n\nNote that if a visit is locked and this flag is sent as `true`, your organization may need to re-run billing or payroll in the AlayaCare web application to properly reflect the changes.\n"
          }
        }
      },
