          "type": "string",
          "format": "date"
        }
      },
      "billingPeriodTo": {
        "in": "query",
        "name": "billing_period_to",
        "description": "Returns all billing periods that overlap with the entered date range.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "searchId": {
        "in": "query",
        "name": "search_id",
