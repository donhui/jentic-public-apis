                  "$ref": "#/components/schemas/BillCodeScalarQuerySchema"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          },
          "404": {
            "$ref": "#/components/responses/BillCodeNotFound"
          }
        }
      }
    },
