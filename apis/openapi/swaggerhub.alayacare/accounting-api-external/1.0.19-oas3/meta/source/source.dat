        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "billcodeRateRRuleId": {
        "name": "billcode_rate_rrule_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      }
    },
