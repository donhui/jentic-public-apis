        ],
        "summary": "Count the number of items matching the given filters",
        "parameters": [
          {
            "$ref": "#/components/parameters/bill_code_id"
          },
          {
            "$ref": "#/components/parameters/billing_frequency"
          },
          {
            "$ref": "#/components/parameters/branch_id"
          },
          {
            "$ref": "#/components/parameters/cancelled_code_id"
          },
          {
            "$ref": "#/components/parameters/client_cost_centre_id"
          },
          {
            "$ref": "#/components/parameters/client_group_id"
          },
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/end_date"
          },
          {
            "$ref": "#/components/parameters/funded"
          },
          {
            "$ref": "#/components/parameters/funder_id"
          },
          {
            "$ref": "#/components/parameters/funder_methodology"
          },
          {
            "$ref": "#/components/parameters/ids"
          },
          {
            "$ref": "#/components/parameters/include"
          },
          {
            "$ref": "#/components/parameters/master_invoice_id"
          },
          {
            "$ref": "#/components/parameters/not_ids"
          },
          {
            "$ref": "#/components/parameters/sort_by"
          },
          {
            "$ref": "#/components/parameters/page"
          },
          {
            "$ref": "#/components/parameters/count"
          },
          {
            "$ref": "#/components/parameters/program_name"
          },
          {
            "$ref": "#/components/parameters/service_code_id"
          },
          {
            "$ref": "#/components/parameters/service_premium_code"
          },
          {
            "$ref": "#/components/parameters/sort_order"
          },
          {
            "$ref": "#/components/parameters/source_id"
          },
          {
            "$ref": "#/components/parameters/source_type"
          },
          {
            "$ref": "#/components/parameters/start_date"
          },
          {
            "$ref": "#/components/parameters/status"
          },
          {
            "$ref": "#/components/parameters/visit_id"
          },
          {
            "$ref": "#/components/parameters/is_copy"
          },
          {
            "$ref": "#/components/parameters/lock_key"
          },
          {
            "$ref": "#/components/parameters/service_id"
          },
          {
            "$ref": "#/components/parameters/is_splittable"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of billable Item",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_items": {
                      "type": "integer",
                      "example": 1
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      }
    },
    "/billable_item_error": {
      "get": {
        "tags": [
          "Billable Item",
          "Billable Item Generation Errors"
        ],
        "summary": "This endpoint returns a paginated list of billable item errors from the last billable item run, filtered by the branches that the user currently has access to\n",
        "parameters": [
          {
            "description": "Page",
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "description": "Count (number of items to be returned)",
            "name": "count",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "branch_id",
            "in": "query",
            "description": "List of branch IDs",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "end_at",
            "in": "query",
            "description": "End date",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "source_id",
            "in": "query",
            "description": "List of source IDs",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "source_type",
            "in": "query",
            "description": "List of source types",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "start_at",
            "in": "query",
            "description": "Start date",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "description": "List of client IDs",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "funder_id",
            "in": "query",
            "description": "List of funder IDs",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "client_group_id",
            "in": "query",
            "description": "List of client group IDs",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "service_code_id",
            "in": "query",
            "description": "List of service code IDs",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "style": "form",
            "explode": true
          }
        ],
        "responses": {
          "200": {
            "description": "Result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillableItemErrorList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/schemas/ApiError"
          }
        }
      }
    },
    "/bill_code_modifier": {
      "get": {
