        "name": "start_date",
        "in": "query",
        "schema": {
          "type": "string",
          "example": "2021-09-01T14:00:00.000Z"
        },
        "required": false,
        "description": "Filter billable items where the start_at datetime is greater than or equal to the given value. Note: Value must be a datetime in UTC\n"
      },
      "status": {
        "name": "status",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "ready_to_bill",
            "invoiced",
            "on_hold"
          ]
        },
        "description": "Multiple values can be given as ?status=on_hold&status=ready_to_bill\n"
      },
      "visit_id": {
        "name": "visit_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "Multiple values can be given as ?visit_id=1&visit_id=2\n"
      },
