            "invoices",
            "invoice_items",
            "taxes",
            "employee",
            "visit",
            "chris"
          ]
        },
        "description": "Defines if the relationship should be included in the response Multiple values can be given as ?include=master_invoice&include=taxes\n"
      },
      "master_invoice_id": {
        "name": "master_invoice_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "Multiple values can be given as ?master_invoice_id=1&master_invoice_id=2 Note: Only invoiced billable items will be returned\n"
      },
      "not_ids": {
        "name": "not_ids",
        "in": "query",
        "required": false,
        "schema": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "description": "Multiple values can be given as ?not_ids=1&not_ids=2\n"
      },
      "sort_by": {
        "name": "sort_by",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "id",
            "branch",
            "branch_id",
            "client_name",
            "funder_methodology",
            "start_at",
            "status"
          ],
          "default": "id"
        },
        "description": "Defines the order by property\n"
      },
      "page": {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 1
        },
        "description": "Filter by page number.\n"
      },
      "program_name": {
        "name": "program_name",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Multiple values can be given as ?program_name=Program A&program_name=Program B\n"
      },
      "service_code_id": {
        "name": "service_code_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "Filter billable items whose linked visit's service code id matches the given value Multiple values can be given as ?service_code_id=1&service_code_id=2\n"
      },
      "service_premium_code": {
        "name": "service_premium_code",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Fetch billable item where Service Code name, Service Code Description, Visit Premium Code or Client Billing Premium Code contains the provided string Multiple values can be given as ?service_premium_code=service code B&service_premium_code=premium A\n"
      },
      "sort_order": {
        "name": "sort_order",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "default": "asc"
        },
        "description": "Defines the direction of the order by\n"
      },
      "source_id": {
        "name": "source_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "If the billable item is related to a visit, this should be visit id If the billable item is related to a client or visit premium, this should be the id of the guid premium row, where the guid_to is liked to a client guid or visit guid accordingly Multiple values can be given as ?source_id=1&source_id=2\n"
      },
      "source_type": {
        "name": "source_type",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "client_premium",
            "custom_item",
            "premium",
            "visit_custom_item",
            "visit_premium",
            "visit"
          ]
        },
        "description": "Multiple values can be given as ?source_type=client_premium&source_type=visit\n"
      },
