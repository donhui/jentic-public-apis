      "client_group_id": {
        "name": "client_group_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "Filter billable items where the client belongs to the given client group id Multiple values can be given as ?client_group_id=1&client_group_id=2\n"
      },
      "client_id": {
        "name": "client_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "Multiple values can be given as ?client_id=1&client_id=2\n"
      },
      "count": {
        "name": "count",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "The maximum item to be returned in a paginated call\n"
      },
      "end_date": {
        "name": "end_date",
        "in": "query",
        "schema": {
          "type": "string",
          "example": "2021-09-02T14:00:00.000Z"
        },
        "required": false,
        "description": "Filter billable items where the start_at datetime is lesser than or equal to the given value. Note: Value must be a datetime in UTC\n"
      },
      "funded": {
        "name": "funded",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "yes",
            "no",
            "true",
            "false"
          ]
        },
        "description": "Filter billable items whose linked visit is funded or not\n"
      },
      "funder_id": {
        "name": "funder_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1
        },
        "description": "Filter billable items whose payor's funder id matches the given value Multiple values can be given as ?funder_id=1&funder_id=2 Note: Only single payor and electronic billing billable items are going to be returned\n"
      },
      "funder_methodology": {
        "name": "funder_methodology",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "ltci",
            "co_pay",
            "medicaid",
            "split_percentage",
            "co_contribution",
            "single_payor"
          ]
        },
        "description": "Multiple values can be given as ?funder_methodology=1&funder_methodology=2\n"
      },
      "ids": {
        "name": "ids",
        "in": "query",
        "required": false,
        "schema": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "description": "Multiple values can be given as ?ids=1&ids=2\n"
      },
