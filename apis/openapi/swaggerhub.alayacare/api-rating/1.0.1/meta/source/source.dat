{
  "openapi": "3.0.3",
  "info": {
    "title": "Billable Item Management API",
    "version": "1.0.1",
    "description": "This end point can be used to create, edit and retrieve billable items before they can be processed in invoices.\n",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/AlayaCare/api-rating/1.0.1/swagger.json"
  },
  "servers": [
    {
      "url": "https://{tenant}.alayacare.com/api/v1/rating/",
      "description": "For internal requests, made within the application"
    },
    {
      "url": "https://{tenant}.alayacare.com/api/v2/rating/",
      "description": "For external requests. A valid API key is required for authentication."
    }
  ],
  "paths": {
    "/billable_item": {
      "get": {
        "tags": [
          "Billable Item"
        ],
        "summary": "Retrieve list of Billable Items to display in Billable Management screen",
        "parameters": [
          {
            "$ref": "#/components/parameters/bill_code_id"
          },
          {
            "$ref": "#/components/parameters/billing_frequency"
          },
          {
            "$ref": "#/components/parameters/branch_id"
          },
          {
            "$ref": "#/components/parameters/cancelled_code_id"
          },
          {
            "$ref": "#/components/parameters/client_cost_centre_id"
          },
          {
            "$ref": "#/components/parameters/client_group_id"
          },
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/count"
          },
          {
            "$ref": "#/components/parameters/end_date"
          },
          {
            "$ref": "#/components/parameters/funded"
          },
          {
            "$ref": "#/components/parameters/funder_id"
          },
          {
            "$ref": "#/components/parameters/funder_methodology"
          },
          {
            "$ref": "#/components/parameters/ids"
          },
          {
            "$ref": "#/components/parameters/include"
          },
          {
            "$ref": "#/components/parameters/is_archived"
          },
          {
            "$ref": "#/components/parameters/is_copy"
          },
          {
            "$ref": "#/components/parameters/is_splittable"
          },
          {
            "$ref": "#/components/parameters/lock_key"
          },
          {
            "$ref": "#/components/parameters/master_invoice_id"
          },
          {
            "$ref": "#/components/parameters/not_ids"
          },
          {
            "$ref": "#/components/parameters/page"
          },
          {
            "$ref": "#/components/parameters/program_name"
          },
          {
            "$ref": "#/components/parameters/service_code_id"
          },
          {
            "$ref": "#/components/parameters/service_id"
          },
          {
            "$ref": "#/components/parameters/service_premium_code"
          },
          {
            "$ref": "#/components/parameters/sort_by"
          },
          {
            "$ref": "#/components/parameters/sort_order"
          },
          {
            "$ref": "#/components/parameters/source_id"
          },
          {
            "$ref": "#/components/parameters/source_type"
          },
          {
            "$ref": "#/components/parameters/start_date"
          },
          {
            "$ref": "#/components/parameters/status"
          },
          {
            "$ref": "#/components/parameters/visit_id"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of billable Item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillableItemList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      },
      "post": {
        "tags": [
          "Billable Item"
        ],
        "summary": "Add a new billable item.",
        "description": "While technically possible, we do NOT recommend creating billable items where the source_type equals visit, premium or client_premium. These should be created only by the official billable item generation pipeline, and manually creating them could lead to unexpected issues.",
        "requestBody": {
          "$ref": "#/components/requestBodies/Data"
        },
        "responses": {
          "200": {
            "description": "A list of billable Item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillableItem"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      }
    },
    "/billable_item/{billable_item_id}": {
      "patch": {
        "tags": [
          "Billable Item"
        ],
        "summary": "Modify an existing billable item",
        "parameters": [
          {
            "name": "billable_item_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/UpdateData"
        },
        "responses": {
          "200": {
            "description": "A list of billable Item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillableItemList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      },
      "delete": {
        "tags": [
          "Billable Item"
        ],
        "summary": "Deletes a single billable item",
        "parameters": [
          {
            "name": "billable_item_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A simple confirmation that the deletion worked"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      }
    },
    "/billable_item/set": {
      "patch": {
        "tags": [
          "Billable Item"
        ],
        "summary": "Update multiple billable items status",
        "requestBody": {
          "$ref": "#/components/requestBodies/SetData"
        },
        "responses": {
          "200": {
            "description": "An empty response when updated successfuly"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      }
    },
    "/billable_item/change-payor": {
      "post": {
        "tags": [
          "Billable Item",
          "COB"
        ],
        "summary": "Create new items for when changing payors in a COB invoice",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "posting_date",
                  "items"
                ],
                "properties": {
                  "posting_date": {
                    "type": "string",
                    "format": "date",
                    "nullable": true
                  },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "original_billable_item_id",
                        "program_id",
                        "policy_id",
                        "bill_code_id",
                        "paid_amount",
                        "rate",
                        "quantity",
                        "tiered_units",
                        "bill_rate_external_id",
                        "bill_rate_guid",
                        "bill_rate_id",
                        "adjustments"
                      ],
                      "properties": {
                        "original_billable_item_id": {
                          "type": "integer",
                          "nullable": false
                        },
                        "program_id": {
                          "type": "integer",
                          "nullable": false
                        },
                        "policy_id": {
                          "type": "integer",
                          "nullable": true
                        },
                        "bill_code_id": {
                          "type": "integer",
                          "nullable": false
                        },
                        "paid_amount": {
                          "type": "number",
                          "nullable": false
                        },
                        "rate": {
                          "type": "number",
                          "nullable": false
                        },
                        "quantity": {
                          "type": "number",
                          "nullable": false
                        },
                        "tiered_units": {
                          "type": "integer",
                          "nullable": true
                        },
                        "bill_rate_external_id": {
                          "type": "integer",
                          "nullable": true
                        },
                        "bill_rate_guid": {
                          "type": "integer",
                          "nullable": true
                        },
                        "bill_rate_id": {
                          "type": "integer",
                          "nullable": true
                        },
                        "adjustments": {
                          "type": "object",
                          "nullable": true,
                          "properties": {
                            "adjustment_date": {
                              "type": "string",
                              "format": "date",
                              "nullable": true
                            },
                            "adjustment_code": {
                              "type": "string",
                              "nullable": true
                            },
                            "adjustment_reason_code": {
                              "type": "string",
                              "nullable": true
                            },
                            "remark_code": {
                              "type": "string",
                              "nullable": true
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The list of the newly created billable items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BillableItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/billable_item/regenerate": {
      "patch": {
        "tags": [
          "Billable Item"
        ],
        "summary": "Regenerate billable items",
        "requestBody": {
          "$ref": "#/components/requestBodies/RegenerateData"
        },
        "responses": {
          "200": {
            "description": "Ok"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      }
    },
