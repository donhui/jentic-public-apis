              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "response": {
                "value": {
                  "code": 401,
                  "message": "Authorization required."
                }
              }
            }
          }
        }
      },
      "ErrorResponseBadRequest": {
        "description": "Authorization required",
        "content": {
          "application/json": {
