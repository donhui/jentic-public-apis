        ],
        "summary": "This endpoint returns a paginated list of bill code modifier rules, filtered by the branches that the user currently has access to.\n",
        "parameters": [
          {
            "description": "Page",
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "description": "Count (number of items to be returned)",
            "name": "count",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillCodeModfierList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/schemas/ApiError"
          }
        }
      },
      "post": {
        "tags": [
          "Bill Code Modifier"
        ],
        "summary": "This endpoint creates/modifiers a bill code modifier entity\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillCodeModfier"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillCodeModfier"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/schemas/ApiError"
          }
        }
      }
    },
    "/service_accounting": {
      "get": {
        "tags": [
          "Service accounting"
        ],
        "summary": "This endpoint fetches a list of service's accounting information",
        "parameters": [
          {
            "description": "Service ID (Allows multiple params at a time. Eg. service_id=1&service_id=2)",
            "name": "service_id",
            "in": "query",
            "required": true,
            "style": "pipeDelimited",
            "explode": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Service accounting",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ServiceAccountingSchema"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/service_accounting/{service_id}": {
      "post": {
        "tags": [
          "Service accounting"
        ],
        "summary": "This endpoint creates or updates a service's accounting information",
        "parameters": [
          {
            "description": "Service ID",
            "name": "service_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ServiceAccountingSchema"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Create or update successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceAccountingSchema"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidRequest"
          }
        }
      }
    },
    "/service_accounting/{service_id}/set_custom_rate": {
      "post": {
        "tags": [
          "Service accounting"
        ],
        "summary": "This endpoint creates or updates a service's custom rate information",
        "parameters": [
          {
            "description": "Service ID",
            "name": "service_id",
