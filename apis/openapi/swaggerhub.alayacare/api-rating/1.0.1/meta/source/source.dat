          "400": {
            "$ref": "#/components/responses/InvalidRequest"
          }
        }
      }
    },
    "/service_code/{service_code_id}/funder_driven": {
      "post": {
        "tags": [
          "Funder Driven Service Code"
        ],
        "summary": "This endpoint receives needed info for rating for a funder driven Service Code\n",
        "parameters": [
          {
            "description": "Service Code ID",
            "name": "service_code_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FunderDrivenRatingSchema"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Create successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceCodeSchema"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ServiceCodeFunderDriven400Response"
          }
        }
      }
    },
    "/bill_code/{source_type}/{source_id}": {
      "get": {
        "tags": [
          "Calculate Item's Bill Code"
        ],
        "summary": "This endpoint looks for a bill code for a given source. If a billable item exists for that source item, the bill code linked to that is returned. if not, the whole lookup for the bill code based on the source type is done.\n",
        "parameters": [
          {
            "name": "source_type",
            "in": "path",
            "required": true,
            "description": "\"visit\" for a visit item, \"premium\" for a visit premium, \"client_premium\" for a client billing premium\n",
            "schema": {
              "type": "string",
              "enum": [
                "visit",
                "premium",
                "client_premium"
              ]
            }
          },
          {
            "name": "source_id",
            "in": "path",
            "required": true,
            "description": "If the source item is a visit, use the visit id If the source item is a client or visit premium, use the id of the guid premium row, where the guid_to is liked to a client guid or visit guid accordingly\n",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Result.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/BillableItemId"
                    },
                    {
                      "$ref": "#/components/schemas/BillCode"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/schemas/ApiError"
          },
          "404": {
            "$ref": "#/components/schemas/NotFoundError"
          }
        }
      }
    },
    "/bill_code/defaults": {
      "post": {
        "tags": [
          "Calculate Item's Bill Code"
        ],
        "summary": "This endpoint will look up the default bill code for a specific service code and funder combo. If a billable item is given, it will then fetch what the rate will be for that bill code and item.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "service_code_id",
                    "funder_id",
                    "billable_item_ids"
                  ],
                  "properties": {
                    "service_code_id": {
                      "type": "integer"
                    },
                    "funder_id": {
                      "type": "integer"
                    },
                    "billable_item_ids": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Result.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "bill_code": {
                        "$ref": "#/components/schemas/BillCode"
                      },
                      "billable_item_rates": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "billable_item_id": {
                              "type": "integer"
                            },
                            "rate": {
                              "$ref": "#/components/schemas/ComputedBillRate"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/schemas/ApiError"
          },
          "404": {
            "$ref": "#/components/schemas/NotFoundError"
          }
        }
      }
    },
    "/bill_rate/{billrate_id}/tiered_rates": {
      "get": {
        "tags": [
          "Tiered Rates"
        ],
        "summary": "This endpoint gets a bill rate's tiered rate information",
        "parameters": [
          {
            "description": "Bill Rate ID",
            "name": "billrate_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Create or update successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillRateTieredRateListSchema"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Tiered Rates"
        ],
        "summary": "This endpoint creates or updates a bill rate's tiered rate information",
        "parameters": [
          {
            "description": "Bill Rate ID",
            "name": "billrate_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillRateTieredRateListSchema"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Create or update successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillRateTieredRateListSchema"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidRequest"
          }
        }
      }
    },
    "/bill_rate/effective_rate": {
      "get": {
        "tags": [
          "Effective rate"
        ],
        "summary": "This endpoint gets the effective rate for a given bill code quantity combination",
        "parameters": [
          {
            "description": "Bill Code ID",
            "name": "bill_code_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "description": "Datetime",
            "name": "datetime",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "2021-10-05T20:00:00Z"
            }
          },
          {
            "description": "Timezone",
            "name": "timezone",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "America/Toronto"
            }
          },
          {
            "description": "Client ID",
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "description": "Quantity",
            "name": "quantity",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "example": 12.0
            }
          },
          {
            "description": "Service ID",
            "name": "service_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "description": "Use Funder Multiplier",
            "name": "use_funder_multiplier",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Return a Computed Rate",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComputedBillRate"
                }
              }
            }
          }
        }
      }
    },
    "/visit/project_visit_items": {
      "get": {
        "tags": [
          "Billable Item Projection"
        ],
        "summary": "Retrieve a list of potential billable items that correspond to the visit.",
        "parameters": [
          {
            "name": "visit_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of billable Item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VisitProjection"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      }
    },
    "/visit/project_visit_items_by_service/{service_id}": {
      "post": {
        "tags": [
          "Billable Item Projection"
        ],
        "summary": "It projects the billable items for a given service.",
        "description": "It projects the billable items for a given service for possible visits given their start and end dates. It can be used to project billable items before a visit or recurrence is created. If the `visit_guid` is sent, then the hours_approved bill code will be used to calculate the billable items.",
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "datetimes",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/VisitsDuration"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of projected billable Item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VisitProjectionByService"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponseBadRequest"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponseAuthentication"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "description": "Error response",
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 400,
            "description": "Response code"
          },
          "message": {
            "type": "string",
            "example": "Invalid request",
            "description": "Detailed error message"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "BillableItemList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PaginatedList"
          }
        ],
        "description": "Paginated List of billable items",
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BillableItem"
            }
          }
        }
      },
      "Premium": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "id of the related premium",
            "example": 1
          },
          "code": {
            "type": "string",
            "description": "code of the related premium",
            "example": "Premium Code"
          }
        }
      },
      "ServiceCode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "service code ID",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "name of the service code ( always populated )",
            "example": "Service Code Name"
          },
          "description": {
            "type": "string",
            "description": "description of the service_code ( not always populated )",
            "example": "Service Code Description"
          },
          "rating_methodology": {
            "type": "string",
            "description": "rating methodology of the service_code",
            "example": "Service Code Rating Methodology"
          }
        }
      },
      "Funder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "funder ID",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "name of the funder",
            "example": "Funder Name"
          },
          "code": {
            "type": "string",
            "description": "code of the funder",
            "example": "Funder code"
          },
          "invoicing_model": {
            "type": "string",
            "description": "invoicing model of the funder",
            "enum": [
              "individual_invoices",
              "funder_individual",
              "medicaid"
            ],
            "example": "individual_invoices"
          }
        }
      },
      "BillCode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "bill code ID",
            "example": 1
          },
          "description": {
            "type": "string",
            "description": "description of the bill code",
            "example": "Bill Code Description"
          },
          "code": {
            "type": "string",
            "description": "code of the bill code",
            "example": "Bill Code code"
          },
          "units": {
            "type": "string",
            "description": "Defines if the billable item billed by hours or flat rate.",
            "enum": [
              "hours",
              "visit",
              "rate"
            ],
            "example": "hours"
          },
          "billing_increment": {
            "type": "integer",
            "nullable": true
          },
          "is_midnight_rule_applicable": {
            "type": "boolean",
            "description": "Wheter this bill code will break the billable item into 2 if it goes over midnight"
          },
          "send_decimal_units": {
            "type": "boolean"
          },
          "taxes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tax"
            }
          }
        }
      },
      "ComputedBillRate": {
        "type": "object",
        "properties": {
          "computed_rate": {
            "type": "number",
            "description": "The computed bill rate",
            "example": 12.0
          },
          "rate_type": {
            "type": "string",
            "description": "The rate entity that was used",
            "enum": [
              "normal_bill_rate",
              "client_bill_rate",
              "service_code_bill_rate",
              "time_specific_bill_rate",
              "tiered_bill_rate"
            ]
          },
          "rate": {
            "type": "number",
            "description": "The computed bill rate",
            "example": 12.0
          },
          "overridden_units": {
            "type": "string",
            "description": "In some cases, you may have a rate type different than what the bill code is. In most cases, this will be null\n",
            "example": null,
            "enum": [
              "rate",
              "hours",
              "visits"
            ]
          },
          "tiered_unit": {
            "type": "integer",
            "description": "Number or units ff the rate is tiered",
            "example": 10
          },
          "guid": {
            "type": "integer",
            "description": "Guid of the rate entity",
            "example": 92
          },
          "external_id": {
            "type": "integer",
            "description": "External id of the rate entity if available.",
            "example": 1003
          },
          "bill_rate_id": {
            "type": "integer",
            "description": "id of the rate entity if available.",
            "example": 100
          }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "GT Account ID",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "client name from gt_account description",
            "example": "Robert Denis Rheault"
          }
        }
      },
      "Employee": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "employee id",
            "example": 1
          },
          "full_name": {
            "type": "string",
            "description": "emplyee full name",
            "example": "Robert Denis Rheault"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "GT Account ID",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "contact name from gt_account description",
            "example": "Robert Denis Rheault"
          }
        }
      },
      "Branch": {
        "description": "AlayaCare branch",
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Branch ID",
            "example": 1000
          },
          "name": {
            "type": "string",
            "description": "Branch name",
            "example": "AlayaCare Health"
          }
        }
      },
      "Program": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Program ID",
            "example": 1
          },
          "program_type": {
            "type": "string",
            "description": "Type of the program, also, refered as the funding_methodology or payor_methodology",
            "enum": [
              "single_payor",
              "co_contribution",
              "split_percentage",
              "medicaid",
              "co-pay",
              "ltci"
            ],
            "example": "single_payor"
          },
          "name": {
            "type": "string",
            "description": "the program name",
            "example": "Program Name"
          },
          "billing_frequency": {
            "type": "integer",
            "description": "billing_frequency attached to the program.",
            "example": 1
          },
          "is_taxable": {
            "type": "boolean",
            "description": "progam is taxable",
            "example": false
          },
          "guarantor_funder_id": {
            "type": "integer",
            "description": "Id of the guarantor funder",
            "example": 1,
            "minimum": 1
          },
          "guarantor_funder": {
            "$ref": "#/components/schemas/Funder"
          },
          "guarantor_billing_contact_id": {
            "type": "integer",
            "description": "guarantor_billing_contact_id attached to the program.",
            "example": 1,
            "minimum": 1
          },
          "guarantor_billing_contact": {
            "$ref": "#/components/schemas/Contact"
          }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "invoice ID",
            "example": 1
          },
          "invoice_number": {
            "type": "integer",
            "description": "invoice number",
            "example": 1
          }
        }
      },
      "Invoices": {
        "type": "array",
        "nullable": true,
        "description": "null if the master invoice id is null, or if not present in the include such as `?include=invoices`\n",
        "items": {
          "$ref": "#/components/schemas/Invoice"
        }
      },
      "Payor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "payor ID",
            "example": 1
          },
          "funder_id": {
            "type": "integer",
            "description": "funder ID",
            "example": 1
          },
          "funder": {
            "$ref": "#/components/schemas/Funder"
          },
          "billing_contact_id": {
            "type": "integer",
            "description": "billing contact ID",
            "example": 1
          },
          "billing_contact": {
            "$ref": "#/components/schemas/Contact"
          }
        }
      },
      "InvoiceItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "invoice item ID",
            "example": 1
          },
          "adjustment_type": {
            "type": "string",
            "description": "ajustment type",
            "example": "void"
          },
          "billable_item_id": {
            "type": "integer",
            "description": "billable item ID",
            "example": 1
          },
          "guid_to": {
            "type": "integer",
            "description": "guid",
            "example": 1
          },
          "invoice_id": {
            "type": "integer",
            "description": "invoice ID",
            "example": 1
          },
          "idinvoice": {
            "type": "integer",
            "description": "invoice ID",
            "example": 1
          },
          "invoice": {
            "$ref": "#/components/schemas/Invoice"
          },
          "item_start_at": {
            "type": "string",
            "description": "start time of the invoice item",
            "example": "2021-01-05T16:00:00Z"
          },
          "payor": {
            "$ref": "#/components/schemas/Payor"
          },
          "payor_id": {
            "type": "integer",
            "description": "payor ID",
            "example": 1
          },
          "subtotal": {
            "type": "number",
            "description": "invoice item subtotal",
            "example": 23.12
          },
          "total": {
            "type": "number",
            "description": "invoice item total",
            "example": 12.42
          },
          "total_taxes": {
            "type": "number",
            "description": "invoice item total taxes",
            "example": 12.32
          },
          "type": {
            "type": "string",
            "description": "invoice item type",
            "example": "visit"
          }
        }
      },
      "InvoiceItems": {
        "type": "array",
        "nullable": true,
        "description": "null if the master invoice id is null, or if not present in the include such as `?include=invoice_items`\n",
        "items": {
          "$ref": "#/components/schemas/InvoiceItem"
        }
      },
      "Tax": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Tax ID",
            "example": 10
          },
          "name": {
            "type": "string",
            "description": "Name of the tax",
            "example": "GST"
          },
          "number": {
            "type": "string",
            "description": "Number of the tax",
            "example": "0001"
          },
          "percent": {
            "type": "number",
            "description": "Number of the tax",
            "example": 9.975
          }
        }
      },
      "BillableItemTax": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Billable item Tax row ID",
            "example": 4433
          },
          "billable_item_id": {
            "type": "integer",
            "description": "Billable item ID",
            "example": 2134
          },
          "is_original": {
            "type": "boolean",
            "description": "If true, the tax comes directly from the bill code tax. If false, the user has added that tax manually\n",
            "example": true
          },
          "is_enabled": {
            "type": "boolean",
            "description": "If false, the user has removed it from the billable item",
            "example": true
          },
          "tax": {
            "$ref": "#/components/schemas/Tax"
          },
          "tax_id": {
            "type": "integer",
            "description": "Tax ID",
            "example": 10
          }
        }
      },
      "BillableItemTaxes": {
        "type": "array",
        "nullable": true,
        "description": "null if no taxes are linked to the billable item, or if not present in the include such as `?include=taxes`\n",
        "items": {
          "$ref": "#/components/schemas/BillableItemTax"
        }
      },
      "MasterInvoice": {
        "type": "object",
        "nullable": true,
        "description": "null if the master invoice id is null, or if not present in the include such as `?include=master_invoice`\n",
        "properties": {
          "id": {
            "type": "integer",
            "description": "master invoice ID",
            "example": 7645
          },
          "billing_period_id": {
            "type": "integer",
            "description": "billing period ID",
            "example": 3456,
            "minimum": 1
          },
          "status": {
            "type": "string",
            "description": "this is the status of the master invoice, can be void, draft etc...",
            "example": "sent"
          }
        }
      },
      "ChrisFields": {
        "type": "object",
        "nullable": true,
        "description": "null if no CHRIS fields are linked to the billable item, or if not present in the include such as `?include=chris`\n",
        "properties": {
          "billable_item_id": {
            "type": "integer",
            "description": "billable item ID, must match the billable item that this object is returned with",
            "example": 1289,
            "minimum": 1
          },
          "brn": {
            "type": "string",
            "description": "the BRN associated with the billable item",
            "example": "[a-z]\\+"
          }
        }
      },
      "ActivityCode": {
        "type": "object",
        "properties": {
          "activity_code_id": {
            "type": "integer",
            "description": "Activity code ID",
            "example": 4433
          },
          "billable_item_id": {
            "type": "integer",
            "description": "Billable item ID",
            "example": 2134
          },
          "description": {
            "type": "string",
            "description": "A description of the activity code",
            "example": "[a-z]\\+"
          }
        }
      },
      "COBFields": {
        "type": "object",
        "nullable": true,
        "description": "null if no COB fields are linked to the billable item, or if not present in the include such as `?include=cob`\n",
        "properties": {
          "id": {
            "type": "integer",
            "description": "billable item ID, must match the billable item that this object is returned with",
            "example": 1289,
            "minimum": 1
          },
          "master_program_id": {
            "type": "integer"
          },
          "master_policy_id": {
            "type": "integer"
          },
          "parent_billable_item_id": {
            "type": "integer"
          },
          "sequence": {
            "type": "integer"
          },
          "previous_funder_id": {
            "type": "integer"
          },
          "previous_billing_contact_id": {
            "type": "integer"
          },
          "disposition_added": {
            "type": "integer"
          },
          "adjustment_reason_group": {
            "type": "string"
          },
          "adjustment_reason_code": {
            "type": "string"
          },
          "adjustment_date": {
            "type": "string",
            "format": "date"
          },
          "payment_amount": {
            "type": "number"
          },
          "payment_quantity": {
            "type": "number"
          },
          "use_claim_date_as_disposition_date": {
            "type": "integer"
          },
          "adjustment_remark_code": {
            "type": "string"
          },
          "member_contact_id": {
            "type": "integer"
          },
          "member_number": {
            "type": "string"
          },
          "relationship_to_insured": {
            "type": "string"
          },
          "previous_member_contact_id": {
            "type": "integer"
          },
          "previous_member_number": {
            "type": "string"
          },
          "posting_date": {
            "type": "string",
            "format": "date"
          },
          "previous_relationship_to_insured": {
            "type": "string"
          }
        }
      },
      "ActivityCodes": {
        "type": "array",
        "nullable": true,
        "description": "null if no activity codes are linked to the billable item, or if not present in the include such as `?include=chris`\n",
        "items": {
          "$ref": "#/components/schemas/ActivityCode"
        }
      },
      "BillableItem": {
        "description": "details of a billable item",
        "type": "object",
        "properties": {
          "bill_code": {
            "$ref": "#/components/schemas/BillCode"
          },
          "bill_rate_id": {
            "type": "integer",
            "description": "Id of the bill rate or premium object from which this billable item's rate is calculated"
          },
          "bill_rate_guid": {
            "type": "integer",
            "description": "GUID of the bill rate or premium object from which this billable item's rate is calculated"
          },
          "bill_rate_external_id": {
            "type": "integer",
            "description": "External_id of the bill rate from which this billable item's rate is calculated"
          },
          "billing_frequency": {
            "type": "integer",
            "description": "Available billing frequencies:\n * `1` = 1 Week\n * `2` = 2 Weeks\n * `3` = 4 Weeks\n * `4` = Calendar Month\n",
            "example": 1
          },
          "branch": {
            "$ref": "#/components/schemas/Branch"
          },
          "cancelled_code_id": {
            "type": "integer",
            "example": null
          },
          "client": {
            "$ref": "#/components/schemas/Client"
          },
          "create_user_id": {
            "type": "integer",
            "example": 100,
            "description": "Id of the user who created triggered the billable item generation."
          },
          "created_at": {
            "type": "string",
            "example": "2021-10-05T20:00:00Z",
            "description": "UTC datetime of when the billable item was created."
          },
          "description": {
            "type": "string",
            "example": "this is a billable item description"
          },
          "employee": {
            "$ref": "#/components/schemas/Employee"
          },
          "end_at": {
            "type": "string",
            "example": "2021-01-05T21:00:00Z",
            "description": "UTC datetime of the end datetime of the source item."
          },
          "gl_revenue_acc_account_id": {
            "type": "integer",
            "example": 10,
            "description": "Id of the gl revenue account of the billable item."
          },
          "guid_to": {
            "type": "integer",
            "example": 10,
            "description": "guid of the source item related to this billable item"
          },
          "id": {
            "type": "integer",
            "example": 2134,
            "description": "Id of the billable item"
          },
          "invoices": {
            "$ref": "#/components/schemas/Invoices"
          },
          "invoice_items": {
            "$ref": "#/components/schemas/InvoiceItems"
          },
          "is_modified": {
            "type": "boolean",
            "example": false,
            "description": "true if the billable item has even been modified."
          },
          "is_splittable": {
            "type": "boolean",
            "example": false,
            "description": "true if the billable item is splittable."
          },
          "master_invoice": {
            "$ref": "#/components/schemas/MasterInvoice"
          },
          "master_invoice_id": {
            "type": "integer",
            "example": 3456,
            "description": "Id of the master invoice where the billable item has been invoiced. Note: The billable item must be invoiced for this property to have a value.\n"
          },
          "original_bill_code_id": {
            "type": "integer",
            "example": 302,
            "description": "Original bill code id of the billable item. This value will never be modified. It is used to verify if the billable item's bill code has been modified by a user.\n"
          },
          "original_end_date_time": {
            "type": "string",
            "example": "2021-01-05T20:00:00Z",
            "description": "Original UTC datetime of the end datetime of the source item. This value will never be modified. It is used to verify if the billable item's end at has been modified by a user.\n"
          },
          "original_quantity": {
            "type": "number",
            "description": "Original quantity of the source item. This value will never be modified. It is used to verify if the billable item's quantity has been modified by a user.\n",
            "example": 2.35
          },
          "original_rate": {
            "type": "number",
            "description": "Original rate of the bill code. This value will never be modified. It is used to verify if the billable item's quantity has been modified by a user.\n",
            "example": 12.3321
          },
          "original_start_date_time": {
            "type": "string",
            "example": "2021-01-05T16:00:00Z",
            "description": "Original UTC datetime of the start at datetime of the source item. This value will never be modified. It is used to verify if the billable item's start at has been modified by a user.\n"
          },
          "premium": {
            "$ref": "#/components/schemas/Premium"
          },
          "program": {
            "$ref": "#/components/schemas/Program"
          },
          "quantity": {
            "type": "number",
            "description": "Defines the quantity to be billed. If unit is hours this represents the amount of hours to bill.",
            "example": 2.35
          },
          "rate": {
            "type": "number",
            "description": "Defines the bill rate.",
            "example": 12.3321
          },
          "rating_methodology": {
            "type": "string",
            "description": "rating methodology of the linked visit's service code",
            "enum": [
              "funder_driven"
            ],
            "example": "funder_driven"
          },
          "service_code": {
            "$ref": "#/components/schemas/ServiceCode"
          },
          "source_id": {
            "type": "integer",
            "description": "Depends on the source_type\n * `visit` = this relates to the visit id\n * `visit_custom_item` = this relates to the visit id\n * `premium` = this relates to the guid premium row guid_to is liked to the visit's guid\n * `client_premium` = this relates to the guid premium row guid_to is liked to the client's guid\n * `custom_item` = null\n",
            "example": 3124
          },
          "source_type": {
            "type": "string",
            "enum": [
              "client_premium",
              "custom_item",
              "premium",
              "visit_custom_item",
              "visit_premium",
              "visit"
            ],
            "description": "What entity type this billable item is related to",
            "example": "visit"
          },
          "start_at": {
            "type": "string",
            "example": "2021-01-05T16:00:00Z",
            "description": "UTC datetime of the start datetime of the source item"
          },
          "status": {
            "type": "string",
            "enum": [
              "ready_to_bill",
              "invoiced",
              "on_hold"
            ],
            "example": "invoiced",
            "description": "Status of the billable item"
          },
          "taxes": {
            "$ref": "#/components/schemas/BillableItemTaxes"
          },
          "timezone": {
            "type": "string",
            "example": "America/New_York",
            "description": "Timezone used for all datetime operations, such as finding the correct rate"
          },
          "unit": {
            "type": "string",
            "enum": [
              "hours",
              "visit",
              "rate"
            ],
            "description": "Defines if the billable item billed by hours or flat rate.",
            "example": "hours"
          },
          "update_user_id": {
            "type": "integer",
            "example": 100,
            "description": "Id of the user who last did a modification on the billable item"
          },
          "updated_at": {
            "type": "string",
            "example": "2021-10-05T20:00:00Z",
            "description": "UTC datetime of when the billable item was last edited"
          },
          "value": {
            "type": "number",
            "example": 28.98,
            "description": "Rate * Quantity"
          },
          "visit_id": {
            "type": "integer",
            "example": 3124,
            "description": "Id of the visit that the billable item is linked to."
          },
          "tiered_units": {
            "type": "integer",
            "example": 1
          },
          "chris_fields": {
            "$ref": "#/components/schemas/ChrisFields"
          },
          "cob": {
            "$ref": "#/components/schemas/COBFields"
          },
          "activity_codes": {
            "$ref": "#/components/schemas/ActivityCodes"
          },
          "visit": {
            "type": "object",
            "description": "This only is returned when the get attribute `include=visit` is passed",
            "properties": {
              "id": {
                "type": "integer",
                "description": "Visit id",
                "example": 3124
              },
              "start_at": {
                "type": "integer",
                "description": "Visit scheduled start time epoch",
                "example": 1633478400
              },
              "end_at": {
                "type": "integer",
                "description": "Visit scheduled end time epoch",
                "example": 1633478400
              },
              "hours_bill": {
                "type": "number",
                "description": "Quantity of overriden approved hours. If null, this is not overriden. If 0, visit has been overriden to exclude it from billing",
                "example": null
              },
              "visit_bill": {
                "type": "number",
                "description": "Quantity of overriden approved visit. If null, this is not overriden. If 0, visit has been overriden to exclude it from billing",
                "example": null
              },
              "hours_approved": {
                "type": "number",
                "description": "Quantity hours approved.",
                "example": 2.35
              },
              "service_id": {
                "type": "integer",
                "description": "Service id of the visit",
                "example": 432
              }
            }
          }
        },
        "nullable": true
      },
      "PaginatedList": {
        "description": "Base model of all paginated lists",
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Number of items in the response",
            "example": 10
          },
          "page": {
            "type": "integer",
            "description": "Current page number",
            "example": 1
          },
          "total_pages": {
            "type": "integer",
            "description": "Total number of pages available",
            "example": 1
          },
          "total_items": {
            "type": "integer",
            "description": "Total number of items available",
            "example": 1
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "count",
          "page",
          "total_pages",
          "total_items",
          "items"
        ]
      },
      "BillableItemErrorList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PaginatedList"
          }
        ],
        "description": "Paginated List of billable items errors",
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BillableItemError"
            }
          }
        }
      },
      "BillableItemError": {
        "description": "details of a billable item",
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Billable item error ID",
            "example": 2
          },
          "source_type": {
            "type": "string",
            "description": "the item type on which the billable item error is based",
            "enum": [
              "visit",
              "premium",
              "client_premium"
            ],
            "example": "visit"
          },
          "source_id": {
            "type": "integer",
            "description": "Unique Identifier for the source item. If source type is visit, this column will have a visit ID for example",
            "example": 3,
            "minimum": 1
          },
          "visit_id": {
            "type": "integer",
            "description": "Visit id that the billable item error is linked to (null for client premiums)",
            "example": 3
          },
          "start_at": {
            "type": "string",
            "description": "billable item start datetime, used to display the date.",
            "example": "2019-09-02 11:55:00"
          },
          "end_at": {
            "type": "string",
            "description": "billable item end datetime",
            "example": "2019-09-02 12:55:00"
          },
          "branch_id": {
            "type": "integer",
            "description": "Branch id of where the source item belongs to",
            "example": 1000
          },
          "client_id": {
            "type": "integer",
            "description": "Client id of who the source item belongs to",
            "example": 1100
          },
          "client": {
            "$ref": "#/components/schemas/Client1"
          },
          "error_type": {
            "type": "string",
            "description": "Error type",
            "enum": [
              "BillCodeNotBillableError",
              "BillCodeNotFoundError",
              "BillRateNotFound",
              "MultipleBillCodesError",
              "MultiplePrimaryFunderBreakdownsError",
              "PrimaryFunderBreakdownNotFoundError"
            ],
            "example": "BillCodeNotFoundError"
          },
          "error_message": {
            "type": "string",
            "description": "A more descriptive message on the error",
            "example": "Visit with id"
          },
          "created_at": {
            "type": "string",
            "description": "billable item error creation date",
            "example": "2019-09-04T12:00:00Z"
          }
        },
        "nullable": true
      },
      "Client1": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "GT Account ID",
            "example": 1100
          },
          "name": {
            "type": "string",
            "description": "client name from gt_account description",
            "example": "Robert Denis"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "description": "Error returned from the API",
        "properties": {
          "code": {
            "type": "string",
            "description": "The error code",
            "example": 401
          },
          "message": {
            "type": "string",
            "example": "An error occurred",
            "description": "The error description"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "BillCodeModfierList": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PaginatedList"
          }
        ],
        "description": "Paginated List of billable items errors",
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BillCodeModfier"
            }
          }
        }
      },
      "BillCodeModfier": {
        "description": "details of a bill code modifer and its rules",
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Auto generated ID. Will be available in get endpoints. Not required when creating a new bill code modifier REQUIRED when updating an exisiting one.\n",
            "example": 2
          },
          "name": {
            "type": "string",
            "description": "Bill code modifier name",
            "example": "Name"
          },
          "description": {
            "type": "string",
            "description": "Bill code modifier description",
            "example": "Description"
          },
          "type": {
            "type": "integer",
            "description": "Bill code modifier type\n  1: MODIFIER\n  2: OCCURRENCE\n",
            "enum": [
              1,
              2
            ],
            "example": 1
          },
          "branch_id": {
            "type": "integer",
            "description": "Branch id that created the bill code modifier",
            "example": 1000
          },
          "rules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Rule"
            }
          }
        },
        "nullable": true
      },
      "Rule": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Auto generated ID. Will be available in get endpoints. Not required when creating/updating a bill code modifier\n",
            "example": 321
          },
          "code": {
            "type": "string",
            "description": "Code that will be stamped to the billable item if the given rule type applies",
            "example": 1100
          },
          "rule_type": {
            "type": "integer",
            "description": "Rule types\n  # Types for modifiers\n  1: SECOND VISIT SAME DAY AND BILL CODE\n  2: AFTER SECOND VISIT SAME DAY AND BILL CODE\n  3: VISIT LASTING MORE THAN 12H AND LESS THAN 16H\n  # Types for occurrences\n  4: FIRST VISIT OF THE DAY\n",
            "example": 1,
            "enum": [
              1,
              2,
              3,
              4
            ]
          },
          "modifiers_rules_id": {
            "type": "integer",
            "description": "Id of the parent bill code modifier rule",
            "example": 2
          }
        }
      },
      "BillCodeBillCodeModifiersRules": {
        "type": "object",
        "properties": {
          "bill_code_id": {
            "type": "integer",
            "description": "bill code id linked to modifier rule",
            "example": 321
          },
          "bill_code_modifiers_rules_id": {
            "type": "integer",
            "description": "modifier rule id",
            "example": 321
          }
        }
      },
      "BillCodeBillCodeModifiersRulesList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/BillCodeBillCodeModifiersRules"
        }
      },
      "ActiveBillableItemFilters": {
        "type": "object",
        "properties": {
          "program_id": {
            "type": "integer",
            "description": "id of program used to filter billable items",
            "example": 321
          },
          "billing_period_id": {
            "type": "integer",
            "description": "id of a billing period used to filter billable items",
            "example": 321
          }
        }
      },
