      "VisitProjectionError": {
        "type": "object",
        "properties": {
          "branch_id": {
            "type": "integer",
            "example": 1000
          },
          "client": {
            "type": "object",
            "example": null
          },
          "client_id": {
            "type": "integer",
            "example": 2050
          },
          "created_at": {
            "type": "string",
            "example": "2023-02-27T22:47:33.931430Z"
          },
          "end_at": {
            "type": "string",
            "example": "2023-02-17T19:42:00"
          },
          "error_message": {
            "type": "string",
            "example": "'NoneType' object has no attribute 'billing_frequency'"
          },
          "error_type": {
            "type": "string",
            "example": "BillableItemGenerationError"
          },
          "id": {
            "type": "object",
            "example": null
          },
          "source_id": {
            "type": "integer",
            "example": 943
          },
          "source_type": {
            "type": "string",
            "example": "visit"
          },
          "start_at": {
            "type": "string",
            "example": "2023-02-17T18:42:00"
          },
          "visit_id": {
            "type": "integer",
            "example": 943
          }
        }
      },
      "ProjectedBillableItem": {
        "description": "details of a billable item",
        "type": "object",
        "properties": {
          "bill_code": {
            "type": "string",
            "description": "The bill code object isn't loaded for projected billable items endpoints.",
            "nullable": true,
            "example": null
          },
          "billing_frequency": {
            "type": "integer",
            "description": "Available billing frequencies:\n * `1` = 1 Week\n * `2` = 2 Weeks\n * `3` = 4 Weeks\n * `4` = Calendar Month\n",
            "example": 1
          },
          "branch": {
            "type": "string",
            "description": "The branch object isn't loaded for projected billable items endpoints.",
            "nullable": true,
            "example": null
          },
          "cancelled_code_id": {
            "type": "integer",
            "example": null
          },
          "client": {
            "type": "string",
            "description": "The client object isn't loaded for projected billable items endpoints.",
            "nullable": true,
            "example": null
          },
          "create_user_id": {
            "type": "integer",
            "example": 100,
            "description": "Id of the user who created triggered the billable item generation."
          },
          "created_at": {
            "type": "string",
            "example": "2021-10-05T20:00:00Z",
            "description": "UTC datetime of when the billable item was created."
          },
          "description": {
            "type": "string",
            "example": "this is a billable item description"
          },
          "employee": {
            "type": "string",
            "description": "The employee object isn't loaded for projected billable items endpoints.",
            "nullable": true
          },
          "end_at": {
            "type": "string",
            "example": "2021-01-05T20:00:00Z",
            "description": "UTC datetime of the end datetime of the source item."
          },
          "gl_revenue_acc_account_id": {
            "type": "integer",
            "example": 10,
            "description": "Id of the gl revenue account of the billable item."
          },
          "id": {
            "type": "integer",
            "example": null,
            "description": "A projected billable item doesn't have ID"
          },
          "invoices": {
            "type": "string",
            "nullable": true,
            "description": "A projected billable item doesn't have invoices",
            "example": null
          },
          "invoice_items": {
            "type": "string",
            "nullable": true,
            "description": "A projected billable item doesn't have invoices items",
            "example": null
          },
          "is_modified": {
            "type": "boolean",
            "example": false,
            "description": "true if the billable item has even been modified."
          },
          "is_splittable": {
            "type": "boolean",
            "example": false,
            "description": "true if the billable item is splittable."
          },
          "master_invoice": {
            "type": "string",
            "description": "A projected billable item doesn't have master invoice.",
            "nullable": true,
            "example": null
          },
          "master_invoice_id": {
            "type": "integer",
            "nullable": true,
            "description": "A projected billable item doesn't have master invoice ID.",
            "example": null
          },
          "original_bill_code_id": {
            "type": "integer",
            "example": 302,
            "description": "Original bill code id of the billable item. This value will never be modified. It is used to verify if the billable item's bill code has been modified by a user.\n"
          },
          "original_end_date_time": {
            "type": "string",
            "example": "2021-01-05T20:00:00Z",
            "description": "Original UTC datetime of the end datetime of the source item. This value will never be modified. It is used to verify if the billable item's end at has been modified by a user.\n"
          },
          "original_quantity": {
            "type": "number",
            "description": "Original quantity of the source item. This value will never be modified. It is used to verify if the billable item's quantity has been modified by a user.\n",
            "example": 2.35
          },
          "original_rate": {
            "type": "number",
            "description": "Original rate of the bill code. This value will never be modified. It is used to verify if the billable item's quantity has been modified by a user.\n",
            "example": 12.3321
          },
          "original_start_date_time": {
            "type": "string",
            "example": "2021-01-05T16:00:00Z",
            "description": "Original UTC datetime of the start at datetime of the source item. This value will never be modified. It is used to verify if the billable item's start at has been modified by a user.\n"
          },
          "premium": {
            "type": "string",
            "description": "Premium object isn't load in Projected billable items endpoint.",
            "nullable": true,
            "example": null
          },
          "program": {
            "type": "string",
            "description": "Program object isn't load in Projected billable items endpoint.",
            "nullable": true,
            "example": null
          },
          "quantity": {
            "type": "number",
            "description": "Defines the quantity to be billed. If unit is hours this represents the amount of hours to bill.",
            "example": 2.35
          },
          "rate": {
            "type": "number",
            "description": "Defines the bill rate.",
            "example": 12.3321
          },
          "rating_methodology": {
            "type": "string",
            "description": "rating methodology of the linked visit's service code",
            "enum": [
              "funder_driven"
            ],
            "example": "funder_driven"
          },
          "service_code": {
            "type": "string",
            "nullable": true,
            "description": "The service code object isn't loaded in Projected billable item endpoints.",
            "example": null
          },
          "source_id": {
            "type": "integer",
            "description": "Depends on the source_type\n * `visit` = this relates to the visit id\n * `visit_custom_item` = this relates to the visit id\n * `premium` = this relates to the guid premium row guid_to is liked to the visit's guid\n * `client_premium` = this relates to the guid premium row guid_to is liked to the client's guid\n * `custom_item` = null\n",
            "example": 3124
          },
          "source_type": {
            "type": "string",
            "enum": [
              "client_premium",
              "custom_item",
              "premium",
              "visit_custom_item",
              "visit_premium",
              "visit"
            ],
            "description": "What entity type this billable item is related to",
            "example": "visit"
          },
          "start_at": {
            "type": "string",
            "example": "2021-01-05T16:00:00Z",
            "description": "UTC datetime of the start datetime of the source item"
          },
          "status": {
            "type": "string",
            "enum": [
              "ready_to_bill",
              "invoiced",
              "on_hold"
            ],
            "example": "invoiced",
            "description": "Status of the billable item"
          },
          "taxes": {
            "type": "string",
            "description": "The taxes object list isn't loaded for projected billable items endpoints.",
            "nullable": true
          },
          "timezone": {
            "type": "string",
            "example": "America/New_York",
            "description": "Timezone used for all datetime operations, such as finding the correct rate"
          },
          "unit": {
            "type": "string",
            "enum": [
              "hours",
              "visit",
              "rate"
            ],
            "description": "Defines if the billable item billed by hours or flat rate.",
            "example": "hours"
          },
          "update_user_id": {
            "type": "integer",
            "example": 100,
            "description": "Id of the user who last did a modification on the billable item"
          },
          "updated_at": {
            "type": "string",
            "example": "2021-10-05T20:00:00Z",
            "description": "UTC datetime of when the billable item was last edited"
          },
          "value": {
            "type": "number",
            "example": 28.98,
            "description": "Rate * Quantity"
          },
          "visit_id": {
            "type": "integer",
            "example": 3124,
            "description": "Id of the visit that the billable item is linked to."
          },
          "chris_fields": {
            "type": "string",
            "nullable": true,
            "description": "Chris fields objects aren't loaded in Projected billable item endpoints.",
            "example": null
          },
          "activity_codes": {
            "type": "string",
            "nullable": true,
            "description": "Activity Code objects aren't loaded in Projected billable item endpoints.",
            "example": null
          }
        },
        "nullable": true
      }
    },
    "responses": {
      "Success": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "response": {
                "value": {
                  "code": 401,
                  "message": "Authorization required."
                }
              }
            }
          }
        }
      },
      "ErrorResponseAuthentication": {
        "description": "Authorization required",
        "content": {
          "application/json": {
