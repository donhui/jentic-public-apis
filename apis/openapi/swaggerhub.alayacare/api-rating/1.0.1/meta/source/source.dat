        "name": "is_copy",
        "in": "query",
        "required": false,
        "schema": {
          "type": "boolean",
          "minimum": 0
        },
        "description": "Billable item is a copy\n"
      },
      "lock_key": {
        "name": "lock_key",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Billable item lock_key\n"
      },
      "service_id": {
        "name": "service_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "description": "Multiple values can be given as ?service_id=1&service_id=2\n"
      },
      "is_splittable": {
        "name": "is_splittable",
        "in": "query",
        "required": false,
        "schema": {
          "type": "boolean",
          "minimum": 0
        },
        "description": "Billable item is_splittable\n"
      },
      "is_archived": {
        "name": "is_archived",
        "in": "query",
        "required": false,
        "schema": {
          "type": "boolean",
          "minimum": 0
        },
        "description": "If false, filters out billable items linked to voided/deleted invoices or master invoices\n"
      }
    },
    "requestBodies": {
      "Data": {
        "description": "Only include the attributes that you are modifying",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "bill_code_id",
                "branch_id",
                "client_id",
                "description",
                "end_at",
                "program_id",
                "quantity",
                "rate",
                "source_type",
                "start_at",
                "status",
                "taxes",
                "timezone"
              ],
              "properties": {
                "bill_code_id": {
                  "type": "integer",
                  "minimum": 1
                },
