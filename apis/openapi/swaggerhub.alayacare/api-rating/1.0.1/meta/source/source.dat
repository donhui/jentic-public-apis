                  "message": "pagination page must be greater than 0"
                }
              }
            }
          }
        }
      },
      "InvalidRequest": {
        "description": "Invalid data.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            },
            "examples": {
              "response": {
                "value": {
                  "code": 400,
                  "message": "There was a problem with your request."
                }
              }
            }
          }
        }
      },
      "NotFound": {
        "description": "Not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            },
            "examples": {
              "response": {
                "value": {
                  "code": 404,
                  "message": "No entity found"
                }
              }
            }
          }
        }
      },
      "ServiceCodeFunderDriven400Response": {
        "description": "Validation errors",
        "content": {
          "application/json": {
            "schema": {
              "oneOf": [
                {
                  "type": "object",
                  "description": "Some or all bill codes are not found",
                  "properties": {
                    "code": {
                      "type": "string",
                      "description": "The error code",
                      "example": 400
                    },
                    "message": {
                      "type": "string",
                      "example": "bill_code_not_found",
                      "description": "The error description"
                    },
                    "bill_code_ids_not_found": {
                      "type": "array",
                      "example": [
                        1,
                        2
                      ],
                      "items": {
                        "type": "integer",
                        "minimum": 1
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "description": "Two or more bill codes given share the same funder",
                  "properties": {
                    "code": {
                      "type": "string",
                      "description": "The error code",
                      "example": 400
                    },
                    "message": {
                      "type": "string",
                      "example": "many_bill_code_for_same_funder",
                      "description": "The error description"
                    },
                    "bill_code_ids_with_same_funder": {
                      "type": "array",
                      "example": [
                        1,
                        2
                      ],
                      "description": "List of bill code ids that share the same funder",
                      "items": {
                        "type": "integer",
                        "minimum": 1
                      }
                    },
                    "funder_id_with_duplicate_bill_codes": {
                      "type": "integer",
                      "description": "Funder id that has multiple bill codes sharing it",
                      "example": 1
                    }
                  }
                },
                {
                  "type": "object",
                  "description": "A funder id that was originally attached to a service code is missing",
                  "properties": {
                    "code": {
                      "type": "string",
                      "description": "The error code",
                      "example": 400
                    },
                    "message": {
                      "type": "string",
                      "example": "missing_funder_in_bill_code",
                      "description": "The error description"
                    },
                    "missing_funder_id": {
                      "type": "integer",
                      "example": 1
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "parameters": {
      "bill_code_id": {
