    "/pdns_reverse_historic": {
      "get": {
        "summary": "Historic reverse passive DNS lookup",
        "description": "Returns domains that previously referenced a given value but no longer do. Use type=a (default) for IP, type=ns for nameserver, type=mx for mail server.",
