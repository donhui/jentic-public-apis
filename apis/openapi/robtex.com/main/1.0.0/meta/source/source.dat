    "/pdns_reverse": {
      "get": {
        "summary": "Reverse passive DNS lookup",
        "description": "Returns domains that reference a given value. Use type=a (default) for IP, type=ns for nameserver, type=mx for mail server.",
        "operationId": "pdnsReverse",
        "parameters": [
          {
            "name": "value",
            "in": "query",
            "description": "IP address, nameserver, or mail server hostname",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "8.8.8.8"
          },
          {
            "name": "type",
            "in": "query",
            "description": "Record type",
            "required": false,
            "schema": {
              "type": "string",
              "default": "a",
              "enum": [
                "a",
