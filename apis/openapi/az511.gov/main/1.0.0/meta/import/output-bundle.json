  "components": {
    "schemas": {
      "Camera": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Camera identifier"
          },
          "name": {
            "type": "string",
            "description": "Camera name/location"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "imageUrl": {
            "type": "string",
            "description": "URL to the camera image"
          }
        }
      },
      "WeatherStation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Station identifier"
          },
          "name": {
            "type": "string",
            "description": "Station name"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "temperature": {
            "type": "number",
            "description": "Current temperature"
          },
          "humidity": {
            "type": "number",
            "description": "Current humidity"
          }
        }
      },
      "MessageSign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Sign identifier"
          },
          "name": {
            "type": "string",
            "description": "Sign name/location"
          },
          "message": {
            "type": "string",
            "description": "Current message displayed"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Event identifier"
          },
          "type": {
            "type": "string",
            "description": "Event type"
          },
          "description": {
            "type": "string",
            "description": "Event description"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Alert identifier"
          },
          "type": {
            "type": "string",
            "description": "Alert type"
          },
          "description": {
            "type": "string",
            "description": "Alert description"
          },
          "severity": {
            "type": "string",
            "description": "Alert severity level"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RestArea": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Rest area identifier"
          },
          "name": {
            "type": "string",
            "description": "Rest area name"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "amenities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Available amenities"
          }
        }
      },
      "WorkZoneData": {
        "type": "object",
        "description": "WZDx formatted work zone data",
        "properties": {
          "type": {
            "type": "string"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
