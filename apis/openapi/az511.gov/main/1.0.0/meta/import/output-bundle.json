{
  "openapi": "3.0.3",
  "info": {
    "title": "Arizona 511 API",
    "version": "1.0.0",
    "description": "Traffic and transportation data API for the state of Arizona. Provides access to cameras, weather stations, message signs, events, alerts, rest areas, and work zone data. Rate limited to 10 calls per 60 seconds.",
    "x-jentic-source-url": "https://az511.gov/developers/doc"
  },
  "servers": [
    {
      "url": "https://az511.com/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/endpoint/cameras": {
      "get": {
        "operationId": "getcameras",
        "summary": "Get all traffic cameras",
        "description": "Retrieves all traffic camera data.",
        "tags": [
          "Traffic"
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Developer API key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Camera"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
