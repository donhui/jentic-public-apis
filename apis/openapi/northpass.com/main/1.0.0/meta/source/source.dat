    "/v2/people/{person_uuid}/relationships/courses": {
      "post": {
        "tags": [
          "People"
        ],
        "summary": "Associate a person with a course",
        "description": "Add existing courses to an existing person.\nDepending on the `type` it will either enroll a person to a course (`enrolled-courses`) or add the course to the list of managed courses (`managed-courses`).\nThis will associate the person with any courses they are not currently associated with and ignore any courses that the person is already associated with. You do not have to include any courses that the person is already associated with, as this will not remove any current associations.\n",
