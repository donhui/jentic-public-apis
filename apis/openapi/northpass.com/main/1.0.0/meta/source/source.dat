    "/v2/people": {
      "get": {
        "tags": [
          "People"
        ],
        "summary": "List people",
        "description": "Returns a list of people.\n\n**filters:**\n`partnerships_type` - person's partnership type *(string)*, available values: `Partnerships::Admin`, `Partnerships::Manager`, `Partnerships::Learner`\n\n**default sorting:** `full_name` ASC\n",
        "parameters": [
          {
            "name": "include",
            "in": "query",
            "description": "permitted inclusions: `school`, `partnerships`, `groups`\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "the number of the page",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "the number of items per page",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "query term",
            "required": false,
