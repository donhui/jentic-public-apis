  "components": {
    "securitySchemes": {
      "CognitoAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "AWS Cognito authorization token"
      }
    },
    "schemas": {
      "Address": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "BusinessBorrowerRequest": {
        "type": "object",
        "required": [
          "id",
          "company",
          "date_of_incorporation",
          "address",
          "email",
          "website"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the borrower"
          },
          "company": {
            "type": "string",
            "description": "Name of the business"
          },
          "date_of_incorporation": {
            "type": "string",
            "format": "date",
            "description": "Business incorporation date"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "website": {
            "type": "string",
            "format": "uri"
          },
          "entity_document_id": {
            "type": "string",
            "description": "Identity document for the business"
          },
          "country_code": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "credit_ranking": {
            "type": "string",
            "description": "Credit score value"
          },
          "industry": {
            "type": "string",
            "enum": [
              "retail",
              "restaurants",
              "real_estate"
            ]
          }
        }
      },
      "BusinessBorrower": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "date_of_incorporation": {
            "type": "string",
            "format": "date"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "website": {
            "type": "string"
          }
        }
      },
      "ConsumerBorrowerRequest": {
        "type": "object",
        "required": [
          "id",
          "is_veteran",
          "first_name",
          "last_name",
          "address",
          "date_of_birth",
          "email"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the borrower"
          },
          "is_veteran": {
