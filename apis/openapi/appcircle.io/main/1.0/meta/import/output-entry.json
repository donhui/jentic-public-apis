    "/auth/v1/in-app-update/token": {
      "post": {
        "summary": "Retrieve Access Token for In-App Update",
        "security": [],
        "description": "Retrieve an access token using the provided organization ID, profile ID, and secret. This token is required to authenticate subsequent store download requests for in-app updates.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "profileId": {
                    "type": "string",
                    "description": "Appcircle enterprise store profile Id",
                    "example": "s3cr3tV4lu3"
                  },
                  "secret": {
                    "type": "string",
                    "description": "The secret associated with the in-app update. This is used to authenticate the request. You can create the secret in the settings section of the profile in the enterprise store module.",
                    "example": "s3cr3tV4lu3"
                  }
                },
                "required": [
                  "profileId",
                  "secret"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "eyJhbGciOiJSUzI1NiIsImtpZCI6IkVENEVDQTEMxjJGRDlGCncgJMyr9ThrqNGY_z1cfJlFt-Gzls8Dc35I9o",
                      "description": "Token for authentication"
                    },
                    "expires_in": {
                      "type": "number",
                      "example": "14400",
                      "description": "Token expires after the given seconds"
                    },
                    "refresh_expires_in": {
                      "type": "number",
                      "description": "Refresh token expires after the given seconds",
                      "example": "14400"
                    },
                    "token_type": {
                      "type": "string",
                      "example": "Bearer",
                      "description": "The type of token this is, typically just the string 'bearer'"
                    },
                    "not-before-policy": {
                      "type": "number",
                      "example": 1592285118,
                      "description": "A timestamp indicating when the token becomes valid."
                    },
                    "scope": {
                      "type": "string",
                      "example": "profile email",
                      "description": "The scope of the access token."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/v1/api-key/token": {
      "post": {
        "summary": "Retrieve Access Token for API Key",
        "security": [],
        "description": "Retrieve an access token using the provided API key name and secret. This token is required to authenticate Appcircle API requests.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Appcircle Organization API key name",
                    "example": "myapikey"
                  },
                  "secret": {
                    "type": "string",
                    "description": "The secret associated with the API key. This is used to authenticate the request.",
                    "example": "s3cr3tV4lu3"
                  },
                  "organizationId": {
                    "type": "string",
                    "description": "The ID of the organization associated with the API key.",
                    "example": "123e4567-e89b-12d3-a456-426614174000"
                  }
                },
                "required": [
                  "name",
                  "secret"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
