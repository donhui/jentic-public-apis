                  },
                  "scope": {
                    "type": "string",
                    "description": "Scope of the access request. Defaults to 'openid profile email' if not provided.",
                    "default": "openid profile email"
                  },
                  "subOrganizationId": {
                    "type": "string",
                    "description": "Sub-organization ID if applicable. If not provided, the token will be for the root organization."
