{
  "openapi": "3.0.3",
  "info": {
    "title": "Appcircle Authentication API",
    "description": "Welcome to Appcircle API documentation. Appcircle API allows you to access the wide range of Appcircle features programmatically for various integration use cases.",
    "version": "1.0",
    "x-jentic-source-url": "https://api.appcircle.io/openapi/modules/auth"
  },
  "servers": [
    {
      "url": "https://auth.appcircle.io"
    }
  ],
  "paths": {
    "/auth/v1/token": {
      "post": {
        "summary": "Get Access Token",
        "security": [],
        "description": "Retrieve an access token using your personal access token (PAT). This token can be used for authentication in subsequent API requests.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "pat": {
                    "type": "string",
                    "description": "Bearer (apiKey – Personal Access Token). How to get your personal access token? [https://docs.appcircle.io/appcircle-api/api-authentication](https://docs.appcircle.io/appcircle-api/api-authentication)"
                  }
                },
                "required": [
                  "pat"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "eyJhbGciOiJSUzI1NiIsImtpZCI6IkVENEVDQTEMxjJGRDlGCncgJMyr9ThrqNGY_z1cfJlFt-Gzls8Dc35I9o",
                      "description": "Token for authentication"
                    },
                    "expires_in": {
                      "type": "number",
                      "example": "14400",
                      "description": "Token expires after the given seconds"
                    },
                    "refresh_expires_in": {
                      "type": "number",
                      "description": "Refresh token expires after the given seconds",
                      "example": "14400"
                    },
                    "refresh_token": {
                      "type": "string",
                      "example": "CfDJ8NxTkf4RATAEjptui_CemyIf16C1MWm4j9IiSS4ZcojOBuvGZEqaNg5FXEKJa6AXz1KeJ3Mr39zhuVYh22",
                      "description": ""
                    },
                    "token_type": {
                      "type": "string",
                      "example": "Bearer",
                      "description": "The type of token this is, typically just the string 'bearer'"
                    },
                    "id_token": {
                      "type": "string",
                      "description": "ID tokens are used in token-based authentication to cache user profile information and provide it to a client application"
                    },
                    "not-before-policy": {
                      "type": "number",
                      "example": 1592285118,
                      "description": ""
                    },
                    "session_state": {
                      "type": "string",
                      "description": ""
                    },
                    "scope": {
                      "type": "string",
                      "example": "openid profile email roles",
                      "description": ""
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/v2/token": {
      "post": {
        "summary": "Get Access Token with Scope and Sub-Organization ID",
        "security": [],
        "description": "Retrieve an access token with specific scopes and for a sub-organization using your personal access token (PAT). This token can be used for authentication in subsequent API requests.",
