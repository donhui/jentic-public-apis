              ]
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An array of assessments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
