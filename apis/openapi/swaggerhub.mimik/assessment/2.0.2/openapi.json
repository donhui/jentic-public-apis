        "parameters": [
          {
            "name": "types",
            "in": "query",
            "style": "form",
            "explode": true,
            "description": "Types of information to be retrieved",
            "schema": {
              "minItems": 1,
              "uniqueItems": true,
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "assessments",
                  "assessmentResponses",
                  "config",
                  "healthCheck"
                ]
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Information about the service and its resources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {},
                      "example": {
                        "assessments": {
                          "count": 14
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "security": [
          {
            "AdminSecurity": [
              "read:system"
            ]
          }
        ],
        "x-swagger-router-controller": "infoController"
      }
    },
