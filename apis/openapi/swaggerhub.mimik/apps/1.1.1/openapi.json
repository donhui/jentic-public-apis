          },
          {
            "name": "pageSize",
            "description": "Defines the number of apps to return in a given page.",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 10,
            "minimum": 10,
            "maximum": 100
          },
          {
            "name": "startAfter",
            "description": "Defines the id of the last record from previous page.",
            "in": "query",
            "type": "string"
          }
        ],
        "security": [
          {
            "UserSecurity": [
              "read:apps"
            ]
          },
          {
            "AdminSecurity": [
              "read:apps"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "An array of apps",
            "schema": {
              "type": "object",
              "properties": {
                "count": {
                  "description": "total apps, only available when startAfter query param is not used.",
                  "type": "integer"
                },
                "nextPageUrl": {
                  "description": "url to the next page of data. Not available on last page.",
                  "type": "string",
                  "format": "url"
                },
                "data": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/App"
                  }
