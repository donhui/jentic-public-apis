        "read:apps": "read apps",
        "read:appGroup": "get an app group by id",
        "read:appGroups": "get a list of app groups"
      }
    },
    "AdminSecurity": {
      "type": "oauth2",
      "tokenUrl": "https://mimik.com/oauth/token",
      "flow": "application",
      "scopes": {
        "read:system": "read system info",
        "read:apps": "read apps",
        "create:app": "add an app",
        "update:app": "update an app",
        "delete:app": "delete an app",
