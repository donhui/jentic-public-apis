        "update:appGroup": "update an app group",
        "delete:appGroup": "delete an app group",
        "read:appGroups": "get a list of app groups",
        "create:memberApps": "add apps to group",
        "delete:memberApp": "remove an app from group",
        "create:userGroups": "add userGroups to app group",
        "delete:userGroup": "delete userGroup from app group"
      }
    }
