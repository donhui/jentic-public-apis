{
  "openapi": "3.0.3",
  "info": {
    "title": "The Muse API",
    "description": "The Muse API provides access to job listings and company profiles. It allows searching and filtering jobs by company, category, level, and location, as well as browsing company profiles.",
    "version": "2.0.0",
    "contact": {
      "name": "The Muse API Support",
      "email": "api@themuse.com",
      "url": "https://www.themuse.com/developers/api/v2"
    },
    "termsOfService": "https://www.themuse.com/developers/api/v2/terms",
    "x-jentic-source-url": "https://www.themuse.com/developers/api/v2"
  },
  "servers": [
    {
      "url": "https://www.themuse.com/api/public",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Jobs",
      "description": "Job listing operations"
    },
    {
      "name": "Companies",
      "description": "Company profile operations"
    }
  ],
  "paths": {
    "/jobs": {
      "get": {
        "operationId": "listJobs",
        "summary": "List jobs",
        "description": "Retrieves a paginated list of job postings sorted by relevance. Each page contains up to 20 results.",
        "tags": ["Jobs"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": true,
            "description": "Page number to retrieve.",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "descending",
            "in": "query",
            "description": "Reverse the default sort order. Default is false.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "company",
            "in": "query",
            "description": "Filter by company name. Can be specified multiple times.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Filter by job category (e.g. Software Engineer, Marketing, Design).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "level",
            "in": "query",
            "description": "Filter by experience level.",
            "schema": {
              "type": "string",
              "enum": [
                "Entry Level",
                "Mid Level",
                "Senior Level",
                "Management",
                "Internship"
              ]
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Filter by geographic location.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "description": "API key for authentication. Increases rate limit from 500 to 3600 requests/hour.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with paginated job listings.",
            "headers": {
              "X-RateLimit-Remaining": {
                "description": "Number of requests remaining in the current window.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Limit": {
                "description": "Total allowed requests in the current window.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Reset": {
                "description": "Seconds until the rate limit resets.",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden. Typically due to rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Resource not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}": {
      "get": {
        "operationId": "getJob",
        "summary": "Get job details",
        "description": "Retrieves detailed information about a specific job posting.",
        "tags": ["Jobs"],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "description": "Unique job identifier.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with job details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Job not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/companies": {
      "get": {
        "operationId": "listCompanies",
        "summary": "List companies",
        "description": "Retrieves a paginated list of company profiles. Each page contains up to 20 results.",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": true,
            "description": "Page number to retrieve.",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "descending",
            "in": "query",
            "description": "Reverse the default sort order.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "industry",
            "in": "query",
            "description": "Filter by industry name.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Filter by company size.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Filter by location.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with paginated company listings.",
            "headers": {
              "X-RateLimit-Remaining": {
                "description": "Number of requests remaining.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Limit": {
                "description": "Total allowed requests.",
                "schema": {
                  "type": "integer"
                }
              },
              "X-RateLimit-Reset": {
                "description": "Seconds until reset.",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/companies/{companyId}": {
      "get": {
        "operationId": "getCompany",
        "summary": "Get company details",
        "description": "Retrieves detailed information about a specific company.",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "companyId",
            "in": "path",
            "required": true,
            "description": "Unique company identifier.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with company details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "404": {
            "description": "Company not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key obtained by registering at The Muse developer portal. Without a key, rate limit is 500 requests/hour; with a key, 3600 requests/hour."
      }
    },
    "schemas": {
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique job identifier."
          },
          "name": {
            "type": "string",
            "description": "Job title."
          },
          "contents": {
            "type": "string",
            "description": "Full HTML job description."
          },
          "type": {
            "type": "string",
            "description": "Source type (e.g. external)."
          },
          "publication_date": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 publication timestamp."
          },
          "short_name": {
            "type": "string",
            "description": "URL-friendly identifier."
          },
          "model_type": {
            "type": "string",
            "description": "Content model type.",
            "example": "jobs"
          },
          "locations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Location"
            },
            "description": "Job locations."
          },
          "categories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            },
            "description": "Job categories."
          },
          "levels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Level"
            },
            "description": "Experience levels."
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            },
            "description": "Job tags."
          },
          "refs": {
            "$ref": "#/components/schemas/JobRefs"
          },
          "company": {
            "$ref": "#/components/schemas/CompanySummary"
          }
        }
      },
      "JobListResponse": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Current page number."
          },
          "page_count": {
            "type": "integer",
            "description": "Total number of pages."
          },
          "items_per_page": {
            "type": "integer",
            "description": "Number of items per page (typically 20)."
          },
          "took": {
            "type": "integer",
            "description": "Query execution time in milliseconds."
          },
          "timed_out": {
            "type": "boolean",
            "description": "Whether the query timed out."
          },
          "total": {
            "type": "integer",
            "description": "Total number of matching results."
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          }
        }
      },
      "Company": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique company identifier."
          },
          "name": {
            "type": "string",
            "description": "Company name."
          },
          "short_name": {
            "type": "string",
            "description": "URL-friendly company identifier."
          },
          "description": {
            "type": "string",
            "description": "Company description."
          },
          "publication_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "ISO 8601 publication timestamp."
          },
          "model_type": {
            "type": "string",
            "description": "Content model type."
          },
          "twitter": {
            "type": "string",
            "nullable": true,
            "description": "Company Twitter handle."
          },
          "locations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Location"
            },
            "description": "Company office locations."
          },
          "industries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Industry"
            },
            "description": "Company industries."
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            },
            "description": "Company tags."
          },
          "size": {
            "$ref": "#/components/schemas/CompanySize"
          },
          "refs": {
            "$ref": "#/components/schemas/CompanyRefs"
          }
        }
      },
      "CompanyListResponse": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Current page number."
          },
          "page_count": {
            "type": "integer",
            "description": "Total number of pages."
          },
          "items_per_page": {
            "type": "integer",
            "description": "Items per page."
          },
          "took": {
            "type": "integer",
            "description": "Query time in milliseconds."
          },
          "timed_out": {
            "type": "boolean"
          },
          "total": {
            "type": "integer",
            "description": "Total matching results."
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Company"
            }
          },
          "aggregations": {
            "type": "object",
            "description": "Aggregation/facet data."
          }
        }
      },
      "CompanySummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "short_name": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "CompanySize": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Size label."
          },
          "short_name": {
            "type": "string",
            "description": "Size short identifier."
          }
        }
      },
      "CompanyRefs": {
        "type": "object",
        "properties": {
          "landing_page": {
            "type": "string",
            "format": "uri"
          },
          "jobs_page": {
            "type": "string",
            "format": "uri"
          },
          "mini_f1_image": {
            "type": "string",
            "format": "uri"
          },
          "f1_image": {
            "type": "string",
            "format": "uri"
          },
          "f2_image": {
            "type": "string",
            "format": "uri"
          },
          "f3_image": {
            "type": "string",
            "format": "uri"
          },
          "logo_image": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Location name."
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Category name."
          }
        }
      },
      "Level": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Level name."
          },
          "short_name": {
            "type": "string",
            "description": "Level short identifier."
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "short_name": {
            "type": "string"
          }
        }
      },
      "Industry": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "JobRefs": {
        "type": "object",
        "properties": {
          "landing_page": {
            "type": "string",
            "format": "uri",
            "description": "Full URL to the job listing."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "HTTP status code."
          },
          "error": {
            "type": "string",
            "description": "Error message."
          }
        }
      }
    }
  }
}
