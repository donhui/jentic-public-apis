      "EvaluatePathsV3": {
        "type": "object",
        "required": [
          "executionContext",
          "paths"
        ],
        "properties": {
          "executionContext": {
            "$ref": "#/components/schemas/ExecutionContext"
          },
          "paths": {
            "type": "array",
            "description": "List of JS paths to evaluate. \n\n Usage examples: \n\n `matter.client.{ __id, __description, phoneNumberList}` \n\n or \n\n `matter.matterStatus`\n\n `matter.{__firmId,fileNumber,reLine1,type,matterTypeId,costAgreementDate,costRecoveriesBalance}`  - retrieve key matter details\n \n `matter.currentStaff.{__id,userName}` - retrieve current staff member\n \n `matter.currentStaff.branch.{firmName,city}` - retrieve current staff member location data\n \n `matter.purchaser.{__id,__classes,description,addressList,isSupplier}` - retrieve purchase information\n\n `firm.firmDetails` - list out all the details of the firm\n\n `firm.firmDetails.currentUser.userName` - gets the firm's current User's user name\n\n `firm.firmDetails.currentUser.__id` - gets the firm's current User ID\n \n `firmDetails.staffList[0].{__id, userId, email, firstName, lastName, middleName, initials, rate1, rate2, rate3, rate4, rate5, rate6, status, phone, mobile}` - gets the first record of the staff list and lists the details specified\n\n `card.version` - displays the current version of the card record\n\n `card.fullName` - gets the card's full name\n\n `card.personList[0].{dateOfBirth, gender, surname, firstNames, lastName}` - gets the person details of the gard\n\n `card.originalAddressList.{number, street, suburb, state, across}` - gets the address details of the card's original address\n\n `card.webAddressList.{__className, type, address, tableId, addressType, pageLocation, pageType, url}` - gets a list of the web addresses/email of the card",
            "items": {
              "type": "string"
            }
          },
          "objectId": {
            "type": "string",
            "description": "Object GUID to start path evaluation from"
          },
          "includeDefaults": {
            "type": "boolean",
            "description": "Return default value from inherited class",
            "default": true
          },
          "params": {
            "$ref": "#/components/schemas/RequestParams"
          }
        }
      },
