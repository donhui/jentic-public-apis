          "SecondsPerUnit": {
            "type": "integer",
            "description": "How many seconds there are per unit",
            "format": "int32"
          },
          "FeeUnits": {
            "type": "integer",
            "description": "How many fee units",
            "format": "int32"
          },
          "FeeHoursQuantity": {
            "type": "number",
            "description": "The quantity of fee hours to allocate",
            "format": "double"
          },
          "Timed": {
            "type": "boolean",
            "description": "Is this timed"
          },
          "CalculationMode": {
            "type": "integer",
            "description": "0 = Fixed rate per hour | 1 = Fixed amount",
            "format": "int32"
          },
          "IncTax": {
            "type": "boolean",
            "description": "Includes TAX"
          },
          "TotalIncTax": {
            "type": "number",
            "description": "Total inclusive of TAX",
            "format": "double"
          },
          "TotalExTax": {
            "type": "number",
            "description": "Total exclusive of TAX",
            "format": "double"
          },
          "TotalTax": {
            "type": "number",
            "description": "Total TAX value",
            "format": "double"
          },
          "BillingDescription": {
            "type": "string",
            "description": "The description that will appear on the fee"
          },
          "Memo": {
            "type": "string",
            "description": "The memo for this fee"
          },
          "BillingMode": {
            "type": "integer",
            "description": "Billing Mode: -1 = Not billable | 0 = Billable next invoice | 1 = Billable later invoice",
            "format": "int32"
          },
          "RowVersion": {
            "type": "integer",
            "description": "This field is for internal use and can be ignored",
            "format": "int64"
          },
          "ExternalURL": {
            "type": "string",
            "description": "When this field is populated, LEAP will open the URL provided when opened"
          },
          "ExternalJSON": {
            "type": "string",
            "description": "Use this field for capturing app specific custom data (not used by LEAP)"
          },
          "FeeId": {
            "type": "string",
            "description": "A new GUID that will identify the fee",
            "format": "uuid"
          },
          "MatterId": {
            "type": "string",
            "description": "The matter Id",
            "format": "uuid"
          },
          "TaxCodeId": {
            "type": "string",
            "description": "The TaxCode Id, this can be retrieved from [GET /api/v2/taxcodes](https://leap.build/api-reference/#tag/Tax-Codes/paths/~1api~1v2~1taxcodes/get)",
            "format": "uuid"
          },
          "TaskCodeId": {
            "type": "string",
            "description": "The TaskCode Id, this can be retrieved from [GET /api/v2/taskcodes/fees](https://leap.build/api-reference/#tag/Task-Codes/paths/~1api~1v2~1taskcodes~1fees/get)",
            "format": "uuid"
          },
          "WorkDoneByStaffId": {
            "type": "string",
            "description": "The Id (GUID) of the staff member the work was completed by",
            "format": "uuid"
          },
          "AttributeFeesToStaffId": {
            "type": "string",
            "description": "Which staff member to attribute the fees to",
            "format": "uuid"
          }
        }
      },
