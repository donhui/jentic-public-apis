          "CalculationMode": {
            "type": "integer",
            "description": "0 = Fixed rate per hour | 1 = Fixed amount",
            "format": "int32"
          },
          "CalculationScript": {
            "type": "string",
            "description": "Used internally, can be ignored"
          },
          "ImportedFrom": {
            "type": "string",
            "description": "This property is set to 'Import', if task code is imported from conversions (internal)"
          },
          "BillingMode": {
            "type": "integer",
            "description": "Billing Mode: -1 = Not billable | 0 = Billable next invoice | 1 = Billable later invoice",
            "format": "int32"
          }
        }
