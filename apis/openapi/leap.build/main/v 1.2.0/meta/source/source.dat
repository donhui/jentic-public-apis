                },
                "format": {
                  "type": "string",
                  "format": "integer",
                  "description": "Format of any attachments"
                },
                "fileUrl": {
                  "type": "string",
                  "format": "integer",
                  "description": "URL of any attachments"
                },
                "token": {
                  "type": "string"
                }
              }
