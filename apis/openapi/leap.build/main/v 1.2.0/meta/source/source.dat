          },
          "DeletedDate": {
            "type": "string",
            "description": "Deleted date (any valid datetime)",
            "format": "date-time"
          },
          "RowVersion": {
            "type": "integer",
            "description": "Database row Id that references this item",
            "format": "int64"
          },
          "LAActivityDescription": {
            "type": "string",
            "description": "This field is related to LegalAid fields and can be ignored"
          },
          "LAADisplayDescription": {
            "type": "string",
            "description": "This field is related to LegalAid fields and can be ignored"
          },
          "PurchaseOrderGUID": {
            "type": "string",
            "description": "The purchase order Id for the purchase order related to the cost recovery",
            "format": "uuid"
          },
          "ExternalURL": {
            "type": "string",
            "description": "When this field is populated, LEAP will open the URL provided when opened"
