                "type": "string",
                "format": "uuid"
              },
              "address": {
                "type": "string",
                "description": "Email address of the task owner"
              },
              "name": {
                "type": "string",
                "description": "Name of the staff member assigned to the task"
              },
              "staffId": {
                "type": "string",
                "format": "uuid",
                "description": "LEAP Staff GUID of the staff member assigned to the task"
              },
              "userId": {
                "type": "string",
                "format": "uuid",
                "description": "LEAP User GUID of the staff member assigned to the task"
              },
              "sent": {
                "type": "boolean"
              }
            }
          },
          "assignees": {
            "type": "array",
            "items": {
              "properties": {
                "todoGuid": {
                  "type": "string",
                  "format": "uuid"
                },
                "address": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "staffId": {
                  "type": "string",
                  "format": "uuid"
                },
                "userId": {
                  "type": "string",
                  "format": "uuid"
                },
                "sent": {
                  "type": "boolean"
                }
              }
            }
          },
          "attachments": {
            "type": "array",
            "items": {
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid",
                  "description": "GUID of any attachments"
                },
                "name": {
                  "type": "string",
                  "description": "Name of any attachments"
                },
                "type": {
                  "type": "string",
                  "format": "integer",
