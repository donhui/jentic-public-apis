      "CostRecoveryCreateModel": {
        "type": "object",
        "required": [
          "BillingDescription",
          "TransactionDate",
          "CostRecoveryId",
          "MatterId",
          "TaxCodeId"
        ],
        "properties": {
          "PurchaseMode": {
            "type": "integer",
            "description": "Internally used, can be ignored"
          },
          "TransactionDate": {
            "type": "string",
            "description": "Date & time of the transaction in *ISO 8601* format.",
            "format": "date-time"
          },
          "Quantity": {
            "type": "integer",
            "description": "Indicates the quantity of billable units in the cost recovery.",
            "format": "int32"
          },
          "AmountEach": {
            "type": "number",
            "description": "Indicates the dollar value of each billable item.",
            "format": "double"
          },
          "TotalIncTax": {
            "type": "number",
            "description": "Indicates the total value of the cost recovery including tax.",
            "format": "double"
          },
          "TotalExTax": {
            "type": "number",
            "description": "Indicates the total value of the cost recovery excluding tax.",
            "format": "double"
          },
          "TotalTax": {
            "type": "number",
            "description": "Indicates the total value of tax applied for the cost recovery.",
            "format": "double"
          },
          "BillingDescription": {
            "type": "string",
            "description": "The description of the cost recovery item."
          },
          "BillingMode": {
            "type": "integer",
            "description": "Indicates the billing mode of the cost recovery. Valid entries:\n\n- -1 = Not billable\n- 0 = Billable next invoice\n- 1 = Billable later invoice\n",
            "format": "int32"
          },
          "IncTax": {
            "type": "boolean",
            "description": "Indicates whether tax is included in this cost recovery."
          },
          "ExternalURL": {
            "type": "string",
            "description": "When this field is populated, LEAP will open the URL provided when opened."
          },
          "ExternalJSON": {
            "type": "string",
            "description": "JSON file to be attached to the cost recovery. Provided by third party where desired."
          },
          "FunctionGroupId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the button used to open the application."
          },
          "InterestCalculcationDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date to calculate interest from."
          },
          "CostRecoveryId": {
            "type": "string",
            "description": "GUID for the Cost Recovery record (to be generated by the developer).",
            "format": "uuid"
          },
          "MatterId": {
            "type": "string",
            "description": "LEAP GUID for the matter the cost recovery will be recorded against.",
            "format": "uuid"
          },
          "TaxCodeId": {
            "type": "string",
            "description": "LEAP ID of the relevant tax code for the cost recovery record. Current tax codes can be retrieved from [GET /api/v2/taxcodes](http://leap.build/api-reference/#tag/Tax-Codes/paths/~1api~1v2~1taxcodes/get).",
            "format": "uuid"
          },
          "TaskCodeId": {
            "type": "string",
            "description": "LEAP ID of the relevant task code for the cost recovery record. Current cost recovery task codes can be retrieved from [GET /api/v2/taskcodes/costrecovery](http://leap.build/api-reference/#tag/Task-Codes/paths/~1api~1v2~1taskcodes~1costrecovery/get).",
            "format": "uuid"
          },
          "PurchaseSupplierCardId": {
            "type": "string",
            "description": "LEAP GUID of the Card record for the Purchase Supplier. Card records for a firm can be retrieved from [GET /api/v2/cards](http://leap.build/api-reference/#tag/Cards/operation/Card_GetCards) or [GET /api/v1/cards/search](http://leap.build/api-reference/#tag/Cards/paths/~1api~1v1~1cards~1search/get).",
            "format": "uuid"
          }
        }
      },
