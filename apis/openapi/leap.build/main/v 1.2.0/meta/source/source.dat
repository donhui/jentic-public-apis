    "/api/v2/matters/matterxpathparser": {
      "get": {
        "tags": [
          "Matters"
        ],
        "summary": "Get result from parsing xPath expression, for given AsyncRequestId",
        "description": "Retrieve the asynchronous response from POST /api/v2/matters/matterxpathparser.\n\n<b>Note: This endpoint is in the process of being deprecated. [GET /api/v1/reporting/getasyncrequest/{requestId}](http://localhost/leap.integrations.build_develop/index.html#tag/Reporting/paths/~1api~1v1~1reporting~1getasyncrequest~1%7Brequestid%7D/get) should be used to retrieve asynchronous results from POST /api/v2/matters/matterxpathparser.</b>                \n",
        "security": [
          {
            "Bearer": [
              "Authorization"
            ],
            "APIKey": [
              "x-api-key"
            ]
          }
        ],
        "parameters": [
          {
            "name": "asyncRequestId",
            "in": "query",
            "description": "This is derived from the response body on `POST /api/v1/matters/matterxpathparser`",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "LEAP Auth Token",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "LEAP API Key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MattersPathParserResponse"
                }
              }
            },
            "headers": {
              "Access-Control-Allow-Origin": {
                "type": "string",
                "description": "Allows CORS sharing"
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorForAysncRequestId"
                }
              }
            },
            "headers": {
              "Access-Control-Allow-Origin": {
                "type": "string",
                "description": "Allows CORS sharing"
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Matters"
        ],
        "summary": "Retrieve matter information from the matter.xml file via an xPath request. ",
        "description": "*Utilise [GET /api/v1/reporting/getasyncrequest/{requestId}](https://leap.build/api-reference/#tag/Reporting/paths/~1api~1v1~1reporting~1getasyncrequest~1%7Brequestid%7D/get) to retrieve results.*\n\n<b>Note: the v1 version of this endpoint is in the process of being deprecated. This v2 endpoint functions the same as the v1 version.</b>\n\nThis endpoint allows you to fetch properties from the matter.xml using the xPath expression for a given list of Matter GUIDs.\n\n### Cache\n\nNo caching is set unless specified for an endpoint.\n",
        "security": [
          {
            "Bearer": [
              "Authorization"
            ],
            "APIKey": [
              "x-api-key"
            ]
          }
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "LEAP Auth Token",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "LEAP API Key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MatterxPathParser"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncRequestResponse"
                }
              }
            },
            "headers": {
              "Access-Control-Allow-Origin": {
                "type": "string",
                "description": "Allows CORS sharing"
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "headers": {
              "Access-Control-Allow-Origin": {
                "type": "string",
                "description": "Allows CORS sharing"
              }
            }
          }
        }
      }
    },
