      },
      "post": {
        "tags": [
          "Definable Tables"
        ],
        "summary": "Add definable table to matter",
        "description": "Definable Tables are tables that store the data for fields within the \"Details\" portion of a Matter. These tables are known as \"definable\" because they not automatically populated via the system but rather based off of the Client or Firm's specific details relating to the matter.\n\nEach LEAP Matter can store matter-specific data in one or more definable tables. A definable table can contain one or more fields.\n\nA LEAP Matter's matterTypeId determines the available definable tables and how each field in a definable table is displayed or laid out.\n\nThe Content team designs definable tables and they are based on documents related to the matter (Examples: \"Cheque details\" or \"Settlement details\" related to a matter). Fields in the definable tables\nare part of these designs and are not static.    \n",
        "security": [
          {
            "Bearer": [
              "Authorization"
            ],
            "APIKey": [
              "x-api-key"
            ]
          }
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "LEAP Auth Token",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "LEAP API Key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MatterId",
            "in": "path",
            "description": "Matter ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DefinableTablePostBody"
              }
            }
          },
          "description": "Definable Table",
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefinableTablePostResponse200"
                }
              }
            },
            "headers": {
              "Access-Control-Allow-Origin": {
                "type": "string",
                "description": "Allows CORS sharing"
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage400"
                }
              }
