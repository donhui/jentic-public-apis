          "CostRecoveryId": {
            "type": "string",
            "description": "Id related to this CostRecovery",
            "format": "uuid"
          },
          "MatterId": {
            "type": "string",
            "description": "Matter Id",
            "format": "uuid"
          },
          "TaxCodeId": {
            "type": "string",
            "description": "The TaxCode Id, this can be retrieved from [GET /api/v2/taxcodes](https://leap.build/api-reference/#tag/Tax-Codes/paths/~1api~1v2~1taxcodes/get)",
