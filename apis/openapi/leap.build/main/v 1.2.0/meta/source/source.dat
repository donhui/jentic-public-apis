      "MattersWriteCreateMatterv2": {
        "type": "object",
        "required": [
          "cards",
          "criticalDates",
          "file",
          "matterTypeId",
          "staff",
          "state"
        ],
        "properties": {
          "definableTables": {
            "type": "array",
            "description": "List of definable tables on the matter (defaults to matter type specific tables if left empty).",
            "items": {
              "$ref": "#/components/schemas/MattersWriteDefinableTable"
            }
          },
          "cards": {
            "type": "array",
            "description": "List of cards on the matter (only client card is required).",
            "items": {
              "$ref": "#/components/schemas/MattersWriteCard"
            }
          },
          "matterTypeId": {
            "type": "string",
            "description": "Matter type Id.",
            "format": "uuid"
          },
          "deleted": {
            "type": "boolean",
            "description": "Deleted flag."
          },
          "noFileCreated": {
            "type": "boolean",
            "description": "Is there a  physical file created for archiving?"
          },
          "financial": {
            "$ref": "#/components/schemas/MattersWriteFinancial"
          },
          "state": {
            "type": "string",
            "description": "Geographical state of the matter."
          },
          "title": {
            "$ref": "#/components/schemas/MattersWriteTitle"
          },
          "substitution": {
            "type": "object",
            "$ref": "#/components/schemas/MattersWriteSubstitution"
          },
          "customDescription": {
            "type": "string",
            "description": "Custom description of the matter."
          },
          "criticalDates": {
            "type": "array",
            "description": "List of critical dates on the matter.",
            "items": {
              "$ref": "#/components/schemas/MattersWriteCriticalDate"
            }
          },
          "file": {
            "$ref": "#/components/schemas/MattersWriteFile"
          },
          "staff": {
            "$ref": "#/components/schemas/MattersWriteStaff"
          },
          "workObtained": {
            "type": "string",
            "description": "Where the work was obtained from.",
            "nullable": true
          },
          "invoiceFixed": {
            "type": "boolean",
            "description": "Is the first invoice a fixed fee?"
          },
          "invoiceFixedAmount": {
            "type": "number",
            "format": "double",
            "description": "Amount of the first fixed invoice.",
            "minimum": 0,
            "maximum": 2147483647
          },
          "referrerCard": {
            "$ref": "#/components/schemas/MattersWriteReferrerCard"
          },
          "debtorNote": {
            "type": "string",
            "description": "Debtor note.",
            "nullable": true
          },
          "taxFree": {
            "type": "boolean",
            "description": "Is this matter tax free?"
          },
          "acl": {
            "description": "Access control list details.",
            "$ref": "#/components/schemas/MattersWriteAcl"
          },
          "archive": {
            "description": "Archive details.",
            "$ref": "#/components/schemas/MattersWriteArchive"
          },
          "reportingGroupId": {
            "type": "string",
            "description": "Reporting Group Id.",
            "format": "uuid",
            "nullable": true
          },
          "billingCategoryId": {
            "type": "string",
            "description": "Billing Category Id.",
            "format": "uuid",
            "nullable": true
          },
          "wealthMatId": {
            "type": "string",
            "description": "Wealth Counsel Matter Id.",
            "nullable": true
          },
          "legacyMatterId": {
            "type": "string",
            "description": "Legacy Matter Id.",
            "nullable": true
          }
        }
