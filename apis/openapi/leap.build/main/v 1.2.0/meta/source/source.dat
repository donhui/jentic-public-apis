      "Definition_200Response_Get_v3_Matters": {
        "type": "object",
        "properties": {
          "MatterList": {
            "type": "array",
            "items": {
              "type": "object",
              "$ref": "#/components/schemas/Definition_Get_v3_Matters_Obj"
            }
          },
          "LastRowVersion": {
            "type": "integer",
            "description": "The `lastRowVer` field, is the database identity record of the item being requested.\n\nProvide this to get a DELTA of all matters that have been changed or created since the `lastRowVer` provided.",
            "format": "int64"
          }
        }
      },
      "Definition_Get_v3_Matters_Obj": {
        "type": "object",
        "properties": {
          "rowVersion": {
            "type": "Integer",
            "description": "The rowVersion is the database version of the particular matter record"
          },
          "matterId": {
            "type": "string",
            "description": "Unique identifier of the Matter"
          },
          "fileNumber": {
            "type": "string",
            "description": "The file number of the matter as it appears in LEAP's Matter List Dashboard"
          },
          "firstDescription": {
            "type": "string",
            "description": "Usually the last name of the Client"
          },
          "secondDescription": {
            "type": "string"
          },
          "customDescription": {
            "type": "string",
            "description": "Describes the matter type"
          },
          "matterTypeName": {
            "type": "string",
            "description": "Describes the matter type"
          },
          "matterTypeId": {
            "type": "string",
            "description": "Unique identifier of the matter type"
          },
          "matterStatus": {
            "type": "string",
            "description": "Describes the status of the matter\nExamples:\n\"??\" - status when there has been no confirmation on the date itself but there is a corresponding date linked to the matter which has passed \"Unexchanged\" - status when matter sale/purchase has not resulted in a property changing owners          ",
            "enum": [
              "??",
              "In Progress",
              "Unexchanged",
              "Complete",
              "Archived"
            ]
          },
          "isCurrent": {
            "type": "boolean",
            "description": "Flags the matter if it is open or not.\nIf the matter is not archived and if the 'Not Proceeding Date' of the matter is null or still greater than the current date and if the completion of the matter is not yet confirmed, then the matter will remain \"current\" (ie: active).\nIf this is false, then it means that the matter is closed."
          },
          "state": {
            "type": "string",
            "description": "State where the matter has been opened"
          },
          "responsibleStaffId": {
            "type": "string",
            "description": "The staff ID responsible for the matter. Should be a staff member of the law firm."
          },
          "creditStaffId": {
            "type": "string",
            "description": "The credit staff ID for the matter. Should be a staff member of the law firm."
          },
          "actingStaffId": {
            "type": "string",
            "description": "The acting staff ID for the matter. Should be a staff member of the law firm."
          },
          "assistingStaffId": {
            "type": "string",
            "description": "The assisting staff ID for the matter. Should be a staff member of the law firm."
          },
          "isArchived": {
            "type": "boolean",
            "description": "Flags the matter as \"Deleted\""
          },
          "deleted": {
            "type": "boolean",
            "description": "Flags the matter as \"Deleted\""
          },
          "version": {
            "type": "Integer"
          },
          "instructionDate": {
            "type": "date",
            "format": "DateTime",
            "description": "The date when the matter has been opened"
          },
          "billingMode": {
            "type": "Integer",
            "description": "Billing Mode: -1 = Not billable | 0 = Billable next invoice | 1 = Billable later invoice",
            "enum": [
              0,
              1,
              -1
            ]
          },
          "archiveDate": {
            "type": "date",
            "format": "DateTime"
          },
          "isMatterAccessible": {
            "type": "boolean",
            "description": "This flag is directly related to the Restrict Matter Access controls in Matters. Allows users to restrict access to a Matter based on which Staff should have access to it. Returns \"True\" if the user related to the token calling the endpoint has access to the Matter and vice-versa."
          }
        }
      },
