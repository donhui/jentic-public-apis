      "TransitRegisterTransactionCreate": {
        "type": "object",
        "required": [
          "Amount",
          "MatterId",
          "PaymentTypeDetail",
          "PaymentTypeId",
          "ReceivedDate",
          "TransactionId"
        ],
        "properties": {
          "TransactionId": {
            "type": "string",
            "format": "uuid",
            "description": "GUID for the transaction (to be generated by the developer)"
          },
          "MatterId": {
            "type": "string",
            "format": "uuid",
            "description": "LEAO GUID of the attached matter"
          },
          "ReceivedFrom": {
            "type": "string",
            "description": "Who the transaction was received from"
          },
          "PaymentTypeName": {
            "type": "string",
            "description": "Payment type"
          },
          "PaymentTypeGuid": {
            "type": "string",
            "format": "uuid",
            "description": "LEAP GUID of the payment type"
          },
          "PaymentTypeId": {
            "type": "integer",
            "format": "int32",
            "description": "LEAP Id of the payment type"
          },
          "Amount": {
            "type": "number",
            "format": "double",
            "description": "Dollar value of the payment"
          },
          "Reason": {
            "type": "string",
            "description": "Reason for the payment"
          },
          "Paid": {
            "type": "boolean",
            "description": "Paid status of the transaction"
          },
          "PaidTo": {
            "type": "string",
            "description": "Who the transaction was paid to"
          },
          "TransactionNumber": {
            "type": "string",
            "description": "Transaction number for the transaction"
          },
          "ReceivedDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date the transaction was received"
          },
          "PaidToDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date the transaction was paid"
          },
          "EntryDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date the transaction was entered/recorded"
          },
          "PaymentTypeDetail": {
            "description": "Details relating to the payment",
            "$ref": "#/components/schemas/PaymentTypeDetail"
          },
          "WarningAcknowledgments": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          }
        }
      },
