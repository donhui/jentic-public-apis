      "CostRecoveryTaskCode": {
        "type": "object",
        "required": [
          "AmountEach",
          "GroupOnInvoice",
          "InclusiveTax",
          "TaskCodeId",
          "TaxCodeId"
        ],
        "properties": {
          "TaskCodeId": {
            "type": "string",
            "description": "GUID for the Cost Recovery Task Code record (to be generated by the developer). Current cost recovery task codes can be retrieved from [GET /api/v2/taskcodes/costrecovery](http://leap.build/api-reference/#tag/Task-Codes/paths/~1api~1v2~1taskcodes~1costrecovery/get).",
            "format": "uuid"
          },
          "TaxCodeId": {
            "type": "string",
            "description": "LEAP GUID of the relevant tax code for the cost recovery task code record. Current tax codes can be retrieved from [GET /api/v2/taxcodes](http://leap.build/api-reference/#tag/Tax-Codes/paths/~1api~1v2~1taxcodes/get).",
            "format": "uuid"
          },
          "NameFileAs": {
            "type": "string",
            "description": "The name of the Task Code - will be displayed in LEAP."
          },
          "BillingDescription": {
            "type": "string",
            "description": "The description that will appear on the newly created task code."
          },
          "PurchaseSupplierCardId": {
            "type": "string",
            "description": "LEAP GUID of the Card record for the Purchase Supplier. Card records for a firm can be retrieved from [GET /api/v2/cards](http://leap.build/api-reference/#tag/Cards/operation/Card_GetCards) or [GET /api/v1/cards/search](http://leap.build/api-reference/#tag/Cards/paths/~1api~1v1~1cards~1search/get).",
            "format": "uuid"
          },
          "GroupOnInvoice": {
            "type": "boolean",
            "description": "Group these items on the invoice"
          },
          "AmountEach": {
            "type": "number",
            "description": "Indicates the dollar value of each billable item.",
            "format": "double"
          },
          "InclusiveTax": {
            "type": "boolean",
            "description": "Indicates whether tax is included in the cost recovery task code."
          },
          "ImportedFrom": {
            "type": "string",
            "description": "This property is set to 'Import', if task code is imported from conversions (internal)"
          },
          "PurchaseMode": {
            "type": "integer",
            "description": "Internally used, can be ignored",
            "format": "int32"
          }
        }
      },
      "AccTaskCodeCostRecovery": {
