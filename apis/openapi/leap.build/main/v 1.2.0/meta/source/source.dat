      "TrustReceiptCreateTrustReceipt": {
        "type": "object",
        "required": [
          "BankAccountGUID",
          "EntryDate",
          "PaymentTypeDetails",
          "PaymentTypeGUID",
          "ReceivedFrom",
          "TransactionDate",
          "TransactionNumber",
          "TrustReceiptItems"
        ],
        "properties": {
          "TrustReceiptGUID": {
            "type": "string",
            "format": "uuid",
            "description": "GUID for the receipt that is being created (to be generated by the developer). If an ID is not passed in, an ID will be generated by LEAP.\n"
          },
          "BankAccountGUID": {
            "type": "string",
            "format": "uuid",
            "description": "GUID for the bank account the receipt is being paid into. Bank Accounts for a matter can be retrieved from [GET /api/v1/trustreceipt/initialisationdata](http://leap.build/api-reference/#tag/TrustReceipt/paths/~1api~1v1~1trustreceipt~1initialisationdata/get)."
          },
          "EntryDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date & time of the entry in *ISO 8601* format."
          },
          "TransactionDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date & time of the original transaction in *ISO 8601* format."
          },
          "TransactionNumber": {
            "type": "string",
            "description": "Identifying number for the transaction. Any value provided will be overridden by the next sequential number for the target data file if `TransactionNumberAuto` value provided is \"true\".\n"
          },
          "TransactionNumberAuto": {
            "type": "boolean",
            "description": "Determies whether the `TransactionNumber` should be overridden by the next sequential number for the target data file."
          },
          "ReceivedFrom": {
            "type": "string",
            "description": "Individual or entity the receipt was received from."
          },
          "PaymentTypeGUID": {
            "type": "string",
            "format": "uuid",
            "description": "LEAP GUID for the Payment Type the receipt was tendered in e.g. EFT, Cash, Credit Card. All current Payment Types can be retrieved from [GET /api/v1/paymenttypes](https://leap.build/api-reference/#tag/Payment-Types/paths/~1api~1v1~1paymenttypes/get)."
          },
          "PaymentTypeName": {
            "type": "string",
            "description": "**Recommended field**. Name of the Payment Type the receipt was tendered in. All current Payment Types can be retrieved from [GET /api/v1/paymenttypes](https://leap.build/api-reference/#tag/Payment-Types/paths/~1api~1v1~1paymenttypes/get).\n"
          },
          "PaymentTypeId": {
            "type": "integer",
            "format": "int32",
            "description": "LEAP ID for the Payment Type the receipt was tendered in e.g. EFT, Cash, Credit Card. All current Payment Types can be retrieved from [GET /api/v1/paymenttypes](https://leap.build/api-reference/#tag/Payment-Types/paths/~1api~1v1~1paymenttypes/get)."
          },
          "ReversedOrReversal": {
            "type": "boolean",
            "description": "Indicates whether the receipt has been reversed or is itself a reversal. In most cases this value should be \"false\"."
          },
          "ReceiptedByStaffGUID": {
            "type": "string",
            "format": "uuid",
            "description": "LEAP GUID of the staff member the receipt was processed by. Staff Members can be retrieved from [GET /api/v1/firms/{firmId}](http://leap.build/api-reference/#tag/Firms/paths/~1api~1v1~1firms~1%7Bfirmid%7D/get)"
          },
          "NeedsBanking": {
            "type": "boolean",
            "description": "Indicates whether the receipt requires banking."
          },
          "Reconciled": {
            "type": "integer",
            "format": "int32",
            "description": "Indicates whether the receipt has been reconciled in/against the target bank account."
          },
          "ClearanceDays": {
            "type": "integer",
            "format": "int32",
            "description": "Indicates the number of clearance days for the receipt."
          },
          "ClearedDate": {
            "type": "string",
            "format": "date-time",
            "description": "Indicates the clearance date of the receipt."
          },
          "BankDepositGUID": {
            "type": "string",
            "format": "uuid",
            "description": "GUID for the Bank Deposit record attached to the receipt (to be generated by the developer)."
          },
          "AnticipatedDepositId": {
            "type": "string",
            "format": "uuid",
            "description": "GUID for the Anticipated Deposit record attached to the receipt (to be generated by the developer)."
          },
          "IsRapidPay": {
            "type": "integer",
            "format": "int32",
            "description": "Indicates whether the receipt is a Rapid Pay transaction."
          },
          "BTISettlementDate": {
            "type": "string",
            "format": "date-time",
            "description": "Incidates the BTI settlement date of the receipt."
          },
          "ExtPayReceiptNo": {
            "type": "string",
            "description": "External receipt number (e.g. Rapid Pay)"
          },
          "WarningAcknowledgments": {
            "type": "array",
            "description": "Allows you to acknowledge any warning acknowledgements that would appear for the receipt upon processing.",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          },
          "TrustReceiptItems": {
            "type": "array",
            "description": "Items relating specifically to the Trust Receipt Item.",
            "items": {
              "$ref": "#/components/schemas/CreateTrustReceiptItem"
            }
          },
          "PaymentTypeDetails": {
            "description": "Details relating to the supplied Payment Type of the receipt.",
            "$ref": "#/components/schemas/PaymentTypeDetail"
          }
        }
      },
