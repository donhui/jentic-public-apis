          },
          {
            "name": "rowVersion",
            "in": "query",
            "description": "The `rowVersion` field, is the database identity record of the item being requested.\n\nProvide this to get a DELTA of all cards that have been changed or created since the `rowVersion` provided.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "crStatus",
