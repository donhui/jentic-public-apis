    "/api/v1/lists/invoices": {
      "get": {
        "tags": [
          "Office Invoices"
        ],
        "summary": "Returns a list of invoices.",
        "security": [
          {
            "Bearer": [
              "Authorization"
            ],
            "APIKey": [
              "x-api-key"
            ]
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "This will determine the number of Invoices to return, ranging from (1 – 10000).\n\nIf this ‘limit’ parameter is not included in the request, then the default of 2500 will be applied.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "This will determine the page of data to return.\n\nIf your limit is set to 5000 then page=1 will return Invoice 0-5000. Meaning page=2 would return Invoice 5000-10000 and so on.\n\nYou can increment pages until you run out of data (nothing will be returned).",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sequence",
            "in": "query",
            "description": "If this ‘sequenceNumber’ parameter is not included in the request, then all (max) invoices will be returned.\n\nIf the parameter is included, then the returned list will contain the Invoices starting from the ‘sequenceNumber‘.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "LEAP Auth Token",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Access-Control-Allow-Origin": {
                "type": "string",
                "description": "Allows CORS sharing"
              }
            }
          },
          "301": {
            "description": "Moved Permanently",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/301"
                }
              }
            },
            "headers": {
              "Access-Control-Allow-Origin": {
                "type": "string",
                "description": "Allows CORS sharing"
              }
            }
