      "PostEmailsSend_RequestBody": {
        "type": "object",
        "required": [
          "sender",
          "to",
          "body",
          "subject",
          "firmId"
        ],
        "properties": {
          "matterId": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "staffId": {
            "type": "string",
            "format": "uuid"
          },
          "matterNo": {
            "type": "string"
          },
          "folderId": {
            "type": "string",
            "format": "uuid"
          },
          "sender": {
            "$ref": "#/components/schemas/Email_RequestBody_Fields"
          },
          "to": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "*Main recipient email addresses*",
              "$ref": "#/components/schemas/Email_RequestBody_Fields"
            }
          },
          "cc": {
            "type": "array",
            "description": "*Carbon copy recipient email addresses*",
            "items": {
              "type": "object",
              "$ref": "#/components/schemas/Email_RequestBody_Fields"
            }
          },
          "bcc": {
            "type": "array",
            "description": "*Blind carbon copy recipient email addresses (Other recipients can't see these email recipients)*",
            "items": {
              "type": "object",
              "$ref": "#/components/schemas/Email_RequestBody_Fields"
            }
          },
          "attachments": {
            "type": "array",
            "description": "*File attachments to the email*",
            "items": {
              "type": "object",
              "required": [
                "id",
                "name"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "int",
                  "description": "*Possible values: can be 0,1,2*",
                  "default": 0
                },
                "format": {
                  "type": "int",
                  "description": "*Possible values: can be 0,1*",
                  "default": 0
                },
                "fileUrl": {
                  "type": "string",
                  "default": "Get value from /api/v1/sample"
                },
                "token": {
                  "type": "string"
                },
                "outlookAttachmentId": {
                  "type": "string"
                }
              }
            }
          },
          "body": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "importance": {
            "type": "integer"
          },
          "staffInitials": {
            "type": "string"
          },
          "categories": {
            "type": "array",
            "description": "*Category*",
            "items": {
              "type": "object",
              "properties": {
                "string": {
                  "type": "string"
                }
              }
            }
          },
          "saveToMatter": {
            "type": "boolean"
          },
          "clientSystemId": {
            "type": "string",
            "format": "uuid"
          },
          "firmId": {
            "type": "string",
            "format": "uuid"
          },
          "useFallbackOnSendError": {
            "type": "boolean"
          }
        }
      },
