    "securitySchemes": {
      "Bearer": {
        "name": "Authorization",
        "in": "header",
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "All API endpoints require authorization.\n\nFor <a href=\"https://developer.leap.build/knowledge-base/general/creating-your-app/\">Public Apps</a>, we recommend using the <a href=\"https://developer.leap.build/knowledge-base/general/sdk-authorization/\">LEAP Host SDK</a>.\n\nFor <a href=\"https://developer.leap.build/knowledge-base/general/creating-your-app/\">Connector Apps</a>, we recommend using the <a href=\"https://developer.leap.build/knowledge-base/general/authorization-code-flow/\">Authorization Code Flow</a>.\n\nOnce your App is pre-approved in the LEAP Developer Console, you can generate <a href=\"https://developer.leap.build/knowledge-base/general/security-api-credentials/\">API Credentials</a>.\n\nPlease see the <a href=\"https://developer.leap.build/knowledge-base/general/authorization/\">LEAP Developer Knowledge Base</a> for further information.\n"
      },
      "APIKey": {
        "type": "apiKey",
        "name": "x-api-key",
        "in": "header",
        "description": "A LEAP API Key is used for client identification, logging and manages usage plans.\n\n Once you have your LEAP API Key, you'll be required to pass it into a `x-api-key` header for <b>all</b> LEAP Service requests;\n\n \n\n<b>Example:</b> \n\n ```\n curl -X GET https://[API_Domain]/api/v2/cards/12345678-687e-4da3-85ac-9cd1db6c2f8c \\\n -H 'authorization: Bearer Token' \\\n -H 'x-api-key: [LEAP API Key]'\n```\n##"
      }
    }
  }
