      "MatterJson": {
        "type": "object",
        "properties": {
          "__firmId": {
            "type": "string",
            "description": "Firm ID that the matter belongs to"
          },
          "type": {
            "type": "string",
            "description": "Description of the matter type"
          },
          "matterTypeId": {
            "type": "string",
            "description": "GUID of the matter type ID"
          },
          "fileNumber": {
            "type": "string",
            "description": "Unique identifier of the matter as a file number"
          },
          "credit": {
            "type": "string",
            "description": "(Optional) staff GUID who will receive the credit for this matter"
          },
          "personResponsible": {
            "type": "string",
            "description": "(Optional) staff GUID responsible for the matter"
          },
          "personActing": {
            "type": "string",
            "description": "(Required) staff GUID of the person handling the matter"
          },
          "personAssisting": {
            "type": "string",
            "description": "(Required) staff GUID of the person assisting the staff handling the matter"
          },
          "staffInitials": {
            "type": "string",
            "description": "(Deprecated) staff initial of the creator of the matter"
          },
          "title": {
            "type": "string",
            "description": "Title of the matter"
          },
          "acl": {
            "$ref": "#/components/schemas/AclJson"
          },
          "criticalDates": {
            "type": "object",
            "description": "List of the critical dates that are important to the Matter",
            "properties": {
              "additionalProp1": {
                "$ref": "#/components/schemas/CriticalDate"
              },
              "additionalProp2": {
                "$ref": "#/components/schemas/CriticalDate"
              },
              "additionalProp3": {
                "$ref": "#/components/schemas/CriticalDate"
              }
            }
          },
          "referrerCardId": {
            "description": "Card GUID of the person who referred this matter",
            "type": "string"
          },
          "referrerPersonId": {
            "type": "string",
            "description": "Person GUID of the person who referred this matter"
          },
          "deleteCode": {
            "type": "integer",
            "description": "Flags whether the matter has been deleted or not",
            "format": "int32"
          },
          "accounting": {
            "description": "List of Accounting-related information regarding the Matter",
            "$ref": "#/components/schemas/MatterAccountingJson"
          },
          "archive": {
            "description": "List of Achival-related information regarding the Matter",
            "$ref": "#/components/schemas/MatterArchiveJson"
          },
          "msTeams": {
            "$ref": "#/components/schemas/MatterMsTeamsJson"
          },
          "fileLocation": {
            "type": "string",
            "description": "Physical location of the file for archiving"
          },
          "definableTableList": {
            "type": "array",
            "Description": "List of definable tables associated with the matter",
            "items": {
              "type": "string"
            }
          },
          "cardList": {
            "type": "array",
            "Description": "List of Card objects associated with the matter",
            "items": {
              "type": "string"
            }
          },
          "state": {
            "type": "string",
            "description": "State where the matter has been created for"
          },
          "recordVersion": {
            "type": "integer",
            "description": "Current version of the matter",
            "format": "int32"
          },
          "baseRecurringMatter": {
            "type": "string",
            "description": "GUID of the recurring matter where the matter  is based on"
          },
          "workObtained": {
            "type": "string",
            "description": "List on how the matter was obtained (See dropdown for \"Work Obtained\" in the Matter details window of LEAP Desktop)"
          },
          "titleClient": {
            "type": "string",
            "description": "Maps to the \"Matter Title\" tab of the Matter Details in LEAP Desktop."
          },
          "clientPrefix": {
            "type": "string",
            "description": "Maps to the \"Matter Title\" tab of the Matter Details in LEAP Desktop. Flag to check if the Client Name will be used as prefix for the matter"
          },
          "clientSuffix": {
            "type": "string",
            "description": "Maps to the \"Matter Title\" tab of the Matter Details in LEAP Desktop. Flag to check if the Client Name will be used as suffix for the matter"
          },
          "otherPrefix": {
            "type": "string",
            "description": "Maps to the \"Matter Title\" tab of the Matter Details in LEAP Desktop. Flag to check if the Other Side Name will be used as prefix for the matter"
          },
          "otherSuffix": {
            "type": "string",
            "description": "Maps to the \"Matter Title\" tab of the Matter Details in LEAP Desktop. Flag to check if the Other Side Name will be used as suffix for the matter"
          },
          "clientDefault": {
            "type": "string",
            "description": "Flag to check if the Client Name's default \"Re:\" line will be used in letters to Client"
          },
          "otherDefault": {
            "type": "string",
            "description": "Flag to check if the Other Side's Name default \"Re:\" line will be used in letters to Client"
          },
          "notificationStatus": {
            "type": "string",
            "description": "Flag to check if Notifications are toggled on/off for the Matter"
          },
          "onlyAllowPersonResponsible": {
            "type": "string",
            "description": "Toggle to restrict access to \"Person Responsible\" field in \"Matter Details\"\n\nMaps to \"Matter Details -> Access & Permissions -> Restrict Access to Matter Details\""
          },
          "onlyAllowPersonActing": {
            "type": "string",
            "description": "Toggle to restrict access to \"Person Acting\" field in \"Matter Details\"\n\nMaps to \"Matter Details -> Access & Permissions -> Restrict Access to Matter Details\""
          },
          "onlyAllowPersonAssisting": {
            "type": "string",
            "description": "Toggle to restrict access to \"Person Assisting\" field in \"Matter Details\"\n\nMaps to \"Matter Details -> Access & Permissions -> Restrict Access to Matter Details\""
          },
          "percentageComplete": {
            "type": "string",
            "description": "Indicator of the matter's current progress"
          },
          "billingMethod": {
            "type": "string",
            "description": "Billing mode for the matter (under \"Matter Accounting Details\")"
          },
          "autoCustomDescription": {
            "type": "boolean",
            "description": "Flags whether the matter has an automatic custom description"
          },
          "__className": {
            "type": "string",
            "description": "(Internal use only) Used to identify if the JSON is for Matter, Card or Person for PUT /api/v1/matters/{matterId}"
          },
          "__id": {
            "type": "string",
            "description": "(Internal use only) If '__className' is 'Matter', '__id' represents the 'MatterID'"
          },
          "__substitution": {
            "$ref": "#/components/schemas/SubstitutionJson"
          }
        }
      },
