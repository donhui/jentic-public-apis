      "FeeUpdateMultipleModel": {
        "type": "object",
        "properties": {
          "FeeList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FeeUpdateMultipleItemModel"
            },
            "description": "Array of IDs of fees to be updated"
          },
          "MatterGUID": {
            "type": "string",
            "format": "uuid",
            "description": "Related matter ID of the fees"
          },
          "TaskCodeGUID": {
            "type": "string",
            "format": "uuid",
            "description": "Task code ID where the fee will be billed against. Use GET /api/v1/tasks to get a list of available task codes for the matter"
          },
          "TaxCodeGUID": {
            "type": "string",
            "format": "uuid",
            "description": "Tax code ID where the fee will be billed against. Use GET /api/v2/taxcodes to get a list of available tax codes for the matter"
          },
          "Deleted": {
            "type": "boolean",
            "description": "Indicates when this fee was marked as \"Deleted\""
          },
          "DeletedDate": {
            "type": "string",
            "format": "date-time",
            "description": "Indicates the date when this fee has been marked as \"Deleted\""
          },
          "BillingMode": {
            "type": "integer",
            "description": "Flags the fee if not billable and if it is, which pay cycle it will be made billable (This billing or next billing)\nBilling Mode: -1 = Not billable | 0 = Billable next invoice | 1 = Billable later invoice",
            "format": "int32"
          },
          "WorkDoneByStaffGUID": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the Staff in the firm who worked and is charging for the fee"
          },
          "MatterSourceList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatterSourceList"
            },
            "description": "Collection of Matter IDs that are related to this fee"
          },
          "WarningAcknowledgments": {
            "type": "array",
            "description": "Used to check if message warnings have been acknowledged for the fees being updated. \n\nFor example, a fee that has been flagged as \"Deleted\" and has time entry billable activities will have a value of '1048' in this array\nAnother possible value would be '1099', which means that the update request has (a) valid Matter GUID value(s) and the matter has been archived",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          }
        }
      },
