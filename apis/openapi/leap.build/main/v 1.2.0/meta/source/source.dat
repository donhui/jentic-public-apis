            "description": "Matter file reference"
          },
          "Count": {
            "type": "integer",
            "description": "How many items",
            "format": "int32"
          },
          "TotalTax": {
            "type": "number",
            "description": "Total TAX value",
            "format": "double"
          },
          "InclusiveTax": {
            "type": "boolean",
            "description": "Inclusive of TAX"
          },
          "TaxCodeId": {
            "type": "string",
            "description": "The TaxCode Id, this can be retrieved from [GET /api/v2/taxcodes](https://leap.build/api-reference/#tag/Tax-Codes/paths/~1api~1v2~1taxcodes/get)",
            "format": "uuid"
          },
          "Memo": {
            "type": "string",
            "description": "The memo for this fee"
          },
          "CalculationMode": {
            "type": "integer",
            "description": "0 = Fixed rate per hour | 1 = Fixed amount",
            "format": "int32"
          },
          "FeesCreatedByStaffId": {
            "type": "string",
            "description": "Which staff (GUID) created the fee",
            "format": "uuid"
          },
          "AttributeFeesToStaffId": {
            "type": "string",
            "description": "Which staff member to attribute the fees to",
            "format": "uuid"
          },
          "ExternalURL": {
            "type": "string",
            "description": "When this field is populated, LEAP will open the URL provided when opened"
          },
          "ExternalJSON": {
            "type": "string",
            "description": "Use this field for capturing app specific custom data (not used by LEAP)"
          },
          "FeeId": {
            "type": "string",
            "description": "Fee Id",
            "format": "uuid"
          },
          "InvoiceItemId": {
            "type": "string",
            "description": "The Id of the attached invoice",
            "format": "uuid"
          },
          "WorkDoneByStaffId": {
            "type": "string",
            "description": "The Id (GUID) of the staff member the work was completed by",
