    "/api/v2/cards": {
      "get": {
        "tags": [
          "Cards"
        ],
        "summary": "Returns a list of cards for a firm",
        "operationId": "Card_GetCards",
        "security": [
          {
            "Bearer": [
              "Authorization"
            ],
            "APIKey": [
              "x-api-key"
            ]
          }
        ],
        "parameters": [
          {
            "name": "rowVersion",
            "in": "query",
            "description": "The `rowVersion` field, is the database identity record of the item being requested. Provide this to get a DELTA of all cards that have been changed or created since the `rowVersion` provided.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maxItems",
            "in": "query",
            "description": "Maximum number of total returned records returned while paginating (max of 10000).",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "LEAP Auth Token",
