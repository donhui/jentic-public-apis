            "format": "uuid",
            "description": "LEAP GUID of the client attached to the task"
          },
          "matterId": {
            "type": "string",
            "format": "uuid",
            "description": "LEAP GUID of the matter attached to the task"
          },
          "start": {
            "type": "string",
