      "CreateOfficeReceipt": {
        "type": "object",
        "required": [
          "Amount",
          "MailTo",
          "PaymentTypeGUID",
          "TransactionDate",
          "TransactionNumber"
        ],
        "properties": {
          "OfficeReceiptGUID": {
            "type": "string",
            "format": "uuid",
            "description": "GUID for the receipt that is being created (to be generated by the developer). If an ID is not passed in, an ID will be generated by LEAP."
          },
          "ReceivedFrom": {
            "type": "string",
            "description": "Individual or entity the receipt was received from."
          },
          "MailTo": {
            "type": "string",
            "description": "Address to mail to."
          },
          "BankAccountGUID": {
            "type": "string",
            "format": "uuid",
            "description": "GUID for the bank account the receipt is being paid into. Bank Accounts for a matter can be retrieved from [GET /api/v1/trustreceipt/initialisationdata](http://leap.build/api-reference/#tag/TrustReceipt/paths/~1api~1v1~1trustreceipt~1initialisationdata/get)."
          },
          "TransactionNumber": {
            "type": "string",
            "description": "Identifying number for the transaction. Any value provided will be overridden by the next sequential number for the target data file if `TransactionNumberAuto` value provided is \"true\"."
          },
          "AutoNumber": {
            "type": "integer",
            "format": "int32",
            "description": "Dictates whether the receipt number will be automatically generated by the system (0 = false, 1 = true).        \n"
          },
          "TransactionDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date & time of the original transaction in *ISO 8601* format."
          },
          "PaymentTypeName": {
            "type": "string",
            "description": "**Recommended field**. Name of the Payment Type the receipt was tendered in. All current Payment Types can be retrieved from [GET /api/v1/paymenttypes](https://leap.build/api-reference/#tag/Payment-Types/paths/~1api~1v1~1paymenttypes/get).\n"
          },
          "PaymentTypeId": {
            "type": "integer",
            "format": "int32",
            "description": "LEAP ID for the Payment Type the receipt was tendered in e.g. EFT, Cash, Credit Card. All current Payment Types can be retrieved from [GET /api/v1/paymenttypes](https://leap.build/api-reference/#tag/Payment-Types/paths/~1api~1v1~1paymenttypes/get)."
          },
          "PaymentTypeGUID": {
            "type": "string",
            "format": "uuid",
            "description": "LEAP GUID for the Payment Type the receipt was tendered in e.g. EFT, Cash, Credit Card. All current Payment Types can be retrieved from [GET /api/v1/paymenttypes](https://leap.build/api-reference/#tag/Payment-Types/paths/~1api~1v1~1paymenttypes/get)."
          },
          "ReversedOrReversal": {
            "type": "integer",
            "format": "int32",
            "description": "Indicates whether the receipt has been reversed or is itself a reversal. In most cases this value should be \"false\"."
          },
          "Memo": {
            "type": "string",
            "description": "Memo of the office receipt."
          },
          "NeedsBanking": {
            "type": "integer",
            "format": "int32",
            "description": "Indicates whether the receipt requires banking."
          },
          "Amount": {
            "type": "number",
            "format": "double",
            "description": "Indicates the dollar value of the receipt."
          },
          "TrustToOfficeTrustpayGUID": {
            "type": "string",
            "format": "uuid",
            "description": "The Trust to Office Trust Payment GUID is the GUID for the Trust Transfer (Payment from the Trust Account) to the Office Account. This is populated if the Office Receipt is a receipt of funds transferred from the Trust Account."
          },
          "PaymentTypeDetails": {
            "$ref": "#/components/schemas/PaymentTypeDetail"
          },
          "OfficeReceiptItem": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateOfficeReceiptItem"
            }
          },
          "WarningAcknowledgments": {
            "type": "array",
            "description": "Allows you to acknowledge any warning acknowledgements that would appear for the receipt upon processing.",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          }
        }
      },
