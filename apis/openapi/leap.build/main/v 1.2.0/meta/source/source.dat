            "description": "Start date of the task"
          },
          "due": {
            "type": "string",
            "format": "date-time",
            "description": "Due date of the task"
          },
          "completed": {
            "type": "string",
            "format": "date-time",
            "description": "Completion status of the task"
          },
          "status": {
            "type": "string",
            "description": "LEAP status of the task"
          },
          "subject": {
            "type": "string",
            "description": "Description of the task in LEAP/Outlook"
          },
          "importance": {
            "type": "integer",
            "description": "Importance of the task in LEAP"
          },
          "matterNo": {
            "type": "string",
            "description": "Matter number in LEAP (e.g. NC-0001)"
          },
          "timezone": {
            "type": "string",
            "description": "Set timezone of the task"
          },
          "reminderDateTime": {
            "type": "string",
            "format": "date-time",
