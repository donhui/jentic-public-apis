          "TotalExTax": {
            "type": "number",
            "description": "Indicates the total value of the cost recovery excluding tax.",
            "format": "double"
          },
          "TotalTax": {
            "type": "number",
            "description": "Indicates the total value of tax applied for the cost recovery.",
            "format": "double"
          },
          "BillingDescription": {
            "type": "string",
