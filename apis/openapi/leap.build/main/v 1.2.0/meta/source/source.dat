      "InitialisationInvoiceInitRequest": {
        "type": "object",
        "properties": {
          "MatterGUID": {
            "type": "string",
            "format": "uuid",
            "description": "Matter ID that this invoice is related to"
          },
          "InvSemaphoreGUID": {
            "type": "string",
            "format": "uuid",
            "description": "Specify the id of a \"semaphore\" which ensures no other updates to the invoice while the new invoice is being created (can use a known id or a random one)"
          },
          "LABillingStage": {
            "type": "integer",
            "format": "int32",
            "description": "(UK-Only field for Legal Aid) Billing stage of the Invoice for LegalAid invoices"
          },
          "MatterBillingMode": {
            "type": "integer",
            "format": "int32",
            "description": "Billing mode as set in \"Matter Details > Accounting > Billing Mode\""
          },
          "InvLAStrObjBilling": {
            "type": "string",
            "description": "(UK-Only field for Legal Aid) Base64 string of a JSON object representing the Legal Aid billing, including \"StandardFee\" and \"PoliceStationFee\". Only the \"StandardFee\" is used. Only applies to the UK or IE regions OR the \"isDeveloperRequest\" set to true"
          },
          "InvLAExceptional": {
            "type": "integer",
            "format": "int32",
            "description": "(UK-Only field for Legal Aid)"
          },
          "InvLACRMPSFFExceeded": {
            "type": "integer",
            "format": "int32",
            "description": "(UK-Only field for Legal Aid)"
          },
          "isDeveloperRequest": {
            "type": "integer",
            "format": "int32",
            "description": "Used to run the Legal Aid code for other regions (other than UK or IE)"
          },
          "ExTimeAndFees": {
            "type": "boolean",
            "description": "Flag to exclude time and fees in the invoice"
          },
          "ExCostRecoveries": {
            "type": "boolean",
            "description": "Flag to exclude cost recoveries in the invoice"
          },
          "ExDisbursementJournals": {
            "type": "boolean",
            "description": "Flag to exclude disbursement journals in the invoice"
          },
          "ExOfficePayments": {
            "type": "boolean",
            "description": "Flag to exclude office payments in the invoice"
          },
          "ExAnticipatedPayments": {
            "type": "boolean",
            "description": "Flag to exclude anticipated payments in the invoice"
          },
          "BillAtDate": {
            "type": "string",
            "description": "Date when the invoice was billed at",
            "format": "date-time"
          },
          "FixedFee": {
            "type": "boolean",
            "description": "Flag to determine whether this invoice is a fixed fee or not"
          },
          "FixedFeeAmount": {
            "type": "number",
            "format": "double",
            "description": "Actual value of the fixed fee"
          },
          "QuickInvoiceFeeId": {
            "type": "string",
            "description": "The id is used to filter the existing unbilled accounting fees to add to the invoice. Will only ever match to one fee at most (as the id is unique)",
            "format": "uuid"
          }
        }
      },
      "RecurringMatterRecurringMatter": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
