{
  "openapi": "3.0.3",
  "info": {
    "title": "LightwaveRF API",
    "version": "1.0.0",
    "description": "LightwaveRF API provides control of LightwaveRF smart home devices including lighting, heating, and power sockets. It supports device discovery, state management, and event-driven automation.",
    "x-jentic-source-url": "https://api.lightwaverf.com/"
  },
  "servers": [
    {
      "url": "https://publicapi.lightwaverf.com/v1"
    }
  ],
  "paths": {
    "/structures": {
      "get": {
        "operationId": "listStructures",
        "summary": "List all structures",
        "description": "Retrieves all structures (homes/buildings) associated with the authenticated user account.",
        "tags": ["Structures"],
        "responses": {
          "200": {
            "description": "List of structures",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StructureListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/structures/{structureId}": {
      "get": {
        "operationId": "getStructure",
        "summary": "Get structure details",
        "description": "Retrieves details of a specific structure including its rooms and devices.",
        "tags": ["Structures"],
        "parameters": [
          {
            "name": "structureId",
            "in": "path",
            "required": true,
            "description": "Unique structure identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Structure details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Structure"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/features/{featureId}": {
      "get": {
        "operationId": "getFeatureValue",
        "summary": "Get feature value",
        "description": "Reads the current value of a device feature (e.g., brightness, on/off state, temperature).",
        "tags": ["Features"],
        "parameters": [
          {
            "name": "featureId",
            "in": "path",
            "required": true,
            "description": "Unique feature identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feature value",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeatureValue"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "setFeatureValue",
        "summary": "Set feature value",
        "description": "Sets the value of a device feature (e.g., turn on/off, set brightness level).",
        "tags": ["Features"],
        "parameters": [
          {
            "name": "featureId",
            "in": "path",
            "required": true,
            "description": "Unique feature identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeatureSetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feature value set successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeatureValue"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/features": {
      "post": {
        "operationId": "batchSetFeatures",
        "summary": "Batch set feature values",
        "description": "Sets values for multiple device features in a single request.",
        "tags": ["Features"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchFeatureSetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch operation results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchFeatureResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/events": {
      "get": {
        "operationId": "listEvents",
        "summary": "List device events",
        "description": "Retrieves recent events from devices, such as state changes and triggers.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Start timestamp for event range (ISO 8601)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "description": "End timestamp for event range (ISO 8601)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StructureListResponse": {
        "type": "object",
        "properties": {
          "structures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Structure"
            }
          }
        }
      },
      "Structure": {
        "type": "object",
        "properties": {
          "structureId": {
            "type": "string",
            "description": "Unique structure identifier"
          },
          "name": {
            "type": "string",
            "description": "Structure name"
          },
          "groupIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of room/group IDs within this structure"
          },
          "devices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Device"
            }
          }
        }
      },
      "Device": {
        "type": "object",
        "properties": {
          "deviceId": {
            "type": "string",
            "description": "Unique device identifier"
          },
          "name": {
            "type": "string",
            "description": "Device name"
          },
          "type": {
            "type": "string",
            "description": "Device type"
          },
          "featureIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of feature IDs for this device"
          }
        }
      },
      "FeatureValue": {
        "type": "object",
        "properties": {
          "featureId": {
            "type": "string",
            "description": "Feature identifier"
          },
          "value": {
            "type": "number",
            "description": "Current feature value"
          },
          "type": {
            "type": "string",
            "description": "Feature type (e.g., switch, dimLevel, temperature)"
          }
        }
      },
      "FeatureSetRequest": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "number",
            "description": "Value to set for the feature"
          }
        }
      },
      "BatchFeatureSetRequest": {
        "type": "object",
        "required": ["features"],
        "properties": {
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["featureId", "value"],
              "properties": {
                "featureId": {
                  "type": "string"
                },
                "value": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "BatchFeatureResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FeatureValue"
            }
          }
        }
      },
      "EventListResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "description": "Event identifier"
          },
          "featureId": {
            "type": "string",
            "description": "Feature that triggered the event"
          },
          "value": {
            "type": "number",
            "description": "Feature value at time of event"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "OAuth2 bearer token for LightwaveRF API access"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}