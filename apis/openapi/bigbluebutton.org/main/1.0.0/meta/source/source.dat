{
  "openapi": "3.0.3",
  "info": {
    "title": "BigBlueButton API",
    "description": "REST API for BigBlueButton, an open-source web conferencing system for online learning, virtual meetings, and collaboration. All API calls require a checksum calculated from the call name, query string, and shared secret.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.bigbluebutton.org/"
  },
  "servers": [
    {
      "url": "https://{host}/bigbluebutton/api",
      "variables": {
        "host": {
          "default": "your-server.example.com",
          "description": "BigBlueButton server hostname"
        }
      }
    }
  ],
  "security": [
    {
      "checksumAuth": []
    }
  ],
  "tags": [
    { "name": "Administration", "description": "Meeting administration" },
    { "name": "Monitoring", "description": "Meeting monitoring" },
    { "name": "Recordings", "description": "Recording management" }
  ],
  "paths": {
    "/create": {
      "get": {
        "operationId": "createMeeting",
        "tags": ["Administration"],
        "summary": "Create a new meeting",
        "parameters": [
          { "name": "name", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Meeting name" },
          { "name": "meetingID", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Unique meeting ID" },
          { "name": "attendeePW", "in": "query", "schema": { "type": "string" }, "description": "Attendee password (deprecated)" },
          { "name": "moderatorPW", "in": "query", "schema": { "type": "string" }, "description": "Moderator password (deprecated)" },
          { "name": "welcome", "in": "query", "schema": { "type": "string" }, "description": "Welcome message" },
          { "name": "record", "in": "query", "schema": { "type": "boolean" }, "description": "Whether to record the meeting" },
          { "name": "duration", "in": "query", "schema": { "type": "integer" }, "description": "Max meeting duration in minutes (0 = unlimited)" },
          { "name": "voiceBridge", "in": "query", "schema": { "type": "string" } },
          { "name": "maxParticipants", "in": "query", "schema": { "type": "integer" } },
          { "name": "autoStartRecording", "in": "query", "schema": { "type": "boolean" } },
          { "name": "allowStartStopRecording", "in": "query", "schema": { "type": "boolean" } },
          { "name": "muteOnStart", "in": "query", "schema": { "type": "boolean" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" }, "description": "SHA checksum for authentication" }
        ],
        "responses": {
          "200": {
            "description": "Meeting created",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/CreateMeetingResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/join": {
      "get": {
        "operationId": "joinMeeting",
        "tags": ["Administration"],
        "summary": "Join an existing meeting",
        "parameters": [
          { "name": "meetingID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "fullName", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "password", "in": "query", "schema": { "type": "string" }, "description": "Deprecated - use role" },
          { "name": "role", "in": "query", "schema": { "type": "string", "enum": ["MODERATOR", "VIEWER"] } },
          { "name": "userID", "in": "query", "schema": { "type": "string" } },
          { "name": "createTime", "in": "query", "schema": { "type": "integer" } },
          { "name": "redirect", "in": "query", "schema": { "type": "boolean", "default": true } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Join response (XML if redirect=false)",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/JoinMeetingResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/end": {
      "get": {
        "operationId": "endMeeting",
        "tags": ["Administration"],
        "summary": "Forcibly end a meeting",
        "parameters": [
          { "name": "meetingID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "password", "in": "query", "schema": { "type": "string" }, "description": "Moderator password (deprecated)" },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Meeting ended",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/insertDocument": {
      "post": {
        "operationId": "insertDocument",
        "tags": ["Administration"],
        "summary": "Upload documents into a running meeting",
        "parameters": [
          { "name": "meetingID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string",
                "description": "XML containing document URLs or base64-encoded content"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Documents inserted",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/sendChatMessage": {
      "get": {
        "operationId": "sendChatMessage",
        "tags": ["Administration"],
        "summary": "Send a message to public meeting chat",
        "parameters": [
          { "name": "meetingID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "message", "in": "query", "required": true, "schema": { "type": "string", "maxLength": 500 } },
          { "name": "userName", "in": "query", "schema": { "type": "string" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Message sent",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/isMeetingRunning": {
      "get": {
        "operationId": "isMeetingRunning",
        "tags": ["Monitoring"],
        "summary": "Check if a meeting is currently running",
        "parameters": [
          { "name": "meetingID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Meeting running status",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/MeetingRunningResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/getMeetings": {
      "get": {
        "operationId": "getMeetings",
        "tags": ["Monitoring"],
        "summary": "List all running meetings on the server",
        "parameters": [
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of meetings",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/GetMeetingsResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/getMeetingInfo": {
      "get": {
        "operationId": "getMeetingInfo",
        "tags": ["Monitoring"],
        "summary": "Get detailed information about a specific meeting",
        "parameters": [
          { "name": "meetingID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Meeting details",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/MeetingInfo" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/getRecordings": {
      "get": {
        "operationId": "getRecordings",
        "tags": ["Recordings"],
        "summary": "Retrieve available recordings",
        "parameters": [
          { "name": "meetingID", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated meeting IDs" },
          { "name": "recordID", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated record IDs" },
          { "name": "state", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated states to filter" },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of recordings",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/GetRecordingsResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/publishRecordings": {
      "get": {
        "operationId": "publishRecordings",
        "tags": ["Recordings"],
        "summary": "Change publication status of recordings",
        "parameters": [
          { "name": "recordID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "publish", "in": "query", "required": true, "schema": { "type": "boolean" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Publication status updated",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/deleteRecordings": {
      "get": {
        "operationId": "deleteRecordings",
        "tags": ["Recordings"],
        "summary": "Permanently delete recordings",
        "parameters": [
          { "name": "recordID", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Comma-separated record IDs" },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Recordings deleted",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/updateRecordings": {
      "get": {
        "operationId": "updateRecordings",
        "tags": ["Recordings"],
        "summary": "Update recording metadata",
        "parameters": [
          { "name": "recordID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Recordings updated",
            "content": {
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/getRecordingTextTracks": {
      "get": {
        "operationId": "getRecordingTextTracks",
        "tags": ["Recordings"],
        "summary": "Retrieve caption/subtitle tracks for a recording",
        "parameters": [
          { "name": "recordID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Text tracks",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TextTracksResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    },
    "/putRecordingTextTrack": {
      "post": {
        "operationId": "putRecordingTextTrack",
        "tags": ["Recordings"],
        "summary": "Upload caption or subtitle files to a recording",
        "parameters": [
          { "name": "recordID", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "kind", "in": "query", "required": true, "schema": { "type": "string", "enum": ["subtitles", "captions"] } },
          { "name": "lang", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "label", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "checksum", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "string", "format": "binary", "description": "Subtitle file (SRT, SSA, ASS, or WebVTT)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text track uploaded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Checksum error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "checksumAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "checksum",
        "description": "SHA checksum calculated from API call name + query string + shared secret"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "returncode": { "type": "string", "enum": ["SUCCESS", "FAILED"] },
          "messageKey": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "CreateMeetingResponse": {
        "type": "object",
        "properties": {
          "returncode": { "type": "string" },
          "meetingID": { "type": "string" },
          "internalMeetingID": { "type": "string" },
          "attendeePW": { "type": "string" },
          "moderatorPW": { "type": "string" },
          "createTime": { "type": "integer" },
          "voiceBridge": { "type": "string" },
          "createDate": { "type": "string" },
          "hasBeenForciblyEnded": { "type": "boolean" },
          "messageKey": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "JoinMeetingResponse": {
        "type": "object",
        "properties": {
          "returncode": { "type": "string" },
          "meetingID": { "type": "string" },
          "userID": { "type": "string" },
          "authToken": { "type": "string" },
          "sessionToken": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      },
      "MeetingRunningResponse": {
        "type": "object",
        "properties": {
          "returncode": { "type": "string" },
          "running": { "type": "boolean" }
        }
      },
      "GetMeetingsResponse": {
        "type": "object",
        "properties": {
          "returncode": { "type": "string" },
          "meetings": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MeetingInfo" }
          }
        }
      },
      "MeetingInfo": {
        "type": "object",
        "properties": {
          "returncode": { "type": "string" },
          "meetingName": { "type": "string" },
          "meetingID": { "type": "string" },
          "internalMeetingID": { "type": "string" },
          "createTime": { "type": "integer" },
          "createDate": { "type": "string" },
          "voiceBridge": { "type": "string" },
          "running": { "type": "boolean" },
          "recording": { "type": "boolean" },
          "hasBeenForciblyEnded": { "type": "boolean" },
          "startTime": { "type": "integer" },
          "endTime": { "type": "integer" },
          "participantCount": { "type": "integer" },
          "moderatorCount": { "type": "integer" },
          "maxUsers": { "type": "integer" },
          "attendees": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Attendee" }
          },
          "metadata": { "type": "object" }
        }
      },
      "Attendee": {
        "type": "object",
        "properties": {
          "userID": { "type": "string" },
          "fullName": { "type": "string" },
          "role": { "type": "string" },
          "isPresenter": { "type": "boolean" },
          "isListeningOnly": { "type": "boolean" },
          "hasJoinedVoice": { "type": "boolean" },
          "hasVideo": { "type": "boolean" }
        }
      },
      "GetRecordingsResponse": {
        "type": "object",
        "properties": {
          "returncode": { "type": "string" },
          "recordings": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Recording" }
          }
        }
      },
      "Recording": {
        "type": "object",
        "properties": {
          "recordID": { "type": "string" },
          "meetingID": { "type": "string" },
          "name": { "type": "string" },
          "published": { "type": "boolean" },
          "state": { "type": "string" },
          "startTime": { "type": "integer" },
          "endTime": { "type": "integer" },
          "participants": { "type": "integer" },
          "playback": {
            "type": "object",
            "properties": {
              "format": {
                "type": "object",
                "properties": {
                  "type": { "type": "string" },
                  "url": { "type": "string", "format": "uri" },
                  "length": { "type": "integer" }
                }
              }
            }
          },
          "metadata": { "type": "object" }
        }
      },
      "TextTracksResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "returncode": { "type": "string" },
              "tracks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "href": { "type": "string", "format": "uri" },
                    "kind": { "type": "string" },
                    "lang": { "type": "string" },
                    "label": { "type": "string" },
                    "source": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}