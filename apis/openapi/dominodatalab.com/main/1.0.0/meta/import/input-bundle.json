  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Domino-Api-Key"
      }
    },
    "schemas": {
      "AiGatewayEndpoint": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "AiGatewayEndpointCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "config": {
            "type": "object"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "ownerId": {
            "type": "string"
          }
        }
      },
      "ProjectCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "CollaboratorAdd": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "JobCreate": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string"
          },
          "commandToRun": {
            "type": "string"
          }
        }
      },
      "ModelDeployment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ModelDeploymentCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "modelPath": {
            "type": "string"
          }
        }
      },
      "RegisteredModel": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "versions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
