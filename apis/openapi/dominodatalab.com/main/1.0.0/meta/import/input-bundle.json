{
  "openapi": "3.0.3",
  "info": {
    "title": "Domino Platform API",
    "version": "1.0.0",
    "description": "REST API for the Domino Data Lab platform. Manage projects, jobs, model deployments, environments, datasets, and more.",
    "x-jentic-source-url": "https://docs.dominodatalab.com/en/cloud/api_guide/8c929e/domino-platform-api-reference/"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "your-domino-instance.dominodatalab.com"
        }
      }
    }
  ],
  "paths": {
    "/aigateway/v1/audit": {
      "get": {
        "operationId": "getAiGatewayAudit",
        "summary": "Retrieve AI Gateway audit data",
        "tags": [
          "AIGateway"
        ],
        "responses": {
          "200": {
            "description": "Audit data retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/aigateway/v1/endpoints": {
      "get": {
        "operationId": "listAiGatewayEndpoints",
        "summary": "List active LLM endpoints",
        "tags": [
          "AIGateway"
        ],
        "responses": {
          "200": {
            "description": "List of endpoints",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AiGatewayEndpoint"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createAiGatewayEndpoint",
        "summary": "Create a new AI Gateway endpoint",
        "tags": [
          "AIGateway"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiGatewayEndpointCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Endpoint created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/aigateway/v1/endpoints/{endpointName}": {
      "patch": {
        "operationId": "updateAiGatewayEndpoint",
        "summary": "Update an AI Gateway endpoint",
        "tags": [
          "AIGateway"
        ],
        "parameters": [
          {
            "name": "endpointName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiGatewayEndpointCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Endpoint updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteAiGatewayEndpoint",
        "summary": "Delete an AI Gateway endpoint",
        "tags": [
          "AIGateway"
        ],
        "parameters": [
          {
            "name": "endpointName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Endpoint deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
