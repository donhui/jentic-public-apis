{
  "openapi": "3.0.3",
  "info": {
    "title": "Renault Car Configurator API",
    "description": "REST API for the Renault Car Configurator (C2GWeb). Provides access to vehicle model documentation, configurations, pricing, specifications, and presentation data using a Linked Data approach.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://doc.rplug.renault.com/car-configurator/documentation/api/index.html"
  },
  "servers": [
    {
      "url": "https://doc.rplug.renault.com/car-configurator",
      "description": "Renault Configurator API server"
    }
  ],
  "security": [],
  "tags": [
    { "name": "DocList", "description": "List commercial data of models" },
    { "name": "Documentation", "description": "Commercial data on a specific model" },
    { "name": "Configuration", "description": "Configuration resource for customer choices" },
    { "name": "Product", "description": "Product resource with stability over time" },
    { "name": "SpecificationCategories", "description": "Model specifications and their structure" },
    { "name": "Presentation", "description": "UI elements such as labels and groupings" },
    { "name": "PriceList", "description": "Detailed prices of versions and options" },
    { "name": "VersionCategory", "description": "Version structure and categories" }
  ],
  "paths": {
    "/docs": {
      "get": {
        "operationId": "listDocuments",
        "summary": "List available models",
        "description": "List commercial data of all models in the range. Works also as a service to select/filter models according to a pattern.",
        "tags": ["DocList"],
        "parameters": [
          {
            "name": "dlf-program",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided program code."
          },
          {
            "name": "dlf-phase",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided phase code."
          },
          {
            "name": "dlf-modelkind",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided model kind code."
          },
          {
            "name": "dlf-modelspeccode",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided model specification code."
          },
          {
            "name": "dlf-market",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided market code."
          },
          {
            "name": "dlf-brand",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided brand code."
          },
          {
            "name": "dlf-tariffnumber",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided tariff number."
          },
          {
            "name": "dlf-tariffadditivenumber",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided tariff additive number."
          },
          {
            "name": "dlf-commercialkind",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided commercial kind code."
          },
          {
            "name": "dlf-localsemiclair",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided local semiclair code."
          },
          {
            "name": "dlf-clientid",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided local clientId code."
          },
          {
            "name": "dlf-clienttype",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter docs whose id matches provided local clientType code."
          },
          {
            "name": "v",
            "in": "query",
            "schema": { "type": "integer", "enum": [1, 2], "default": 2 },
            "description": "Protocol version number. If not provided, latest version is used."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved document list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DocListResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid filter parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/range": {
      "get": {
        "operationId": "listPublicRange",
        "summary": "List models of public range",
        "description": "Alias for /docs that lists models of the public range.",
        "tags": ["DocList"],
        "parameters": [
          { "name": "v", "in": "query", "schema": { "type": "integer", "enum": [1, 2], "default": 2 }, "description": "Protocol version number." }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved public range",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DocListResponse" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/renaultrange": {
      "get": {
        "operationId": "listRenaultRange",
        "summary": "List Renault brand models",
        "description": "Alias for /docs that lists models of brand Renault.",
        "tags": ["DocList"],
        "parameters": [
          { "name": "v", "in": "query", "schema": { "type": "integer", "enum": [1, 2], "default": 2 }, "description": "Protocol version number." }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved Renault range",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DocListResponse" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/daciarange": {
      "get": {
        "operationId": "listDaciaRange",
        "summary": "List Dacia brand models",
        "description": "Alias for /docs that lists models of brand Dacia.",
        "tags": ["DocList"],
        "parameters": [
          { "name": "v", "in": "query", "schema": { "type": "integer", "enum": [1, 2], "default": 2 }, "description": "Protocol version number." }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved Dacia range",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DocListResponse" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/doc/{docId}": {
      "get": {
        "operationId": "getDocumentation",
        "summary": "Get model documentation",
        "description": "Provides commercial data on a model including marketing model information, configuration URI, presentation URI, prices, and version categories.",
        "tags": ["Documentation"],
        "parameters": [
          {
            "name": "docId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The documentation/model identifier."
          },
          {
            "name": "mtc",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Constrain this documentation with a MTC (Model Type Code)."
          },
          {
            "name": "scc",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Create a window frame on this documentation using specification categories."
          },
          {
            "name": "v",
            "in": "query",
            "schema": { "type": "integer", "enum": [1, 2], "default": 2 },
            "description": "Protocol version number."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved model documentation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MarketingModelResponse" }
              }
            }
          },
          "303": {
            "description": "Redirect to constrained documentation (when v=1 and mtc/scc is used)."
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/c/{configurationId}": {
      "get": {
        "operationId": "getConfiguration",
        "summary": "Get configuration",
        "description": "Provides representation for a configuration including customer choices, impossible specifications, and possible choices with links to corresponding configurations (Linked Data).",
        "tags": ["Configuration"],
        "parameters": [
          {
            "name": "configurationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The configuration identifier."
          },
          {
            "name": "mpf",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1], "default": 1 },
            "description": "If set to 1, provides the min price optimum of the configuration."
          },
          {
            "name": "mpf-i",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1], "default": 0 },
            "description": "If set to 1, provides min price optimums of following configurations."
          },
          {
            "name": "du",
            "in": "query",
            "schema": { "type": "integer", "enum": [-1, 0, 1, 2, 3], "default": 0 },
            "description": "Controls the list of impossible specifications and conflict diagnostic links."
          },
          {
            "name": "maxprice",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Makes a maxprice choice."
          },
          {
            "name": "complete",
            "in": "query",
            "schema": { "type": "string", "enum": ["minprice", "versionbase", "minpriceversion", "maxminpriceversion", "versionbase-fgp", "arbitrary"] },
            "description": "Complete the configuration according to a given strategy."
          },
          {
            "name": "proposedconfuri",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Replace the proposed configuration with the provided configuration."
          },
          {
            "name": "fmode",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1], "default": 1 },
            "description": "Friendly mode. 0 to deactivate, 1 to activate."
          },
          {
            "name": "sc-i",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Specification category codes to filter impacts."
          },
          {
            "name": "schoice",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Make choice of specifications identified by their spec codes."
          },
          {
            "name": "schoicemode",
            "in": "query",
            "schema": { "type": "string", "enum": ["include", "exclude", "remove"] },
            "description": "Mode for how provided specifications are used as choices."
          },
          {
            "name": "v",
            "in": "query",
            "schema": { "type": "integer", "enum": [1, 2], "default": 2 },
            "description": "Protocol version number."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved configuration",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConfigurationResponse" }
              }
            }
          },
          "303": {
            "description": "Redirect to new configuration URI (when v=1)."
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": {
            "description": "Configuration not found or incompatible specifications.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/product/{productId}": {
      "get": {
        "operationId": "getProduct",
        "summary": "Get product",
        "description": "Get a product resource. Much like a Configuration, but providing stability over time. A given product has a URI that remains valid through time.",
        "tags": ["Product"],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The product identifier."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved product",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProductResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/speccats/{docId}": {
      "get": {
        "operationId": "getSpecificationCategories",
        "summary": "Get specification categories",
        "description": "Provides all information on specification categories of a marketing model including the set of specifications available on a model.",
        "tags": ["SpecificationCategories"],
        "parameters": [
          {
            "name": "docId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The documentation/model identifier."
          },
          {
            "name": "v",
            "in": "query",
            "schema": { "type": "integer", "enum": [1, 2], "default": 2 },
            "description": "Protocol version number."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved specification categories",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpecificationCategoriesResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/pres/{docId}": {
      "get": {
        "operationId": "getPresentation",
        "summary": "Get presentation data",
        "description": "All elements needed to build a UI for a configurator. Each resource provides data for one model.",
        "tags": ["Presentation"],
        "parameters": [
          {
            "name": "docId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The documentation/model identifier."
          },
          {
            "name": "v",
            "in": "query",
            "schema": { "type": "integer", "enum": [1, 2], "default": 2 },
            "description": "Protocol version number."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved presentation data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PresentationResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/pricelist/{docId}": {
      "get": {
        "operationId": "getPriceList",
        "summary": "Get price list",
        "description": "Provides, for each version of a model, the price of the version and prices of specifications on the version.",
        "tags": ["PriceList"],
        "parameters": [
          {
            "name": "docId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The documentation/model identifier."
          },
          {
            "name": "plf-ref",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter price types by their reference."
          },
          {
            "name": "plf-cur",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter price types by their currency."
          },
          {
            "name": "v",
            "in": "query",
            "schema": { "type": "integer", "enum": [1, 2], "default": 2 },
            "description": "Protocol version number."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved price list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PriceListResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/category/{docId}": {
      "get": {
        "operationId": "getVersionCategories",
        "summary": "Get version categories",
        "description": "Provides, for each version, the categories of each specification according to the version.",
        "tags": ["VersionCategory"],
        "parameters": [
          {
            "name": "docId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The documentation/model identifier."
          },
          {
            "name": "vcf-versionid",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter results with provided versionId specification code."
          },
          {
            "name": "v",
            "in": "query",
            "schema": { "type": "integer", "enum": [1, 2], "default": 2 },
            "description": "Protocol version number."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved version categories",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VersionCategoriesResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message."
          }
        }
      },
      "DocListResponse": {
        "type": "object",
        "properties": {
          "docs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MinimalMarketingModelData" },
            "description": "List of marketing model documents."
          }
        }
      },
      "MinimalMarketingModelData": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Marketing model identifier." },
          "label": { "type": "string", "description": "Marketing model label." },
          "uri": { "type": "string", "description": "URI to the documentation resource." }
        }
      },
      "MarketingModelResponse": {
        "type": "object",
        "properties": {
          "marketingModel": {
            "$ref": "#/components/schemas/MarketingModel"
          }
        }
      },
      "MarketingModel": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Marketing model ID." },
          "label": { "type": "string", "description": "Model label." },
          "configurationUri": { "type": "string", "description": "URI to the first configuration." },
          "presentationUri": { "type": "string", "description": "URI of presentation info." },
          "priceTypes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PriceType" },
            "description": "Supported price types."
          },
          "versionCategoryUri": { "type": "string", "description": "URI of version category info." }
        }
      },
      "PriceType": {
        "type": "object",
        "properties": {
          "reference": { "type": "string" },
          "currency": { "type": "string" },
          "label": { "type": "string" }
        }
      },
      "ConfigurationResponse": {
        "type": "object",
        "properties": {
          "configuration": {
            "$ref": "#/components/schemas/Configuration"
          }
        }
      },
      "Configuration": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Configuration identifier." },
          "uri": { "type": "string", "description": "Configuration URI." },
          "choices": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SpecChoice" },
            "description": "Customer choices."
          },
          "impossibleSpecs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ImpossibleSpec" },
            "description": "Impossible specifications according to choices."
          },
          "possibleSpecs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PossibleSpec" },
            "description": "Still possible choices with links to corresponding configurations."
          },
          "price": { "$ref": "#/components/schemas/Price" },
          "productUri": { "type": "string", "description": "URI to corresponding product resource." }
        }
      },
      "SpecChoice": {
        "type": "object",
        "properties": {
          "specCode": { "type": "string", "description": "Specification code." },
          "specLabel": { "type": "string", "description": "Specification label." },
          "specCategoryCode": { "type": "string", "description": "Specification category code." }
        }
      },
      "ImpossibleSpec": {
        "type": "object",
        "properties": {
          "specCode": { "type": "string" },
          "specLabel": { "type": "string" },
          "diagUri": { "type": "string", "description": "URI to conflict diagnostic." }
        }
      },
      "PossibleSpec": {
        "type": "object",
        "properties": {
          "specCode": { "type": "string" },
          "specLabel": { "type": "string" },
          "configurationUri": { "type": "string", "description": "URI to resulting configuration if this spec is chosen." },
          "impact": { "$ref": "#/components/schemas/Impact" }
        }
      },
      "Impact": {
        "type": "object",
        "properties": {
          "priceImpact": { "type": "number", "description": "Price impact of selecting this specification." }
        }
      },
      "Price": {
        "type": "object",
        "properties": {
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "reference": { "type": "string" }
        }
      },
      "ProductResponse": {
        "type": "object",
        "properties": {
          "product": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Product identifier." },
              "uri": { "type": "string", "description": "Product URI (stable over time)." },
              "configurationUri": { "type": "string", "description": "URI to the current configuration." },
              "specs": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/SpecChoice" }
              }
            }
          }
        }
      },
      "SpecificationCategoriesResponse": {
        "type": "object",
        "properties": {
          "specificationCategories": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SpecificationCategory" },
            "description": "List of specification categories."
          }
        }
      },
      "SpecificationCategory": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "description": "Category code." },
          "label": { "type": "string", "description": "Category label." },
          "specs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "specCode": { "type": "string" },
                "specLabel": { "type": "string" }
              }
            }
          }
        }
      },
      "PresentationResponse": {
        "type": "object",
        "properties": {
          "marketingModelPresentation": {
            "type": "object",
            "properties": {
              "groups": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/PresentationGroup" }
              }
            }
          }
        }
      },
      "PresentationGroup": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "label": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PresentationItem" }
          }
        }
      },
      "PresentationItem": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "PriceListResponse": {
        "type": "object",
        "properties": {
          "pricesList": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/VersionPriceEntry" },
