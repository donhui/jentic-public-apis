{
  "openapi": "3.0.3",
  "info": {
    "title": "Ghost Content API",
    "version": "5.0.0",
    "description": "Read-only API for accessing published content on a Ghost site. Provides access to posts, pages, authors, tags, tiers, and site settings.",
    "x-jentic-source-url": "https://ghost.org/docs/content-api/"
  },
  "servers": [
    {
      "url": "https://{domain}/ghost/api/content",
      "variables": {
        "domain": {
          "default": "example.ghost.io",
          "description": "Your Ghost site domain"
        }
      }
    }
  ],
