            "type": "string"
          },
          "access_token": {
            "type": "string"
          },
          "device_id": {
            "type": "string"
          },
          "home_server": {
            "type": "string"
          }
        }
      },
      "DirectoryRoomResponse": {
        "type": "object",
        "properties": {
          "room_id": {
            "type": "string"
          },
          "servers": {
            "type": "array",
            "items": {
