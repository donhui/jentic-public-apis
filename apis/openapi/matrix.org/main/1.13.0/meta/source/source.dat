            "type": "string"
          },
          "prev_batch": {
            "type": "string"
          },
          "total_room_count_estimate": {
            "type": "integer"
          }
        }
      },
      "PublicRoomsChunk": {
        "type": "object",
        "properties": {
          "room_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "topic": {
            "type": "string"
          },
          "num_joined_members": {
            "type": "integer"
          },
          "world_readable": {
            "type": "boolean"
          },
          "guest_can_join": {
            "type": "boolean"
          },
          "avatar_url": {
            "type": "string"
          },
          "canonical_alias": {
            "type": "string"
          }
        }
      },
      "MessagesResponse": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string"
          },
          "end": {
            "type": "string"
          },
          "chunk": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatrixEvent"
            }
          },
          "state": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatrixEvent"
            }
          }
        }
      },
      "EventSendResponse": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "displayname": {
            "type": "string"
          },
          "avatar_url": {
            "type": "string"
          }
        }
      },
      "PresenceEvent": {
        "type": "object",
        "properties": {
          "presence": {
            "type": "string",
            "enum": [
              "online",
              "offline",
              "unavailable"
            ]
          },
          "last_active_ago": {
            "type": "integer"
          },
          "status_msg": {
            "type": "string"
          },
          "currently_active": {
            "type": "boolean"
          }
        }
      },
      "Filter": {
        "type": "object",
        "properties": {
          "event_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "event_format": {
            "type": "string",
            "enum": [
              "client",
              "federation"
            ]
          },
          "presence": {
            "type": "object"
          },
          "account_data": {
            "type": "object"
          },
          "room": {
            "type": "object"
          }
        }
      },
      "FilterResponse": {
        "type": "object",
        "properties": {
          "filter_id": {
            "type": "string"
          }
        }
      },
      "RegistrationResponse": {
        "type": "object",
        "properties": {
