{
  "openapi": "3.0.3",
  "info": {
    "title": "Piwik PRO Analytics API",
    "version": "1.0.0",
    "description": "Piwik PRO Analytics API provides programmatic access to query analytics data, sessions, events, real-time data, and manage goals. Authentication uses OAuth2 client credentials.",
    "x-jentic-source-url": "https://developers.piwik.pro"
  },
  "servers": [
    {
      "url": "https://{account}.piwik.pro",
      "description": "Piwik PRO account-specific server",
      "variables": {
        "account": {
          "description": "Your Piwik PRO account name",
          "default": "your-account"
        }
      }
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/auth/token": {
      "post": {
        "operationId": "createAccessToken",
        "summary": "Create access token",
        "description": "Generate an access token using client credentials OAuth grant type for API authentication. Token is valid for 30 minutes.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/analytics/v1/query/": {
      "post": {
        "operationId": "executeAnalyticsQuery",
        "summary": "Execute analytics query",
        "description": "Query the database directly with filters, dimensions, and metrics. Results are cached for 10 minutes. Supports gzip compression.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyticsQueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsQueryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/analytics/v1/real-time-query/": {
      "post": {
        "operationId": "executeRealTimeQuery",
        "summary": "Execute real-time query",
        "description": "Query real-time database with a lookback window in minutes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RealTimeQueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Real-time query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsQueryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/analytics/v1/sessions/": {
      "post": {
        "operationId": "fetchSessions",
        "summary": "Fetch sessions",
        "description": "Fetch raw sessions from the database with filtering and pagination.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sessions data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsQueryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/analytics/v1/events/": {
      "post": {
        "operationId": "fetchEvents",
        "summary": "Fetch events",
        "description": "Retrieve raw event-level data from the database.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Events data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsQueryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/analytics/v1/real-time-events/": {
      "post": {
        "operationId": "fetchRealTimeEvents",
        "summary": "Fetch real-time events",
        "description": "Access real-time event data. Data retained for 1 hour with typical 2-minute delay.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RealTimeEventsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Real-time events data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsQueryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/analytics/v1/manage/goals/": {
      "post": {
        "operationId": "createGoal",
        "summary": "Create a goal",
        "description": "Create a new conversion goal with trigger conditions.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Goal created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Goal"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "/auth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "TokenRequest": {
        "type": "object",
        "required": ["grant_type", "client_id", "client_secret"],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": ["client_credentials"]
          },
          "client_id": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "example": 1800
          },
          "access_token": {
            "type": "string"
          }
        }
      },
      "AnalyticsQueryRequest": {
        "type": "object",
        "required": ["website_id", "columns", "date_from", "date_to"],
        "properties": {
          "website_id": {
            "type": "string",
            "format": "uuid",
            "description": "Website/app ID"
          },
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Column"
            },
            "description": "List of dimensions and metrics"
          },
          "date_from": {
            "type": "string",
            "format": "date",
            "description": "Start date"
          },
          "date_to": {
            "type": "string",
            "format": "date",
            "description": "End date"
          },
          "filters": {
            "type": "object",
            "description": "Filter conditions"
          },
          "metric_filters": {
            "type": "object",
            "description": "Metric-based filters"
          },
          "offset": {
            "type": "integer",
            "default": 0
          },
          "limit": {
            "type": "integer",
            "default": 100
          },
          "order_by": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "format": {
            "type": "string",
            "description": "Response format options"
          }
        }
      },
      "RealTimeQueryRequest": {
        "type": "object",
        "required": ["website_id", "columns", "lookback_window"],
        "properties": {
          "website_id": {
            "type": "string",
            "format": "uuid"
          },
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Column"
            }
          },
          "lookback_window": {
            "type": "integer",
            "description": "Lookback window in minutes"
          },
          "filters": {
            "type": "object"
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "SessionsRequest": {
        "type": "object",
        "required": ["website_id", "columns", "date_from", "date_to"],
        "properties": {
          "website_id": {
            "type": "string",
            "format": "uuid"
          },
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Column"
            }
          },
          "date_from": {
            "type": "string",
            "format": "date"
          },
          "date_to": {
            "type": "string",
            "format": "date"
          },
          "filters": {
            "type": "object"
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "format": {
            "type": "string"
          }
        }
      },
      "RealTimeEventsRequest": {
        "type": "object",
        "required": ["website_id", "columns"],
        "properties": {
          "website_id": {
            "type": "string",
            "format": "uuid"
          },
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Column"
            }
          },
          "datetime_from": {
            "type": "string",
            "format": "date-time"
          },
          "datetime_to": {
            "type": "string",
            "format": "date-time"
          },
          "filters": {
            "type": "object"
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "Column": {
        "type": "object",
        "properties": {
          "column_id": {
            "type": "string",
            "description": "Column/dimension/metric identifier"
          },
          "transformation_id": {
            "type": "string",
            "description": "Optional transformation to apply"
          }
        }
      },
      "AnalyticsQueryResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer"
              }
            }
          }
        }
      },
      "GoalRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "trigger_type": {
            "type": "string"
          },
          "pattern": {
            "type": "string"
          },
          "revenue": {
            "type": "number"
          }
        }
      },
      "Goal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "trigger_type": {
            "type": "string"
          },
          "pattern": {
            "type": "string"
          },
          "revenue": {
            "type": "number"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or expired token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  }
}