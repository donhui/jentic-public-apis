{
  "openapi": "3.0.3",
  "info": {
    "title": "Ignition Gateway API",
    "description": "Ignition Gateway REST API for managing configuration resources. Provides endpoints to list, create, and delete configuration resources within the Ignition platform.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.docs.inductiveautomation.com/docs/8.3/platform/gateway/openapi"
  },
  "servers": [
    {
      "url": "https://{gatewayHost}:{port}",
      "description": "Ignition Gateway server",
      "variables": {
        "gatewayHost": {
          "default": "localhost",
          "description": "Gateway hostname"
        },
        "port": {
          "default": "8088",
          "description": "Gateway port"
        }
      }
    }
  ],
  "paths": {
    "/openapi": {
      "get": {
        "operationId": "getApiDocumentation",
        "summary": "Get interactive API documentation",
        "description": "A browser-based UI for exploring all available endpoints.",
        "tags": [
          "OpenAPI"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Interactive API documentation page",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "operationId": "getApiSpec",
        "summary": "Get raw API specification",
        "description": "A machine-readable OpenAPI specification document used for importing into tools or generating client SDKs.",
        "tags": [
          "OpenAPI"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "OpenAPI specification in JSON format",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/data/api/v1/resources/list/{moduleId}/{typeId}": {
      "get": {
        "operationId": "listConfigurationResources",
        "summary": "List configuration resources",
        "description": "Lists all resources of a given configuration type within a module.",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "moduleId",
            "in": "path",
            "required": true,
            "description": "Module identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "typeId",
            "in": "path",
            "required": true,
            "description": "Configuration type identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of resources",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/data/api/v1/resources/{moduleId}/{typeId}": {
      "post": {
        "operationId": "createConfigurationResource",
        "summary": "Create a configuration resource",
        "description": "Creates a new configuration resource within a module.",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "moduleId",
            "in": "path",
            "required": true,
            "description": "Module identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "typeId",
            "in": "path",
            "required": true,
            "description": "Configuration type identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateResourceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resource created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/data/api/v1/resources/{moduleId}/{typeId}/{name}/{signature}": {
      "delete": {
        "operationId": "deleteConfigurationResource",
        "summary": "Delete a configuration resource",
        "description": "Deletes a specific named resource identified by its module, type, name, and signature.",
        "tags": [
          "Resources"
        ],
        "parameters": [
          {
            "name": "moduleId",
            "in": "path",
            "required": true,
            "description": "Module identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "typeId",
            "in": "path",
            "required": true,
            "description": "Configuration type identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Resource name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "signature",
            "in": "path",
            "required": true,
            "description": "Resource signature",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resource deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Ignition-API-Token",
        "description": "Ignition API token for authentication"
      }
    },
    "schemas": {
      "Resource": {
        "type": "object",
        "properties": {
          "moduleId": {
            "type": "string"
          },
          "typeId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "signature": {
            "type": "string"
          }
        }
      },
      "ResourceListResponse": {
        "type": "object",
        "properties": {
          "resources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Resource"
            }
          }
        }
      },
      "CreateResourceRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Resource name"
          },
          "data": {
            "type": "object",
            "description": "Resource configuration data"
          }
        }
      },
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiToken": []
    }
  ],
  "tags": [
    {
      "name": "OpenAPI",
      "description": "API documentation endpoints"
    },
    {
      "name": "Resources",
      "description": "Configuration resource management"
    }
  ]
}