    "/v1/projects": {
      "get": {
        "tags": [
          "Projects"
        ],
        "summary": "Search for projects",
        "description": "Explore projects exploiting various filter parameters",
        "operationId": "search_2",
        "parameters": [
          {
            "name": "logicalOperator",
            "in": "query",
            "description": "Logical operator used to combine field-level queries. Default value: *AND* </br>\nUse it when specifying multiple fields in the search. </br>\n*example: (mainTitle=geography) AND (description=19th century)*\n",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "AND",
                "OR",
                "NOT"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Keyword-based search. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "title",
            "in": "query",
            "description": "Search in the project's title. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keywords",
            "in": "query",
            "description": "The project's keywords. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "query",
            "description": "The OpenAIRE id of the project. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "code",
            "in": "query",
            "description": "The grant agreement (GA) code of the project. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "acronym",
            "in": "query",
            "description": "Project's acronym. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "callIdentifier",
            "in": "query",
            "description": "The identifier of the research call. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "fundingShortName",
            "in": "query",
            "description": "The short name of the funder. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "fundingStreamId",
            "in": "query",
            "description": "The identifier of the funding stream. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "fromStartDate",
            "in": "query",
            "description": "Gets the projects with start date greater than or equal to the given date. Provide a date in YYYY or YYYY-MM-DD format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toStartDate",
            "in": "query",
            "description": "Gets the projects with start date less than or equal to the given date. Provide a date in YYYY or YYYY-MM-DD format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromEndDate",
            "in": "query",
            "description": "Gets the projects with end date greater than or equal to the given date. Provide a date in YYYY or YYYY-MM-DD format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toEndDate",
            "in": "query",
            "description": "Gets the projects with end date less than or equal to the given date. Provide a date in YYYY or YYYY-MM-DD format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "relOrganizationName",
            "in": "query",
            "description": "The name or short name of the related organization. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relOrganizationId",
            "in": "query",
            "description": "The organization identifier of the related organization. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relCommunityId",
            "in": "query",
            "description": "Retrieve projects connected to the community (with OpenAIRE id). Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relOrganizationCountryCode",
            "in": "query",
            "description": "The country code of the related organizations. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relCollectedFromDatasourceId",
            "in": "query",
            "description": "Retrieve projects collected from the data source (with OpenAIRE id). Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number of the results, \nused for basic start/rows pagination. \nMax dataset to retrieve - 10000 records. \nTo get more than that, use cursor-based pagination.",
            "required": false,
            "schema": {
              "minimum": 1,
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of results per page",
            "required": false,
            "schema": {
              "maximum": 100,
              "minimum": 1,
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor-based pagination. Initial value: `cursor=*`. \nCursor should be used when it is required to retrieve a big dataset (more than 10000 records). \nTo get the next page of results, use nextCursor returned in the response.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "The field to sort the results by and the sort direction. The format should be in the format `fieldname ASC|DESC`, where fieldname is one of 'relevance', 'startDate', 'endDate'. Multiple sorting parameters should be comma-separated.",
            "required": false,
            "schema": {
              "pattern": "^((relevance|startDate|endDate)\\s+(ASC|DESC),?\\s*)+$",
              "type": "string",
              "default": "relevance DESC"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
