{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenAIRE Graph API",
    "description": "The Graph API allows developers to access metadata records of the OpenAIRE Graph by performing queries over its entities, i.e., research products (publications, data, software, other research products), projects, data sources, and organizations. <ul><li><a href=\"https://api.openaire.eu/graph/swagger-ui/index.html?urls.primaryName=OpenAIRE%20Graph%20API%20V1\">version 1.0</a></li><li><a href=\"https://api.openaire.eu/graph/swagger-ui/index.html?urls.primaryName=OpenAIRE%20Graph%20API%20V2\">version 2.0</a></li></ul><p>For more information, please visit the <a target=\"blank\" href=\"https://graph.openaire.eu/docs/apis/graph-api\">Graph API documentation</a></p>",
    "termsOfService": "https://graph.openaire.eu/docs/apis/terms",
    "contact": {
      "name": "Contact us",
      "url": "https://graph.openaire.eu/helpdesk"
    },
    "license": {
      "name": "License",
      "url": "https://graph.openaire.eu/docs/license"
    },
    "x-jentic-source-url": "https://graph.openaire.eu/docs/apis/home/",
    "version": "2.0"
  },
  "servers": [
    {
      "url": "https://api.openaire.eu/graph",
      "description": "Server base URL"
    }
  ],
  "tags": [
    {
      "name": "Organizations",
      "description": "API endpoints to explore organizations"
    },
    {
      "name": "Data sources",
      "description": "API endpoints to explore data sources"
    },
    {
      "name": "Research products",
      "description": "API endpoints to explore research products"
    },
    {
      "name": "Projects",
      "description": "API endpoints to explore projects"
    },
    {
      "name": "Products",
      "description": "API endpoints to explore <strong>Product</strong> entity."
    },
    {
      "name": "Persons",
      "description": "API endpoints to explore persons"
    },
    {
      "name": "Publications",
      "description": "API endpoints to explore publications"
    }
  ],
  "paths": {
    "/v2/researchProducts": {
      "get": {
        "tags": [
          "Research products"
        ],
        "summary": "Search for research products",
        "description": "Explore research products exploiting various filter parameters",
        "operationId": "search",
        "parameters": [
          {
            "name": "logicalOperator",
            "in": "query",
            "description": "Logical operator used to combine field-level queries. Default value: *AND* </br>\nUse it when specifying multiple fields in the search. </br>\n*example: (mainTitle=geography) AND (description=19th century)*\n",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "AND",
                "OR",
                "NOT"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Keyword-based search. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mainTitle",
            "in": "query",
            "description": "Search in the research product's main title. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "description",
            "in": "query",
            "description": "Search in the research product's description. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "query",
            "description": "The OpenAIRE id of the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "pid",
            "in": "query",
            "description": "The persistent identifier of the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "originalId",
            "in": "query",
            "description": "The identifier of the record at the original sources. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "rorId",
            "in": "query",
            "description": "Research Organization Registry Identifier (ROR). Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "The type of the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "publication",
                  "dataset",
                  "software",
                  "other"
                ]
              }
            }
          },
          {
            "name": "fromPublicationDate",
            "in": "query",
            "description": "Gets the research products whose publication date is greater than or equal to he given date. Provide a date in YYYY or YYYY-MM-DD format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toPublicationDate",
            "in": "query",
            "description": "Gets the research products whose publication date is less than or equal to the given date. Provide a date in YYYY or YYYY-MM-DD format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subjects",
            "in": "query",
            "description": "List of subjects associated to the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "countryCode",
            "in": "query",
            "description": "The country code for the country associated with the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "authorFullName",
            "in": "query",
            "description": "The full name of the authors involved in producing this research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "authorOrcid",
            "in": "query",
            "description": "The ORCiD of the authors involved in producing this research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "publisher",
            "in": "query",
            "description": "The name of the entity that holds, archives, publishes prints, distributes, releases, issues, or produces the resource. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "bestOpenAccessRightLabel",
            "in": "query",
            "description": "The best open access rights among the research product's instances. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "OPEN SOURCE",
                  "OPEN",
                  "EMBARGO",
                  "RESTRICTED",
                  "CLOSED",
                  "UNKNOWN"
                ]
              }
            }
          },
          {
            "name": "influenceClass",
            "in": "query",
            "description": "Citation-based indicator that reflects the overall impact of a research product; please choose a class among 'C1', 'C2', 'C3', 'C4', 'C5' for  top 0.01%, top 0.1%, top 1%, top 10%, and average in terms of influence respectively. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "C1",
                  "C2",
                  "C3",
                  "C4",
                  "C5"
                ]
              }
            }
          },
          {
            "name": "popularityClass",
            "in": "query",
            "description": "Citation-based indicator that reflects current impact or attention of a research product; please choose a class among 'C1', 'C2', 'C3', 'C4', 'C5' for  top 0.01%, top 0.1%, top 1%, top 10%, and average in terms of popularity respectively. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "C1",
                  "C2",
                  "C3",
                  "C4",
                  "C5"
                ]
              }
            }
          },
          {
            "name": "impulseClass",
            "in": "query",
            "description": "Citation-based indicator that reflects the initial momentum of a research product directly after its publication; please choose a class among 'C1', 'C2', 'C3', 'C4', 'C5' for  top 0.01%, top 0.1%, top 1%, top 10%, and in terms of average impulse respectively. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "C1",
                  "C2",
                  "C3",
                  "C4",
                  "C5"
                ]
              }
            }
          },
          {
            "name": "citationCountClass",
            "in": "query",
            "description": "Citation-based indicator that reflects the overall impact of a research product by summing all its citations; please choose a class among 'C1', 'C2', 'C3', 'C4', 'C5' for  top 0.01%, top 0.1%, top 1%, top 10%, and average in terms of citation count respectively. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "C1",
                  "C2",
                  "C3",
                  "C4",
                  "C5"
                ]
              }
            }
          },
          {
            "name": "instanceType",
            "in": "query",
            "description": "Retrieve publications of the given instance type; check <a href='http://api.openaire.eu/vocabularies/dnet:publication_resource' target='_blank'>here</a> for all possible instance type values `[Only for publications]`. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "sdg",
            "in": "query",
            "description": "Retrieves publications classified with the respective Sustainable Development Goal number (for further information check <a href='https://sdgs.un.org/goals' target='_blank'>here</a>); please provide an SDG number between 1 and 17 `[Only for publications]`. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "maximum": 17,
                "minimum": 1,
                "type": "integer"
              }
            }
          },
          {
            "name": "fos",
            "in": "query",
            "description": "Retrieves publications classified with a given Field of Science (FOS); please provide a valid <a href='https://explore.openaire.eu/assets/common-assets/vocabulary/fos.json' target='_blank'>FOS classification identifier</a>  `[Only for publications]`. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "isPeerReviewed",
            "in": "query",
            "description": "Indicates whether the publications are peerReviewed or not `[Only for publications]`",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "isInDiamondJournal",
            "in": "query",
            "description": "Indicates whether the publication was published in a diamond journal or not `[Only for publications]`",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "isPubliclyFunded",
            "in": "query",
            "description": "Indicates whether the publication was publicly funded or not `[Only for publications]`",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "isGreen",
            "in": "query",
            "description": "Indicates whether the publication was published following the green open access model `[Only for publications]`",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "openAccessColor",
            "in": "query",
            "description": "Specifies the Open Access color of the publication `[Only for publications]`. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "bronze",
                  "gold",
                  "hybrid"
                ]
              }
            }
          },
          {
            "name": "relOrganizationId",
            "in": "query",
            "description": "Retrieve research products connected to the organization (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relCommunityId",
            "in": "query",
            "description": "Retrieve research products connected to the community (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relProjectId",
            "in": "query",
            "description": "Retrieve research products connected to the project (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relProjectCode",
            "in": "query",
            "description": "Retrieve research products connected to the project with code. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "hasProjectRel",
            "in": "query",
            "description": "Retrieve research products that are connected to a project",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "relProjectFundingShortName",
            "in": "query",
            "description": "Retrieve research products connected to a project that has a funder with the given short name. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relProjectFundingStreamId",
            "in": "query",
            "description": "Retrieve research products connected to a project that has the given funding identifier. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relHostingDataSourceId",
            "in": "query",
            "description": "Retrieve research products hosted by the data source (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relCollectedFromDatasourceId",
            "in": "query",
            "description": "Retrieve research products collected from the data source (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number of the results, \nused for basic start/rows pagination. \nMax dataset to retrieve - 10000 records. \nTo get more than that, use cursor-based pagination.",
            "required": false,
            "schema": {
              "minimum": 1,
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of results per page",
            "required": false,
            "schema": {
              "maximum": 100,
              "minimum": 1,
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor-based pagination. Initial value: `cursor=*`. \nCursor should be used when it is required to retrieve a big dataset (more than 10000 records). \nTo get the next page of results, use nextCursor returned in the response.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "The field to sort the results by and the sort direction. The format should be in the format `fieldname ASC|DESC`, where fieldname is one of 'relevance', 'publicationDate', 'dateOfCollection', 'influence', 'popularity', 'citationCount', 'impulse'. Multiple sorting parameters should be comma-separated.",
            "required": false,
            "schema": {
              "pattern": "^((relevance|publicationDate|dateOfCollection|influence|popularity|citationCount|impulse)\\s+(ASC|DESC),?\\s*)+$",
              "type": "string",
              "default": "relevance DESC"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResearchProductsSearchResponseV2"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/researchProducts/{id}": {
      "get": {
        "tags": [
          "Research products"
        ],
        "summary": "Retrieve a research product by id",
        "description": "Get a research product object by specifying its id.",
        "operationId": "getById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The OpenAIRE id of the research product",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResult"
                }
              }
            }
          }
        }
      }
    },
    "/v1/researchProducts": {
      "get": {
        "tags": [
          "Research products"
        ],
        "summary": "Search for research products",
        "description": "Deprecated: Use <a href=\"https://api.openaire.eu/graph/swagger-ui/index.html?urls.primaryName=OpenAIRE%20Graph%20API%20V2\">version 2.0</a> instead.\nThis version is no longer supported and will be removed in the future.",
        "operationId": "search_1",
        "parameters": [
          {
            "name": "logicalOperator",
            "in": "query",
            "description": "Logical operator used to combine field-level queries. Default value: *AND* </br>\nUse it when specifying multiple fields in the search. </br>\n*example: (mainTitle=geography) AND (description=19th century)*\n",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "AND",
                "OR",
                "NOT"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Keyword-based search. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mainTitle",
            "in": "query",
            "description": "Search in the research product's main title. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "description",
            "in": "query",
            "description": "Search in the research product's description. </br>Supports logical operators: AND, OR, NOT </br>\nLogical operators must be in UPPERCASE (AND, OR, NOT). Lowercase operators (and, or, not) are treated as ***search terms***, not as operators. </br>\nUse parentheses `()` to group conditions and control evaluation order. </br>\n*example: ((geography OR physics) AND (applied mathematics)) OR (literature and arts)*\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "query",
            "description": "The OpenAIRE id of the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "pid",
            "in": "query",
            "description": "The persistent identifier of the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "originalId",
            "in": "query",
            "description": "The identifier of the record at the original sources. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "rorId",
            "in": "query",
            "description": "Research Organization Registry Identifier (ROR). Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "The type of the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "publication",
                  "dataset",
                  "software",
                  "other"
                ]
              }
            }
          },
          {
            "name": "fromPublicationDate",
            "in": "query",
            "description": "Gets the research products whose publication date is greater than or equal to he given date. Provide a date in YYYY or YYYY-MM-DD format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toPublicationDate",
            "in": "query",
            "description": "Gets the research products whose publication date is less than or equal to the given date. Provide a date in YYYY or YYYY-MM-DD format",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subjects",
            "in": "query",
            "description": "List of subjects associated to the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "countryCode",
            "in": "query",
            "description": "The country code for the country associated with the research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "authorFullName",
            "in": "query",
            "description": "The full name of the authors involved in producing this research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "authorOrcid",
            "in": "query",
            "description": "The ORCiD of the authors involved in producing this research product. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "publisher",
            "in": "query",
            "description": "The name of the entity that holds, archives, publishes prints, distributes, releases, issues, or produces the resource. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "bestOpenAccessRightLabel",
            "in": "query",
            "description": "The best open access rights among the research product's instances. Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "OPEN SOURCE",
                  "OPEN",
                  "EMBARGO",
                  "RESTRICTED",
                  "CLOSED",
                  "UNKNOWN"
                ]
              }
            }
          },
          {
            "name": "influenceClass",
            "in": "query",
            "description": "Citation-based indicator that reflects the overall impact of a research product; please choose a class among 'C1', 'C2', 'C3', 'C4', 'C5' for  top 0.01%, top 0.1%, top 1%, top 10%, and average in terms of influence respectively. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "C1",
                  "C2",
                  "C3",
                  "C4",
                  "C5"
                ]
              }
            }
          },
          {
            "name": "popularityClass",
            "in": "query",
            "description": "Citation-based indicator that reflects current impact or attention of a research product; please choose a class among 'C1', 'C2', 'C3', 'C4', 'C5' for  top 0.01%, top 0.1%, top 1%, top 10%, and average in terms of popularity respectively. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "C1",
                  "C2",
                  "C3",
                  "C4",
                  "C5"
                ]
              }
            }
          },
          {
            "name": "impulseClass",
            "in": "query",
            "description": "Citation-based indicator that reflects the initial momentum of a research product directly after its publication; please choose a class among 'C1', 'C2', 'C3', 'C4', 'C5' for  top 0.01%, top 0.1%, top 1%, top 10%, and in terms of average impulse respectively. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "C1",
                  "C2",
                  "C3",
                  "C4",
                  "C5"
                ]
              }
            }
          },
          {
            "name": "citationCountClass",
            "in": "query",
            "description": "Citation-based indicator that reflects the overall impact of a research product by summing all its citations; please choose a class among 'C1', 'C2', 'C3', 'C4', 'C5' for  top 0.01%, top 0.1%, top 1%, top 10%, and average in terms of citation count respectively. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "C1",
                  "C2",
                  "C3",
                  "C4",
                  "C5"
                ]
              }
            }
          },
          {
            "name": "instanceType",
            "in": "query",
            "description": "Retrieve publications of the given instance type; check <a href='http://api.openaire.eu/vocabularies/dnet:publication_resource' target='_blank'>here</a> for all possible instance type values `[Only for publications]`. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "sdg",
            "in": "query",
            "description": "Retrieves publications classified with the respective Sustainable Development Goal number (for further information check <a href='https://sdgs.un.org/goals' target='_blank'>here</a>); please provide an SDG number between 1 and 17 `[Only for publications]`. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "maximum": 17,
                "minimum": 1,
                "type": "integer"
              }
            }
          },
          {
            "name": "fos",
            "in": "query",
            "description": "Retrieves publications classified with a given Field of Science (FOS); please provide a valid <a href='https://explore.openaire.eu/assets/common-assets/vocabulary/fos.json' target='_blank'>FOS classification identifier</a>  `[Only for publications]`. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "isPeerReviewed",
            "in": "query",
            "description": "Indicates whether the publications are peerReviewed or not `[Only for publications]`",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "isInDiamondJournal",
            "in": "query",
            "description": "Indicates whether the publication was published in a diamond journal or not `[Only for publications]`",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "isPubliclyFunded",
            "in": "query",
            "description": "Indicates whether the publication was publicly funded or not `[Only for publications]`",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "isGreen",
            "in": "query",
            "description": "Indicates whether the publication was published following the green open access model `[Only for publications]`",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "openAccessColor",
            "in": "query",
            "description": "Specifies the Open Access color of the publication `[Only for publications]`. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "bronze",
                  "gold",
                  "hybrid"
                ]
              }
            }
          },
          {
            "name": "relOrganizationId",
            "in": "query",
            "description": "Retrieve research products connected to the organization (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relCommunityId",
            "in": "query",
            "description": "Retrieve research products connected to the community (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relProjectId",
            "in": "query",
            "description": "Retrieve research products connected to the project (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relProjectCode",
            "in": "query",
            "description": "Retrieve research products connected to the project with code. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "hasProjectRel",
            "in": "query",
            "description": "Retrieve research products that are connected to a project",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "relProjectFundingShortName",
            "in": "query",
            "description": "Retrieve research products connected to a project that has a funder with the given short name. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relProjectFundingStreamId",
            "in": "query",
            "description": "Retrieve research products connected to a project that has the given funding identifier. </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relHostingDataSourceId",
            "in": "query",
            "description": "Retrieve research products hosted by the data source (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "relCollectedFromDatasourceId",
            "in": "query",
            "description": "Retrieve research products collected from the data source (with OpenAIRE id). </br> Logical operator: *OR*",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number of the results, \nused for basic start/rows pagination. \nMax dataset to retrieve - 10000 records. \nTo get more than that, use cursor-based pagination.",
            "required": false,
            "schema": {
              "minimum": 1,
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of results per page",
            "required": false,
            "schema": {
              "maximum": 100,
              "minimum": 1,
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor-based pagination. Initial value: `cursor=*`. \nCursor should be used when it is required to retrieve a big dataset (more than 10000 records). \nTo get the next page of results, use nextCursor returned in the response.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "The field to sort the results by and the sort direction. The format should be in the format `fieldname ASC|DESC`, where fieldname is one of 'relevance', 'publicationDate', 'dateOfCollection', 'influence', 'popularity', 'citationCount', 'impulse'. Multiple sorting parameters should be comma-separated.",
            "required": false,
            "schema": {
              "pattern": "^((relevance|publicationDate|dateOfCollection|influence|popularity|citationCount|impulse)\\s+(ASC|DESC),?\\s*)+$",
              "type": "string",
              "default": "relevance DESC"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResearchProductsSearchResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "deprecated": true
      }
    },
