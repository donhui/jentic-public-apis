  "servers": [
    {
      "url": "https://faq.messagebird.com/"
    }
  ],
  "paths": {
    "/api/v1/datasets": {
      "get": {
        "parameters": [
          {
            "description": "The list mode indicating to query public datasets, only user datasets or both.\n\n - LIST_MODE_UNDEFINED: The list dataset mode type undefined.\n - ALL: List all datasets.\n - ONLY_TEMPLATE: List the template datasets. Template datasets are used as examples and can be found under the `Templates` tab in the [dataset overview of the dashboard](https://dashboard.messagebird.com/knowledge-base/list). You can clone such datasets to kickstart the creation of a dataset that is tailored to your use-case.\n - ONLY_USER: List the user datasets.",
            "example": "ONLY_USER",
            "in": "query",
            "name": "listMode",
            "required": false,
            "schema": {
              "default": "LIST_MODE_UNDEFINED",
              "enum": [
                "LIST_MODE_UNDEFINED",
                "ALL",
                "ONLY_TEMPLATE",
                "ONLY_USER"
              ],
              "type": "string"
            }
          },
          {
            "description": "The limit defining the maximal number of datasets to return.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": "20",
              "format": "int64",
              "type": "integer"
            }
          },
          {
            "description": "The cursor to view the next paginated collection of datasets as provided by the `next_cursor` value in the ListDatasetsResponse.",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "default": "null",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1ListDatasetsResponse"
                }
              }
            },
            "description": "A successful response."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Returned when the user is not authorized."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Returned when the resource does not exist."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/rpcStatus"
                }
              }
            },
            "description": "An unexpected error response."
          }
        },
        "security": [
          {
            "AccessKey": []
          }
        ],
        "tags": [
          "FAQ"
        ],
        "description": "Lists datasets containing answers and corresponding questions. You can choose to list only your own datasets, as well as template datasets, or both. You might need to iterate over multiple pages to obtain all of your datasets.",
        "operationId": "FAQ_ListDatasets",
        "summary": "List datasets"
      }
    },
    "/api/v1/datasets/{datasetId}": {
      "get": {
        "parameters": [
          {
            "description": "The unique ID for the dataset.",
            "in": "path",
            "name": "datasetId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1Dataset"
                }
              }
            },
            "description": "A successful response."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Returned when the user is not authorized."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Returned when the resource does not exist."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/rpcStatus"
                }
              }
            },
            "description": "An unexpected error response."
          }
        },
        "security": [
          {
            "AccessKey": []
          }
        ],
        "tags": [
          "FAQ"
        ],
        "description": "Retrieves the dataset for the given dataset ID.",
        "operationId": "FAQ_GetDataset",
        "summary": "Get dataset"
      }
    },
    "/api/v1/datasets/{datasetId}/predict-answer": {
      "post": {
        "parameters": [
          {
            "description": "The unique ID that identifies the dataset for which a question should be answered.",
            "in": "path",
            "name": "datasetId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1PredictAnswerResponse"
                }
              }
            },
            "description": "A successful response."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Returned when the user is not authorized."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Returned when the resource does not exist."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/rpcStatus"
                }
              }
            },
            "description": "An unexpected error response."
          }
        },
        "security": [
          {
            "AccessKey": []
          }
        ],
        "tags": [
          "FAQ"
        ],
        "description": "Predicts an answer corresponding to a question which is possibly contained in the phrase given an FAQ dataset. The FAQ API uses machine learning to generalize from the questions and answers in the dataset to infer the answer of the given question. This requires the active model for the dataset to be trained. Training a model usually takes around 1 minute after a dataset is created or updated. This endpoint yields an error if the model has not been trained yet.",
        "operationId": "FAQ_PredictAnswer",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "description": "A request for predicting an answer from a phrase and a dataset ID.",
                "example": {
                  "phrase": "Who founded MessageBird?"
                },
                "properties": {
                  "phrase": {
                    "description": "The phrase that might contain a question to be answered.",
                    "example": "Who founded MessageBird?",
                    "title": "Phrase",
                    "type": "string"
                  }
                },
                "title": "PredictAnswerRequest",
                "type": "object"
              }
            }
          },
          "required": true
        },
        "summary": "Predict Answer"
      }
    },
    "/api/v1/supported-languages": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1LanguageList"
                }
              }
