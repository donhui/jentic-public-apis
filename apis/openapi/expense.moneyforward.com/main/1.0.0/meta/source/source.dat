{
  "openapi": "3.0.3",
  "info": {
    "title": "MoneyForward Cloud Expense API",
    "version": "1.0.0",
    "description": "MoneyForward Cloud Expense API for managing expense transactions, reports, departments, projects, employees, and journal entries in a cloud-based expense management and workflow service.",
    "x-jentic-source-url": "https://expense.moneyforward.com/api/index.html"
  },
  "servers": [
    {
      "url": "https://expense.moneyforward.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "oauth2": [
        "office_setting:write"
      ]
    }
  ],
  "paths": {
    "/api/external/v1/offices": {
      "get": {
        "operationId": "listoffices",
        "summary": "List offices the user belongs to",
        "description": "Returns a list of offices (business entities) that the authenticated user belongs to.",
        "tags": [
          "Offices"
        ],
        "security": [
          {
            "oauth2": [
              "user_setting:write"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "List of offices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "offices": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Office"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/external/v1/offices/{office_id}/me/ex_transactions": {
      "get": {
        "operationId": "listmyexpensetransactions",
        "summary": "List personal expense transactions",
        "description": "Retrieves the authenticated user's expense transaction records with various filters.",
        "tags": [
          "Expense Transactions"
        ],
        "security": [
          {
            "oauth2": [
              "transaction:write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "office_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Office ID"
          },
          {
            "name": "dept_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by department ID"
          },
          {
            "name": "project_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by project ID"
          },
          {
            "name": "ex_item_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by expense item ID"
          },
          {
            "name": "amount_from",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Minimum amount filter"
          },
          {
            "name": "amount_to",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Maximum amount filter"
          },
          {
            "name": "date_from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date filter"
          },
          {
            "name": "date_to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date filter"
          },
          {
            "name": "approval_status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by approval status"
          }
        ],
        "responses": {
          "200": {
            "description": "List of expense transactions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ex_transactions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ExTransaction"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createexpensetransaction",
        "summary": "Create an expense transaction",
        "description": "Creates a new expense transaction entry.",
        "tags": [
          "Expense Transactions"
        ],
        "security": [
          {
            "oauth2": [
              "transaction:write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "office_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Office ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExTransactionCreateInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Expense transaction created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExTransaction"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/external/v1/offices/{office_id}/me/ex_transactions/{id}": {
      "put": {
        "operationId": "updateexpensetransaction",
        "summary": "Update an expense transaction",
        "description": "Updates an existing expense transaction.",
        "tags": [
          "Expense Transactions"
        ],
        "security": [
          {
            "oauth2": [
              "transaction:write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "office_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Office ID"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExTransactionCreateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExTransaction"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteexpensetransaction",
        "summary": "Delete an expense transaction",
        "description": "Deletes an existing expense transaction.",
        "tags": [
          "Expense Transactions"
        ],
        "security": [
          {
            "oauth2": [
              "transaction:write"
            ]
          }
        ],
        "parameters": [
          {
            "name": "office_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Office ID"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Transaction deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/external/v1/offices/{office_id}/me/ex_reports": {
      "get": {
        "operationId": "listmyexpensereports",
