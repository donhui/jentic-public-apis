    "/api/external/v1/offices/{office_id}/ex_journals_by_ex_transactions": {
      "get": {
        "operationId": "listjournalentriesbytransactions",
        "summary": "List journal entries by expense transactions",
        "description": "Retrieves ledger/journal entries linked to expense transactions. Maximum date range window of 3 months.",
        "tags": [
          "Journal Entries"
        ],
        "parameters": [
          {
            "name": "office_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Office ID"
          },
          {
            "name": "date_from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (max 3-month window)"
          },
          {
            "name": "date_to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (max 3-month window)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of journal entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ex_journals": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ExJournal"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
