{
  "asyncapi": "2.6.0",
  "info": {
    "title": "Manhattan Albertsons API Integration",
    "version": "1.4.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/SmarterSorting/alberstsons-asyncapi-specs/1.4.0/swagger.json"
  },
  "defaultContentType": "application/json",
  "servers": {
    "production": {
      "url": "google://pubsub",
      "protocol": "gcloud-pubsub"
    }
  },
  "channels": {
    "item-catalog": {
      "publish": {
        "message": {
          "oneOf": [
            {
              "$ref": "#/components/messages/itemCatalogMessage"
            },
            {
              "$ref": "#/components/messages/itemCatalogErrorMessage"
            }
          ]
        }
      },
      "subscribe": {
        "message": {
          "$ref": "#/components/messages/itemCatalogMessage"
        }
      }
    },
    "item-catalog-error": {
      "subscribe": {
        "message": {
          "$ref": "#/components/messages/itemCatalogErrorMessage"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "division": {
        "type": "string",
        "pattern": "^\\d{2}$",
        "examples": [
          "25"
        ]
      },
      "supplier_info": {
        "type": "object",
        "properties": {
          "supplier_name": {
            "type": "string",
            "description": "Supplier Name",
            "example": "A Supplier"
          },
          "supplier_id": {
            "type": "string",
            "description": "Supplier Id (DUNS)"
          },
          "supplier_website": {
            "type": "string",
            "description": "Supplier Website"
          },
          "supplier_address": {
            "type": "string",
            "description": "Supplier Address"
          },
          "supplier_contact_name": {
            "type": "string",
            "description": "Supplier Contact Name"
          },
          "supplier_contact_phone_number": {
            "type": "string",
            "description": "Supplier Contact Phone Number"
          },
          "supplier_contact_email": {
            "type": "string",
            "description": "Supplier Contact Email Address"
          },
          "supplier_metadata": {
            "type": "object",
            "description": "Arbitrary key/value pairs to provide additional metadata related to this supplier. Any keys or values will be accepted."
          }
        },
        "examples": [
          {
            "supplier_name": "A Supplier",
            "supplier_id": "12345",
            "supplier_website": "https://example.com",
            "supplier_address": "1234 Elm St",
            "supplier_contact_name": "Supplier Employee",
            "supplier_contact_phone_number": "555-555-5555",
            "supplier_contact_email": "name@example.com",
            "supplier_metadata": {
              "supplier_additional_stuff": "goes here",
              "supplier_city": "Anytown"
            }
          }
        ]
      }
    },
    "messages": {
      "itemCatalogMessage": {
        "payload": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Product Name",
              "examples": [
                "Kaboom Bowl Blaster"
              ]
            },
            "upc": {
              "type": "string",
              "description": "GTIN 14",
              "examples": [
                "00757037351253"
              ]
            },
            "status": {
              "type": "string",
              "description": "either 'active' or 'inactive'",
              "examples": [
                "active"
              ]
            },
            "smic": {
              "type": "string",
              "description": "Special Material Identification Code designating item category, 4-digit",
              "example": "9876"
            },
            "distribution_centers": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "list of 4 character distribution center codes",
              "examples": [
                [
                  "WIRV",
                  "WSLC"
                ]
              ]
            },
            "divisions": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/division"
              }
            },
            "data": {
              "type": "object",
              "examples": [
                {
                  "additional_key": "value_pairs"
                }
              ]
            },
            "item_requires_registration": {
              "type": "boolean",
              "description": "Indicates whether this item is hazardous and, thus, requires the related supplier(s) to register the product on the SmarterX platform",
              "default": false,
              "example": true
            },
            "supplier_info": {
              "type": "array",
              "description": "list of suppliers and related contact details associated with this UPC",
              "items": {
                "$ref": "#/components/schemas/supplier_info"
              }
            }
          }
        }
      },
      "itemCatalogErrorMessage": {
        "payload": {
          "type": "object",
          "properties": {
            "upc": {
              "type": "string",
              "description": "GTIN 14"
            },
            "created_timestamp": {
              "type": "number",
              "description": "posix timestamp of error message creation time"
            },
            "error_message": {
              "type": "string",
              "description": "error message from Item Catalog processing application"
            }
          }
        }
      }
    }
  }
}