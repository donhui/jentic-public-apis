{
  "openapi": "3.0.3",
  "info": {
    "title": "Envelope API",
    "description": "Event management API for programmatically managing events, guests, and related resources.",
    "license": {
      "name": "MIT"
    },
    "contact": {
      "email": "support@envelope.so"
    },
    "version": "1.0.4",
    "x-jentic-source-url": "https://docs.envelope.so"
  },
  "servers": [
    {
      "url": "https://envelope.so/api"
    }
  ],
  "paths": {
    "/v1/guests": {
      "get": {
        "summary": "List all guests",
        "tags": [
          "Guests"
        ],
        "description": "Retrieves a paginated list of guests with filtering, sorting, and search capabilities.",
        "parameters": [
          {
            "name": "event",
            "in": "query",
            "description": "Event ID to scope the guest list.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of records to skip for pagination.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "example": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of records to return.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20,
              "example": 20
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search term for filtering guests by first name, last name, or email.",
            "schema": {
              "type": "string",
              "example": "john"
            }
          },
          {
            "name": "email",
            "in": "query",
            "description": "Filter guests by exact email address match.",
            "schema": {
              "type": "string",
              "example": "john@example.com"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "Sort field and direction (field:asc|desc).",
            "schema": {
              "type": "string",
              "example": "lastName:asc"
            }
          },
          {
            "name": "filterBy",
            "in": "query",
            "description": "JSON-encoded filter criteria for guest properties.",
            "schema": {
              "type": "string",
              "example": "{\"status.confirmation\":1}"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of guests with pagination metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/GuestWithPopulated"
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total count of matching guests"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "operationId": "getV1Guests"
      },
      "post": {
        "summary": "Create a new guest",
        "tags": [
          "Guests"
        ],
        "description": "Creates a new guest with personal information and custom properties.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewGuest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guest created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guest"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "operationId": "postV1Guests"
      }
    },
    "/v1/guests/{_id}": {
      "get": {
        "summary": "Get a guest by ID",
        "tags": [
          "Guests"
        ],
        "description": "Retrieves detailed guest information including status and custom properties.",
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "description": "Guest ID to retrieve.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "event",
            "in": "query",
            "required": true,
            "description": "Associated event ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Guest details retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GuestWithPopulated"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "operationId": "getV1GuestsId"
      },
      "patch": {
        "summary": "Update a guest",
        "tags": [
          "Guests"
        ],
        "description": "Updates guest information with partial modifications.",
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "description": "Guest ID to update.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "event",
            "in": "query",
            "required": true,
            "description": "Associated event ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GuestUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guest updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guest"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "operationId": "patchV1GuestsId"
      },
      "delete": {
        "summary": "Delete a guest",
        "tags": [
          "Guests"
        ],
        "description": "Permanently removes a guest and their associated data.",
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "description": "Guest ID to delete.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "event",
            "in": "query",
            "required": true,
            "description": "Associated event ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Guest deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guest"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "operationId": "deleteV1GuestsId"
      }
    },
    "/v1/guests/{_id}/check-in": {
      "post": {
        "summary": "Check in a guest",
        "tags": [
          "Guests"
        ],
        "description": "Records guest attendance by checking them in to the event or specific zone.",
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "description": "Guest ID to check in.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "eventId"
                ],
                "properties": {
                  "eventId": {
                    "type": "string",
                    "description": "ID of the event"
                  },
                  "incrementBy": {
                    "type": "integer",
                    "description": "Number to increment attendance by",
                    "default": 1
                  },
                  "method": {
                    "type": "string",
                    "enum": [
                      "qrScan",
                      "manual"
                    ],
                    "description": "Method used for check-in"
                  },
                  "zoneId": {
                    "type": "string",
                    "description": "ID of the zone if checking into specific zone"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guest checked in successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guest"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "integer",
                      "example": 400
                    },
                    "message": {
                      "type": "string",
                      "example": "incrementBy is required"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        },
        "operationId": "postV1GuestsIdCheckIn"
      },
      "delete": {
        "summary": "Remove guest check-in",
        "tags": [
          "Guests"
        ],
        "description": "Removes guest attendance record from the event or specific zone.",
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "description": "Guest ID to remove check-in from.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "eventId"
                ],
                "properties": {
                  "eventId": {
                    "type": "string",
                    "description": "ID of the event"
                  },
                  "zoneId": {
                    "type": "string",
                    "description": "ID of the zone if removing zone check-in"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guest check-in removed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guest"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "operationId": "deleteV1GuestsIdCheckIn"
      }
    },
    "/v1/guests/register": {
      "post": {
        "summary": "Register a guest",
        "tags": [
          "Guests"
        ],
        "description": "Registers a new guest or confirms an existing guest through a public form submission.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "eventId",
                  "formData"
                ],
                "properties": {
                  "eventId": {
                    "type": "string",
                    "description": "ID of the event"
                  },
                  "formData": {
                    "type": "object",
                    "required": [
                      "properties"
                    ],
                    "properties": {
                      "properties": {
                        "type": "object",
                        "required": [
                          "email"
                        ],
                        "properties": {
                          "firstName": {
                            "type": "string",
                            "description": "First name of the guest"
                          },
                          "lastName": {
                            "type": "string",
                            "description": "Last name of the guest"
                          },
                          "email": {
                            "type": "string",
                            "description": "Email address of the guest"
                          }
                        },
                        "additionalProperties": true
                      },
                      "partners": {
                        "type": "integer",
                        "description": "Number of additional guests (+1, +2)",
                        "minimum": 0,
                        "maximum": 2
                      },
                      "givenConsents": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "Array of consent IDs that the guest has given"
                      }
                    }
                  },
                  "guestId": {
                    "type": "string",
                    "description": "ID of existing guest if updating"
                  },
                  "pageId": {
                    "type": "string",
                    "description": "ID of the page containing the form"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guest registered successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Guest"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters or registration constraints not met.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "integer",
                      "example": 400
                    },
                    "message": {
                      "type": "string",
                      "example": "Guest email is required"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Event is full or registration not allowed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "integer",
                      "example": 403
                    },
                    "message": {
                      "type": "string",
                      "example": "Event is full"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Event, guest, or form section not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "integer",
                      "example": 404
                    },
                    "message": {
                      "type": "string",
                      "example": "Event not found"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "operationId": "postV1GuestsRegister"
      }
    },
    "/v1/events": {
      "get": {
        "summary": "List all events",
        "tags": [
          "Events"
        ],
        "description": "Retrieves accessible events with optional time-based filtering.",
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "description": "Filter events by time frame (upcoming/past).",
            "schema": {
              "type": "string",
              "enum": [
                "upcoming",
                "past"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Events retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Event"
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total count of matching events"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "operationId": "getV1Events"
      }
    },
    "/v1/events/{_id}": {
      "get": {
        "summary": "Get an event by ID",
        "tags": [
          "Events"
        ],
        "description": "Retrieves detailed event information including settings and configuration.",
        "parameters": [
          {
            "name": "_id",
            "in": "path",
            "required": true,
            "description": "Event ID to retrieve.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event details retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "operationId": "getV1EventsId"
      }
    }
  },
  "components": {
    "schemas": {
      "Guest": {
        "type": "object",
        "required": [
          "_id",
          "event",
          "status",
          "properties"
        ],
        "properties": {
          "_id": {
            "type": "string",
            "description": "Guest ID"
          },
          "event": {
            "type": "string",
            "description": "Event ID"
          },
          "confirmedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Date and time when the guest was confirmed"
          },
          "attendedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Date and time when the guest attended the event"
          },
          "starred": {
            "type": "boolean",
            "default": false,
            "description": "Indicates if the guest is starred"
          },
          "status": {
            "type": "object",
            "required": [
              "confirmation",
              "attendance",
              "givenConsents",
              "visitedZones"
            ],
            "description": "Guest status information including confirmation, attendance, consents and check-in details",
            "properties": {
              "confirmation": {
                "type": "integer",
                "description": "-1 = declined, \n 0 = default, \n 1 = confirmed, \n 2 = confirmed + 1 partner, \n 3 = confirmed + 2 partners",
                "default": 0
              },
              "attendance": {
                "type": "integer",
                "description": "0 = default, \n 1 = attended, \n 2 = attended + 1 partner, \n 3 = attended + 2 partners",
                "default": 0
              },
              "declineMessage": {
                "type": "string",
                "nullable": true,
                "description": "Message from the guest when they declined the invitation"
              },
              "givenConsents": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Array of consents that the guest has given",
                "default": []
              },
              "visitedZones": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Array of zone IDs that the guest has visited",
                "default": []
              },
              "addMethod": {
                "type": "string",
                "enum": [
                  "batchImport",
                  "singleAdd",
                  "checkInAdd",
                  "publicRegistration"
                ],
                "description": "Method used to add the guest to the event"
              },
              "checkInMethod": {
                "type": "string",
                "enum": [
                  "qrScan",
                  "manual"
                ],
                "nullable": true,
                "description": "Method used to check in the guest"
              }
            },
            "example": {
              "confirmation": 2,
              "attendance": 1,
              "declineMessage": null,
              "givenConsents": [],
              "visitedZones": [],
              "addMethod": "publicRegistration",
              "checkInMethod": "qrScan"
            }
          },
          "properties": {
            "type": "object",
            "required": [
              "firstName",
              "lastName",
              "email",
              "lang"
            ],
            "description": "Guest properties including default required fields and any custom properties defined for the event",
            "properties": {
              "firstName": {
                "type": "string",
                "description": "First name of the guest"
              },
              "lastName": {
                "type": "string",
                "description": "Last name of the guest"
              },
              "email": {
                "type": "string",
                "description": "Email address of the guest"
              },
              "lang": {
                "type": "string",
                "description": "Language of the guest"
              }
            },
            "example": {
              "firstName": "John",
              "lastName": "Doe",
              "email": "john@example.com",
              "lang": "en",
              "X62TkjiV": "My custom note",
              "yN9hzaCj": "1QLXYBlw",
              "Ybb48GO7": [
                "7bR7m2au",
                "BdwYyYmi"
              ]
            }
          }
        }
      },
      "GuestWithPopulated": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Guest"
          },
          {
            "type": "object",
            "required": [
              "_populated"
            ],
            "properties": {
              "_populated": {
                "type": "object",
                "required": [
                  "properties",
                  "status"
                ],
                "properties": {
                  "properties": {
                    "type": "object",
                    "description": "Localized and human-readable guest properties",
                    "additionalProperties": {
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      ]
                    },
                    "example": {
                      "First name": "John",
                      "Last name": "Doe",
                      "Email": "john@example.com",
                      "Language": "en",
                      "Note": "My custom note",
                      "Ticket type": "VIP",
                      "Interests": [
                        "Technology",
                        "Business"
                      ]
                    }
                  },
                  "status": {
                    "type": "object",
                    "required": [
                      "confirmation",
                      "attendance"
                    ],
                    "description": "Localized and human-readable guest status",
                    "properties": {
                      "confirmation": {
                        "type": "string",
                        "description": "Localized confirmation status",
                        "example": "Confirmed (+1)"
                      },
                      "attendance": {
                        "type": "string",
                        "description": "Localized attendance status",
                        "example": "Attended"
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "NewGuest": {
        "type": "object",
        "required": [
          "event",
          "properties"
        ],
        "properties": {
          "event": {
            "type": "string",
            "description": "Event ID"
          },
          "properties": {
            "type": "object",
            "required": [
              "firstName",
              "lastName",
              "email"
            ],
            "description": "Guest required properties and any custom properties defined for the event",
            "properties": {
              "firstName": {
                "type": "string",
                "description": "First name of the guest"
              },
              "lastName": {
                "type": "string",
                "description": "Last name of the guest"
              },
              "email": {
                "type": "string",
                "description": "Email address of the guest"
              }
            }
          }
        }
      },
      "GuestUpdate": {
        "type": "object",
        "properties": {
          "starred": {
            "type": "boolean",
            "description": "Indicates if the guest is starred"
          },
          "status": {
            "type": "object",
            "properties": {
              "confirmation": {
                "type": "integer",
                "description": "Confirmation status of the guest"
              },
              "declineMessage": {
                "type": "string",
                "description": "Message from the guest when they declined the invitation"
              }
            }
          },
          "properties": {
            "type": "object",
            "description": "Guest properties including default fields and any custom properties defined for the event",
            "properties": {
              "firstName": {
                "type": "string",
                "description": "First name of the guest"
              },
              "lastName": {
                "type": "string",
                "description": "Last name of the guest"
              },
              "email": {
                "type": "string",
                "description": "Email address of the guest"
              }
            }
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Event ID"
          },
          "general": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
