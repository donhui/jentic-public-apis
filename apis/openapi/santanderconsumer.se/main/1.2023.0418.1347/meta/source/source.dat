            "format": "date-time"
          }
        }
      },
      "SummaryPayment": {
        "type": "object",
        "properties": {
          "typeInstalment": {
            "type": "integer",
            "format": "int32",
            "enum": [0, 1, 2]
          },
          "numberOfTerms": {
            "type": "integer",
            "format": "int32"
          },
          "payment": {
            "type": "number",
            "format": "double"
          },
          "insuranceAmount": {
            "type": "number",
            "format": "double"
          },
          "feesPorcentage": {
            "type": "number",
            "format": "double"
          },
          "feesAmount": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["httpCode", "httpMessage", "moreInformation"],
        "properties": {
          "httpCode": {
            "type": "string"
          },
          "httpMessage": {
            "type": "string"
          },
          "moreInformation": {
            "type": "string"
          },
          "errorCode": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            }
          }
        }
      },
      "ErrorDetail": {
        "type": "object",
        "required": ["code", "message", "target"],
        "properties": {
          "code": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "int32"
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for dealer authentication"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ]
}