{
  "openapi": "3.0.3",
  "info": {
    "title": "Associated Press Content API",
    "description": "The Associated Press (AP) Content API provides programmatic access to AP's news content, including articles, images, and multimedia. It enables searching, retrieving, and filtering AP news content by various criteria such as keywords, dates, media type, and more.",
    "version": "1.0.0",
    "contact": {
      "name": "AP Developer",
      "url": "https://developer.ap.org"
    },
    "x-jentic-source-url": "https://developer.ap.org/"
  },
  "servers": [
    {
      "url": "https://api.ap.org",
      "description": "AP Content API production server"
    }
  ],
  "security": [
    {
      "ApiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Content",
      "description": "Search and retrieve AP news content"
    },
    {
      "name": "Feed",
      "description": "Access AP content feeds"
    }
  ],
  "paths": {
    "/media/v/content/search": {
      "get": {
        "operationId": "searchContent",
        "summary": "Search AP content",
        "description": "Search for AP news content including articles, images, and videos using various filters and keywords.",
        "tags": ["Content"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Search query string. Supports boolean operators (AND, OR, NOT) and phrase matching with quotes.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "media_type",
            "in": "query",
            "required": false,
            "description": "Filter by media type",
            "schema": {
              "type": "string",
              "enum": ["text", "photo", "video", "audio", "graphic"]
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "description": "Filter content published after this date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "description": "Filter content published before this date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort order for results",
            "schema": {
              "type": "string",
              "enum": ["relevance", "date:asc", "date:desc"],
              "default": "relevance"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "subject",
            "in": "query",
            "required": false,
            "description": "Filter by AP subject code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "required": false,
            "description": "Filter by location (city, state, country)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Insufficient permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/media/v/content/{id}": {
      "get": {
        "operationId": "getContentById",
        "summary": "Get content item by ID",
        "description": "Retrieve a specific AP content item by its unique identifier, including the full article text, metadata, and associated media.",
        "tags": ["Content"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Unique content item identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with content item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentItem"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Content item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/media/v/content/feed": {
      "get": {
        "operationId": "getContentFeed",
        "summary": "Get AP content feed",
        "description": "Access a continuous feed of AP news content, suitable for integration with news platforms and content management systems.",
        "tags": ["Feed"],
        "parameters": [
          {
            "name": "media_type",
            "in": "query",
            "required": false,
            "description": "Filter feed by media type",
            "schema": {
              "type": "string",
              "enum": ["text", "photo", "video", "audio", "graphic"]
            }
          },
          {
            "name": "subject",
            "in": "query",
            "required": false,
            "description": "Filter by AP subject code",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "min_date",
            "in": "query",
            "required": false,
            "description": "Minimum publication date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "max_date",
            "in": "query",
            "required": false,
            "description": "Maximum publication date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "description": "Number of items per page",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "next_page",
            "in": "query",
            "required": false,
            "description": "Token for fetching the next page of results",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with feed items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "apikey",
        "description": "AP Content API key obtained from the AP Developer portal at https://developer.ap.org"
      }
    },
    "schemas": {
      "ContentItem": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string",
            "description": "Unique content identifier"
          },
          "headline": {
            "type": "string",
            "description": "Article headline"
          },
          "headline_extended": {
            "type": "string",
            "nullable": true,
            "description": "Extended headline with additional context"
          },
          "byline": {
            "type": "string",
            "nullable": true,
            "description": "Author byline"
          },
          "dateline": {
            "type": "string",
            "nullable": true,
            "description": "Dateline indicating origin location"
          },
          "body": {
            "type": "string",
            "nullable": true,
            "description": "Full article body text"
          },
          "published": {
            "type": "string",
            "format": "date-time",
            "description": "Publication date and time"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Last update date and time"
          },
          "media_type": {
            "type": "string",
            "description": "Type of content (text, photo, video, etc.)"
          },
          "subjects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subject"
            },
            "description": "Subject classifications"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "renditions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Rendition"
            },
            "description": "Available media renditions"
          },
          "source": {
            "type": "string",
            "description": "Content source (e.g., AP)"
          },
          "uri": {
            "type": "string",
            "format": "uri",
            "description": "Canonical URI for this content item"
          }
        }
      },
      "Subject": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "AP subject code"
          },
          "name": {
            "type": "string",
            "description": "Subject name"
          }
        }
      },
      "Location": {
        "type": "object",
        "nullable": true,
        "properties": {
          "city": {
            "type": "string",
            "nullable": true,
            "description": "City name"
          },
          "state": {
            "type": "string",
            "nullable": true,
            "description": "State or province"
          },
          "country": {
            "type": "string",
            "nullable": true,
            "description": "Country name"
          },
          "country_code": {
            "type": "string",
            "nullable": true,
            "description": "ISO country code"
          }
        }
      },
      "Rendition": {
        "type": "object",
        "properties": {
          "href": {
            "type": "string",
            "format": "uri",
            "description": "URL of the rendition"
          },
          "media_type": {
            "type": "string",
            "description": "MIME type of the rendition"
          },
          "width": {
            "type": "integer",
            "nullable": true,
            "description": "Width in pixels (for images/video)"
          },
          "height": {
            "type": "integer",
            "nullable": true,
            "description": "Height in pixels (for images/video)"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "total_results": {
            "type": "integer",
            "description": "Total number of matching results"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "page_size": {
            "type": "integer",
            "description": "Number of results per page"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentItem"
            }
          }
        }
      },
      "FeedResponse": {
        "type": "object",
        "properties": {
          "next_page": {
            "type": "string",
            "nullable": true,
            "description": "Token for fetching the next page"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentItem"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message"
              }
            }
          }
        }
      }
    }
  }
}
