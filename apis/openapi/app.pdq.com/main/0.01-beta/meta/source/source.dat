{
  "openapi": "3.0.3",
  "info": {
    "title": "PDQ Connect",
    "version": "0.01-beta",
    "description": "PDQ is a device management product, making it easy to remotely manage devices.",
    "x-jentic-source-url": "https://app.pdq.com/v1/docs"
  },
  "servers": [
    {
      "url": "https://app.pdq.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "authorization": []
    }
  ],
  "tags": [
    {"name": "Deployments", "description": "Deploy packages to devices"},
    {"name": "Devices", "description": "Manage and query devices"},
    {"name": "Groups", "description": "Device group management"},
    {"name": "Packages", "description": "Package management"}
  ],
  "paths": {
    "/v1/api/deployments": {
      "post": {
        "operationId": "createDeployment",
        "summary": "Deploy a package version to target devices or groups",
        "tags": ["Deployments"],
        "parameters": [
          {
            "name": "package",
            "in": "query",
            "required": true,
            "description": "Package ID or Package Version ID",
            "example": "pkg_123abc",
            "schema": {"type": "string"}
          },
          {
            "name": "targets",
            "in": "query",
            "required": true,
            "description": "Comma-delimited Device IDs or Group IDs",
            "example": "grp_123abc,dvc_123abc",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "204": {"description": "Deployments created successfully"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}},
          "422": {"description": "Invalid or missing IDs", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}}
        }
      }
    },
    "/v1/api/devices": {
      "get": {
        "operationId": "listDevices",
        "summary": "List devices",
        "tags": ["Devices"],
        "parameters": [
          {
            "name": "includes",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of related objects to include",
            "example": "networking,processors",
            "schema": {"type": "string"}
          },
          {
            "name": "group",
            "in": "query",
            "required": false,
            "description": "Filter by group ID",
            "schema": {"type": "string"}
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Page size (max 250, default 100)",
            "example": 50,
            "schema": {"type": "integer"}
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (default 1)",
            "example": 1,
            "schema": {"type": "integer"}
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort by field in camelCase",
            "schema": {"$ref": "#/components/schemas/DeviceSort"}
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "description": "Filter devices by fields",
            "schema": {"$ref": "#/components/schemas/DeviceFilter"},
            "style": "deepObject"
          }
        ],
        "responses": {
          "200": {"description": "Devices response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DevicesResponse"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}},
          "422": {"description": "Invalid params", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}}
        }
      }
    },
    "/v1/api/devices/{device_id}": {
      "get": {
        "operationId": "getDevice",
        "summary": "Get a device",
        "tags": ["Devices"],
        "parameters": [
          {
            "name": "device_id",
            "in": "path",
            "required": true,
            "description": "Device ID",
            "example": "dvc_123abc",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Device response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DeviceResponse"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}}
        }
      }
    },
    "/v1/api/groups": {
      "get": {
        "operationId": "listGroups",
        "summary": "List groups",
        "tags": ["Groups"],
        "parameters": [
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Page size (max 100, default 100)",
            "schema": {"type": "integer"}
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (default 1)",
            "schema": {"type": "integer"}
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort by field",
            "schema": {"$ref": "#/components/schemas/GroupSort"}
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "description": "Filter groups by fields",
            "schema": {"$ref": "#/components/schemas/GroupFilter"},
            "style": "deepObject"
          }
        ],
        "responses": {
          "200": {"description": "Groups response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GroupsResponse"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}},
          "422": {"description": "Invalid params", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}}
        }
      }
    },
    "/v1/api/packages": {
      "get": {
        "operationId": "listPackages",
        "summary": "List packages",
        "tags": ["Packages"],
        "parameters": [
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Page size (max 100, default 100)",
            "schema": {"type": "integer"}
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (default 1)",
            "schema": {"type": "integer"}
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort by field",
            "schema": {"$ref": "#/components/schemas/PackageSort"}
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "description": "Filter packages by fields",
            "schema": {"$ref": "#/components/schemas/PackageFilter"},
            "style": "deepObject"
          }
        ],
        "responses": {
          "200": {"description": "Packages response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PackagesResponse"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}},
          "422": {"description": "Invalid params", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}}
        }
      }
    },
    "/v1/api/packages/{package_id}": {
      "get": {
        "operationId": "getPackage",
        "summary": "Get a package with recent package versions",
        "tags": ["Packages"],
        "parameters": [
          {
            "name": "package_id",
            "in": "path",
            "required": true,
            "description": "Package ID",
            "example": "pkg_123abc",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Package response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PackageResponse"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "403": {"description": "Forbidden", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorsResponse"}}}}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "authorization": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Device": {
        "type": "object",
        "description": "A managed device",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "hostname": {"type": "string"},
          "os": {"type": "string"},
          "osVersion": {"type": "string"},
          "osFullName": {"type": "string"},
          "architecture": {"type": "string"},
          "manufacturer": {"type": "string"},
          "model": {"type": "string"},
          "serialNumber": {"type": "string"},
          "currentUser": {"type": "string"},
          "lastUser": {"type": "string"},
          "publicIpAddress": {"type": "string"},
          "macAddress": {"type": "string"},
          "memory": {"type": "integer"},
          "freePercent": {"type": "integer"},
          "requireReboot": {"type": "boolean"},
          "smbVersionOne": {"type": "boolean"},
          "insertedAt": {"type": "string", "format": "date-time"},
          "updatedAt": {"type": "string", "format": "date-time"},
          "lastSeenAt": {"type": "string", "format": "date-time"},
          "lastBootUpTime": {"type": "string", "format": "date-time"},
          "biosVersion": {"type": "string"},
          "biosManufacturer": {"type": "string"},
          "timezone": {"type": "string"},
          "powershellVersion": {"type": "string"},
          "dotNetVersions": {"type": "string"},
          "osInstallDate": {"type": "string", "format": "date-time"},
          "family": {"type": "string"},
          "chassis": {"type": "string"}
        }
      },
      "Group": {
        "type": "object",
        "description": "A group of devices",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "source": {"type": "string", "enum": ["pdq", "custom"]},
          "type": {"type": "string", "enum": ["dynamic", "static"]},
          "inserted_at": {"type": "string", "format": "date-time"}
        }
      },
      "Package": {
        "type": "object",
        "description": "A deployable package",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "publisher": {"type": "string"},
          "source": {"type": "string", "enum": ["pdq", "custom"]}
        }
      },
      "DeviceSort": {
        "type": "string",
        "enum": ["timezone", "memory", "currentUser", "freePercent", "systemVersion", "insertedAt", "os", "osVersion", "hostname", "serialNumber"]
      },
      "GroupSort": {
        "type": "string",
        "enum": ["id", "insertedAt", "name", "source", "type"]
      },
      "PackageSort": {
        "type": "string",
        "enum": ["name", "os", "publisher", "source"]
      },
      "DeviceFilter": {
        "type": "object",
        "properties": {
          "hostname": {"type": "string"},
          "os": {"type": "string"},
          "model": {"type": "string"},
          "memory": {"type": "string"},
          "freePercent": {"type": "string"},
          "requireReboot": {"type": "string", "enum": ["true", "false"]},
          "smbVersionOne": {"type": "string", "enum": ["true", "false"]},
          "lastSeenAt": {"type": "string"},
          "insertedAt": {"type": "string"},
          "updatedAt": {"type": "string"},
          "lastBootUpTime": {"type": "string"}
        }
      },
      "GroupFilter": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "source": {"type": "string"},
          "type": {"type": "string"},
          "insertedAt": {"type": "string"}
        }
      },
      "PackageFilter": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "publisher": {"type": "string"},
          "source": {"type": "string"},
          "os": {"type": "string"}
        }
      },
      "DevicesResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/Device"}}
        }
      },
      "DeviceResponse": {
        "type": "object",
        "properties": {
          "data": {"$ref": "#/components/schemas/Device"}
        }
      },
      "GroupsResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/Group"}}
        }
      },
      "PackagesResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/Package"}}
        }
      },
      "PackageResponse": {
        "type": "object",
        "properties": {
          "data": {"$ref": "#/components/schemas/Package"}
        }
      },
      "ErrorsResponse": {
        "type": "object",
        "required": ["errors"],
        "properties": {
          "errors": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Error"}
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": {"type": "number"},
          "detail": {"type": "string"}
        }
      }
    }
  }
}