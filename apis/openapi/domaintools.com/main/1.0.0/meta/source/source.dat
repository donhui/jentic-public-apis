              "type": "string"
            }
          },
          "mnt_keys": {
            "type": "object",
            "description": "Maintainer keys.",
            "additionalProperties": true
          },
          "created_date": {
            "type": "string",
            "format": "date-time",
            "description": "Date the contact was created.",
            "example": "2008-02-01T00:00:00"
          },
          "updated_date": {
            "type": "string",
            "format": "date-time",
            "description": "Date the contact was last updated.",
            "example": "2018-05-22T00:00:00"
