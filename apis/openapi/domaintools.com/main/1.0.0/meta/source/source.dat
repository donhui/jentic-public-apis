      "EnrichResult": {
        "type": "object",
        "description": "A comprehensive domain profile result from Iris Enrich API.",
        "properties": {
          "domain": {
            "type": "string"
          },
          "whois_url": {
            "type": "string"
          },
          "adsense": {
            "$ref": "#/components/schemas/EnrichTracker"
          },
          "alexa": {
            "type": "integer"
          },
          "popularity_rank": {
            "type": "number"
          },
          "active": {
            "type": "boolean"
          },
          "google_analytics": {
            "$ref": "#/components/schemas/EnrichTracker"
          },
          "ga4": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EnrichTracker"
            }
          },
          "gtm_codes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EnrichTracker"
            }
          },
          "fb_codes": {
