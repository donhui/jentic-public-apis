                "lineItemQty": {
                  "type": "string",
                  "example": 101
                },
                "lineItemTotal": {
                  "type": "string",
                  "example": 100
                }
              }
            }
          },
          "lineItemsHeader": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
