                },
                "example": {
                  "statusCode": 404,
                  "name": "Error",
                  "message": "Document with id 7 not found"
                }
              }
            },
            "description": "**The request was not successful.** It may happen for the following reasons:\n  * passed unimplemented response type\n  * document with passed id couldn\u2019t be found or this document is not Ready for Export\n"
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent.",
            "content": {
