    "/v2/documents/status": {
      "get": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          },
          {
            "name": "requestId",
            "in": "query",
            "description": "Id of the request you want to get information about",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/DocumentStatusRequestId"
            }
          },
          {
            "name": "filter[statusExport]",
            "in": "query",
            "description": "Filter by statusExport",
            "schema": {
              "$ref": "#/components/schemas/DocumentStatusFilterStatusExport"
            }
          },
          {
            "name": "filter[statusIsArchived]",
            "in": "query",
            "description": "Filter by statusIsArchived",
            "schema": {
              "$ref": "#/components/schemas/DocumentStatusFilterStatusIsArchived"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number of documents starting from 1",
            "schema": {
              "$ref": "#/components/schemas/DocumentStatusPage"
            }
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "construct and return request status",
        "description": "You can use this method to retrieve information about specific request. A successful response you get from this method is the same as the one you get on the `webhookUrl` provided to the **/documents/extract** endpoint during sending documents to recognition. But for webhook you can receive up to `documentsPerPage` documents at ones. And if you want to get other documents, you should use this endpoint. It provides parameter `page` that can be used to receive other documents by specifying number of the page. **Please note, fileAI system has a naming convention for certain line items' columns ([see naming convention](https://docs.google.com/spreadsheets/d/11xI8bPiK1c6XWzOadbiiHfUeDqGqbdb7vZhjXHmMvNg/edit?usp=sharing))**",
        "responses": {
          "200": {
            "description": "**The request was successful**. Request information was retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestInfoStatus"
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unuthorized request has been sent.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 401,
                    "message": "Incorrect access token",
                    "name": "Unauthorized"
                  }
                }
              }
            }
          },
          "404": {
            "description": "**The request was not successful**. Request with specified `requestId` was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 404,
                    "message": "Request with id: {requestId} not found",
                    "name": "Not Found"
                  }
                }
              }
            }
          },
          "422": {
            "description": "**The request was not successful**. Request has incorrect filter value (`statusIsArchived, statusExport`).",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/Error"
                    }
                  ]
                },
                "examples": {
                  "filter.statusExport": {
                    "value": {
                      "statusCode": 422,
                      "message": "filter.statusExport must be one of the following values: Ready for Export, Analyzing, Action Required",
                      "name": "Unprocessable Entity"
                    }
                  },
                  "filter.statusIsArchived": {
                    "value": {
                      "statusCode": 422,
                      "message": "filter.statusIsArchived must be one of the following values: 0, 1",
                      "name": "Unprocessable Entity"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "access_token"
      },
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "authorization"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "statusCode",
              "message",
              "name"
            ],
            "properties": {
              "statusCode": {
                "type": "integer",
                "description": "Code of the error",
                "example": 401
              },
              "message": {
                "type": "string",
                "description": "Error details",
                "example": "Unauthorized request"
              },
              "name": {
                "type": "string",
                "enum": [
                  "Error"
                ]
              }
            }
          }
        }
      },
      "cookie": {
        "nullable": true,
        "type": "object",
        "description": "Parameter that can be used for specifying any user-specific data that will be returned with the request result as-is"
      },
      "webhookUrl": {
        "type": "string",
        "description": "url you want to receive webhook to"
      },
      "requestSource": {
        "type": "string",
        "enum": [
          "extract",
          "changeRequest"
        ],
        "description": "Source of the request:\n* **extract** - when request was created after request to `/documents/extract` endpoint\n* **changeRequest** - when request was created after request to `/documents/changeRequest` endpoint\n"
      },
      "changeRequestStatus": {
        "type": "string",
        "enum": [
          "error",
          "pendingVerification",
          "verified"
        ],
        "description": "Status of the request:\n * `error` - request has been finished with error during sending documents to recognition\n * `pendingVerification` - waiting for all documents to be verified\n * `verified` - all documents from request have been verified\n",
        "example": "pendingVerification"
      },
      "requestStatus": {
        "type": "string",
        "enum": [
          "error",
          "pendingRecognition",
          "pendingVerification",
          "verified"
        ],
        "description": "Status of the request:\n * `error` - request has been finished with error during sending documents to recognition\n * `pendingRecognition` - waiting for all documents to be recognized at least once\n * `pendingVerification` - waiting for all documents to be verified\n * `verified` - all documents from request have been verified\n",
        "example": "pendingRecognition"
      },
      "date": {
        "type": "object",
        "required": [
          "epoch",
          "format",
          "string"
        ],
        "properties": {
          "epoch": {
            "type": "string",
            "description": "Milliseconds in UTC of the date"
          },
          "format": {
            "type": "string",
            "description": "Format used to format date"
          },
          "string": {
            "type": "string",
            "description": "Formatted date using specified format"
          }
        }
      },
      "Payslip": {
        "type": "object",
        "description": "Payslip document",
        "required": [
          "externalDetails",
          "status"
        ],
        "properties": {
          "externalDetails": {
            "type": "object",
            "required": [
              "documentId",
              "link"
            ],
            "properties": {
              "source": {
                "type": "string",
                "description": "Source of the document (S3 file provided during initial request)",
                "example": "https://bucketname.s3.bucket-region.amazonaws.com/document.pdf"
              },
              "documentId": {
                "type": "integer",
                "description": "Id of the document into fileAI system",
                "example": 48
              },
              "link": {
                "type": "string",
                "description": "Link to document on fileAI web-site",
                "example": "https://app.file.ai/documents/48"
              }
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "Analyzing",
              "Action Required",
              "Ready for Export"
            ],
            "description": "Document's status into fileAI system",
            "example": "Analyzing"
          },
          "documentType": {
            "type": "string",
            "example": "Payslip"
          },
          "supplierName": {
            "type": "string",
            "nullable": true
          },
          "currencyCode": {
            "type": "string",
            "description": "currency code. Full list of the currency codes can be found [here](https://iban.com/currency-codes)"
          },
          "employeeName": {
            "type": "string"
          },
          "payDate": {
            "$ref": "#/components/schemas/date"
          },
          "payPeriodFrom": {
            "$ref": "#/components/schemas/date"
          },
          "payPeriodTo": {
            "$ref": "#/components/schemas/date"
          },
          "totalEarnings": {
            "type": "number"
          },
          "totalPayments": {
            "type": "number"
          },
