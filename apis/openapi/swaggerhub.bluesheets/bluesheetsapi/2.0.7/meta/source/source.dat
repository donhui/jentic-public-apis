                "example": "https://app.file.ai/documents/101"
              }
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "Analyzing",
              "Action Required",
              "Ready for Export"
            ],
            "description": "Document's status into fileAI system",
            "example": "Analyzing"
          },
          "supplierName": {
            "type": "string",
            "nullable": true
          },
          "customerName": {
            "type": "string",
            "nullable": true
          },
