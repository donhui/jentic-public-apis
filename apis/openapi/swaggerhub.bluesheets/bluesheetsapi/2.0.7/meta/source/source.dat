                            "type": "string",
                            "example": "decimal"
                          },
                          "value": {
                            "type": "number",
                            "example": 25
                          }
                        }
                      },
                      "qty": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "example": "decimal"
                          },
                          "value": {
                            "type": "number",
                            "example": 10
                          }
                        }
                      },
                      "uid": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "type": "number",
                            "example": 0
                          }
                        }
                      }
                    }
                  }
                },
                "type": {
                  "type": "string",
                  "example": "flatTable"
                },
                "maxIndexHeaders": {
                  "type": "number",
                  "example": 7
                },
                "maxIndexRows": {
                  "type": "number",
                  "example": 3
                }
              }
            }
          }
        }
      },
      "RequestInfoStatus": {
        "type": "object",
        "description": "Please note, fileAI system has a naming convention for certain line items' columns ([see naming convention](https://docs.google.com/spreadsheets/d/11xI8bPiK1c6XWzOadbiiHfUeDqGqbdb7vZhjXHmMvNg/edit?usp=sharing))",
        "required": [
          "id",
          "status",
          "webhookStatus",
          "documents",
          "meta",
          "source",
          "page",
          "documentsPerPage",
          "totalDocumentsCount"
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/DocumentStatusRequestId"
          },
          "source": {
            "$ref": "#/components/schemas/RequestsForPeriodSource"
          },
          "status": {
            "$ref": "#/components/schemas/requestStatus"
          },
          "cookie": {
            "$ref": "#/components/schemas/cookie"
          },
          "webhookStatus": {
            "$ref": "#/components/schemas/webhookStatus"
          },
          "documents": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/InvoiceStatus"
                }
              ]
            }
          },
          "meta": {
            "type": "object",
            "description": "metadata associated with the request",
            "example": {
              "webhookUrl": "https://webhook.site/86f1d2e7-55c0-419e-90a5-b7828cc49b39"
            }
          },
          "page": {
            "type": "number",
            "description": "used page number for selection documents",
            "example": 2
          },
          "documentsPerPage": {
            "type": "number",
            "description": "current constant used for page size",
            "example": 5
          },
          "totalDocumentsCount": {
            "type": "number",
            "description": "total count of documents for this request",
            "example": 8
          }
        }
      },
      "InvoiceStatus": {
        "type": "object",
        "description": "Invoice document",
        "required": [
          "externalDetails",
          "status"
        ],
        "properties": {
          "externalDetails": {
            "type": "object",
            "required": [
              "documentId",
              "link"
            ],
            "properties": {
              "source": {
                "type": "string",
                "description": "Source of the document (S3 file provided during initial request)",
                "example": "https://bucketname.s3.bucket-region.amazonaws.com/document.pdf"
              },
              "documentId": {
                "type": "integer",
                "description": "Id of the document into fileAI system",
                "example": 101
              },
              "link": {
                "type": "string",
                "description": "Link to document on fileAI web-site",
                "example": "https://app.file.ai/documents/101"
              }
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "Analyzing",
              "Action Required",
              "Ready for Export"
            ],
            "description": "Document's status into fileAI system",
            "example": "Analyzing"
          },
          "supplierName": {
            "type": "string",
            "nullable": true
          },
          "customerName": {
            "type": "string",
            "nullable": true
          },
          "vatNumber": {
            "type": "string"
          },
          "invoiceNumber": {
            "type": "string"
          },
          "invoiceTotal": {
            "type": "string"
          },
          "invoiceSubtotal": {
            "type": "string"
          },
          "invoiceTax": {
            "type": "string"
          },
          "documentType": {
            "type": "string",
            "example": "Invoice"
          },
          "invoiceDate": {
            "$ref": "#/components/schemas/date"
          },
          "invoiceDueDate": {
            "$ref": "#/components/schemas/date"
          },
          "currencyCode": {
            "type": "string",
            "description": "currency code. Full list of the currency codes can be found [here](https://iban.com/currency-codes)"
          },
          "invoiceTotalQty": {
            "type": "string"
          },
          "lineItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lineItemDescription": {
                  "type": "string",
                  "example": "Example description value"
                },
                "lineItemQty": {
                  "type": "string",
                  "example": 101
                },
                "lineItemTotal": {
                  "type": "string",
                  "example": 100
                }
              }
            }
          },
          "lineItemsHeader": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "lineItemDescription",
                  "description": "column name in the fileAI system"
                },
                "name": {
                  "type": "string",
                  "example": "Product description",
                  "description": "column header text from the document"
                }
              }
            }
          },
          "createdBy": {
            "$ref": "#/components/schemas/DocumentStatusCreatedBy"
          },
          "updatedBy": {
            "$ref": "#/components/schemas/DocumentStatusUpdatedBy"
          },
          "createdDate": {
            "$ref": "#/components/schemas/date"
          },
          "updatedDate": {
            "$ref": "#/components/schemas/date"
          },
          "statusIsArchived": {
            "$ref": "#/components/schemas/DocumentStatusFilterStatusIsArchived"
          },
          "statusExport": {
            "$ref": "#/components/schemas/DocumentStatusFilterStatusExport"
          },
          "cookie": {
            "$ref": "#/components/schemas/cookie"
          }
        }
      },
      "DocumentStatusFilterStatusExport": {
        "type": "string",
        "enum": [
          "Ready for Export",
          "Analyzing",
          "Action Required"
        ],
        "example": "Analyzing"
      },
      "DocumentStatusFilterStatusIsArchived": {
        "type": "number",
        "enum": [
          0,
          1
        ],
        "example": 0
      },
      "DocumentStatusRequestId": {
        "type": "string",
        "example": "b9609fd8-f276-40a7-96bd-0bf0b38379d0",
        "format": "uuid"
      },
      "DocumentStatusPage": {
        "type": "number",
        "example": 1
      },
      "DocumentStatusCreatedBy": {
        "type": "object",
        "properties": {
          "createdBy": {
            "type": "string",
            "enum": [
              "user",
              "email",
              "integration",
              "clone",
              "merge",
              "split",
              "api"
            ],
            "example": "user"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "DocumentStatusUpdatedBy": {
        "type": "string",
        "example": "system"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    },
    {
      "cookie": []
    }
  ]
}