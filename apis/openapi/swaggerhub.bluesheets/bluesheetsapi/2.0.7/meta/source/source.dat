          "meta",
          "source",
          "page",
          "documentsPerPage",
          "totalDocumentsCount"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "id of the Request entity",
            "format": "uuid",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0831"
          },
          "source": {
            "$ref": "#/components/schemas/RequestsForPeriodSource"
          },
          "status": {
            "$ref": "#/components/schemas/requestStatus"
          },
          "cookie": {
            "$ref": "#/components/schemas/cookie"
          },
          "webhookStatus": {
            "$ref": "#/components/schemas/webhookStatus"
          },
          "documents": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/Invoice"
                },
                {
                  "$ref": "#/components/schemas/BankStatement"
                },
                {
                  "$ref": "#/components/schemas/Payslip"
                }
              ]
            }
          },
          "meta": {
            "type": "object",
            "description": "metadata associated with the request",
            "example": {
              "webhookUrl": "https://webhook.site/86f1d2e7-55c0-419e-90a5-b7828cc49b39"
            }
          },
          "page": {
            "type": "number",
            "description": "used page number for selection documents",
            "example": 2
          },
          "documentsPerPage": {
            "type": "number",
            "description": "current constant used for page size",
            "example": 5
          },
          "totalDocumentsCount": {
            "type": "number",
            "description": "total count of documents for this request",
            "example": 8
          }
        }
      },
