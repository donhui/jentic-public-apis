{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "fileAI production server",
      "url": "https://app.file.ai/backend/api"
    }
  ],
  "info": {
    "description": "This is an API that is aimed to simplify managing documents. If you have any questions about the API that are not covered in the following documentation, please click \"Contact the developer\" link underneath.\n>  Please, be aware that you need API key for accessing the API. You can get API keys through fileAI web-interface in the 'API Keys' section. As soon as you obtain your API key, you should include it in the each API request as an  `access_token` query parameter or `authorization` cookie argument. For example correctly configured url with query parameter will look the following:\n  ```\n  https://app.file.ai/backend/api/documents/extract?access_token=<YOUR_API_KEY>\n  ```\n",
    "version": "2.0.7",
    "title": "fileAI documents API",
    "contact": {
      "email": "developer@file.ai"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Bluesheets/BluesheetsAPI/2.0.7/swagger.json"
  },
  "tags": [
    {
      "name": "Document Endpoints"
    }
  ],
  "paths": {
    "/documents/markDocumentsExported": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json",
                "multipart/form-data"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "Mark documents as exported",
        "operationId": "postMarkDocumentsExported",
        "description": "## WARNING! The endpoint has been officially deprecated. Please use a /v2 version of this endpoint.\nThis endpoint marks the document as successfully exported, creates an entry in the export queue, and creates an entry in the history of the document about the successful export.\n",
        "responses": {
          "200": {
            "description": "**The request was successful**. Request does not return data",
            "content": {}
          },
          "400": {
            "description": "**The request was not successful**. Invalid ExtractRequest object has been sent, there is a reason why this error may happen:\n  * `documentIds` property was not provided in the request;\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 400,
                    "message": "Message with the reason why RequestObject is invalid",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent. It may happen due to the following reasons:\n  * You forgot to specify `access_token` query parameter or `authorization` cookie argument with the value of your API key;\n  * Your API key has been disabled by organziation owner;\n  * Your API key has been revoked by admin;\n  * You make the request from IP that is not specified in the IP's whitelist in the API key's settings.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestsMarkDocumentsExported"
              }
            }
          },
          "description": "Request body has following parameters in it:\n * `integrationName` **(default value - 'General')** - The name of the integration to which the document is to be exported;\n * `documentIds` **(required)** - Array of id documents to be exported;\n * `archive` - boolean value, if true - document will be archived after export\n"
        }
      }
    },
    "/documents/extract": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json",
                "multipart/form-data"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "sending files to recognition",
        "operationId": "sendDocumentsToRecognition",
        "description": "## WARNING! The endpoint has been officially deprecated. Please use a /v2 version of this endpoint.\nYou can submit files to recognition using this endpoint. This endpoint\nis an asynchronous, therefore you will not receive recognized document\nright in the response. Instead, you will receive **Request** entity with\nholds the status of the recognition. If request is successful and you\nprovide valid `webhookUrl` in the body of the request, you will receive\nwebhook. Body of the request will be **RequestInfo** entity as response from `/v2/documents/status` with passed `page` parameter as 1. On the\nother hand you may receive webhook in two following cases:\n  * when request get status `pendingVerification` (each document was recognized at least once). **PLEASE NOTE: if all documents from the request was not in the `Analyzing` status after recognition, you will not receive webhook about this status and you will get only one webhook instead of two.**;\n  * when request get status `verified` (each document is with the status which is different from `Analyzing`).\n",
        "responses": {
          "200": {
            "description": "**The request was successful**. Request entity will be returned to you. **PLEASE NOTE:** the Request entity you get as a response contains `status` property which can take value `error` which means that documents were not sent to recognition and some error happened during this process, details of the error you can find in the `meta.message`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Request"
                }
              }
            }
          },
          "400": {
            "description": "**The request was not successful**. Invalid ExtractRequest object has been sent, there are some reasons why this error may happen:\n  * `files` property was not provided in the body;\n  * `Content-Type` header is different from **application/json**;\n  * `webhookUrl` you provided is not valid url or it is a url onto localhost.\n  * `tag` you provided does not exist in the organization.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 400,
                    "message": "Message with the reason why RequestObject is invalid",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent. It may happen due to the following reasons:\n  * You forgot to specify `access_token` query parameter or `authorization` cookie argument with the value of your API key;\n  * Your API key has been disabled by organziation owner;\n  * Your API key has been revoked by admin;\n  * You make the request from IP that is not specified in the IP's whitelist in the API key's settings.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequestMultipartData"
              }
            }
          },
          "description": "Request body has following parameters in it:\n  * `files` **(required)** - each object could have meta and cookie. Meta used for specify tag and target document type; cookie to be returned with file as is. There are three ways of speficying files parameter:\n    - an array of objects that specifies file location at the S3 bucket, url *(required)*, and awsAccessKeyId *(optional)*, awsSecretAccessKey *(optional)* for getting file from the bucket, additionally, a *password* key can be included for decrypting password-protected PDF files.\n    - an array of objects that specified two keys: src *(required)*, that contains encoded base64 files in data URL and title *(required)*, that contains file name. A *password* key can also be included for decrypting password-protected PDF files.\n    - array of files using multipart/form-data\n    \n * `cookie` (optional) - any valid JSON type with user data that will be returned as-is to the webhook or during checking request status using **/documents/status** endpoint;\n * `webhookUrl` (optional) - a url you want to get webhooks on about request status.\n * `tag` (optional) - tag name or tag id you want to assign to the document, the system will assign 'General' tag if the tag with specified tag name doesn't exist.\n * `documentType` (optional) - document type id or name you want to assign to the document, if the document type is not found in the system, the system will determine the document type after the document is processed.\n * `reimbursable` (optional) - object used to create expense (will be used only if tag's generateExpense option is true).\n * `password` (optional) - a string used to decode password-protected PDF files. This password is applied to all items in the `files` array and is used only when the request is sent with `multipart/form-data`.\n"
        }
      }
    },
    "/documents/status": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "construct and return request status",
        "operationId": "getRequestStatus",
        "description": "## WARNING! The endpoint has been officially deprecated. Please use a /v2 version of this endpoint.\nYou can use this method to retrieve information about specific request.\nA successful response you get from this method is the same as the one\nyou get on the `webhookUrl` provided to the **/documents/extract**\nendpoint during sending documents to recognition. But for webhook you can receive up to `documentsPerPage` documents at ones. And if you want to get other documents, you should use this endpoint. It provides parameter `page` that can be used to receive other documents by specifying number of the page. **Please note,\nfileAI system has a naming convention for certain line items'\ncolumns ([see naming\nconvention](https://docs.google.com/spreadsheets/d/11xI8bPiK1c6XWzOadbiiHfUeDqGqbdb7vZhjXHmMvNg/edit?usp=sharing))**\n",
        "responses": {
          "200": {
            "description": "**The request was successful**. Request information was retrieved. Structure of the response is the same as the structure of the request body sent to `webhookUrl`",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestInfo"
                }
              }
            }
          },
          "400": {
            "description": "**The request was not successful**. Request has incorrect filter value (`statusIsArchived`).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 400,
                    "message": "Value 2 is forbidden for filter 'statusIsArchived', following values are accepted: 1, 0",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Uauthorized request has been sent.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "**The request was not successful**. Request with specified `requestId` was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 404,
                    "message": "Unknown request with id: {requestId}",
                    "name": "Error"
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestObject"
              }
            }
          },
          "description": "Request body contains next parameters:\n  * `requestId` **(required)** - id of the request you want to get information about.\n  * `page` (optional) - page number of documents starting from 1\n  * `filter` (optional) - object where filter values are specified (currently the only available filter is `statusIsArchived` which can be either 0 for not archived documents or 1 for archived documents)\n"
        }
      }
    },
    "/documents/changeRequest": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "submit change request",
        "operationId": "submitChangeRequest",
        "description": "## WARNING! The endpoint has been officially deprecated. Please use a /v2 version of this endpoint.\nThis method can be used to send already processed document back into processing queue. Use cases for this flow can be certain errors in document verification or certain edge cases that you can assist on. The steps of this method is similar to `/documents/extract` one except the thing that this endpoint operates with existing documents and create new change request associated with it. The status of the change request can be reviewed the same way as for extract request, using `/documents/status` endpoint.<br><br>\nSimilar to `/documents/extract`, this endpoint provides webhooks. When the document, requested by ChangeRequest, goes back to being 'Ready to Export', a webhook will be returned. They will contain the information about all documents that were submitted for recognition at once. Body of the request will be RequestInfo entity as response from `/documents/status`.\n",
        "responses": {
          "401": {
            "description": "**The request was not successful**. Uauthorized request has been sent.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "**The request was not successful**. Invalid ChangeRequest object has been sent, there are some reasons why this error may happen:\n  * `comment` property was not provided in the body;\n  * `documentId` property was not provided in the body\n  * `Content-Type` header is different from **application/json**;\n  * `webhookUrl` you provided is not valid url or it is a url onto localhost.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 422,
                    "message": "Message with the reason why ChangeRequest object is invalid",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "200": {
            "description": "**The request was successful**. Structure of the response is the same as the structure of the request body sent to `webhookUrl`",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangeRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "**The request was not successful**. Incorrect input data was send",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 400,
                    "message": "Unexpected number in JSON at position 80",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "404": {
            "description": "**The request was not successful**. Document not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 404,
                    "message": "Error document with id 355711 not found",
                    "name": "Error"
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeRequest"
              }
            }
          },
          "description": "Request body has following parameters in it:\n  * `comment` **(required)** - a comment with a statement what kind of change needs to be made on the document;\n  * `documentId` **(required)** - an id of the document the change is required for;\n * `cookie` (optional) - any valid JSON type with user data that will be returned as-is to the webhook or during checking request status using **/documents/status** endpoint;\n * `webhookUrl` (optional) - a url you want to get webhooks on about request status.\n"
        }
      }
    },
    "/documents/importJsonData": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "import json data to fileAI system",
        "operationId": "importJsonData",
        "description": "This method can be used for sending data in JSON format into fileAI system to be processed and saved as documents.",
        "responses": {
          "401": {
            "description": "**The request was not successful**. Uauthorized request has been sent.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "**The request was not successful**. Invalid body data has been sent, there are some reasons why this error may happen:\n  * `data` property was not provided in the body;\n  * `userDocumentType` property was not provided in the body;\n  * `integrationName` property was not provided in the body\n  * `Content-Type` header is different from **application/json**;\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 422,
                    "message": "Message with the reason why body data is invalid",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "200": {
            "description": "**The request was successful**.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportJsonDataResponse"
                }
              }
            }
          },
          "400": {
            "description": "**The request was not successful**. Request with specified `integrationName` was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 400,
                    "message": "Integration {integrationName} does not support JSON documents import",
                    "name": "Error"
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportJsonData"
              }
            }
          },
          "description": "Request body has following parameters in it:\n * `integrationName` **(required)** - name of the integration that sends documents in JSON format. Currently only General and Zonal intergations are available. General is default integration\n * `userDocumentType` **(optional)** - description of the userDocumentTypes (Tags) from GET /v2/userDocumentTypes endpoint. If blank, the tag will default to \"General\"\n * `documentType` **(required for General Integration)** - name of description of document types. Available document types for General Integration are Invoice (Sales), Invoice (Purchases), Purchase Order, Delivery Order, Bank Statement\n * `data` **(required)** - based on schema as per document type. Sample fields provided below is for Invoices. Fields will differ based on each differing document types.\n \nDo reach out to support@file.ai for fields relating to other document types, or any customization requests\n"
        }
      }
    },
    "/v2/userDocumentTypes": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "create create tags into organization",
        "operationId": "createTag",
        "description": "This method can be used for creation tag into organization. POST https://app.file.ai/backend/api/v2/userDocumentTypes\n",
        "responses": {
          "200": {
            "description": "**The request was successful**. Request information was retrieved. Structure of the response is an object with all data about created tag.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseForTagToCreate"
                }
              }
            }
          },
          "422": {
            "description": "**The request was not successful**. Here are some reasons why this error may happen:\n  * `UserDocumentType (tag)` with name form request is already exists\n  * `hex color` is not valid(error message: **Invalid color. Color should be HEX color**)\n  * `color` is not among the acceptable values.\n  * `Content-Type` header is different from **application/json**;\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 422,
                    "message": "Message with the reason why request is invalid",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent. It may happen due to the following reasons:\n  * You forgot to specify `access_token` query parameter or `authorization` cookie argument with the value of your API key;\n  * Your API key has been disabled by organziation owner;\n  * Your API key has been revoked by admin;\n  * You make the request from IP that is not specified in the IP's whitelist in the API key's settings.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestsForTagToCreate"
              }
            }
          },
          "description": "Request body has following parameters in it:\n  * `name` **(required)** - the name of the tag to create\n * `color` (optional) - the color of the tag to create. Color should be in HEX format, which consists of either 3 characters (shorthand, e.g., #F00) or 6 characters (full, e.g., #FF0000) following the '#' symbol. Default value - '#4B5565'.\n"
        }
      }
    },
    "/v2/documents/changeRequest": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "submit change request",
        "description": "This method can be used to send already processed document back into processing queue. Use cases for this flow can be certain errors in document verification or certain edge cases that you can assist on. The steps of this method is similar to `/v2/documents/extract` one except the thing that this endpoint operates with existing documents and create new change request associated with it. The status of the change request can be reviewed the same way as for extract request, using `/v2/documents/status` endpoint.<br><br> Similar to `/v2/documents/extract`, this endpoint provides webhooks. When the document, requested by ChangeRequest, goes back to being 'Ready to Export', a webhook will be returned. They will contain the information about all documents that were submitted for recognition at once. Body of the request will be RequestInfo entity as response from `/v2/documents/status`.\n",
        "responses": {
          "201": {
            "description": "**The request was successful**. Structure of the response is the same as the structure of the request body sent to `webhookUrl`",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangeRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "**The request was not successful**.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "ToManyChangeRequests": {
                    "summary": "To many change requests",
                    "value": {
                      "error": {
                        "statusCode": 400,
                        "message": "Cannot submit more change requests for this document, the limit of 3 has been reached",
                        "name": "Bad Request"
                      }
                    }
                  },
                  "ChangeRequestCreate": {
                    "summary": "Error while creating change request",
                    "value": {
                      "error": {
                        "statusCode": 400,
                        "message": "Error while creating new request",
                        "name": "Bad Request"
                      }
                    }
                  },
                  "ChangeRequestPostprocess": {
                    "summary": "Error during completing request",
                    "value": {
                      "error": {
                        "statusCode": 400,
                        "message": "Something went wrong during completing request, please try again",
                        "name": "Bad Request"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent. It may happen due to the following reasons:\n  * You forgot to specify `access_token` query parameter or `authorization` cookie argument with the value of your API key;\n  * Your API key has been disabled by organziation owner;\n  * Your API key has been revoked by admin;\n  * You make the request from IP that is not specified in the IP's whitelist in the API key's settings.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "**The request was not successful**. Document with provided not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 404,
                    "message": "Document with id: 1 not found",
                    "name": "Not Found"
                  }
                }
              }
            }
          },
          "422": {
            "description": "**The request was not successful**. Invalid ChangeRequest object has been sent, there is a reason why this error may happen:\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "InvalidDocumentIdValue": {
                    "summary": "Invalid 'documentId' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "documentId must be a number conforming to the specified constraints",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "InvalidCommentValue": {
                    "summary": "Invalid 'comment' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "comment must be a string",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "InvalidCookieValue": {
                    "summary": "Invalid 'cookie' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "cookie must be an object",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "InvalidWebhookUrlValue": {
                    "summary": "Invalid 'webhookUrl' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "webhookUrl must be a URL address",
                        "name": "Unprocessable Entity"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeRequest"
              }
            }
          },
          "description": "Request body has following parameters in it:\n  * `comment` **(required)** - a comment with a statement what kind of change needs to be made on the document;\n  * `documentId` **(required)** - an id of the document the change is required for;\n * `cookie` (optional) - any valid JSON type with user data that will be returned as-is to the webhook or during checking request status using **/v2/documents/status** endpoint;\n * `webhookUrl` (optional) - a url you want to get webhooks on about request status.\n"
        }
      }
    },
    "/v2/documents/extract": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json",
                "multipart/form-data"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "sending files to recognition",
        "description": "You can submit files to recognition using this endpoint. This endpoint is an asynchronous, therefore you will not receive recognized document right in the response. Instead, you will receive **Request** entity with holds the status of the recognition. If request is successful and you provide valid `webhookUrl` in the body of the request, you will receive webhook. Body of the request will be **RequestInfo** entity as response from `/v2/documents/status` with passed `page` parameter as 1. On the other hand you may receive webhook in two following cases:\n  * when request get status `pendingVerification` (each document was recognized at least once). **PLEASE NOTE: if all documents from the request was not in the `Analyzing` status after recognition, you will not receive webhook about this status and you will get only one webhook instead of two.**;\n  * when request get status `verified` (each document is with the status which is different from `Analyzing`).\n",
        "responses": {
          "201": {
            "description": "**The request was successful**. Request entity will be returned to you. **PLEASE NOTE:** the Request entity you get as a response contains `status` property which can take value `error` which means that documents were not sent to recognition and some error happened during this process, details of the error you can find in the `meta.message`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Request"
                }
              }
            }
          },
          "400": {
            "description": "**The request was not successful**. Extract processing errors.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "NoFilesReceived": {
                    "summary": "No files received",
                    "value": {
                      "error": {
                        "statusCode": 400,
                        "message": "No files received for processing",
                        "name": "Bad Request"
                      }
                    }
                  },
                  "ArchivedTag": {
                    "summary": "Archived tag cannot be applied",
                    "value": {
                      "error": {
                        "statusCode": 400,
                        "message": "Archived tag cannot be applied to a document",
                        "name": "Bad Request"
                      }
                    }
                  },
                  "ProcessedFilesLimit": {
                    "summary": "Files processed limit",
                    "value": {
                      "error": {
                        "statusCode": 400,
                        "message": "You have hit the limit for files processed under your current plan. Please reach out to your Workspace Owner/Admin to upgrade your plan.",
                        "name": "Bad Request"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent. It may happen due to the following reasons:\n  * You forgot to specify `access_token` query parameter or `authorization` cookie argument with the value of your API key;\n  * Your API key has been disabled by organziation owner;\n  * Your API key has been revoked by admin;\n  * You make the request from IP that is not specified in the IP's whitelist in the API key's settings.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "**The request was not successful**. Provided data not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "NotFoundTag": {
                    "summary": "Tag with provided id not found",
                    "value": {
                      "error": {
                        "statusCode": 404,
                        "message": "Tag with id: ${tagId} not exist in the organization",
                        "name": "Not Found"
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "**The request was not successful**. Invalid Extract object has been sent, there is a reason why this error may happen:\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "InvalidTagvalue": {
                    "summary": "Invalid 'tag' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "tag must be a string",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "WrongDocumentIdType": {
                    "summary": "Invalid 'documentType' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "documentType must be a string",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "InvalidCookieValue": {
                    "summary": "Invalid 'cookie' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "cookie must be an object",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "InvalidWebhookUrlValue": {
                    "summary": "Invalid 'webhookUrl' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "webhookUrl must be a URL address",
                        "name": "Unprocessable Entity"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ExtractRequestMultipartData"
              }
            }
          },
          "description": "Request body has following parameters in it:\n  * `files` **(required)** - each object could have meta and cookie. Meta used for specify tag and target document type; cookie to be returned with file as is. There are three ways of speficying files parameter:\n    - an array of objects that specifies file location at the S3 bucket, url *(required)*, and awsAccessKeyId *(optional)*, awsSecretAccessKey *(optional)* for getting file from the bucket, additionally, a *password* key can be included for decrypting password-protected PDF files.\n    - an array of objects that specified two keys: src *(required)*, that contains encoded base64 files in data URL and title *(required)*, that contains file name. A *password* key can also be included for decrypting password-protected PDF files.\n    - array of files using multipart/form-data\n    \n * `cookie` (optional) - any valid JSON type with user data that will be returned as-is to the webhook or during checking request status using **/documents/status** endpoint;\n * `webhookUrl` (optional) - a url you want to get webhooks on about request status.\n * `tag` (optional) - tag name or tag id you want to assign to the document, the system will assign 'General' tag if the tag with specified tag name doesn't exist.\n * `documentType` (optional) - document type id or name you want to assign to the document, if the document type is not found in the system, the system will determine the document type after the document is processed.\n * `reimbursable` (optional) - object used to create expense (will be used only if tag's generateExpense option is true).\n * `password` (optional) - a string used to decode password-protected PDF files. This password is applied to all items in the `files` array and is used only when the request is sent with `multipart/form-data`.\n"
        }
      }
    },
    "/v2/documents/markDocumentsExported": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json",
                "multipart/form-data"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "Mark documents as exported",
        "description": "This endpoint marks the document as successfully exported, creates an entry in the export queue, and creates an entry in the history of the document about the successful export.\n",
        "responses": {
          "204": {
            "description": "**The request was successful**. Request does not return data",
            "content": {}
          },
          "400": {
            "description": "**The request was not successful**. Processing errors.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "DocumentsMismatch": {
                    "summary": "One of the documentId's is not valid",
                    "value": {
                      "error": {
                        "statusCode": 400,
                        "message": "One of the documentId's is not valid or the document does not belong to your organization",
                        "name": "Bad Request"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent. It may happen due to the following reasons:\n  * You forgot to specify `access_token` query parameter or `authorization` cookie argument with the value of your API key;\n  * Your API key has been disabled by organziation owner;\n  * Your API key has been revoked by admin;\n  * You make the request from IP that is not specified in the IP's whitelist in the API key's settings.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "**The request was not successful**. Invalid MarkDocumentsExported object has been sent, there is a reason why this error may happen:\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "MissingDocumentIds": {
                    "summary": "Missing 'documentIds'",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "`documentIds` should not be empty",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "InvalidDocumentIdValue": {
                    "summary": "Invalid 'documentId' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "each value in `documentIds` must be a number conforming to the specified constraints",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "InvalidIntegrationNameValue": {
                    "summary": "Invalid 'integrationName' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "`integrationName` must be one of the following values: Sculpture Hospitality, General",
                        "name": "Unprocessable Entity"
                      }
                    }
                  },
                  "InvalidArchiveValue": {
                    "summary": "Invalid 'archive' value",
                    "value": {
                      "error": {
                        "statusCode": 422,
                        "message": "`archive` must be a boolean value",
                        "name": "Unprocessable Entity"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestsMarkDocumentsExported"
              }
            }
          },
          "description": "Request body has following parameters in it:\n * `integrationName` **(default value - 'General')** - The name of the integration to which the document is to be exported;\n * `documentIds` **(required)** - Array of id documents to be exported;\n * `archive` - boolean value, if true - document will be archived after export\n"
        }
      }
    },
    "/v2/documents/archiveDocument": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          }
        ],
        "tags": [
          "Document Endpoints"
        ],
        "summary": "archive document",
        "operationId": "archiveDocument",
        "description": "You can archive document using this endpoint.\n",
        "responses": {
          "204": {
            "description": "**The request was successful**. As a result of the successful execution of the request, a response with an empty body is returned."
          },
          "400": {
            "description": "**The request was not successful**. Here are some reasons why this error may happen:\n  * `document` with id from request does not exist within organization\n  * `document` with id from request is already archived\n  * `document` with id from request is currently processing or exporting\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 400,
                    "message": "Document cannot be archived",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent. It may happen due to the following reasons:\n  * You forgot to specify `access_token` query parameter or `authorization` cookie argument with the value of your API key;\n  * Your API key has been disabled by organziation owner;\n  * Your API key has been revoked by admin;\n  * You make the request from IP that is not specified in the IP's whitelist in the API key's settings.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "**The request was not successful**. Here are some reasons why this error may happen:\n  * `Content-Type` header is different from **application/json**;\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 422,
                    "message": "Message with the reason why request is invalid",
                    "name": "Error"
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ArchiveDocumentRequest"
              }
            }
          },
          "description": "Request body has following parameters in it:\n  * `documentId` **(required)** - the id of the document to archive (only one documentId can be passed in the request)\n"
        }
      }
    },
    "/v2/requests/requestsForPeriod": {
      "get": {
        "tags": [
          "Document Endpoints"
        ],
        "description": "This method can be used to obtain requests ids for the specified conditions. It might be useful to get all requests for the specified timeframe in order to get the details separately using `/documents/status/` endpoint. Please note, that requests might be created from different sources, for example, it might be through API request to `/documents/extract` method (then **source** will be equal to **extract**).\n",
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          },
          {
            "name": "startDate",
            "in": "query",
            "description": "unix timestamp of the start date in milliseconds",
            "schema": {
              "$ref": "#/components/schemas/RequestsForPeriodStartDate"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "description": "unix timestamp of the end date in milliseconds",
            "schema": {
              "$ref": "#/components/schemas/RequestsForPeriodEndDate"
            }
          },
          {
            "name": "source",
            "in": "query",
            "description": "a string that indicates source of requests",
            "schema": {
              "$ref": "#/components/schemas/RequestsForPeriodSource"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "a string that indicates status of requests",
            "schema": {
              "$ref": "#/components/schemas/RequestsForPeriodStatus"
            }
          }
        ],
        "summary": "get request for sent period",
        "operationId": "getRequestsForPeriod",
        "responses": {
          "200": {
            "description": "**The request was successful.** Returns an array requests ids",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestsForPeriodStartDateResponseResponse"
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "400": {
            "description": "**The request was not successful.** It may happen if passed an incorrect source of request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 400,
                    "name": "Error",
                    "message": "Unknown source: uploat"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/documents/exportReadyDocuments": {
      "get": {
        "summary": "Get all documents that are ready for export to the specified integration",
        "description": "## WARNING! The endpoint has been officially deprecated. Please use a /v2 version of this  endpoint.\nThis endpoint is used to get a list of all documents that are ready to be exported. For this request, pagination of the output of documents is available, for this, two parameters can be passed to the request - offset and limit. It is also possible to filter documents by tag, upload date and document date.\n",
        "tags": [
          "Document Endpoints"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            },
            "required": true
          },
          {
            "in": "query",
            "name": "integrationName",
            "schema": {
              "$ref": "#/components/schemas/IntegrationNameForExportReadyDocuments"
            },
            "description": "Integration name. If provided, returns only documents that were not already exported to the provided integration i.e. ready to be exported into provided integration"
          },
          {
            "in": "query",
            "name": "includeActionRequired",
            "schema": {
              "$ref": "#/components/schemas/IncludeActionRequiredForExportReadyDocuments"
            },
            "description": "Include action required. If 'true', returns a list of documents with export status 'Ready for export' or 'Action required', if 'false' - only documents that are ready to be exported"
          },
          {
            "in": "query",
            "name": "filter",
            "description": "An object that contains filtering parameters",
            "schema": {
              "$ref": "#/components/schemas/FilterForExportReadyDocuments"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "**The request was successful**. In response, you will receive a list of documents with fields that can be used for export",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExportReadyDocumentsResponse"
                }
              }
            }
          },
          "400": {
            "description": "**The request was not successful**. Invalid ExtractRequest object has been sent, there are some reasons why this error may happen:\n  * `Content-Type` header is different from **application/json**;\n  * `documentIds` property was not provided in the request;\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "statusCode": 400,
                    "message": "Message with the reason why RequestObject is invalid",
                    "name": "Error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "**The request was not successful**. Unauthorized request has been sent. It may happen due to the following reasons:\n  * You forgot to specify `access_token` query parameter or `authorization` cookie argument with the value of your API key;\n  * Your API key has been disabled by organziation owner;\n  * Your API key has been revoked by admin;\n  * You make the request from IP that is not specified in the IP's whitelist in the API key's settings.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v2/documents/exportReadyDocuments": {
      "get": {
        "summary": "Get all documents that are ready for export to the specified integration",
        "description": "This endpoint is used to get a list of all documents that are ready to be exported. For this request, pagination of the output of documents is available, for this, two parameters can be passed to the request - offset and limit. It is also possible to filter documents by tag, upload date and document date.\n",
        "tags": [
          "Document Endpoints"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Content-Type",
