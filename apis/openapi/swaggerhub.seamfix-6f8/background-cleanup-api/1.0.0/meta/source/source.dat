{
  "openapi": "3.0.3",
  "info": {
    "title": "Background Cleanup API",
    "description": "This API provides **background cleanup capabilities** by automatically detecting and isolating the \nsubject in an image, then removing or replacing the background with a standardized color (white) or format.\n\nIt ensures all images meet visual and regulatory standards for **identity verification**, \n**biometric enrollment**, or **document processing**, improving consistency and accuracy across workflows.\n\n## Workflow\n1. **Authenticate** \u2013 Call the Authorization API to obtain a bearer token.\n2. **Submit Image** \u2013 Send a base64-encoded image to the background cleanup endpoint.\n3. **Receive Processed Image** \u2013 The API returns a cleaned image with the background removed/replaced.\n\n|\n\n## Result Codes\n| Code | Meaning |\n|------|---------|\n| `0`  | \u2705 Image successfully processed |\n| `-1` | \u274c Processing failed |\n\n## Use Cases\n- **ID Photo Standardization** \u2014 Ensure passport/ID photos have uniform white backgrounds.\n- **Biometric Enrollment** \u2014 Clean up images before facial recognition processing.\n- **Document Processing** \u2014 Remove noisy backgrounds from scanned documents.\n- **Regulatory Compliance** \u2014 Meet ICAO and other standards for identity photos.\n",
    "version": "1.0.0",
    "contact": {
      "name": "API Provider Support"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/seamfix-6f8/Background-Cleanup-API/1.0.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/seamfix-6f8/Background-Cleanup-API/1.0.0"
    },
    {
      "url": "https://tenant.seamfix.com",
      "description": "Authentication Server"
    },
    {
      "url": "https://platform-portrait.seamfix.com",
      "description": "Background Cleanup Server"
    }
  ],
  "tags": [
    {
      "name": "Authorization",
      "description": "Authentication endpoints for obtaining access tokens"
    },
    {
      "name": "Background Cleanup",
      "description": "Image background removal and standardization endpoints"
    }
  ],
  "paths": {
    "/auth/authenticate/ext": {
      "post": {
        "tags": [
          "Authorization"
        ],
        "summary": "Authenticate and obtain access token",
        "description": "Authenticates the client using the provided credentials. The access token is returned \nin the **response headers** under the `Authorization` field. This token must be included \nin subsequent API calls as a Bearer token.\n",
        "operationId": "authenticate",
        "servers": [
          {
            "url": "https://tenant.seamfix.com",
            "description": "Authentication Server"
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Client authentication credentials",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRequest"
              },
              "example": {
                "userId": "000000000000",
                "publicKey": "SFXTESTPUBK_oIX4bcSvcUgCQBvNZRC3GMeIxtZnG854",
                "accountId": "1234567890"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful. The access token is returned in the \nresponse headers under the `Authorization` field.\n",
            "headers": {
              "Authorization": {
                "description": "Bearer token to be used for subsequent API calls.",
                "schema": {
                  "type": "string",
                  "example": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed. Invalid credentials provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestErrorResponse"
                },
                "example": {
                  "errorCode": "REQUEST_UNAUTHORISED",
                  "status": 401,
                  "message": "Request Unauthorised"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/face/clip": {
      "post": {
        "tags": [
          "Background Cleanup"
        ],
        "summary": "Remove and replace image background",
        "description": "Processes an image by detecting and isolating the subject, then removing the existing \nbackground and replacing it with a standardized white background.\n\n### How It Works\n1. Send a base64-encoded image along with a unique transaction ID.\n2. The API detects the subject (e.g., a person's face and upper body).\n4. The background is removed and replaced with a clean white background.\n5. The processed image is returned as a base64-encoded string in `clippedImage`.\n\n\n\n### Result Codes\n| Code | Meaning |\n|------|---------|\n| `0`  | \u2705 Background successfully removed and image processed |\n| `-1` | \u274c Processing failed |\n",
        "operationId": "backgroundCleanup",
        "servers": [
          {
            "url": "https://platform-portrait.seamfix.com",
            "description": "Background Cleanup Server"
          }
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Background cleanup request containing the image to process, \na unique transaction ID, and the action(s) to perform.\n",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BackgroundCleanupRequest"
              },
              "example": {
                "image": "/9j/4AAQSkZJRgABAQEASABIAAD/2wBDAA...",
                "transactionId": "txr-CLIP-ABCDEF123",
                "actions": [
                  "CLIP"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Background cleanup completed successfully. The processed image with a clean \nwhite background is returned in the `clippedImage` field as a base64-encoded string.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackgroundCleanupResponse"
                },
                "examples": {
                  "success": {
                    "summary": "\u2705 Background successfully removed",
                    "value": {
                      "transactionId": "txr-CLIP-ABCDEF123",
                      "transactionStatus": "Successful",
                      "transactionStatusCode": "00",
                      "responses": [
                        {
                          "code": 0,
                          "description": "Background successfully removed",
                          "actionType": "CLIP",
                          "clippedImage": "/9j/4AAQSkZJRgABAQEASABIAAD...",
                          "score": null,
                          "icaoTokenImage": null,
                          "metrics": null
                        }
                      ]
                    }
                  },
                  "failure": {
                    "summary": "\u274c Processing failed",
                    "value": {
                      "transactionId": "txr-CLIP-ABCDEF123",
                      "transactionStatus": "Successful",
                      "transactionStatusCode": "00",
                      "responses": [
                        {
                          "code": -1,
                          "description": "Image Processing Failed",
                          "actionType": "CLIP",
                          "clippedImage": null,
                          "score": null,
                          "icaoTokenImage": null,
                          "metrics": null
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request \u2014 Validation error or malformed request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestErrorResponse"
                },
                "examples": {
                  "validationError": {
                    "summary": "Request Validation Error",
                    "value": {
                      "errorCode": "REQUEST_VALIDATION_ERROR",
                      "status": 400,
                      "message": "Bad Request"
                    }
                  },
                  "badRequest": {
                    "summary": "Malformed Request",
                    "value": {
                      "errorCode": "BAD_REQUEST",
                      "status": 400,
                      "message": "The request could not be processed due to malformed syntax or invalid data."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized \u2014 Invalid, expired, or missing token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestErrorResponse"
                },
                "examples": {
                  "unauthorised": {
                    "summary": "Request Unauthorised",
                    "value": {
                      "errorCode": "REQUEST_UNAUTHORISED",
                      "status": 401,
                      "message": "Request Unauthorised"
                    }
                  },
                  "expiredToken": {
                    "summary": "Token Expired",
                    "value": {
                      "errorCode": "REQUEST_UNAUTHORISED_EXPIRED_TOKEN",
                      "status": 401,
                      "message": "Request Unauthorised, Token Expired"
                    }
                  },
                  "userNotFound": {
                    "summary": "User Not Found",
                    "value": {
                      "errorCode": "REQUEST_UNAUTHORISED_USER_NOT_FOUND",
                      "status": 401,
                      "message": "Request Unauthorised, User not found"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Processing Error \u2014 The request was received but could not be processed.\nThese errors return a `status` of `-1` in the response body.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessingErrorResponse"
                },
                "examples": {
                  "duplicateRef": {
                    "summary": "Duplicate Transaction Reference",
                    "value": {
                      "errorCode": "TX_REF_ALREADY_EXIST",
                      "status": -1,
                      "message": "Transaction Ref already Exist"
                    }
                  },
                  "generalError": {
                    "summary": "General Processing Error",
                    "value": {
                      "errorCode": "ERROR",
                      "status": -1,
                      "message": "Unable to process the request"
                    }
                  },
                  "processingFailed": {
                    "summary": "Image Processing Failed",
                    "value": {
                      "errorCode": "PROCESS_FAILED",
                      "status": -1,
                      "message": "Image Processing Failed"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable \u2014 The server is temporarily unable to process the request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestErrorResponse"
                },
                "example": {
                  "errorCode": "REQUEST_SERVICE_UNAVAILABLE",
                  "status": 503,
                  "message": "Service Unavailable"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token obtained from the Authorization API (`/auth/authenticate/ext`). \nThe token is returned in the response **headers** under the `Authorization` field.\nInclude it in subsequent requests as `Authorization: Bearer <token>`.\n"
      }
    },
    "schemas": {
      "AuthRequest": {
        "type": "object",
        "required": [
          "userId",
          "publicKey",
          "accountId"
        ],
        "properties": {
          "userId": {
            "type": "string",
            "description": "The unique user identifier for authentication.",
            "example": "000000000000"
          },
          "publicKey": {
            "type": "string",
            "description": "The public API key assigned to the client.",
            "example": "SFXTESTPUBK_oIX4bcSvcUgCQBvNZRC3GMeIxtZnG854"
          },
          "accountId": {
            "type": "string",
            "description": "The account identifier associated with the client.",
            "example": "1234567890"
          }
        }
      },
      "BackgroundCleanupRequest": {
        "type": "object",
        "required": [
          "image"
        ],
        "properties": {
          "image": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded string of the image to be processed. \nThe image should contain a clearly visible subject (e.g., a person) \nwhose background needs to be removed or replaced.\n",
            "example": "/9j/4AAQSkZJRgABAQEASABIAAD/2wBDAA..."
          }
        }
      },
      "BackgroundCleanupResponse": {
        "type": "object",
        "properties": {
          "code": {
            "x-stoplight": {
              "id": "8lbyfa3j9i3e5"
            },
            "enum": []
          },
          "transactionId": {
            "type": "string",
            "description": "The same transaction ID provided in the request.",
            "example": "txr-CLIP-ABCDEF123"
          },
          "description": {
            "type": "string",
            "x-stoplight": {
              "id": "ntscczgbcxuyz"
            }
          },
          "clippedImage": {
            "type": "string",
            "x-stoplight": {
              "id": "smpj5u3236k57"
            }
          }
        }
      },
      "RequestErrorResponse": {
        "type": "object",
        "description": "Standard error response for HTTP-level errors (400, 401, 503).",
        "properties": {
          "errorCode": {
            "type": "string",
            "description": "Machine-readable error code.",
            "enum": [
              "REQUEST_VALIDATION_ERROR",
              "BAD_REQUEST",
              "REQUEST_UNAUTHORISED",
              "REQUEST_UNAUTHORISED_EXPIRED_TOKEN",
              "REQUEST_UNAUTHORISED_USER_NOT_FOUND",
              "REQUEST_SERVICE_UNAVAILABLE"
            ],
            "example": "REQUEST_VALIDATION_ERROR"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code.",
            "example": 400
          },
          "message": {
            "type": "string",
            "description": "Human-readable error description.",
            "example": "Bad Request"
          }
        }
      },
      "ProcessingErrorResponse": {
        "type": "object",
        "description": "Processing error response for errors that occur during background cleanup.\nThese always return a `status` of `-1`.\n",
        "properties": {
          "errorCode": {
            "type": "string",
            "description": "Machine-readable error code indicating the processing failure.",
            "enum": [
              "TX_REF_ALREADY_EXIST",
              "ERROR",
              "PROCESS_FAILED"
            ],
            "example": "PROCESS_FAILED"
          },
          "status": {
            "type": "integer",
            "description": "Always `-1` for processing errors.",
            "example": -1
          },
          "message": {
            "type": "string",
            "description": "Human-readable description of the processing failure.",
            "example": "Image Processing Failed"
          }
        }
      }
    }
  }
}