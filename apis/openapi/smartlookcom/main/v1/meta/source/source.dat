{
  "openapi": "3.0.3",
  "info": {
    "title": "Smartlook API",
    "description": "Smartlook REST API for managing sessions, visitors, events, funnels, and webhooks. Rate limits: Free plan 20 req/hr, Paid plans 100 req/hr, REST API add-on 1,000 req/hr. Inactive tokens expire after 90 days.",
    "version": "v1",
    "x-jentic-source-url": "https://integrations.smartlook.com/docs/api-overview"
  },
  "servers": [
    {
      "url": "https://api.{region}.smartlook.cloud",
      "variables": {
        "region": {
          "default": "eu",
          "description": "API region (eu or us)"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "sessions"},
    {"name": "visitors"},
    {"name": "events"},
    {"name": "funnels"},
    {"name": "webhooks"},
    {"name": "system"}
  ],
  "paths": {
    "/api/v1/sessions": {
      "post": {
        "operationId": "searchSessions",
        "summary": "Search sessions",
        "tags": ["sessions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of sessions matching the search criteria",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionSearchResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/sessions/{id}": {
      "get": {
        "operationId": "getSession",
        "summary": "Get session details",
        "tags": ["sessions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Session details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Session not found"}
        }
      }
    },
    "/api/v1/sessions/{id}/public": {
      "get": {
        "operationId": "getSessionPublicLink",
        "summary": "Get session public link",
        "tags": ["sessions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Public link for the session",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {"type": "string", "format": "uri"}
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Session not found"}
        }
      }
    },
    "/api/v1/visitors/{id}": {
      "get": {
        "operationId": "getVisitor",
        "summary": "Get visitor details",
        "tags": ["visitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Visitor details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Visitor"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Visitor not found"}
        }
      },
      "delete": {
        "operationId": "deleteVisitor",
        "summary": "Delete visitor",
        "tags": ["visitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Visitor deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Visitor not found"}
        }
      }
    },
    "/api/v1/visitors/{id}/sessions": {
      "get": {
        "operationId": "getVisitorSessions",
        "summary": "Get visitor sessions",
        "tags": ["visitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "List of visitor sessions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sessions": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Session"}
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/visitors/{id}/events": {
      "get": {
        "operationId": "getVisitorEvents",
        "summary": "Get visitor events",
        "tags": ["visitors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "List of visitor events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "events": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Event"}
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/visitors/search": {
      "post": {
        "operationId": "searchVisitors",
        "summary": "Search visitors",
        "tags": ["visitors"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VisitorSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of visitors matching the search criteria",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VisitorSearchResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/visitors": {
      "delete": {
        "operationId": "deleteVisitors",
        "summary": "Delete visitors",
        "tags": ["visitors"],
        "responses": {
          "200": {"description": "Visitors deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/events": {
      "get": {
        "operationId": "listEvents",
        "summary": "Get events list",
        "tags": ["events"],
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "events": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Event"}
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/events/{id}": {
      "get": {
        "operationId": "getEvent",
        "summary": "Get event details",
        "tags": ["events"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Event details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Event not found"}
        }
      },
      "delete": {
        "operationId": "deleteEvent",
        "summary": "Delete event",
        "tags": ["events"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Event deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Event not found"}
        }
      }
    },
    "/api/v1/events/{id}/visitors": {
      "get": {
        "operationId": "getEventVisitors",
        "summary": "Get event visitors",
        "tags": ["events"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "List of visitors for the event",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "visitors": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Visitor"}
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/funnels": {
      "get": {
        "operationId": "listFunnels",
        "summary": "Get funnels list",
        "tags": ["funnels"],
        "responses": {
          "200": {
            "description": "List of funnels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "funnels": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Funnel"}
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/funnels/{id}": {
      "get": {
        "operationId": "getFunnel",
        "summary": "Get funnel details",
        "tags": ["funnels"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Funnel details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Funnel"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Funnel not found"}
        }
      }
    },
    "/api/v1/funnels/{id}/visitors/drop-off": {
      "get": {
        "operationId": "getFunnelDropOffVisitors",
        "summary": "Get funnel drop-off visitors",
        "tags": ["funnels"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "List of drop-off visitors for the funnel",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "visitors": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Visitor"}
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/statistics": {
      "get": {
        "operationId": "getStatistics",
        "summary": "Get API usage statistics",
        "tags": ["system"],
        "responses": {
          "200": {
            "description": "API usage statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "usage": {"type": "object"}
                  }
                }
              }
            }
          },
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/me": {
      "get": {
        "operationId": "getProjectInfo",
        "summary": "Get project information",
        "tags": ["system"],
        "responses": {
          "200": {
            "description": "Project information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"},
          "429": {"description": "Rate limit exceeded"}
        }
      }
    },
    "/api/v1/webhooks": {
      "get": {
        "operationId": "listWebhooks",
        "summary": "Get webhooks",
        "tags": ["webhooks"],
        "responses": {
          "200": {
            "description": "List of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "webhooks": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Webhook"}
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createWebhook",
        "summary": "Create webhook",
        "tags": ["webhooks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created webhook",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/webhooks/{id}": {
      "get": {
        "operationId": "getWebhook",
        "summary": "Get webhook",
        "tags": ["webhooks"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Webhook not found"}
        }
      },
      "patch": {
        "operationId": "updateWebhook",
        "summary": "Update webhook",
        "tags": ["webhooks"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated webhook",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Webhook not found"}
        }
      },
      "delete": {
        "operationId": "deleteWebhook",
        "summary": "Delete webhook",
        "tags": ["webhooks"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Webhook deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Webhook not found"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Session": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "visitorId": {"type": "string"},
          "duration": {"type": "integer"},
          "startedAt": {"type": "string", "format": "date-time"},
          "endedAt": {"type": "string", "format": "date-time"},
          "ip": {"type": "string"},
          "country": {"type": "string"},
          "city": {"type": "string"},
          "device": {"type": "string"},
          "browser": {"type": "string"},
          "os": {"type": "string"},
          "referrer": {"type": "string"},
          "landingPage": {"type": "string"}
        }
      },
      "SessionSearchRequest": {
        "type": "object",
        "properties": {
          "filters": {"type": "object"},
          "limit": {"type": "integer"},
          "offset": {"type": "integer"}
        }
      },
      "SessionSearchResponse": {
        "type": "object",
        "properties": {
          "sessions": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Session"}
          },
          "totalCount": {"type": "integer"}
        }
      },
      "Visitor": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "customId": {"type": "string"},
          "email": {"type": "string"},
          "name": {"type": "string"},
          "sessionsCount": {"type": "integer"},
          "lastSeenAt": {"type": "string", "format": "date-time"},
          "firstSeenAt": {"type": "string", "format": "date-time"}
        }
      },
      "VisitorSearchRequest": {
        "type": "object",
        "properties": {
          "filters": {"type": "object"},
          "limit": {"type": "integer"},
          "offset": {"type": "integer"}
        }
      },
      "VisitorSearchResponse": {
        "type": "object",
        "properties": {
          "visitors": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Visitor"}
          },
          "totalCount": {"type": "integer"}
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "type": {"type": "string"},
          "count": {"type": "integer"}
        }
      },
      "Funnel": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "steps": {
            "type": "array",
            "items": {"type": "object"}
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "plan": {"type": "string"}
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "url": {"type": "string", "format": "uri"},
          "events": {
            "type": "array",
            "items": {"type": "string"}
          },
          "enabled": {"type": "boolean"}
        }
      },
      "WebhookCreateRequest": {
        "type": "object",
        "required": ["url", "events"],
        "properties": {
          "url": {"type": "string", "format": "uri"},
          "events": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      },
      "WebhookUpdateRequest": {
        "type": "object",
        "properties": {
          "url": {"type": "string", "format": "uri"},
          "events": {
            "type": "array",
            "items": {"type": "string"}
          },
          "enabled": {"type": "boolean"}
        }
      }
    }
  }
}