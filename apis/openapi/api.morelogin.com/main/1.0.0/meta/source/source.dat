  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Access token obtained from the OAuth token endpoint"
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "msg": {
            "type": "string",
            "nullable": true
          },
          "data": {
            "type": "object",
            "properties": {
              "scope": {
                "type": "string"
              },
              "access_token": {
                "type": "string"
              },
              "token_type": {
                "type": "string"
              },
              "expires_in": {
                "type": "integer"
              },
              "client_metadata": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "msg": {
            "type": "string",
            "nullable": true
          },
          "data": {
            "type": "object"
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "CloudPhoneListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "msg": {
            "type": "string",
            "nullable": true
          },
          "data": {
            "type": "object",
            "properties": {
              "list": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CloudPhone"
                }
              },
              "total": {
                "type": "integer"
              }
            }
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "CloudPhone": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "groupId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateCloudPhoneRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "groupId": {
            "type": "string"
          },
          "proxyId": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "msg": {
            "type": "string"
          },
          "requestId": {
            "type": "string"
          }
        }
      }
    }
  }
}