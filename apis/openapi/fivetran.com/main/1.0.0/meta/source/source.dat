  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Base64-encoded API key and secret pair. Format: Basic base64(api_key:api_secret)"
      }
    },
    "parameters": {
      "cursor": {
        "name": "cursor",
        "in": "query",
        "description": "Paging cursor for pagination.",
        "schema": { "type": "string" }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "description": "Number of records to fetch per page. Accepts 1-1000; default is 100.",
        "schema": {
          "type": "integer",
          "format": "int32",
          "minimum": 1,
          "maximum": 1000,
          "default": 100
        }
      },
      "connectionId": {
        "name": "connectionId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the connection.",
        "schema": { "type": "string" }
      },
      "destinationId": {
        "name": "destinationId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the destination.",
        "schema": { "type": "string" }
      },
      "groupId": {
        "name": "groupId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the group.",
        "schema": { "type": "string" }
      },
      "userId": {
        "name": "userId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the user.",
        "schema": { "type": "string" }
      },
      "teamId": {
        "name": "teamId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the team.",
        "schema": { "type": "string" }
      },
      "webhookId": {
        "name": "webhookId",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the webhook.",
        "schema": { "type": "string" }
      },
      "hash": {
        "name": "hash",
        "in": "path",
        "required": true,
        "description": "The hash of the certificate or fingerprint.",
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "StandardResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable message"
          },
          "data": {
            "type": "object",
            "description": "Response payload"
          }
        }
      },
      "AccountInfoResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Account ID" },
              "name": { "type": "string", "description": "Account name" },
              "country": { "type": "string" },
              "created_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "ConnectionListResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Connection" }
              },
              "next_cursor": { "type": "string" }
            }
          }
        }
      },
      "ConnectionResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/Connection" }
        }
      },
      "Connection": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique connection identifier" },
          "service": { "type": "string", "description": "Connector type name" },
          "schema": { "type": "string", "description": "Destination schema name" },
          "paused": { "type": "boolean", "description": "Connection pause state" },
          "pause_after_trial": { "type": "boolean" },
          "sync_frequency": { "type": "integer", "description": "Sync frequency in minutes" },
          "group_id": { "type": "string" },
          "connected_by": { "type": "string", "description": "User ID of connection creator" },
          "created_at": { "type": "string", "format": "date-time" },
          "succeeded_at": { "type": "string", "format": "date-time" },
          "failed_at": { "type": "string", "format": "date-time" },
          "schedule_type": {
            "type": "string",
            "enum": ["auto", "manual"]
          },
          "daily_sync_time": { "type": "string", "description": "Sync start time for 1440-minute frequency (HH:00)" },
          "data_delay_sensitivity": {
            "type": "string",
            "enum": ["LOW", "NORMAL", "HIGH", "CUSTOM", "SYNC_FREQUENCY"]
          },
          "data_delay_threshold": { "type": "integer" },
          "status": { "$ref": "#/components/schemas/ConnectionStatus" },
          "setup_tests": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SetupTest" }
          },
          "config": {
            "type": "object",
            "description": "Service-specific connection configuration"
          },
          "connect_card": {
            "type": "object",
            "properties": {
              "token": { "type": "string" },
              "uri": { "type": "string" }
            }
          }
        }
      },
      "ConnectionStatus": {
        "type": "object",
        "properties": {
          "setup_state": {
            "type": "string",
            "enum": ["incomplete", "connected", "broken"]
          },
          "sync_state": {
            "type": "string",
            "enum": ["scheduled", "syncing", "paused", "rescheduled"]
          },
          "update_state": {
            "type": "string",
            "enum": ["on_schedule", "delayed"]
          },
          "is_historical_sync": { "type": "boolean" },
          "rescheduled_for": { "type": "string", "format": "date-time" },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "details": { "type": "object" }
              }
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "details": { "type": "object" }
              }
            }
          },
          "schema_status": { "type": "string" }
        }
      },
      "SetupTest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["PASSED", "SKIPPED", "WARNING", "FAILED", "JOB_FAILED"]
          },
          "message": { "type": "string" },
          "details": { "type": "object" }
        }
      },
      "CreateConnectionRequest": {
        "type": "object",
        "required": ["group_id", "service", "config"],
        "properties": {
          "group_id": { "type": "string", "description": "Target group identifier" },
          "service": { "type": "string", "description": "Connector type name" },
          "config": {
            "type": "object",
            "description": "Service-specific configuration including required 'schema' field",
            "properties": {
              "schema": { "type": "string", "description": "Destination schema name (permanent)" }
            },
            "required": ["schema"]
          },
          "paused": { "type": "boolean" },
          "pause_after_trial": { "type": "boolean" },
          "sync_frequency": {
            "type": "integer",
            "enum": [1, 5, 15, 30, 60, 120, 180, 360, 480, 720, 1440]
          },
          "daily_sync_time": { "type": "string" },
          "schedule_type": { "type": "string", "enum": ["auto", "manual"] },
          "data_delay_sensitivity": { "type": "string", "enum": ["LOW", "NORMAL", "HIGH", "CUSTOM", "SYNC_FREQUENCY"] },
          "data_delay_threshold": { "type": "integer" },
          "destination_schema_names": { "type": "string", "enum": ["FIVETRAN_NAMING", "SOURCE_NAMING"] },
          "trust_certificates": { "type": "boolean" },
          "trust_fingerprints": { "type": "boolean" },
          "run_setup_tests": { "type": "boolean" },
          "proxy_agent_id": { "type": "string" },
          "private_link_id": { "type": "string" },
          "hybrid_deployment_agent_id": { "type": "string" },
          "networking_method": { "type": "string", "enum": ["Directly", "PrivateLink", "SshTunnel", "ProxyAgent"] },
          "connect_card_config": {
            "type": "object",
            "properties": {
              "redirect_uri": { "type": "string" },
              "hide_setup_guide": { "type": "boolean" }
            }
          }
        }
      },
      "UpdateConnectionRequest": {
        "type": "object",
        "properties": {
          "paused": { "type": "boolean" },
          "sync_frequency": { "type": "integer" },
          "daily_sync_time": { "type": "string" },
          "schedule_type": { "type": "string", "enum": ["auto", "manual"] },
          "data_delay_sensitivity": { "type": "string" },
          "data_delay_threshold": { "type": "integer" },
          "trust_certificates": { "type": "boolean" },
          "trust_fingerprints": { "type": "boolean" },
          "run_setup_tests": { "type": "boolean" },
          "config": { "type": "object" },
          "networking_method": { "type": "string" },
          "proxy_agent_id": { "type": "string" },
          "private_link_id": { "type": "string" },
          "hybrid_deployment_agent_id": { "type": "string" }
        }
      },
      "DestinationListResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Destination" }
              },
              "next_cursor": { "type": "string" }
            }
          }
        }
      },
      "DestinationResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/Destination" }
        }
      },
      "Destination": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "service": { "type": "string", "description": "Destination type" },
          "region": { "type": "string" },
          "networking_method": { "type": "string" },
          "setup_status": {
            "type": "string",
            "enum": ["INCOMPLETE", "CONNECTED", "BROKEN"]
          },
          "group_id": { "type": "string" },
          "time_zone_offset": { "type": "string" },
          "daylight_saving_time_enabled": { "type": "boolean" },
          "setup_tests": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SetupTest" }
          },
          "config": { "type": "object", "description": "Destination-specific configuration" }
        }
      },
      "CreateDestinationRequest": {
        "type": "object",
        "required": ["group_id", "service", "time_zone_offset"],
        "properties": {
          "group_id": { "type": "string" },
          "service": { "type": "string" },
          "time_zone_offset": { "type": "string", "description": "UTC offset from -11 to +12" },
          "region": { "type": "string" },
          "trust_certificates": { "type": "boolean" },
          "trust_fingerprints": { "type": "boolean" },
          "run_setup_tests": { "type": "boolean" },
          "daylight_saving_time_enabled": { "type": "boolean" },
          "hybrid_deployment_agent_id": { "type": "string" },
          "private_link_id": { "type": "string" },
          "networking_method": { "type": "string", "enum": ["Directly", "PrivateLink", "SshTunnel", "ProxyAgent"] },
          "proxy_agent_id": { "type": "string" },
          "config": { "type": "object" }
        }
      },
      "UpdateDestinationRequest": {
        "type": "object",
        "properties": {
          "region": { "type": "string" },
          "time_zone_offset": { "type": "string" },
          "daylight_saving_time_enabled": { "type": "boolean" },
          "trust_certificates": { "type": "boolean" },
          "trust_fingerprints": { "type": "boolean" },
          "run_setup_tests": { "type": "boolean" },
          "config": { "type": "object" },
          "networking_method": { "type": "string" },
          "proxy_agent_id": { "type": "string" },
          "private_link_id": { "type": "string" },
          "hybrid_deployment_agent_id": { "type": "string" }
        }
      },
      "GroupListResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Group" }
              },
              "next_cursor": { "type": "string" }
            }
          }
        }
      },
      "GroupResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/Group" }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "UserListResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/User" }
              },
              "next_cursor": { "type": "string" }
            }
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/User" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "given_name": { "type": "string" },
          "family_name": { "type": "string" },
          "verified": { "type": "boolean" },
          "invited": { "type": "boolean" },
          "picture": { "type": "string" },
          "phone": { "type": "string" },
          "role": { "type": "string" },
          "logged_in_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "InviteUserRequest": {
        "type": "object",
        "required": ["email", "role"],
        "properties": {
          "email": { "type": "string" },
          "given_name": { "type": "string" },
          "family_name": { "type": "string" },
          "phone": { "type": "string" },
          "role": { "type": "string" }
        }
      },
      "RoleListResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "is_custom": { "type": "boolean" },
                    "scope": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              },
              "next_cursor": { "type": "string" }
            }
          }
        }
      },
      "TeamListResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Team" }
              },
              "next_cursor": { "type": "string" }
            }
          }
        }
      },
      "TeamResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/Team" }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "role": { "type": "string" }
        }
      },
      "WebhookListResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Webhook" }
              },
              "next_cursor": { "type": "string" }
            }
          }
        }
      },
      "WebhookResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/Webhook" }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["group", "account"] },
          "url": { "type": "string" },
          "events": {
            "type": "array",
            "items": { "type": "string" }
          },
          "active": { "type": "boolean" },
          "secret": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "created_by": { "type": "string" },
          "group_id": { "type": "string" }
        }
      },
      "CreateWebhookRequest": {
        "type": "object",
        "required": ["url", "events"],
        "properties": {
          "url": { "type": "string", "description": "Endpoint URL for webhook event delivery" },
          "events": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Event types triggering the webhook"
          },
          "active": { "type": "boolean" },
          "secret": { "type": "string", "description": "Secret for signing webhook payloads" }
        }
      }
    }
  },
