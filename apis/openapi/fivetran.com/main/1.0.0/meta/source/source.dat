{
  "openapi": "3.1.0",
  "info": {
    "title": "Fivetran REST API",
    "description": "The Fivetran REST API enables you to manage your Fivetran connectors, destinations, groups, users, webhooks, and other resources programmatically.",
    "version": "1.0.0",
    "contact": {
      "name": "Fivetran",
      "url": "https://fivetran.com"
    },
    "x-jentic-source-url": "https://fivetran.com/docs/rest-api"
  },
  "servers": [
    {
      "url": "https://api.fivetran.com/v1",
      "description": "Fivetran API v1"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/account/info": {
      "get": {
        "operationId": "getAccountInfo",
        "summary": "Get Account Info",
        "description": "Returns current account information derived from the API key.",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountInfoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections": {
      "get": {
        "operationId": "listConnections",
        "summary": "List All Connections",
        "description": "Returns a list of all connections within your Fivetran account.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/cursor" },
          { "$ref": "#/components/parameters/limit" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createConnection",
        "summary": "Create a Connection",
        "description": "Creates a new connection within a specified group.",
        "tags": ["Connections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateConnectionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Connection created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/connections/{connectionId}": {
      "get": {
        "operationId": "getConnection",
        "summary": "Retrieve Connection Details",
        "description": "Returns the details of a specified connection.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Connection not found"
          }
        }
      },
      "patch": {
        "operationId": "updateConnection",
        "summary": "Update a Connection",
        "description": "Modifies the configuration, schedule, or pause state of a connection.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateConnectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connection updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Connection not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteConnection",
        "summary": "Delete a Connection",
        "description": "Permanently removes the specified connection.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "responses": {
          "200": {
            "description": "Connection deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          },
          "404": {
            "description": "Connection not found"
          }
        }
      }
    },
    "/connections/{connectionId}/sync": {
      "post": {
        "operationId": "syncConnection",
        "summary": "Trigger Connection Sync",
        "description": "Triggers an incremental data sync for the specified connection.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "responses": {
          "200": {
            "description": "Sync triggered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/resync": {
      "post": {
        "operationId": "resyncConnection",
        "summary": "Trigger Connection Historical Re-sync",
        "description": "Triggers a full historical re-sync for the specified connection.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "responses": {
          "200": {
            "description": "Re-sync triggered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/test": {
      "post": {
        "operationId": "testConnection",
        "summary": "Run Connection Setup Tests",
        "description": "Runs setup tests to validate the connection configuration.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "responses": {
          "200": {
            "description": "Tests completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/state": {
      "get": {
        "operationId": "getConnectionState",
        "summary": "Retrieve Connection State",
        "description": "Returns the current sync state of the specified connection.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateConnectionState",
        "summary": "Update Connection State",
        "description": "Updates the current sync state of the specified connection.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "State updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/connect-card": {
      "post": {
        "operationId": "generateConnectCard",
        "summary": "Generate Connect Card",
        "description": "Generates a Connect Card URI for embedded connector setup.",
        "tags": ["Connections"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "redirect_uri": {
                    "type": "string",
                    "description": "Redirect URI after setup"
                  },
                  "hide_setup_guide": {
                    "type": "boolean",
                    "description": "Whether to hide the setup guide"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connect Card generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/schemas": {
      "get": {
        "operationId": "getConnectionSchema",
        "summary": "Retrieve Connection Schema Config",
        "description": "Returns the schema configuration for the specified connection.",
        "tags": ["Connection Schema"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateConnectionSchema",
        "summary": "Update Connection Schema Config",
        "description": "Updates the schema configuration for the specified connection.",
        "tags": ["Connection Schema"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Schema updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/schemas/reload": {
      "post": {
        "operationId": "reloadConnectionSchema",
        "summary": "Reload Connection Schema Config",
        "description": "Reloads the schema configuration from the source for the specified connection.",
        "tags": ["Connection Schema"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "responses": {
          "200": {
            "description": "Schema reloaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/schemas/{schemaName}": {
      "patch": {
        "operationId": "updateConnectionDatabaseSchema",
        "summary": "Update Connection Database Schema Config",
        "description": "Updates a database schema configuration for the specified connection.",
        "tags": ["Connection Schema"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          {
            "name": "schemaName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The schema name"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Schema updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/schemas/{schemaName}/tables/{tableName}": {
      "patch": {
        "operationId": "updateConnectionTable",
        "summary": "Update Connection Table Config",
        "description": "Updates a table configuration for the specified connection.",
        "tags": ["Connection Schema"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          {
            "name": "schemaName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Table config updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/schemas/{schemaName}/tables/{tableName}/columns/{columnName}": {
      "patch": {
        "operationId": "updateConnectionColumn",
        "summary": "Update Connection Column Config",
        "description": "Updates a column configuration for the specified connection.",
        "tags": ["Connection Schema"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          {
            "name": "schemaName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "columnName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Column config updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/schemas/{schemaName}/tables/{tableName}/resync": {
      "post": {
        "operationId": "resyncConnectionTable",
        "summary": "Re-sync Connection Table Data",
        "description": "Triggers a re-sync for the specified table within the connection.",
        "tags": ["Connection Schema"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          {
            "name": "schemaName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Table re-sync triggered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/schemas/{schemaName}/tables/{tableName}/columns": {
      "get": {
        "operationId": "getSourceTableColumns",
        "summary": "Retrieve Source Table Columns Config",
        "description": "Returns the columns configuration for the specified table.",
        "tags": ["Connection Schema"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          {
            "name": "schemaName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/fingerprints": {
      "get": {
        "operationId": "listConnectionFingerprints",
        "summary": "List Connection Fingerprints",
        "description": "Returns a list of SSH fingerprints for the specified connection.",
        "tags": ["Certificates"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          { "$ref": "#/components/parameters/cursor" },
          { "$ref": "#/components/parameters/limit" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "approveConnectionFingerprint",
        "summary": "Approve Fingerprint for Connection",
        "description": "Approves an SSH fingerprint for the specified connection.",
        "tags": ["Certificates"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "hash": { "type": "string" },
                  "public_key": { "type": "string" }
                },
                "required": ["hash", "public_key"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Fingerprint approved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/fingerprints/{hash}": {
      "get": {
        "operationId": "getConnectionFingerprint",
        "summary": "Get Connection Fingerprint Details",
        "description": "Returns details of a specific SSH fingerprint for the connection.",
        "tags": ["Certificates"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          { "$ref": "#/components/parameters/hash" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "revokeConnectionFingerprint",
        "summary": "Revoke Connection Fingerprint",
        "description": "Revokes an SSH fingerprint for the connection.",
        "tags": ["Certificates"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          { "$ref": "#/components/parameters/hash" }
        ],
        "responses": {
          "200": {
            "description": "Fingerprint revoked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/certificates": {
      "get": {
        "operationId": "listConnectionCertificates",
        "summary": "List Connection Certificates",
        "description": "Returns a list of SSL certificates for the specified connection.",
        "tags": ["Certificates"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          { "$ref": "#/components/parameters/cursor" },
          { "$ref": "#/components/parameters/limit" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "approveConnectionCertificate",
        "summary": "Approve Certificate for Connection",
        "description": "Approves an SSL certificate for the specified connection.",
        "tags": ["Certificates"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "hash": { "type": "string" },
                  "encoded_cert": { "type": "string" }
                },
                "required": ["hash", "encoded_cert"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Certificate approved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/connections/{connectionId}/certificates/{hash}": {
      "get": {
        "operationId": "getConnectionCertificate",
        "summary": "Get Connection Certificate Details",
        "description": "Returns details of a specific SSL certificate for the connection.",
        "tags": ["Certificates"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          { "$ref": "#/components/parameters/hash" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "revokeConnectionCertificate",
        "summary": "Revoke Connection Certificate",
        "description": "Revokes an SSL certificate for the connection.",
        "tags": ["Certificates"],
        "parameters": [
          { "$ref": "#/components/parameters/connectionId" },
          { "$ref": "#/components/parameters/hash" }
        ],
        "responses": {
          "200": {
            "description": "Certificate revoked",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/destinations": {
      "get": {
        "operationId": "listDestinations",
        "summary": "List All Destinations",
        "description": "Returns a list of all destinations within your Fivetran account.",
        "tags": ["Destinations"],
        "parameters": [
          { "$ref": "#/components/parameters/cursor" },
          { "$ref": "#/components/parameters/limit" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DestinationListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createDestination",
        "summary": "Create a Destination",
        "description": "Creates a new destination within a specified group.",
        "tags": ["Destinations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDestinationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Destination created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DestinationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/destinations/{destinationId}": {
      "get": {
        "operationId": "getDestination",
        "summary": "Retrieve Destination Details",
        "description": "Returns the details of a specified destination.",
        "tags": ["Destinations"],
        "parameters": [
          { "$ref": "#/components/parameters/destinationId" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DestinationResponse"
                }
              }
            }
          },
          "404": {
            "description": "Destination not found"
          }
        }
      },
      "patch": {
        "operationId": "updateDestination",
        "summary": "Update a Destination",
        "description": "Modifies the configuration of the specified destination.",
        "tags": ["Destinations"],
        "parameters": [
          { "$ref": "#/components/parameters/destinationId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDestinationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Destination updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DestinationResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteDestination",
        "summary": "Delete a Destination",
        "description": "Permanently removes the specified destination.",
        "tags": ["Destinations"],
        "parameters": [
          { "$ref": "#/components/parameters/destinationId" }
        ],
        "responses": {
          "200": {
            "description": "Destination deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
    "/destinations/{destinationId}/test": {
      "post": {
