        "tags": ["Press Releases"],
        "summary": "Get press release",
        "operationId": "getPressRelease",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PressRelease"}}}}
