  "servers": [{"url": "https://api.pr.co/v1/pressrooms/{pressroom_id}"}],
  "security": [{"ApiKeyAuth": []}],
  "tags": [
    {"name": "Press Releases", "description": "Press release management"},
    {"name": "Clippings", "description": "Media clippings"},
    {"name": "Events", "description": "Event management"},
    {"name": "Media Kits", "description": "Media kit resources"},
    {"name": "Contacts", "description": "Spokesperson contacts"},
    {"name": "Search", "description": "Search operations"}
  ],
