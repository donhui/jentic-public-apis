  "components": {
    "schemas": {
      "Analytics": {
        "properties": {
          "wfOrgId": {
            "title": "Wforgid",
            "type": "string",
            "nullable": true
          },
          "organizationId": {
            "title": "Organizationid",
            "description": "studio organization id",
            "example": "1",
            "type": "string",
            "nullable": true
          },
          "wfGalleryId": {
            "title": "Wfgalleryid",
            "type": "string",
            "nullable": true
          },
          "wfAssistantId": {
            "title": "Wfassistantid",
            "type": "string",
            "nullable": true
          },
          "userId": {
            "title": "Userid",
            "type": "string",
            "nullable": true
          }
        },
        "type": "object",
        "title": "Analytics"
      },
      "AuthSettings": {
        "properties": {
          "require_wf_org_authentication": {
            "type": "boolean",
            "title": "Require Wf Org Authentication",
            "default": false
          }
        },
        "type": "object",
        "title": "AuthSettings"
      },
      "DigitalPerson": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "image": {
            "type": "string",
            "title": "Image"
          },
          "transparent_image": {
            "type": "string",
            "title": "Transparent Image"
          },
          "avatar_image": {
            "type": "string",
            "title": "Avatar Image"
          },
          "image_jpg": {
            "type": "string",
            "title": "Image Jpg"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "image",
          "transparent_image",
          "avatar_image",
          "image_jpg"
        ],
        "title": "DigitalPerson"
      },
      "GeneratorRequest": {
        "properties": {
          "name": {
            "title": "Name",
            "description": "The display name for the Digital Person in the conversation (e.g., 'Sarah'). If not provided, a default based on the avatar is used.",
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "title": "Role",
            "description": "The role the Digital Person will play (e.g., 'Customer Service Agent', 'Product Advisor')."
          },
          "tone": {
            "title": "Tone",
            "description": "The desired conversational tone for the Digital Person (e.g., 'Friendly'). Friendly is the default tone.",
            "type": "string",
            "nullable": true
          },
          "objectives": {
            "title": "Objectives",
            "description": "A list of high-level objectives for the conversation to be executed in order (e.g., 'Collect user feedback', 'Troubleshoot an issue').",
            "default": [],
            "items": {
              "type": "string"
            },
            "type": "array",
            "nullable": true
          },
          "auto_end_session": {
            "title": "Auto End Session",
            "description": "Automatically end the session after the last objective is completed. If not provided, defaults to True if objectives are present otherwise, defaults to False.",
            "type": "boolean",
            "nullable": true
          },
          "results": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Results",
            "description": "A dictionary defining the key pieces of information the Digital Person should aim to collect or provide. Keys are identifiers, values are descriptions (e.g., {'user_email': 'The user's email address'})."
          },
          "parameters": {
            "title": "Parameters",
            "description": "Optional parameters to be passed through to the webhook triggered at the end of the interaction.",
            "default": {},
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "nullable": true
          },
          "event": {
            "title": "Event",
            "description": "An optional event name. If provided, a trigger with this name will be created/updated with sample data based on the 'results'.",
            "type": "string",
            "nullable": true
          },
          "purpose": {
            "type": "string",
            "title": "Purpose",
            "description": "A detailed description of the overall purpose of this Digital Person interaction. This will be used to generate the system prompt."
          },
          "context": {
            "title": "Context",
            "description": "Key-value pairs providing additional context for the AI to understand its environment or constraints or additional information.  This will be added with no changes as context to the system prompt.(e.g., {'Onboarding Information': 'information goes here'}).",
            "default": {},
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "nullable": true
          },
          "knowledge_snippet": {
            "title": "Knowledge Snippet",
            "description": "An optional knowledge snippet that will be added directly to the Digital Person's interaction system prompt. This should be short and brief",
            "type": "string",
            "nullable": true
          },
          "context_mapping": {
            "title": "Context Mapping",
            "description": "Optional input mapping for context field.",
            "default": {},
            "additionalProperties": {
              "additionalProperties": {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              "type": "object"
            },
            "type": "object",
            "nullable": true
          },
          "results_mapping": {
            "title": "Results Mapping",
            "description": "Optional output mapping for results field.",
            "default": {},
            "additionalProperties": {
              "additionalProperties": {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              "type": "object"
            },
            "type": "object",
            "nullable": true
          },
          "base_web_url": {
            "title": "Base Web Url",
            "description": "The base URL for constructing the interaction URL. Defaults to environment setting.",
            "default": "https://workforce.soulmachines.com",
            "type": "string",
            "nullable": true
          },
          "user_id": {
            "title": "User Id",
            "description": "An identifier for the user initiating the generation request.",
            "type": "string",
            "nullable": true
          },
          "avatar": {
            "title": "Avatar",
            "description": "The avatar look for the Digital Person. This will be used to choose the avatars look from a well known set of avatars. (default to '{DEFAULT_AVATAR}')",
            "default": "",
            "type": "string",
            "nullable": true
          },
          "style_id": {
            "title": "Style Id",
            "type": "string",
            "nullable": true
          },
          "template_id": {
            "title": "Template Id",
            "description": "template to use as a base for the interaction",
            "example": "",
            "type": "string",
            "nullable": true
          },
          "voice_id": {
            "title": "Voice Id",
            "type": "string",
            "nullable": true
          },
          "response_length": {
            "default": "moderate",
            "$ref": "#/components/schemas/ResponseLength",
            "nullable": true
          },
          "timezone": {
            "title": "Timezone",
            "description": "The timezone for the interaction, if specific timing is relevant (e.g., 'America/New_York').",
            "default": "NONE",
            "type": "string",
            "nullable": true
          },
          "webhook": {
            "description": "Optional direct webhook configuration to be called upon interaction completion, bypassing named triggers.",
            "$ref": "#/components/schemas/Webhook",
            "nullable": true
          },
          "model": {
            "title": "Model",
            "default": "gpt-4.1",
            "type": "string",
            "nullable": true
          },
          "timeout_secs": {
            "title": "Timeout Secs",
            "description": "The timeout to wait for the interaction to be fully created in seconds, default is 20 seconds. Even if 0 seconds is given a valid URL is still returned that will wait for the interaction to be created as needed.",
            "default": 20,
            "type": "integer",
            "nullable": true
          },
          "ttl_seconds": {
            "title": "Ttl Seconds",
            "description": "Optional TTL in seconds for the interaction record. If 0 or negative, the record will not expire. If None, a default TTL will be applied.",
            "type": "integer",
            "nullable": true
          },
          "auth_settings": {
            "description": "Optional authentication settings for the interaction. If not provided, the authentication settings from the template will be used.",
            "$ref": "#/components/schemas/AuthSettings",
            "nullable": true
          },
          "welcome_message": {
            "title": "Welcome Message",
            "description": "An optional welcome message for the interaction. If not provided, the AI-generated welcome message will be used.",
            "type": "string",
            "nullable": true
          },
          "topics_to_avoid": {
            "title": "Topics To Avoid",
            "description": "An optional list of topics to avoid in the interaction. If provided, the agent will avoid these topics in the interaction.",
            "type": "string",
            "nullable": true
          },
          "allowed_domains": {
            "title": "Allowed Domains",
            "description": "List of allowed origin URLs that can use this interaction (e.g., ['https://example.com', 'http://localhost:3000']). If None, no origin restrictions apply.",
            "items": {
              "type": "string"
            },
            "type": "array",
            "nullable": true
          }
        },
        "type": "object",
        "required": [
          "role",
          "results",
          "purpose"
        ],
        "title": "GeneratorRequest",
        "description": "Request body for the generator endpoint, detailing the desired interaction to be created."
      },
