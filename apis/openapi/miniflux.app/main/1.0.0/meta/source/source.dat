{
  "openapi": "3.0.3",
  "info": {
    "title": "Miniflux API",
    "version": "1.0.0",
    "description": "Miniflux is a minimalist and opinionated feed reader. This API allows managing feeds, entries, categories, users, and API keys programmatically.",
    "x-jentic-source-url": "https://miniflux.app/docs/api.html"
  },
  "servers": [
    {
      "url": "https://miniflux.example.org/v1",
      "description": "Miniflux API server (replace with your instance URL)"
    }
  ],
  "paths": {
    "/discover": {
      "post": {
        "operationId": "discoverSubscriptions",
        "summary": "Discover subscriptions",
        "description": "Discover RSS/Atom feeds from a website URL.",
        "tags": ["Discovery"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url"],
                "properties": {
                  "url": { "type": "string", "description": "Website URL to discover feeds from" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of discovered feeds",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DiscoveredFeed" }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/flush-history": {
      "put": {
        "operationId": "flushHistory",
        "summary": "Flush read history",
        "description": "Flush the history of read entries. Also supports DELETE method.",
        "tags": ["Entries"],
        "responses": {
          "202": { "description": "History flushed successfully" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteHistory",
        "summary": "Delete read history",
        "description": "Delete the history of read entries.",
        "tags": ["Entries"],
        "responses": {
          "202": { "description": "History deleted successfully" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/feeds": {
      "get": {
        "operationId": "listFeeds",
        "summary": "Get all feeds",
        "description": "Returns all feeds for the authenticated user.",
        "tags": ["Feeds"],
        "responses": {
          "200": {
            "description": "List of feeds",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Feed" }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createFeed",
        "summary": "Create a feed",
        "description": "Subscribe to a new feed.",
        "tags": ["Feeds"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["feed_url"],
                "properties": {
                  "feed_url": { "type": "string", "description": "Feed URL" },
                  "category_id": { "type": "integer", "description": "Category ID (optional since Miniflux >= 2.0.49)" },
                  "username": { "type": "string", "description": "Feed username for authentication" },
                  "password": { "type": "string", "description": "Feed password for authentication" },
                  "crawler": { "type": "boolean", "description": "Enable content scraping" },
                  "user_agent": { "type": "string", "description": "Custom user agent" },
                  "scraper_rules": { "type": "string", "description": "Custom scraper rules" },
                  "rewrite_rules": { "type": "string", "description": "Custom rewrite rules" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feed created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "feed_id": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/feeds/{feedId}": {
      "get": {
        "operationId": "getFeed",
        "summary": "Get a feed",
        "description": "Returns a single feed by its ID.",
        "tags": ["Feeds"],
        "parameters": [
          { "name": "feedId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Feed details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Feed" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Feed not found" }
        }
      },
      "put": {
        "operationId": "updateFeed",
        "summary": "Update a feed",
        "description": "Update an existing feed.",
        "tags": ["Feeds"],
        "parameters": [
          { "name": "feedId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "category_id": { "type": "integer" },
                  "feed_url": { "type": "string" },
                  "site_url": { "type": "string" },
                  "scraper_rules": { "type": "string" },
                  "rewrite_rules": { "type": "string" },
                  "crawler": { "type": "boolean" },
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "user_agent": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated feed",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Feed" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Feed not found" }
        }
      },
      "delete": {
        "operationId": "deleteFeed",
        "summary": "Delete a feed",
        "description": "Remove a feed subscription.",
        "tags": ["Feeds"],
        "parameters": [
          { "name": "feedId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Feed deleted" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Feed not found" }
        }
      }
    },
    "/feeds/{feedId}/refresh": {
      "put": {
        "operationId": "refreshFeed",
        "summary": "Refresh a feed",
        "description": "Refresh a specific feed. This is a synchronous operation.",
        "tags": ["Feeds"],
        "parameters": [
          { "name": "feedId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Feed refreshed" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Feed not found" }
        }
      }
    },
    "/feeds/refresh": {
      "put": {
        "operationId": "refreshAllFeeds",
        "summary": "Refresh all feeds",
        "description": "Refresh all feeds in the background.",
        "tags": ["Feeds"],
        "responses": {
          "204": { "description": "All feeds refresh initiated" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/feeds/{feedId}/icon": {
      "get": {
        "operationId": "getFeedIcon",
        "summary": "Get feed icon by feed ID",
        "description": "Returns the icon/favicon for a feed.",
        "tags": ["Feeds"],
        "parameters": [
          { "name": "feedId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Feed icon",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Icon" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "No icon for this feed" }
        }
      }
    },
    "/feeds/{feedId}/mark-all-as-read": {
      "put": {
        "operationId": "markFeedAsRead",
        "summary": "Mark feed entries as read",
        "description": "Mark all entries for a feed as read.",
        "tags": ["Feeds"],
        "parameters": [
          { "name": "feedId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Entries marked as read" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Feed not found" }
        }
      }
    },
    "/feeds/{feedId}/entries/{entryId}": {
      "get": {
        "operationId": "getFeedEntry",
        "summary": "Get a feed entry",
        "description": "Returns a single entry from a specific feed.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "feedId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "entryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Entry details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Entry" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Entry not found" }
        }
      }
    },
    "/feeds/{feedId}/entries": {
      "get": {
        "operationId": "listFeedEntries",
        "summary": "Get feed entries",
        "description": "Returns entries for a specific feed with pagination.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "feedId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["read", "unread", "removed"] } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["id", "status", "published_at", "created_at", "category_title", "category_id"] } },
          { "name": "direction", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] } }
        ],
        "responses": {
          "200": {
            "description": "Paginated entry list",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EntryList" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Feed not found" }
        }
      }
    },
    "/entries/{entryId}": {
      "get": {
        "operationId": "getEntry",
        "summary": "Get an entry",
        "description": "Returns a single entry by its ID.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "entryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Entry details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Entry" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Entry not found" }
        }
      },
      "put": {
        "operationId": "updateEntry",
        "summary": "Update an entry",
        "description": "Update entry fields such as title or content.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "entryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Entry updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Entry not found" }
        }
      }
    },
    "/entries/{entryId}/save": {
      "post": {
        "operationId": "saveEntryToThirdParty",
        "summary": "Save entry to third-party services",
        "description": "Send the entry to configured third-party services (e.g. Wallabag, Pinboard).",
        "tags": ["Entries"],
        "parameters": [
          { "name": "entryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "202": { "description": "Accepted" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Entry not found" }
        }
      }
    },
    "/entries/{entryId}/fetch-content": {
      "get": {
        "operationId": "fetchEntryContent",
        "summary": "Fetch original article content",
        "description": "Fetch the original article content for an entry.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "entryId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "update_content", "in": "query", "description": "If true, update the entry content in the database", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Fetched content",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "content": { "type": "string" } } } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Entry not found" }
        }
      }
    },
    "/entries/{entryId}/bookmark": {
      "put": {
        "operationId": "toggleEntryBookmark",
        "summary": "Toggle entry bookmark",
        "description": "Toggle the bookmark/starred status of an entry.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "entryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Bookmark toggled" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Entry not found" }
        }
      }
    },
    "/entries": {
      "get": {
        "operationId": "listEntries",
        "summary": "Get entries",
        "description": "Returns entries across all feeds with optional filtering and pagination.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["read", "unread", "removed"] } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["id", "status", "published_at", "created_at", "category_title", "category_id"] } },
          { "name": "direction", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] } },
          { "name": "before", "in": "query", "description": "Unix timestamp to filter entries before this date", "schema": { "type": "integer" } },
          { "name": "after", "in": "query", "description": "Unix timestamp to filter entries after this date", "schema": { "type": "integer" } },
          { "name": "published_before", "in": "query", "description": "Unix timestamp to filter by publish date", "schema": { "type": "integer" } },
          { "name": "published_after", "in": "query", "description": "Unix timestamp to filter by publish date", "schema": { "type": "integer" } },
          { "name": "changed_before", "in": "query", "description": "Unix timestamp to filter by change date", "schema": { "type": "integer" } },
          { "name": "changed_after", "in": "query", "description": "Unix timestamp to filter by change date", "schema": { "type": "integer" } },
          { "name": "before_entry_id", "in": "query", "description": "Filter entries before this entry ID", "schema": { "type": "integer" } },
          { "name": "after_entry_id", "in": "query", "description": "Filter entries after this entry ID", "schema": { "type": "integer" } },
          { "name": "starred", "in": "query", "description": "Filter starred entries", "schema": { "type": "boolean" } },
          { "name": "search", "in": "query", "description": "Full-text search query", "schema": { "type": "string" } },
          { "name": "category_id", "in": "query", "description": "Filter by category ID", "schema": { "type": "integer" } },
          { "name": "globally_visible", "in": "query", "description": "Filter globally visible entries", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated entry list",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EntryList" } } }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateEntries",
        "summary": "Update entries status",
        "description": "Bulk update the status of multiple entries.",
        "tags": ["Entries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["entry_ids", "status"],
                "properties": {
                  "entry_ids": { "type": "array", "items": { "type": "integer" } },
                  "status": { "type": "string", "enum": ["read", "unread"] }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Entries updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/categories/{categoryId}/entries": {
      "get": {
        "operationId": "listCategoryEntries",
        "summary": "Get category entries",
        "description": "Returns entries for a specific category.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "categoryId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["read", "unread", "removed"] } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "schema": { "type": "string" } },
          { "name": "direction", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] } }
        ],
        "responses": {
          "200": {
            "description": "Paginated entry list",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EntryList" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Category not found" }
        }
      }
    },
    "/categories/{categoryId}/feeds": {
      "get": {
        "operationId": "listCategoryFeeds",
        "summary": "Get category feeds",
        "description": "Returns feeds in a specific category.",
        "tags": ["Categories"],
        "parameters": [
          { "name": "categoryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of feeds",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Feed" } } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Category not found" }
        }
      }
    },
    "/categories": {
      "get": {
        "operationId": "listCategories",
        "summary": "Get categories",
        "description": "Returns all categories for the authenticated user.",
        "tags": ["Categories"],
        "parameters": [
          { "name": "counts", "in": "query", "description": "Include feed counts per category", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "List of categories",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } } } }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createCategory",
        "summary": "Create a category",
        "description": "Create a new category.",
        "tags": ["Categories"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Category created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Category" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/categories/{categoryId}": {
      "put": {
        "operationId": "updateCategory",
        "summary": "Update a category",
        "description": "Update an existing category.",
        "tags": ["Categories"],
        "parameters": [
          { "name": "categoryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated category",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Category" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Category not found" }
        }
      },
      "delete": {
        "operationId": "deleteCategory",
        "summary": "Delete a category",
        "description": "Delete a category. Feeds in this category will be moved to another category.",
        "tags": ["Categories"],
        "parameters": [
          { "name": "categoryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Category deleted" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Category not found" }
        }
      }
    },
    "/categories/{categoryId}/refresh": {
      "put": {
        "operationId": "refreshCategoryFeeds",
        "summary": "Refresh category feeds",
        "description": "Refresh all feeds in a category.",
        "tags": ["Categories"],
        "parameters": [
          { "name": "categoryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Refresh initiated" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Category not found" }
        }
      }
    },
    "/categories/{categoryId}/mark-all-as-read": {
      "put": {
        "operationId": "markCategoryAsRead",
        "summary": "Mark category entries as read",
        "description": "Mark all entries in a category as read.",
        "tags": ["Categories"],
        "parameters": [
          { "name": "categoryId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Entries marked as read" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Category not found" }
        }
      }
    },
    "/icons/{iconId}": {
      "get": {
        "operationId": "getIcon",
        "summary": "Get feed icon by icon ID",
        "description": "Returns an icon by its ID.",
        "tags": ["Feeds"],
        "parameters": [
          { "name": "iconId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Icon data",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Icon" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Icon not found" }
        }
      }
    },
    "/enclosures/{enclosureId}": {
      "get": {
        "operationId": "getEnclosure",
        "summary": "Get an enclosure",
        "description": "Returns an enclosure (podcast/media attachment) by its ID.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "enclosureId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Enclosure details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Enclosure" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Enclosure not found" }
        }
      },
      "put": {
        "operationId": "updateEnclosure",
        "summary": "Update an enclosure",
        "description": "Update enclosure metadata.",
        "tags": ["Entries"],
        "parameters": [
          { "name": "enclosureId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "media_progression": { "type": "integer", "description": "Media progression in seconds" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Enclosure updated" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Enclosure not found" }
        }
      }
    },
    "/export": {
      "get": {
        "operationId": "exportOPML",
        "summary": "OPML export",
        "description": "Export all subscriptions as an OPML file.",
        "tags": ["Import/Export"],
        "responses": {
          "200": {
            "description": "OPML file content",
            "content": { "application/xml": { "schema": { "type": "string" } } }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/import": {
      "post": {
        "operationId": "importOPML",
        "summary": "OPML import",
        "description": "Import subscriptions from an OPML file.",
        "tags": ["Import/Export"],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": { "type": "string" }
            }
          }
        },
        "responses": {
          "201": { "description": "Import successful" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "Get all users",
        "description": "Returns all users. Requires admin privileges.",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "List of users",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden - admin only" }
        }
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create a user",
        "description": "Create a new user. Requires admin privileges.",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "is_admin": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden - admin only" }
        }
      }
    },
    "/users/{userId}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get a user",
        "description": "Returns a user by ID or username.",
        "tags": ["Users"],
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "description": "User ID (integer) or username (string)", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "User not found" }
        }
      },
      "put": {
        "operationId": "updateUser",
        "summary": "Update a user",
        "description": "Update user profile settings.",
        "tags": ["Users"],
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "is_admin": { "type": "boolean" },
                  "theme": { "type": "string" },
                  "language": { "type": "string" },
                  "timezone": { "type": "string" },
                  "entry_sorting_direction": { "type": "string" },
                  "entries_per_page": { "type": "integer" },
                  "keyboard_shortcuts": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated user",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" },
          "404": { "description": "User not found" }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete a user",
        "description": "Delete a user. Requires admin privileges.",
        "tags": ["Users"],
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "User deleted" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden - admin only" }
        }
      }
    },
    "/users/{userId}/mark-all-as-read": {
      "put": {
        "operationId": "markUserEntriesAsRead",
