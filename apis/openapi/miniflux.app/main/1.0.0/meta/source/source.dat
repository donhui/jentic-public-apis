        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "Current user details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/feeds/counters": {
      "get": {
        "operationId": "getFeedCounters",
        "summary": "Fetch read/unread counters",
