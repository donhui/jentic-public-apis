{
  "openapi": "3.0.3",
  "info": {
    "title": "Hebcal API",
    "version": "1.0.0",
    "description": "Jewish calendar REST API providing calendar events, holiday information, Shabbat times, zmanim (halachic times), Hebrew date conversion, yahrzeit/anniversary calculations, and Torah reading data. No authentication required.",
    "x-jentic-source-url": "https://www.hebcal.com/home/developer-apis"
  },
  "servers": [
    { "url": "https://www.hebcal.com" }
  ],
  "paths": {
    "/hebcal": {
      "get": {
        "operationId": "getCalendarEvents",
        "summary": "Get Jewish calendar events",
        "description": "Returns Jewish holidays, Torah readings, candle lighting times and other calendar events.",
        "tags": ["Calendar"],
        "parameters": [
          { "name": "v", "in": "query", "required": true, "description": "API version (must be 1)", "schema": { "type": "integer", "enum": [1] } },
          { "name": "cfg", "in": "query", "required": true, "description": "Output format", "schema": { "type": "string", "enum": ["json", "xml", "csv", "ics"] } },
          { "name": "year", "in": "query", "description": "Gregorian year or 'now'", "schema": { "type": "string" } },
          { "name": "month", "in": "query", "description": "Month number (1-12) or 'x' for all", "schema": { "type": "string" } },
          { "name": "maj", "in": "query", "description": "Include major holidays", "schema": { "type": "string", "enum": ["on", "off"] } },
          { "name": "min", "in": "query", "description": "Include minor holidays", "schema": { "type": "string", "enum": ["on", "off"] } },
          { "name": "mod", "in": "query", "description": "Include modern holidays", "schema": { "type": "string", "enum": ["on", "off"] } },
          { "name": "nx", "in": "query", "description": "Include Rosh Chodesh", "schema": { "type": "string", "enum": ["on", "off"] } },
          { "name": "ss", "in": "query", "description": "Include special Shabbatot", "schema": { "type": "string", "enum": ["on", "off"] } },
          { "name": "mf", "in": "query", "description": "Include minor fasts", "schema": { "type": "string", "enum": ["on", "off"] } },
          { "name": "c", "in": "query", "description": "Include candle lighting times", "schema": { "type": "string", "enum": ["on", "off"] } },
          { "name": "geo", "in": "query", "description": "Location type", "schema": { "type": "string", "enum": ["geoname", "zip", "pos"] } },
          { "name": "zip", "in": "query", "description": "US ZIP code", "schema": { "type": "string" } },
          { "name": "geonameid", "in": "query", "description": "GeoNames.org numeric ID", "schema": { "type": "integer" } },
          { "name": "latitude", "in": "query", "schema": { "type": "number" } },
          { "name": "longitude", "in": "query", "schema": { "type": "number" } },
          { "name": "tzid", "in": "query", "description": "Timezone identifier", "schema": { "type": "string" } },
          { "name": "lg", "in": "query", "description": "Language for transliterations", "schema": { "type": "string" } },
          { "name": "s", "in": "query", "description": "Include weekly Torah portion", "schema": { "type": "string", "enum": ["on", "off"] } }
        ],
        "responses": {
          "200": { "description": "Calendar events", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CalendarResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/shabbat": {
      "get": {
        "operationId": "getShabbatTimes",
        "summary": "Get Shabbat candle lighting and havdalah times",
        "description": "Returns Shabbat times for a specific location.",
        "tags": ["Shabbat"],
        "parameters": [
          { "name": "cfg", "in": "query", "required": true, "schema": { "type": "string", "enum": ["json", "xml"] } },
          { "name": "geo", "in": "query", "description": "Location type", "schema": { "type": "string", "enum": ["geoname", "zip", "pos"] } },
          { "name": "zip", "in": "query", "schema": { "type": "string" } },
          { "name": "geonameid", "in": "query", "schema": { "type": "integer" } },
          { "name": "latitude", "in": "query", "schema": { "type": "number" } },
          { "name": "longitude", "in": "query", "schema": { "type": "number" } },
          { "name": "tzid", "in": "query", "schema": { "type": "string" } },
          { "name": "b", "in": "query", "description": "Minutes before sunset for candle lighting", "schema": { "type": "integer", "default": 18 } },
          { "name": "M", "in": "query", "description": "Havdalah minutes after sunset", "schema": { "type": "integer" } },
          { "name": "lg", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Shabbat times", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CalendarResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/zmanim": {
      "get": {
        "operationId": "getZmanim",
        "summary": "Get halachic times (zmanim)",
        "description": "Returns halachic times for a specific date and location including alot hashachar, sunrise, sunset, and more.",
        "tags": ["Zmanim"],
        "parameters": [
          { "name": "cfg", "in": "query", "required": true, "schema": { "type": "string", "enum": ["json", "xml"] } },
          { "name": "date", "in": "query", "description": "Date in YYYY-MM-DD format", "schema": { "type": "string", "format": "date" } },
          { "name": "geo", "in": "query", "schema": { "type": "string", "enum": ["geoname", "zip", "pos"] } },
          { "name": "zip", "in": "query", "schema": { "type": "string" } },
          { "name": "geonameid", "in": "query", "schema": { "type": "integer" } },
          { "name": "latitude", "in": "query", "schema": { "type": "number" } },
          { "name": "longitude", "in": "query", "schema": { "type": "number" } },
          { "name": "elevation", "in": "query", "description": "Elevation in meters", "schema": { "type": "number" } },
          { "name": "tzid", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Halachic times", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ZmanimResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/converter": {
      "get": {
        "operationId": "convertDate",
        "summary": "Convert between Hebrew and Gregorian dates",
        "description": "Converts dates between the Hebrew and Gregorian calendars.",
        "tags": ["Converter"],
        "parameters": [
          { "name": "cfg", "in": "query", "required": true, "schema": { "type": "string", "enum": ["json", "xml"] } },
          { "name": "gy", "in": "query", "description": "Gregorian year", "schema": { "type": "integer" } },
          { "name": "gm", "in": "query", "description": "Gregorian month", "schema": { "type": "integer" } },
          { "name": "gd", "in": "query", "description": "Gregorian day", "schema": { "type": "integer" } },
          { "name": "hy", "in": "query", "description": "Hebrew year", "schema": { "type": "integer" } },
          { "name": "hm", "in": "query", "description": "Hebrew month name", "schema": { "type": "string" } },
          { "name": "hd", "in": "query", "description": "Hebrew day", "schema": { "type": "integer" } },
          { "name": "gs", "in": "query", "description": "Convert from Gregorian to Hebrew if 1, Hebrew to Gregorian if 0", "schema": { "type": "integer", "enum": [0, 1] } }
        ],
        "responses": {
          "200": { "description": "Converted date", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ConverterResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/yahrzeit": {
      "get": {
        "operationId": "getYahrzeit",
        "summary": "Calculate yahrzeit and anniversary dates",
        "description": "Returns 20-year projection of yahrzeit (memorial) or Hebrew anniversary dates.",
        "tags": ["Yahrzeit"],
        "parameters": [
          { "name": "cfg", "in": "query", "required": true, "schema": { "type": "string", "enum": ["json", "xml"] } },
          { "name": "yy", "in": "query", "description": "Year of death/event (Gregorian)", "schema": { "type": "integer" } },
          { "name": "ym", "in": "query", "description": "Month of death/event", "schema": { "type": "integer" } },
          { "name": "yd", "in": "query", "description": "Day of death/event", "schema": { "type": "integer" } },
          { "name": "years", "in": "query", "description": "Number of years to project", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "Yahrzeit dates", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/YahrzeitResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/leyning": {
      "get": {
        "operationId": "getLeyning",
        "summary": "Get Torah reading information",
        "description": "Returns Torah reading (leyning/kriyah) details for Shabbat and holidays.",
        "tags": ["Leyning"],
        "parameters": [
          { "name": "cfg", "in": "query", "required": true, "schema": { "type": "string", "enum": ["json", "xml"] } },
          { "name": "date", "in": "query", "description": "Date in YYYY-MM-DD format", "schema": { "type": "string", "format": "date" } },
          { "name": "lg", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Leyning details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LeyningResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CalendarResponse": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "date": { "type": "string" },
          "location": { "type": "object" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CalendarEvent" } }
        }
      },
      "CalendarEvent": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "date": { "type": "string" },
          "category": { "type": "string" },
          "subcat": { "type": "string" },
          "hebrew": { "type": "string" },
          "link": { "type": "string" },
          "memo": { "type": "string" }
        }
      },
      "ZmanimResponse": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "location": { "type": "object" },
          "times": {
            "type": "object",
            "properties": {
              "alotHaShachar": { "type": "string" },
              "misheyakir": { "type": "string" },
              "sunrise": { "type": "string" },
              "sofZmanShma": { "type": "string" },
              "sofZmanTfilla": { "type": "string" },
              "chatzot": { "type": "string" },
              "minchaGedola": { "type": "string" },
              "minchaKetana": { "type": "string" },
              "plagHaMincha": { "type": "string" },
              "sunset": { "type": "string" },
              "tzeit": { "type": "string" }
            }
          }
        }
      },
      "ConverterResponse": {
        "type": "object",
        "properties": {
          "gy": { "type": "integer", "description": "Gregorian year" },
          "gm": { "type": "integer", "description": "Gregorian month" },
          "gd": { "type": "integer", "description": "Gregorian day" },
          "hy": { "type": "integer", "description": "Hebrew year" },
          "hm": { "type": "string", "description": "Hebrew month name" },
          "hd": { "type": "integer", "description": "Hebrew day" },
          "hebrew": { "type": "string" }
        }
      },
      "YahrzeitResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "date": { "type": "string" },
                "hebrew": { "type": "string" }
              }
            }
          }
        }
      },
      "LeyningResponse": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "parshaName": { "type": "string" },
          "readings": { "type": "object" },
          "haftara": { "type": "string" }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}
