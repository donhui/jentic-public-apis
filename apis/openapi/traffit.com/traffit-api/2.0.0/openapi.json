{
  "openapi": "3.0.3",
  "info": {
    "title": "TRAFFIT API",
    "version": "2.0.0",
    "description": "TRAFFIT Applicant Tracking System Integration API. Manage candidates, jobs, clients, CRM contacts, webhooks, users, sources, workflows, and more.",
    "x-jentic-source-url": "https://api.traffit.com/"
  },
  "servers": [{"url": "https://www.{traffit_name}.traffit.com", "variables": {"traffit_name": {"default": "example", "description": "Your TRAFFIT instance name"}}}],
  "paths": {
    "/oauth2/token": {"post": {"operationId": "generateToken", "summary": "Generate access token", "tags": ["Authentication"], "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"client_id": {"type": "string"}, "client_secret": {"type": "string"}, "grant_type": {"type": "string"}, "scope": {"type": "string"}}}}}}, "responses": {"200": {"description": "Token generated"}, "400": {"description": "Bad request"}}}},
    "/public/job_posts/published": {"get": {"operationId": "listPublishedJobPosts", "summary": "List published job posts", "tags": ["Public"], "responses": {"200": {"description": "Job posts list"}, "400": {"description": "Bad request"}}}},
    "/api/integration/v2/webhooks/": {"post": {"operationId": "registerWebhook", "summary": "Register webhook", "tags": ["Webhooks"], "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["type", "url"], "properties": {"type": {"type": "string"}, "url": {"type": "string"}}}}}}, "responses": {"201": {"description": "Created"}, "400": {"description": "Bad request"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/webhooks/{webhook_id}": {"delete": {"operationId": "removeWebhook", "summary": "Remove webhook", "tags": ["Webhooks"], "parameters": [{"name": "webhook_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"204": {"description": "Deleted"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/webhooks/types": {"get": {"operationId": "getWebhookTypes", "summary": "Get webhook types", "tags": ["Webhooks"], "responses": {"200": {"description": "Webhook types"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/employees/": {
      "get": {"operationId": "listCandidates", "summary": "List candidates", "tags": ["Candidates"], "responses": {"200": {"description": "Candidate list"}, "400": {"description": "Bad request"}, "401": {"description": "Unauthorized"}}},
      "post": {"operationId": "createCandidate", "summary": "Create candidate", "tags": ["Candidates"], "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"201": {"description": "Created"}, "400": {"description": "Bad request"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/employees/{employee_id}": {
      "get": {"operationId": "getCandidate", "summary": "Get candidate", "tags": ["Candidates"], "parameters": [{"name": "employee_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Candidate details"}, "401": {"description": "Unauthorized"}}},
      "put": {"operationId": "updateCandidate", "summary": "Update candidate", "tags": ["Candidates"], "parameters": [{"name": "employee_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"200": {"description": "Updated"}, "401": {"description": "Unauthorized"}}},
      "patch": {"operationId": "patchCandidate", "summary": "Patch candidate fields", "tags": ["Candidates"], "parameters": [{"name": "employee_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"200": {"description": "Patched"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/employees/{employee_id}/tags": {
      "get": {"operationId": "getCandidateTags", "summary": "Get candidate tags", "tags": ["Candidates"], "parameters": [{"name": "employee_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Tags"}, "401": {"description": "Unauthorized"}}},
      "patch": {"operationId": "addCandidateTags", "summary": "Add tags to candidate", "tags": ["Candidates"], "parameters": [{"name": "employee_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object", "properties": {"tags": {"type": "array", "items": {"type": "string"}}}}}}}, "responses": {"200": {"description": "Tags added"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/employees/{employee_id}/files/": {"post": {"operationId": "addCandidateFile", "summary": "Add file to candidate", "tags": ["Candidates"], "parameters": [{"name": "employee_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"multipart/form-data": {"schema": {"type": "object", "properties": {"file[file]": {"type": "string", "format": "binary"}, "file[isPublic]": {"type": "boolean"}, "dictionary_file_type": {"type": "string"}}}}}}, "responses": {"201": {"description": "File added"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/employees/{employee_id}/recruitments": {"get": {"operationId": "getCandidateJobs", "summary": "Get candidate jobs", "tags": ["Candidates"], "parameters": [{"name": "employee_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Job list"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/employees/{employee_id}/activities": {"get": {"operationId": "getCandidateActivities", "summary": "Get candidate activities", "tags": ["Candidates"], "parameters": [{"name": "employee_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Activities"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/recruitments/": {
      "get": {"operationId": "listJobs", "summary": "List jobs", "tags": ["Jobs"], "responses": {"200": {"description": "Job list"}, "401": {"description": "Unauthorized"}}},
      "post": {"operationId": "createJob", "summary": "Create job", "tags": ["Jobs"], "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"201": {"description": "Created"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/recruitments/{recruitment_id}": {
      "get": {"operationId": "getJob", "summary": "Get job", "tags": ["Jobs"], "parameters": [{"name": "recruitment_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Job details"}, "401": {"description": "Unauthorized"}}},
      "patch": {"operationId": "updateJob", "summary": "Update job", "tags": ["Jobs"], "parameters": [{"name": "recruitment_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"200": {"description": "Updated"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/recruitments/{recruitment_id}/employees": {
      "get": {"operationId": "getJobCandidates", "summary": "Get candidates from job", "tags": ["Jobs"], "parameters": [{"name": "recruitment_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Candidate list"}, "401": {"description": "Unauthorized"}}},
      "post": {"operationId": "addCandidateToJob", "summary": "Add candidate to job", "tags": ["Jobs"], "parameters": [{"name": "recruitment_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"201": {"description": "Added"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/recruitments/{recruitment_id}/states": {"get": {"operationId": "getJobStates", "summary": "Get job states", "tags": ["Jobs"], "parameters": [{"name": "recruitment_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "State list"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/clients/": {
      "get": {"operationId": "listClients", "summary": "List clients", "tags": ["Clients"], "responses": {"200": {"description": "Client list"}, "401": {"description": "Unauthorized"}}},
      "post": {"operationId": "createClient", "summary": "Create client", "tags": ["Clients"], "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"201": {"description": "Created"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/clients/{client_id}": {
      "get": {"operationId": "getClient", "summary": "Get client", "tags": ["Clients"], "parameters": [{"name": "client_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Client details"}, "401": {"description": "Unauthorized"}}},
      "put": {"operationId": "updateClient", "summary": "Update client", "tags": ["Clients"], "parameters": [{"name": "client_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"200": {"description": "Updated"}, "401": {"description": "Unauthorized"}}},
      "patch": {"operationId": "patchClient", "summary": "Patch client fields", "tags": ["Clients"], "parameters": [{"name": "client_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"200": {"description": "Patched"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/users/": {
      "get": {"operationId": "listUsers", "summary": "List users", "tags": ["Users"], "responses": {"200": {"description": "User list"}, "401": {"description": "Unauthorized"}}},
      "post": {"operationId": "createUser", "summary": "Create user", "tags": ["Users"], "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"201": {"description": "Created"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/users/{user_id}": {
      "get": {"operationId": "getUser", "summary": "Get user", "tags": ["Users"], "parameters": [{"name": "user_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "User details"}, "401": {"description": "Unauthorized"}}},
      "patch": {"operationId": "updateUser", "summary": "Update user", "tags": ["Users"], "parameters": [{"name": "user_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"200": {"description": "Updated"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/sources/": {"get": {"operationId": "listSources", "summary": "List sources", "tags": ["Sources"], "responses": {"200": {"description": "Source list"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/sources/{source_id}": {
      "get": {"operationId": "getSource", "summary": "Get source", "tags": ["Sources"], "parameters": [{"name": "source_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Source details"}, "401": {"description": "Unauthorized"}}},
      "put": {"operationId": "updateSource", "summary": "Update source", "tags": ["Sources"], "parameters": [{"name": "source_id", "in": "path", "required": true, "schema": {"type": "string"}}], "requestBody": {"content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"200": {"description": "Updated"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/workflows/": {"get": {"operationId": "listWorkflows", "summary": "List workflows", "tags": ["Workflows"], "responses": {"200": {"description": "Workflow list"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/dictionaries/": {"get": {"operationId": "listDictionaries", "summary": "List dictionaries", "tags": ["Dictionaries"], "responses": {"200": {"description": "Dictionary list"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/dictionaries/{dictionary_id}/items": {"get": {"operationId": "getDictionaryItems", "summary": "Get dictionary items", "tags": ["Dictionaries"], "parameters": [{"name": "dictionary_id", "in": "path", "required": true, "schema": {"type": "string"}}], "responses": {"200": {"description": "Items"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/provisions/": {"get": {"operationId": "listProvisions", "summary": "List provisions", "tags": ["Provisions"], "responses": {"200": {"description": "Provision list"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/provisions/types": {"get": {"operationId": "getProvisionTypes", "summary": "Get provision types", "tags": ["Provisions"], "responses": {"200": {"description": "Types"}, "401": {"description": "Unauthorized"}}}},
    "/api/integration/v2/talents/": {
      "get": {"operationId": "listTalents", "summary": "List talents", "tags": ["Talents"], "responses": {"200": {"description": "Talent list"}, "401": {"description": "Unauthorized"}}},
      "post": {"operationId": "createTalent", "summary": "Create talent", "tags": ["Talents"], "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}}, "responses": {"201": {"description": "Created"}, "401": {"description": "Unauthorized"}}}
    },
    "/api/integration/v2/files/upload": {"post": {"operationId": "uploadFile", "summary": "Upload file", "tags": ["Files"], "requestBody": {"content": {"multipart/form-data": {"schema": {"type": "object", "properties": {"file": {"type": "string", "format": "binary"}}}}}}, "responses": {"201": {"description": "Uploaded"}, "401": {"description": "Unauthorized"}}}}
  },
  "components": {
    "schemas": {
      "ErrorResponse": {"type": "object", "properties": {"error": {"type": "string"}, "message": {"type": "string"}}}
    },
    "securitySchemes": {
      "oauth2": {"type": "oauth2", "flows": {"clientCredentials": {"tokenUrl": "/oauth2/token", "scopes": {"employee": "Candidate management", "recruitment": "Job management", "client": "Client management", "webhook": "Webhook management", "user": "User management"}}}}
    }
  },
  "security": [{"oauth2": []}]
}
