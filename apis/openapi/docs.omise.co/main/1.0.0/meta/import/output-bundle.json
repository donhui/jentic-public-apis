{
  "openapi": "3.0.3",
  "info": {
    "title": "Omise Payments API",
    "description": "Omise payment gateway API providing charge management, customer management, token creation, refunds, and transfers.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.omise.co/docs"
  },
  "servers": [
    {
      "url": "https://api.omise.co",
      "description": "Omise API server"
    },
    {
      "url": "https://vault.omise.co",
      "description": "Omise Vault server (for tokens)"
    }
  ],
  "paths": {
    "/charges": {
      "post": {
        "operationId": "createCharge",
        "summary": "Create a charge",
        "description": "Create and authorize or capture a charge from a card, customer, or source.",
        "tags": [
          "Charges"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CreateChargeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Charge created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Charge"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failure"
          }
        }
      },
      "get": {
        "operationId": "listCharges",
        "summary": "List charges",
        "description": "Retrieve a paginated list of charges for the account.",
        "tags": [
          "Charges"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Records per page"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Number of records to skip"
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "chronological",
                "reverse_chronological"
              ]
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Earliest UTC datetime (ISO 8601)"
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Latest UTC datetime (ISO 8601)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of charges",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChargeList"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failure"
          }
        }
      }
    },
    "/charges/{id}": {
      "get": {
        "operationId": "retrieveCharge",
        "summary": "Retrieve a charge",
