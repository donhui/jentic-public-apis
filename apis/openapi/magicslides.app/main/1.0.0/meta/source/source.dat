{
  "openapi": "3.0.3",
  "info": {
    "title": "MagicSlides API",
    "description": "MagicSlides is an AI-powered tool that creates professional presentations from text, PDFs, and more in seconds, supporting 100+ languages.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.magicslides.app/magicslides-api/docs"
  },
  "servers": [
    {
      "url": "https://api.magicslides.app/public/api",
      "description": "MagicSlides Public API"
    }
  ],
  "tags": [
    { "name": "Presentations", "description": "Generate presentations from various input sources" }
  ],
  "paths": {
    "/ppt-from-text": {
      "post": {
        "operationId": "createPresentationFromText",
        "summary": "Generate a presentation from text",
        "description": "Unified endpoint that handles all input types: topics, summaries, YouTube videos, websites, PDFs, and DOCX documents.",
        "tags": ["Presentations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePresentationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presentation generated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PresentationResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ppt_from_topic": {
      "post": {
        "operationId": "createPresentationFromTopic",
        "summary": "Generate presentation from topic (deprecated)",
        "description": "Generate customized presentations from topics with AI control over style, length, language, and images. Deprecated: use /ppt-from-text instead.",
        "tags": ["Presentations"],
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TopicPresentationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presentation generated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PresentationResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ppt_from_summery": {
      "post": {
        "operationId": "createPresentationFromSummary",
        "summary": "Generate presentation from summary (deprecated)",
        "description": "Convert text summaries into presentations. Deprecated: use /ppt-from-text instead.",
        "tags": ["Presentations"],
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SummaryPresentationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presentation generated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PresentationResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/ppt_from_youtube": {
      "post": {
        "operationId": "createPresentationFromYoutube",
        "summary": "Generate presentation from YouTube (deprecated)",
        "description": "Generate presentations from YouTube video content. Deprecated: use /ppt-from-text instead.",
        "tags": ["Presentations"],
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/YoutubePresentationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presentation generated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PresentationResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "apiKey",
        "in": "query",
        "description": "API key in format ms-api-{base64-encoded-payload}.{secret}. Can also be passed in request body."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": { "type": "string", "description": "Descriptive error message" },
          "code": { "type": "string", "description": "Error code" }
        }
      },
      "PresentationOptions": {
        "type": "object",
        "properties": {
          "template": { "type": "string", "description": "Template identifier" },
          "language": { "type": "string", "description": "Presentation language" },
          "slideCount": { "type": "integer", "description": "Number of slides" },
          "aiImages": { "type": "boolean", "description": "Generate AI images for slides" },
          "imageForEachSlide": { "type": "boolean", "description": "Add image to each slide" },
          "googleImage": { "type": "boolean", "description": "Use Google Images" },
          "googleText": { "type": "boolean", "description": "Use Google search for text" },
          "model": { "type": "string", "description": "AI model to use" },
          "presentationFor": { "type": "string", "description": "Target audience" },
          "presentationCategory": { "type": "string", "description": "Presentation category" },
          "watermark": { "type": "boolean", "description": "Include watermark" }
        }
      },
      "CreatePresentationRequest": {
        "type": "object",
        "required": ["apiKey"],
        "properties": {
          "apiKey": { "type": "string", "description": "API key for authentication" },
          "topic": { "type": "string", "description": "Topic for the presentation" },
          "summary": { "type": "string", "description": "Text summary to convert" },
          "youtubeURL": { "type": "string", "description": "YouTube video URL" },
          "websiteURL": { "type": "string", "description": "Website URL to use as source" },
          "pdfURL": { "type": "string", "description": "PDF URL to use as source" },
          "docxURL": { "type": "string", "description": "DOCX URL to use as source" },
          "template": { "type": "string" },
          "language": { "type": "string" },
          "slideCount": { "type": "integer" },
          "aiImages": { "type": "boolean" },
          "imageForEachSlide": { "type": "boolean" },
          "googleImage": { "type": "boolean" },
          "googleText": { "type": "boolean" },
          "model": { "type": "string" },
          "presentationFor": { "type": "string" },
          "presentationCategory": { "type": "string" },
          "watermark": { "type": "boolean" }
        }
      },
      "TopicPresentationRequest": {
        "type": "object",
        "required": ["topic", "email", "accessId"],
        "properties": {
          "topic": { "type": "string", "description": "Presentation topic" },
          "extraInfoSource": { "type": "string", "description": "Additional info source" },
          "email": { "type": "string", "description": "User email (legacy auth)" },
          "accessId": { "type": "string", "description": "Access ID (legacy auth)" },
          "apiKey": { "type": "string", "description": "API key (takes precedence)" },
          "template": { "type": "string" },
          "language": { "type": "string" },
          "slideCount": { "type": "integer" },
          "aiImages": { "type": "boolean" },
          "imageForEachSlide": { "type": "boolean" },
          "googleImage": { "type": "boolean" },
          "googleText": { "type": "boolean" },
          "model": { "type": "string" },
          "presentationFor": { "type": "string" },
          "watermark": { "type": "boolean" }
        }
      },
      "SummaryPresentationRequest": {
        "type": "object",
        "required": ["msSummaryText", "email", "accessId"],
        "properties": {
          "msSummaryText": { "type": "string", "description": "Summary text to convert" },
          "email": { "type": "string", "description": "User email (legacy auth)" },
          "accessId": { "type": "string", "description": "Access ID (legacy auth)" },
          "apiKey": { "type": "string", "description": "API key (takes precedence)" },
          "template": { "type": "string" },
          "language": { "type": "string" },
          "slideCount": { "type": "integer" },
          "aiImages": { "type": "boolean" },
          "imageForEachSlide": { "type": "boolean" },
          "googleImage": { "type": "boolean" },
          "googleText": { "type": "boolean" },
          "model": { "type": "string" },
          "presentationFor": { "type": "string" },
          "watermark": { "type": "boolean" }
        }
      },
      "YoutubePresentationRequest": {
        "type": "object",
        "required": ["youtubeURL", "email", "accessId"],
        "properties": {
          "youtubeURL": { "type": "string", "description": "YouTube video URL" },
          "email": { "type": "string", "description": "User email (legacy auth)" },
          "accessId": { "type": "string", "description": "Access ID (legacy auth)" },
          "apiKey": { "type": "string", "description": "API key (takes precedence)" },
          "template": { "type": "string" },
          "language": { "type": "string" },
          "slideCount": { "type": "integer" },
          "aiImages": { "type": "boolean" },
          "imageForEachSlide": { "type": "boolean" },
          "googleImage": { "type": "boolean" },
          "googleText": { "type": "boolean" },
          "model": { "type": "string" },
          "presentationFor": { "type": "string" },
          "watermark": { "type": "boolean" }
        }
      },
      "PresentationResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "description": "Status message" },
          "message": { "type": "string" },
          "inputType": { "type": "string", "description": "Detected input type" },
          "url": { "type": "string", "description": "URL to download the presentation" },
          "pptId": { "type": "string", "description": "Presentation identifier" },
          "pdfUrl": { "type": "string", "description": "URL to download PDF version" },
          "json": { "type": "object", "description": "Presentation data as JSON" },
          "tokenUsed": { "type": "integer", "description": "Tokens consumed" },
          "openAICallTime": { "type": "number", "description": "AI processing time in seconds" }
        }
      }
    }
  }
}