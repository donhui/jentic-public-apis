{
  "openapi": "3.0.3",
  "info": {
    "title": "Huawei Cloud DNS API",
    "description": "Huawei Cloud Domain Name Service API for managing public and private DNS zones, record sets, and name servers.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://support.huaweicloud.com/intl/en-us/api-dns/dns_api_60000.html"
  },
  "servers": [
    {
      "url": "https://dns.ap-southeast-3.myhuaweicloud.com",
      "description": "Huawei Cloud DNS - AP Singapore"
    }
  ],
  "paths": {
    "/v2/zones": {
      "post": {
        "operationId": "createPublicZone",
        "summary": "Create a public zone",
        "tags": ["Public Zones"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateZoneRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Zone creation accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Zone" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "operationId": "listPublicZones",
        "summary": "Query public zones",
        "tags": ["Public Zones"],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string", "default": "public" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "maximum": 500, "default": 500 },
            "description": "Records per page"
          },
          {
            "name": "marker",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Resource ID for pagination"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "name",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Zone name (supports fuzzy search)"
          },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["ACTIVE", "PENDING_CREATE", "FREEZE"] }
          },
          {
            "name": "sort_key",
            "in": "query",
            "schema": { "type": "string", "enum": ["name", "created_at", "updated_at"] }
          },
          {
            "name": "sort_dir",
            "in": "query",
            "schema": { "type": "string", "enum": ["asc", "desc"] }
          },
          {
            "name": "enterprise_project_id",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Zone list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ZoneListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/zones/{zone_id}": {
      "get": {
        "operationId": "getZone",
        "summary": "Query a zone by ID",
        "tags": ["Public Zones"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" }
        ],
        "responses": {
          "200": {
            "description": "Zone details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Zone" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "operationId": "updateZone",
        "summary": "Modify a zone",
        "tags": ["Public Zones"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "description": { "type": "string", "maxLength": 255 },
                  "email": { "type": "string" },
                  "ttl": { "type": "integer", "minimum": 1, "maximum": 2147483647 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Zone updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Zone" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteZone",
        "summary": "Delete a zone",
        "tags": ["Public Zones"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" }
        ],
        "responses": {
          "202": {
            "description": "Zone deletion accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Zone" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/zones/{zone_id}/nameservers": {
      "get": {
        "operationId": "getZoneNameservers",
        "summary": "Query name servers for a zone",
        "tags": ["Public Zones"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" }
        ],
        "responses": {
          "200": {
            "description": "Name server list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NameserverListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/zones/{zone_id}/associaterouter": {
      "post": {
        "operationId": "associateRouterToZone",
        "summary": "Associate a VPC router with a private zone",
        "tags": ["Private Zones"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "router": {
                    "type": "object",
                    "properties": {
                      "router_id": { "type": "string", "description": "VPC router ID" },
                      "router_region": { "type": "string", "description": "Region of the router" }
                    },
                    "required": ["router_id"]
                  }
                },
                "required": ["router"]
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Router association accepted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/zones/{zone_id}/disassociaterouter": {
      "post": {
        "operationId": "disassociateRouterFromZone",
        "summary": "Disassociate a VPC router from a private zone",
        "tags": ["Private Zones"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "router": {
                    "type": "object",
                    "properties": {
                      "router_id": { "type": "string", "description": "VPC router ID" },
                      "router_region": { "type": "string", "description": "Region of the router" }
                    },
                    "required": ["router_id"]
                  }
                },
                "required": ["router"]
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Router disassociation accepted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2.1/zones/{zone_id}/recordsets": {
      "post": {
        "operationId": "createRecordSet",
        "summary": "Create a record set in a zone",
        "tags": ["Record Sets"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRecordSetRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Record set creation accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecordSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "operationId": "listRecordSetsInZone",
        "summary": "List record sets in a zone",
        "tags": ["Record Sets"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "maximum": 500 }
          },
          {
            "name": "marker",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Record type filter (A, AAAA, CNAME, MX, etc.)"
          }
        ],
        "responses": {
          "200": {
            "description": "Record set list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecordSetListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2.1/zones/{zone_id}/recordsets/{recordset_id}": {
      "get": {
        "operationId": "getRecordSet",
        "summary": "Query a record set",
        "tags": ["Record Sets"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" },
          { "$ref": "#/components/parameters/RecordSetId" }
        ],
        "responses": {
          "200": {
            "description": "Record set details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecordSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateRecordSet",
        "summary": "Modify a record set",
        "tags": ["Record Sets"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" },
          { "$ref": "#/components/parameters/RecordSetId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "description": { "type": "string", "maxLength": 255 },
                  "ttl": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
                  "records": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "weight": { "type": "integer", "minimum": 0, "maximum": 1000 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record set updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecordSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteRecordSet",
        "summary": "Delete a record set",
        "tags": ["Record Sets"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" },
          { "$ref": "#/components/parameters/RecordSetId" }
        ],
        "responses": {
          "202": {
            "description": "Record set deletion accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecordSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2.1/zones/{zone_id}/recordsets/batch/delete": {
      "post": {
        "operationId": "batchDeleteRecordSets",
        "summary": "Batch delete record sets in a zone",
        "tags": ["Record Sets"],
        "parameters": [
          { "$ref": "#/components/parameters/ZoneId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "recordset_ids": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "List of record set IDs to delete"
                  }
                },
                "required": ["recordset_ids"]
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Batch deletion accepted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/recordsets": {
      "get": {
        "operationId": "listAllRecordSets",
        "summary": "List all record sets across zones",
        "tags": ["Record Sets"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "maximum": 500 }
          },
          {
            "name": "marker",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "zone_type",
            "in": "query",
            "schema": { "type": "string", "enum": ["public", "private"] }
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Record type filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Record set list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecordSetListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "iamToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Auth-Token",
        "description": "IAM user authentication token"
      }
    },
    "parameters": {
      "ZoneId": {
        "name": "zone_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Zone UUID"
      },
      "RecordSetId": {
        "name": "recordset_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Record set UUID"
      }
    },
    "schemas": {
      "CreateZoneRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Domain name with trailing dot",
            "maxLength": 254
          },
          "description": { "type": "string", "maxLength": 255 },
          "zone_type": { "type": "string", "enum": ["public"] },
          "email": { "type": "string", "description": "Administrator email for SOA record" },
          "ttl": {
            "type": "integer",
            "description": "TTL in seconds",
            "default": 300,
            "minimum": 1,
            "maximum": 2147483647
          },
          "enterprise_project_id": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Tag" }
          }
        },
        "required": ["name"]
      },
      "Zone": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "email": { "type": "string" },
          "zone_type": { "type": "string" },
          "ttl": { "type": "integer" },
          "serial": { "type": "integer", "description": "SOA sequence number" },
          "status": {
            "type": "string",
            "enum": ["ACTIVE", "PENDING_CREATE", "PENDING_DELETE", "DISABLE"]
          },
          "record_num": { "type": "integer" },
          "pool_id": { "type": "string" },
          "project_id": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "links": { "$ref": "#/components/schemas/Links" },
          "tags": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Tag" }
          }
        }
      },
      "ZoneListResponse": {
        "type": "object",
        "properties": {
          "zones": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Zone" }
          },
          "links": { "$ref": "#/components/schemas/Links" },
          "metadata": {
            "type": "object",
            "properties": {
              "total_count": { "type": "integer" }
            }
          }
        }
      },
      "CreateRecordSetRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "FQDN with trailing dot"
          },
          "type": {
            "type": "string",
            "enum": ["A", "AAAA", "MX", "CNAME", "TXT", "SRV", "NS", "SOA", "CAA", "PTR"],
            "description": "Record type"
          },
          "description": { "type": "string", "maxLength": 255 },
          "status": { "type": "string", "enum": ["ENABLE", "DISABLE"], "default": "ENABLE" },
          "ttl": {
            "type": "integer",
            "default": 300,
            "minimum": 1,
            "maximum": 2147483647
          },
          "records": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Record values"
          },
          "line": { "type": "string", "description": "Resolution line ID" },
          "weight": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000,
            "description": "Weight for weighted routing"
          },
          "tags": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Tag" }
          }
        },
        "required": ["name", "type"]
      },
      "RecordSet": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string" },
          "ttl": { "type": "integer" },
          "records": {
            "type": "array",
            "items": { "type": "string" }
          },
          "zone_id": { "type": "string" },
          "zone_name": { "type": "string" },
          "weight": { "type": "integer" },
          "default": { "type": "boolean" },
          "project_id": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "links": { "$ref": "#/components/schemas/Links" }
        }
      },
      "RecordSetListResponse": {
        "type": "object",
        "properties": {
          "recordsets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RecordSet" }
          },
          "links": { "$ref": "#/components/schemas/Links" },
          "metadata": {
            "type": "object",
            "properties": {
              "total_count": { "type": "integer" }
            }
          }
        }
      },
      "NameserverListResponse": {
        "type": "object",
        "properties": {
          "nameservers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "hostname": { "type": "string" },
                "priority": { "type": "integer" }
              }
            }
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" }
        },
        "required": ["key"]
      },
      "Links": {
        "type": "object",
        "properties": {
          "self": { "type": "string" },
          "next": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required or token expired"
      }
    }
  },
  "security": [
    { "iamToken": [] }
  ]
}