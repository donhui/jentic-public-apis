{
  "openapi": "3.0.3",
  "info": {
    "title": "BuzzSumo API",
    "description": "BuzzSumo provides APIs for content discovery, influencer research, media monitoring, project management, and backlinks analysis.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developers.buzzsumo.com"
  },
  "servers": [
    {
      "url": "https://app.buzzsumo.com/api",
      "description": "BuzzSumo API server"
    }
  ],
  "paths": {
    "/search/articles": {
      "get": {
        "operationId": "searchArticles",
        "summary": "Search for articles",
        "description": "Search for popular articles for any topic or domain.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query (topic, term, or URL)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "num_results",
            "in": "query",
            "description": "Number of results per page",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/search/articles/sharers": {
      "get": {
        "operationId": "getArticleSharers",
        "summary": "Get article sharers",
        "description": "Get users who shared a particular article.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Article URL",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of sharers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SharersResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/search/trends": {
      "get": {
        "operationId": "getTrends",
        "summary": "Get trending content",
        "description": "Find trending content for the last 24 hours.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trending content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/search/influencers": {
      "get": {
        "operationId": "searchInfluencers",
        "summary": "Find influencers",
        "description": "Find influencers for any keyword or topic.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Influencer results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfluencerResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/search/shared-links": {
      "get": {
        "operationId": "getSharedLinks",
        "summary": "Get shared links",
        "description": "Look up share or backlink counts for a specific URL.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "URL to look up",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Shared links data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SharedLinksResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/alerts": {
      "get": {
        "operationId": "listAlerts",
        "summary": "List all alerts",
        "description": "List all alerts configured in the user's account.",
        "tags": ["Alerts"],
        "responses": {
          "200": {
            "description": "List of alerts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Alert"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createAlert",
        "summary": "Create a new alert",
        "description": "Create a new monitoring alert.",
        "tags": ["Alerts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlertInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alert created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Alert"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/alerts/{alert_id}": {
      "get": {
        "operationId": "getAlert",
        "summary": "Retrieve an alert",
        "description": "Get details of a specific alert.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alert details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Alert"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Alert not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteAlert",
        "summary": "Delete an alert",
        "description": "Delete a specific alert.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alert deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Alert not found"
          }
        }
      }
    },
    "/alerts/{alert_id}/mentions": {
      "get": {
        "operationId": "listMentions",
        "summary": "List alert mentions",
        "description": "Get mentions for a specific alert.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of mentions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MentionsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/alerts/{alert_id}/stats": {
      "get": {
        "operationId": "getAlertStats",
        "summary": "Get alert statistics",
        "description": "Retrieve statistics for a specific alert.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alert statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List all projects",
        "description": "List all projects in the user's account.",
        "tags": ["Projects"],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create a project",
        "description": "Create a new project.",
        "tags": ["Projects"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/projects/{project_id}": {
      "get": {
        "operationId": "getProject",
        "summary": "Retrieve a project",
        "description": "Get details of a specific project.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Project not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteProject",
        "summary": "Delete a project",
        "description": "Delete a specific project.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project deleted"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/projects/{project_id}/articles": {
      "get": {
        "operationId": "listProjectArticles",
        "summary": "List project articles",
        "description": "Get all articles saved to a project.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of articles",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleSearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "saveUrlsToProject",
        "summary": "Save URLs to a project",
        "description": "Save article URLs to a specific project.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveUrlsInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "URLs saved"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/backlinks": {
      "post": {
        "operationId": "retrieveBacklinks",
        "summary": "Retrieve backlinks",
        "description": "Retrieve backlinks for a given URL or domain.",
        "tags": ["Backlinks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BacklinksRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Backlinks data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BacklinksResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ArticleSearchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Article"
            }
          },
          "total_results": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          }
        }
      },
      "Article": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "published_date": {
            "type": "string"
          },
          "domain_name": {
            "type": "string"
          },
          "total_shares": {
            "type": "integer"
          },
          "facebook_shares": {
            "type": "integer"
          },
          "twitter_shares": {
            "type": "integer"
          },
          "pinterest_shares": {
            "type": "integer"
          },
          "total_backlinks": {
            "type": "integer"
          }
        }
      },
      "SharersResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sharer"
            }
          }
        }
      },
      "Sharer": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "followers": {
            "type": "integer"
          }
        }
      },
      "InfluencerResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Influencer"
            }
          }
        }
      },
      "Influencer": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "followers": {
            "type": "integer"
          },
          "retweet_ratio": {
            "type": "number"
          },
          "reply_ratio": {
            "type": "number"
          }
        }
      },
      "SharedLinksResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string"
                },
                "total_shares": {
                  "type": "integer"
                },
                "total_backlinks": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      },
      "AlertInput": {
        "type": "object",
        "required": ["name", "query"],
        "properties": {
          "name": {
            "type": "string"
          },
          "query": {
            "type": "string"
          }
        }
      },
      "MentionsResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Article"
            }
          }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "total_mentions": {
            "type": "integer"
          },
          "total_shares": {
            "type": "integer"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      },
      "ProjectInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "SaveUrlsInput": {
        "type": "object",
        "required": ["urls"],
        "properties": {
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "BacklinksRequest": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "description": "URL or domain to get backlinks for"
          }
        }
      },
      "BacklinksResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source_url": {
                  "type": "string"
                },
                "target_url": {
                  "type": "string"
                },
                "domain": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "BuzzSumo API key"
      }
    }
  },
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Search",
      "description": "Content search and discovery"
    },
    {
      "name": "Alerts",
      "description": "Media monitoring alerts"
    },
    {
      "name": "Projects",
      "description": "Project management"
    },
    {
      "name": "Backlinks",
      "description": "Backlinks analysis"
    }
  ]
}