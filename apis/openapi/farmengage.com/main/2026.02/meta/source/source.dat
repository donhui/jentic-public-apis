      "UpsertVehicle": {
        "required": [
          "manufacturerId",
          "name",
          "vehicleTypeId"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 50,
            "minLength": 1,
            "pattern": "^[^/\\\\:*<>|.\"]+$",
            "type": "string"
          },
          "manufacturerId": {
            "minLength": 1,
            "pattern": "^[^/\\\\:*<>|.\"]+$",
            "type": "string"
          },
          "vehicleTypeId": {
            "type": "integer",
            "format": "int32"
          },
