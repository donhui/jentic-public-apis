      },
      "UpsertWorkOrder": {
        "required": [
          "cropZoneId",
          "dueDateTime",
          "name",
          "operationTypeId",
          "plannedDateTime"
        ],
        "type": "object",
        "properties": {
          "operationTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "operationSubTypeId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "cropZoneId": {
            "type": "string",
            "format": "uuid"
          },
          "managementZoneId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "plannedDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "dueDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "area": {
            "minimum": 0,
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "comments": {
            "type": "string",
            "nullable": true
          },
          "vehicles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpsertWorkOrderVehicle"
            },
            "nullable": true
          },
          "implements": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpsertWorkOrderImplement"
            },
            "nullable": true
          },
          "materials": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpsertWorkOrderMaterial"
            },
            "nullable": true
          },
          "tankMixes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpsertWorkOrderTankMix"
            },
            "nullable": true
          },
          "contacts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpsertWorkOrderContact"
            },
            "nullable": true
          },
          "restriction": {
            "$ref": "#/components/schemas/UpsertWorkOrderRestriction"
          },
          "guidances": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UpsertWorkOrderGuidance"
            },
            "description": "Maximum of 2 guidance objects can be passed because the WorkOrder can have ONLY 1 guidance of Line Type AND/OR 1 guidance of Area Type.\r\n\n\r\nOnly one of the attributes i.e guidanceId OR fieldId OR landmarkId OR boundaryId can be set for a guidance object at a time.",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
