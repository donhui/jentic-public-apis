                  "$ref": "#/components/schemas/SlackActionConfig"
                },
                "description": "Slack notification actions configured for this agent"
              },
              "emailActions": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/EmailActionConfig"
                },
                "description": "Email actions configured for this agent"
              }
            },
            "required": [
              "calendarActions",
              "customActions",
              "transferActions",
              "slackActions",
              "emailActions"
            ],
            "description": "Tools available to the agent"
          },
          "generatedPrompt": {
            "type": "string",
            "description": "Pre-generated system prompt from centralized builder",
            "example": "You are a helpful assistant..."
          },
          "mcpServers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/McpServerConfig"
            },
            "description": "MCP server configurations for tool execution"
          },
          "toolDefinitions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToolDefinition"
            },
            "description": "OpenAI-compatible tool definitions"
          },
          "builderVersion": {
            "type": "string",
            "description": "Builder version for contract versioning",
            "example": "v1"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "name",
          "prompt",
          "openingLine",
          "language",
          "llmProvider",
          "llmModel",
          "temperature",
          "maxTokens",
          "knowledgeBaseId",
          "tools",
          "generatedPrompt",
          "mcpServers",
          "toolDefinitions",
          "builderVersion"
        ]
      },
      "UpdateInternalAgent": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Agent name",
            "example": "Updated Support Agent"
          },
          "prompt": {
            "type": "string",
            "nullable": true,
            "description": "System prompt",
            "example": "Updated system prompt..."
          },
          "voiceId": {
            "type": "string",
            "nullable": true,
            "description": "Voice configuration ID",
            "example": "voice_456"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the agent is active",
            "example": true
          },
          "backgroundSound": {
            "type": "boolean",
            "description": "Enable background sound",
            "example": false
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Agent description",
            "example": "Updated description"
          },
          "openingLine": {
            "type": "string",
            "nullable": true,
            "description": "First message",
            "example": "Hi there!"
          },
          "knowledgeBaseId": {
            "type": "string",
            "nullable": true,
            "description": "Knowledge base ID",
            "example": "kb_456"
          },
          "language": {
            "type": "string",
            "enum": [
              "english",
              "spanish",
              "french",
              "german",
              "portuguese",
              "dutch",
              "chinese",
              "japanese"
            ],
            "description": "Agent language",
            "example": "spanish"
          },
          "llmProvider": {
            "type": "string",
            "nullable": true,
            "enum": [
              "openai",
              "anthropic",
              "google"
            ],
            "description": "LLM provider for this agent. Set to null to use global engine_call_settings default.",
            "example": "anthropic"
          },
          "voicemail": {
            "type": "boolean",
            "description": "Enable voicemail",
            "example": true
          },
          "voicemailMessage": {
            "type": "string",
            "nullable": true,
            "description": "Voicemail message",
            "example": "Updated voicemail message"
          },
          "hipaaCompliance": {
            "type": "boolean",
            "description": "Enable HIPAA compliance mode. When enabled, no logs, recordings, or transcriptions will be stored.",
            "example": false
          },
          "callDuration": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60,
            "description": "Maximum call duration in minutes (1-60)",
            "example": 30
          }
        }
      },
      "CalendarAction": {
        "type": "object",
