      "EmailActionConfig": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Email action ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Action name",
            "example": "Send Confirmation"
          },
          "condition": {
            "type": "string",
            "nullable": true,
            "description": "Condition when to trigger this action",
