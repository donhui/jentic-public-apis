          }
        },
        "required": [
          "conversationId"
        ]
      },
      "CreateCallRequest": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "agentId": {
                "type": "string",
                "format": "uuid",
                "description": "UUID of the agent to use for the call (required)",
                "example": "123e4567-e89b-12d3-a456-426614174000"
              },
              "variables": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Custom variables to pass to the assistant. These override contact field values.",
                "example": {
                  "customerName": "John Doe",
                  "appointmentTime": "3pm"
                }
              },
              "type": {
                "type": "string",
                "enum": [
                  "contact"
                ],
                "description": "Call type - \"contact\" to call a contact by ID",
                "example": "contact"
              },
              "contactId": {
                "type": "string",
                "format": "uuid",
                "description": "UUID of the contact to call",
                "example": "456e4567-e89b-12d3-a456-426614174000"
              }
            },
            "required": [
              "agentId",
              "type",
              "contactId"
            ]
          },
          {
            "type": "object",
            "properties": {
              "agentId": {
                "type": "string",
                "format": "uuid",
                "description": "UUID of the agent to use for the call (required)",
                "example": "123e4567-e89b-12d3-a456-426614174000"
              },
              "variables": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Custom variables to pass to the assistant. These override contact field values.",
                "example": {
                  "customerName": "John Doe",
                  "appointmentTime": "3pm"
                }
              },
              "type": {
                "type": "string",
                "enum": [
                  "phoneNumber"
                ],
                "description": "Call type - \"phoneNumber\" to call a phone number directly",
                "example": "phoneNumber"
              },
              "phoneNumber": {
                "type": "string",
                "pattern": "^\\+[1-9]\\d{1,14}$",
                "description": "Phone number to call in E.164 format",
                "example": "+14155551234"
              },
              "firstName": {
                "type": "string",
                "maxLength": 255,
                "description": "First name of the contact",
                "example": "John"
              },
              "lastName": {
                "type": "string",
                "maxLength": 255,
                "description": "Last name of the contact",
                "example": "Doe"
              },
              "email": {
                "type": "string",
                "format": "email",
                "description": "Email address of the contact",
                "example": "john@example.com"
              },
              "businessName": {
                "type": "string",
                "maxLength": 255,
                "description": "Business/company name of the contact",
                "example": "Acme Inc"
              },
              "customFields": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Custom field values by field name. Field names must match existing custom field definitions.",
                "example": {
                  "Lead Source": "Website",
                  "Industry": "Technology"
                }
              }
            },
            "required": [
              "agentId",
              "type",
              "phoneNumber"
            ]
          }
        ]
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
