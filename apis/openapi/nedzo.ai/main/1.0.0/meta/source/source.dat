      "SmsComplianceSettings": {
        "type": "object",
        "properties": {
          "smsOptOutMessage": {
            "type": "string",
            "nullable": true,
            "description": "Template message appended to SMS for opt-out compliance",
            "example": "Reply STOP to unsubscribe"
          },
          "smsSenderInfo": {
            "type": "string",
            "nullable": true,
            "description": "Sender identification shown in SMS messages",
            "example": "Acme Corp"
          }
        },
        "required": [
          "smsOptOutMessage",
          "smsSenderInfo"
        ]
      },
      "UpdateSmsCompliance": {
        "type": "object",
        "properties": {
          "smsOptOutMessage": {
            "type": "string",
            "enum": [
              "Reply STOP to unsubscribe",
              "Text STOP to opt out",
              "Reply STOP to stop receiving messages",
              "Send STOP to unsubscribe from future messages"
            ],
            "description": "Opt-out message template to use",
            "example": "Reply STOP to unsubscribe"
          },
          "smsSenderInfo": {
            "type": "string",
            "maxLength": 160,
            "description": "Sender identification (max 160 characters, alphanumeric and basic punctuation only)",
            "example": "Acme Corp"
          }
        }
      },
      "SmsRestriction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique restriction record identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace this restriction belongs to",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "phoneNumberId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "Associated phone number ID (if still exists)",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "phoneNumber": {
            "type": "string",
            "description": "Phone number that triggered the restriction",
            "example": "+15551234567"
          },
          "type": {
            "type": "string",
            "enum": [
              "warning",
              "limit_reached",
              "filter_block"
            ],
            "description": "Type of restriction event",
            "example": "warning"
          },
          "reason": {
            "type": "string",
            "description": "Human-readable reason for the restriction",
            "example": "Daily SMS limit exceeded"
          },
          "telnyxErrorCode": {
            "type": "string",
            "nullable": true,
            "description": "Telnyx error code if applicable",
            "example": "40300"
          },
          "metadata": {
            "type": "object",
            "nullable": true,
            "additionalProperties": {
              "nullable": true
            },
            "description": "Additional metadata associated with this restriction",
            "example": {
              "campaign_id": "abc123"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the restriction was recorded (ISO 8601)",
            "example": "2025-12-28T12:00:00Z"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "phoneNumberId",
          "phoneNumber",
          "type",
          "reason",
          "telnyxErrorCode",
          "metadata",
          "createdAt"
        ]
      },
      "SmsRestrictionsList": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SmsRestriction"
            },
            "description": "Array of restriction records"
          },
          "pagination": {
            "type": "object",
            "properties": {
              "total": {
                "type": "number",
                "description": "Total number of records matching the query",
                "example": 150
              },
              "limit": {
                "type": "number",
                "description": "Maximum records per page",
                "example": 50
              },
              "offset": {
                "type": "number",
                "description": "Number of records skipped",
                "example": 0
              }
            },
            "required": [
              "total",
              "limit",
              "offset"
            ],
            "description": "Pagination metadata"
          }
        },
        "required": [
          "data",
          "pagination"
        ]
      },
      "SmsDailyUsage": {
        "type": "object",
        "properties": {
          "used": {
            "type": "integer",
            "minimum": 0,
            "description": "Outbound SMS sent today (UTC)"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum outbound SMS allowed per day"
          }
        },
        "required": [
          "used",
          "limit"
        ]
      },
      "WorkflowNode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique node identifier within the workflow",
            "example": "node-1"
          },
          "type": {
            "type": "string",
            "description": "Node type (e.g., voiceCall, sendSms, wait, condition)",
            "example": "voiceCall"
          },
          "parentId": {
            "type": "string",
            "nullable": true,
            "description": "Parent node ID for tree structure",
            "example": null
          },
          "pathId": {
            "type": "string",
            "nullable": true,
            "description": "Path identifier for conditional branches",
            "example": null
          },
          "config": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "description": "Node-specific configuration",
            "example": {
              "agentId": "agent-123"
            }
          },
          "position": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              }
            },
            "required": [
              "x",
              "y"
            ],
            "description": "Visual position in workflow editor",
            "example": {
              "x": 100,
              "y": 200
            }
          }
        },
        "required": [
          "id",
          "type",
          "parentId",
          "pathId",
          "config",
          "position"
        ]
      },
      "WorkflowResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique workflow identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace this workflow belongs to",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Workflow name",
            "example": "My Workflow"
          },
          "nodesJson": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkflowNode"
            },
            "description": "Workflow nodes",
            "example": []
          },
          "isPublished": {
            "type": "boolean",
            "description": "Whether workflow has been published (has a published version)",
            "example": false
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether workflow is enabled. Inactive workflows do not respond to triggers even if published.",
            "example": true
          },
          "version": {
            "type": "integer",
            "description": "Workflow version number",
            "example": 1
          },
          "publishedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Timestamp when last published (ISO 8601)",
            "example": null
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp (ISO 8601)",
            "example": "2025-01-01T00:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp (ISO 8601)",
            "example": "2025-01-01T00:00:00Z"
          },
          "deletedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Soft delete timestamp (ISO 8601), null if not deleted",
            "example": null
          }
        },
        "required": [
          "id",
          "workspaceId",
          "name",
          "nodesJson",
          "isPublished",
          "isActive",
          "version",
          "publishedAt",
          "createdAt",
          "updatedAt",
          "deletedAt"
        ]
      },
