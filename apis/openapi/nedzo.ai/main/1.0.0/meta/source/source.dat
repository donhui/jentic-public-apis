      },
      "delete": {
        "tags": [
          "Templates"
        ],
        "summary": "Delete template",
        "description": "Soft-delete a template. The template will no longer appear in listings but can be recovered. Requires Account Admin role.",
        "security": [
          {
            "jwtAuth": []
          }
