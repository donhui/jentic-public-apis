          "state"
        ]
      },
      "AvailableNumberWithPrice": {
        "type": "object",
        "properties": {
          "phoneNumber": {
            "type": "string",
            "description": "Phone number in E.164 format",
            "example": "+14155551234"
          },
          "nationalFormat": {
            "type": "string",
            "nullable": true,
            "description": "National format",
            "example": "(415) 555-1234"
          },
          "numberType": {
            "type": "string",
            "enum": [
              "local",
              "mobile"
            ],
            "description": "Number type",
            "example": "local"
          },
          "region": {
            "$ref": "#/components/schemas/RegionInfo"
          },
          "price": {
            "type": "number",
            "description": "Price in cents (with markup)",
            "example": 499
          },
          "exceedsMaxPrice": {
            "type": "boolean",
            "description": "True if price exceeds max price limit",
            "example": false
          }
        },
        "required": [
          "phoneNumber",
          "nationalFormat",
          "numberType",
          "region",
          "price"
        ]
      },
      "PurchaseEligibilityResponse": {
        "type": "object",
        "properties": {
          "eligible": {
            "type": "boolean",
            "description": "Whether purchase is allowed",
            "example": true
          },
          "reason": {
            "type": "string",
            "enum": [
              "NO_PAYMENT_METHOD",
              "INSUFFICIENT_FUNDS"
            ],
            "description": "Reason for ineligibility"
          },
          "canTopUp": {
            "type": "boolean",
            "description": "Whether user can add funds",
            "example": true
          },
          "redirectTo": {
            "type": "string",
            "nullable": true,
            "enum": [
              "account_billing",
              "workspace_billing"
            ],
            "description": "Where to redirect user for top-up"
          },
          "requiredAmount": {
            "type": "number",
            "description": "Amount needed in cents",
            "example": 499
          },
          "availableBalance": {
            "type": "number",
            "description": "Current balance in cents",
            "example": 100
          },
          "message": {
            "type": "string",
            "description": "User-facing message",
            "example": "Contact your admin to add funds"
          }
        },
        "required": [
          "eligible"
        ]
      },
      "CheckEligibility": {
        "type": "object",
        "properties": {
