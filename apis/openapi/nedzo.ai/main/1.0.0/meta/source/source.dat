          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "502": {
            "description": "Stripe API error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workspaces/{workspaceId}/billing/payment-methods/attach": {
      "post": {
        "summary": "Attach payment method to workspace",
        "description": "Attach a confirmed PaymentMethod to the workspace's customer on connected Stripe.",
        "tags": [
          "Workspace Billing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "paymentMethodId": {
                    "type": "string",
                    "description": "Stripe PaymentMethod ID (pm_xxx)",
                    "example": "pm_1234567890abcdef"
                  }
                },
                "required": [
                  "paymentMethodId"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment method attached",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "paymentMethod": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "Payment method ID",
                          "example": "pm_xyz"
                        },
                        "type": {
                          "type": "string",
                          "description": "Payment method type",
                          "example": "card"
                        },
                        "brand": {
                          "type": "string",
                          "nullable": true,
                          "description": "Card brand",
                          "example": "visa"
                        },
                        "last4": {
                          "type": "string",
                          "nullable": true,
                          "description": "Last 4 digits",
                          "example": "4242"
                        },
                        "expMonth": {
                          "type": "number",
                          "nullable": true,
                          "description": "Expiration month",
                          "example": 12
                        },
                        "expYear": {
                          "type": "number",
                          "nullable": true,
                          "description": "Expiration year",
                          "example": 2026
                        },
                        "isDefault": {
                          "type": "boolean",
                          "description": "Is default payment method",
                          "example": true
                        },
                        "createdAt": {
                          "type": "string",
                          "description": "Created timestamp",
                          "example": "2024-01-15T10:00:00Z"
                        }
                      },
                      "required": [
                        "id",
                        "type",
                        "brand",
                        "last4",
                        "expMonth",
                        "expYear",
                        "isDefault",
                        "createdAt"
                      ]
                    },
                    "isDefault": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "paymentMethod",
                    "isDefault"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "502": {
            "description": "Stripe API error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
