            "example": "Make an AI voice call to the contact"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this action is currently available for use",
            "example": true
          },
          "configSchema": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "description": "JSON Schema for action configuration (if any)",
            "example": {
              "agentId": {
                "type": "string",
                "required": true
              }
            }
          },
          "comingSoon": {
            "type": "boolean",
            "description": "Whether this action is planned but not yet available",
            "example": false
          }
        },
        "required": [
          "type",
          "name",
          "description",
          "enabled"
        ]
      },
