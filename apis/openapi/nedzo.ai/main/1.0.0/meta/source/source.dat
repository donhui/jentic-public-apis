    "/internal/workspaces/{workspaceId}/billing/customers/search": {
      "get": {
        "summary": "Search Stripe customers (Admin only)",
        "description": "Search customers on account's connected Stripe. Requires admin or owner role.",
        "tags": [
          "Workspace Billing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Search query (email or name)",
              "example": "john@example.com"
            },
            "required": true,
            "name": "q",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Stripe customer ID",
                        "example": "cus_xyz"
                      },
                      "name": {
                        "type": "string",
                        "nullable": true,
                        "description": "Customer name",
                        "example": "John Smith"
                      },
                      "email": {
                        "type": "string",
                        "nullable": true,
                        "description": "Customer email",
                        "example": "john@example.com"
                      }
                    },
                    "required": [
                      "id",
                      "name",
                      "email"
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
