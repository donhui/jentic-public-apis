      "TemplateFullContent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique template identifier",
            "example": "abc12345-6789-0def-ghij-klmnopqrstuv"
          },
          "name": {
            "type": "string",
            "description": "Template name",
            "example": "Sales Appointment Setter"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Template description",
            "example": "AI agent configured for booking sales appointments"
          },
          "templateType": {
            "type": "string",
            "enum": [
              "agent",
              "workflow",
              "workspace"
            ],
            "description": "The type of entity this template was created from",
            "example": "agent"
          },
          "schemaVersion": {
            "type": "string",
            "description": "Snapshot schema version",
            "example": "1.0.0"
          },
          "snapshot": {
            "type": "object",
            "properties": {
              "schemaVersion": {
                "type": "string"
              },
              "exportedAt": {
                "type": "string"
              },
              "sourcePlatformVersion": {
                "type": "string"
              },
              "content": {
                "type": "object",
                "properties": {
                  "agents": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": {
                        "nullable": true
                      }
                    }
                  },
                  "workflows": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": {
                        "nullable": true
                      }
                    }
                  },
                  "customFields": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": {
                        "nullable": true
                      }
                    }
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": {
                        "nullable": true
                      }
                    }
                  }
                }
              },
              "metadata": {
                "type": "object",
                "properties": {
                  "originalIds": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "requiredIntegrations": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "originalIds",
                  "requiredIntegrations"
                ]
              }
            },
            "required": [
              "schemaVersion",
              "exportedAt",
              "sourcePlatformVersion",
              "content",
              "metadata"
            ],
            "description": "Full decompressed template snapshot"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 creation timestamp",
            "example": "2026-01-26T10:30:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "templateType",
          "schemaVersion",
          "snapshot",
          "createdAt"
        ]
      },
      "ImportValidationError": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "workspace_limit_exceeded",
              "template_not_found",
              "template_private",
              "forbidden",
              "snapshot_corruption"
            ],
            "description": "Error type",
            "example": "workspace_limit_exceeded"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Import would exceed workspace limits (52/50 agents)"
          },
          "details": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "description": "Additional error details"
          }
        },
        "required": [
          "type",
          "message"
        ],
        "description": "Error details (when failed)"
      },
      "ImportStatusResponse": {
        "type": "object",
        "properties": {
          "importId": {
            "type": "string",
            "format": "uuid",
            "description": "Import job ID",
            "example": "def45678-90ab-cdef-1234-567890abcdef"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "validating",
              "creating_entities",
              "remapping_refs",
              "completed",
              "failed"
            ],
            "description": "Current status of the import operation",
            "example": "queued"
          },
          "progress": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Progress percentage (0-100)",
            "example": 50
          },
          "itemsCreated": {
            "allOf": [
              {
                "$ref": "#/components/schemas/TemplateItemCounts"
              },
              {
                "description": "Summary of items created (when completed)"
              }
            ]
          },
          "error": {
            "$ref": "#/components/schemas/ImportValidationError"
          },
          "startedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "When import processing started",
            "example": "2026-01-26T10:30:00.000Z"
          },
          "completedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "When import completed or failed",
            "example": "2026-01-26T10:30:30.000Z"
          }
        },
        "required": [
          "importId",
          "status",
          "startedAt",
          "completedAt"
        ]
      },
      "ImportValidationWarning": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "missing_integration",
              "large_import"
            ],
            "description": "Warning type",
            "example": "missing_integration"
          },
          "message": {
            "type": "string",
            "description": "Human-readable warning message",
            "example": "2 workflows require Cal.com integration"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Affected item names (if applicable)",
            "example": [
              "Lead Nurture Workflow",
              "Follow-up Workflow"
            ]
          },
          "integration": {
            "type": "string",
            "description": "Integration identifier (for missing_integration type)",
            "example": "cal_com"
          }
        },
        "required": [
          "type",
          "message"
        ]
      },
      "ImportValidationResult": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "boolean",
            "description": "Whether the import can proceed",
            "example": true
          },
          "itemCounts": {
            "$ref": "#/components/schemas/TemplateItemCounts"
          },
          "warnings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImportValidationWarning"
            },
            "description": "Non-blocking warnings (import can still proceed)"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImportValidationError"
            },
            "description": "Blocking errors (import cannot proceed)"
          }
        },
        "required": [
          "valid",
          "itemCounts",
          "warnings",
          "errors"
        ]
      },
      "InitiateImportResponse": {
        "type": "object",
        "properties": {
          "importId": {
            "type": "string",
            "format": "uuid",
            "description": "Import job ID for status tracking",
            "example": "def45678-90ab-cdef-1234-567890abcdef"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "validating",
              "creating_entities",
              "remapping_refs",
              "completed",
              "failed"
            ],
            "description": "Current status of the import operation",
            "example": "queued"
          },
          "validation": {
            "$ref": "#/components/schemas/ImportValidationResult"
          },
          "message": {
            "type": "string",
            "description": "Status message",
            "example": "Import queued successfully. New items will be created. Your existing setup remains unchanged."
          }
        },
        "required": [
          "importId",
          "status",
          "validation",
          "message"
        ]
      },
      "InitiateImport": {
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID of the target workspace to import into",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "workspaceId"
        ]
      },
      "MagicLinkResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the magic link was sent successfully",
            "example": true
          },
          "message": {
            "type": "string",
            "description": "Human-readable status message",
            "example": "Magic link sent to your email"
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "MagicLinkRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address to send magic link to",
            "example": "user@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "RegisterResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether registration was successful",
            "example": true
          },
          "message": {
            "type": "string",
            "description": "Human-readable status message",
            "example": "Welcome email sent. Please check your inbox to activate your account."
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address for the new account",
            "example": "user@example.com"
          },
          "firstName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "User first name",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "User last name",
            "example": "Doe"
          },
          "phone": {
            "type": "string",
            "maxLength": 50,
            "description": "Phone number (optional)",
            "example": "+1 (555) 123-4567"
          },
          "countryCode": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "ISO 3166-1 alpha-2 country code (optional)",
            "example": "US"
          },
          "industry": {
            "type": "string",
            "maxLength": 100,
            "description": "Industry/vertical of the user (optional)",
            "example": "Agency"
          },
          "referrerCode": {
            "type": "string",
            "maxLength": 255,
            "description": "Referral code from ref URL parameter (optional)",
            "example": "partner1"
          },
          "referrerSource": {
            "type": "string",
            "maxLength": 255,
            "description": "UTM source parameter (optional)",
            "example": "google"
          },
          "referrerMedium": {
            "type": "string",
            "maxLength": 255,
            "description": "UTM medium parameter (optional)",
            "example": "cpc"
          },
          "referrerCampaign": {
            "type": "string",
            "maxLength": 255,
            "description": "UTM campaign parameter (optional)",
            "example": "launch"
          },
          "referrerUrl": {
            "type": "string",
            "maxLength": 2048,
            "description": "Full referrer URL from registration page (optional)",
            "example": "https://app.nedzo.ai/register?ref=partner1&utm_source=google"
          },
          "toltPartnerId": {
            "type": "string",
            "maxLength": 255,
            "description": "Tolt affiliate partner ID for commission tracking (optional)",
            "example": "partner_abc123"
          },
          "toltClickId": {
            "type": "string",
            "maxLength": 255,
            "description": "Tolt click ID for attribution (optional)",
            "example": "click_xyz789"
          },
          "toltProgramId": {
            "type": "string",
            "maxLength": 255,
            "description": "Tolt program ID (optional)",
            "example": "program_default"
          }
        },
        "required": [
          "email",
          "firstName",
          "lastName"
        ]
      },
      "WebhookSuccessResponse": {
        "type": "object",
        "properties": {
          "executionId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID of the queued workflow execution",
            "example": "987e6543-e21b-12d3-a456-426614174999"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued"
            ],
            "description": "Execution status (always \"queued\" for webhook triggers)",
            "example": "queued"
          }
        },
        "required": [
          "executionId",
          "status"
        ]
      },
      "WebhookContact": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\+?[1-9]\\d{1,14}$",
            "description": "Contact phone number in E.164 format (e.g., +15551234567)",
            "example": "+15551234567"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email address",
            "example": "john@example.com"
          },
          "name": {
            "type": "string",
            "description": "Contact name",
            "example": "John Doe"
          }
        }
      },
      "WebhookPayload": {
        "type": "object",
        "properties": {
          "contactId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID of existing contact in Nedzo",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "contact": {
            "$ref": "#/components/schemas/WebhookContact"
          }
        }
      },
      "StripeWebhookEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "object": {
                "type": "object",
                "additionalProperties": {
                  "nullable": true
                }
              }
            },
            "required": [
              "object"
            ]
          },
          "created": {
            "type": "number"
          },
          "livemode": {
            "type": "boolean"
          },
          "account": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "type",
          "data",
          "created",
          "livemode"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/v1/ghl/agents": {
      "get": {
        "summary": "List agents for GHL workflow dropdown",
        "description": "Returns agents formatted for GoHighLevel workflow builder dropdown. Called by GHL when configuring workflow actions. Uses locationId for workspace lookup instead of API key authentication.",
        "tags": [
          "GoHighLevel"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "GHL location ID for workspace lookup",
              "example": "ghl-location-uuid"
            },
            "required": true,
            "name": "locationId",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Agent options for GHL dropdown. Returns empty options array if location not connected.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GhlAgentsResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ghl/call": {
      "post": {
        "summary": "Trigger call from GHL workflow",
        "description": "Initiates an outbound call when a GoHighLevel workflow action executes. Uses locationId for workspace lookup instead of API key authentication. Returns conversation ID for tracking.",
        "tags": [
          "GoHighLevel"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GhlCallRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Call initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GhlCallResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error - invalid phone number or agent ID format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Location not connected or agent not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "502": {
            "description": "Call could not be initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ghl/contact": {
      "put": {
        "summary": "Upsert contact from GHL",
        "description": "Creates or updates a contact when a GoHighLevel workflow syncs contact data. Uses locationId for workspace lookup instead of API key authentication. Matches contacts by phone number (primary) or email (secondary). Returns contact ID and whether a new contact was created.",
        "tags": [
          "GoHighLevel"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GhlContactUpsertRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created or updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GhlContactUpsertResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error - invalid phone number or email format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Location not connected to Nedzo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete contact from GHL",
        "description": "Soft-deletes a contact when a GoHighLevel workflow removes contact data. Uses locationId for workspace lookup instead of API key authentication. Matches contacts by phone number (primary) or email (secondary). Idempotent - returns success even if contact not found or already deleted.",
        "tags": [
          "GoHighLevel"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GhlContactDeleteRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Contact deleted successfully (or already deleted/not found)"
          },
          "400": {
            "description": "Validation error - invalid phone number or email format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Location not connected to Nedzo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/templates/{id}/preview": {
      "get": {
        "tags": [
          "Templates"
        ],
        "summary": "Get template preview",
        "description": "Preview a template without full content. Public templates can be viewed by anyone. Private templates require authentication and account membership. Returns metadata, item counts, and required integrations.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Template UUID",
              "example": "abc12345-6789-0def-ghij-klmnopqrstuv"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Template preview data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplatePreview"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - template is private and user is not a member",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "404": {
            "description": "Template not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          }
        }
      }
    },
    "/public/widget/{id}/config": {
      "get": {
        "summary": "Get widget configuration",
        "description": "Returns widget styling and Vapi-compatible assistant configuration for embedding. Public endpoint \u2014 no authentication required. IP-rate-limited.",
        "tags": [
          "Public - Widget"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Web agent UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Widget configuration with assistant config",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WidgetConfigResponse"
                }
              }
            }
          },
          "404": {
            "description": "Agent not found, deleted, or inactive",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/public/widget/{id}/impression": {
      "post": {
        "summary": "Record widget impression",
        "description": "Records a widget load impression for analytics. Always returns 204 regardless of success or failure. Public endpoint \u2014 no authentication required.",
        "tags": [
          "Public - Widget"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Web agent UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WidgetImpressionRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Impression recorded (or silently ignored on error)"
          }
        }
      }
    },
    "/public/branding": {
      "get": {
        "summary": "Get branding for current domain",
        "description": "Returns brand name, logo, and color based on the Host header. Used by the frontend to apply white-label branding. Public endpoint \u2014 no authentication required. IP-rate-limited.",
        "tags": [
          "Public - Branding"
        ],
        "responses": {
          "200": {
            "description": "Branding information for the resolved domain",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrandingResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/workspaces": {
      "get": {
        "summary": "List workspaces",
        "description": "List all workspaces accessible to the API key. Account-scoped keys see all workspaces in account. Workspace-scoped keys see only their workspace.",
        "tags": [
          "Workspaces"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Array of workspaces accessible to the API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Workspace"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create workspace",
        "description": "Create a new workspace within the account. Requires account-scoped API key (workspace-scoped keys cannot create workspaces).",
        "tags": [
          "Workspaces"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWorkspace"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workspace created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workspace"
                }
              }
            }
          },
          "400": {
            "description": "Validation error - invalid request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - workspace-scoped keys cannot create workspaces",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/workspaces/{id}": {
      "get": {
        "summary": "Get workspace by ID",
        "description": "Retrieves a specific workspace by its UUID. Requires valid API key with access to the workspace.",
        "tags": [
          "Workspaces"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Workspace retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workspace"
                }
              }
            }
          },
          "400": {
            "description": "Invalid workspace ID format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "API key does not have access to this workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update workspace",
        "description": "Updates workspace details. All fields are optional - only provided fields will be updated. Requires API key with access to the workspace.",
        "tags": [
          "Workspaces"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateWorkspace"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workspace updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workspace"
                }
              }
            }
          },
          "400": {
            "description": "Validation error - invalid request body or workspace ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "API key does not have access to this workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete workspace",
        "description": "Permanently deletes a workspace. Requires API key with access to the workspace. Workspace-scoped keys cannot delete their own workspace.",
        "tags": [
          "Workspaces"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Workspace deleted successfully (no content)"
          },
          "400": {
            "description": "Invalid workspace ID format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "API key does not have access to this workspace or cannot delete own scoped workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/agents": {
      "get": {
