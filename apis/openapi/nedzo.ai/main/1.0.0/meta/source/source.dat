      "SendVerificationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the verification was sent successfully",
            "example": true
          },
          "verificationId": {
            "type": "string",
            "description": "Telnyx verification ID for tracking",
            "example": "12ade33a-21c0-473b-b055-b3c836e1c292"
          },
          "phoneNumber": {
            "type": "string",
            "description": "Phone number the verification was sent to",
            "example": "+13035551234"
          },
          "method": {
            "type": "string",
            "enum": [
              "sms",
              "call"
            ],
            "description": "Delivery method used",
            "example": "sms"
          },
          "timeoutSecs": {
            "type": "number",
            "description": "Seconds until the code expires",
            "example": 300
          }
        },
        "required": [
          "success",
          "verificationId",
          "phoneNumber",
          "method",
          "timeoutSecs"
        ]
      },
      "SendVerificationRequest": {
        "type": "object",
        "properties": {
          "phoneNumber": {
            "type": "string",
            "minLength": 10,
            "description": "Phone number to verify in E.164 format",
            "example": "+13035551234"
          },
          "method": {
            "type": "string",
            "enum": [
              "sms",
              "call"
            ],
            "description": "Verification delivery method",
            "example": "sms"
          }
        },
        "required": [
          "phoneNumber",
          "method"
        ]
      },
      "VerifyCodeResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the code was verified successfully",
            "example": true
          },
          "phoneNumber": {
            "type": "string",
            "description": "Verified phone number",
            "example": "+13035551234"
          },
          "callerIdId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the created caller ID record (if added to workspace)",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "success",
          "phoneNumber"
        ]
      },
      "VerifyCodeRequest": {
        "type": "object",
        "properties": {
          "phoneNumber": {
            "type": "string",
            "minLength": 10,
            "description": "Phone number that received the code in E.164 format",
            "example": "+13035551234"
          },
          "code": {
            "type": "string",
            "minLength": 4,
            "maxLength": 8,
            "description": "Verification code entered by user",
            "example": "123456"
          }
        },
        "required": [
          "phoneNumber",
          "code"
        ]
      },
      "CallerId": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Caller ID record UUID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace UUID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "phoneNumber": {
            "type": "string",
            "description": "Verified phone number",
            "example": "+13035551234"
          },
          "label": {
            "type": "string",
            "nullable": true,
            "description": "Optional label for the caller ID",
            "example": "My Mobile"
          },
          "verifiedAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the phone number was verified",
            "example": "2025-01-15T12:00:00Z"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the record was created",
            "example": "2025-01-15T12:00:00Z"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "phoneNumber",
          "label",
          "verifiedAt",
          "createdAt"
        ]
      },
      "CallerIdListResponse": {
