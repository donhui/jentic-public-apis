          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the agent is active",
            "example": true
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Agent description",
            "example": "Updated description"
          },
          "enabledChannels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "sms",
                "email",
                "whatsapp",
                "instagram",
                "facebook"
              ]
            },
            "description": "Enabled channel types",
            "example": [
              "sms"
            ]
          },
          "waitTimeSeconds": {
            "type": "integer",
            "minimum": 0,
            "maximum": 60,
            "description": "Delay in seconds before AI responds (0-60)",
            "example": 5
          },
          "pauseOnManualMessage": {
            "type": "boolean",
            "description": "Whether to auto-pause AI on manual message",
            "example": true
          },
          "reactivateAfterValue": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Number of time units before auto-reactivation",
            "example": 60
          },
          "reactivateAfterUnit": {
            "type": "string",
            "nullable": true,
            "enum": [
              "minutes",
              "hours",
              "days"
            ],
            "description": "Time unit for reactivation",
            "example": "minutes"
          },
          "maxMessagesPerConversation": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Max AI messages per conversation (null = unlimited)",
            "example": 10
          },
          "maxMessagesSendFinal": {
            "type": "boolean",
            "description": "Whether to send a final message when limit reached",
            "example": true
          },
          "maxMessagesFinalMessage": {
            "type": "string",
            "nullable": true,
            "description": "Custom final message when limit reached",
            "example": "A team member will follow up with you shortly."
          },
          "pauseOnEscalation": {
            "type": "boolean",
            "description": "Whether to pause on escalation event",
            "example": true
          },
          "pauseOnAppointmentBooked": {
            "type": "boolean",
            "description": "Whether to pause on appointment booked",
            "example": true
          },
          "pauseIdleTimeoutSeconds": {
            "type": "integer",
            "minimum": 60,
            "maximum": 3600,
            "description": "Idle timeout seconds for pause_pending transition",
            "example": 300
          },
          "protectionKeywords": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "maxItems": 50,
            "description": "Keywords that immediately pause the conversation",
            "example": [
              "refund",
