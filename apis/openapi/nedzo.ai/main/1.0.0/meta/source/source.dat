            "example": true
          },
          "backgroundSound": {
            "type": "boolean",
            "description": "Enable background sound during calls",
            "example": true
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Agent description",
            "example": "Handles customer inquiries and support requests"
          },
          "openingLine": {
            "type": "string",
            "nullable": true,
            "description": "First message the agent says",
            "example": "Hello! How can I help you today?"
          },
          "knowledgeBaseId": {
            "type": "string",
            "nullable": true,
            "description": "Knowledge base reference ID",
            "example": "kb_123"
          },
          "language": {
            "type": "string",
            "enum": [
              "english",
              "spanish",
              "french",
              "german",
              "portuguese",
              "dutch",
              "chinese",
              "japanese"
            ],
            "description": "Agent language",
            "example": "english"
          },
          "llmProvider": {
            "type": "string",
            "nullable": true,
            "enum": [
              "openai",
              "anthropic",
              "google"
            ],
            "description": "LLM provider for this agent. If null, uses global engine_call_settings default.",
            "example": "openai"
          },
          "voicemail": {
            "type": "boolean",
            "description": "Whether voicemail is enabled",
            "example": false
          },
          "voicemailMessage": {
            "type": "string",
            "nullable": true,
            "description": "Voicemail message",
            "example": "Please leave a message after the tone."
          },
          "hipaaCompliance": {
            "type": "boolean",
            "description": "Whether HIPAA compliance mode is enabled. When enabled, no logs, recordings, or transcriptions will be stored.",
            "example": false
          },
          "callDuration": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60,
            "description": "Maximum call duration in minutes (1-60)",
            "example": 30
          },
          "deletedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Soft delete timestamp (ISO 8601)",
            "example": null
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Agent creation timestamp (ISO 8601)",
            "example": "2025-12-11T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Agent last update timestamp (ISO 8601)",
            "example": "2025-12-11T12:00:00Z"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "name",
          "prompt",
          "voiceId",
          "isActive",
          "backgroundSound",
          "description",
          "openingLine",
          "knowledgeBaseId",
          "language",
          "llmProvider",
          "voicemail",
          "voicemailMessage",
          "hipaaCompliance",
          "callDuration",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateInternalAgent": {
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace ID to create agent in",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Agent name (required)",
            "example": "Customer Support Agent"
          },
          "prompt": {
            "type": "string",
            "nullable": true,
            "description": "System prompt for the agent",
            "example": "You are a helpful customer support assistant..."
          },
          "voiceId": {
            "type": "string",
            "nullable": true,
            "description": "Voice configuration ID",
            "example": "voice_123"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the agent is active (defaults to true)",
            "example": true
          },
          "backgroundSound": {
            "type": "boolean",
            "description": "Enable background sound (defaults to true)",
            "example": true
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Agent description",
            "example": "Handles customer inquiries"
          },
          "openingLine": {
            "type": "string",
            "nullable": true,
            "description": "First message the agent says",
            "example": "Hello! How can I help you today?"
          },
          "knowledgeBaseId": {
            "type": "string",
            "nullable": true,
            "description": "Knowledge base reference ID",
            "example": "kb_123"
          },
          "language": {
            "type": "string",
            "enum": [
              "english",
              "spanish",
              "french",
              "german",
              "portuguese",
              "dutch",
              "chinese",
              "japanese"
            ],
            "description": "Agent language (defaults to english)",
            "example": "english"
          },
          "llmProvider": {
            "type": "string",
            "nullable": true,
            "enum": [
              "openai",
              "anthropic",
              "google"
            ],
            "description": "LLM provider for this agent. If null/omitted, uses global engine_call_settings default.",
            "example": "openai"
          },
          "voicemail": {
            "type": "boolean",
            "description": "Enable voicemail (defaults to false)",
            "example": false
          },
          "voicemailMessage": {
            "type": "string",
            "nullable": true,
            "description": "Voicemail message",
            "example": "Please leave a message after the tone."
          },
          "hipaaCompliance": {
            "type": "boolean",
            "description": "Enable HIPAA compliance mode (defaults to false). When enabled, no logs, recordings, or transcriptions will be stored.",
            "example": false
          },
          "callDuration": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60,
            "description": "Maximum call duration in minutes (1-60, defaults to 30)",
            "example": 30
          }
        },
        "required": [
          "workspaceId",
          "name"
        ]
      },
      "ToolDefinition": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "function"
            ],
            "description": "Tool type",
            "example": "function"
          },
          "function": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Function name",
                "example": "fetch_calendar_slots"
              },
              "description": {
                "type": "string",
                "description": "Function description",
                "example": "Get available appointment times"
              },
              "parameters": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "object"
                    ]
                  },
                  "properties": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "description": "Parameter type",
                          "example": "string"
                        },
                        "description": {
                          "type": "string",
                          "description": "Parameter description",
                          "example": "The calendar name to use"
                        }
                      },
                      "required": [
                        "type"
                      ]
                    }
                  },
                  "required": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "type",
                  "properties"
                ]
              }
            },
            "required": [
              "name",
              "description",
              "parameters"
            ]
          }
        },
        "required": [
          "type",
          "function"
        ]
      },
      "McpServerConfig": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "calendar",
              "email",
              "slack",
              "sms"
            ],
            "description": "MCP server type",
            "example": "calendar"
          },
          "url": {
            "type": "string",
            "description": "MCP server URL",
            "example": "https://mcp.nedzo.ai/calendar"
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Headers to send with MCP requests",
            "example": {
              "x-workspace-id": "ws-123",
              "x-agent-id": "agent-123"
            }
          }
        },
        "required": [
          "type",
          "url",
          "headers"
        ]
      },
      "UnifiedAgentConfig": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Agent ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace ID",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Agent name",
            "example": "Sales Agent"
          },
          "agentType": {
            "type": "string",
            "enum": [
              "inbound_voice",
              "outbound_voice",
              "chat",
              "web_chat",
              "web_voice",
              "web_both"
            ],
            "description": "Agent type (inbound_voice, outbound_voice, chat, web_chat, web_voice, web_both)",
            "example": "outbound_voice"
          },
          "generatedPrompt": {
            "type": "string",
            "description": "Pre-generated system prompt from centralized builder",
            "example": "You are a helpful sales assistant..."
          },
          "toolDefinitions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToolDefinition"
            },
            "description": "OpenAI-compatible tool definitions (empty array if no actions configured)"
          },
          "mcpServers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/McpServerConfig"
            },
            "description": "MCP server configurations for tool execution (empty array if no MCP-enabled actions)"
          },
          "builderVersion": {
            "type": "string",
            "description": "Builder version for API contract versioning",
            "example": "v1"
          },
          "llmProvider": {
            "type": "string",
            "nullable": true,
            "description": "LLM provider (null when using workspace default)",
            "example": "openai"
          },
          "llmModel": {
            "type": "string",
            "nullable": true,
            "description": "LLM model name (null when using workspace default)",
            "example": "gpt-4o"
          },
          "temperature": {
            "type": "number",
            "description": "LLM temperature setting (defaults to 0.7 if not set)",
            "example": 0.7
          },
          "maxTokens": {
            "type": "number",
            "description": "Maximum tokens for LLM response (defaults to 1024 if not set)",
            "example": 1024
          },
          "openingLine": {
            "type": "string",
            "nullable": true,
            "description": "First message the agent says (null when no greeting configured)",
            "example": "Hello! How can I help you today?"
          },
          "knowledgeBaseId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "Knowledge base ID for RAG (null when no KB attached)",
            "example": "kb_123"
          },
          "calendarActions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string"
                },
                "condition": {
                  "type": "string",
                  "nullable": true
                },
                "calendarType": {
                  "type": "string"
                },
                "calendarId": {
                  "type": "string"
                },
                "timezone": {
                  "type": "string",
                  "nullable": true
                }
              },
              "required": [
                "id",
                "name",
                "condition",
                "calendarType",
                "calendarId",
                "timezone"
              ]
            },
            "description": "Calendar actions configured for this agent (used for tool argument enrichment)"
          },
          "slackActions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string"
                },
                "condition": {
                  "type": "string",
                  "nullable": true
                },
                "channelId": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "name",
                "condition",
                "channelId"
              ]
            },
            "description": "Slack actions configured for this agent (used for tool argument enrichment)"
          },
          "emailActions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string"
                },
                "condition": {
                  "type": "string",
                  "nullable": true
                },
                "fromName": {
                  "type": "string"
                },
                "fromAddress": {
                  "type": "string"
                },
                "subject": {
                  "type": "string"
                },
                "recipientType": {
                  "type": "string",
                  "enum": [
                    "contact",
                    "specific",
                    "ask"
                  ]
                },
                "messageMode": {
                  "type": "string",
                  "enum": [
                    "fixed",
                    "ai_generated"
                  ]
                }
              },
              "required": [
                "id",
                "name",
                "condition",
                "fromName",
                "fromAddress",
                "subject",
                "recipientType",
                "messageMode"
              ]
            },
            "description": "Email actions configured for this agent (used for tool argument enrichment)"
          },
          "customActions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string"
                },
                "condition": {
                  "type": "string",
                  "nullable": true
                },
                "method": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "headers": {
                  "type": "object",
                  "nullable": true,
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "authType": {
                  "type": "string",
                  "nullable": true,
                  "enum": [
                    "bearer",
                    "api_key",
                    "basic"
                  ]
                },
                "authValue": {
                  "type": "string",
                  "nullable": true
                },
                "parameters": {
                  "type": "array",
                  "nullable": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "name"
                    ]
                  }
                },
                "isActive": {
                  "type": "boolean"
                }
              },
              "required": [
                "id",
                "name",
                "condition",
                "method",
                "url",
                "headers",
                "authType",
                "authValue",
                "parameters",
                "isActive"
              ]
            },
            "description": "Custom actions configured for this agent (used for webhook tool execution)"
          },
          "transferActions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string"
                },
                "condition": {
                  "type": "string",
                  "nullable": true
                },
                "targetNumber": {
                  "type": "string",
                  "nullable": true
                }
              },
              "required": [
                "id",
                "name",
                "condition",
                "targetNumber"
              ]
            },
            "description": "Transfer actions configured for this agent"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "name",
          "agentType",
          "generatedPrompt",
          "toolDefinitions",
          "mcpServers",
          "builderVersion",
          "llmProvider",
          "llmModel",
          "temperature",
          "maxTokens",
          "openingLine",
          "knowledgeBaseId",
          "calendarActions",
          "slackActions",
          "emailActions",
          "customActions",
          "transferActions"
        ]
      },
      "CalendarActionConfig": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Calendar action ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Display name for the calendar action",
