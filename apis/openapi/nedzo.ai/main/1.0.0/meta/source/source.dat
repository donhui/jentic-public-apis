      "TestWorkflowResponse": {
        "type": "object",
        "properties": {
          "executionId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the test execution",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued"
            ],
            "description": "Status of the test execution (always queued on success)",
