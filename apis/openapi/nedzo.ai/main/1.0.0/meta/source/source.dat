          }
        },
        "required": [
          "executionId",
          "cancelledAt"
        ]
      },
      "TemplateResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique template identifier",
            "example": "abc12345-6789-0def-ghij-klmnopqrstuv"
          },
          "accountId": {
            "type": "string",
            "format": "uuid",
            "description": "Account that owns this template",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Template name",
            "example": "Sales Appointment Setter"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Template description",
            "example": "AI agent configured for booking sales appointments"
          },
          "templateType": {
            "type": "string",
            "enum": [
              "agent",
              "workflow",
              "workspace"
            ],
            "description": "The type of entity this template was created from",
            "example": "agent"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "private"
            ],
            "description": "Template visibility - public templates can be discovered by anyone",
            "example": "private"
          },
          "schemaVersion": {
            "type": "string",
            "description": "Snapshot schema version for compatibility",
            "example": "1.0.0"
          },
          "snapshotSizeBytes": {
            "type": "number",
            "nullable": true,
            "description": "Uncompressed snapshot size in bytes",
            "example": 15234
          },
          "requiredIntegrations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Integration types required by this template",
            "example": [
              "cal_com",
              "leadconnector"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 creation timestamp",
            "example": "2026-01-26T10:30:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 last update timestamp",
            "example": "2026-01-26T10:30:00.000Z"
          }
        },
        "required": [
          "id",
          "accountId",
          "name",
          "description",
          "templateType",
          "visibility",
          "schemaVersion",
          "snapshotSizeBytes",
          "requiredIntegrations",
          "createdAt",
          "updatedAt"
        ]
      },
