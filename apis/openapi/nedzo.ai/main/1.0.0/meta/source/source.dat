    "/internal/telephony/available-countries": {
      "get": {
        "tags": [
          "Internal - Telephony"
        ],
        "summary": "Get available countries",
        "description": "Returns countries that have synced requirement templates and are available for compliance bundles",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Available countries with supported phone types",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "countries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {
                            "type": "string",
                            "minLength": 2,
                            "maxLength": 2,
                            "description": "ISO 3166-1 alpha-2 country code"
                          },
                          "name": {
                            "type": "string",
                            "description": "Human-readable country name"
                          },
                          "supportedTypes": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "enum": [
                                "local",
                                "mobile",
                                "tollfree",
                                "national"
                              ]
                            },
                            "description": "Phone number types supported in this country"
                          }
                        },
                        "required": [
                          "code",
                          "name",
                          "supportedTypes"
                        ]
                      }
                    }
                  },
                  "required": [
                    "countries"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
