      "PhoneNumber": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace ID",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "number": {
            "type": "string",
            "description": "Phone number in E.164 format",
            "example": "+14155551234"
          },
          "countryDial": {
            "type": "string",
            "nullable": true,
            "description": "Country dialing code",
            "example": "+1"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "active",
              "payment_failed",
              "activation_failed"
            ],
            "description": "Phone number status",
            "example": "active"
          },
          "type": {
            "type": "string",
            "enum": [
              "inbound_outbound",
              "outbound_only"
            ],
            "description": "Phone number type",
            "example": "outbound_only"
          },
          "engineId": {
            "type": "string",
            "nullable": true,
            "description": "Voice engine ID",
            "example": "asst_abc123"
          },
          "telephonyId": {
            "type": "string",
            "nullable": true,
            "description": "Provider phone number ID",
            "example": "1234567890"
          },
          "price": {
            "type": "number",
            "nullable": true,
            "description": "Monthly price in USD",
            "example": 1.5
          },
          "purchasedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Purchase timestamp",
            "example": "2025-12-11T12:00:00Z"
          },
          "renewalAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Next renewal timestamp",
            "example": "2026-01-11T12:00:00Z"
          },
          "dialsToday": {
            "type": "number",
            "description": "Dials today",
            "example": 0
          },
          "dialsTotal": {
            "type": "number",
            "description": "Total dials",
            "example": 0
          },
          "available": {
            "type": "boolean",
            "description": "Available for use",
            "example": true
          },
          "friendlyName": {
            "type": "string",
            "nullable": true,
            "description": "User-defined label",
            "example": "Main Office"
          },
          "inboundAgentId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "Voice agent for inbound calls",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "chatAgentId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "Chat agent for SMS",
            "example": "567e4567-e89b-12d3-a456-426614174000"
          },
          "fallbackEnabled": {
            "type": "boolean",
            "description": "Ring human first before AI",
            "example": false
          },
          "fallbackNumber": {
            "type": "string",
            "nullable": true,
            "description": "Human number to ring first",
            "example": "+14155559999"
          },
          "fallbackRingDuration": {
            "type": "number",
            "minimum": 1,
            "maximum": 60,
            "description": "Seconds to ring before AI (1-60)",
            "example": 20
          },
          "purchaseConsentAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Timestamp when user consented to purchase",
            "example": "2026-01-30T12:00:00Z"
          },
          "purchaseConsentUserId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "User who gave purchase consent",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "purchaseConsentIp": {
            "type": "string",
            "nullable": true,
            "description": "IP address at time of consent",
            "example": "192.168.1.1"
          },
          "purchaseConsentUserAgent": {
            "type": "string",
            "nullable": true,
            "description": "User agent at time of consent",
            "example": "Mozilla/5.0..."
          },
          "purchasePriceCents": {
            "type": "number",
            "nullable": true,
            "description": "Price user agreed to pay in cents",
            "example": 499
          },
          "vapiSyncStatus": {
            "type": "string",
            "nullable": true,
            "enum": [
              "pending",
              "synced",
              "failed"
            ],
            "description": "VAPI sync status",
            "example": "synced"
          },
          "deletedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Soft delete timestamp",
            "example": null
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-12-11T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-12-11T12:00:00Z"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "number",
          "countryDial",
          "status",
          "type",
          "engineId",
          "telephonyId",
          "price",
          "purchasedAt",
          "renewalAt",
          "dialsToday",
          "dialsTotal",
          "available",
          "friendlyName",
          "inboundAgentId",
          "chatAgentId",
          "fallbackEnabled",
          "fallbackNumber",
          "fallbackRingDuration",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "AvailablePhoneNumber": {
        "type": "object",
        "properties": {
          "phoneNumber": {
            "type": "string",
