    "/internal/wallet/workspace/{workspaceId}/topup": {
      "post": {
        "summary": "Top-up workspace wallet",
        "description": "Top-up a workspace wallet with conditional routing: if workspace has an active rebilling subscription, charges via Stripe Connect; otherwise debits from parent account wallet.",
        "tags": [
          "Internal - Wallet"
        ],
        "security": [
          {
            "serviceKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace ID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TopupWorkspaceWallet"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workspace wallet top-up initiated or completed",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/WorkspaceWalletConnectResponse"
                    },
                    {
                      "$ref": "#/components/schemas/WorkspaceWalletTransferResponse"
                    }
                  ],
                  "description": "Response varies based on routing: Connect path returns client secret, account transfer path returns new balance"
                }
              }
            }
          },
          "400": {
            "description": "Validation error (amount below minimum or insufficient account balance)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace or account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "502": {
            "description": "Payment service error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/wallet/transactions": {
      "get": {
        "summary": "List wallet transactions",
        "description": "List wallet transactions (top-ups, debits, refunds) for an account. Transactions are ordered by date descending.",
        "tags": [
          "Internal - Wallet"
        ],
        "security": [
          {
            "serviceKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Account ID to list transactions for",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "accountId",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20,
              "description": "Number of transactions to return",
              "example": 20
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "nullable": true,
              "minimum": 0,
              "default": 0,
              "description": "Number of transactions to skip",
              "example": 0
            },
            "required": false,
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet transactions retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WalletTransactionsResponse"
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
