          "domainVerifiedAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "EmailIntegrationWithDns": {
        "allOf": [
          {
            "$ref": "#/components/schemas/EmailIntegration"
          },
          {
            "type": "object",
            "nullable": true,
            "properties": {
              "sendingDnsRecords": {
                "type": "array",
                "nullable": true,
                "items": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/DnsRecord"
                    },
                    {
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "TXT",
                            "CNAME",
                            "MX"
                          ],
                          "description": "DNS record type"
                        },
                        "name": {
                          "type": "string",
                          "description": "DNS record name/host"
                        },
                        "value": {
                          "type": "string",
                          "description": "DNS record value"
                        },
                        "valid": {
                          "type": "boolean",
                          "description": "Whether record is verified"
                        },
                        "purpose": {
                          "type": "string",
                          "enum": [
                            "spf",
                            "dkim",
                            "mx",
                            "dmarc"
                          ],
                          "description": "Purpose classification for display grouping"
                        },
                        "recommended": {
                          "type": "boolean",
                          "description": "Whether this is a recommended (not required) record"
                        }
                      }
                    }
                  ]
                },
                "description": "DNS records for sending verification"
              },
              "receivingDnsRecords": {
                "type": "array",
                "nullable": true,
                "items": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/DnsRecord"
                    },
                    {
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "TXT",
                            "CNAME",
                            "MX"
                          ],
                          "description": "DNS record type"
                        },
                        "name": {
                          "type": "string",
                          "description": "DNS record name/host"
                        },
                        "value": {
                          "type": "string",
                          "description": "DNS record value"
                        },
                        "valid": {
                          "type": "boolean",
                          "description": "Whether record is verified"
                        },
                        "purpose": {
                          "type": "string",
                          "enum": [
                            "spf",
                            "dkim",
                            "mx",
                            "dmarc"
                          ],
                          "description": "Purpose classification for display grouping"
                        },
                        "recommended": {
                          "type": "boolean",
                          "description": "Whether this is a recommended (not required) record"
                        }
                      }
                    }
                  ]
                },
                "description": "DNS records for receiving (if configured)"
              },
              "allDnsRecords": {
                "type": "array",
                "nullable": true,
                "items": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/DnsRecord"
                    },
                    {
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "TXT",
                            "CNAME",
                            "MX"
                          ],
                          "description": "DNS record type"
                        },
                        "name": {
                          "type": "string",
                          "description": "DNS record name/host"
                        },
                        "value": {
                          "type": "string",
                          "description": "DNS record value"
                        },
                        "valid": {
                          "type": "boolean",
                          "description": "Whether record is verified"
                        },
                        "purpose": {
                          "type": "string",
                          "enum": [
                            "spf",
                            "dkim",
                            "mx",
                            "dmarc"
                          ],
                          "description": "Purpose classification for display grouping"
                        },
                        "recommended": {
                          "type": "boolean",
                          "description": "Whether this is a recommended (not required) record"
                        }
                      }
                    }
                  ]
                },
                "description": "All DNS records combined and sorted by purpose"
              }
            },
            "required": [
              "sendingDnsRecords",
              "receivingDnsRecords",
              "allDnsRecords"
            ]
          }
        ]
      },
