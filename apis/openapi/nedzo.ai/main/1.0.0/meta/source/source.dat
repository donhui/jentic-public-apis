            "example": "https://storage.example.com/docs/file.pdf"
          },
          "fileName": {
            "type": "string",
            "nullable": true,
            "description": "Original file name (for file type)",
            "example": "product-docs.pdf"
          },
          "websiteUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "Website URL (for website type)",
