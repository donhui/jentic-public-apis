          },
          "textContent": {
            "type": "string",
            "nullable": true,
            "description": "Text content (for text type)",
            "example": "Company overview..."
          },
          "deletedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Soft delete timestamp",
            "example": null
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-12-11T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-12-11T12:00:00Z"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "name",
          "type",
          "fileUrl",
          "fileName",
          "websiteUrl",
          "textContent",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ]
      },
