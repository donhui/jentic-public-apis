            "type": "string",
            "nullable": true,
            "description": "National format",
            "example": "(415) 555-1234"
          },
          "phoneNumberType": {
            "type": "string",
            "description": "Type",
            "example": "local"
          },
          "regionInformation": {
            "nullable": true
          },
          "cost": {
            "nullable": true
          },
          "features": {
            "nullable": true
          }
