                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          }
