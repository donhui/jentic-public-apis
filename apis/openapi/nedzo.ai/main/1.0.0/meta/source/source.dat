    "/internal/billing/plans": {
      "get": {
        "tags": [
          "Internal - Billing"
        ],
        "summary": "Get available subscription plans",
        "description": "Returns all available subscription plans with pricing and features",
        "responses": {
          "200": {
            "description": "List of available plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "plans": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Plan identifier"
                          },
                          "name": {
                            "type": "string",
                            "description": "Plan name"
                          },
                          "description": {
                            "type": "string",
                            "nullable": true,
                            "description": "Plan description"
                          },
                          "stripeProductId": {
                            "type": "string",
                            "description": "Stripe product ID"
                          },
                          "stripePriceIdMonthly": {
                            "type": "string",
                            "description": "Stripe price ID for monthly billing"
                          },
                          "stripePriceIdAnnual": {
                            "type": "string",
                            "nullable": true,
                            "description": "Stripe price ID for annual billing"
                          },
                          "monthlyPrice": {
                            "type": "number",
                            "description": "Monthly price in cents"
                          },
                          "annualPrice": {
                            "type": "number",
                            "nullable": true,
                            "description": "Annual price in cents"
                          },
                          "features": {
                            "type": "object",
                            "properties": {
                              "workspaces": {
                                "anyOf": [
                                  {
                                    "type": "number"
                                  },
                                  {
                                    "type": "string",
                                    "enum": [
                                      "unlimited"
                                    ]
                                  }
                                ],
                                "description": "Number of workspaces allowed"
                              },
                              "concurrentCalls": {
                                "type": "number",
                                "description": "Maximum concurrent calls"
                              },
                              "whiteLabel": {
                                "type": "boolean",
                                "description": "White-label branding enabled"
                              },
                              "rebilling": {
                                "type": "boolean",
                                "description": "Rebilling feature enabled"
                              },
                              "teamAccess": {
                                "type": "boolean",
                                "description": "Team access enabled"
                              }
                            },
                            "required": [
                              "workspaces",
                              "concurrentCalls",
                              "whiteLabel",
                              "rebilling",
                              "teamAccess"
                            ]
                          },
                          "featureList": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "description": "Human-readable feature list"
                          },
                          "displayOrder": {
                            "type": "number",
                            "description": "Display order"
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "description",
                          "stripeProductId",
                          "stripePriceIdMonthly",
                          "stripePriceIdAnnual",
                          "monthlyPrice",
                          "annualPrice",
                          "features",
                          "featureList",
                          "displayOrder"
                        ]
                      }
                    }
                  },
                  "required": [
                    "plans"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing JWT token"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/internal/billing/subscribe": {
      "post": {
