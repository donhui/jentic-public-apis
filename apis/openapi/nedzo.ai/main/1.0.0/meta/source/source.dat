      "CreateAccount": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Account name (required, whitespace trimmed)",
            "example": "Acme Corp"
          },
          "subscriptionStatus": {
            "type": "string",
            "enum": [
              "trialing",
              "active",
              "past_due",
              "canceled",
              "unpaid"
            ],
            "description": "Initial subscription status (defaults to trialing)",
            "example": "trialing"
          },
          "subscriptionPlan": {
            "type": "string",
            "nullable": true,
            "enum": [
              "trial",
              "business",
              "agency",
              "enterprise"
            ],
            "description": "Initial subscription plan",
            "example": "business"
          },
          "subscriptionEndsAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Subscription end timestamp (ISO 8601)",
            "example": "2025-12-31T23:59:59Z"
          },
          "trialStatus": {
            "type": "string",
            "nullable": true,
            "enum": [
              "active_trial",
              "trial_ended",
              "converted",
              "churned_before_trial_end"
            ],
            "description": "Initial trial status",
            "example": "active_trial"
          },
          "stripeCustomerId": {
            "type": "string",
            "nullable": true,
            "description": "Stripe customer ID",
            "example": "cus_1234567890"
          },
          "stripeSubscriptionId": {
            "type": "string",
            "nullable": true,
            "description": "Stripe subscription ID",
            "example": "sub_1234567890"
          },
          "stripeProductId": {
            "type": "string",
            "nullable": true,
            "description": "Stripe product ID",
            "example": "prod_1234567890"
          },
          "stripePriceId": {
            "type": "string",
            "nullable": true,
            "description": "Stripe price ID",
            "example": "price_1234567890"
          },
          "stripeCancelAtPeriodEnd": {
            "type": "boolean",
            "description": "Whether subscription cancels at period end",
            "example": false
          },
          "stripeConnectAccountId": {
            "type": "string",
            "nullable": true,
            "description": "Stripe Connect account ID",
            "example": "acct_1234567890"
          },
          "stripeConnectOnboardingComplete": {
            "type": "boolean",
            "description": "Whether Stripe Connect onboarding is complete",
            "example": false
          },
          "stripeConnectChargesEnabled": {
            "type": "boolean",
            "description": "Whether Stripe Connect charges are enabled",
            "example": false
          },
          "stripeConnectPayoutsEnabled": {
            "type": "boolean",
            "description": "Whether Stripe Connect payouts are enabled",
            "example": false
          },
          "stripeConnectDefaultCurrency": {
            "type": "string",
            "nullable": true,
            "enum": [
              "usd",
              "eur",
              "gbp",
              "cad",
              "aud",
              "jpy",
              "chf",
              "nzd",
              "sgd",
              "hkd",
              "mxn",
              "brl"
            ],
            "description": "Stripe Connect default currency (ISO 4217 lowercase)",
            "example": "usd"
          },
          "toltPartner": {
            "type": "string",
            "nullable": true,
            "description": "Tolt partner identifier",
            "example": "partner_abc123"
          },
          "toltReferral": {
            "type": "string",
            "nullable": true,
            "description": "Tolt referral identifier",
            "example": "ref_xyz789"
          },
          "toltPartnerId": {
            "type": "string",
            "nullable": true,
            "description": "Tolt affiliate partner ID for commission tracking",
            "example": "partner_abc123"
          },
          "toltClickId": {
            "type": "string",
            "nullable": true,
            "description": "Tolt click ID for attribution",
            "example": "click_xyz789"
          },
          "toltProgramId": {
            "type": "string",
            "nullable": true,
            "description": "Tolt program ID",
            "example": "program_default"
          },
          "whiteLabelActive": {
            "type": "boolean",
            "description": "Whether white labeling is active",
            "example": false
          },
          "whiteLabelName": {
            "type": "string",
            "nullable": true,
            "description": "White label brand name",
            "example": "Custom Brand"
          },
          "whiteLabelIcon": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "White label icon URL (must be valid URL)",
            "example": "https://example.com/icon.png"
          },
          "whiteLabelUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "White label URL (must be valid URL)",
            "example": "https://custom.example.com"
          },
          "whiteLabelApiDomain": {
            "type": "string",
            "nullable": true,
            "description": "White label API domain",
            "example": "api.custom.example.com"
          },
          "whiteLabelDomainVerified": {
            "type": "boolean",
            "description": "Whether app domain is verified",
            "example": false
          },
          "whiteLabelApiDomainVerified": {
            "type": "boolean",
            "description": "Whether API domain is verified",
            "example": false
          },
          "whiteLabelDefaultTheme": {
            "type": "string",
            "enum": [
              "light",
              "dark",
              "system"
            ],
            "description": "Default theme for white label (light, dark, or system)",
            "example": "system"
          },
          "whiteLabelPrivacyPolicyUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "Privacy policy URL for white label",
            "example": "https://custom.example.com/privacy"
          },
          "whiteLabelTermsUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "Terms of service URL for white label",
            "example": "https://custom.example.com/terms"
          },
          "whiteLabelCustomHeadJs": {
            "type": "string",
            "nullable": true,
            "description": "Custom JavaScript to inject in head",
            "example": "<!-- analytics -->"
          },
          "whiteLabelCustomBodyJs": {
            "type": "string",
            "nullable": true,
            "description": "Custom JavaScript to inject in body",
            "example": "<!-- tracking -->"
          }
        },
        "required": [
          "name"
        ]
      },
