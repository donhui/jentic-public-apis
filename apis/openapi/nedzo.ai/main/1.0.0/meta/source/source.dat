          },
          "name": {
            "type": "string",
            "description": "Display name",
            "example": "Product Documentation"
          },
          "type": {
            "type": "string",
            "enum": [
              "file",
              "website",
              "text"
            ],
            "description": "Type of knowledge item",
            "example": "file"
          },
          "fileUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
