      "delete": {
        "summary": "Cancel subscription",
        "description": "Cancel subscription immediately.",
        "tags": [
          "Internal - Billing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Account UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "accountId",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Subscription cancelled successfully"
