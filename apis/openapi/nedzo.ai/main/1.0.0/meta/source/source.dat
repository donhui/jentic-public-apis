          "id",
          "agentId",
          "name",
          "phoneNumberId",
          "recipientType",
          "recipientValue",
          "messageTemplate",
          "messageMode",
          "condition",
          "isActive",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ]
      },
