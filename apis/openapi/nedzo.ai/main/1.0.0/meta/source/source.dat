      "post": {
        "summary": "Invite user to account",
        "description": "Invite a new member to the account via email. Creates user in Supabase Auth, public.users, workspace memberships, and permissions (for role=user). Sends branded invite email via Mailgun. Requires JWT auth with admin/owner role.",
