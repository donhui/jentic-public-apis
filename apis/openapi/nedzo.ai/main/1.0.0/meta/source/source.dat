    "/internal/workspaces/{workspaceId}/billing/customers/link": {
      "post": {
        "summary": "Link existing Stripe customer (Admin only)",
        "description": "Link an existing customer from connected Stripe to this workspace. Enforces 1:1 constraint.",
        "tags": [
          "Workspace Billing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": {
                    "type": "string",
                    "description": "Existing Stripe customer ID on connected account",
                    "example": "cus_xyz123"
                  }
                },
                "required": [
                  "customerId"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer linked",
