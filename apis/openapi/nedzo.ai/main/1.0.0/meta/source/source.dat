      "WorkflowVersionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique version record identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workflowId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the workflow this version belongs to",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "version": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Version number (increments with each publish)",
