            "example": "Acme Corp"
          },
          "locationName": {
            "type": "string",
            "nullable": true,
            "description": "Friendly name for the address",
            "example": "HQ - San Francisco"
          },
          "streetAddress": {
            "type": "string",
            "nullable": true,
            "description": "Street address",
            "example": "123 Main St"
          },
          "city": {
            "type": "string",
            "nullable": true,
            "description": "City",
            "example": "New York"
          },
          "state": {
            "type": "string",
            "nullable": true,
            "description": "State/Province (or County for UK)",
            "example": "NY"
          },
          "zip": {
            "type": "string",
