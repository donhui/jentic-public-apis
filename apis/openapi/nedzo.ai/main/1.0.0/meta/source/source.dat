      "OAuthConnection": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace ID",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "provider": {
            "type": "string",
            "enum": [
              "cal_com",
              "calendly",
              "leadconnector",
              "google",
              "slack"
            ],
            "description": "OAuth provider",
            "example": "calendly"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "needs_reconnect",
              "error"
            ],
            "description": "Connection status",
            "example": "active"
          },
          "tokenExpiresAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Token expiration timestamp",
            "example": "2025-12-31T00:00:00Z"
          },
          "providerUserId": {
            "type": "string",
            "nullable": true,
            "description": "User ID in provider",
            "example": "12345"
          },
          "providerEmail": {
            "type": "string",
            "nullable": true,
            "description": "Email in provider",
            "example": "user@example.com"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-12-11T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-12-11T12:00:00Z"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "provider",
          "status",
          "tokenExpiresAt",
          "providerUserId",
          "providerEmail",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateOAuthConnection": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "cal_com",
              "calendly",
              "leadconnector",
              "google",
              "slack"
            ],
            "description": "OAuth provider",
            "example": "calendly"
          },
          "accessToken": {
            "type": "string",
            "minLength": 1,
            "description": "OAuth access token",
            "example": "eyJ..."
          },
          "refreshToken": {
            "type": "string",
            "nullable": true,
            "description": "OAuth refresh token",
            "example": "eyJ..."
          },
          "tokenExpiresAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Token expiration timestamp",
            "example": "2025-12-31T00:00:00Z"
          },
          "providerUserId": {
            "type": "string",
            "nullable": true,
            "description": "User ID in provider",
            "example": "12345"
          },
          "providerEmail": {
            "type": "string",
            "nullable": true,
            "format": "email",
            "description": "Email in provider",
            "example": "user@example.com"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "default": {},
            "description": "Provider-specific metadata",
            "example": {
              "token_type": "Bearer"
            }
          }
        },
        "required": [
          "provider",
          "accessToken"
        ]
      },
