    "/v1/call": {
      "post": {
        "summary": "Initiate outbound call",
        "description": "Initiate an outbound voice call to the specified phone number using the configured agent. Returns a call ID immediately for tracking. The call is placed asynchronously - use the conversations endpoint to retrieve call results once the call completes. Rate limited to 10 requests per minute.",
        "tags": [
          "Calls"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCallRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Call initiated successfully. Returns call ID for tracking.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error - invalid phone number format, invalid agent ID, agent not active, or no phone number available for the workspace.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Trial expired - please subscribe to continue using Nedzo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Agent not found (includes unauthorized access for security)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (10 requests per minute). Retry-After header included.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "502": {
            "description": "Call could not be initiated. Please try again.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/onboarding/complete": {
      "post": {
        "tags": [
          "Internal - Onboarding"
        ],
        "summary": "Complete user onboarding",
        "description": "Atomically creates account, user, and workspace for new user",
        "requestBody": {
          "description": "Onboarding data",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100,
                    "description": "User first name",
                    "example": "John"
                  },
                  "lastName": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100,
                    "description": "User last name",
                    "example": "Doe"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "User email from auth user",
                    "example": "john@example.com"
                  },
                  "phone": {
                    "type": "string",
                    "nullable": true,
                    "description": "User phone number (optional)",
                    "example": "+1 (555) 123-4567"
                  },
                  "businessName": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 200,
                    "description": "Business/account name",
                    "example": "Acme Inc."
                  },
                  "industry": {
                    "type": "string",
                    "nullable": true,
                    "maxLength": 100,
                    "description": "Business industry (optional)",
                    "example": "Real Estate"
                  },
                  "useCase": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1000,
                    "description": "What the user will use Nedzo for",
                    "example": "Automating appointment scheduling for real estate showings"
                  },
                  "subscriptionPlan": {
                    "type": "string",
                    "enum": [
                      "trial",
                      "business",
                      "agency",
                      "enterprise"
                    ],
                    "description": "Selected subscription plan (trial, business, agency, or enterprise)",
                    "example": "trial"
                  },
                  "tosAcceptedAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 timestamp when TOS was accepted",
                    "example": "2024-01-16T12:00:00Z"
                  },
                  "marketingOptIn": {
                    "type": "boolean",
                    "description": "Whether user opted in to marketing emails",
                    "example": false
                  },
                  "attributionSource": {
                    "type": "string",
                    "description": "Comma-separated list of attribution sources",
                    "example": "Google/search engine, Friend or family"
                  },
                  "referrerCode": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Referral code from ref URL parameter (optional)",
                    "example": "partner1"
                  },
                  "referrerSource": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "UTM source parameter (optional)",
                    "example": "google"
                  },
                  "referrerMedium": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "UTM medium parameter (optional)",
                    "example": "cpc"
                  },
                  "referrerCampaign": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "UTM campaign parameter (optional)",
                    "example": "launch"
                  },
                  "referrerUrl": {
                    "type": "string",
                    "maxLength": 2048,
                    "description": "Full referrer URL from registration page (optional)",
                    "example": "https://app.nedzo.ai/register?ref=partner1&utm_source=google"
                  },
                  "toltPartnerId": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Tolt affiliate partner ID for commission tracking (optional)",
                    "example": "partner_abc123"
                  },
                  "toltClickId": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Tolt click ID for attribution (optional)",
                    "example": "click_xyz789"
                  },
                  "toltProgramId": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Tolt program ID (optional)",
                    "example": "program_default"
                  }
                },
                "required": [
                  "firstName",
                  "lastName",
                  "email",
                  "businessName",
                  "useCase",
                  "subscriptionPlan",
                  "tosAcceptedAt",
                  "marketingOptIn"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Onboarding completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accountId": {
                      "type": "string",
                      "format": "uuid",
                      "description": "Created account ID",
                      "example": "123e4567-e89b-12d3-a456-426614174000"
                    },
                    "workspaceId": {
                      "type": "string",
                      "format": "uuid",
                      "description": "Created workspace ID",
                      "example": "123e4567-e89b-12d3-a456-426614174001"
                    },
                    "workspaceSlug": {
                      "type": "string",
                      "description": "Workspace slug for routing",
                      "example": "acme-inc-abc123"
                    },
                    "userId": {
                      "type": "string",
                      "format": "uuid",
                      "description": "Created user ID",
                      "example": "123e4567-e89b-12d3-a456-426614174002"
                    }
                  },
                  "required": [
                    "accountId",
                    "workspaceId",
                    "workspaceSlug",
                    "userId"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - JWT required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - User already has an account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/onboarding/plans": {
      "get": {
        "tags": [
          "Internal - Onboarding"
        ],
        "summary": "Get available subscription plans",
        "description": "Returns available subscription plans for plan selection during onboarding. Uses onboarding auth (no user record required).",
        "responses": {
          "200": {
            "description": "List of available plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "plans": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Plan identifier"
                          },
                          "name": {
                            "type": "string",
                            "description": "Plan name"
                          },
                          "description": {
                            "type": "string",
                            "nullable": true,
                            "description": "Plan description"
                          },
                          "stripeProductId": {
                            "type": "string",
                            "description": "Stripe product ID"
                          },
                          "stripePriceIdMonthly": {
                            "type": "string",
                            "description": "Stripe price ID for monthly billing"
                          },
                          "stripePriceIdAnnual": {
                            "type": "string",
                            "nullable": true,
                            "description": "Stripe price ID for annual billing"
                          },
                          "monthlyPrice": {
                            "type": "number",
                            "description": "Monthly price in cents"
                          },
                          "annualPrice": {
                            "type": "number",
                            "nullable": true,
                            "description": "Annual price in cents"
                          },
                          "features": {
                            "type": "object",
                            "properties": {
                              "workspaces": {
                                "anyOf": [
                                  {
                                    "type": "number"
                                  },
                                  {
                                    "type": "string",
                                    "enum": [
                                      "unlimited"
                                    ]
                                  }
                                ],
                                "description": "Number of workspaces allowed"
                              },
                              "concurrentCalls": {
                                "type": "number",
                                "description": "Maximum concurrent calls"
                              },
                              "whiteLabel": {
                                "type": "boolean",
                                "description": "White-label branding enabled"
                              },
                              "rebilling": {
                                "type": "boolean",
                                "description": "Rebilling feature enabled"
                              },
                              "teamAccess": {
                                "type": "boolean",
                                "description": "Team access enabled"
                              }
                            },
                            "required": [
                              "workspaces",
                              "concurrentCalls",
                              "whiteLabel",
                              "rebilling",
                              "teamAccess"
                            ]
                          },
                          "featureList": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "description": "Human-readable feature list"
                          },
                          "displayOrder": {
                            "type": "number",
                            "description": "Display order"
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "description",
                          "stripeProductId",
                          "stripePriceIdMonthly",
                          "stripePriceIdAnnual",
                          "monthlyPrice",
                          "annualPrice",
                          "features",
                          "featureList",
                          "displayOrder"
                        ]
                      }
                    }
                  },
                  "required": [
                    "plans"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - JWT required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/connect/oauth/callback": {
      "get": {
        "summary": "Stripe Connect OAuth callback",
        "description": "Handles the OAuth callback from Stripe. Exchanges authorization code for access token and redirects to frontend.",
        "tags": [
          "Internal - Connect"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "Authorization code from Stripe (present on success)",
              "example": "ac_xxx"
            },
            "required": false,
            "name": "code",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "State parameter for CSRF protection",
              "example": "a1b2c3d4e5f6..."
            },
            "required": false,
            "name": "state",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Error code from Stripe (present on failure)",
              "example": "access_denied"
            },
            "required": false,
            "name": "error",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Error description from Stripe",
              "example": "The user denied your request"
            },
            "required": false,
            "name": "error_description",
            "in": "query"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to frontend with success or error"
          }
        }
      }
    },
    "/internal/accounts": {
