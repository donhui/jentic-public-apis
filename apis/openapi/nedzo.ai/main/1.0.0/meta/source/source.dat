          },
          "calendarType": {
            "type": "string",
            "description": "Calendar provider type (e.g., google, outlook)",
            "example": "google"
          },
          "calendarId": {
            "type": "string",
            "description": "Calendar ID from the provider",
            "example": "primary"
          },
          "timezone": {
            "type": "string",
            "nullable": true,
            "description": "Timezone for calendar operations",
            "example": "America/New_York"
          }
        },
        "required": [
          "id",
          "name",
          "calendarType",
          "calendarId",
          "timezone"
        ]
      },
      "CustomActionConfig": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Custom action ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Action name",
            "example": "lookup_order"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Action description/condition",
            "example": "Look up order status when user asks about their order"
          },
          "method": {
            "type": "string",
            "description": "HTTP method",
            "example": "GET"
          },
          "url": {
            "type": "string",
            "description": "Webhook URL",
            "example": "https://api.example.com/orders"
          },
          "parameters": {
            "nullable": true,
            "description": "Action parameters schema",
            "example": {
              "orderId": {
                "type": "string",
                "description": "Order ID"
              }
            }
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the action is active",
            "example": true
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "method",
          "url",
          "isActive"
        ]
      },
