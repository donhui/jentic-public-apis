    "/internal/workspaces/{workspaceId}/slack/channels": {
      "get": {
        "summary": "List Slack channels",
        "description": "List available Slack channels for a workspace. Requires an active Slack OAuth connection.",
        "tags": [
          "Slack"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "List of Slack channels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "channels": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Slack channel ID (e.g., C0123456789)"
                          },
                          "name": {
                            "type": "string",
                            "description": "Channel name"
                          }
                        },
                        "required": [
                          "id",
                          "name"
                        ]
                      }
                    }
                  },
                  "required": [
                    "channels"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Slack connection invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace or Slack connection not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workspaces/{workspaceId}/slack/channels/{channelId}/join": {
      "post": {
        "summary": "Join a Slack channel",
        "description": "Add the bot to a public Slack channel. Private channels require a manual /invite in Slack.",
        "tags": [
          "Slack"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "pattern": "^[A-Z0-9]{9,12}$",
              "description": "Slack channel ID (e.g., C0123456789)"
            },
            "required": true,
            "name": "channelId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully joined channel",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "Whether the bot successfully joined the channel"
                    }
                  },
                  "required": [
                    "success"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Cannot join channel (private, archived, or missing scope)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace, Slack connection, or channel not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workspaces/{workspaceId}/calendars": {
      "get": {
        "summary": "List calendars from provider",
        "description": "Fetch calendars or event types from a connected calendar provider (Cal.com, Calendly, or LeadConnector).",
        "tags": [
          "Calendars"
        ],
        "security": [
          {
            "jwtAuth": []
          },
          {
            "serviceKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "calcom",
                "cal_com",
                "calendly",
                "leadconnector",
                "google"
              ],
              "description": "Calendar provider (OAuth provider name or DB name)",
              "example": "calendly"
            },
            "required": true,
            "name": "provider",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List of calendars/event types from the provider",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CalendarItem"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid provider or request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "No OAuth connection found for provider",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "502": {
