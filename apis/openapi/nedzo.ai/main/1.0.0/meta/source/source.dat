{
  "openapi": "3.0.3",
  "info": {
    "title": "Nedzo API",
    "version": "1.0.0",
    "description": "RESTful API for Nedzo AI communications platform. Provides programmatic access to workspaces, agents, contacts, and contact lists.",
    "x-jentic-source-url": "https://docs.nedzo.ai"
  },
  "servers": [
    {
      "url": "https://api.nedzo.ai",
      "description": "Production"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key",
        "description": "API key authentication using Bearer token format. Obtain your API key from the Nedzo dashboard."
      },
      "serviceKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Service-Key",
        "description": "Internal service key authentication. Used for service-to-service communication. Requires IP allowlist."
      },
      "jwtAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Supabase JWT authentication for dashboard users. Obtain token via Supabase Auth."
      }
    },
    "schemas": {
      "GhlAgentOption": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "Display name shown in GHL dropdown",
            "example": "Sales Agent"
          },
          "value": {
            "type": "string",
            "format": "uuid",
            "description": "Agent UUID used when action executes",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "label",
          "value"
        ]
      },
      "GhlAgentsResponse": {
        "type": "object",
        "properties": {
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GhlAgentOption"
            },
            "description": "Array of agent options for GHL dropdown"
          }
        },
        "required": [
          "options"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "format": "uri",
            "description": "URI reference identifying the problem type",
            "example": "https://api.nedzo.ai/errors/not-found"
          },
          "title": {
            "type": "string",
            "description": "Short, human-readable summary of the problem",
            "example": "Not Found"
          },
          "status": {
            "type": "integer",
            "minimum": 400,
            "maximum": 599,
            "description": "HTTP status code",
            "example": 404
          },
          "detail": {
            "type": "string",
            "description": "Human-readable explanation specific to this occurrence",
            "example": "Workspace with ID 123e4567-e89b-12d3-a456-426614174000 not found"
          },
          "instance": {
            "type": "string",
            "description": "URI reference identifying the specific occurrence",
            "example": "/v1/workspaces/123e4567-e89b-12d3-a456-426614174000"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "description": "Field name that failed validation",
                  "example": "name"
                },
                "message": {
                  "type": "string",
                  "description": "Validation error message",
                  "example": "Name is required"
                }
              },
              "required": [
                "field",
                "message"
              ]
            },
            "description": "Validation errors (present for 400 Validation Error)",
            "example": [
              {
                "field": "name",
                "message": "Name is required"
              }
            ]
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "detail"
        ]
      },
      "GhlCallResponse": {
        "type": "object",
        "properties": {
          "conversationId": {
            "type": "string",
            "format": "uuid",
            "description": "Nedzo conversation ID for tracking the call",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "conversationId"
        ]
      },
      "GhlCallRequest": {
        "type": "object",
        "properties": {
          "locationId": {
            "type": "string",
            "description": "GHL location ID that identifies the workspace connection",
            "example": "ghl-location-uuid"
          },
          "agentId": {
            "type": "string",
            "format": "uuid",
            "description": "Nedzo agent UUID selected in GHL workflow",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "phoneNumber": {
            "type": "string",
            "pattern": "^\\+[1-9]\\d{1,14}$",
            "description": "Phone number to call in E.164 format",
            "example": "+14155551234"
          },
          "firstName": {
            "type": "string",
            "maxLength": 255,
            "description": "Contact first name from GHL",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "maxLength": 255,
            "description": "Contact last name from GHL",
            "example": "Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email from GHL",
            "example": "john@example.com"
          },
          "businessName": {
            "type": "string",
            "maxLength": 255,
            "description": "Contact business name from GHL",
            "example": "Acme Inc"
          }
        },
        "required": [
          "locationId",
          "agentId",
          "phoneNumber"
        ]
      },
      "GhlContactUpsertResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Contact UUID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "created": {
            "type": "boolean",
            "description": "True if new contact was created, false if existing contact was updated",
            "example": true
          }
        },
        "required": [
          "id",
          "created"
        ]
      },
      "GhlContactUpsertRequest": {
        "type": "object",
        "properties": {
          "locationId": {
            "type": "string",
            "description": "GHL location ID that identifies the workspace connection",
            "example": "ghl-location-uuid"
          },
          "phoneNumber": {
            "type": "string",
            "pattern": "^\\+[1-9]\\d{1,14}$",
            "description": "Phone number in E.164 format - primary match key",
            "example": "+14155551234"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email - secondary match key (used if no phone)",
            "example": "john@example.com"
          },
          "firstName": {
            "type": "string",
            "maxLength": 255,
            "description": "Contact first name",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "maxLength": 255,
            "description": "Contact last name",
            "example": "Doe"
          },
          "businessName": {
            "type": "string",
            "maxLength": 255,
            "description": "Contact business name",
            "example": "Acme Inc"
          },
          "customFields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Custom fields as key-value pairs. Keys are field names, values are field values. New fields are auto-created as text type.",
            "example": {
              "Lead Source": "Website",
              "Company Size": "50"
            }
          }
        },
        "required": [
          "locationId"
        ]
      },
      "GhlContactDeleteRequest": {
        "type": "object",
        "properties": {
          "locationId": {
            "type": "string",
            "description": "GHL location ID that identifies the workspace connection",
            "example": "ghl-location-uuid"
          },
          "phoneNumber": {
            "type": "string",
            "pattern": "^\\+[1-9]\\d{1,14}$",
            "description": "Phone number in E.164 format - primary match key",
            "example": "+14155551234"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email - secondary match key (used if no phone)",
            "example": "john@example.com"
          }
        },
        "required": [
          "locationId"
        ]
      },
      "TemplateItemCounts": {
        "type": "object",
        "properties": {
          "agents": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of agents in the template",
            "example": 3
          },
          "workflows": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of workflows in the template",
            "example": 5
          },
          "customFields": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of custom fields in the template",
            "example": 12
          },
          "tags": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of tags in the template",
            "example": 8
          }
        },
        "required": [
          "agents",
          "workflows",
          "customFields",
          "tags"
        ]
      },
      "IntegrationRequirement": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Integration identifier",
            "example": "cal_com"
          },
          "displayName": {
            "type": "string",
            "description": "User-friendly integration name",
            "example": "Cal.com Calendar"
          }
        },
        "required": [
          "id",
          "displayName"
        ]
      },
      "TemplatePreview": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique template identifier",
            "example": "abc12345-6789-0def-ghij-klmnopqrstuv"
          },
          "name": {
            "type": "string",
            "description": "Template name",
            "example": "Sales Appointment Setter"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Template description",
            "example": "AI agent configured for booking sales appointments"
          },
          "templateType": {
            "type": "string",
            "enum": [
              "agent",
              "workflow",
              "workspace"
            ],
            "description": "The type of entity this template was created from",
            "example": "agent"
          },
          "authorName": {
            "type": "string",
            "description": "Name of the template creator (or \"Archived Account\")",
            "example": "John Doe"
          },
          "itemCounts": {
            "$ref": "#/components/schemas/TemplateItemCounts"
          },
          "integrations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IntegrationRequirement"
            },
            "description": "Required integrations with display names"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 creation timestamp",
            "example": "2026-01-26T10:30:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "templateType",
          "authorName",
          "itemCounts",
          "integrations",
          "createdAt"
        ]
      },
      "TemplateError": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Error type URI",
            "example": "https://api.nedzo.ai/errors/not-found"
          },
          "title": {
            "type": "string",
            "description": "HTTP status text",
            "example": "Not Found"
          },
          "status": {
            "type": "number",
            "description": "HTTP status code",
            "example": 404
          },
          "detail": {
            "type": "string",
            "description": "Detailed error message",
            "example": "Agent not found"
          },
          "instance": {
            "type": "string",
            "description": "Request path",
            "example": "/internal/templates"
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "detail",
          "instance"
        ]
      },
      "WidgetStyle": {
        "type": "object",
        "properties": {
          "position": {
            "type": "string",
            "description": "Widget position on the page",
            "example": "bottom-right"
          },
          "theme": {
            "type": "string",
            "description": "Widget color theme",
            "example": "light"
          },
          "ctaText": {
            "type": "string",
            "description": "Call-to-action button text",
            "example": "Talk to an agent"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "description": "Avatar image URL (null for default gradient)",
            "example": null
          },
          "widgetName": {
            "type": "string",
            "description": "Widget display name",
            "example": "Agent"
          },
          "widgetDescription": {
            "type": "string",
            "description": "Widget description text",
            "example": "Your AI assistant"
          },
          "showBranding": {
            "type": "boolean",
            "description": "Whether to show branding",
            "example": false
          },
          "brandingText": {
            "type": "string",
            "description": "Branding text when shown",
            "example": "Powered by Unibox"
          }
        },
        "required": [
          "position",
          "theme",
          "ctaText",
          "avatarUrl",
          "widgetName",
          "widgetDescription",
          "showBranding",
          "brandingText"
        ]
      },
      "WidgetConfigResponse": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "format": "uuid",
            "description": "Agent identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "widgetMode": {
            "type": "string",
            "description": "Widget mode (voice, chat, both)",
            "example": "voice"
          },
          "chatUrl": {
            "type": "string",
            "nullable": true,
            "description": "Chat service URL (null when chat not configured)",
            "example": null
          },
          "widget": {
            "$ref": "#/components/schemas/WidgetStyle"
          },
          "assistant": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "description": "Full Vapi-compatible assistant configuration object produced by buildVapiAssistantConfig()",
            "example": {
              "transcriber": {
                "provider": "deepgram",
                "model": "nova-3",
                "language": "multi"
              },
              "model": {
                "provider": "openai",
                "model": "gpt-4o",
                "messages": [
                  {
                    "role": "system",
                    "content": "..."
                  }
                ]
              },
              "voice": {
                "provider": "openai",
                "voiceId": "alloy"
              },
              "firstMessage": "Hello, how can I help you today?"
            }
          }
        },
        "required": [
          "agentId",
          "widgetMode",
          "chatUrl",
          "widget",
          "assistant"
        ]
      },
      "WidgetImpressionRequest": {
        "type": "object",
        "properties": {
          "pageUrl": {
            "type": "string",
            "maxLength": 2048,
            "format": "uri",
            "description": "Page URL where the widget loaded",
            "example": "https://example.com/contact"
          },
          "sessionId": {
            "type": "string",
            "maxLength": 128,
            "description": "Client-generated session ID",
            "example": "sess_abc123"
          }
        }
      },
      "BrandingResponse": {
        "type": "object",
        "properties": {
          "brandName": {
            "type": "string",
            "description": "Brand display name",
            "example": "Nedzo"
          },
          "logoUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "Logo image URL (null for default)",
            "example": "https://v2.nedzo.ai/favicon.png"
          },
          "brandColor": {
            "type": "string",
            "description": "Brand primary color (hex)",
            "example": "#3b82f6"
          },
          "faviconUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "Favicon URL (null for default)",
            "example": "https://v2.nedzo.ai/favicon.png"
          }
        },
        "required": [
          "brandName",
          "logoUrl",
          "brandColor",
          "faviconUrl"
        ]
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique workspace identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "accountId": {
            "type": "string",
            "format": "uuid",
            "description": "Account ID that owns this workspace",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Workspace name",
            "example": "My Workspace"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000,
            "description": "Optional workspace description",
            "example": "Main workspace for customer campaigns"
          },
          "timezone": {
            "type": "string",
            "description": "Workspace timezone (IANA format)",
            "example": "America/New_York"
          },
          "icon": {
            "type": "string",
            "nullable": true,
            "description": "Workspace icon URL or identifier",
            "example": "https://example.com/icon.png"
          },
          "contactName": {
            "type": "string",
            "nullable": true,
            "description": "Contact name for workspace",
            "example": "John Doe"
          },
          "contactEmail": {
            "type": "string",
            "nullable": true,
            "format": "email",
            "description": "Contact email for workspace",
            "example": "contact@example.com"
          },
          "contactPhone": {
            "type": "string",
            "nullable": true,
            "description": "Contact phone for workspace",
            "example": "+1234567890"
          },
          "streetAddress": {
            "type": "string",
            "nullable": true,
            "description": "Street address for workspace",
            "example": "123 Main St"
          },
          "state": {
            "type": "string",
            "nullable": true,
            "description": "State/province for workspace",
            "example": "NY"
          },
          "zip": {
            "type": "string",
            "nullable": true,
            "description": "ZIP/postal code for workspace",
            "example": "10001"
          },
          "country": {
            "type": "string",
            "nullable": true,
            "description": "Country for workspace",
            "example": "US"
          },
          "businessRegistrationNumber": {
            "type": "string",
            "nullable": true,
            "description": "Business registration number (EIN, VAT, etc.)",
            "example": "12-3456789"
          },
          "balance": {
            "type": "number",
            "description": "Workspace balance in cents",
            "example": 0
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Workspace creation timestamp",
            "example": "2025-12-11T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Workspace last update timestamp",
            "example": "2025-12-11T12:00:00Z"
          }
        },
        "required": [
          "id",
          "accountId",
          "name",
          "description",
          "timezone",
          "icon",
          "contactName",
          "contactEmail",
          "contactPhone",
          "streetAddress",
          "state",
          "zip",
          "country",
          "businessRegistrationNumber",
          "balance",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateWorkspace": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Workspace name (required)",
            "example": "My New Workspace"
          },
          "description": {
            "type": "string",
            "maxLength": 1000,
            "description": "Optional workspace description",
            "example": "Workspace for Q1 campaigns"
          },
          "timezone": {
            "type": "string",
            "description": "Workspace timezone (IANA format). Defaults to UTC.",
            "example": "America/Los_Angeles"
          },
          "icon": {
            "type": "string",
            "description": "Workspace icon URL or identifier",
            "example": "https://example.com/icon.png"
          },
          "contactName": {
            "type": "string",
            "description": "Contact name for workspace",
            "example": "John Doe"
          },
          "contactEmail": {
            "type": "string",
            "format": "email",
            "description": "Contact email for workspace",
            "example": "admin@example.com"
          },
          "contactPhone": {
            "type": "string",
            "description": "Contact phone for workspace",
            "example": "+1987654321"
          },
          "streetAddress": {
            "type": "string",
            "description": "Street address for workspace",
            "example": "123 Main St"
          },
          "state": {
            "type": "string",
            "description": "State/province for workspace",
            "example": "NY"
          },
          "zip": {
            "type": "string",
            "description": "ZIP/postal code for workspace",
            "example": "10001"
          },
          "country": {
            "type": "string",
            "description": "Country for workspace",
            "example": "US"
          },
          "businessRegistrationNumber": {
            "type": "string",
            "description": "Business registration number (EIN, VAT, etc.)",
            "example": "12-3456789"
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateWorkspace": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Workspace name",
            "example": "Updated Workspace Name"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "maxLength": 1000,
            "description": "Workspace description (can be set to null)",
            "example": "Updated description"
          },
          "timezone": {
            "type": "string",
            "description": "Workspace timezone (IANA format)",
            "example": "Europe/London"
          },
          "icon": {
            "type": "string",
            "nullable": true,
            "description": "Workspace icon URL or identifier (can be set to null)",
            "example": "https://example.com/icon.png"
          },
          "contactName": {
            "type": "string",
            "nullable": true,
            "description": "Contact name (can be set to null)",
            "example": "John Doe"
          },
          "contactEmail": {
            "anyOf": [
              {
                "type": "string",
                "format": "email"
              },
              {
                "nullable": true
              },
              {
                "nullable": true
              }
            ],
            "description": "Contact email (can be set to null)",
            "example": "newemail@example.com"
          },
          "contactPhone": {
            "type": "string",
            "nullable": true,
            "description": "Contact phone (can be set to null)",
            "example": "+44123456789"
          },
          "streetAddress": {
            "type": "string",
            "nullable": true,
            "description": "Street address (can be set to null)",
            "example": "123 Main St"
          },
          "state": {
            "type": "string",
            "nullable": true,
            "description": "State/province (can be set to null)",
            "example": "NY"
          },
          "zip": {
            "type": "string",
            "nullable": true,
            "description": "ZIP/postal code (can be set to null)",
            "example": "10001"
          },
          "country": {
            "type": "string",
            "nullable": true,
            "description": "Country (can be set to null)",
            "example": "US"
          },
          "businessRegistrationNumber": {
            "type": "string",
            "nullable": true,
            "description": "Business registration number (can be set to null)",
            "example": "12-3456789"
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique agent identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Agent name",
            "example": "Customer Support Agent"
          },
          "agentType": {
            "type": "string",
            "enum": [
              "Inbound Voice",
              "Outbound Voice",
              "Chat",
              "Widget"
            ],
            "description": "Type of agent (Inbound Voice, Outbound Voice, Chat, Widget)",
            "example": "Inbound Voice"
          },
          "prompt": {
            "type": "string",
            "nullable": true,
            "description": "System prompt for the agent",
            "example": "You are a helpful customer support agent."
          },
          "voiceId": {
            "type": "string",
            "nullable": true,
            "description": "Voice provider ID for text-to-speech",
            "example": "voice_abc123"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the agent is active and can receive calls",
            "example": true
          },
          "backgroundSound": {
            "type": "boolean",
            "description": "Enable background sound during calls",
            "example": true
          },
          "openingLine": {
            "type": "string",
            "nullable": true,
            "description": "First message the agent speaks when a call starts",
            "example": "Hello, how can I help you today?"
          },
          "language": {
            "type": "string",
            "enum": [
              "english",
              "spanish",
              "french",
              "german",
              "portuguese",
              "dutch",
              "chinese",
              "japanese"
            ],
            "description": "Agent language",
            "example": "english"
          },
          "voicemail": {
            "type": "boolean",
            "description": "Enable voicemail detection",
            "example": false
          },
          "voicemailMessage": {
            "type": "string",
            "nullable": true,
            "description": "Message to leave when voicemail is detected",
            "example": "Please call us back at your earliest convenience."
          },
          "hipaaCompliance": {
            "type": "boolean",
            "description": "HIPAA compliance mode (Enterprise only). When enabled, no logs, recordings, or transcriptions are stored.",
            "example": false
          },
          "callDuration": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60,
            "description": "Maximum call duration in minutes (1-60)",
            "example": 30
          },
          "speed": {
            "type": "number",
            "minimum": 0.5,
            "maximum": 1.5,
            "description": "Voice speed multiplier (0.5-1.5)",
            "example": 1
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Agent creation timestamp",
            "example": "2025-12-11T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Agent last update timestamp",
            "example": "2025-12-11T12:00:00Z"
          }
        },
        "required": [
          "id",
          "name",
          "agentType",
          "prompt",
          "voiceId",
          "isActive",
          "backgroundSound",
          "openingLine",
          "language",
          "voicemail",
          "voicemailMessage",
          "hipaaCompliance",
          "callDuration",
          "speed",
          "createdAt",
          "updatedAt"
        ]
      },
