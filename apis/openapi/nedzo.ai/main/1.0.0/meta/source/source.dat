    "/internal/workspaces/{workspaceId}/billing/wallet/top-up": {
      "post": {
        "summary": "Top up workspace wallet",
        "description": "Add funds to workspace wallet by charging the connected Stripe payment method.",
        "tags": [
          "Workspace Billing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number",
                    "minimum": 1000,
                    "description": "Amount to add in cents (minimum $10)",
                    "example": 5000
                  }
                },
                "required": [
                  "amount"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Top-up successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "Whether top-up succeeded",
                      "example": true
                    },
                    "newBalance": {
                      "type": "number",
                      "description": "New wallet balance in cents",
                      "example": 9500
                    },
                    "charged": {
                      "type": "object",
                      "properties": {
                        "workspaceAmount": {
                          "type": "number",
                          "description": "Amount charged to workspace",
                          "example": 5000
                        },
                        "accountAmount": {
                          "type": "number",
                          "description": "Amount charged to account (if cascade)",
                          "example": 0
                        }
                      },
                      "required": [
                        "workspaceAmount"
                      ],
                      "description": "Charge breakdown"
                    }
                  },
                  "required": [
                    "success",
                    "newBalance",
                    "charged"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error or payment failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "502": {
            "description": "Stripe API error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workspaces/{workspaceId}/billing/transactions": {
      "get": {
        "summary": "List workspace wallet transactions",
        "description": "Get paginated list of wallet transactions for the workspace.",
        "tags": [
          "Workspace Billing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          },
          {
            "schema": {
              "type": "number",
              "minimum": 1,
              "maximum": 100,
              "default": 20,
              "description": "Number of transactions to return",
              "example": 20
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true,
              "minimum": 0,
              "default": 0,
              "description": "Offset for pagination",
              "example": 0
            },
            "required": false,
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Transaction ID",
                            "example": "tx_123"
                          },
                          "type": {
                            "type": "string",
                            "description": "Transaction type",
                            "example": "credit"
                          },
                          "amount": {
                            "type": "number",
                            "description": "Amount in cents",
                            "example": 5000
                          },
                          "balanceAfter": {
                            "type": "number",
                            "description": "Balance after transaction",
                            "example": 9500
                          },
                          "description": {
                            "type": "string",
                            "nullable": true,
                            "description": "Transaction description",
                            "example": "Wallet top-up"
                          },
                          "stripePaymentId": {
                            "type": "string",
                            "nullable": true,
                            "description": "Stripe payment ID",
                            "example": "pi_xxx"
                          },
                          "createdAt": {
                            "type": "string",
                            "description": "Created timestamp",
                            "example": "2024-01-15T10:00:00Z"
                          }
                        },
                        "required": [
                          "id",
                          "type",
                          "amount",
                          "balanceAfter",
                          "description",
                          "stripePaymentId",
                          "createdAt"
                        ]
                      }
                    },
                    "total": {
                      "type": "number",
                      "description": "Total transaction count",
                      "example": 42
                    },
                    "hasMore": {
                      "type": "boolean",
                      "description": "Whether more transactions exist",
                      "example": true
                    }
                  },
                  "required": [
                    "data",
                    "total",
                    "hasMore"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
