    "/internal/workflows/{workflowId}/executions/{executionId}/retry": {
      "post": {
        "summary": "Retry failed execution",
        "description": "Retries a failed or cancelled workflow execution by creating a new execution with the same workflow snapshot and trigger data. Returns 409 Conflict if execution is running, pending, waiting, or completed.",
        "tags": [
          "Internal - Executions"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workflow ID (UUID)",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workflowId",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Execution ID (UUID)",
              "example": "456e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "executionId",
            "in": "path"
          }
        ],
        "responses": {
          "201": {
