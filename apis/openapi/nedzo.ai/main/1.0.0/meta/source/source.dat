        "required": [
          "id",
          "number",
          "status",
          "amountDue",
          "amountPaid",
          "currency",
          "customerEmail",
          "description",
          "periodStart",
          "periodEnd",
          "createdAt",
          "pdfUrl",
          "hostedInvoiceUrl"
        ]
      },
