            "nullable": true,
            "format": "date-time",
            "description": "When execution completed (ISO 8601)",
            "example": "2025-01-15T10:00:05Z"
          },
          "duration": {
            "type": "number",
            "nullable": true,
            "description": "Total execution duration in seconds",
            "example": 5
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StepDetail"
            },
            "description": "Array of execution steps in order",
            "example": []
          },
          "errorSummary": {
            "type": "string",
            "nullable": true,
            "description": "First error message for quick display",
            "example": null
          },
          "isTest": {
            "type": "boolean",
            "description": "Whether this is a test execution",
            "example": false
          }
        },
        "required": [
          "id",
          "workflowId",
          "workflowName",
          "workspaceId",
          "status",
          "triggerType",
          "triggerSource",
          "triggerData",
          "contact",
          "createdAt",
          "startedAt",
          "completedAt",
          "duration",
          "steps",
          "errorSummary",
          "isTest"
        ]
      },
      "CancelExecutionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique execution identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workflowId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the workflow this execution belongs to",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "status": {
            "type": "string",
            "enum": [
              "cancelled"
            ],
            "description": "Execution status after cancellation",
            "example": "cancelled"
          },
          "completedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when execution was cancelled (ISO 8601)",
            "example": "2025-01-15T10:05:00Z"
          },
          "message": {
            "type": "string",
            "description": "Confirmation message",
            "example": "Execution cancelled successfully"
          }
        },
        "required": [
          "id",
          "workflowId",
          "status",
          "completedAt",
          "message"
        ]
      },
      "RetryExecutionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "New execution ID",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "workflowId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the workflow",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending"
            ],
            "description": "Initial status of the new execution",
            "example": "pending"
          },
          "triggerType": {
            "type": "string",
            "description": "Type of trigger (copied from original)",
            "example": "contactCreated"
          },
          "triggerData": {
            "type": "object",
            "nullable": true,
            "additionalProperties": {
              "nullable": true
            },
            "description": "Trigger data (copied from original)",
            "example": {
              "contactId": "456e4567-e89b-12d3-a456-426614174000"
            }
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when new execution started (ISO 8601)",
            "example": "2025-01-15T10:10:00Z"
          },
          "retriedFromId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the original execution that was retried",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "message": {
            "type": "string",
            "description": "Confirmation message",
            "example": "Execution retry initiated successfully"
          }
        },
        "required": [
          "id",
          "workflowId",
          "status",
          "triggerType",
          "triggerData",
          "startedAt",
          "retriedFromId",
          "message"
        ]
      },
      "NeedsReviewWorkflow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Workflow ID",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Workflow name",
            "example": "New Contact Outreach"
          },
          "consecutiveFailures": {
            "type": "integer",
            "description": "Number of consecutive failed executions",
            "example": 7
          },
          "needsReview": {
            "type": "boolean",
            "description": "Whether workflow needs review (true when >= 5 consecutive failures)",
            "example": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "When workflow was last updated (ISO 8601)",
            "example": "2026-02-08T10:00:05Z"
          }
        },
        "required": [
          "id",
          "name",
          "consecutiveFailures",
          "needsReview",
          "updatedAt"
        ]
      },
      "NeedsReviewResponse": {
        "type": "object",
        "properties": {
          "workflows": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NeedsReviewWorkflow"
            },
            "description": "Array of workflows needing review",
            "example": []
          },
          "total": {
            "type": "integer",
            "description": "Total number of workflows needing review",
            "example": 0
          },
          "page": {
            "type": "integer",
            "description": "Current page number (0-indexed)",
            "example": 0
          },
          "limit": {
            "type": "integer",
            "description": "Number of items per page",
            "example": 20
          }
        },
        "required": [
          "workflows",
          "total",
          "page",
          "limit"
        ]
      },
      "NeedsReviewCountResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Number of workflows needing review",
            "example": 2
          }
        },
        "required": [
          "count"
        ]
      },
      "RetryFromFailedStepResponse": {
        "type": "object",
        "properties": {
          "executionId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the execution being retried (same execution, not a new one)",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "status": {
            "type": "string",
            "enum": [
              "running"
            ],
            "description": "Updated status of the execution after retry",
            "example": "running"
          },
          "message": {
            "type": "string",
            "description": "Confirmation message",
            "example": "Execution retry started from step 2"
          },
          "fromStepIndex": {
            "type": "integer",
            "minimum": 0,
            "description": "Step index where execution will resume",
            "example": 2
          }
        },
        "required": [
          "executionId",
          "status",
          "message",
          "fromStepIndex"
        ]
      },
      "RetryFromFailedStepBody": {
        "type": "object",
        "properties": {
          "fromStepIndex": {
            "type": "integer",
            "minimum": 0,
            "description": "Step index to resume from (0-based). If omitted, resumes from failed step.",
            "example": 2
          },
          "fromNodeId": {
            "type": "string",
            "description": "Node ID to resume from. If omitted, resumes from failed step.",
            "example": "node_abc123"
          }
        }
      },
      "BulkAcknowledgeResponse": {
        "type": "object",
        "properties": {
          "acknowledgedCount": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of executions successfully acknowledged",
            "example": 2
          },
          "skippedCount": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of executions skipped (non-failed or already acknowledged)",
            "example": 0
          }
        },
        "required": [
          "acknowledgedCount",
          "skippedCount"
        ]
      },
      "BulkAcknowledgeBody": {
        "type": "object",
        "properties": {
          "executionIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "minItems": 1,
            "maxItems": 100,
            "description": "Array of execution IDs to acknowledge (1-100)",
            "example": [
              "456e4567-e89b-12d3-a456-426614174000",
              "789e4567-e89b-12d3-a456-426614174000"
            ]
          }
        },
        "required": [
          "executionIds"
        ]
      },
      "AcknowledgeExecutionResponse": {
        "type": "object",
        "properties": {
          "executionId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the acknowledged execution",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "acknowledgedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when execution was acknowledged (ISO 8601)",
            "example": "2026-02-03T10:30:00Z"
          }
        },
        "required": [
          "executionId",
          "acknowledgedAt"
        ]
      },
      "UnacknowledgeExecutionResponse": {
        "type": "object",
        "properties": {
          "executionId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the un-acknowledged execution",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "unacknowledgedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when execution was un-acknowledged (ISO 8601)",
            "example": "2026-02-03T10:35:00Z"
          }
        },
        "required": [
          "executionId",
          "unacknowledgedAt"
        ]
      },
      "CancelInProgressExecutionResponse": {
        "type": "object",
        "properties": {
          "executionId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the cancelled execution",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "cancelledAt": {
            "type": "string",
            "format": "date-time",
