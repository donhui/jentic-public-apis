    "/internal/telephony/phone-numbers/{phoneNumberId}/billing-history": {
      "get": {
        "summary": "Get billing history for a phone number",
        "description": "Retrieve paginated billing events for a specific phone number.",
        "tags": [
          "Telephony - Phone Numbers"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Phone number UUID"
            },
            "required": true,
            "name": "phoneNumberId",
            "in": "path"
          },
          {
            "schema": {
              "type": "number",
              "minimum": 1,
              "maximum": 100,
              "default": 50,
              "description": "Maximum number of events to return"
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true,
              "minimum": 0,
              "default": 0,
              "description": "Number of events to skip"
            },
            "required": false,
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Billing history for phone number",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "events": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "phoneNumberId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "workspaceId": {
                            "type": "string",
                            "format": "uuid"
                          },
                          "eventType": {
                            "type": "string",
                            "enum": [
                              "charge_attempted",
                              "charge_succeeded",
                              "charge_failed",
                              "grace_period_started",
                              "suspended",
                              "reactivated"
                            ]
                          },
                          "amountCents": {
                            "type": "number",
                            "nullable": true
                          },
                          "paymentMethod": {
                            "type": "string",
                            "nullable": true,
                            "enum": [
                              "wallet",
                              "card"
                            ]
                          },
                          "billingEntityType": {
                            "type": "string",
                            "nullable": true,
                            "enum": [
                              "account",
                              "workspace"
                            ]
                          },
                          "billingEntityId": {
                            "type": "string",
                            "nullable": true,
                            "format": "uuid"
                          },
                          "stripePaymentId": {
                            "type": "string",
                            "nullable": true
                          },
                          "errorMessage": {
                            "type": "string",
                            "nullable": true
                          },
                          "createdAt": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "phoneNumberId",
                          "workspaceId",
                          "eventType",
                          "amountCents",
                          "paymentMethod",
                          "billingEntityType",
                          "billingEntityId",
                          "stripePaymentId",
                          "errorMessage",
                          "createdAt"
                        ]
                      }
                    },
                    "total": {
                      "type": "number"
                    },
                    "limit": {
                      "type": "number"
                    },
                    "offset": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "events",
                    "total",
                    "limit",
                    "offset"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Phone number not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
