      "post": {
        "summary": "Revert workflow to previous version",
        "description": "Restore a workflow to a previous version from its version history. The workflow version number is incremented (not reset) and the workflow is automatically unpublished, requiring explicit republishing after review.",
        "tags": [
          "Internal - Workflows"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workflow ID (UUID)",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RevertWorkflowRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow reverted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid target version",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "No permission to modify this workflow",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workflow or target version not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workflows/{id}/test": {
      "post": {
        "summary": "Test workflow execution",
        "description": "Trigger a test execution of a workflow with sample contact data. Test executions bypass is_active and is_published checks, allowing editors to verify workflow behavior before publishing. The execution is marked as a test and queued for processing.",
        "tags": [
          "Internal - Workflows"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
