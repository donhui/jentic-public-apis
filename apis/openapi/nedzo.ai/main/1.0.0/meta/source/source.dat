            "example": "Updated Support Chat"
          },
          "prompt": {
            "type": "string",
            "nullable": true,
            "description": "System prompt",
            "example": "Updated system prompt..."
          },
          "openingLine": {
            "type": "string",
            "nullable": true,
            "description": "First message",
            "example": "Hi there!"
          },
          "language": {
            "type": "string",
            "enum": [
              "english",
              "spanish",
              "french",
              "german",
              "portuguese",
              "dutch",
              "chinese",
              "japanese"
            ],
            "description": "Agent language",
            "example": "spanish"
          },
          "llmProvider": {
            "type": "string",
            "nullable": true,
            "enum": [
              "openai",
              "anthropic"
            ],
