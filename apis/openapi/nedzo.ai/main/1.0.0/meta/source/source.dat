    "/internal/workflows/executions/{executionId}/retry": {
      "post": {
        "summary": "Retry execution from failed step",
        "description": "Retries a failed execution from the specific step that failed, or from a specified step index/node ID. Preserves previous step outputs and resumes the SAME execution (does not create a new execution). Returns 400 Bad Request if execution is not in failed status.",
        "tags": [
          "Internal - Executions"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Execution ID (UUID)",
              "example": "456e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "executionId",
            "in": "path"
          }
        ],
        "requestBody": {
          "description": "Optional retry options (fromStepIndex or fromNodeId). If omitted, retries from failed step.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RetryFromFailedStepBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Execution retry started successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetryFromFailedStepResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - execution not in failed status, invalid step index, or retry point after failed step",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - insufficient permissions (requires editor or admin role)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Execution not found or belongs to different workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workflows/executions/acknowledge": {
      "post": {
        "summary": "Bulk acknowledge failed executions",
        "description": "Acknowledges multiple failed executions at once (up to 100). Only failed, unacknowledged executions in the workspace are acknowledged. Returns count of acknowledged and skipped executions.",
        "tags": [
          "Internal - Executions"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "requestBody": {
          "description": "Array of execution IDs to acknowledge (1-100)",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkAcknowledgeBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk acknowledge completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkAcknowledgeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - executionIds empty or over limit (100)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - insufficient permissions (requires editor or admin role)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workflows/executions/{executionId}/acknowledge": {
      "post": {
        "summary": "Acknowledge failed execution",
        "description": "Acknowledges a failed execution by setting acknowledged_at timestamp. The execution is removed from Needs Review list but remains visible in history with failed status. Returns 400 Bad Request if execution is not in failed status.",
        "tags": [
          "Internal - Executions"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Execution ID (UUID)",
              "example": "456e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "executionId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Execution acknowledged successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcknowledgeExecutionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - execution not in failed status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - insufficient permissions (requires editor or admin role)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Execution not found or belongs to different workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Un-acknowledge failed execution",
        "description": "Un-acknowledges a previously acknowledged execution by clearing acknowledged_at timestamp. The execution is restored to the Needs Review list. Returns 400 Bad Request if execution is not acknowledged.",
        "tags": [
          "Internal - Executions"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Execution ID (UUID)",
              "example": "456e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "executionId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Execution un-acknowledged successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnacknowledgeExecutionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - execution is not acknowledged",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - insufficient permissions (requires editor or admin role)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Execution not found or belongs to different workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workflows/executions/{executionId}/cancel": {
      "post": {
        "summary": "Cancel in-progress execution",
        "description": "Cancels a running or awaiting_callback execution by setting status to cancelled and removing pending jobs. The execution stops immediately and no further steps are executed. Returns 400 Bad Request if execution is already completed, failed, or cancelled.",
        "tags": [
          "Internal - Executions"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Execution ID (UUID)",
              "example": "456e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "executionId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Execution cancelled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelInProgressExecutionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - execution already completed, failed, or cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - insufficient permissions (requires editor or admin role)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Execution not found or belongs to different workspace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/templates": {
      "get": {
        "tags": [
          "Templates"
        ],
        "summary": "List account templates",
        "description": "List all templates available to the authenticated user's account. Supports filtering by template type and visibility. Results are paginated and sorted by creation date (newest first).",
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "agent",
                "workflow",
                "workspace"
              ],
              "description": "Filter by template type",
              "example": "agent"
            },
            "required": false,
            "name": "templateType",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "public",
                "private"
              ],
              "description": "Filter by visibility",
              "example": "private"
            },
            "required": false,
            "name": "visibility",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Maximum number of templates to return (1-100)",
              "example": "50"
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Number of templates to skip for pagination",
              "example": "0"
            },
            "required": false,
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List of templates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TemplateResponse"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Templates"
        ],
        "summary": "Create template from agent",
        "description": "Create a new template by capturing the configuration of an existing AI agent. The template can later be imported into other workspaces. Sensitive data (API keys, tokens, secrets) is automatically excluded. Requires Account Admin role.",
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "requestBody": {
          "description": "Template creation parameters",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTemplateFromAgent"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Template created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error - invalid input or template exceeds size limit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - user is not an account administrator",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "404": {
            "description": "Not found - workspace or agent does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateError"
                }
              }
            }
          }
        }
      }
    },
    "/internal/templates/{id}": {
      "get": {
        "tags": [
          "Templates"
