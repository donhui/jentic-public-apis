    "/internal/oauth-connections/{id}/test": {
      "post": {
        "summary": "Test OAuth connection",
        "description": "Test an OAuth connection by calling the provider API. Returns user info and available resources.",
        "tags": [
          "OAuth Connections"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Connection UUID"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Test results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "provider": {
                      "type": "string"
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "email": {
                          "type": "string"
                        },
                        "uri": {
                          "type": "string"
                        }
                      }
                    },
                    "eventTypes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "uri": {
                            "type": "string"
                          },
                          "active": {
                            "type": "boolean"
                          },
                          "schedulingUrl": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "name",
                          "uri",
                          "active"
                        ]
