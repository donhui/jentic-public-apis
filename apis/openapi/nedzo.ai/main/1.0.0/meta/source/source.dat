              "description": "Filter contacts by workspace ID (required for account-scoped API keys, optional for workspace-scoped keys)",
              "example": "789e4567-e89b-12d3-a456-426614174000"
            },
            "required": false,
            "name": "workspaceId",
            "in": "query"
