      "TrialStatusResponse": {
        "type": "object",
        "properties": {
          "isTrialing": {
            "type": "boolean",
            "description": "Whether the account is currently in trial status",
            "example": true
          },
          "trialEndsAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "ISO 8601 timestamp when trial ends (null if not trialing or never had trial)",
            "example": "2026-01-23T10:30:00.000Z"
          },
          "trialDaysRemaining": {
            "type": "integer",
            "nullable": true,
            "description": "Number of days remaining in trial (null if not trialing). Minimum 0 for expired trials.",
            "example": 5
          },
          "subscriptionStatus": {
            "type": "string",
            "enum": [
              "trialing",
              "active",
              "past_due",
              "cancelled",
              "expired"
            ],
            "description": "Current subscription status",
            "example": "trialing"
          },
          "subscriptionTier": {
            "type": "string",
            "enum": [
              "none",
              "business",
              "agency",
              "enterprise"
            ],
            "description": "Current subscription tier (none = trial/no subscription)",
            "example": "none"
          }
        },
        "required": [
          "isTrialing",
          "trialEndsAt",
          "trialDaysRemaining",
          "subscriptionStatus",
          "subscriptionTier"
        ]
      },
      "DnsRecord": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "TXT",
              "CNAME",
              "MX"
            ],
            "description": "DNS record type",
            "example": "TXT"
          },
          "name": {
            "type": "string",
            "description": "Record name/host",
            "example": "notifications.customer.com"
          },
          "value": {
            "type": "string",
            "description": "Record value to set",
            "example": "v=spf1 include:mailgun.org ~all"
          },
          "valid": {
            "type": "boolean",
            "description": "Whether this record has been verified",
            "example": false
          },
          "purpose": {
            "type": "string",
            "enum": [
              "spf",
              "dkim",
              "mx",
              "dmarc"
            ],
            "description": "Purpose classification for display grouping",
            "example": "spf"
          },
          "recommended": {
            "type": "boolean",
            "description": "Whether this is a recommended (not required) record",
            "example": false
          }
        },
        "required": [
          "type",
          "name",
          "value",
          "valid",
          "purpose"
        ]
      },
      "GetEmailDomainResponse": {
        "type": "object",
        "properties": {
          "emailDomain": {
            "type": "string",
            "nullable": true,
            "description": "Configured email domain (null if not set)",
            "example": "notifications.customer.com"
          },
          "emailFromName": {
            "type": "string",
            "nullable": true,
            "description": "Sender display name",
            "example": "Customer Support"
          },
          "emailFromAddress": {
            "type": "string",
            "nullable": true,
            "description": "Local part of from email address",
            "example": "auth"
          },
          "emailActive": {
            "type": "boolean",
            "description": "Whether email sending is active",
            "example": true
          },
          "mailgunDomainVerified": {
            "type": "boolean",
            "description": "Whether Mailgun has verified DNS records",
            "example": true
          },
          "mailgunDomainVerifiedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "When domain was verified",
            "example": "2024-01-15T10:30:00Z"
          },
          "mailgunDomainLastCheckedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "When verification was last checked",
            "example": "2024-01-16T03:00:00Z"
          },
          "sendingDnsRecords": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "DNS records for sending (null if no domain configured)"
          },
          "receivingDnsRecords": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "DNS records for DKIM (null if no domain configured)"
          },
          "allDnsRecords": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "All DNS records combined and sorted by purpose (null if no domain configured)"
          }
        },
        "required": [
          "emailDomain",
          "emailFromName",
          "emailFromAddress",
          "emailActive",
          "mailgunDomainVerified",
          "mailgunDomainVerifiedAt",
          "mailgunDomainLastCheckedAt",
          "sendingDnsRecords",
          "receivingDnsRecords",
          "allDnsRecords"
        ]
      },
      "SetupEmailDomainResponse": {
        "type": "object",
        "properties": {
          "emailDomain": {
            "type": "string",
            "description": "The configured email domain",
            "example": "notifications.customer.com"
          },
          "state": {
            "type": "string",
            "enum": [
              "unverified",
              "active",
              "disabled"
            ],
            "description": "Current domain verification state",
            "example": "unverified"
          },
          "sendingDnsRecords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "DNS records required for sending emails"
          },
          "receivingDnsRecords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "DNS records for DKIM verification"
          },
          "allDnsRecords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "All DNS records combined and sorted by purpose"
          }
        },
        "required": [
          "emailDomain",
          "state",
          "sendingDnsRecords",
          "receivingDnsRecords",
          "allDnsRecords"
        ]
      },
      "SetupEmailDomainRequest": {
        "type": "object",
        "properties": {
          "emailDomain": {
            "type": "string",
            "minLength": 3,
            "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)+$",
            "description": "Email sending subdomain (e.g., notifications.customer.com)",
            "example": "notifications.customer.com"
          },
          "emailFromName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "description": "Sender display name (optional, defaults to account name)",
            "example": "Customer Support"
          },
          "emailFromAddress": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z0-9._-]+$",
            "default": "auth",
            "description": "Local part of from email address (optional, defaults to \"auth\")",
            "example": "noreply"
          }
        },
        "required": [
          "emailDomain"
        ]
      },
      "VerifyEmailDomainResponse": {
        "type": "object",
        "properties": {
          "verified": {
            "type": "boolean",
            "description": "Whether the domain is fully verified",
            "example": true
          },
          "state": {
            "type": "string",
            "enum": [
              "unverified",
              "active",
              "disabled"
            ],
            "description": "Current domain state",
            "example": "active"
          },
          "emailActive": {
            "type": "boolean",
            "description": "Whether email sending is now active",
            "example": true
          },
          "sendingDnsRecords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "Updated DNS record verification status"
          },
          "receivingDnsRecords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "Updated DKIM record verification status"
          },
          "allDnsRecords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DnsRecord"
            },
            "description": "All DNS records combined and sorted by purpose"
          },
          "lastCheckedAt": {
            "type": "string",
            "format": "date-time",
            "description": "When verification was checked",
            "example": "2024-01-15T10:30:00Z"
          }
        },
        "required": [
          "verified",
          "state",
          "emailActive",
          "sendingDnsRecords",
          "receivingDnsRecords",
          "allDnsRecords",
          "lastCheckedAt"
        ]
      },
      "DomainInfo": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "app",
              "api"
            ],
            "description": "Type of custom domain: app for frontend, api for backend",
            "example": "app"
          },
          "domain": {
            "type": "string",
            "nullable": true,
            "description": "The configured domain, or null if not configured",
            "example": "app.acmecorp.com"
          },
          "status": {
            "type": "string",
            "enum": [
              "none",
              "pending",
              "active",
              "failed"
            ],
            "description": "Current verification status of the domain",
            "example": "active"
          },
          "sslStatus": {
            "type": "string",
            "nullable": true,
            "enum": [
              "initializing",
              "pending_validation",
              "pending_issuance",
              "pending_deployment",
              "active",
              "expired",
              "deleted"
            ],
            "description": "SSL certificate status from Cloudflare",
            "example": "active"
          },
          "cnameTarget": {
            "type": "string",
            "description": "The CNAME target the customer should point their domain to",
            "example": "customers.nedzo.ai"
          },
          "createdAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "When the domain was configured (ISO 8601)",
            "example": "2026-01-23T12:00:00Z"
          },
          "verifiedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "When the domain became active (ISO 8601)",
            "example": "2026-01-23T12:05:00Z"
          },
          "error": {
            "type": "string",
            "nullable": true,
            "description": "Error message if domain verification failed",
            "example": null
          }
        },
        "required": [
          "type",
          "domain",
          "status",
          "sslStatus",
          "cnameTarget",
          "createdAt",
          "verifiedAt",
          "error"
        ]
      },
      "GetDomainsResponse": {
        "type": "object",
        "properties": {
          "app": {
            "$ref": "#/components/schemas/DomainInfo"
          },
          "api": {
            "$ref": "#/components/schemas/DomainInfo"
          }
        },
        "required": [
          "app",
          "api"
        ]
      },
      "SetupDomainResponse": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "The configured domain",
            "example": "app.acmecorp.com"
          },
          "type": {
            "type": "string",
            "enum": [
              "app",
              "api"
            ],
            "description": "Type of custom domain: app for frontend, api for backend",
            "example": "app"
          },
          "status": {
            "type": "string",
            "enum": [
              "none",
              "pending",
              "active",
              "failed"
            ],
            "description": "Current verification status of the domain",
            "example": "active"
          },
          "cnameTarget": {
            "type": "string",
            "description": "The CNAME target to configure in DNS",
            "example": "customers.nedzo.ai"
          },
          "message": {
            "type": "string",
            "description": "Instructions for the user",
            "example": "Add a CNAME record: app.acmecorp.com \u2192 customers.nedzo.ai"
          }
        },
        "required": [
          "domain",
          "type",
          "status",
          "cnameTarget",
          "message"
        ]
      },
      "SetupDomainRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "app",
              "api"
            ],
            "description": "Type of custom domain: app for frontend, api for backend",
            "example": "app"
          },
          "domain": {
            "type": "string",
            "minLength": 3,
            "maxLength": 253,
            "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)+$",
            "description": "The custom domain to configure (must be a valid subdomain)",
            "example": "app.acmecorp.com"
          }
        },
        "required": [
          "type",
          "domain"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique user identifier (references auth.users)",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "accountId": {
            "type": "string",
            "format": "uuid",
            "description": "Account the user belongs to",
            "example": "123e4567-e89b-12d3-a456-426614174001"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address",
            "example": "john.doe@example.com"
          },
          "firstName": {
            "type": "string",
            "nullable": true,
            "description": "User first name",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "nullable": true,
            "description": "User last name",
            "example": "Doe"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "User profile picture URL",
            "example": "https://example.com/avatars/john.png"
          },
          "phone": {
            "type": "string",
            "nullable": true,
            "description": "User phone number",
            "example": "+15551234567"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "admin",
              "user"
            ],
            "description": "Global role determining permissions",
            "example": "user"
          },
          "kycSessionId": {
            "type": "string",
            "nullable": true,
            "description": "KYC verification session ID",
            "example": "kyc_sess_1234567890"
          },
          "kycVerified": {
            "type": "boolean",
            "description": "Whether KYC verification is complete",
            "example": false
          },
          "notificationsAppointmentBooked": {
            "type": "boolean",
            "description": "Notification preference for appointments",
            "example": true
          },
          "deletedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Soft delete timestamp (ISO 8601)",
            "example": null
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "User creation timestamp (ISO 8601)",
            "example": "2025-12-11T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "User last update timestamp (ISO 8601)",
            "example": "2025-12-11T12:00:00Z"
          }
        },
        "required": [
          "id",
          "accountId",
          "email",
          "firstName",
          "lastName",
          "avatarUrl",
          "phone",
          "role",
          "kycSessionId",
          "kycVerified",
          "notificationsAppointmentBooked",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ]
      },
