            ]
          },
          "availableStart": {
            "type": "string",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$",
            "description": "Start of daily availability window",
            "example": "09:00"
          },
          "availableEnd": {
            "type": "string",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$",
            "description": "End of daily availability window",
            "example": "17:00"
          },
          "slotDurationMinutes": {
            "type": "integer",
            "description": "Duration of each booking slot in minutes",
            "example": 30
          },
          "timezone": {
            "type": "string",
            "pattern": "^[A-Za-z_]+\\/[A-Za-z_]+(\\/[A-Za-z_]+)?$",
            "description": "IANA timezone",
            "example": "America/Los_Angeles"
          }
        }
      },
      "KnowledgeItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace ID",
