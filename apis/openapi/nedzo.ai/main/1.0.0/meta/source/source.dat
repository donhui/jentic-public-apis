      "EngineSettings": {
        "type": "object",
        "properties": {
          "llmProvider": {
            "type": "string",
            "description": "LLM provider",
            "example": "openai"
          },
          "llmModel": {
            "type": "string",
            "description": "LLM model",
            "example": "gpt-4o"
          },
          "llmMaxTokens": {
            "type": "number",
            "description": "Max tokens",
            "example": 200
          },
          "llmTemperature": {
            "type": "number",
            "description": "Temperature",
            "example": 0.3
          },
          "voiceModel": {
            "type": "string",
            "description": "ElevenLabs model",
            "example": "eleven_turbo_v2_5"
          },
          "voiceUseSpeakerBoost": {
            "type": "boolean",
            "description": "Enable speaker boost",
            "example": true
          },
          "voiceOptimizeStreamingLatency": {
            "type": "number",
            "description": "Latency optimization (0-4)",
            "example": 2
          },
          "voiceChunkEnabled": {
            "type": "boolean",
            "description": "Enable chunking",
            "example": true
          },
          "voiceChunkMinCharacters": {
            "type": "number",
            "description": "Min chars for chunking",
            "example": 30
          },
          "voiceFormatEnabled": {
            "type": "boolean",
            "description": "Enable format plan",
            "example": true
          },
          "voiceNumberToDigitsCutoff": {
            "type": "number",
            "description": "Number to digits cutoff",
            "example": 2025
          },
          "transcriberSmartFormat": {
            "type": "boolean",
            "description": "Enable smart format",
            "example": false
          },
          "transcriberMipOptOut": {
            "type": "boolean",
            "description": "MIP opt out",
            "example": true
          },
          "transcriberNumerals": {
            "type": "boolean",
            "description": "Enable numerals",
            "example": true
          },
          "silenceTimeoutSeconds": {
            "type": "number",
            "description": "Silence timeout",
            "example": 20
          },
          "responseDelaySeconds": {
            "type": "number",
            "description": "Response delay",
            "example": 0
          },
          "llmRequestDelaySeconds": {
            "type": "number",
            "description": "LLM request delay",
            "example": 0
          },
          "endCallFunctionEnabled": {
            "type": "boolean",
            "description": "Enable end call function",
            "example": true
          },
          "idleMessageMaxSpokenCount": {
            "type": "number",
            "description": "Max idle messages",
            "example": 3
          },
          "idleTimeoutSeconds": {
            "type": "number",
            "description": "Idle timeout",
            "example": 20
          },
          "stopSpeakingNumWords": {
            "type": "number",
            "description": "Words to trigger stop",
            "example": 2
          },
          "stopSpeakingBackoffSeconds": {
            "type": "number",
            "description": "Backoff after stop",
            "example": 1.5
          },
          "startSpeakingWaitSeconds": {
            "type": "number",
            "description": "Wait before speaking",
            "example": 0.3
          }
        },
        "required": [
          "llmProvider",
          "llmModel",
          "llmMaxTokens",
          "llmTemperature",
          "voiceModel",
          "voiceUseSpeakerBoost",
          "voiceOptimizeStreamingLatency",
          "voiceChunkEnabled",
          "voiceChunkMinCharacters",
          "voiceFormatEnabled",
          "voiceNumberToDigitsCutoff",
          "transcriberSmartFormat",
          "transcriberMipOptOut",
          "transcriberNumerals",
          "silenceTimeoutSeconds",
          "responseDelaySeconds",
          "llmRequestDelaySeconds",
          "endCallFunctionEnabled",
          "idleMessageMaxSpokenCount",
          "idleTimeoutSeconds",
          "stopSpeakingNumWords",
          "stopSpeakingBackoffSeconds",
          "startSpeakingWaitSeconds"
        ],
        "description": "Engine settings from engine_call_settings table"
      },
      "SimulatorConfigResponse": {
        "type": "object",
        "properties": {
          "systemPrompt": {
            "type": "string",
            "description": "Complete system prompt built by the centralized prompt builder (includes standard prompt, agent prompt, calendar/slack/email/custom action instructions)"
          },
          "voiceSettings": {
            "$ref": "#/components/schemas/VoiceSettings"
          },
          "engineSettings": {
            "$ref": "#/components/schemas/EngineSettings"
          },
          "idleMessages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Messages to say when user is silent",
            "example": [
              "Hello?",
              "Still there?",
              "Can you hear me okay?"
            ]
          },
          "silenceTimeoutMessage": {
            "type": "string",
            "description": "Message before ending call due to silence",
            "example": "I don't hear you, so I'm going to hang up now."
          },
          "transcriberModel": {
            "type": "string",
            "description": "Deepgram model for transcription",
            "example": "nova-3"
          },
          "bcp47Language": {
            "type": "string",
            "description": "BCP-47 language code",
            "example": "en"
          },
          "endCallDescription": {
            "type": "string",
            "description": "Language-specific description for the endCall function"
          },
          "voicemailMessage": {
            "type": "string",
            "nullable": true,
            "description": "Message to leave on voicemail",
            "example": "Hi, this is a message from our team. Please call us back."
          },
          "mcpServers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "calendar",
                    "email",
                    "slack",
                    "sms"
                  ],
                  "description": "MCP server type",
                  "example": "calendar"
                },
                "url": {
                  "type": "string",
                  "description": "MCP server URL",
                  "example": "https://mcp.nedzo.ai/calendar"
                },
                "headers": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "description": "Headers to include with MCP requests",
                  "example": {
                    "x-workspace-id": "123",
                    "x-agent-id": "456"
                  }
                }
              },
              "required": [
                "type",
                "url",
                "headers"
              ]
            },
            "description": "MCP server configurations for calendar, email, and slack tools"
          },
          "customActions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "condition": {
                  "type": "string",
                  "nullable": true
                },
                "method": {
                  "type": "string"
                },
                "url": {
                  "type": "string",
                  "nullable": true
                },
                "headers": {
                  "type": "object",
                  "nullable": true,
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "authType": {
                  "type": "string",
                  "nullable": true,
                  "enum": [
                    "bearer",
                    "api_key",
                    "basic"
                  ]
                },
                "authValue": {
                  "type": "string",
                  "nullable": true
                },
                "parameters": {
                  "type": "array",
                  "nullable": true,
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "name"
                    ]
                  }
                }
              },
              "required": [
                "name",
                "condition",
                "method",
                "url",
                "headers",
                "authType",
                "authValue",
                "parameters"
              ]
            },
            "description": "Custom webhook actions configured for the agent",
            "example": []
          },
          "analysisPlan": {
            "type": "object",
            "properties": {
              "summaryPlan": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "enabled"
                ]
              },
              "structuredDataPlan": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "enabled"
                ]
              },
              "successEvaluationPlan": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "enabled"
                ]
              }
            },
            "required": [
              "summaryPlan",
              "structuredDataPlan",
              "successEvaluationPlan"
            ],
            "description": "Analysis plan configuration - disables VAPI post-call analytics",
            "example": {
              "summaryPlan": {
                "enabled": false
              },
              "structuredDataPlan": {
                "enabled": false
              },
              "successEvaluationPlan": {
                "enabled": false
              }
            }
          }
        },
        "required": [
          "systemPrompt",
          "voiceSettings",
          "engineSettings",
          "idleMessages",
          "silenceTimeoutMessage",
          "transcriberModel",
          "bcp47Language",
          "endCallDescription",
          "voicemailMessage",
          "mcpServers",
          "customActions",
          "analysisPlan"
        ]
      },
      "SimulatorConfigRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "format": "uuid",
            "description": "Agent UUID to fetch full configuration for",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "voiceId": {
            "type": "string",
            "format": "uuid",
            "description": "Voice UUID to fetch settings for",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "language": {
            "type": "string",
            "description": "Agent language (e.g., english, spanish)",
            "example": "english"
          }
        },
        "required": [
          "agentId",
          "voiceId",
          "language"
        ]
      },
      "CallerIdOption": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Phone number ID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "number": {
            "type": "string",
            "description": "Phone number in E.164 format",
            "example": "+14155551234"
          },
          "friendlyName": {
            "type": "string",
            "nullable": true,
            "description": "Friendly name for the phone number",
            "example": "Main Office"
          }
        },
        "required": [
          "id",
          "number",
          "friendlyName"
        ]
      },
      "DialerTokenResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Short-lived JWT token for Telnyx WebRTC SDK authentication",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "expiresAt": {
            "type": "string",
            "description": "ISO 8601 timestamp when the token expires",
            "example": "2026-03-24T13:00:00.000Z"
          },
          "callerIdOptions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CallerIdOption"
            },
            "description": "Available phone numbers for caller ID selection"
          }
        },
        "required": [
          "token",
          "expiresAt",
          "callerIdOptions"
        ]
      },
      "DialerTokenRequest": {
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace UUID to generate a dialer token for",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "workspaceId"
        ]
      },
      "DialerInitiateResponse": {
        "type": "object",
        "properties": {
          "dialerCallId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID of the created dialer call record",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "approved": {
            "type": "boolean",
            "description": "Whether the call was approved (balance held)",
            "example": true
          }
        },
        "required": [
          "dialerCallId",
          "approved"
        ]
      },
      "DialerInitiateRequest": {
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace UUID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "fromNumber": {
            "type": "string",
            "pattern": "^\\+[1-9]\\d{1,14}$",
            "description": "Caller phone number in E.164 format",
            "example": "+14155551234"
          },
          "toNumber": {
            "type": "string",
            "pattern": "^\\+[1-9]\\d{1,14}$",
            "description": "Destination phone number in E.164 format",
            "example": "+14155559876"
          }
        },
        "required": [
          "workspaceId",
          "fromNumber",
          "toNumber"
        ]
      },
      "DialerLinkCallResponse": {
        "type": "object",
        "properties": {
          "linked": {
            "type": "boolean",
            "description": "Whether the call control ID was linked successfully",
            "example": true
          }
        },
        "required": [
          "linked"
        ]
      },
      "DialerLinkCallRequest": {
        "type": "object",
        "properties": {
          "telnyxCallControlId": {
            "type": "string",
            "description": "Telnyx call control ID from the WebRTC SDK",
            "example": "v3:abc123def456"
          }
        },
        "required": [
          "telnyxCallControlId"
        ]
      },
      "DialerCancelResponse": {
        "type": "object",
        "properties": {
          "cancelled": {
            "type": "boolean",
            "description": "Whether the call was cancelled and hold refunded",
            "example": true
          }
        },
        "required": [
          "cancelled"
        ]
      },
      "DialerBalanceCheckResponse": {
        "type": "object",
        "properties": {
          "sufficient": {
            "type": "boolean",
            "description": "Whether the workspace has sufficient balance for a dialer call",
            "example": true
          },
          "balance": {
            "type": "number",
            "description": "Current workspace balance in cents",
            "example": 5000
          },
          "minimumRequired": {
            "type": "number",
            "description": "Minimum balance required in cents for one minute",
            "example": 3
          }
        },
        "required": [
          "sufficient",
          "balance",
          "minimumRequired"
        ]
      },
      "InternalCallResponse": {
        "type": "object",
        "properties": {
          "conversationId": {
            "type": "string",
            "format": "uuid",
            "description": "Conversation identifier for tracking the call",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "conversationId"
        ]
      },
      "InternalCallRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID of the agent to use for the call",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "contactId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID of an existing contact to call (mutually exclusive with phoneNumber)",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "phoneNumber": {
            "type": "string",
            "pattern": "^\\+[1-9]\\d{1,14}$",
            "description": "Phone number to call in E.164 format (mutually exclusive with contactId)",
            "example": "+14155551234"
          },
          "firstName": {
            "type": "string",
            "maxLength": 255,
            "description": "First name for the contact (used when calling by phone number)",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "maxLength": 255,
            "description": "Last name for the contact (used when calling by phone number)",
            "example": "Doe"
          }
        },
        "required": [
          "agentId"
        ]
      },
      "WebTestCallRegisterResponse": {
        "type": "object",
        "properties": {
          "callContextId": {
            "type": "string",
            "format": "uuid",
            "description": "The call context ID to pass in Vapi assistant metadata",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "callContextId"
        ]
      },
      "WebTestCallRegisterRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "format": "uuid",
            "description": "The agent ID for this web test call",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        },
        "required": [
          "agentId"
        ]
      },
      "InternalChatAgent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique chat agent identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace ID that owns this agent",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Agent name",
            "example": "Customer Support Chat"
          },
          "prompt": {
            "type": "string",
            "nullable": true,
            "description": "System prompt for the agent",
            "example": "You are a helpful customer support assistant..."
          },
          "openingLine": {
            "type": "string",
            "nullable": true,
            "description": "First message the agent sends",
            "example": "Hello! How can I help you today?"
          },
          "language": {
            "type": "string",
            "enum": [
              "english",
              "spanish",
              "french",
              "german",
              "portuguese",
              "dutch",
              "chinese",
              "japanese"
            ],
            "description": "Agent language",
            "example": "english"
          },
          "llmProvider": {
            "type": "string",
            "nullable": true,
            "enum": [
              "openai",
              "anthropic"
            ],
            "description": "LLM provider (openai or anthropic)",
            "example": "openai"
          },
          "llmModel": {
            "type": "string",
            "nullable": true,
            "description": "LLM model identifier",
            "example": "gpt-4.1"
          },
          "temperature": {
            "type": "number",
            "description": "LLM temperature (0-2)",
            "example": 0.7
          },
          "maxTokens": {
            "type": "integer",
            "description": "Maximum tokens in response",
            "example": 1024
          },
          "knowledgeBaseId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "Knowledge base ID for RAG",
            "example": "kb_123e4567-e89b-12d3-a456-426614174000"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the agent is active",
            "example": true
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Agent description",
            "example": "Handles customer inquiries via chat"
          },
          "enabledChannels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "sms",
                "email",
                "whatsapp",
                "instagram",
                "facebook"
              ]
            },
            "description": "Enabled channel types for this agent",
            "example": [
              "sms"
            ]
          },
          "waitTimeSeconds": {
            "type": "integer",
            "minimum": 0,
            "maximum": 60,
            "description": "Delay in seconds before AI responds (0-60)",
            "example": 0
          },
          "pauseOnManualMessage": {
            "type": "boolean",
            "description": "Whether to auto-pause AI when a human agent sends a message",
            "example": false
          },
          "reactivateAfterValue": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Number of time units before auto-reactivation (null = stay paused)",
            "example": 60
          },
          "reactivateAfterUnit": {
            "type": "string",
            "nullable": true,
            "enum": [
              "minutes",
              "hours",
              "days"
            ],
            "description": "Time unit for reactivation: minutes, hours, or days",
            "example": "minutes"
          },
          "maxMessagesPerConversation": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Max AI messages per conversation (null = unlimited)",
            "example": null
          },
          "maxMessagesSendFinal": {
            "type": "boolean",
            "description": "Whether to send a final message when max messages limit is reached",
            "example": false
          },
          "maxMessagesFinalMessage": {
            "type": "string",
            "nullable": true,
            "description": "Custom final message text when max messages limit is reached",
            "example": null
          },
          "pauseOnEscalation": {
            "type": "boolean",
            "description": "Whether to set pause_pending when an escalation event fires",
            "example": false
          },
          "pauseOnAppointmentBooked": {
            "type": "boolean",
            "description": "Whether to set pause_pending when an appointment is booked",
            "example": false
          },
          "pauseIdleTimeoutSeconds": {
            "type": "integer",
            "minimum": 60,
            "maximum": 3600,
            "description": "Seconds of idle time before pause_pending transitions to is_paused",
            "example": 300
          },
          "protectionKeywords": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "maxItems": 50,
            "description": "Case-insensitive keyword list that immediately pause the conversation",
            "example": []
          },
          "deletedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Soft delete timestamp (ISO 8601)",
            "example": null
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Agent creation timestamp (ISO 8601)",
            "example": "2026-01-13T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Agent last update timestamp (ISO 8601)",
            "example": "2026-01-13T12:00:00Z"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "name",
          "prompt",
          "openingLine",
          "language",
          "llmProvider",
          "llmModel",
          "temperature",
          "maxTokens",
          "knowledgeBaseId",
          "isActive",
          "description",
          "enabledChannels",
          "waitTimeSeconds",
          "pauseOnManualMessage",
          "reactivateAfterValue",
          "reactivateAfterUnit",
          "maxMessagesPerConversation",
          "maxMessagesSendFinal",
          "maxMessagesFinalMessage",
          "pauseOnEscalation",
          "pauseOnAppointmentBooked",
          "pauseIdleTimeoutSeconds",
          "protectionKeywords",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateInternalChatAgent": {
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace ID to create agent in",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Agent name (required)",
            "example": "Customer Support Chat"
          },
          "prompt": {
            "type": "string",
            "nullable": true,
            "description": "System prompt for the agent",
            "example": "You are a helpful customer support assistant..."
          },
          "openingLine": {
            "type": "string",
            "nullable": true,
            "description": "First message the agent sends",
            "example": "Hello! How can I help you today?"
          },
          "language": {
            "type": "string",
            "enum": [
              "english",
              "spanish",
              "french",
              "german",
              "portuguese",
              "dutch",
              "chinese",
              "japanese"
            ],
            "description": "Agent language (defaults to english)",
            "example": "english"
          },
          "llmProvider": {
            "type": "string",
            "nullable": true,
            "enum": [
              "openai",
              "anthropic"
            ],
            "description": "LLM provider",
            "example": "openai"
          },
          "llmModel": {
            "type": "string",
            "nullable": true,
            "description": "LLM model identifier",
            "example": "gpt-4.1"
          },
          "temperature": {
            "type": "number",
            "minimum": 0,
            "maximum": 2,
            "description": "LLM temperature (0-2, defaults to 0.7)",
            "example": 0.7
          },
          "maxTokens": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8192,
            "description": "Maximum tokens in response (defaults to 1024)",
            "example": 1024
          },
          "knowledgeBaseId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "Knowledge base ID for RAG",
            "example": "kb_123e4567-e89b-12d3-a456-426614174000"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the agent is active (defaults to true)",
            "example": true
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Agent description",
            "example": "Handles customer inquiries"
          },
          "enabledChannels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "sms",
                "email",
                "whatsapp",
                "instagram",
                "facebook"
              ]
            },
            "description": "Enabled channel types",
            "example": [
              "sms"
            ]
          },
          "waitTimeSeconds": {
            "type": "integer",
            "minimum": 0,
            "maximum": 60,
            "description": "Delay in seconds before AI responds (0-60)",
            "example": 0
          },
          "pauseOnManualMessage": {
            "type": "boolean",
            "description": "Whether to auto-pause AI on manual message",
            "example": false
          },
          "reactivateAfterValue": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Number of time units before auto-reactivation",
            "example": 60
          },
          "reactivateAfterUnit": {
            "type": "string",
            "nullable": true,
            "enum": [
              "minutes",
              "hours",
              "days"
            ],
            "description": "Time unit for reactivation",
            "example": "minutes"
          },
          "maxMessagesPerConversation": {
            "type": "integer",
            "nullable": true,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Max AI messages per conversation (null = unlimited)",
            "example": null
          },
          "maxMessagesSendFinal": {
            "type": "boolean",
            "description": "Whether to send a final message when limit reached",
            "example": false
          },
          "maxMessagesFinalMessage": {
            "type": "string",
            "nullable": true,
            "description": "Custom final message when limit reached",
            "example": null
          },
          "pauseOnEscalation": {
            "type": "boolean",
            "description": "Whether to pause on escalation event",
            "example": false
          },
          "pauseOnAppointmentBooked": {
            "type": "boolean",
            "description": "Whether to pause on appointment booked",
            "example": false
          },
          "pauseIdleTimeoutSeconds": {
            "type": "integer",
            "minimum": 60,
            "maximum": 3600,
            "description": "Idle timeout seconds for pause_pending transition",
            "example": 300
          },
          "protectionKeywords": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "maxItems": 50,
            "description": "Keywords that immediately pause the conversation",
            "example": []
          }
        },
        "required": [
          "workspaceId",
          "name"
        ]
      },
      "ToolsConfig": {
