    "/internal/workspaces/{workspaceId}/messaging/restrictions": {
      "get": {
        "summary": "List SMS restriction events",
        "description": "Returns a paginated list of SMS restriction events. Supports filtering by type, phone number, and date range.",
        "tags": [
          "Internal - Messaging"
        ],
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          },
          {
            "schema": {
              "type": "number",
              "minimum": 1,
              "maximum": 100,
              "default": 50,
              "description": "Maximum number of records to return (1-100)",
              "example": 50
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "number",
              "nullable": true,
              "minimum": 0,
              "default": 0,
              "description": "Number of records to skip for pagination",
              "example": 0
            },
            "required": false,
            "name": "offset",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "warning",
                "limit_reached",
                "filter_block"
              ],
              "description": "Filter by restriction type"
            },
            "required": false,
            "name": "type",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Filter by phone number (partial match)",
              "example": "+1555"
            },
            "required": false,
            "name": "phoneNumber",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time",
              "description": "Filter records created after this date (ISO 8601)",
              "example": "2025-12-01T00:00:00Z"
            },
            "required": false,
            "name": "startDate",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time",
              "description": "Filter records created before this date (ISO 8601)",
              "example": "2025-12-31T23:59:59Z"
            },
            "required": false,
            "name": "endDate",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of SMS restriction events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmsRestrictionsList"
                }
              }
            }
          },
          "400": {
            "description": "Invalid workspace ID or query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
