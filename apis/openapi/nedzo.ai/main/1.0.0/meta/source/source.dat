      "AddKnowledgeResponse": {
        "type": "object",
        "properties": {
          "upsertedCount": {
            "type": "integer",
            "description": "Number of vectors upserted",
            "example": 5
          }
        },
        "required": [
          "upsertedCount"
        ]
      },
      "KnowledgeItemInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique ID for this knowledge item (used as vector ID)",
            "example": "doc-123"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "description": "Text content to embed and store",
            "example": "Our return policy allows returns within 30 days of purchase."
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            },
            "description": "Optional metadata to store with the vector",
            "example": {
              "source": "website",
              "url": "https://example.com"
            }
          },
          "embeddingText": {
            "type": "string",
            "description": "Optional enriched text to use for embedding instead of content"
          }
        },
        "required": [
          "id",
          "content"
        ]
      },
      "AddKnowledgeRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "format": "uuid",
            "description": "Agent UUID - used as Pinecone namespace for isolation",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KnowledgeItemInput"
            },
            "minItems": 1,
            "maxItems": 100,
            "description": "Knowledge items to add (max 100 per request)"
          }
        },
        "required": [
          "agentId",
          "items"
        ]
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Vector ID",
            "example": "doc-123"
          },
          "content": {
            "type": "string",
            "description": "Original text content",
            "example": "Our return policy allows returns within 30 days of purchase."
          },
          "score": {
            "type": "number",
            "description": "Similarity score (0-1, higher is more similar)",
            "example": 0.92
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            },
            "description": "Stored metadata",
            "example": {
              "source": "website",
              "url": "https://example.com"
            }
          }
        },
        "required": [
          "id",
          "content",
          "score"
        ]
      },
      "SearchKnowledgeResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            },
            "description": "Search results ordered by similarity score"
          }
        },
        "required": [
          "results"
        ]
      },
      "SearchKnowledgeRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "format": "uuid",
            "description": "Agent UUID - used as Pinecone namespace for isolation",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "query": {
            "type": "string",
            "minLength": 1,
            "description": "Search query text (will be embedded)",
            "example": "How do I return a product?"
          },
          "topK": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 5,
            "description": "Number of results to return (default: 5, max: 20)",
            "example": 5
          },
          "filter": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "description": "Optional metadata filter for narrowing results",
            "example": {
              "source": "website"
            }
          }
        },
        "required": [
          "agentId",
          "query"
        ]
      },
