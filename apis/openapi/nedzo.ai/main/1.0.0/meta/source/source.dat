      "CalendarItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Calendar or event type ID from the provider",
            "example": "evt_123"
          },
          "name": {
            "type": "string",
            "description": "Display name of the calendar or event type",
            "example": "Sales Team Round Robin"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "GoogleCalendarSettings": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Settings record UUID",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "format": "uuid",
            "description": "Workspace UUID",
            "example": "123e4567-e89b-12d3-a456-426614174001"
          },
          "googleCalendarId": {
            "type": "string",
            "nullable": true,
            "description": "Selected Google Calendar ID (e.g., \"primary\" or calendar email)",
            "example": "primary"
          },
          "googleCalendarName": {
            "type": "string",
            "nullable": true,
            "description": "Display name of the selected calendar",
            "example": "My Calendar"
          },
          "availableDays": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 6
            },
            "description": "Days of week when available (0=Sunday, 1=Monday, ..., 6=Saturday)",
            "example": [
              1,
              2,
              3,
              4,
              5
            ]
          },
          "availableStart": {
            "type": "string",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$",
            "description": "Start of daily availability window (HH:MM)",
            "example": "09:00"
          },
          "availableEnd": {
            "type": "string",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$",
            "description": "End of daily availability window (HH:MM)",
            "example": "17:00"
          },
          "slotDurationMinutes": {
            "type": "integer",
            "description": "Duration of each booking slot in minutes",
            "example": 30
          },
          "timezone": {
            "type": "string",
            "pattern": "^[A-Za-z_]+\\/[A-Za-z_]+(\\/[A-Za-z_]+)?$",
            "description": "IANA timezone for availability calculations",
            "example": "America/Los_Angeles"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of creation",
            "example": "2026-01-13T10:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of last update",
            "example": "2026-01-13T10:00:00Z"
          }
        },
        "required": [
          "id",
          "workspaceId",
          "googleCalendarId",
          "googleCalendarName",
          "availableDays",
          "availableStart",
          "availableEnd",
          "slotDurationMinutes",
          "timezone",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateGoogleCalendarSettings": {
        "type": "object",
        "properties": {
          "googleCalendarId": {
            "type": "string",
            "nullable": true,
            "description": "Selected Google Calendar ID",
            "example": "primary"
          },
          "googleCalendarName": {
            "type": "string",
            "nullable": true,
            "description": "Display name of the selected calendar",
