    "/internal/invoices": {
      "get": {
        "summary": "List invoices",
        "description": "List all Stripe invoices for an account with pagination support. Returns invoices in reverse chronological order.",
        "tags": [
          "Internal - Invoices"
        ],
        "security": [
          {
            "serviceKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Account UUID to retrieve invoices for",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "accountId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "pattern": "^\\d+$",
              "description": "Number of invoices to return (1-100)",
              "example": "10"
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Cursor for pagination (invoice ID to start after)",
              "example": "in_1ABC2DEF3GHI4JKL"
            },
            "required": false,
            "name": "startingAfter",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoices retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "502": {
            "description": "Payment service error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
