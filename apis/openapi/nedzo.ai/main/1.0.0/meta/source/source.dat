    "/internal/workspaces/{workspaceId}/billing/status": {
      "get": {
        "summary": "Get workspace billing status",
        "description": "Check if workspace can show billing UI based on Stripe Connect and payment method status.",
        "tags": [
          "Workspace Billing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "workspaceId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Billing status for workspace",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stripeConnected": {
                      "type": "boolean",
                      "description": "Whether account has Stripe Connect enabled",
                      "example": true
                    },
                    "hasPaymentMethod": {
                      "type": "boolean",
                      "description": "Whether workspace has a payment method on connected account",
                      "example": true
                    },
                    "walletBalance": {
                      "type": "number",
                      "description": "Workspace wallet balance in cents",
                      "example": 4500
                    },
                    "isDegraded": {
                      "type": "boolean",
                      "description": "Whether wallet is empty (degraded state)",
                      "example": false
                    },
                    "userRole": {
                      "type": "string",
                      "enum": [
                        "owner",
                        "admin",
                        "user"
                      ],
                      "description": "User role in workspace",
                      "example": "admin"
                    }
                  },
                  "required": [
                    "stripeConnected",
                    "hasPaymentMethod",
                    "walletBalance",
                    "isDegraded",
                    "userRole"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Not a workspace member",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/internal/workspaces/{workspaceId}/billing/setup-intent": {
      "post": {
        "summary": "Create Setup Intent for workspace",
        "description": "Create a Stripe Setup Intent on the account's connected Stripe for adding a payment method.",
        "tags": [
          "Workspace Billing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
