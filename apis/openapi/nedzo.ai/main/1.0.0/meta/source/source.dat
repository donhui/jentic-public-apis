              "lastName": "Doe",
              "phone": "+1234567890"
            }
          },
          "triggerData": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "description": "Optional additional trigger context data",
            "example": {}
          }
        },
        "required": [
          "contact"
        ]
      },
      "WebhookUrlResponse": {
        "type": "object",
        "properties": {
          "webhookUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri",
            "description": "Full webhook URL for triggering this workflow. Null if workflow does not have a webhook trigger.",
            "example": "https://api.nedzo.ai/webhooks/trigger/a3f2b1c0d4e5f6789012345678901234567890abcdef1234567890abcdef1234"
          },
          "webhookToken": {
            "type": "string",
            "nullable": true,
            "minLength": 64,
            "maxLength": 64,
            "description": "The 64-character webhook token. Null if workflow does not have a webhook trigger.",
            "example": "a3f2b1c0d4e5f6789012345678901234567890abcdef1234567890abcdef1234"
          }
        },
        "required": [
          "webhookUrl",
          "webhookToken"
        ]
      },
      "RegenerateWebhookTokenResponse": {
        "type": "object",
        "properties": {
          "webhookUrl": {
            "type": "string",
            "format": "uri",
            "description": "New webhook URL with regenerated token",
            "example": "https://api.nedzo.ai/webhooks/trigger/b4g3c2d1e6f7890123456789012345678901234567890bcdef23456789012345"
          },
          "webhookToken": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64,
            "description": "The new 64-character webhook token",
            "example": "b4g3c2d1e6f7890123456789012345678901234567890bcdef23456789012345"
          },
          "message": {
            "type": "string",
            "description": "Success message",
            "example": "Webhook token regenerated successfully. The old token is now invalid."
          }
        },
        "required": [
          "webhookUrl",
          "webhookToken",
          "message"
        ]
      },
      "ExecutionStatus": {
        "type": "string",
        "enum": [
          "pending",
          "running",
          "waiting",
          "completed",
          "failed",
          "cancelled"
        ],
        "description": "Current execution status",
        "example": "completed"
      },
      "WorkspaceExecutionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique execution identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workflowId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the workflow this execution belongs to",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "workflowName": {
            "type": "string",
            "description": "Name of the workflow",
            "example": "New Contact Call"
          },
          "triggerType": {
            "type": "string",
            "description": "Type of trigger that started this execution",
            "example": "contactCreated"
          },
          "contactId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "ID of the contact involved (if applicable)",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "contactName": {
            "type": "string",
            "nullable": true,
            "description": "Full name of the contact",
            "example": "John Doe"
          },
          "contactPhone": {
            "type": "string",
            "nullable": true,
            "description": "Phone number of the contact",
            "example": "+1234567890"
          },
          "status": {
            "$ref": "#/components/schemas/ExecutionStatus"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when execution was created (ISO 8601)",
            "example": "2025-01-15T10:00:00Z"
          },
          "completedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Timestamp when execution completed (ISO 8601), null if still running",
            "example": "2025-01-15T10:00:05Z"
          },
          "acknowledgedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Timestamp when execution failure was acknowledged (ISO 8601), null if not acknowledged (Story 4.6)",
            "example": null
          },
          "errorMessage": {
            "type": "string",
            "nullable": true,
            "description": "First line of error message if execution failed, null otherwise",
            "example": null
          }
        },
        "required": [
          "id",
          "workflowId",
          "workflowName",
          "triggerType",
          "contactId",
          "contactName",
          "contactPhone",
          "status",
          "createdAt",
          "completedAt",
          "acknowledgedAt",
          "errorMessage"
        ]
      },
