      "Permission": {
        "type": "object",
        "properties": {
          "module": {
            "type": "string",
            "enum": [
              "dashboard",
              "agents",
              "contacts",
              "workflows",
              "conversations",
              "numbers",
              "integrations",
              "settings"
            ],
            "description": "Module name for permission",
            "example": "agents"
          },
          "canView": {
            "type": "boolean",
            "description": "Whether user can view this module",
            "example": true
          },
          "canManage": {
            "type": "boolean",
            "description": "Whether user can manage (create/edit/delete) in this module",
            "example": false
          }
        },
        "required": [
          "module",
          "canView",
          "canManage"
        ]
      },
      "InviteUser": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the user to invite",
            "example": "newuser@example.com"
          },
          "firstName": {
            "type": "string",
            "maxLength": 100,
            "description": "User first name (optional)",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "maxLength": 100,
            "description": "User last name (optional)",
            "example": "Doe"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "user"
            ],
            "description": "Role to assign (cannot invite as owner)",
            "example": "user"
          },
          "accountId": {
            "type": "string",
            "format": "uuid",
            "description": "Account ID to invite user to",
            "example": "123e4567-e89b-12d3-a456-426614174001"
          },
          "workspaceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "minItems": 1,
            "description": "Workspace IDs to add user to (at least one required)",
            "example": [
              "123e4567-e89b-12d3-a456-426614174002"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Permission"
            },
            "description": "Module permissions (only applicable for role=user)",
            "example": [
              {
                "module": "agents",
                "canView": true,
                "canManage": false
              }
            ]
          }
        },
        "required": [
          "email",
          "role",
          "accountId",
          "workspaceIds"
        ]
      },
