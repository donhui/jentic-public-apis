      "ExecutionDetailResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique execution identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "workflowId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the workflow this execution belongs to",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "workflowName": {
            "type": "string",
            "description": "Name of the workflow at time of query",
            "example": "New Contact Call"
          },
          "status": {
            "$ref": "#/components/schemas/ExecutionStatus"
          },
          "triggerType": {
            "type": "string",
            "description": "Type of trigger that started this execution",
            "example": "contactCreated"
          },
          "triggerData": {
            "type": "object",
            "nullable": true,
            "additionalProperties": {
              "nullable": true
            },
            "description": "Data associated with the trigger event",
            "example": {
              "contactId": "456e4567-e89b-12d3-a456-426614174000"
            }
          },
          "contact": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Contact"
              },
              {
                "nullable": true,
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Contact ID",
                    "example": "789e4567-e89b-12d3-a456-426614174000"
                  },
                  "firstName": {
                    "type": "string",
                    "nullable": true,
                    "description": "Contact first name",
                    "example": "John"
                  },
                  "lastName": {
                    "type": "string",
                    "nullable": true,
                    "description": "Contact last name",
                    "example": "Doe"
                  },
                  "phone": {
                    "type": "string",
                    "nullable": true,
                    "description": "Contact phone number",
                    "example": "+1234567890"
                  },
                  "email": {
                    "type": "string",
                    "nullable": true,
                    "description": "Contact email address",
                    "example": "john@example.com"
                  }
                },
                "required": [
                  "id",
                  "firstName",
                  "lastName",
                  "phone",
                  "email"
                ],
                "description": "Enriched contact information from contacts table (if available)"
              }
            ]
          },
          "currentNodeId": {
            "type": "string",
            "nullable": true,
            "description": "ID of the node currently being executed (null if completed)",
            "example": null
          },
          "nodeOutputs": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "description": "Outputs from each executed node, keyed by node ID",
            "example": {
              "node-1": {
                "success": true,
                "callId": "call-789"
              }
            }
          },
          "executionPath": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ordered list of node IDs that were executed",
            "example": [
              "node-1"
            ]
          },
          "errorMessage": {
            "type": "string",
            "nullable": true,
            "description": "Error message if execution failed, null otherwise",
            "example": null
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when execution started (ISO 8601)",
            "example": "2025-01-15T10:00:00Z"
          },
          "completedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Timestamp when execution completed (ISO 8601), null if still running",
            "example": "2025-01-15T10:00:05Z"
          },
          "isTest": {
            "type": "boolean",
            "description": "Whether this is a test execution",
            "example": false
          }
        },
        "required": [
          "id",
          "workflowId",
          "workflowName",
          "status",
          "triggerType",
          "triggerData",
          "contact",
          "currentNodeId",
          "nodeOutputs",
          "executionPath",
          "errorMessage",
          "startedAt",
          "completedAt",
          "isTest"
        ]
      },
