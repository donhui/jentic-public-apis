                  "type": "string"
                },
                "bubbleType": {
                  "type": "string"
                },
                "errorMessage": {
                  "type": "string"
                }
              },
              "required": [
                "bubbleId",
                "bubbleType",
                "errorMessage"
              ]
            },
            "description": "Per-entity failure details"
          },
          "startedAt": {
            "type": "string"
          },
          "completedAt": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "status",
          "dryRun",
          "currentStep",
          "stats",
          "errorMessage",
          "startedAt",
          "completedAt"
        ]
      },
