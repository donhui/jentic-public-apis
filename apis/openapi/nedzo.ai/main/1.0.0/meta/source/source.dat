        "type": "object",
        "properties": {
          "total": {
            "type": "number",
            "description": "Total contacts processed",
            "example": 100
          },
          "created": {
            "type": "number",
            "description": "Contacts created",
            "example": 85
          },
          "updated": {
            "type": "number",
            "description": "Contacts restored from deleted",
            "example": 5
          },
          "skipped": {
            "type": "number",
            "description": "Contacts skipped (duplicates)",
            "example": 8
          },
          "errors": {
            "type": "number",
            "description": "Contacts with errors",
            "example": 2
          }
