    "/internal/telephony/address-bundles/{id}/address": {
      "post": {
        "summary": "Create Telnyx address for bundle",
        "description": "Create a Telnyx address entity and store the address ID on the bundle. Returns existing address ID if already created (idempotent). Use forceNew=true to create a new address when fields have changed.",
        "tags": [
          "Telephony - Address Bundles"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTelnyxAddress"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Existing address returned (idempotent retry)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTelnyxAddressResponse"
                }
              }
            }
          },
          "201": {
            "description": "Address created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTelnyxAddressResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error or bundle not in draft status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Access denied to this address bundle",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Bundle not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
