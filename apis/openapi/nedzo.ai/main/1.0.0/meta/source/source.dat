      "ApiKey": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "accountId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "Account ID (if account-scoped)",
            "example": "456e4567-e89b-12d3-a456-426614174000"
          },
          "workspaceId": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "Workspace ID (if workspace-scoped)",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Key name",
            "example": "Production API Key"
          },
          "keyPrefix": {
            "type": "string",
            "description": "First 12 chars of key for identification",
            "example": "sk_live_abc1"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Permission scopes",
            "example": [
              "read",
              "write"
            ]
          },
          "lastUsedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Last usage timestamp",
            "example": null
          },
          "expiresAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Expiration timestamp",
            "example": "2026-01-01T00:00:00Z"
          },
          "createdBy": {
            "type": "string",
            "nullable": true,
            "format": "uuid",
            "description": "User who created the key",
            "example": "111e4567-e89b-12d3-a456-426614174000"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-12-11T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-12-11T12:00:00Z"
          }
        },
        "required": [
          "id",
          "accountId",
          "workspaceId",
          "name",
          "keyPrefix",
          "scopes",
          "lastUsedAt",
          "expiresAt",
          "createdBy",
          "createdAt",
          "updatedAt"
        ]
      },
