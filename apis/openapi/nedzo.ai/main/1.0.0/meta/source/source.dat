      "patch": {
        "tags": [
          "Templates"
        ],
        "summary": "Update template metadata",
        "description": "Update template name and/or description. Requires Account Admin role.",
        "security": [
          {
            "jwtAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Template UUID",
              "example": "abc12345-6789-0def-ghij-klmnopqrstuv"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "description": "Template update parameters",
          "required": true,
