    "/webhooks/trigger/{token}": {
      "post": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Trigger workflow via webhook",
        "description": "\n    Triggers a workflow execution for the specified webhook token.\n\n    The webhook URL is obtained from the workflow configuration.\n    The token is a 64-character hexadecimal string.\n\n    ## Contact Identification\n\n    The payload must contain a contact identifier:\n    - `contactId` (UUID of existing contact)\n    - `contact.phone` (phone number)\n    - `contact.email` (email address)\n\n    When `contactId` is provided, the system fetches the contact from the database\n    and merges webhook data with the stored contact (webhook data takes precedence).\n\n    ## Custom Fields & Variable Substitution\n\n    Additional fields in the payload are passed through to workflow actions and\n    can be used for:\n\n    1. **Dynamic personalization in emails**: Use `{{variable.path}}` syntax\n       - Example: `{{deal.product}}`, `{{contact.address.city}}`\n       - Missing variables render as empty string (no error)\n\n    2. **AI agent context in phone calls**: All payload data is available to AI\n       - Example: Deal value, product name, close date for conversation context\n\n    3. **Nested data access**: Supports deep nesting with dot notation\n       - Example: `{{contact.address.city}}`, `{{deal.items.0.name}}`\n\n    ## Example Payloads\n\n    **With Contact ID:**\n    ```json\n    {\n      \"contactId\": \"123e4567-e89b-12d3-a456-426614174000\",\n      \"deal\": {\n        \"value\": 5000,\n        \"product\": \"Premium Plan\",\n        \"closeDate\": \"2026-02-03\"\n      },\n      \"source\": \"Salesforce\"\n    }\n    ```\n\n    **With Contact Data Only:**\n    ```json\n    {\n      \"contact\": {\n        \"phone\": \"+15551234567\",\n        \"name\": \"John Doe\",\n        \"address\": {\n          \"city\": \"New York\",\n          \"state\": \"NY\"\n        }\n      },\n      \"deal\": {\n        \"product\": \"Enterprise Plan\",\n        \"value\": 20000\n      }\n    }\n    ```\n\n    **Email Template Example:**\n    Subject: `Thanks for choosing {{deal.product}}!`\n    Body: `Hi {{contact.name}}, your purchase of ${{deal.value}} is confirmed.`\n\n    Rate limit: 100 requests per minute per workspace.\n  ",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 64,
              "maxLength": 64,
              "pattern": "^[0-9a-f]+$",
              "description": "64-character hexadecimal webhook token",
              "example": "a1b2c3d4e5f6789012345678901234567890123456789012345678901234abcd"
            },
            "required": true,
            "name": "token",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookPayload"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Webhook accepted, execution queued",
            "headers": {
              "X-RateLimit-Limit": {
                "schema": {
                  "type": "string",
                  "description": "Maximum requests per minute",
                  "example": "100"
                },
                "required": true
              },
              "X-RateLimit-Remaining": {
                "schema": {
                  "type": "string",
                  "description": "Remaining requests in current window",
                  "example": "95"
                },
                "required": true
              },
              "X-RateLimit-Reset": {
                "schema": {
                  "type": "string",
                  "description": "Unix timestamp when rate limit resets",
                  "example": "1706889600"
                },
                "required": true
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookSuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload or malformed JSON",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "type": "https://api.nedzo.ai/errors/validation-error",
                  "title": "Validation Error",
                  "status": 400,
                  "detail": "Must provide contactId, contact.phone, or contact.email",
                  "instance": "/webhooks/trigger/a1b2c3d4e5f6789012345678901234567890123456789012345678901234abcd"
                }
              }
            }
          },
          "404": {
            "description": "Webhook URL not found or workflow is inactive",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "type": "https://api.nedzo.ai/errors/not-found",
                  "title": "Not Found",
                  "status": 404,
                  "detail": "Webhook URL not found or workflow is inactive",
                  "instance": "/webhooks/trigger/invalid-token-here"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "headers": {
              "X-RateLimit-Limit": {
                "schema": {
                  "type": "string",
                  "description": "Maximum requests per minute",
                  "example": "100"
                },
                "required": true
              },
              "X-RateLimit-Remaining": {
                "schema": {
                  "type": "string",
                  "description": "Remaining requests in current window (0 when rate limited)",
                  "example": "0"
                },
                "required": true
              },
              "X-RateLimit-Reset": {
                "schema": {
                  "type": "string",
                  "description": "Unix timestamp when rate limit resets",
                  "example": "1706889600"
                },
                "required": true
              },
              "Retry-After": {
                "schema": {
                  "type": "string",
                  "description": "Seconds to wait before retrying",
                  "example": "45"
                },
                "required": true
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "type": "https://api.nedzo.ai/errors/rate-limit-exceeded",
                  "title": "Rate Limit Exceeded",
                  "status": 429,
                  "detail": "Rate limit exceeded. Maximum 100 requests per minute per workspace.",
                  "instance": "/webhooks/trigger/a1b2c3d4e5f6789012345678901234567890123456789012345678901234abcd"
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/billing": {
      "post": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Stripe billing webhook",
        "description": "Receives and processes Stripe webhook events for subscription management",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StripeWebhookEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "received": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "received"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid webhook signature or payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Webhook processing failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}