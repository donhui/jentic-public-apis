            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Workspace UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/UpdateWorkspace"
                  },
                  {
                    "properties": {
                      "name": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 255,
                        "description": "Workspace name (whitespace trimmed)",
                        "example": "Updated Workspace Name"
                      },
                      "description": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 1000,
                        "description": "Workspace description",
                        "example": "Updated description"
                      },
                      "icon": {
                        "type": "string",
                        "nullable": true,
                        "format": "uri",
                        "description": "Workspace logo URL (must be valid URL)",
                        "example": "https://example.com/new-logo.png"
                      },
                      "timezone": {
                        "type": "string",
                        "maxLength": 100,
                        "description": "IANA timezone identifier",
                        "example": "Europe/London"
                      },
                      "balanceMinutes": {
                        "type": "number",
                        "minimum": 0,
                        "description": "Minutes balance",
                        "example": 2000
                      },
                      "balanceMessages": {
                        "type": "number",
                        "minimum": 0,
                        "description": "Messages balance",
                        "example": 10000
                      },
                      "contactName": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 255,
                        "description": "Business contact name",
                        "example": "Jane Doe"
                      },
                      "contactPhone": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 50,
                        "description": "Business contact phone",
                        "example": "+15559876543"
                      },
                      "streetAddress": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 500,
                        "description": "Street address",
                        "example": "456 Oak Ave"
                      },
                      "state": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 100,
                        "description": "State or province",
                        "example": "CA"
                      },
                      "zip": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 20,
                        "description": "Postal/ZIP code",
                        "example": "90210"
                      },
                      "ein": {
                        "type": "string",
                        "nullable": true,
                        "maxLength": 50,
                        "description": "Tax ID / EIN",
                        "example": "98-7654321"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workspace updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Workspace"
                    },
                    {
                      "properties": {
                        "id": {
                          "type": "string",
                          "format": "uuid",
                          "description": "Unique workspace identifier",
                          "example": "123e4567-e89b-12d3-a456-426614174000"
                        },
                        "accountId": {
                          "type": "string",
                          "format": "uuid",
                          "description": "Account this workspace belongs to",
                          "example": "789e4567-e89b-12d3-a456-426614174000"
                        },
                        "name": {
                          "type": "string",
                          "description": "Workspace name",
                          "example": "My Workspace"
                        },
                        "description": {
                          "type": "string",
                          "nullable": true,
                          "description": "Workspace description",
                          "example": "Main workspace for sales team"
                        },
                        "icon": {
                          "type": "string",
                          "nullable": true,
                          "format": "uri",
                          "description": "Workspace logo URL (must be valid URL)",
                          "example": "https://example.com/logo.png"
                        },
                        "timezone": {
                          "type": "string",
                          "description": "IANA timezone identifier",
                          "example": "America/New_York"
                        },
                        "balanceMinutes": {
                          "type": "number",
                          "description": "Available minutes balance",
                          "example": 1000
                        },
                        "balanceMessages": {
                          "type": "number",
                          "description": "Available messages balance",
                          "example": 5000
                        },
                        "contactName": {
                          "type": "string",
                          "nullable": true,
                          "description": "Business contact name",
                          "example": "John Smith"
                        },
                        "contactPhone": {
                          "type": "string",
                          "nullable": true,
                          "description": "Business contact phone",
                          "example": "+15551234567"
                        },
                        "streetAddress": {
                          "type": "string",
                          "nullable": true,
                          "description": "Street address",
                          "example": "123 Main St"
                        },
                        "state": {
                          "type": "string",
                          "nullable": true,
                          "description": "State or province",
                          "example": "NY"
                        },
                        "zip": {
                          "type": "string",
                          "nullable": true,
                          "description": "Postal/ZIP code",
                          "example": "10001"
                        },
                        "ein": {
                          "type": "string",
                          "nullable": true,
                          "description": "Tax ID / EIN",
                          "example": "12-3456789"
                        },
                        "deletedAt": {
                          "type": "string",
                          "nullable": true,
                          "format": "date-time",
                          "description": "Soft delete timestamp (ISO 8601)",
                          "example": null
                        },
                        "createdAt": {
                          "type": "string",
                          "format": "date-time",
                          "description": "Workspace creation timestamp (ISO 8601)",
                          "example": "2025-12-11T12:00:00Z"
                        },
                        "updatedAt": {
                          "type": "string",
                          "format": "date-time",
                          "description": "Workspace last update timestamp (ISO 8601)",
                          "example": "2025-12-11T12:00:00Z"
                        }
                      },
                      "required": [
                        "id",
                        "accountId",
                        "name",
                        "description",
                        "icon",
                        "timezone",
                        "balanceMinutes",
                        "balanceMessages",
                        "contactName",
                        "contactPhone",
                        "streetAddress",
                        "state",
                        "zip",
                        "ein",
                        "deletedAt",
                        "createdAt",
                        "updatedAt"
                      ]
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error - invalid request body or workspace ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid service key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "IP not in allowlist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found or deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete workspace",
        "description": "Soft-deletes a workspace by setting deleted_at timestamp.",
        "tags": [
          "Internal - Workspaces"
        ],
        "security": [
          {
            "serviceKeyAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
