      "EmailAction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique action identifier",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "agentId": {
            "type": "string",
            "format": "uuid",
            "description": "Agent ID this action belongs to",
            "example": "789e4567-e89b-12d3-a456-426614174000"
          },
          "name": {
            "type": "string",
            "description": "Action name",
            "example": "Send Welcome Email"
          },
          "fromName": {
            "type": "string",
            "description": "Display name for the sender",
            "example": "Nedzo Support"
          },
          "fromAddress": {
            "type": "string",
            "description": "Local part of sender email (domain comes from email_integrations)",
            "example": "support"
          },
          "subject": {
            "type": "string",
            "description": "Email subject (supports {{contact.X}} variables)",
            "example": "Welcome {{contact.firstName}}!"
          },
          "body": {
            "type": "string",
            "nullable": true,
            "description": "Email body (supports {{contact.X}} variables). Null when messageMode is \"ai_generated\"",
            "example": "Hello {{contact.name}}, thank you for signing up!"
          },
          "messageMode": {
            "type": "string",
            "enum": [
              "fixed",
              "ai_generated"
            ],
            "description": "Whether the message body is fixed or composed by AI at runtime",
            "example": "fixed"
          },
          "recipientType": {
            "type": "string",
            "enum": [
              "contact",
              "specific",
              "ask"
            ],
            "description": "How to determine recipient: contact=use contact.email, specific=use recipientValue, ask=use dynamic to param",
            "example": "contact"
          },
          "recipientValue": {
            "type": "string",
            "nullable": true,
            "description": "Required when recipientType is \"specific\"",
            "example": "admin@example.com"
          },
          "condition": {
            "type": "string",
            "nullable": true,
            "description": "Condition to trigger this action",
            "example": "User requests a follow-up email"
          },
          "isActive": {
            "type": "boolean",
            "description": "Whether the action is active",
            "example": true
          },
          "deletedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Soft delete timestamp",
            "example": null
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2026-01-26T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2026-01-26T12:00:00Z"
          }
        },
        "required": [
          "id",
          "agentId",
          "name",
          "fromName",
          "fromAddress",
          "subject",
          "body",
          "messageMode",
          "recipientType",
          "recipientValue",
          "condition",
          "isActive",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ]
      },
