{
  "swagger": "2.0",
  "info": {
    "version": "1.0.1",
    "title": "Edge Background Check Connector",
    "description": "Edge Custom Background Check API Template. Use this template to help generate your API contracts so that you can connect with CSOD and become a custom background check provider. Detailed in this API are endpoints that should be implemented so that the contract can adhere to Edge Custom Background Check Provier standards",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/csodedge/Background-Check/1.0.1/swagger.json"
  },
  "schemes": [
    "https"
  ],
  "securityDefinitions": {
    "basicAuth": {
      "type": "basic"
    }
  },
  "paths": {
    "/api/Packages": {
      "get": {
        "summary": "This endpoint will be used by Edge to retrieve a list of available packages",
        "tags": [
          "Background Check"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "operationId": "BackgroundCheckPackages_Get",
        "description": "get a list of available background check packages. If accounts are involved then they should be provided in the name property along with the corresponding package. E.g. 'Account 1 - Package 1', 'Account 1 - Package 2'\n",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "a list of background check packages",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/BackgroundCheckPackage"
              }
            }
          }
        }
      }
    },
    "/api/InitiateBackgroundCheck": {
      "post": {
        "summary": "This endpoint will be used by Edge to initiate a background check",
        "tags": [
          "Background Check"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "operationId": "InitiateBackgroundCheck_Post",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "BackgroundCheckRequest",
            "description": "the request body used by Edge to initiate a background check",
            "required": true,
            "schema": {
              "$ref": "#/definitions/BackgroundCheckRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "returns a backgroundcheck response to indicate whether the request was successful and any errors",
            "schema": {
              "$ref": "#/definitions/BackgroundCheckResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "BackgroundCheckPackage": {
      "type": "object",
      "required": [
        "Id",
        "Name"
      ],
      "properties": {
        "Id": {
          "type": "string",
          "description": "unique identifier",
          "example": "bg-pack-a123-5"
        },
        "Name": {
          "type": "string",
          "description": "friendly name of package",
          "example": "Package 5"
        }
      }
    },
    "BackgroundCheckRequest": {
      "type": "object",
      "required": [
        "ApplicantData",
        "CallbackData"
      ],
      "properties": {
        "ApplicantData": {
          "$ref": "#/definitions/ApplicantData"
        },
        "JobRequisitionData": {
          "$ref": "#/definitions/JobRequisitionData"
        },
        "RequestorData": {
          "$ref": "#/definitions/RequestorData"
        },
        "CallbackData": {
          "$ref": "#/definitions/CallbackData"
        },
        "SelectedPackageId": {
          "type": "string",
          "description": "unique id that corresponds to the Id provided by the Get Pacakge Request",
          "example": "bg-pack-a123-5"
        }
      }
    },
    "ApplicantData": {
      "type": "object",
      "required": [
        "FirstName",
        "LastName"
      ],
      "properties": {
        "FirstName": {
          "type": "string",
          "example": "Bob"
        },
        "LastName": {
          "type": "string",
          "example": "Chan"
        },
        "MiddleName": {
          "type": "string",
          "example": "Robert"
        },
        "NamePrefix": {
          "type": "string",
          "description": "prefix",
          "example": "Mr"
        },
        "NameSuffix": {
          "type": "string",
          "description": "suffix",
          "example": "III"
        },
        "RecruiterEmail": {
          "type": "string",
          "description": "email of the person requesting the background check",
          "example": "awesome-recruiter@mycompany.com"
        },
        "OrganizationUnit": {
          "$ref": "#/definitions/OrganizationUnit"
        },
        "ContactInfo": {
          "$ref": "#/definitions/ApplicantContactInfo"
        },
        "Address": {
          "$ref": "#/definitions/ApplicantAddress"
        },
        "Resume": {
          "$ref": "#/definitions/ApplicantResume"
        }
      }
    },
    "OrganizationUnit": {
      "type": "object",
      "description": "the standard organization units available from csod",
      "properties": {
        "Division": {
          "type": "string",
          "example": "tech"
        },
        "Location": {
          "type": "object",
          "properties": {
            "Name": {
              "type": "string",
              "example": "Santa Monica"
            },
            "Ref": {
              "type": "string",
              "example": "SM"
            }
          }
        },
        "CostCenter": {
          "type": "string",
          "example": "Finance"
        },
        "Position": {
          "type": "string",
          "example": "Senior Accountant"
        },
        "Grade": {
          "type": "string",
          "example": "Senior"
        },
        "DivisionId": {
          "type": "string",
          "example": "tech01"
        },
        "PositionId": {
          "type": "string",
          "example": "SenAcc01"
        },
        "CostCenterId": {
          "type": "string",
          "example": "Fin01"
        }
      }
    },
    "ApplicantContactInfo": {
      "type": "object",
      "required": [
        "Email"
      ],
      "properties": {
        "Email": {
          "type": "string",
          "example": "bob@amazingcompany.com"
        },
        "Phone": {
          "type": "string",
          "description": "phone number",
          "example": 12134294921
        },
        "HomePhone": {
          "type": "string",
          "description": "phone number",
          "example": 12133945852
        },
        "Mobile": {
          "type": "string",
          "description": "phone number",
          "example": 12139985903
        }
      }
    },
    "ApplicantAddress": {
      "type": "object",
      "properties": {
        "AddressLine1": {
          "type": "string",
          "description": "address",
          "example": "1601 Cloverfield Blvd"
        },
        "AddressLine2": {
          "type": "string",
          "description": "address continued",
          "example": "STE 600S"
        },
        "AddressCity": {
          "type": "string",
          "description": "city",
          "example": "Santa Monica"
        },
        "AddressState": {
          "type": "string",
          "description": "state or province",
          "example": "CA"
        },
        "AddressPostalZipCode": {
          "type": "string",
          "description": "zip code",
          "example": 90404
        },
        "AddressCountryCode": {
          "type": "string",
          "description": "country code in 3 letters",
          "example": "USA"
        }
      }
    },
    "ApplicantResume": {
      "type": "object",
      "properties": {
        "ProfessionalExperiences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProfessionalExperience"
          }
        },
        "Educations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Education"
          }
        },
        "Certifications": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Certification"
          }
        }
      }
    },
    "ProfessionalExperience": {
      "type": "object",
      "properties": {
        "Position": {
          "type": "string",
          "example": "Accountant"
        },
        "Organization": {
          "type": "string",
          "example": "Cornerstone OnDemand"
        },
        "Description": {
          "type": "string",
          "example": "HR Software Company"
        },
        "StartDate": {
          "type": "string",
          "example": "05/2014"
        },
        "EndDate": {
          "type": "string",
          "example": "05/2016"
        },
        "Current": {
          "type": "string",
          "example": false
        },
        "DateRange": {
          "type": "string",
          "example": "05/2014, 05/2016"
        }
      }
    },
    "Education": {
      "type": "object",
      "properties": {
        "AreaOfStudy": {
          "type": "string",
          "example": "Economics"
        },
        "Minor": {
          "type": "string",
          "example": "Art History"
        },
        "Institution": {
          "type": "string",
          "example": "University of California, Los Angeles"
        },
        "Degree": {
          "type": "string",
          "example": "Bachelor of Arts"
        },
        "Grade": {
          "type": "string",
          "example": 3.8
        },
        "GraduationDate": {
          "type": "string",
          "example": "Fall 2015"
        }
      }
    },
    "Certification": {
      "type": "object",
      "properties": {
        "Name": {
          "type": "string",
          "example": "CPA"
        },
        "Organization": {
          "type": "string",
          "example": "American Institute of Certified Public Accountants"
        },
        "IssuedDate": {
          "type": "string",
          "example": "5/10/2016"
        },
        "ExpirationDate": {
          "type": "string",
          "example": "10/10/2020"
        },
        "Description": {
          "type": "string",
          "example": "CPA"
        }
      }
    },
    "CallbackData": {
      "type": "object",
      "required": [
        "CallbackUrl",
        "ApplicantRefId",
        "ApplicantRefUserId",
        "ApplicantRefOrderId"
      ],
      "description": "callback data includes the callback URL to use as well as the required callback data marked as required",
      "properties": {
        "CallbackUrl": {
          "type": "string",
          "description": "url used to make callbacks into edge for updates to background checks",
          "example": "https://edgeurl/callback/123803912389012-1293123"
        },
        "ApplicantRefId": {
          "type": "string",
          "description": "this is the reference id that needs to be provided on callbacks to help identify applicants",
          "example": "13453-R"
        },
        "ApplicantRefUserId": {
          "type": "string",
          "description": "this is the userid reference that needs to be provided on callbacks",
          "example": 53885329
        },
        "ApplicantRefOrderId": {
          "type": "string",
          "description": "this is the orderid reference that needs to be provided on callbacks",
          "example": 1239588
        }
      }
    },
    "JobRequisitionData": {
      "type": "object",
      "description": "providing data about the requisition the Background Check is ordered for",
      "properties": {
        "Id": {
          "type": "string",
          "description": "this is the job requisition id",
          "example": "req24"
        },
        "DisplayTitle": {
          "type": "string",
          "description": "this is the job title",
          "example": "Store Manager"
        },
        "City": {
          "type": "string",
          "description": "city name",
          "example": "Santa Monica"
        },
        "State": {
          "type": "string",
          "description": "state or province",
          "example": "CA"
        },
        "Country": {
          "type": "string",
          "description": "country code in 3 letters",
          "example": "USA"
        }
      }
    },
    "RequestorData": {
      "type": "object",
      "description": "providing data about the CSOD user requesting the Background Check",
      "properties": {
        "FirstName": {
          "type": "string",
          "example": "Bob"
        },
        "LastName": {
          "type": "string",
          "example": "Chan"
        },
        "EmailAddress": {
          "type": "string",
          "description": "email of the person requesting the background check",
          "example": "bob@amazingcompany.com"
        },
        "Phone": {
          "type": "string",
          "description": "phone number",
          "example": 12134294921
        },
        "UserID": {
          "type": "string",
          "example": "chanbob"
        },
        "Division": {
          "type": "string",
          "example": "Tech division"
        }
      }
    },
    "BackgroundCheckResponse": {
      "type": "object",
      "required": [
        "HasErrors"
      ],
      "properties": {
        "ProviderReferenceId": {
          "type": "string",
          "description": "this is a unique provider reference id generated by the provider to associate a background check request to an applicant",
          "example": "R-231592"
        },
        "HasErrors": {
          "type": "boolean",
          "example": true
        },
        "Errors": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Error"
          }
        }
      }
    },
    "Error": {
      "type": "object",
      "properties": {
        "Description": {
          "type": "string",
          "example": "the user email was not provided"
        }
      }
    }
  },
  "host": "virtserver.swaggerhub.com",
  "basePath": "/csodedge/Background-Check/1.0.1"
}