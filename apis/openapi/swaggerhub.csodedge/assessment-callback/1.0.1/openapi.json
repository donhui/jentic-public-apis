{
    "openapi": "3.0.0",
    "info": {
        "version": "1.0.1",
        "title": "Edge Assessment Connector Callback",
        "description": "This is the callback endpoint for assessments implemented by Cornerstone.",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/csodedge/Assessment-Callback/1.0.1/swagger.json"
    },
    "paths": {
        "/api/UpdateAssessmentStatus": {
            "post": {
                "tags": [
                    "UpdateAssessmentStatus"
                ],
                "operationId": "UpdateAssessmentStatus_Post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateAssessmentStatus"
                            }
                        },
                        "text/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateAssessmentStatus"
                            }
                        },
                        "application/xml": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateAssessmentStatus"
                            }
                        },
                        "text/xml": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateAssessmentStatus"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateAssessmentStatus"
                            }
                        }
                    },
                    "description": "the callback request to make to Cornerstone when updating/completing an assessment",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/csodedge/Assessment-Callback/1.0.1"
        }
    ],
    "components": {
        "schemas": {
            "UpdateAssessmentStatus": {
                "type": "object",
                "required": [
                    "IsPass",
                    "Score",
                    "DetailsUrl"
                ],
                "properties": {
                    "IsPass": {
                        "type": "boolean",
                        "description": "Indicates if the candidate passed the assessment.",
                        "example": true
                    },
                    "Score": {
                        "type": "string",
                        "description": "Indicates the assessment score for the candidate. Must be a non-negative integer value.",
                        "example": "51"
                    },
                    "Result": {
                        "type": "string",
                        "description": "this is an enum that gets mapped, accepted values are | \"Pass\" \"Fail\" \"Needs Review\"",
                        "enum": [
                            "Pass",
                            "Fail",
                            "Needs Review"
                        ],
                        "example": "Pass"
                    },
                    "DetailsUrl": {
                        "type": "string",
                        "description": "Contains the URL to detailed report that a recruiter can launch from Cornerstone to view additional information about the assessment result."
                    },
                    "Comments": {
                        "type": "string",
                        "description": "Use this field to display additional details about the candidate's assessment results in Cornerstone.",
                        "example": "Proceed with candidate"
                    },
                    "SubScores": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/SubScores"
                        }
                    }
                }
            },
            "SubScores": {
                "type": "object",
                "properties": {
                    "Score": {
                        "type": "string",
                        "description": "Indicates the assessment score for the candidate. Must be a non-negative integer value.",
                        "example": "51"
                    },
                    "Result": {
                        "type": "string",
                        "description": "this is an enum that gets mapped, accepted values are | \"Pass\" \"Fail\" \"Needs Review\"",
                        "enum": [
                            "Pass",
                            "Fail",
                            "Needs Review"
                        ],
                        "example": "Pass"
                    },
                    "Details": {
                        "type": "string",
                        "description": "Use this field to display additional details about the candidate's assessment results in Cornerstone.",
                        "example": "Proceed with candidate"
                    },
                    "Description": {
                        "type": "string",
                        "description": "Use this field to display the title of the category scored.",
                        "example": "Communication Skills"
                    }
                }
            }
        }
    }
}