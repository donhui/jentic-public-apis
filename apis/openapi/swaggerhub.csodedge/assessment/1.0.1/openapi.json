{
    "openapi": "3.0.0",
    "info": {
        "version": "1.0.1",
        "title": "Edge Assessment Connector",
        "description": "Edge Assessment API Template. Use this template to help generate your API contracts so that you can connect with CSOD and become an assessment provider. Detailed in this API are endpoints that should be implemented so that the contract can adhere to Edge  Assessment Provider standards.",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/csodedge/Assessment/1.0.1/swagger.json"
    },
    "paths": {
        "/api/Assessment": {
            "get": {
                "summary": "This endpoint is used to retrieve the list of available assessments",
                "security": [
                    {
                        "basicAuth": []
                    }
                ],
                "tags": [
                    "Assessment"
                ],
                "operationId": "Assessment_Get",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/AssessmentItem"
                                    }
                                }
                            },
                            "text/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/AssessmentItem"
                                    }
                                }
                            },
                            "application/xml": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/AssessmentItem"
                                    }
                                }
                            },
                            "text/xml": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/AssessmentItem"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/InitiateAssessment": {
            "post": {
                "summary": "This endpoint is used to initiate the selected assessment and retrieve the launch URL",
                "security": [
                    {
                        "basicAuth": []
                    }
                ],
                "tags": [
                    "InitiateAssessment"
                ],
                "operationId": "InitiateAssessment_Post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/InitiateAssessment"
                            }
                        },
                        "text/json": {
                            "schema": {
                                "$ref": "#/components/schemas/InitiateAssessment"
                            }
                        },
                        "application/xml": {
                            "schema": {
                                "$ref": "#/components/schemas/InitiateAssessment"
                            }
                        },
                        "text/xml": {
                            "schema": {
                                "$ref": "#/components/schemas/InitiateAssessment"
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/InitiateAssessment"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/InitiateAssessmentResponse"
                                }
                            },
                            "text/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/InitiateAssessmentResponse"
                                }
                            },
                            "application/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/InitiateAssessmentResponse"
                                }
                            },
                            "text/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/InitiateAssessmentResponse"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/csodedge/Assessment/1.0.1"
        }
    ],
    "components": {
        "securitySchemes": {
            "basicAuth": {
                "type": "http",
                "scheme": "basic"
            }
        },
        "schemas": {
            "AssessmentItem": {
                "type": "object",
                "description": "assessment item",
                "required": [
                    "Name",
                    "IntegrationOrderId"
                ],
                "properties": {
                    "AssessmentId": {
                        "type": "string",
                        "description": "assessment id",
                        "example": 123
                    },
                    "Name": {
                        "type": "string",
                        "description": "assessment item name",
                        "example": "abc"
                    }
                }
            },
            "InitiateAssessment": {
                "type": "object",
                "description": "initiate the assessment",
                "required": [
                    "AssessmentID",
                    "JobRequisitionID"
                ],
                "properties": {
                    "AssessmentId": {
                        "type": "string",
                        "description": "assessment id",
                        "example": 123
                    },
                    "JobRequisitionId": {
                        "type": "string",
                        "description": "job requisition id",
                        "example": "req11"
                    },
                    "Timestamp": {
                        "type": "string"
                    },
                    "IntegrationOrderId": {
                        "type": "string",
                        "description": "integration order id",
                        "example": 213
                    },
                    "ApplicantData": {
                        "$ref": "#/components/schemas/ApplicantData"
                    },
                    "JobRequisition": {
                        "$ref": "#/components/schemas/JobRequisitionData"
                    },
                    "CallbackData": {
                        "$ref": "#/components/schemas/CallbackData"
                    }
                }
            },
            "ApplicantData": {
                "type": "object",
                "description": "applicant data",
                "required": [
                    "FirstName",
                    "LastName",
                    "Email"
                ],
                "properties": {
                    "FirstName": {
                        "type": "string",
                        "description": "applicant first name",
                        "example": "Bob"
                    },
                    "LastName": {
                        "type": "string",
                        "description": "applicant last name",
                        "example": "Chan"
                    },
                    "MiddleName": {
                        "type": "string",
                        "description": "applicant middle name",
                        "example": "Sun"
                    },
                    "NamePrefix": {
                        "type": "string"
                    },
                    "NameSuffix": {
                        "type": "string"
                    },
                    "Guid": {
                        "type": "string"
                    },
                    "LanguagePreference": {
                        "type": "string"
                    },
                    "Type": {
                        "type": "string",
                        "description": "applicant type (Internal/Extrernal)",
                        "example": "internal or external"
                    },
                    "RecruiterEmail": {
                        "type": "string",
                        "description": "email of the person requesting the assessment",
                        "example": "awesome-recruiter@mycompany.com"
                    },
                    "OrganizationUnit": {
                        "$ref": "#/components/schemas/OrganizationUnit"
                    },
                    "ContactInfo": {
                        "$ref": "#/components/schemas/ApplicantContactInfo"
                    },
                    "Address": {
                        "$ref": "#/components/schemas/ApplicantAddress"
                    }
                }
            },
            "CallbackData": {
                "type": "object",
                "properties": {
                    "TrackingId": {
                        "type": "string"
                    },
                    "CallbackUrl": {
                        "type": "string"
                    },
                    "ApplicantRefId": {
                        "type": "string"
                    },
                    "ApplicantRefUserId": {
                        "type": "string"
                    },
                    "ApplicantRefOrderId": {
                        "type": "string"
                    }
                }
            },
            "OrganizationUnit": {
                "type": "object",
                "description": "the standard organization units available from csod",
                "properties": {
                    "Division": {
                        "type": "string",
                        "example": "tech"
                    },
                    "Location": {
                        "$ref": "#/components/schemas/OrganizationUnitLocation"
                    },
                    "CostCenter": {
                        "type": "string",
                        "example": "Finance"
                    },
                    "Position": {
                        "type": "string",
                        "example": "Senior Accountant"
                    },
                    "Grade": {
                        "type": "string",
                        "example": "Senior"
                    }
                }
            },
            "ApplicantContactInfo": {
                "type": "object",
                "description": "the applicant contact information",
                "properties": {
                    "Email": {
                        "type": "string",
                        "example": "bob@amazingcompany.com"
                    },
                    "Phone": {
                        "type": "string",
                        "description": "phone number",
                        "example": 12134294921
                    },
                    "HomePhone": {
                        "type": "string",
                        "description": "phone number",
                        "example": 12133945852
                    },
                    "Mobile": {
                        "type": "string",
                        "description": "phone number",
                        "example": 12139985903
                    }
                }
            },
            "ApplicantAddress": {
                "type": "object",
                "description": "the applicant address details",
                "properties": {
                    "AddressLine1": {
                        "type": "string",
                        "description": "address",
                        "example": "1601 Cloverfield Blvd"
                    },
                    "AddressLine2": {
                        "type": "string",
                        "description": "address continued",
                        "example": "STE 600S"
                    },
                    "AddressCity": {
                        "type": "string",
                        "description": "city",
                        "example": "Santa Monica"
                    },
                    "AddressState": {
                        "type": "string",
                        "description": "state or province",
                        "example": "CA"
                    },
                    "AddressPostalZipCode": {
                        "type": "string",
                        "description": "zip code",
                        "example": 90404
                    },
                    "AddressCountryCode": {
                        "type": "string",
                        "description": "country code in 3 letters",
                        "example": "USA"
                    }
                }
            },
            "OrganizationUnitLocation": {
                "type": "object",
                "description": "organization unit location",
                "properties": {
                    "Name": {
                        "type": "string",
                        "description": "organization unit location name"
                    },
                    "Ref": {
                        "type": "string"
                    }
                }
            },
            "JobRequisitionData": {
                "type": "object",
                "description": "providing data about the requisition of the Assessment",
                "properties": {
                    "PrimaryOwnerName": {
                        "type": "string"
                    },
                    "PrimaryOwnerEmail": {
                        "type": "string",
                        "example": "bobowe@amazingcompany.com"
                    },
                    "DisplayJobTitle": {
                        "type": "string",
                        "description": "this is the job title",
                        "example": "Store Manager"
                    },
                    "Country": {
                        "type": "string",
                        "description": "country code in 3 letters",
                        "example": "USA"
                    }
                }
            },
            "InitiateAssessmentResponse": {
                "type": "object",
                "description": "initate assessment response",
                "properties": {
                    "Success": {
                        "type": "boolean",
                        "example": "true or false"
                    },
                    "Message": {
                        "type": "string"
                    },
                    "LaunchUrl": {
                        "type": "string"
                    }
                }
            }
        }
    }
}