{
  "openapi": "3.0.3",
  "info": {
    "title": "Prembly API",
    "version": "1.0.0",
    "description": "Prembly identity verification and fraud prevention API for securing digital transactions in emerging markets.",
    "x-jentic-source-url": "https://docs.prembly.com/docs/"
  },
  "servers": [
    {
      "url": "https://api.prembly.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Secret key for API authentication"
      }
    },
    "schemas": {
      "WalletBalance": {
        "type": "object",
        "properties": {
          "balance": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "VerificationStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "verification_id": {
            "type": "string"
          },
          "result": {
            "type": "object"
          }
        }
      },
      "CompanySearchResult": {
        "type": "object",
        "properties": {
          "company_name": {
            "type": "string"
          },
          "registration_number": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "DocumentVerificationRequest": {
        "type": "object",
        "properties": {
          "document_image": {
            "type": "string",
            "format": "binary"
          },
          "document_type": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "DocumentVerificationResult": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "document_type": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "FaceComparisonRequest": {
        "type": "object",
        "properties": {
          "image_one": {
            "type": "string",
            "format": "binary"
          },
          "image_two": {
            "type": "string",
            "format": "binary"
          }
        }
      },
      "Candidate": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Package": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "FraudReport": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "details": {
            "type": "object"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "integer"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "General",
      "description": "General utility endpoints"
    },
    {
      "name": "Business Verification",
      "description": "Company and business verification"
    },
    {
      "name": "Document Verification",
      "description": "Identity document verification"
    },
    {
      "name": "Biometrics",
      "description": "Face comparison and liveness detection"
    },
    {
      "name": "Background Checks",
      "description": "Background check management"
    },
    {
      "name": "Compliance",
      "description": "AML, PEP, and sanctions screening"
    },
    {
      "name": "Fraud",
      "description": "Fraud detection and reporting"
    }
  ],
  "paths": {
    "/wallet-balance": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "Get wallet balance",
        "operationId": "getWalletBalance",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WalletBalance"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/verification-status": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "Check verification status",
        "operationId": "getVerificationStatus",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "parameters": [
          {
            "name": "verification_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/sdk-session": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "Get SDK session details",
        "operationId": "getSdkSession",
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/countries": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "List supported countries",
        "operationId": "listCountries",
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
