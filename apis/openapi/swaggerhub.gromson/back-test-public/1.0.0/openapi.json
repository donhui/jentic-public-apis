{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Back Test Public API",
    "description": "API for public server. Public server allows to add new messages into the system.",
    "contact": {
      "name": "Roman Iudin",
      "email": "gromson@gmail.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/gromson/back-test-public/1.0.0/swagger.json"
  },
  "servers": [
    {
      "description": "Heroku App",
      "url": "https://romson-back-public-api.herokuapp.com/"
    },
    {
      "description": "Local App",
      "url": "http://localhost:8080/"
    }
  ],
  "paths": {
    "/messages": {
      "post": {
        "tags": [
          "messages"
        ],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "summary": "Adding of a message",
        "requestBody": {
          "$ref": "#/components/requestBodies/Message"
        },
        "responses": {
          "200": {
            "description": "Message has been added",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "ID of an added message",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid",
                      "example": "4fd4fda6-230a-4a9e-817e-8e8c6c7b79a8"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "requestBodies": {
      "Message": {
        "description": "Message details",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "description": "Message data",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Author name",
                  "example": "Roman Iudin"
                },
                "email": {
                  "type": "string",
                  "format": "email",
                  "description": "Author email",
                  "example": "my@mail.com"
                },
                "text": {
                  "type": "string",
                  "description": "Message text",
                  "example": "pharetra, felis eget varius ultrices, mauris ipsum"
                }
              }
            }
          }
        }
      }
    },
    "responses": {
      "InternalError": {
        "description": "Internal Server Error"
      },
      "BadRequest": {
        "description": "Bad Request",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Not Found",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "headers": {
          "WWW-Authenticate": {
            "description": "Authentication error",
            "schema": {
              "type": "string",
              "example": "Basic realm=\"Authentication\", error=\"invalid_token\", error_description=\"Login or password are invalid\""
            }
          }
        },
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/Unauthorized"
            }
          }
        }
      }
    },
    "schemas": {
      "ProblemResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Link to the error description",
            "example": "https://example.net/bad-request"
          },
          "title": {
            "type": "string",
            "description": "Status description",
            "example": "Wrong data has been provided"
          },
          "status": {
            "type": "integer",
            "description": "Status code",
            "example": 400
          },
          "detail": {
            "description": "Error details",
            "oneOf": [
              {
                "type": "string",
                "example": "A message should contain a text"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "A message should contain a text",
                  "A message should contain a name of an author"
                ]
              }
            ],
            "example": [
              "A message should contain a text",
              "A message should contain a name of an author"
            ]
          }
        }
      },
      "Unauthorized": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Link to the error description",
            "example": "https://example.net/unauthorized"
          },
          "title": {
            "type": "string",
            "description": "Status description",
            "example": "Unauthorized"
          },
          "status": {
            "type": "integer",
            "description": "Status code",
            "example": 401
          },
          "detail": {
            "type": "string",
            "description": "Error details",
            "example": "A name or a password are incorrect"
          }
        }
      }
    }
  }
}