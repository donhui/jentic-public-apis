{
  "openapi": "3.0.3",
  "info": {
    "title": "Metriport Medical API",
    "version": "1.0.0",
    "description": "Metriport Medical API for managing healthcare facilities, patients, medical documents, and FHIR-based consolidated data queries.",
    "x-jentic-source-url": "https://docs.metriport.com/medical-api/getting-started/quickstart"
  },
  "servers": [
    {
      "url": "https://api.metriport.com/medical/v1",
      "description": "Metriport Medical API"
    }
  ],
  "paths": {
    "/organization": {
      "post": {
        "operationId": "createOrganization",
        "summary": "Create Organization",
        "description": "Creates an Organization in Metriport to represent your healthcare entity.",
        "tags": ["Organization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrganizationInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Organization created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Organization"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/facility": {
      "get": {
        "operationId": "listFacilities",
        "summary": "List Facilities",
        "description": "Returns an array of all the Facilities created under your Organization.",
        "tags": ["Facility"],
        "responses": {
          "200": {
            "description": "Facilities retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FacilityListResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createFacility",
        "summary": "Create Facility",
        "description": "Creates a Facility in Metriport where your patients receive care.",
        "tags": ["Facility"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FacilityInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Facility created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Facility"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/facility/{id}": {
      "get": {
        "operationId": "getFacility",
        "summary": "Get Facility",
        "description": "Retrieves a facility by ID.",
        "tags": ["Facility"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Facility"
          }
        ],
        "responses": {
          "200": {
            "description": "Facility retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Facility"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateFacility",
        "summary": "Update Facility",
        "description": "Updates a facility by ID.",
        "tags": ["Facility"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Facility"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FacilityInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Facility updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Facility"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/patient": {
      "get": {
        "operationId": "listPatients",
        "summary": "List Patients",
        "description": "Returns all patients, optionally filtered by facility or search criteria.",
        "tags": ["Patient"],
        "parameters": [
          {
            "name": "facilityId",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "The ID of the Facility where the patient is receiving care"
          },
          {
            "name": "filters",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Search criteria supporting combined filter logic with boolean operators and date formats"
          }
        ],
        "responses": {
          "200": {
            "description": "Patients retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientListResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createPatient",
        "summary": "Create Patient",
        "description": "Creates a Patient in Metriport.",
        "tags": ["Patient"],
        "parameters": [
          {
            "name": "facilityId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Facility where the Patient is receiving care"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patient created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/patient/{id}": {
      "get": {
        "operationId": "getPatient",
        "summary": "Get Patient",
        "description": "Retrieves a patient by ID.",
        "tags": ["Patient"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Patient"
          }
        ],
        "responses": {
          "200": {
            "description": "Patient retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updatePatient",
        "summary": "Update Patient",
        "description": "Updates the specified Patient.",
        "tags": ["Patient"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Patient to update"
          },
          {
            "name": "facilityId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Facility where the patient is receiving care"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patient updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deletePatient",
        "summary": "Delete Patient",
        "description": "Deletes a patient by ID.",
        "tags": ["Patient"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Patient to delete"
          },
          {
            "name": "facilityId",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "The ID of the Facility where the patient is receiving care"
          }
        ],
        "responses": {
          "204": { "description": "Patient deleted successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/document/query/{patientId}": {
      "post": {
        "operationId": "startDocumentQuery",
        "summary": "Start Document Query",
        "description": "Triggers a document query across the network for the specified patient.",
        "tags": ["Document"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Patient"
          },
          {
            "name": "facilityId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Facility"
          }
        ],
        "responses": {
          "200": {
            "description": "Document query started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "queryId": { "type": "string" },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/document/download": {
      "get": {
        "operationId": "getDocumentUrl",
        "summary": "Get Document URL",
        "description": "Returns a presigned URL to download a document. URL expires in 60 seconds.",
        "tags": ["Document"],
        "parameters": [
          {
            "name": "fileName",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The file name of the document from meta.source attribute"
          },
          {
            "name": "conversionType",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["html", "pdf"] },
            "description": "Convert XML/CDA files to html or pdf"
          }
        ],
        "responses": {
          "200": {
            "description": "Document URL retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": { "type": "string", "description": "Presigned download URL valid for 60 seconds" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/document/bulk/download/{patientId}": {
      "post": {
        "operationId": "startBulkDocumentDownload",
        "summary": "Start Bulk Document Download",
        "description": "Start bulk download of document URLs for a patient.",
        "tags": ["Document"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Patient"
          }
        ],
        "responses": {
          "200": {
            "description": "Bulk download started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/document/upload/{patientId}": {
      "post": {
        "operationId": "uploadDocument",
        "summary": "Upload Document",
        "description": "Upload a document for a patient.",
        "tags": ["Document"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Patient"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The document file to upload"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Document uploaded successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/patient/{patientId}/consolidated/query": {
      "post": {
        "operationId": "startConsolidatedDataQuery",
        "summary": "Start Consolidated Data Query",
        "description": "Start a consolidated data query for a patient, returning FHIR resources.",
        "tags": ["FHIR"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Patient"
          }
        ],
        "responses": {
          "200": {
            "description": "Consolidated data query started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "queryId": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/patient/{patientId}/consolidated/data": {
      "post": {
        "operationId": "createConsolidatedData",
        "summary": "Create Consolidated Data",
        "description": "Create patient's consolidated FHIR data.",
        "tags": ["FHIR"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The ID of the Patient"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "FHIR resource bundle"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Consolidated data created" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Address": {
        "type": "object",
        "properties": {
          "addressLine1": { "type": "string" },
          "addressLine2": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string" }
        },
        "required": ["addressLine1", "city", "state", "zip", "country"]
      },
      "OrganizationInput": {
        "type": "object",
        "required": ["name", "type", "location"],
        "properties": {
          "name": { "type": "string", "description": "Organization name" },
          "type": { "type": "string", "description": "Organization type", "enum": ["acuteCare", "ambulatory", "hospital", "labSystems", "pharmacy", "postAcuteCare"] },
          "location": { "$ref": "#/components/schemas/Address" }
        }
      },
      "Organization": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "location": { "$ref": "#/components/schemas/Address" }
        }
      },
      "FacilityInput": {
        "type": "object",
        "required": ["name", "npi", "address"],
        "properties": {
          "name": { "type": "string", "description": "Facility name" },
          "npi": { "type": "string", "description": "National Provider Identifier" },
          "tin": { "type": "string", "description": "Tax Identification Number" },
          "active": { "type": "boolean", "description": "Whether the facility is active" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "Facility": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "oid": { "type": "string", "description": "Organization identifier in OID format" },
          "name": { "type": "string" },
          "npi": { "type": "string" },
          "tin": { "type": "string" },
          "active": { "type": "boolean" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "FacilityListResponse": {
        "type": "object",
        "properties": {
          "facilities": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Facility" }
          }
        }
      },
      "PatientInput": {
        "type": "object",
        "required": ["firstName", "lastName", "dob", "genderAtBirth"],
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "dob": { "type": "string", "format": "date", "description": "Date of birth in YYYY-MM-DD format" },
          "genderAtBirth": { "type": "string", "enum": ["M", "F"] },
          "personalIdentifiers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "state": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          },
          "address": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Address" }
          },
          "contact": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phone": { "type": "string" },
                "email": { "type": "string" }
              }
            }
          },
          "externalId": { "type": "string" },
          "cohorts": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "dob": { "type": "string", "format": "date" },
          "genderAtBirth": { "type": "string" },
          "personalIdentifiers": { "type": "array", "items": { "type": "object" } },
          "address": { "type": "array", "items": { "$ref": "#/components/schemas/Address" } },
          "contact": { "type": "array", "items": { "type": "object" } },
          "externalId": { "type": "string" },
          "facilityIds": { "type": "array", "items": { "type": "string" } }
        }
      },
      "PatientListResponse": {
        "type": "object",
        "properties": {
          "patients": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Patient" }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error message" },
          "status": { "type": "integer", "description": "HTTP status code" }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Metriport API key"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ]
}