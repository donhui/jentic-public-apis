{
  "openapi": "3.0.3",
  "info": {
    "title": "SearchAPI Google Search",
    "description": "SearchAPI provides a real-time Google Search scraping API. Retrieve organic results, knowledge graphs, ads, and more from Google search results programmatically.",
    "version": "1.0.0",
    "contact": {
      "name": "SearchAPI",
      "url": "https://www.searchapi.io"
    },
    "x-jentic-source-url": "https://www.searchapi.io/docs/google"
  },
  "servers": [
    {
      "url": "https://www.searchapi.io/api/v1",
      "description": "SearchAPI production server"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    },
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "googleSearch",
        "summary": "Perform a Google search",
        "description": "Returns Google search results for the given query including organic results, knowledge graphs, ads, related questions, and more.",
        "parameters": [
          {
            "name": "engine",
            "in": "query",
            "required": true,
            "description": "Search engine to use. Set to 'google' for Google Search.",
            "schema": {
              "type": "string",
              "enum": ["google"],
              "default": "google"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query. Supports operators like site:, inurl:, intitle:, AND, OR.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "device",
            "in": "query",
            "required": false,
            "description": "Device type for the search.",
            "schema": {
              "type": "string",
              "enum": ["desktop", "mobile", "tablet"],
              "default": "desktop"
            }
          },
          {
            "name": "location",
            "in": "query",
            "required": false,
            "description": "Canonical location for the search (e.g., 'New York, United States').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uule",
            "in": "query",
            "required": false,
            "description": "Google-encoded location. Cannot be used with 'location'.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gl",
            "in": "query",
            "required": false,
            "description": "Country code for the search (e.g., 'us', 'gb').",
            "schema": {
              "type": "string",
              "default": "us"
            }
          },
          {
            "name": "hl",
            "in": "query",
            "required": false,
            "description": "Interface language (e.g., 'en', 'de').",
            "schema": {
              "type": "string",
              "default": "en"
            }
          },
          {
            "name": "lr",
            "in": "query",
            "required": false,
            "description": "Restrict results to a specific language (e.g., 'lang_en').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "num",
            "in": "query",
            "required": false,
            "description": "Number of results to return.",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "kgmid",
            "in": "query",
            "required": false,
            "description": "Knowledge Graph identifier (e.g., '/m/02_286' for New York).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoogleSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": ["Google Search"]
      }
    },
    "/locations": {
      "get": {
        "operationId": "listLocations",
        "summary": "List available locations",
        "description": "Returns available locations that can be used with the location parameter in search queries.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Location search query.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of available locations.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LocationResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": ["Utilities"]
      }
    },
    "/account": {
      "get": {
        "operationId": "getAccountInfo",
        "summary": "Get account information",
        "description": "Returns information about your SearchAPI account including remaining credits.",
        "responses": {
          "200": {
            "description": "Account information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": ["Utilities"]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key passed as a query parameter."
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication."
      }
    },
    "schemas": {
      "GoogleSearchResponse": {
        "type": "object",
        "properties": {
          "search_metadata": {
            "$ref": "#/components/schemas/SearchMetadata"
          },
          "search_parameters": {
            "type": "object",
            "description": "Echo of the search parameters used."
          },
          "search_information": {
            "type": "object",
            "properties": {
              "total_results": {
                "type": "integer"
              },
              "time_taken_displayed": {
                "type": "number"
              },
              "query_displayed": {
                "type": "string"
              }
            }
          },
          "organic_results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganicResult"
            }
          },
          "knowledge_graph": {
            "type": "object",
            "description": "Knowledge Graph information if available."
          },
          "related_questions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "question": {
                  "type": "string"
                },
                "snippet": {
                  "type": "string"
                },
                "link": {
                  "type": "string"
                }
              }
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "current": {
                "type": "integer"
              },
              "next": {
                "type": "string"
              }
            }
          }
        }
      },
      "SearchMetadata": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "request_time_taken": {
            "type": "number"
          }
        }
      },
      "OrganicResult": {
        "type": "object",
        "properties": {
          "position": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "link": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "displayed_link": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "snippet_highlighted_words": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "LocationResult": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "canonical_name": {
            "type": "string"
          },
          "country_code": {
            "type": "string"
          },
          "target_type": {
            "type": "string"
          }
        }
      },
      "AccountInfo": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "plan": {
            "type": "string"
          },
          "credits_remaining": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Google Search",
      "description": "Google search scraping endpoints"
    },
    {
      "name": "Utilities",
      "description": "Utility and account endpoints"
    }
  ]
}