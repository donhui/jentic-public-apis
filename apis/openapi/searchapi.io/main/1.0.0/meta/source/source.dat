{
  "openapi": "3.0.3",
  "info": {
    "title": "SearchAPI",
    "version": "1.0.0",
    "description": "SearchAPI provides real-time Google Search results including organic listings, knowledge graphs, ads, local results, and various SERP features.",
    "x-jentic-source-url": "https://www.searchapi.io/docs/google",
    "contact": {
      "name": "SearchAPI",
      "url": "https://www.searchapi.io"
    }
  },
  "servers": [
    {
      "url": "https://www.searchapi.io",
      "description": "SearchAPI production server"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/api/v1/search": {
      "get": {
        "operationId": "searchGoogle",
        "summary": "Search Google",
        "description": "Retrieve real-time Google Search results including organic listings, knowledge graphs, ads, local results, and various SERP features.",
        "parameters": [
          {
            "name": "engine",
            "in": "query",
            "required": true,
            "description": "Search engine to use",
            "schema": {
              "type": "string",
              "default": "google"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query. Supports operators like site:, inurl:, intitle:",
            "schema": { "type": "string" }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Canonical location name for geotargeting",
            "schema": { "type": "string" }
          },
          {
            "name": "uule",
            "in": "query",
            "description": "Google-encoded location parameter",
            "schema": { "type": "string" }
          },
          {
            "name": "device",
            "in": "query",
            "description": "Device type for the search",
            "schema": {
              "type": "string",
              "enum": ["desktop", "mobile", "tablet"]
            }
          },
          {
            "name": "gl",
            "in": "query",
            "description": "Country code (e.g., us, uk, de)",
            "schema": { "type": "string", "default": "us" }
          },
          {
            "name": "hl",
            "in": "query",
            "description": "Interface language (e.g., en, fr, de)",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "lr",
            "in": "query",
            "description": "Language restriction in lang_xx format",
            "schema": { "type": "string" }
          },
          {
            "name": "cr",
            "in": "query",
            "description": "Country restriction",
            "schema": { "type": "string" }
          },
          {
            "name": "nfpr",
            "in": "query",
            "description": "Exclude auto-corrected results (0 or 1)",
            "schema": { "type": "integer", "enum": [0, 1] }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Toggle duplicate content filter",
            "schema": { "type": "integer" }
          },
          {
            "name": "safe",
            "in": "query",
            "description": "SafeSearch mode",
            "schema": {
              "type": "string",
              "enum": ["active", "blur", "off"]
            }
          },
          {
            "name": "time_period",
            "in": "query",
            "description": "Date range filtering",
            "schema": { "type": "string" }
          },
          {
            "name": "verbatim",
            "in": "query",
            "description": "Disable query modifications",
            "schema": { "type": "boolean" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Result page number",
            "schema": { "type": "integer" }
          },
          {
            "name": "num",
            "in": "query",
            "description": "Number of results per page (deprecated)",
            "schema": { "type": "integer" }
          },
          {
            "name": "kgmid",
            "in": "query",
            "description": "Knowledge Graph entity identifier",
            "schema": { "type": "string" }
          },
          {
            "name": "optimization_strategy",
            "in": "query",
            "description": "Optimization strategy for results",
            "schema": {
              "type": "string",
              "enum": ["performance", "ads"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": ["Search"]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key passed as query parameter"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as Bearer token"
      }
    },
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "properties": {
          "search_metadata": {
            "$ref": "#/components/schemas/SearchMetadata"
          },
          "search_parameters": {
            "type": "object",
            "description": "Processed search parameters"
          },
          "search_information": {
            "$ref": "#/components/schemas/SearchInformation"
          },
          "knowledge_graph": {
            "type": "object",
            "description": "Knowledge Graph entity information when applicable"
          },
          "organic_results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganicResult"
            }
          },
          "ads": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Ad"
            }
          },
          "local_results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LocalResult"
            }
          },
          "shopping_ads": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "SearchMetadata": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "created_at": { "type": "string" },
          "processed_at": { "type": "string" }
        }
      },
      "SearchInformation": {
        "type": "object",
        "properties": {
          "total_results": { "type": "integer" },
          "time_taken_displayed": { "type": "number" },
          "query_displayed": { "type": "string" }
        }
      },
      "OrganicResult": {
        "type": "object",
        "properties": {
          "position": { "type": "integer" },
          "title": { "type": "string" },
          "link": { "type": "string", "format": "uri" },
          "displayed_link": { "type": "string" },
          "snippet": { "type": "string" },
          "date": { "type": "string" },
          "sitelinks": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "Ad": {
        "type": "object",
        "properties": {
          "position": { "type": "integer" },
          "title": { "type": "string" },
          "link": { "type": "string", "format": "uri" },
          "displayed_link": { "type": "string" },
          "tracking_link": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "LocalResult": {
        "type": "object",
        "properties": {
          "position": { "type": "integer" },
          "title": { "type": "string" },
          "place_id": { "type": "string" },
          "address": { "type": "string" },
          "rating": { "type": "number" },
          "reviews": { "type": "integer" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  },
  "tags": [
    { "name": "Search", "description": "Google search endpoints" }
  ]
}