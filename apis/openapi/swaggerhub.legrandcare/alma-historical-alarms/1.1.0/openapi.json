{
  "openapi": "3.0.0",
  "info": {
    "title": "ALMA Alarm System API",
    "description": "API to manage and retrieve ALMA historical alarms and related metadata",
    "version": "1.1.0",
    "contact": {
      "email": "antonio.palmero@neat-group.com"
    },
    "license": {
      "name": "Legrand care License",
      "url": "https://neat-group.com/content/basicassets/Legrand-Care-API-Program-Terms-and-Conditions_oct-05_2022.pdf"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/LegrandCare/ALMA_HISTORICAL_ALARMS/1.1.0/swagger.json"
  },
  "paths": {
    "/alarms": {
      "get": {
        "operationId": "getHistoricalAlarms",
        "summary": "Retrieve historical alarms with pagination, sorting, and filtering",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "Field to sort by (creation_date, finalizatio_date)",
            "schema": {
              "type": "string",
              "enum": [
                "creation_date",
                "finalization_date"
              ]
            }
          },
          {
            "name": "sort_order",
            "in": "query",
            "description": "Sort order (asc or desc)",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "asc"
            }
          },
          {
            "name": "alarm_state_id",
            "in": "query",
            "description": "Filter by alarm state",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "alarm_hist_state_id",
            "in": "query",
            "description": "Filter by alarm hist state (alive or terminated)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "alarm_type_id",
            "in": "query",
            "description": "Filter by alarm type",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "source_id",
            "in": "query",
            "description": "Filter by alarm type",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "own_alarms",
            "in": "query",
            "description": "Filter by the alarms handled by the logged user",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "creation_rdate",
            "in": "query",
            "description": "Filter alarms created in the relative period defined by the variable.",
            "schema": {
              "type": "string",
              "enum": [
                "Today",
                "Yesterday",
                "Last7days"
              ]
            }
          },
          {
            "name": "creation_start_date",
            "in": "query",
            "description": "Filter alarms created after this date (inclusive). The use of this value is incompatible with the use of parameter creation_rdate. Parameter creation_start_date MUST be used along with parameter creation_end_date.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "creation_end_date",
            "in": "query",
            "description": "Filter alarms created before this date (inclusive).The use of this value is incompatible with the use of parameter creation_rdate. Parameter creation_end_date MUST be used along with parameter creation_start_date.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "finalization_rdate",
            "in": "query",
            "description": "Filter alarms whose last date was in the relative period defined by the variable",
            "schema": {
              "type": "string",
              "enum": [
                "Today",
                "Yesterday",
                "Last7days"
              ]
            }
          },
          {
            "name": "finalization_start_date",
            "in": "query",
            "description": "Filter alarms whose last date was after this date (inclusive). The use of this value is incompatible with the use of parameter finalization_rdate. Parameter finalization_start_date MUST be used along with parameter finalization_end_date.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "finalization_end_date",
            "in": "query",
            "description": "Filter alarms whose last date before this date (inclusive).The use of this value is incompatible with the use of parameter finalization_rdate. Parameter finalization_end_date MUST be used along with parameter finalization_start_date.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "position_id",
            "in": "query",
            "description": "Filter by location",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A pageable list of historical alarms",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlarmsInfo"
                }
              }
            }
          }
        }
      }
    },
    "/alarms/{id}": {
      "get": {
        "operationId": "getAlarmById",
        "summary": "Retrieve detailed information about a specific alarm",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed alarm information including timeline",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlarmDetail"
                }
              }
            }
          }
        }
      }
    },
    "/alarm-states": {
      "get": {
        "operationId": "getAlarmStates",
        "summary": "Retrieve all possible alarm states",
        "responses": {
          "200": {
            "description": "List of alarm states",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlarmState"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/alarm-hist-states": {
      "get": {
        "operationId": "getAlarmHistStates",
        "summary": "Retrieve all possible alarm hist states (alive or terminated)",
        "responses": {
          "200": {
            "description": "List of alarm hist states",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlarmHistState"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/alarm-types": {
      "get": {
        "operationId": "getAlarmTypes",
        "summary": "Retrieve all possible alarm types",
        "responses": {
          "200": {
            "description": "List of alarm types",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlarmType"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/locations": {
      "get": {
        "operationId": "getLocations",
        "summary": "Retrieve all possible locations",
        "responses": {
          "200": {
            "description": "List of locations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Position"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sources": {
      "get": {
        "operationId": "getSources",
        "summary": "Retrieve all possible sources",
        "responses": {
          "200": {
            "description": "List of sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Source"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Alarm": {
        "type": "object",
        "description": "An alarm in the system",
        "properties": {
          "id": {
            "type": "integer",
            "description": "ALMA Alarm identifier. It's unique. It must be the one used in the route /alarms/{id} to obtain the details of the alarm."
          },
          "alarm_id": {
            "type": "integer",
            "description": "DServer alarm identifier. It can be null or 0 under certain circumtances."
          },
          "creation_date": {
            "type": "string",
            "format": "date-time",
            "description": "String in iso8601 format representing the moment the alarm was created in ALMA."
          },
          "finalization_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "String in iso8601 format representing the moment the alarm was removed from ALMA. It can be null"
          },
          "source": {
            "$ref": "#/components/schemas/Source"
          },
          "alarm_type": {
            "$ref": "#/components/schemas/AlarmType"
          },
          "alarm_state": {
            "$ref": "#/components/schemas/AlarmState"
          },
          "hist_state": {
            "$ref": "#/components/schemas/AlarmHistState"
          },
          "priority": {
            "type": "integer",
            "description": "Alarm priority established by DServer"
          },
          "msg_text": {
            "type": "string",
            "description": "Message of the alarm"
          },
          "handlers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            },
            "description": "Users that have accepted the alarm in some point of the life of the alarm"
          },
          "position": {
            "$ref": "#/components/schemas/Position"
          }
        }
      },
      "User": {
        "type": "object",
        "description": "One of the possible handlers of the alarm",
        "properties": {
          "user_id": {
            "type": "integer",
            "description": "Numeric identifier of the User"
          },
          "user_name": {
            "type": "string",
            "description": "Name of the user as it's described in DServer configuration"
          }
        }
      },
      "AlarmDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Alarm"
          },
          {
            "type": "object",
            "properties": {
              "events": {
                "type": "array",
                "description": "Events related to the alarm",
                "items": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          }
        ]
      },
      "Event": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "integer"
          },
          "message_dt": {
            "type": "string",
            "format": "date-time"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          },
          "message": {
            "type": "string"
          },
          "additional_info": {
            "type": "object",
            "description": "A JSON object with variable schema"
          }
        }
      },
      "Role": {
        "type": "object",
        "properties": {
          "role_id": {
            "type": "integer"
          },
          "role_name": {
            "type": "string"
          }
        }
      },
      "Source": {
        "type": "object",
        "description": "Element creating the alarm.",
        "properties": {
          "source_id": {
            "type": "integer",
            "format": "int32",
            "description": "Numeric identifier of the creator of the alarm"
          },
          "source_name": {
            "type": "string",
            "description": "Name of the source as it's included in DServer configuration"
          }
        }
      },
      "AlarmType": {
        "type": "object",
        "description": "Type of alarm.",
        "properties": {
          "source_id": {
            "type": "integer",
            "format": "int32",
            "description": "Numeric identifier of the type of alarm"
          },
          "source_name": {
            "type": "string",
            "description": "Name of the type of alarm as it's included in DServer configuration"
          }
        }
      },
      "AlarmState": {
        "type": "object",
        "description": "Last state of the alarm.",
        "properties": {
          "alarm_state_id": {
            "type": "integer",
            "format": "int32",
            "description": "Numeric identifier of the state"
          },
          "alarm_state": {
            "type": "string",
            "description": "Description of the last state of the alarm."
          }
        }
      },
      "AlarmHistState": {
        "type": "object",
        "description": "Last history state of the alarm. It says if the alarm is alive or not.",
        "properties": {
          "alarm_hist_state_id": {
            "type": "integer",
            "format": "int32",
            "description": "Numeric identifier of the history state",
            "enum": [
              10,
              20,
              30
            ]
          },
          "alarm_hist_state": {
            "type": "string",
            "description": "Description of the last history state of the alarm.",
            "enum": [
              "ALIVE",
              "TERMINATED",
              "ZOMBIE"
            ]
          }
        }
      },
      "Position": {
        "type": "object",
        "description": "Information regarding the location or position of the source of the alarm.",
        "properties": {
          "position_id": {
            "type": "integer",
            "format": "int32",
            "description": "Numeric identifier of the position"
          },
          "position_name": {
            "type": "string",
            "description": "Description of the position of the alarm as it's described in DServer configuration."
          },
          "geo_position": {
            "type": "string",
            "description": "GPS coordinates of the source of the alarm.",
            "nullable": true
          }
        }
      },
      "AlarmsInfo": {
        "type": "object",
        "description": "Alarms obtained after applying the filtering, sorting and paging parameters.",
        "properties": {
          "total_alarms": {
            "type": "integer",
            "description": "Total number of alarms after applying the filtering values."
          },
          "total_pages": {
            "type": "integer",
            "description": "Total number of pages after applying the filtering and paging parameters."
          },
          "current_page": {
            "type": "integer",
            "description": "Page requested"
          },
          "alarms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Alarm"
            }
          }
        }
      }
    }
  }
}