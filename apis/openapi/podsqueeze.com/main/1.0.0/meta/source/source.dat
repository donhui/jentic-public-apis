{
  "openapi": "3.0.3",
  "info": {
    "title": "Podsqueeze API",
    "version": "1.0.0",
    "description": "Podsqueeze is a repurposing tool for podcasters that uses AI to turn episodes into content like transcripts, summaries, and social media posts.",
    "x-jentic-source-url": "https://podsqueeze.com/blog/podsqueeze-api-documentation/"
  },
  "servers": [
    {
      "url": "https://europe-central2-wannabe-entrepreneur.cloudfunctions.net/podsqueeze-api",
      "description": "Podsqueeze API Server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Episodes",
      "description": "Episode processing and management"
    }
  ],
  "paths": {
    "/": {
      "post": {
        "operationId": "processEpisode",
        "summary": "Process Episode",
        "description": "Submit an episode for processing/transcription.",
        "tags": [
          "Episodes"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "mode",
                  "podcastId"
                ],
                "properties": {
                  "mode": {
                    "type": "string",
                    "enum": [
                      "process_episode",
                      "get_job_status",
                      "get_episode_assets",
                      "get_all_episodes_ids"
                    ]
                  },
                  "podcastId": {
                    "type": "string",
                    "description": "Podcast ID"
                  },
                  "languageCode": {
                    "type": "string",
                    "description": "Language code for transcription"
                  },
                  "episodeId": {
                    "type": "string",
                    "description": "Episode ID (for get_job_status and get_episode_assets modes)"
                  },
                  "keys": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Asset keys to retrieve"
                  },
                  "timestamp": {
                    "type": "string",
                    "description": "Filter episodes after this timestamp"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "EpisodeResponse": {
        "type": "object",
        "properties": {
          "episodeId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "episodeTitle": {
            "type": "string"
          },
          "transcript": {
            "type": "string"
          },
          "srt": {
            "type": "string"
          },
          "timestamps": {
            "type": "string"
          },
          "quotes": {
            "type": "string"
          },
          "keywords": {
            "type": "string"
          },
          "bulletPoints": {
            "type": "string"
          },
          "longPost": {
            "type": "string"
          },
          "mentions": {
            "type": "string"
          },
          "newsletter": {
            "type": "string"
          },
          "shortPost": {
            "type": "string"
          },
          "titles": {
            "type": "string"
          },
          "tweets": {
            "type": "string"
          },
          "customPrompts": {
            "type": "object"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}