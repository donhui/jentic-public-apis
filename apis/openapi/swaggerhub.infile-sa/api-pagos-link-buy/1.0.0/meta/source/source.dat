{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "API pagos link&buy",
    "description": "El API dise\u00f1ado facilita la transacci\u00f3n y comunicaci\u00f3n para el pago con visanet",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/INFILE-SA/api-pagos_link_buy/1.0.0/swagger.json"
  },
  "servers": [
