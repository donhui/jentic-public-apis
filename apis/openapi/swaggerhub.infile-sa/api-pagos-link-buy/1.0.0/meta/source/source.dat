      "description": "Servidor de pruebas",
      "url": "https://linkbuy-servicios-dev.infile.com"
    }
  ],
  "tags": [
    {
      "name": "Compras",
      "description": "Es el ingreso de la informaci\u00f3n de la transacci\u00f3n a realizar."
    },
    {
      "name": "Pago",
      "description": "Este servicio es el que realiza el pago de la transacci\u00f3n ya creada."
    },
    {
      "name": "CompraAnular",
      "description": "Anulacion de compras realizadas"
    }
  ],
  "paths": {
    "/api/compras": {
      "post": {
        "tags": [
          "Compras"
        ],
        "summary": "Compra con tarjeta de credito de algun servicio",
        "operationId": "compraServicio",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompraRequest"
              },
              "example": {
                "compra": {
                  "fecha_transaccion": "2024-10-14 11:06:03 -0600",
                  "importe_total": 1.0,
                  "nombre": "nombre-transaccion",
                  "email": "correo@gmail.com",
                  "nit": "123456789",
                  "nombre_entrega": "nombre-transaccion",
                  "titulo_compra": "Compra de membresia mensual youtube plus",
                  "descripcion_compra": "Compra de Pruebas",
                  "codigo_referencia_cliente": "",
                  "llave_uso_api": "******* Aqui debe ingresar la llave que se le asigo no INFILE.S.A *******",
                  "url_respuesta": "https://webhook.site/2dbda0fd-420c-48f9-b1f0-a3c095600b8e",
                  "enviar_correo": 0,
                  "detalles": [
                    {
                      "cantidad": 1,
                      "producto": "Membresia mensual youtube plus",
                      "descripcion": "Membresia mensual youtube plus",
                      "codigo_referencia_producto": "10017",
                      "precio_unitario": 0.5,
                      "precio": 0.5
                    },
                    {
                      "cantidad": 1,
                      "producto": "Membresia mensual youtube plus",
                      "descripcion": "Membresia mensual youtube plus",
                      "codigo_referencia_producto": "10017",
                      "precio_unitario": 0.5,
                      "precio": 0.5
                    }
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "La compra fue exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompraResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "No autorizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCompra401"
                }
              }
            }
          },
          "404": {
            "description": "Recurso no encontrado"
          },
          "422": {
            "description": "Contenido no procesable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCompra422"
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor"
          }
        },
        "security": [
          {
            "UsuarioApi": []
          },
          {
            "LlaveApi": []
          }
        ]
      }
    },
    "/api/pagos": {
      "post": {
        "tags": [
          "Pago"
        ],
        "summary": "Pago de la compra",
        "operationId": "pagoServicio",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PagoRequest"
              },
              "example": {
                "pago": {
                  "codigo_transaccion": "***** Debe ingresar el codigo de transaccion de la compra que se realizo ******",
                  "numero_tarjeta": "4000000000000416",
                  "nombre_tarjeta": "NOMBRE",
                  "importe_total": 1.0,
                  "mes_expiracion": "11",
                  "anio_expiracion": "2024",
                  "cvv": "123"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "El pago fue exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagoResponse"
                }
              }
            }
          },
          "200": {
            "description": "Error en el pago",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagoRespuestaNoValida"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "No autorizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorPago401"
                }
              }
            }
          },
          "404": {
            "description": "Recurso no encontrado"
          },
          "422": {
            "description": "Contenido no procesable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorPago422"
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor"
          }
        },
        "security": [
          {
            "UsuarioApi": []
          },
          {
            "LlaveApi": []
          }
        ]
      }
    },
    "/api/compras/anular": {
      "post": {
        "tags": [
          "CompraAnular"
        ],
        "summary": "Anulacion de compras",
        "operationId": "anularServicio",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompraAnularRequest"
              },
              "example": {
                "compra": {
                  "codigo_transaccion": "***** Debe ingresar el codigo de transaccion de la compra realizada *****"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compra anulada correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompraAnularResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCompraAnular400"
                }
              }
            }
          },
          "401": {
            "description": "El Acceso es denegado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorCompraAnular401"
                }
              }
            }
          },
          "404": {
            "description": "Recurso no encontrado"
          },
          "500": {
            "description": "Error interno del servidor"
          }
        },
        "security": [
          {
            "UsuarioApi": []
          },
          {
            "LlaveApi": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "UsuarioApi": {
        "type": "apiKey",
        "in": "header",
        "name": "usuario-api"
      },
      "LlaveApi": {
        "type": "apiKey",
        "in": "header",
        "name": "llave-api"
      }
    },
    "schemas": {
      "CompraRequest": {
        "type": "object",
        "required": [
          "compra"
        ],
        "properties": {
          "compra": {
            "type": "object",
            "required": [
              "fecha_transaccion",
              "importe_total",
              "nombre",
              "email",
              "nit",
              "titulo_compra",
              "descripcion_compra",
              "codigo_referencia_cliente",
              "llave_uso_api",
              "enviar_correo",
              "detalles"
            ],
            "description": "Detalles de la compra realizada por el cliente.",
            "properties": {
              "fecha_transaccion": {
                "type": "string",
                "format": "date-time",
                "description": "Fecha y hora en que se realiz\u00f3 la transacci\u00f3n de la compra."
              },
              "importe_total": {
                "type": "number",
                "description": "Monto total de la compra en la moneda correspondiente."
              },
              "nombre": {
                "type": "string",
                "description": "Nombre del cliente que realiza la compra."
              },
              "email": {
                "type": "string",
                "description": "Correo electr\u00f3nico del cliente para recibir confirmaciones y notificaciones."
              },
              "nit": {
                "type": "string",
                "description": "N\u00famero de Identificaci\u00f3n Tributaria (NIT) del cliente."
              },
              "nombre_entrega": {
                "type": "string",
                "description": "Nombre de la persona que recibir\u00e1 el producto o servicio puede ser el mismo del campo nombre."
              },
              "titulo_compra": {
                "type": "string",
                "description": "T\u00edtulo o nombre de la compra, generalmente relacionado con el producto o servicio."
              },
              "descripcion_compra": {
                "type": "string",
                "description": "Descripci\u00f3n detallada del producto o servicio comprado."
              },
              "codigo_referencia_cliente": {
                "type": "string",
                "description": "C\u00f3digo de referencia asignado por el cliente para identificar la transacci\u00f3n."
              },
              "llave_uso_api": {
                "type": "string",
                "description": "Llave utilizada para autenticar el uso de la API asignada por INFILE.S.A ."
              },
              "url_respuesta": {
                "type": "string",
                "description": "URL a la que se enviar\u00e1 la respuesta del estado de la transacci\u00f3n."
              },
              "enviar_correo": {
                "type": "integer",
                "description": "Indica si se debe enviar un correo electr\u00f3nico de confirmaci\u00f3n (1 para s\u00ed, 0 para no), si es 0 el campo de correo si es necesario"
              },
              "detalles": {
                "type": "array",
                "description": "Lista de productos o servicios incluidos en la compra.",
                "items": {
                  "type": "object",
                  "required": [
                    "cantidad",
                    "producto",
                    "descripcion",
                    "codigo_referencia_producto",
                    "precio_unitario",
                    "precio"
                  ],
                  "properties": {
                    "cantidad": {
                      "type": "integer",
                      "description": "Cantidad del producto o servicio comprado."
                    },
                    "producto": {
                      "type": "string",
                      "description": "Nombre del producto o servicio comprado."
                    },
                    "descripcion": {
                      "type": "string",
                      "description": "Descripci\u00f3n adicional del producto o servicio."
                    },
                    "codigo_referencia_producto": {
                      "type": "string",
                      "description": "C\u00f3digo de referencia del producto proporcionado por el cliente o proveedor."
                    },
                    "precio_unitario": {
                      "type": "number",
                      "description": "Precio unitario del producto o servicio."
                    },
                    "precio": {
                      "type": "number",
                      "description": "Precio total para el producto o servicio seg\u00fan la cantidad comprada."
                    }
                  }
                }
              }
            }
          }
        }
      },
      "PagoRequest": {
        "type": "object",
        "required": [
          "pago"
        ],
        "properties": {
          "pago": {
            "type": "object",
            "required": [
              "codigo_transaccion",
              "numero_tarjeta",
              "nombre_tarjeta",
              "importe_total",
              "mes_expiracion",
              "anio_expiracion",
              "cvv"
            ],
            "description": "Informaci\u00f3n detallada del pago realizado con tarjeta.",
            "properties": {
              "codigo_transaccion": {
                "type": "string",
                "description": "C\u00f3digo \u00fanico de identificaci\u00f3n de la transacci\u00f3n de pago."
              },
              "numero_tarjeta": {
                "type": "string",
                "description": "N\u00famero de la tarjeta de cr\u00e9dito o d\u00e9bito utilizada para realizar el pago."
              },
              "nombre_tarjeta": {
                "type": "string",
                "description": "Nombre del titular de la tarjeta tal como aparece en la tarjeta."
              },
              "importe_total": {
                "type": "number",
                "description": "Monto total que se est\u00e1 pagando con la tarjeta."
              },
              "mes_expiracion": {
                "type": "string",
                "description": "Mes de expiraci\u00f3n de la tarjeta en formato MM."
              },
              "anio_expiracion": {
                "type": "string",
                "description": "A\u00f1o de expiraci\u00f3n de la tarjeta en formato YY o YYYY."
              },
              "cvv": {
                "type": "string",
                "description": "C\u00f3digo de seguridad de la tarjeta, tambi\u00e9n conocido como CVV o CVC, generalmente un n\u00famero de 3 o 4 d\u00edgitos."
              }
            }
          }
        }
      },
      "CompraAnularRequest": {
        "type": "object",
        "required": [
          "compra"
        ],
        "description": "En esta seccion podra anular el pago de algo servicio",
        "properties": {
          "compra": {
            "type": "object",
            "required": [
              "codigo_transaccion"
            ],
            "properties": {
              "codigo_transaccion": {
                "type": "string",
                "description": "C\u00f3digo \u00fanico de identificaci\u00f3n de la transacci\u00f3n de pago."
              }
            }
          }
        }
      },
      "CompraResponse": {
        "type": "object",
        "description": "Respuesta de la API para una compra realizada, con los detalles de la transacci\u00f3n y los productos adquiridos.",
        "properties": {
          "resultado": {
            "type": "boolean",
            "description": "Indica si la transacci\u00f3n fue exitosa.",
            "example": true
          },
          "compra": {
            "type": "object",
            "description": "Informaci\u00f3n detallada de la compra.",
            "properties": {
              "id": {
                "type": "integer",
                "description": "Identificador \u00fanico de la compra.",
                "example": 46080
              },
              "empresa_id": {
                "type": "integer",
                "description": "Identificador \u00fanico de la empresa que realiza la transacci\u00f3n.",
                "example": 320
              },
              "cliente_id": {
                "type": "integer",
                "description": "Identificador \u00fanico del cliente que realiz\u00f3 la compra.",
                "example": 11200
              },
              "fecha_transaccion": {
                "type": "string",
                "format": "date-time",
                "description": "Fecha y hora en que se realiz\u00f3 la transacci\u00f3n.",
                "example": "2024-10-14T14:45:11.034-06:00"
              },
              "codigo_transaccion": {
                "type": "string",
                "description": "C\u00f3digo \u00fanico asignado a la transacci\u00f3n.",
                "example": "285e617908891ae7794fb158947b5d20fcd1fd1515fcf891a0f4803d35e52955"
              },
              "codigo_transaccion_cliente": {
                "type": "string",
                "description": "C\u00f3digo de referencia de la transacci\u00f3n por parte del cliente.",
                "example": ""
              },
              "nombre_entrega": {
                "type": "string",
                "description": "Nombre del destinatario para la entrega del producto o servicio.",
                "example": "nombre"
              },
              "direccion_entrega": {
                "type": "string",
                "nullable": true,
                "description": "Direcci\u00f3n de entrega, si es aplicable.",
                "example": null
              },
              "telefono_entrega": {
                "type": "string",
                "nullable": true,
                "description": "N\u00famero de tel\u00e9fono del destinatario.",
                "example": null
              },
              "comentario_entrega": {
                "type": "string",
                "nullable": true,
                "description": "Comentarios adicionales sobre la entrega.",
                "example": null
              },
              "ip": {
                "type": "string",
                "description": "Direcci\u00f3n IP del cliente que realiz\u00f3 la transacci\u00f3n.",
                "example": "190.61.5.34,54.208.143.244"
              },
              "estado": {
                "type": "string",
                "description": "Estado actual de la compra.",
                "example": "Enviado"
              },
              "titulo_compra": {
                "type": "string",
                "description": "T\u00edtulo o nombre de la compra realizada.",
                "example": "Compra de membresia mensual youtube plus"
              },
              "descripcion_compra": {
                "type": "string",
                "description": "Descripci\u00f3n detallada de la compra.",
                "example": "Compra de Pruebas"
              },
              "importe_total": {
                "type": "number",
                "description": "Importe total de la compra.",
                "example": 1
              },
              "created_at": {
                "type": "string",
                "format": "date-time",
                "description": "Fecha y hora de creaci\u00f3n de la compra.",
                "example": "2024-10-14T14:45:11.042-06:00"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time",
                "description": "Fecha y hora de la \u00faltima actualizaci\u00f3n de la compra.",
                "example": "2024-10-14T14:45:11.076-06:00"
              },
              "empresa_pasarela_id": {
                "type": "integer",
                "description": "Identificador de la empresa encargada de procesar el pago.",
                "example": 560
              },
              "origen": {
                "type": "string",
                "description": "Origen de la transacci\u00f3n, como \"API\".",
                "example": "API"
              },
              "fecha_envio_correo": {
                "type": "string",
                "format": "date-time",
                "description": "Fecha y hora en que se envi\u00f3 el correo de confirmaci\u00f3n.",
                "example": "2024-10-14T14:45:11.075-06:00"
              },
              "tipo": {
                "type": "string",
                "description": "Tipo de transacci\u00f3n, como \"Compra\".",
                "example": "Compra"
              },
              "url_respuesta": {
                "type": "string",
                "description": "URL a la que se debe enviar la respuesta de la transacci\u00f3n.",
                "example": "https://webhook.site/2dbda0fd-420c-48f9-b1f0-a3c095600b8e"
              },
              "cuotas": {
                "type": "integer",
                "description": "N\u00famero de cuotas en las que se dividir\u00e1 el pago.",
                "example": 0
              },
              "forma_pago": {
                "type": "string",
                "description": "M\u00e9todo de pago utilizado en la compra.",
                "example": "Ambos"
              },
              "fecha_pagos_limite": {
                "type": "string",
                "nullable": true,
                "description": "Fecha l\u00edmite para los pagos, si es aplicable.",
                "example": null
              },
              "cantidad_pagos_limite": {
                "type": "string",
                "nullable": true,
                "description": "Cantidad de pagos permitidos hasta la fecha l\u00edmite.",
                "example": null
              },
              "aplicar_cantidad_pagos_limite": {
                "type": "boolean",
                "description": "Indica si se debe aplicar un l\u00edmite a la cantidad de pagos.",
                "example": false
              },
              "aplicar_fecha_pagos_limite": {
                "type": "boolean",
                "description": "Indica si se debe aplicar una fecha l\u00edmite para los pagos.",
                "example": false
              },
              "enviar_correo": {
                "type": "boolean",
                "description": "Indica si se debe enviar un correo de confirmaci\u00f3n al cliente.",
                "example": false
              },
              "indicar_datos_entrega": {
                "type": "boolean",
                "description": "Indica si se deben solicitar datos de entrega al cliente.",
                "example": false
              },
              "seleccionar_cuotas": {
                "type": "boolean",
                "description": "Indica si el cliente seleccion\u00f3 la opci\u00f3n de cuotas.",
                "example": true
              },
              "folio": {
                "type": "string",
                "nullable": true,
                "description": "N\u00famero de folio asociado a la transacci\u00f3n.",
                "example": null
              }
            }
          },
          "detalle": {
            "type": "array",
            "description": "Lista de productos o servicios adquiridos en la compra.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "description": "Identificador \u00fanico del detalle de compra.",
                  "example": 47240
                },
                "empresa_id": {
                  "type": "integer",
                  "description": "Identificador \u00fanico de la empresa que ofrece el producto.",
                  "example": 320
                },
                "compra_id": {
                  "type": "integer",
                  "description": "Identificador \u00fanico de la compra asociada.",
                  "example": 46080
                },
                "cantidad": {
                  "type": "integer",
                  "description": "Cantidad adquirida del producto o servicio.",
                  "example": 1
                },
                "descripcion": {
                  "type": "string",
                  "description": "Descripci\u00f3n del producto o servicio adquirido.",
                  "example": "Membresia mensual youtube plus"
                },
                "precio_unitario": {
                  "type": "number",
                  "description": "Precio unitario del producto o servicio.",
                  "example": 0.5
                },
                "codigo_referencia": {
                  "type": "string",
                  "nullable": true,
                  "description": "C\u00f3digo de referencia del producto, si es aplicable.",
                  "example": null
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Fecha y hora en que se cre\u00f3 el detalle de compra.",
                  "example": "2024-10-14T14:45:11.055-06:00"
                },
                "updated_at": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Fecha y hora en que se actualiz\u00f3 el detalle de compra.",
                  "example": "2024-10-14T14:45:11.055-06:00"
                },
                "producto": {
                  "type": "string",
                  "description": "Nombre del producto o servicio adquirido.",
                  "example": "Membresia mensual youtube plus"
                },
                "producto_id": {
                  "type": "string",
                  "nullable": true,
                  "description": "Identificador \u00fanico del producto, si es aplicable.",
                  "example": null
                },
                "precio": {
                  "type": "number",
                  "description": "Precio total del producto o servicio adquirido.",
