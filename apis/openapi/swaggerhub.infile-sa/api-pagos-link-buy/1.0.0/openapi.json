      "PagoRequest": {
        "type": "object",
        "required": [
          "pago"
        ],
        "properties": {
          "pago": {
            "type": "object",
            "required": [
              "codigo_transaccion",
              "numero_tarjeta",
              "nombre_tarjeta",
              "importe_total",
              "mes_expiracion",
              "anio_expiracion",
              "cvv"
