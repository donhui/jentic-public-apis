              },
              "cvv": {
                "type": "string",
                "description": "Código de seguridad de la tarjeta, también conocido como CVV o CVC, generalmente un número de 3 o 4 dígitos."
              }
            }
          }
        }
      },
      "CompraAnularRequest": {
        "type": "object",
