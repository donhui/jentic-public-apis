                      "cantidad": 1,
                      "producto": "Membresia mensual youtube plus",
                      "descripcion": "Membresia mensual youtube plus",
                      "codigo_referencia_producto": "10017",
                      "precio_unitario": 0.5,
                      "precio": 0.5
                    },
                    {
                      "cantidad": 1,
                      "producto": "Membresia mensual youtube plus",
                      "descripcion": "Membresia mensual youtube plus",
                      "codigo_referencia_producto": "10017",
                      "precio_unitario": 0.5,
                      "precio": 0.5
                    }
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "La compra fue exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompraResponse"
