    "schemas": {
      "CompraRequest": {
        "type": "object",
        "required": [
          "compra"
        ],
        "properties": {
          "compra": {
            "type": "object",
            "required": [
              "fecha_transaccion",
              "importe_total",
              "nombre",
              "email",
              "nit",
              "titulo_compra",
              "descripcion_compra",
              "codigo_referencia_cliente",
              "llave_uso_api",
              "enviar_correo",
              "detalles"
            ],
            "description": "Detalles de la compra realizada por el cliente.",
            "properties": {
              "fecha_transaccion": {
                "type": "string",
                "format": "date-time",
                "description": "Fecha y hora en que se realizó la transacción de la compra."
              },
              "importe_total": {
                "type": "number",
                "description": "Monto total de la compra en la moneda correspondiente."
              },
              "nombre": {
                "type": "string",
                "description": "Nombre del cliente que realiza la compra."
              },
              "email": {
                "type": "string",
                "description": "Correo electrónico del cliente para recibir confirmaciones y notificaciones."
              },
              "nit": {
                "type": "string",
                "description": "Número de Identificación Tributaria (NIT) del cliente."
              },
              "nombre_entrega": {
                "type": "string",
                "description": "Nombre de la persona que recibirá el producto o servicio puede ser el mismo del campo nombre."
              },
              "titulo_compra": {
                "type": "string",
                "description": "Título o nombre de la compra, generalmente relacionado con el producto o servicio."
              },
              "descripcion_compra": {
                "type": "string",
                "description": "Descripción detallada del producto o servicio comprado."
              },
              "codigo_referencia_cliente": {
                "type": "string",
                "description": "Código de referencia asignado por el cliente para identificar la transacción."
              },
              "llave_uso_api": {
                "type": "string",
                "description": "Llave utilizada para autenticar el uso de la API asignada por INFILE.S.A ."
              },
              "url_respuesta": {
                "type": "string",
                "description": "URL a la que se enviará la respuesta del estado de la transacción."
              },
              "enviar_correo": {
                "type": "integer",
                "description": "Indica si se debe enviar un correo electrónico de confirmación (1 para sí, 0 para no), si es 0 el campo de correo si es necesario"
              },
              "detalles": {
                "type": "array",
                "description": "Lista de productos o servicios incluidos en la compra.",
                "items": {
                  "type": "object",
                  "required": [
                    "cantidad",
                    "producto",
                    "descripcion",
                    "codigo_referencia_producto",
                    "precio_unitario",
                    "precio"
                  ],
                  "properties": {
                    "cantidad": {
                      "type": "integer",
                      "description": "Cantidad del producto o servicio comprado."
                    },
                    "producto": {
                      "type": "string",
                      "description": "Nombre del producto o servicio comprado."
                    },
                    "descripcion": {
                      "type": "string",
                      "description": "Descripción adicional del producto o servicio."
                    },
                    "codigo_referencia_producto": {
                      "type": "string",
                      "description": "Código de referencia del producto proporcionado por el cliente o proveedor."
                    },
                    "precio_unitario": {
                      "type": "number",
                      "description": "Precio unitario del producto o servicio."
                    },
                    "precio": {
                      "type": "number",
                      "description": "Precio total para el producto o servicio según la cantidad comprada."
                    }
