{
    "openapi": "3.0.0",
    "info": {
        "description": "Servicio API para la consulta de los datos de receptor.\n",
        "version": "1.0.0",
        "title": "API Consulta receptores",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/INFILE-SA/API_CONSULTA_RECEPTORES/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "receptor",
            "description": "Realiza la consulta en base al nit para obtener los datos de receptor.",
            "externalDocs": {
                "description": "Find out more",
                "url": "http://swagger.io"
            }
        }
    ],
    "paths": {
        "/rest/action": {
            "post": {
                "tags": [
                    "receptor"
                ],
                "summary": "Solicitud para la obtención de datos de receptor.",
                "description": "Solicitud para la obtención de datos de receptor.",
                "operationId": "consultaReceptor",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Consulta"
                            }
                        }
                    },
                    "description": "JSON con los datos de consulta principal como lo es, emisor, clave y nit",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "La comunicación fue exitosa. Esto indica que la petición se recibió, revisó y validó. Si la consulta con los datos proporcionados es exitosa y concuerda con datos válidos, se devolverán los datos de receptor. En caso contrario, se proporcionará un detalle de cada error encontrado durante la validación.",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "response": {
                                        "value": {
                                            "nit": "376429925",
                                            "nombre": "ERICK ARMANDO PÉREZ CHÁVEZ",
                                            "mensaje": ""
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/INFILE-SA/API_CONSULTA_RECEPTORES/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "Consulta": {
                "type": "object",
                "properties": {
                    "emisor_codigo": {
                        "type": "string",
                        "format": "string",
                        "example": "ITDEMO"
                    },
                    "emisor_clave": {
                        "type": "string",
                        "format": "string",
                        "example": "76A930503C7647C4B07FC74B28595J56"
                    },
                    "nit_consulta": {
                        "type": "string",
                        "format": "string",
                        "example": "376429925K"
                    }
                }
            }
        }
    }
}