{
  "openapi": "3.0.3",
  "info": {
    "title": "iyzico Payment API",
    "description": "iyzico payment processing API supporting non-3DS and 3DS payment flows for merchants in Turkey and international markets.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.iyzico.com/en/payment-methods/api/non-3ds/non-3ds-implementation/create-payment"
  },
  "servers": [
    {
      "url": "https://api.iyzipay.com",
      "description": "Production server"
    },
    {
      "url": "https://sandbox-api.iyzipay.com",
      "description": "Sandbox server"
    }
  ],
  "paths": {
    "/payment/auth": {
      "post": {
        "operationId": "createNon3DSPayment",
        "summary": "Create Non-3DS Payment",
        "description": "Process a non-3DS payment transaction. Charges the buyer's card without 3D Secure verification.",
        "tags": ["Payments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment processed successfully or with failure details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing authorization header",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "iyzicoAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CreatePaymentRequest": {
        "type": "object",
        "required": ["price", "paidPrice", "currency", "paymentCard", "buyer", "shippingAddress", "billingAddress", "basketItems"],
        "properties": {
          "locale": {
            "type": "string",
            "description": "Language locale (e.g., tr, en)"
          },
          "conversationId": {
            "type": "string",
            "description": "Unique conversation ID for request tracking"
          },
          "price": {
            "type": "string",
            "description": "Total basket price"
          },
          "paidPrice": {
            "type": "string",
            "description": "Amount charged to buyer"
          },
          "currency": {
            "type": "string",
            "enum": ["TRY", "USD", "EUR", "GBP", "NOK", "CHF"],
            "description": "Transaction currency"
          },
          "installment": {
            "type": "integer",
            "description": "Number of installments (1 for single payment)"
          },
          "basketId": {
            "type": "string",
            "description": "Basket/order identifier"
          },
          "paymentChannel": {
            "type": "string",
            "description": "Payment channel"
          },
          "paymentGroup": {
            "type": "string",
            "enum": ["PRODUCT", "LISTING", "SUBSCRIPTION"],
            "description": "Payment group type"
          },
          "paymentCard": {
            "$ref": "#/components/schemas/PaymentCard"
          },
          "buyer": {
            "$ref": "#/components/schemas/Buyer"
          },
          "shippingAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "billingAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "basketItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BasketItem"
            }
          }
        }
      },
      "PaymentCard": {
        "type": "object",
        "required": ["cardHolderName", "cardNumber", "expireYear", "expireMonth", "cvc"],
        "properties": {
          "cardHolderName": {
            "type": "string",
            "description": "Name on the card"
          },
          "cardNumber": {
            "type": "string",
            "description": "Card number"
          },
          "expireYear": {
            "type": "string",
            "description": "Card expiry year"
          },
          "expireMonth": {
            "type": "string",
            "description": "Card expiry month"
          },
          "cvc": {
            "type": "string",
            "description": "Card verification code"
          },
          "registerCard": {
            "type": "integer",
            "description": "Set to 1 to save the card"
          }
        }
      },
      "Buyer": {
        "type": "object",
        "required": ["id", "name", "surname", "identityNumber", "email", "registrationAddress", "city", "country"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Buyer ID"
          },
          "name": {
            "type": "string",
            "description": "Buyer first name"
          },
          "surname": {
            "type": "string",
            "description": "Buyer last name"
          },
          "identityNumber": {
            "type": "string",
            "description": "Buyer identity number"
          },
          "email": {
            "type": "string",
            "description": "Buyer email address"
          },
          "gsmNumber": {
            "type": "string",
            "description": "Buyer phone number"
          },
          "registrationDate": {
            "type": "string",
            "description": "Buyer registration date"
          },
          "lastLoginDate": {
            "type": "string",
            "description": "Buyer last login date"
          },
          "registrationAddress": {
            "type": "string",
            "description": "Registration address"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "country": {
            "type": "string",
            "description": "Country"
          },
          "ip": {
            "type": "string",
            "description": "Buyer IP address"
          }
        }
      },
      "Address": {
        "type": "object",
        "required": ["address", "contactName", "city", "country"],
        "properties": {
          "address": {
            "type": "string",
            "description": "Full address"
          },
          "contactName": {
            "type": "string",
            "description": "Contact name"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "country": {
            "type": "string",
            "description": "Country"
          },
          "zipCode": {
            "type": "string",
            "description": "Postal code"
          }
        }
      },
      "BasketItem": {
        "type": "object",
        "required": ["id", "price", "name", "category1", "itemType"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Item ID"
          },
          "price": {
            "type": "string",
            "description": "Item price"
          },
          "name": {
            "type": "string",
            "description": "Item name"
          },
          "category1": {
            "type": "string",
            "description": "Primary category"
          },
          "category2": {
            "type": "string",
            "description": "Secondary category"
          },
          "itemType": {
            "type": "string",
            "enum": ["PHYSICAL", "VIRTUAL"],
            "description": "Item type"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "failure"],
            "description": "Payment status"
          },
          "locale": {
            "type": "string",
            "description": "Response locale"
          },
          "systemTime": {
            "type": "integer",
            "format": "int64",
            "description": "System timestamp"
          },
          "conversationId": {
            "type": "string",
            "description": "Conversation ID from request"
          },
          "paymentId": {
            "type": "string",
            "description": "Payment identifier"
          },
          "price": {
            "type": "number",
            "description": "Total price"
          },
          "paidPrice": {
            "type": "number",
            "description": "Amount paid"
          },
          "currency": {
            "type": "string",
            "description": "Transaction currency"
          },
          "installment": {
            "type": "integer",
            "description": "Number of installments"
          },
          "fraudStatus": {
            "type": "integer",
            "description": "Fraud check status"
          },
          "cardType": {
            "type": "string",
            "description": "Card type (CREDIT_CARD, DEBIT_CARD)"
          },
          "cardAssociation": {
            "type": "string",
            "description": "Card association (VISA, MASTER_CARD, etc.)"
          },
          "cardFamily": {
            "type": "string",
            "description": "Card family name"
          },
          "binNumber": {
            "type": "string",
            "description": "Card BIN number"
          },
          "lastFourDigits": {
            "type": "string",
            "description": "Last 4 digits of card"
          },
          "itemTransactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemTransaction"
            }
          },
          "errorCode": {
            "type": "string",
            "description": "Error code if payment failed"
          },
          "errorMessage": {
            "type": "string",
            "description": "Error message if payment failed"
          },
          "errorGroup": {
            "type": "string",
            "description": "Error group classification"
          }
        }
      },
      "ItemTransaction": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "string",
            "description": "Basket item ID"
          },
          "paymentTransactionId": {
            "type": "string",
            "description": "Transaction ID for this item"
          },
          "transactionStatus": {
            "type": "integer",
            "description": "Transaction status"
          },
          "price": {
            "type": "number",
            "description": "Item price"
          },
          "paidPrice": {
            "type": "number",
            "description": "Paid price for item"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["failure"]
          },
          "errorCode": {
            "type": "string",
            "description": "Error code"
          },
          "errorMessage": {
            "type": "string",
            "description": "Error message"
          },
          "errorGroup": {
            "type": "string",
            "description": "Error group"
          },
          "locale": {
            "type": "string"
          },
          "systemTime": {
            "type": "integer",
            "format": "int64"
          },
          "conversationId": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "iyzicoAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "IYZWSv2 authorization header with base64-encoded signed hash value"
      }
    }
  },
  "security": [
    {
      "iyzicoAuth": []
    }
  ]
}