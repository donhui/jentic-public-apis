{
  "openapi": "3.0.3",
  "info": {
    "title": "iyzico Payment API",
    "description": "iyzico Non-3DS Payment API for creating and managing payment transactions.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.iyzico.com/en/payment-methods/api/non-3ds/non-3ds-implementation/create-payment"
  },
  "servers": [
    {
      "url": "https://api.iyzipay.com",
      "description": "Production server"
    },
    {
      "url": "https://sandbox-api.iyzipay.com",
      "description": "Sandbox server"
    }
  ],
  "paths": {
    "/payment/auth": {
      "post": {
        "operationId": "createpayment",
        "summary": "Create a Non-3DS Payment",
        "description": "Creates a payment transaction without 3DS verification.",
        "tags": [
          "Payments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment processed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "iyzico_auth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CreatePaymentRequest": {
        "type": "object",
        "required": [
          "paidPrice",
          "price",
          "paymentCard",
          "buyer",
          "billingAddress",
          "basketItems"
        ],
        "properties": {
          "locale": {
            "type": "string",
            "enum": [
              "tr",
              "en"
            ],
            "description": "Language code"
          },
          "conversationId": {
            "type": "string",
            "description": "Request/response matching identifier"
          },
          "price": {
            "type": "string",
            "description": "Basket total amount"
          },
          "paidPrice": {
            "type": "string",
            "description": "Total charge amount including installment fees"
          },
          "currency": {
            "type": "string",
            "enum": [
              "TRY",
              "USD",
              "EUR",
              "GBP",
              "NOK",
              "CHF"
            ],
            "description": "Payment currency"
          },
          "installment": {
            "type": "integer",
            "enum": [
              1,
              2,
              3,
              6,
              9,
              12
            ],
            "description": "Number of installments"
          },
          "basketId": {
            "type": "string",
            "description": "Basket identifier"
          },
          "paymentChannel": {
            "type": "string",
            "enum": [
              "WEB",
              "MOBILE",
              "MOBILE_WEB",
              "MOBILE_IOS",
              "MOBILE_ANDROID",
              "MOBILE_WINDOWS",
              "MOBILE_TABLET",
              "MOBILE_PHONE"
            ],
            "description": "Payment channel"
          },
          "paymentGroup": {
            "type": "string",
            "enum": [
              "PRODUCT",
              "LISTING",
              "SUBSCRIPTION"
            ],
            "description": "Payment group type"
          },
          "paymentCard": {
            "$ref": "#/components/schemas/PaymentCard"
          },
          "buyer": {
            "$ref": "#/components/schemas/Buyer"
          },
          "shippingAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "billingAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "basketItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BasketItem"
            }
          }
        }
      },
      "PaymentCard": {
        "type": "object",
        "required": [
          "cardHolderName",
          "cardNumber",
          "expireMonth",
          "expireYear",
          "cvc"
        ],
        "properties": {
          "cardHolderName": {
            "type": "string"
          },
          "cardNumber": {
            "type": "string"
          },
          "expireMonth": {
            "type": "string"
          },
          "expireYear": {
            "type": "string"
          },
          "cvc": {
            "type": "string"
          },
          "registerCard": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          },
          "cardAlias": {
            "type": "string"
          },
          "cardToken": {
            "type": "string"
          },
          "cardUserKey": {
            "type": "string"
          }
        }
      },
      "Buyer": {
        "type": "object",
        "required": [
          "id",
          "name",
          "surname",
          "identityNumber",
          "email",
          "registrationAddress",
          "city",
          "country"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "surname": {
            "type": "string"
          },
          "identityNumber": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "gsmNumber": {
            "type": "string"
          },
          "registrationDate": {
            "type": "string"
          },
          "lastLoginDate": {
            "type": "string"
          },
          "registrationAddress": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "zipCode": {
            "type": "string"
          },
          "ip": {
            "type": "string"
          }
        }
      },
      "Address": {
        "type": "object",
        "required": [
          "contactName",
          "city",
          "country",
          "address"
        ],
        "properties": {
          "contactName": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "zipCode": {
            "type": "string"
          }
        }
      },
      "BasketItem": {
        "type": "object",
        "required": [
          "id",
          "name",
          "category1",
          "itemType",
          "price"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category1": {
            "type": "string"
          },
          "category2": {
            "type": "string"
          },
          "itemType": {
            "type": "string",
            "enum": [
              "PHYSICAL",
              "VIRTUAL"
            ]
          },
          "price": {
            "type": "string"
          },
          "subMerchantKey": {
            "type": "string",
            "description": "Sub-merchant key for marketplace payments"
          },
          "subMerchantPrice": {
            "type": "string",
            "description": "Sub-merchant price for marketplace payments"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failure"
            ]
          },
          "locale": {
            "type": "string"
          },
          "systemTime": {
            "type": "integer",
            "format": "int64"
          },
          "conversationId": {
            "type": "string"
          },
          "paymentId": {
            "type": "string"
          },
          "fraudStatus": {
            "type": "integer",
            "description": "1: approved, 0: pending, -1: rejected"
          },
          "price": {
            "type": "number"
          },
          "paidPrice": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "installment": {
            "type": "integer"
          },
          "basketId": {
            "type": "string"
          },
          "binNumber": {
            "type": "string"
          },
          "lastFourDigits": {
            "type": "string"
          },
          "cardType": {
            "type": "string"
          },
          "cardAssociation": {
            "type": "string"
          },
          "cardFamily": {
            "type": "string"
          },
          "itemTransactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemTransaction"
            }
          },
          "errorCode": {
            "type": "string"
          },
          "errorMessage": {
            "type": "string"
          },
          "errorGroup": {
            "type": "string"
          },
          "authCode": {
            "type": "string",
            "description": "Authorization code from the bank"
          },
          "hostReference": {
            "type": "string",
            "description": "Host reference number"
          },
          "signature": {
            "type": "string",
            "description": "Response signature"
          }
        }
      },
      "ItemTransaction": {
        "type": "object",
        "properties": {
          "itemId": {
            "type": "string"
          },
          "paymentTransactionId": {
            "type": "string"
          },
          "transactionStatus": {
            "type": "integer"
          },
          "price": {
            "type": "number"
          },
          "paidPrice": {
            "type": "number"
          },
          "merchantCommissionRate": {
            "type": "number"
          },
          "merchantCommissionRateAmount": {
            "type": "number"
          },
          "iyziCommissionRateAmount": {
            "type": "number"
          },
          "iyziCommissionFee": {
            "type": "number"
          },
          "blockageRate": {
            "type": "number"
          },
          "blockageRateAmountMerchant": {
            "type": "number"
          },
          "merchantPayoutAmount": {
            "type": "number"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "iyzico_auth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "IYZWSv2 signed authorization header with base64-encoded hash"
      }
    }
  },
  "security": [
    {
      "iyzico_auth": []
    }
  ],
  "tags": [
    {
      "name": "Payments",
      "description": "Operations related to Payments"
    }
  ]
}