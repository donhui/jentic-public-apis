  "info": {
    "description": "API para consultar informa\u00e7\u00f5es sobre registros de passagens nos \u00faltimos 30 dias, para uma placa informada. Caso exista MDF-e associado \u00e0 placa, ser\u00e1 retornado algumas informa\u00e7\u00f5es sobre percurso, municipio de carregamento e descarregamento, UFs do percurso, dados do transportador e condutor, etc.",
    "version": "1.0.0",
    "title": "API Consulta Registros de Passagem por ve\u00edculo",
    "contact": {
      "email": "cotin@fazenda.ms.gov.br",
      "name": "SEFAZ-MS/COTIN"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/icorrea4/api-dfe-consulta-veiculo/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "RP-e",
      "description": "Registros de Passagens de ve\u00edculos"
    }
  ],
  "paths": {
    "/api/v1/consultaveiculo": {
      "get": {
        "tags": [
          "RP-e"
        ],
        "summary": "Pesquisa se existe registro de passagem para uma placa",
        "description": "Servi\u00e7o de pesquisa de registros de passagem por placa do ve\u00edculo",
        "parameters": [
          {
            "name": "placa",
            "description": "n\u00famero da placa que se deseja pesquisar registro de passagem",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[a-zA-Z]{3}[0-9][A-Za-z0-9][0-9]{2}$"
            },
            "example": "QTP5J78"
          },
          {
            "name": "dataHoraConsulta",
            "description": "Data e Hora da consulta",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "example": "2017-07-21T10:32:28Z"
          },
          {
            "name": "motivo",
            "description": "Motiva\u00e7\u00e3o da consulta, obrigat\u00f3ria a ser preenchida quando a consulta for feita por \u00f3rg\u00e3o de seguran\u00e7a p\u00fablica.",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            }
          },
          {
            "name": "usuario",
            "description": "Identifica\u00e7\u00e3o do Usu\u00e1rio que fez a consulta, obrigat\u00f3ria a ser preenchida quando a consulta for feita por \u00f3rg\u00e3o de seguran\u00e7a p\u00fablica.",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 40
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Consulta realizada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RespostaRPe"
                  }
                }
              }
            }
          },
          "401": {
            "description": "N\u00e3o autorizado!"
          },
          "500": {
            "description": "Erro inesperado no servidor, tente novamente."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RespostaRPe": {
        "description": "Resposta da solicita\u00e7\u00e3o com Registros de Passagens e ou MDF-es.",
        "type": "object",
        "properties": {
          "registrosPassagens": {
            "description": "Registros de passagens associados a esta placa, caso existam.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RegistroPassagem"
            }
          },
          "mdfes": {
            "description": "MDF-e associados a esta placa, caso existam.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MDFe"
            }
          },
          "situacao": {
            "$ref": "#/components/schemas/Situacao"
          }
        }
      },
      "RegistroPassagem": {
        "description": "Informa\u00e7\u00f5es sobre registro de passagem.",
        "type": "object",
        "properties": {
          "placa": {
            "description": "placa do ve\u00edculo",
            "type": "string",
            "pattern": "[A-Z]{2,3}[0-9]{4}|[A-Z]{3,4}[0-9]{3}|[A-Z0-9]{7}",
            "example": "QTP8F91"
          },
          "localizacao": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/LocalizacaoAutomatica"
              },
              {
                "$ref": "#/components/schemas/LocalizacaoManual"
              }
            ]
          },
          "sentidoVia": {
            "description": "Sentido na Via: \u201cE\u201d=Entrada na UF; \u201cS\u201d=Sa\u00edda da UF; \u201cI\u201d=Indeterminado",
            "type": "string",
            "enum": [
              "E",
              "S",
              "I"
            ]
          },
          "dhPas": {
            "description": "Data e Hora da passagem",
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Evento": {
        "description": "Evento do MDF-e (Autoriza\u00e7\u00e3o/ Encerramento/ Cancelamento)",
        "type": "object",
        "properties": {
          "codigo": {
            "description": "c\u00f3digo do evento",
            "type": "string"
          },
          "descricao": {
            "description": "descri\u00e7\u00e3o do evento",
            "type": "string"
          },
          "dataHora": {
            "description": "Data e hora do evento",
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MDFe": {
        "description": "Manifesto dos Documentos Fiscais Eletr\u00f4nicos",
        "type": "object",
        "properties": {
          "infMunCarrega": {
            "description": "Informa\u00e7\u00f5es dos Munic\u00edpios de Carregamento",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Municipio"
            },
            "minLength": 0,
            "maxLength": 50
          },
          "infMunDescarga": {
            "description": "Informa\u00e7\u00f5es dos Munic\u00edpios de Descarregamento",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Municipio"
            },
            "minLength": 0,
            "maxLength": 100
          },
          "infPercurso": {
            "description": "Informa\u00e7\u00f5es do Percurso do MDF-e",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InfPercurso"
            },
            "minLength": 0,
            "maxLength": 25
          },
          "dhIniViagem": {
            "type": "string",
            "format": "date-time"
          },
          "tpRod": {
            "description": "Tipo de Rodado (01 - Trunk, 02-Toco, 03-Cavalo Mecanico, 04- VAN, 05-Utilit\u00e1rio e 06-Outros)",
            "type": "string",
            "enum": [
              "01",
              "02",
              "03",
              "04",
              "05",
              "06"
            ]
          },
          "tpCar": {
            "description": "Tipo de Carroceria (00-N\u00e3o aplic\u00e1vel e 01-Aberta)",
            "type": "string",
            "enum": [
              "00",
              "01"
            ]
          },
          "eventos": {
            "description": "Eventos associados ao MDF-e",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Evento"
            },
            "minLength": 1,
            "maxLength": 3
          },
          "veiculosReboque": {
            "description": "Placas dos reboques",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "placa": {
                  "type": "string",
                  "pattern": "[A-Z0-9]{4}"
                },
                "tpCar": {
                  "description": "Tipo de Carroceria: 00 - N\u00e3o aplic\u00e1vel; 01 - Aberta; 02 - Fechado/Ba\u00fa; 03 - Graneleira; 04 - Porta Container; 05 - Sider",
                  "type": "string",
                  "enum": [
                    "00",
                    "01",
                    "02",
                    "03",
                    "04",
                    "05"
                  ]
                }
              }
            }
          },
          "dadosTransportador": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TransportadorEmitente"
              },
              {
                "$ref": "#/components/schemas/TransportadorProprietario"
              }
            ]
          },
          "dadosCondutor": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Condutor"
            }
          }
        }
      },
      "Municipio": {
        "description": "Municipio conforme tabela do IBGE",
        "properties": {
          "codigo": {
            "type": "integer",
            "format": "int32",
            "example": 5002704
          },
          "nome": {
            "type": "string",
            "minLength": 2,
            "maxLength": 60,
            "example": "Campo Grande"
          }
        }
      },
      "InfPercurso": {
        "description": "UF conforme tabela do IBGE",
        "properties": {
          "UFPer": {
            "type": "string",
            "pattern": "[0-9]{2}",
            "example": 50
          }
        }
      },
      "LocalizacaoAutomatica": {
        "properties": {
          "cIdAntena": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          },
          "xIdAntena": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          },
          "latGPS": {
            "type": "string"
          },
          "longGPS": {
            "type": "string"
          }
        }
      },
      "LocalizacaoManual": {
        "properties": {
          "cPostoUF": {
            "description": "C\u00f3digo do Posto Fiscal para a UF autora do evento",
            "type": "string",
            "minLength": 1,
            "maxLength": 4
          },
          "xPostoUF": {
            "description": "Nome do Posto Fiscal para a UF",
            "type": "string",
            "minLength": 2,
            "maxLength": 60
          },
          "latGPS": {
            "description": "Latitude do local de registro de passagem",
            "type": "string"
          },
          "longGPS": {
            "description": "Longitude do local de registro de passagem",
            "type": "string"
          },
          "localidade": {
            "description": "Localidade do registro offline",
            "type": "string"
          }
        }
      },
      "TransportadorEmitente": {
        "description": "Dados sobre o transportador emitente do MDF-e",
        "oneOf": [
          {
            "properties": {
              "emitCnpj": {
                "description": "CNPJ do transportador",
                "type": "string",
                "pattern": "[0-9]{14}"
              }
            }
          },
          {
            "properties": {
              "emitCpf": {
                "description": "CPF do transportador",
                "type": "string",
                "pattern": "[0-9]{11}"
              }
            }
          }
        ],
        "properties": {
          "emitNome": {
            "description": "Nome/Razao Social do transportador",
            "type": "string"
          }
        }
      },
      "TransportadorProprietario": {
        "description": "Dados sobre o propriet\u00e1rio do veiculo de tra\u00e7\u00e3o. Preencher somente quando o Transportador emitente n\u00e3o for o propriet\u00e1rio.",
        "oneOf": [
          {
            "properties": {
              "propCnpj": {
                "description": "CNPJ do transportador",
                "type": "string",
                "pattern": "[0-9]{14}"
              }
            }
          },
          {
            "properties": {
              "propCpf": {
                "description": "CPF do transportador",
                "type": "string",
                "pattern": "[0-9]{11}"
              }
            }
          }
        ],
        "properties": {
          "propNome": {
            "description": "Nome/Razao Social do transportador",
            "type": "string"
          }
        }
      },
      "Situacao": {
        "description": "Situa\u00e7\u00e3o da resposta da consulta, tem com objetivo reportar se houve sucesso ou n\u00e3o na consulta efetuada. Tipo de situa\u00e7\u00f5es: 100 \u2013 Registro encontrado para a consulta. 101 - Data/hora da consulta n\u00e3o pode ser menor que os \u00faltimos 30 dias 102 - Data/hora da consulta n\u00e3o pode ser maior que a Data/hora atual. 103 - Motivo da consulta \u00e9 obrigat\u00f3rio ser preenchido. 104 \u2013 Registro n\u00e3o encontrado para a consulta. 106 - Placa inv\u00e1lida. 107 - Usu\u00e1rio da consulta \u00e9 obrigat\u00f3rio ser preenchido 999 - Erro n\u00e3o catalogado.",
        "properties": {
          "codigo": {
            "type": "string",
            "pattern": "[0-9]{3}",
            "example": "100"
          },
          "motivo": {
            "type": "string",
            "minLength": 2,
            "maximum": 255,
            "example": "OK"
          }
        }
      },
      "Condutor": {
        "description": "Dados sobre o condutor do ve\u00edculo,  informado quando o consulente for \u00f3rg\u00e3o de seguran\u00e7a p\u00fablica.",
        "properties": {
          "cpf": {
            "type": "string",
            "pattern": "[0-9]{11}"
          },
          "nome": {
            "type": "string"
          }
        }
      }
    }
  }
}