  "tags": [
    {
      "name": "RP-e",
      "description": "Registros de Passagens de ve\u00edculos"
    }
  ],
  "paths": {
    "/api/v1/consultacondutor": {
      "get": {
        "tags": [
          "RP-e"
        ],
        "summary": "Pesquisa se existe registro de passagem por condutor",
        "description": "Servi\u00e7o de pesquisa de registros de passagem por condutor do ve\u00edculo",
        "parameters": [
          {
            "name": "cpf",
            "in": "query",
            "description": "n\u00famero do CPF do condutor que se deseja pesquisar registro de passagem",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "pattern": "[0-9]{11}",
              "type": "string"
            }
          },
          {
            "name": "dataHoraConsulta",
            "in": "query",
            "description": "Data e Hora da Consulta",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "example": "2017-07-21T10:32:28Z"
          },
          {
            "name": "motivo",
            "description": "Motiva\u00e7\u00e3o da consulta, obrigat\u00f3ria a ser preenchida quando a consulta for feita por \u00f3rg\u00e3o de seguran\u00e7a p\u00fablica.",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            }
          },
          {
            "name": "usuario",
            "description": "Identifica\u00e7\u00e3o do Usu\u00e1rio que fez a consulta, obrigat\u00f3ria a ser preenchida quando a consulta for feita por \u00f3rg\u00e3o de seguran\u00e7a p\u00fablica.",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 40
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Consulta realizada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RespostaRPe"
                  }
                }
              }
            }
          },
          "401": {
            "description": "N\u00e3o autorizado!"
          },
          "500": {
            "description": "Erro inesperado no servidor, tente novamente."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RespostaRPe": {
        "description": "Resposta da solicita\u00e7\u00e3o com os MDF-es.",
        "type": "object",
        "properties": {
          "mdfes": {
            "description": "MDF-e associados ao CPF, caso existam.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MDFe"
            }
          },
          "situacao": {
            "$ref": "#/components/schemas/Situacao"
          }
        }
      },
      "Evento": {
        "description": "Evento do MDF-e (Autoriza\u00e7\u00e3o/ Encerramento/ Cancelamento)",
        "type": "object",
        "properties": {
          "codigo": {
            "description": "c\u00f3digo do evento",
            "type": "string"
          },
          "descricao": {
            "description": "descri\u00e7\u00e3o do evento",
            "type": "string"
          },
          "dataHora": {
            "description": "Data e hora do evento",
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MDFe": {
        "type": "object",
        "properties": {
          "infMunCarrega": {
            "maxLength": 50,
            "minLength": 0,
            "type": "array",
            "description": "Informa\u00e7\u00f5es dos Munic\u00edpios de Carregamento",
            "items": {
              "$ref": "#/components/schemas/Municipio"
            }
          },
          "infMunDescarga": {
            "maxLength": 100,
            "minLength": 0,
            "type": "array",
            "description": "Informa\u00e7\u00f5es dos Munic\u00edpios de Descarregamento",
            "items": {
              "$ref": "#/components/schemas/Municipio"
            }
          },
          "infPercurso": {
            "maxLength": 25,
            "minLength": 0,
            "type": "array",
            "description": "Informa\u00e7\u00f5es do Percurso do MDF-e",
            "items": {
              "$ref": "#/components/schemas/InfPercurso"
            }
          },
          "dhIniViagem": {
            "type": "string",
            "format": "date-time"
          },
          "tpRod": {
            "type": "string",
            "description": "Tipo de Rodado (01 - Trunk, 02-Toco, 03-Cavalo Mecanico, 04- VAN, 05-Utilit\u00e1rio e 06-Outros)",
            "enum": [
              "01",
              "02",
              "03",
              "04",
              "05",
              "06"
            ]
          },
          "tpCar": {
            "type": "string",
            "description": "Tipo de Carroceria (00-N\u00e3o aplic\u00e1vel e 01-Aberta)",
            "enum": [
              "00",
              "01"
            ]
          },
          "eventos": {
            "description": "Eventos associados ao MDF-e",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Evento"
            },
            "minLength": 1,
            "maxLength": 3
          },
          "veiculosReboque": {
            "type": "array",
            "description": "Placas dos reboques",
            "items": {
              "$ref": "#/components/schemas/MDFe_veiculosReboque"
            }
          },
          "dadosTransportador": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TransportadorEmitente"
              },
              {
                "$ref": "#/components/schemas/TransportadorProprietario"
              }
            ]
          },
          "dadosCondutor": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Condutor"
            }
          }
        },
        "description": "Manifesto dos Documentos Fiscais Eletr\u00f4nicos"
      },
      "Municipio": {
        "properties": {
          "codigo": {
            "type": "integer",
            "format": "int32",
            "example": 5002704
          },
          "nome": {
            "maxLength": 60,
            "minLength": 2,
            "type": "string",
            "example": "Campo Grande"
          }
        },
        "description": "Municipio conforme tabela do IBGE"
      },
      "InfPercurso": {
        "properties": {
          "UFPer": {
            "pattern": "[0-9]{2}",
            "type": "string",
            "example": "50"
          }
        }
      },
      "LocalizacaoManual": {
        "properties": {
          "cPostoUF": {
            "maxLength": 4,
            "minLength": 1,
            "type": "string",
            "description": "C\u00f3digo do Posto Fiscal para a UF autora do evento"
          },
          "xPostoUF": {
            "maxLength": 60,
            "minLength": 2,
            "type": "string",
            "description": "Nome do Posto Fiscal para a UF"
          },
          "latGPS": {
            "type": "string",
            "description": "Latitude do local de registro de passagem"
          },
          "longGPS": {
            "type": "string",
            "description": "Longitude do local de registro de passagem"
          },
          "localidade": {
            "description": "Localidade do registro offline",
            "type": "string"
          }
        }
      },
      "TransportadorEmitente": {
        "properties": {
          "emitNome": {
            "type": "string",
            "description": "Nome/Razao Social do transportador"
          }
        },
        "description": "Dados sobre o transportador emitente do MDF-e",
        "oneOf": [
          {
            "properties": {
              "emitCnpj": {
                "pattern": "[0-9]{14}",
                "type": "string",
                "description": "CNPJ do transportador"
              }
            }
          },
          {
            "properties": {
              "emitCpf": {
                "pattern": "[0-9]{11}",
                "type": "string",
                "description": "CPF do transportador"
              }
            }
          }
        ]
      },
      "TransportadorProprietario": {
        "properties": {
          "propNome": {
            "type": "string",
            "description": "Nome/Razao Social do transportador"
          }
        },
        "description": "Dados sobre o propriet\u00e1rio do veiculo de tra\u00e7\u00e3o. Preencher somente quando o Transportador emitente n\u00e3o for o propriet\u00e1rio.",
        "oneOf": [
          {
            "properties": {
              "propCnpj": {
                "pattern": "[0-9]{14}",
                "type": "string",
                "description": "CNPJ do transportador"
              }
            }
          },
          {
            "properties": {
              "propCpf": {
                "pattern": "[0-9]{11}",
                "type": "string",
                "description": "CPF do transportador"
              }
            }
          }
        ]
      },
      "Situacao": {
        "description": "Situa\u00e7\u00e3o da resposta da consulta, tem com objetivo reportar se houve sucesso ou n\u00e3o na consulta efetuada. Tipo de situa\u00e7\u00f5es: 100 \u2013 Registro encontrado para a consulta. 101 - Data/hora da consulta n\u00e3o pode ser menor que os \u00faltimos 30 dias 102 - Data/hora da consulta n\u00e3o pode ser maior que a Data/hora atual. 103 - Motivo da consulta \u00e9 obrigat\u00f3rio ser preenchido. 104 \u2013 Registro n\u00e3o encontrado para a consulta. 105 - CPF inv\u00e1lido. 107 - Usu\u00e1rio da consulta \u00e9 obrigat\u00f3rio ser preenchido 999 - Erro n\u00e3o catalogado.",
        "properties": {
          "codigo": {
            "type": "string",
            "pattern": "[0-9]{3}",
            "example": "100"
          },
          "motivo": {
            "type": "string",
            "minLength": 2,
            "maximum": 255,
            "example": "OK"
          }
        }
      },
      "Condutor": {
        "properties": {
          "cpf": {
            "pattern": "[0-9]{11}",
            "type": "string"
          },
          "nome": {
            "type": "string"
          }
        },
        "description": "Dados sobre o condutor do ve\u00edculo, informado quando o consulente for \u00f3rg\u00e3o de seguran\u00e7a p\u00fablica."
      },
      "MDFe_veiculosReboque": {
        "maxItems": 3,
        "minItems": 0,
        "type": "object",
        "properties": {
          "placa": {
            "pattern": "[A-Z0-9]{4}",
            "type": "string"
          },
          "tpCar": {
            "description": "Tipo de Carroceria: 00 - N\u00e3o aplic\u00e1vel; 01 - Aberta; 02 - Fechado/Ba\u00fa; 03 - Graneleira; 04 - Porta Container; 05 - Sider",
            "type": "string",
            "enum": [
              "00",
              "01",
              "02",
              "03",
              "04",
              "05"
            ]
          }
        }
      }
    }
  }
}