            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/embeddings": {
      "post": {
        "tags": ["Search & Similarity"],
        "summary": "Text embeddings",
        "description": "Generate vector embeddings for sentences.",
        "operationId": "embeddings",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["sentences"],
                "properties": {
                  "sentences": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of sentences to generate embeddings for"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Embeddings generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmbeddingsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/semantic-search": {
      "post": {
        "tags": ["Search & Similarity"],
        "summary": "Semantic search",
        "description": "Perform semantic search to find relevant content.",
        "operationId": "semanticSearch",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Search query text"
                  },
                  "num_results": {
                    "type": "integer",
                    "description": "Number of results to return"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SemanticSearchResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/semantic-similarity": {
      "post": {
        "tags": ["Search & Similarity"],
        "summary": "Semantic similarity",
        "description": "Calculate semantic similarity between sentences.",
        "operationId": "semanticSimilarity",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["sentences"],
                "properties": {
                  "sentences": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "minItems": 2,
                    "maxItems": 2,
                    "description": "Pair of sentences to compare"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Similarity score returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimilarityResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/speech-synthesis": {
      "post": {
        "tags": ["Speech & Audio"],
        "summary": "Text-to-speech synthesis",
        "description": "Convert text to spoken audio.",
        "operationId": "speechSynthesis",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "voice": {
                    "type": "string",
                    "description": "Voice to use for synthesis"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpeechSynthesisResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/asr": {
      "post": {
        "tags": ["Speech & Audio"],
        "summary": "Automatic speech recognition",
        "description": "Convert spoken audio to text.",
        "operationId": "asr",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of audio file"
                  },
                  "encoded_file": {
                    "type": "string",
                    "description": "Base64-encoded audio file"
                  },
                  "input_language": {
                    "type": "string",
                    "description": "Language of the audio"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio transcribed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsrResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/image-generation": {
      "post": {
        "tags": ["Image"],
        "summary": "Image generation",
        "description": "Generate images from text descriptions.",
        "operationId": "imageGeneration",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Text description of the image to generate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageGenerationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token retrieved from the NLP Cloud dashboard. Pass as Bearer token in the Authorization header."
      }
    },
    "parameters": {
      "Model": {
        "name": "model",
        "in": "path",
        "required": true,
        "description": "The model to use (e.g., 'en_core_web_lg', 'gpt-j', 'fast-gpt-j', 'finetuned-gpt-neox-20b', etc.)",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "GenerationRequest": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "Input text prompt"
          },
          "max_length": {
            "type": "integer",
            "description": "Maximum number of tokens to generate"
          },
          "length_no_input": {
            "type": "boolean",
            "description": "Whether max_length excludes the input text length"
          },
          "end_sequence": {
            "type": "string",
            "description": "Stop generation at this sequence"
          },
          "remove_input": {
            "type": "boolean",
            "description": "Remove input text from the response"
          },
          "num_beams": {
            "type": "integer",
            "description": "Number of beams for beam search"
          },
          "num_return_sequences": {
            "type": "integer",
            "description": "Number of sequences to return"
          },
          "top_k": {
            "type": "integer",
            "description": "Top-k sampling parameter"
          },
          "top_p": {
            "type": "number",
            "description": "Top-p (nucleus) sampling parameter"
          },
          "temperature": {
            "type": "number",
            "description": "Sampling temperature"
          },
          "repetition_penalty": {
            "type": "number",
            "description": "Penalty for token repetition"
          },
          "bad_words": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Words to avoid in generation"
          },
          "remove_end_sequence": {
            "type": "boolean",
            "description": "Remove end sequence from the response"
          }
        }
      },
      "ChatbotRequest": {
        "type": "object",
        "required": ["input"],
        "properties": {
          "input": {
            "type": "string",
            "description": "User message input"
          },
          "context": {
            "type": "string",
            "description": "System context or persona for the chatbot"
          },
          "history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "input": {
                  "type": "string"
                },
                "response": {
                  "type": "string"
                }
              }
            },
            "description": "Conversation history"
          }
        }
      },
      "EntitiesResponse": {
        "type": "object",
        "properties": {
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "start": {
                  "type": "integer"
                },
                "end": {
                  "type": "integer"
                },
                "type": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SentimentResponse": {
        "type": "object",
        "properties": {
          "scored_labels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "ClassificationResponse": {
        "type": "object",
        "properties": {
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scores": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      },
      "DependenciesResponse": {
        "type": "object",
        "properties": {
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "tag": {
                  "type": "string"
                },
                "dep": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "TokensResponse": {
        "type": "object",
        "properties": {
          "tokens": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "start": {
                  "type": "integer"
                },
                "end": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "IntentClassificationResponse": {
        "type": "object",
        "properties": {
          "intent": {
            "type": "string"
          },
          "score": {
            "type": "number"
          }
        }
      },
      "KeywordsResponse": {
        "type": "object",
        "properties": {
          "keywords_and_keyphrases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "GenerationResponse": {
        "type": "object",
        "properties": {
          "generated_text": {
            "type": "string"
          },
          "nb_generated_tokens": {
            "type": "integer"
          },
          "nb_input_tokens": {
            "type": "integer"
          }
        }
      },
      "SummarizationResponse": {
        "type": "object",
        "properties": {
          "summary_text": {
            "type": "string"
          }
        }
      },
      "ParaphrasingResponse": {
        "type": "object",
        "properties": {
          "paraphrased_text": {
            "type": "string"
          }
        }
      },
      "ChatbotResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "string"
          },
          "history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "input": {
                  "type": "string"
                },
                "response": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "QuestionResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "start": {
            "type": "integer"
          },
          "end": {
            "type": "integer"
          }
        }
      },
      "TranslationResponse": {
        "type": "object",
        "properties": {
          "translation_text": {
            "type": "string"
          }
        }
      },
      "LangDetectionResponse": {
        "type": "object",
        "properties": {
          "languages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "language": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "CorrectionResponse": {
        "type": "object",
        "properties": {
          "correction": {
            "type": "string"
          }
        }
      },
      "EmbeddingsResponse": {
        "type": "object",
        "properties": {
          "embeddings": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          }
        }
      },
      "SemanticSearchResponse": {
        "type": "object",
        "properties": {
          "search_results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "SimilarityResponse": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number",
            "description": "Similarity score between 0 and 1"
          }
        }
      },
      "SpeechSynthesisResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the generated audio file"
          }
        }
      },
      "AsrResponse": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Transcribed text"
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the generated image"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "Error detail message"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "RateLimitExceeded": {
        "description": "Rate limit exceeded - too many requests",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  }
}
