{
  "openapi": "3.0.3",
  "info": {
    "title": "NLP Cloud API",
    "description": "NLP Cloud serves high performance pre-trained and custom models for NLP, sentiment analysis, classification, summarization, paraphrasing, grammar and spelling correction, entities, keywords extraction, text generation, image generation, code generation, question answering, translation, language detection, speech synthesis, and more. Built on spaCy and Hugging Face transformers.",
    "version": "1.0.0",
    "contact": {
      "name": "NLP Cloud",
      "url": "https://nlpcloud.com"
    },
    "x-jentic-source-url": "https://nlpcloud.io"
  },
  "servers": [
    {
      "url": "https://api.nlpcloud.io/v1",
      "description": "NLP Cloud API v1"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Text Analysis",
      "description": "NLP analysis operations: entities, sentiment, dependencies, classification"
    },
    {
      "name": "Text Generation",
      "description": "Text and code generation endpoints"
    },
    {
      "name": "Translation & Language",
      "description": "Translation, language detection, and grammar correction"
    },
    {
      "name": "Search & Similarity",
      "description": "Semantic search, similarity, and embeddings"
    },
    {
      "name": "Speech & Audio",
      "description": "Speech synthesis and automatic speech recognition"
    },
    {
      "name": "Chatbot",
      "description": "Conversational AI"
    },
    {
      "name": "Image",
      "description": "Image generation"
    },
    {
      "name": "Utility",
      "description": "Utility endpoints"
    }
  ],
  "paths": {
    "/{model}/entities": {
      "post": {
        "tags": ["Text Analysis"],
        "summary": "Named entity recognition",
        "description": "Extract named entities from text using the specified model.",
        "operationId": "entities",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "The text to extract entities from"
                  },
                  "searched_entity": {
                    "type": "string",
                    "description": "Optional specific entity type to search for"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entities extracted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntitiesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/sentiment": {
      "post": {
        "tags": ["Text Analysis"],
        "summary": "Sentiment analysis",
        "description": "Analyze sentiment of text.",
        "operationId": "sentiment",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "target": {
                    "type": "string",
                    "description": "Optional target for aspect-based sentiment"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sentiment analyzed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SentimentResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/classification": {
      "post": {
        "tags": ["Text Analysis"],
        "summary": "Text classification",
        "description": "Classify text into specified labels.",
        "operationId": "classification",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text", "labels"],
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of classification labels"
                  },
                  "multi_class": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether multiple labels can be assigned"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text classified successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClassificationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/dependencies": {
      "post": {
        "tags": ["Text Analysis"],
        "summary": "POS tagging and dependency parsing",
        "description": "Perform part-of-speech tagging and dependency parsing on text.",
        "operationId": "dependencies",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dependencies parsed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DependenciesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/tokens": {
      "post": {
        "tags": ["Text Analysis"],
        "summary": "Tokenization",
        "description": "Split text into tokens.",
        "operationId": "tokens",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text tokenized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokensResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/intent-classification": {
      "post": {
        "tags": ["Text Analysis"],
        "summary": "Intent classification",
        "description": "Classify the intent of the given text.",
        "operationId": "intentClassification",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Intent classified successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntentClassificationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/kw-kp-extraction": {
      "post": {
        "tags": ["Text Analysis"],
        "summary": "Keyword and keyphrase extraction",
        "description": "Extract keywords and keyphrases from text.",
        "operationId": "kwKpExtraction",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Keywords extracted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KeywordsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/generation": {
      "post": {
        "tags": ["Text Generation"],
        "summary": "Text generation",
        "description": "Generate text based on a prompt using the specified model.",
        "operationId": "generation",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/code-generation": {
      "post": {
        "tags": ["Text Generation"],
        "summary": "Code generation",
        "description": "Generate source code from a natural language instruction.",
        "operationId": "codeGeneration",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["instruction"],
                "properties": {
                  "instruction": {
                    "type": "string",
                    "description": "Natural language instruction describing the code to generate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Code generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/ad-generation": {
      "post": {
        "tags": ["Text Generation"],
        "summary": "Ad copy generation",
        "description": "Generate advertisement copy from keywords.",
        "operationId": "adGeneration",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["keywords"],
                "properties": {
                  "keywords": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Keywords to generate ad copy from"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ad copy generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/summarization": {
      "post": {
        "tags": ["Text Generation"],
        "summary": "Text summarization",
        "description": "Summarize text to a shorter version.",
        "operationId": "summarization",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "size": {
                    "type": "integer",
                    "description": "Target summary size in number of tokens"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text summarized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummarizationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/paraphrasing": {
      "post": {
        "tags": ["Text Generation"],
        "summary": "Paraphrasing",
        "description": "Rephrase text while preserving meaning.",
        "operationId": "paraphrasing",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text paraphrased successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParaphrasingResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/chatbot": {
      "post": {
        "tags": ["Chatbot"],
        "summary": "Chatbot conversation",
        "description": "Interact with a conversational AI chatbot with context and history.",
        "operationId": "chatbot",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatbotRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chatbot response generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatbotResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/question": {
      "post": {
        "tags": ["Text Analysis"],
        "summary": "Question answering",
        "description": "Answer a question, optionally based on a given context.",
        "operationId": "question",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["question"],
                "properties": {
                  "question": {
                    "type": "string"
                  },
                  "context": {
                    "type": "string",
                    "description": "Optional context to answer the question from"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Question answered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuestionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/translation": {
      "post": {
        "tags": ["Translation & Language"],
        "summary": "Text translation",
        "description": "Translate text between languages.",
        "operationId": "translation",
        "parameters": [
          {
            "$ref": "#/components/parameters/Model"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "source": {
                    "type": "string",
                    "description": "Source language code"
                  },
                  "target": {
                    "type": "string",
                    "description": "Target language code"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text translated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/{model}/langdetection": {
      "post": {
        "tags": ["Translation & Language"],
        "summary": "Language detection",
