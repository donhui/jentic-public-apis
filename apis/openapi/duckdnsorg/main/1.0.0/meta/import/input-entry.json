{
  "openapi": "3.0.3",
  "info": {
    "title": "DuckDNS API",
    "description": "DuckDNS dynamic DNS update API for managing domain IP addresses and TXT records.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.duckdns.org/spec.jsp"
  },
  "servers": [
    {
      "url": "https://www.duckdns.org",
      "description": "DuckDNS API server"
    }
  ],
  "paths": {
    "/update": {
      "get": {
        "operationId": "updateDomain",
        "summary": "Update domain IP address",
        "description": "Update the IP address for one or more DuckDNS domains. If ip is not provided, the requester's public IP is used.",
        "tags": [
          "DNS Update"
        ],
        "parameters": [
          {
            "name": "domains",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of domain names (without .duckdns.org)"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account authentication token"
          },
          {
            "name": "ip",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "IPv4 address to set. If omitted, uses requester's IP."
          },
          {
            "name": "ipv6",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "IPv6 address to set"
          },
          {
            "name": "verbose",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Return detailed response with IP addresses"
          },
          {
            "name": "txt",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "TXT record content to set for the domain"
          },
          {
            "name": "clear",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Clear the IP address and/or TXT record for the domain"
          }
        ],
        "responses": {
          "200": {
            "description": "Update result. Returns 'OK' on success, 'KO' on failure.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/update/{domain}/{token}": {
      "get": {
        "operationId": "updateDomainSimple",
        "summary": "Update domain IP address (simplified URL format)",
        "description": "Simplified update format for basic routers with limited request capabilities.",
        "tags": [
          "DNS Update"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Domain name (without .duckdns.org)"
          },
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account authentication token"
          }
        ],
        "responses": {
          "200": {
            "description": "Update result",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/update/{domain}/{token}/{ip}": {
      "get": {
        "operationId": "updateDomainSimpleWithIp",
        "summary": "Update domain with specific IP (simplified URL format)",
        "tags": [
          "DNS Update"
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Domain name (without .duckdns.org)"
          },
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Account authentication token"
          },
          {
            "name": "ip",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IP address to set"
          }
        ],
        "responses": {
          "200": {
            "description": "Update result",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "DuckDNS account token for authentication"
      }
    },
    "schemas": {
      "UpdateResponse": {
        "type": "string",
        "description": "Plain text response: 'OK' on success, 'KO' on failure. In verbose mode includes additional lines with IP and update status."
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters"
      },
      "Unauthorized": {
        "description": "Authentication failed - invalid token"
      }
    }
  },
  "security": [
    {
      "tokenAuth": []
    }
  ]
}