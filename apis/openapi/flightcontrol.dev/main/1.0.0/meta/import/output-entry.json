{
  "openapi": "3.0.3",
  "info": {
    "title": "Flightcontrol API",
    "description": "The Flightcontrol API enables programmatic control over deployments, projects, environments, services, environment variables, CloudFront cache invalidation, scheduler jobs, AWS accounts, and custom domains.",
