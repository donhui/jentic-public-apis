            "type": "string",
            "example": "Web App"
          },
          "givenId": {
            "type": "string",
            "example": "web-app"
          },
          "type": {
            "type": "string",
            "example": "web"
          },
          "environmentId": {
            "type": "string"
          },
          "projectId": {
            "type": "string"
          },
          "runtimeLogs": {
            "$ref": "#/components/schemas/RuntimeLogs"
          }
