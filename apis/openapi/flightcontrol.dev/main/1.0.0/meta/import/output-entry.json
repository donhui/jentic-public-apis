    "/v1/services": {
      "get": {
        "operationId": "getServices",
        "summary": "List services",
        "description": "Returns a paginated list of services with optional filtering.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "skip",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of items to skip for pagination"
          },
          {
            "name": "take",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of items to return"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "web",
                "worker",
                "static",
                "scheduled"
              ]
            },
            "description": "Filter by service type"
          },
          {
            "name": "projectId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by project ID"
          },
          {
            "name": "isPreview",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Filter for preview services only"
          }
        ],
        "responses": {
          "200": {
            "description": "List of services",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServicesList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
