    "/api/deploy-hook/{envId}/{secret}": {
      "get": {
        "operationId": "triggerDeployHook",
        "summary": "Trigger deployment via deploy hook",
        "description": "Triggers a new deployment for the specified environment using a deploy hook URL. The secret is generated when creating the deploy hook in the Flightcontrol dashboard.",
        "tags": [
          "Deployments"
        ],
        "security": [],
        "parameters": [
          {
            "name": "envId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The unique identifier for the environment"
          },
          {
            "name": "secret",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Authentication secret generated when creating the deploy hook"
          },
          {
            "name": "commit",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Git commit SHA to deploy a specific commit"
          },
          {
            "name": "branch",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Branch to deploy from. Required if specifying a commit."
          },
          {
            "name": "force",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Force deployment of all services regardless of watchPaths settings"
          }
        ],
        "responses": {
          "200": {
            "description": "Deployment triggered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "string",
                      "example": "true"
                    },
                    "deploymentId": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid secret"
          }
        }
      }
    },
