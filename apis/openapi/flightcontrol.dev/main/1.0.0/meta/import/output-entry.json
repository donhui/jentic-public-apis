  "components": {
    "schemas": {
      "ProjectSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "cl2kx7acm00003f6gobvidq2i"
          },
          "name": {
            "type": "string",
            "example": "My Project"
          },
          "repoUrl": {
            "type": "string",
            "example": "https://github.com/team/project"
          }
        }
      },
      "CreateProjectRequest": {
        "type": "object",
        "required": [
          "name",
          "repoUrl",
          "awsAccountId",
          "codeSource",
          "configType"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "The project display name"
          },
          "repoUrl": {
            "type": "string",
            "description": "Git repository URL",
            "example": "https://github.com/team/project"
          },
          "awsAccountId": {
            "type": "string",
            "description": "Flightcontrol AWS account connection ID"
          },
          "codeSource": {
            "type": "object",
            "description": "Git provider configuration",
            "properties": {
              "provider": {
                "type": "string",
                "enum": [
                  "github",
                  "gitlab",
                  "gitlab_self_hosted"
                ],
                "description": "The git provider to use"
              }
            },
            "required": [
              "provider"
            ]
          },
          "configType": {
            "type": "string",
            "enum": [
              "gui",
              "iac"
            ],
            "description": "Configuration type: 'gui' for dashboard-managed or 'iac' for infrastructure-as-code via flightcontrol.json"
          },
          "config": {
            "type": "object",
            "description": "Project configuration object. Required when configType is 'gui'. Follows flightcontrol.json schema."
          },
          "configFilePath": {
            "type": "string",
            "description": "Path to the flightcontrol.json config file. Required when configType is 'iac'."
          },
          "configFileBranch": {
            "type": "string",
            "description": "Git branch containing the config file. Required when configType is 'iac'."
          }
        }
      },
      "CreateEnvironmentRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "The environment name"
          }
        }
      },
      "EditEnvironmentRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The environment name"
          }
        }
      },
      "CreateDeploymentRequest": {
        "type": "object",
        "required": [
          "environmentId"
        ],
        "properties": {
          "environmentId": {
            "type": "string",
            "description": "The environment to deploy to"
          },
          "imageTag": {
            "type": "string",
            "description": "Optional image tag override"
          },
          "imageSha": {
            "type": "string",
            "description": "Optional image SHA override"
          },
          "repositoryUrl": {
            "type": "string",
            "description": "Optional repository URL override"
          }
        }
      },
      "Deployment": {
        "type": "object",
        "properties": {
          "deploymentId": {
            "type": "string",
            "example": "clcpcxekt000lc9ojqtgtc26y"
          },
          "projectId": {
            "type": "string",
            "example": "cluagwibz000ka6p9uzas7p26"
          },
          "environmentId": {
            "type": "string"
          },
          "environmentGivenId": {
            "type": "string",
            "example": "production"
          },
          "isPreviewEnvironment": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "example": "2023-01-09 22:10:02.381"
          },
          "repoUrl": {
            "type": "string"
          },
          "gitCommit": {
            "type": "string"
          },
          "gitBranch": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "INPROGRESS",
              "SUCCESS",
              "ERROR",
              "CANCELLED"
            ]
          },
          "serviceDeployments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ServiceDeployment"
            }
          }
        }
      },
      "ServiceDeployment": {
        "type": "object",
        "properties": {
          "service": {
            "$ref": "#/components/schemas/ServiceRef"
          },
          "serviceDeploymentId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "BUILDING",
              "DEPLOYING",
              "SUCCESS",
              "ERROR",
              "CANCELLED"
            ]
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ServiceRef": {
        "type": "object",
        "properties": {
          "serviceId": {
            "type": "string"
          },
          "serviceGivenId": {
            "type": "string"
          },
          "serviceName": {
            "type": "string"
          },
          "serviceDomain": {
            "type": "string"
          },
          "loadBalancerDomain": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "Service": {
