{
  "openapi": "3.0.3",
  "info": {
    "title": "Mozilla Observatory API",
    "version": "1.0.0",
    "description": "The Mozilla HTTP Observatory API allows you to scan websites for HTTP security headers and best practices. It analyzes HTTP headers and security configurations, providing grades and actionable feedback.",
    "x-jentic-source-url": "https://developer.mozilla.org/en-US/observatory"
  },
  "servers": [
    {
      "url": "https://observatory-api.mdn.mozilla.net/api/v2"
    }
  ],
  "paths": {
    "/scan": {
      "post": {
        "operationId": "scanWebsite",
        "summary": "Scan a website",
        "description": "Initiates a scan of a domain for HTTP security headers and best practices. A site can only be scanned and return a new result every 60 seconds. If previous scan data is older than 24 hours, a rescan is automatically initiated.",
        "tags": ["Scan"],
        "parameters": [
          {
            "name": "host",
            "in": "query",
            "required": true,
            "description": "The hostname to scan (e.g., example.com)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Scan completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid hostname or parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limited - site was scanned less than 60 seconds ago",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ScanResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique scan identifier"
          },
          "details_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to view detailed scan results"
          },
          "algorithm_version": {
            "type": "integer",
            "description": "Version of the scoring algorithm used"
          },
          "scanned_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of when the scan was performed"
          },
          "error": {
            "type": "string",
            "nullable": true,
            "description": "Error message if the scan failed"
          },
          "grade": {
            "type": "string",
            "description": "Letter grade assigned to the scanned site (e.g., A+, A, B, C, D, F)"
          },
          "score": {
            "type": "integer",
            "description": "Numeric score out of 100 (can exceed 100 with bonus points)"
          },
          "status_code": {
            "type": "integer",
            "description": "HTTP status code received from the scanned site"
          },
          "tests_failed": {
            "type": "integer",
            "description": "Number of security tests that failed"
          },
          "tests_passed": {
            "type": "integer",
            "description": "Number of security tests that passed"
          },
          "tests_quantity": {
            "type": "integer",
            "description": "Total number of security tests performed"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}
