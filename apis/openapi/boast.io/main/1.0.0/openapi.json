            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Account ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of sequence enrollments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/SequenceEnrollment"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create A Sequence Enrollment",
        "description": "Creates a sequence enrollment for an account.",
        "operationId": "createSequenceEnrollment",
        "tags": [
          "Sequence Enrollments"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Account ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SequenceEnrollmentCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Sequence enrollment created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/SequenceEnrollment"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/sequence_enrollments/{enrollment_id}": {
      "get": {
        "summary": "Get a Specific Sequence Enrollment",
        "description": "Retrieves a single sequence enrollment.",
        "operationId": "getSequenceEnrollment",
        "tags": [
          "Sequence Enrollments"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Account ID"
          },
          {
            "name": "enrollment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Enrollment ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Sequence enrollment details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/SequenceEnrollment"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Remove a Sequence Enrollment",
        "description": "Removes a sequence enrollment.",
        "operationId": "deleteSequenceEnrollment",
        "tags": [
          "Sequence Enrollments"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Account ID"
          },
          {
            "name": "enrollment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Enrollment ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Sequence enrollment removed"
          }
        }
      }
    },
    "/accounts/{account_id}/webhook_subscriptions": {
      "get": {
        "summary": "Get All Webhook Subscriptions",
        "description": "Retrieves all webhook subscriptions for an account.",
        "operationId": "listWebhookSubscriptions",
        "tags": [
          "Webhook Subscriptions"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Account ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of webhook subscriptions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/WebhookSubscription"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create A Webhook Subscription",
        "description": "Creates a webhook subscription for an account.",
        "operationId": "createWebhookSubscription",
        "tags": [
          "Webhook Subscriptions"
        ],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Account ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscriptionCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/WebhookSubscription"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/webhook_subscriptions/{webhook_subscription_id}": {
      "delete": {
        "summary": "Destroy a Webhook Subscription",
        "description": "Deletes a webhook subscription.",
        "operationId": "deleteWebhookSubscription",
        "tags": [
          "Webhook Subscriptions"
        ],
        "parameters": [
          {
            "name": "account_id",
