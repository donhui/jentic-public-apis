{
  "openapi": "3.0.3",
  "info": {
    "title": "Assignar Public API",
    "version": "2.0.0",
    "description": "Assignar is a workforce and asset management platform for construction subcontractors and self-perform general contractors. Manage activities, allocations, assets, clients, contacts, orders, projects, site diaries, skills, and more.",
    "x-jentic-source-url": "https://assignar.github.io/api-docs/"
  },
  "servers": [
    {
      "url": "https://api.assignar.com.au/v2",
      "description": "Australia / New Zealand"
    },
    {
      "url": "https://api.assignar.com/v2",
      "description": "North America / Europe"
    }
  ],
