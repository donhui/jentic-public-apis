{
  "openapi": "3.0.3",
  "info": {
    "title": "Digidom API",
    "version": "1.0",
    "description": "Digidom is a French company incorporation and management service. The API provides access to manage organizations, documents, invoices, orders, subscriptions, leads, users, letters, payments, and other business entities for Digidom customers.",
    "x-jentic-source-url": "https://api.digidom.pro/v1"
  },
  "servers": [
    {
      "url": "https://api.digidom.pro/v1",
      "description": "Digidom API v1"
    }
  ],
