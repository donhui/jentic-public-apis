{
  "openapi": "3.0.3",
  "info": {
    "title": "MediaSilo API",
    "version": "1.5.0",
    "description": "MediaSilo RESTful API for media asset management. Manage projects, folders, assets, uploads, spotlights, links, metadata, and users programmatically.",
    "x-jentic-source-url": "http://docs.mediasilo.com/docs"
  },
  "servers": [
    {
      "url": "https://api.mediasilo.com/v3",
      "description": "MediaSilo API v3 Server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/projects": {
      "get": {
        "operationId": "listprojects",
        "summary": "Get all projects",
        "tags": [
          "Projects"
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createproject",
        "summary": "Create a project",
        "tags": [
          "Projects"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
