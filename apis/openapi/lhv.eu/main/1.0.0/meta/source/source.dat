{
  "openapi": "3.0.3",
  "info": {
    "title": "LHV Open Banking PSD2 REST API",
    "description": "<div><br>LHV Pank's implementation of the PSD2 specification. Current service has been built only as a demo to introduce the functionality. The performance, availability and the data accuracy is not guaranteed and may vary over time and without prior notice.</div> <br/><ul><li>To use the Sandbox API directly using your own software or some API testing tool like Postman you must also provide a transport layer certificate in your HTTP requests to API endpoints. In production environment this is the place where you shall use the eIDAS PSD2 compliant QWAC certificate. In the Sandbox API you should use a <a href=https://api.sandbox.lhv.eu/psd2/ui/certificate-authority>custom generated test certificate</a>.</li><br><li>Our API uses OAuth2 as a pre-step for PSU identification.<br> In current Sandbox implementation we allow you to skip this step and provide you with two pre-generated authorization tokens:<br><br> <code>Bearer Liis-MariMnnik</code> and <code>Bearer donaldduck</code><br><br> You can use the tokens by clicking on the Authorize button and entering it into the authorization form.</li><br>",
    "contact": {
      "name": "LHV",
      "url": "https://www.lhv.ee/en/",
      "email": "openbanking@lhv.ee"
    },
    "license": {
      "name": "LHV License",
      "url": "https://www.lhv.ee/en/terms-and-conditions"
    },
    "x-jentic-source-url": "https://api.sandbox.lhv.eu/psd2/documentation/api-docs",
    "version": "1.0.0"
  },
  "externalDocs": {
    "description": "LHV Open Banking",
    "url": "https://partners.lhv.ee/en/open-banking/"
  },
  "servers": [
    {
      "url": "https://api.sandbox.lhv.eu/psd2",
      "description": "Generated server url"
    }
  ],
  "security": [
    {
      "Bearer Token": []
    }
  ],
  "tags": [
    {
      "name": "Accounts Service",
      "description": "The Account Information Service allows the user to see a list of available accounts, details about a specific account, balances of a given account and list transaction reports for an account."
    },
    {
      "name": "Funds Confirmation Service",
      "description": "Confirmation of Funds Service returns a confirmation of funds availability"
    },
    {
      "name": "XML Payment Initiation Service",
      "description": "XML Payment Initiation Service enables the user to initiate, update and see the status of an XML payment"
    },
    {
      "name": "Funds Confirmation Consent Service",
      "description": "Service for requesting and terminating confirmation of funds consents"
    },
    {
      "name": "Payment Initiation Service",
      "description": "Payment Initiation Service enables the user to initiate, update and see the status of a payment"
    },
    {
      "name": "Consent Service",
      "description": "Service for requesting and terminating consents"
    }
  ],
  "paths": {
    "/admin/feature-flag/{featureName}": {
      "put": {
        "tags": [
          "feature-flags-controller"
        ],
        "operationId": "updateFeatureFlag",
        "parameters": [
          {
            "name": "featureName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeatureFlagUpdateRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeatureFlagDto"
                }
              }
            }
          }
        }
      }
    },
    "/v1/periodic-payments/sepa-credit-transfers": {
      "post": {
        "tags": [
          "Periodic Payment Service"
        ],
        "description": "Initiate a periodic payment",
        "operationId": "initiatePeriodicPayment",
        "parameters": [
          {
            "name": "PSU-Corporate-ID",
            "in": "header",
            "description": "Customer corporate registry code or private customer national id for expected customer validation purposes.",
            "required": false,
            "allowEmptyValue": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PSU-IP-Address",
            "in": "header",
            "description": "The forwarded IP Address. The corresponding HTTP request IP Address field between PSU and TPP.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "1.2.3.4"
          },
          {
            "name": "TPP-Redirect-Preferred",
            "in": "header",
            "description": "Whether or not to use transaction redirection. Not including this header is equivalent to setting it to true.",
            "schema": {
              "type": "boolean"
            },
            "example": true
          },
          {
            "name": "TPP-Redirect-URI",
            "in": "header",
            "description": "URI of the TPP, where the transaction flow will be redirected to. Mandatory if TPP-Redirect-Preferred header is set to true.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "TPP-Nok-Redirect-URI",
            "in": "header",
            "description": "URI, where the transaction flow will be redirected to in case of a negative result of the redirect SCA method.",
            "allowEmptyValue": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PeriodicPaymentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/hal+json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/PeriodicPaymentInitiationResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeriodicPaymentInitiationResponse"
                }
              },
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/PeriodicPaymentInitiationResponse"
                }
              },
              "application/json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/PeriodicPaymentInitiationResponse"
                }
              }
            }
          }
        }
      }
    },
