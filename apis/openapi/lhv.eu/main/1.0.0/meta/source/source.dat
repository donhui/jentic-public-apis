              "type": "string"
            },
            "example": "1.2.3.4"
          },
          {
            "name": "TPP-Redirect-Preferred",
            "in": "header",
            "description": "Whether or not to use transaction redirection. Not including this header is equivalent to setting it to true.",
            "schema": {
              "type": "boolean"
            },
            "example": true
          },
          {
            "name": "TPP-Redirect-URI",
            "in": "header",
            "description": "URI of the TPP, where the transaction flow will be redirected to. Mandatory if TPP-Redirect-Preferred header is set to true.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "TPP-Nok-Redirect-URI",
            "in": "header",
            "description": "URI, where the transaction flow will be redirected to in case of a negative result of the redirect SCA method.",
            "allowEmptyValue": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "requestBody": {
          "content": {
