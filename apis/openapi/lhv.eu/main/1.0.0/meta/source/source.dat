    "/v1/accounts/{resourceId}/transactions": {
      "get": {
        "tags": [
          "Accounts Service"
        ],
        "description": "Read account transactions information in json or xml CAMT.053 format",
        "operationId": "getTransactions",
        "parameters": [
          {
            "name": "Consent-ID",
            "in": "header",
            "description": "Value that was provided in the Request Consent phase",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "520189d2-e8bb-48ae-8221-45bed93b7316"
          },
          {
            "name": "dateFrom",
            "in": "query",
            "description": "Start date of the transaction list in yyyy-MM-dd format",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "example": "2020-01-14"
          },
          {
            "name": "dateTo",
            "in": "query",
            "description": "End date of the transaction list in yyyy-MM-dd format",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "bookingStatus",
            "in": "query",
            "description": "Requested booking status",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Possible booking statuses of a transaction",
              "enum": [
                "booked",
                "pending",
                "both"
              ]
            }
          },
          {
            "name": "resourceId",
            "in": "path",
            "description": "Resource ID",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "c0abf099-a4d9-4681-92ea-00a3088576c4"
          },
          {
            "name": "PSU-IP-Address",
            "in": "header",
            "description": "The forwarded IP Address. The corresponding HTTP request IP Address field between PSU and TPP.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "127.0.0.1"
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/hal+json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/AccountTransactionsResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountTransactionsResponse"
                }
              },
