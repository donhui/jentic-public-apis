    "/v1/funds-confirmations": {
      "post": {
        "tags": [
          "Funds Confirmation Service"
        ],
        "description": "Check the availability of funds",
        "operationId": "checkFundsAvailability",
        "parameters": [
          {
            "name": "Consent-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "requestBody": {
          "content": {
            "application/json;charset=UTF-8": {
              "schema": {
                "$ref": "#/components/schemas/FundsConfirmationsRequest"
              }
