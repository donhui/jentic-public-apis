              "ERROR",
              "WARNING"
            ]
          },
          "code": {
            "type": "string",
            "description": "TPP message code",
            "enum": [
              "OK",
              "TIMEOUT",
              "USER_REFUSED",
              "DOCUMENT_UNUSABLE",
              "WRONG_VC",
              "NOT_MID_CLIENT",
              "NOT_SID_CLIENT",
              "NOT_BIO_CLIENT",
              "USER_CANCELLED",
              "SIGNATURE_HASH_MISMATCH",
              "PHONE_ABSENT",
              "DELIVERY_ERROR",
              "SIM_ERROR",
              "CLIENT_NOT_SUPPORTED",
              "INVALID_SESSION_STATUS",
              "INTERNAL_ERROR",
              "NOT_FOUND",
              "BIOMETRY_NOT_FOUND",
              "BIOMETRY_NOT_ALLOWED",
              "BIO_SESSION_TIMEOUT",
              "REQUIRED_INTERACTION_NOT_SUPPORTED_BY_APP",
              "USER_REFUSED_CERT_CHOICE",
              "USER_REFUSED_DISPLAYTEXTANDPIN",
              "USER_REFUSED_VC_CHOICE",
              "USER_REFUSED_CONFIRMATIONMESSAGE",
              "USER_REFUSED_CONFIRMATIONMESSAGE_WITH_VC_CHOICE"
            ]
          },
          "text": {
            "type": "string",
            "description": "The text body of the TPP message"
          }
        }
      },
