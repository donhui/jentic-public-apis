    "/v1/consents": {
      "post": {
        "tags": [
          "Consent Service"
        ],
        "description": "Consent request",
        "operationId": "initiateConsent",
        "parameters": [
          {
            "name": "PSU-Corporate-ID",
            "in": "header",
            "description": "Customer corporate registry code or private customer national id for expected customer validation purposes.",
            "required": false,
            "allowEmptyValue": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PSU-IP-Address",
            "in": "header",
            "description": "The forwarded IP Address. The corresponding HTTP request IP Address field between PSU and TPP.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "1.2.3.4"
          },
          {
            "name": "TPP-Redirect-URI",
            "in": "header",
            "description": "Where to redirect the PSU after signing process. This might be changed to mandatory.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "http://lhv-redirect"
          },
          {
            "name": "TPP-Nok-Redirect-URI",
            "in": "header",
            "description": "Where to redirect the PSU after signing process fails.",
            "allowEmptyValue": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "TPP-Redirect-Preferred",
            "in": "header",
            "description": "Whether or not to use consent redirection. Not including this header is equivalent to setting it to true.",
            "schema": {
              "type": "boolean"
            },
            "example": true
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
