            "example": "96654490-0ad6-4cd3-b3a6-e9ca3fb5f22b"
          },
          {
            "name": "PSU-IP-Address",
            "in": "header",
            "description": "The forwarded IP Address. The corresponding HTTP request IP Address field between PSU and TPP.",
            "schema": {
              "type": "string"
            },
            "example": "1.2.3.4"
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "requestBody": {
          "content": {
            "application/json;charset=UTF-8": {
              "schema": {
                "$ref": "#/components/schemas/AuthorisationStartRequest"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthorisationStartRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/hal+json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/DecoupledSigningResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DecoupledSigningResponse"
                }
              },
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/DecoupledSigningResponse"
                }
              },
              "application/json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/DecoupledSigningResponse"
                }
              }
            }
          }
        }
      }
    },
