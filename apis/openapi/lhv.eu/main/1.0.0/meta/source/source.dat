      "PeriodicPaymentInformationResponse": {
        "type": "object",
        "description": "Periodic payment information response",
        "properties": {
          "paymentId": {
            "type": "string",
            "description": "Periodic payment identifier"
          },
          "transactionStatus": {
            "type": "string",
            "description": "Periodic payment transaction status",
            "enum": [
              "RCVD",
              "RJCT",
              "CANC",
              "ACSP",
              "ACSC"
            ]
          },
          "instructedAmount": {
            "$ref": "#/components/schemas/Amount"
          },
          "debtorName": {
            "type": "string",
            "description": "Name of the debtor",
            "example": "Liis-Mari"
          },
          "debtorAccount": {
            "$ref": "#/components/schemas/AccountReference"
          },
          "creditorName": {
            "type": "string",
            "description": "Name of the creditor",
            "example": "Donald Duck"
          },
          "creditorAccount": {
            "$ref": "#/components/schemas/AccountReference"
          },
          "remittanceInformationUnstructured": {
            "type": "string",
            "example": "Sample payment 1 to Donald Duck"
          },
          "remittanceInformationStructured": {
            "$ref": "#/components/schemas/RemittanceInformationStructured"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "example": "2099-10-21"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "example": "2199-11-22"
          },
          "frequency": {
            "type": "string",
            "enum": [
              "DAILY",
              "WEEKLY",
              "MONTHLY",
              "QUARTERLY",
              "SEMIANNUAL",
              "ANNUAL"
            ],
            "example": "MONTHLY"
          },
          "scaMethods": {
            "type": "array",
            "description": "Available SCA methods for signing the periodic payment",
            "items": {
              "$ref": "#/components/schemas/ScaMethod"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        },
        "required": [
          "startDate"
        ]
      },
      "PeriodicPaymentStatusResponse": {
        "type": "object",
