    "/v1/accounts/{resourceId}/balances": {
      "get": {
        "tags": [
          "Accounts Service"
        ],
        "description": "Read account balances information",
        "operationId": "getBalances",
        "parameters": [
          {
            "name": "Consent-ID",
            "in": "header",
            "description": "Value that was provided in the Request Consent phase",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "520189d2-e8bb-48ae-8221-45bed93b7316"
          },
          {
            "name": "resourceId",
            "in": "path",
            "description": "Resource ID",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "c0abf099-a4d9-4681-92ea-00a3088576c4"
          },
          {
            "name": "PSU-IP-Address",
            "in": "header",
            "description": "The forwarded IP Address. The corresponding HTTP request IP Address field between PSU and TPP.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "127.0.0.1"
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/hal+json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/AccountBalancesResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountBalancesResponse"
                }
              },
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountBalancesResponse"
                }
              },
              "application/json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/AccountBalancesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts-list": {
      "get": {
        "tags": [
          "Accounts Service"
        ],
        "description": "Read basic accounts list without previous consent",
        "operationId": "getAccountsListWithoutConsent",
        "parameters": [
          {
            "name": "PSU-Corporate-ID",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "onlyActive",
            "in": "query",
            "description": "Show only accounts with status ENABLED",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/hal+json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/AccountsListWithoutConsentResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountsListWithoutConsentResponse"
                }
              },
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountsListWithoutConsentResponse"
                }
              },
              "application/json;charset=UTF-8": {
                "schema": {
                  "$ref": "#/components/schemas/AccountsListWithoutConsentResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/feature-flag": {
      "get": {
        "tags": [
          "feature-flags-controller"
        ],
        "operationId": "getFeatureFlags",
        "parameters": [
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Unique ID specified by the TPP",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "99391c7e-ad88-49ec-a2ad-99ddcb1f7721"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeatureFlagsResponseDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FeatureFlagUpdateRequestDto": {
        "type": "object",
        "properties": {
          "featureEnabled": {
            "type": "boolean"
          }
        }
      },
      "FeatureFlagDto": {
        "type": "object",
        "properties": {
          "featureName": {
            "type": "string"
          },
          "featureEnabled": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "modifiedDTime": {
            "type": "string",
            "format": "date-time"
          },
          "modifiedBy": {
            "type": "string"
          }
        }
      },
      "AccountReference": {
        "type": "object",
        "description": "Reference to an account by IBAN",
        "properties": {
          "iban": {
            "type": "string",
            "description": "IBAN of an account",
            "example": "EE717700771001735865",
            "pattern": "[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}"
          }
        },
        "required": [
          "iban"
        ]
      },
      "Amount": {
        "type": "object",
        "description": "The total amount with used currency",
        "properties": {
          "currency": {
            "type": "string",
            "description": "ISO 4217 Alpha 3 currency code",
            "example": "EUR",
            "pattern": "[A-Z]{3}"
          },
          "amount": {
            "type": "string",
            "description": "The amount given with fractional digits",
            "example": 25.55
          }
        },
        "required": [
          "amount",
          "currency"
        ]
      },
      "PeriodicPaymentRequest": {
        "type": "object",
        "description": "Periodic payment request object",
        "properties": {
          "debtorAccount": {
            "$ref": "#/components/schemas/AccountReference"
          },
          "instructedAmount": {
            "$ref": "#/components/schemas/Amount"
          },
          "creditorAccount": {
            "$ref": "#/components/schemas/AccountReference"
          },
          "creditorName": {
            "type": "string",
            "description": "Name of the creditor",
            "example": "Donald Duck",
            "maxLength": 70,
            "minLength": 0
          },
          "remittanceInformationUnstructured": {
            "type": "string",
            "example": "Payment to Donald Duck",
            "maxLength": 140,
            "minLength": 0
          },
          "remittanceInformationStructured": {
            "$ref": "#/components/schemas/RemittanceInformationStructured"
          },
          "requestedExecutionDate": {
            "type": "string",
            "format": "date",
            "description": "Future payment requested execution date",
            "example": "2022-05-18"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "example": "2099-10-21"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "example": "2199-11-22"
          },
          "frequency": {
            "type": "string",
            "example": "Monthly"
          }
        },
        "required": [
          "creditorAccount",
          "creditorName",
          "frequency",
          "instructedAmount",
          "startDate"
        ]
      },
      "RemittanceInformationStructured": {
        "type": "object",
        "properties": {
          "reference": {
            "type": "string",
            "example": "Reference example",
            "maxLength": 35,
            "minLength": 0
          }
        },
        "required": [
          "reference"
        ]
      },
      "PeriodicPaymentInitiationResponse": {
        "type": "object",
        "description": "Periodic payment initiation response",
        "properties": {
          "transactionStatus": {
            "type": "string",
            "description": "Periodic payment transaction status",
            "enum": [
              "ACCP",
              "ACSC",
              "ACSP",
              "ACTC",
              "ACWC",
              "ACWP",
              "RCVD",
              "PART",
              "PATC",
              "PDNG",
              "RJCT",
              "CANC"
            ]
          },
          "paymentId": {
            "type": "string",
            "description": "Generated periodic payment identifier"
          },
          "scaMethods": {
            "type": "array",
            "description": "Available SCA methods for signing the periodic payment",
            "items": {
              "$ref": "#/components/schemas/ScaMethod"
            }
          },
          "tppMessages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TppMessage"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "ScaMethod": {
        "type": "object",
        "description": "Strong customer authentication method",
        "properties": {
          "authenticationType": {
            "type": "string",
            "description": "Authentication type",
            "enum": [
              "SMS_OTP",
              "PUSH_OTP"
            ]
          },
          "authenticationMethodId": {
            "type": "string",
            "description": "Authentication method",
            "enum": [
              "MID",
              "SID"
            ]
          },
          "name": {
            "type": "string"
          }
        }
      },
      "TppMessage": {
        "type": "object",
        "description": "Third party provider message",
        "properties": {
          "category": {
            "type": "string",
            "description": "Category of the TPP message",
            "enum": [
              "ERROR",
              "WARNING"
            ]
          },
          "code": {
            "type": "string",
            "description": "TPP message code",
            "enum": [
              "TOKEN_UNKNOWN",
              "TOKEN_INVALID",
              "DEPRECATED",
              "CERTIFICATE_INVALID",
              "CERTIFICATE_MISSING",
              "CERTIFICATE_REVOKED",
              "CERTIFICATE_EXPIRED",
              "SERVICE_INVALID",
              "FORMAT_ERROR",
              "PSU_CREDENTIALS_INVALID",
              "CONSENT_UNKNOWN",
              "CONSENT_INVALID",
              "CONSENT_EXPIRED",
              "CONSENT_REPLACED",
              "RESOURCE_UNKNOWN",
              "RESOURCE_BLOCKED",
              "SERVICE_BLOCKED",
              "PAYMENT_FAILED",
              "PAYMENT_PROCESSING",
              "CONTENT_INVALID",
              "PERIOD_INVALID",
              "AUTHORISATION_FAILED",
              "ROLE_INVALID",
              "CARD_INVALID",
              "ACCESS_EXCEEDED",
              "BAD_REQUEST",
              "INTERNAL_SERVER_ERROR",
              "STATUS_INVALID",
              "ROLE_UNAVAILABLE",
              "CANCELLATION_INVALID"
            ]
          },
          "path": {
            "type": "string",
            "description": "Path"
          },
          "text": {
            "type": "string",
            "description": "The text body of the TPP message"
          }
        }
      },
      "AuthorisationStartRequest": {
        "type": "object",
        "description": "Authorisation start request",
        "properties": {
          "authenticationMethodId": {
            "type": "string",
            "enum": [
              "MID",
              "SID",
              "BIO"
            ]
          },
          "scaAuthenticationData": {
            "type": "string",
            "description": "Phone number for MID approach",
            "example": "+372512345678"
          }
        },
        "required": [
          "authenticationMethodId"
        ]
      },
      "ChallengeData": {
        "type": "object",
        "properties": {
          "data": {
            "type": "string"
          },
          "additionalInformation": {
            "type": "string"
          }
        }
      },
      "ChosenScaMethod": {
        "type": "object",
        "properties": {
          "authenticationType": {
            "type": "string"
          },
          "authenticationMethodId": {
            "type": "string"
          }
        }
      },
      "DecoupledSigningResponse": {
        "type": "object",
        "properties": {
          "authorisationId": {
            "type": "string"
          },
          "scaStatus": {
            "type": "string"
          },
          "chosenScaMethod": {
            "$ref": "#/components/schemas/ChosenScaMethod"
          },
          "challengeData": {
            "$ref": "#/components/schemas/ChallengeData"
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "XmlPaymentResponse": {
        "type": "object",
        "description": "XML payment response",
        "properties": {
          "transactionStatus": {
            "type": "string",
            "description": "XML payment's transaction status",
            "enum": [
              "ACCP",
              "ACSC",
              "ACSP",
              "ACTC",
              "ACWC",
              "ACWP",
              "RCVD",
              "PART",
              "PATC",
              "PDNG",
              "RJCT",
              "CANC"
            ]
          },
          "paymentId": {
            "type": "string",
            "description": "Generated XML payment identifier"
          },
          "scaMethods": {
            "type": "array",
            "description": "Available SCA methods for signing the XML payment",
            "items": {
              "$ref": "#/components/schemas/ScaMethod"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "DecoupledXmlSigningResponse": {
        "type": "object",
        "properties": {
          "authorisationId": {
            "type": "string"
          },
          "scaStatus": {
            "type": "string"
          },
          "chosenScaMethod": {
            "$ref": "#/components/schemas/ChosenScaMethod"
          },
          "challengeData": {
            "$ref": "#/components/schemas/ChallengeData"
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "StartDecoupledOAuthRequest": {
        "type": "object",
        "description": "Authorisation start request",
        "properties": {
          "authenticationMethodId": {
            "type": "string",
            "enum": [
              "BIO",
              "MID",
              "SID",
              "PIN",
              "EID"
            ]
          },
          "scaAuthenticationData": {
            "type": "string",
            "description": "Phone number for MID approach",
            "example": "+372512345678"
          }
        },
        "required": [
          "authenticationMethodId"
        ]
      },
      "DecoupledOAuthResponse": {
        "type": "object",
        "properties": {
          "authorisationId": {
            "type": "string"
          },
          "scaStatus": {
            "type": "string",
            "description": "Status of an OAuth authentication",
            "enum": [
              "RECEIVED",
              "PSU_IDENTIFIED",
              "PSU_AUTHENTICATED",
              "SCA_METHOD_SELECTED",
              "STARTED",
              "UNCONFIRMED",
              "FAILED",
              "EXEMPTED",
              "FINALISED",
              "SPENT",
              "CANCELLED"
            ]
          },
          "chosenScaMethod": {
            "$ref": "#/components/schemas/ScaMethod"
          },
          "challengeData": {
            "$ref": "#/components/schemas/ChallengeData"
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "FundsConfirmationsRequest": {
        "type": "object",
        "description": "Funds Confirmations request object",
        "properties": {
          "account": {
            "$ref": "#/components/schemas/AccountReference",
            "description": "Payment Service User’s account"
          },
          "instructedAmount": {
            "$ref": "#/components/schemas/Amount",
            "description": "The amount to be checked"
          }
        },
        "required": [
          "account",
          "instructedAmount"
        ]
      },
      "FundsConfirmationsResponse": {
        "type": "object",
        "description": "Funds Confirmations response object",
        "properties": {
          "fundsAvailable": {
            "type": "boolean",
            "description": "Represents the truth value indicating the availability of funds"
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "AccessReference": {
        "type": "object",
        "description": "Reference to an balances and transactions",
        "properties": {
          "balances": {
            "type": "array",
            "description": "List of balances",
            "items": {
              "$ref": "#/components/schemas/AccountReference"
            }
          },
          "transactions": {
            "type": "array",
            "description": "List of transactions",
            "items": {
              "$ref": "#/components/schemas/AccountReference"
            }
          },
          "availableAccounts": {
            "type": "string",
            "description": "Only the values \"allAccounts\" or \"allAccountsWithBalances\" is admitted.",
            "example": "allAccounts"
          }
        }
      },
      "ConsentRequest": {
        "type": "object",
        "description": "Consent request",
        "properties": {
          "access": {
            "$ref": "#/components/schemas/AccessReference"
          },
          "recurringIndicator": {
            "type": "boolean",
            "description": "Whether the consent is a long-term or a short-term consent"
          },
          "validUntil": {
            "type": "string",
            "format": "date",
            "example": "2019-11-01"
          },
          "frequencyPerDay": {
            "type": "integer",
            "format": "int32",
            "description": "Amount of requests allowed per day. Ignored for short-term consents",
            "example": 50
          },
          "combinedServiceIndicator": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "access",
          "recurringIndicator",
          "validUntil"
        ]
      },
      "ConsentResponse": {
        "type": "object",
        "description": "Consent response object",
        "properties": {
          "consentStatus": {
            "type": "string",
            "description": "Consent status",
            "enum": [
              "received",
              "rejected",
              "valid",
              "expired",
              "revokedByPsu",
              "terminatedByTpp"
            ]
          },
          "consentId": {
            "type": "string",
            "description": "Generated consent identifier"
          },
          "scaMethods": {
            "type": "array",
            "description": "Available SCA methods for signing the consent",
            "items": {
              "$ref": "#/components/schemas/ScaMethod"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "FundsConfirmationConsentRequest": {
        "type": "object",
        "description": "Consent request",
        "properties": {
          "account": {
            "$ref": "#/components/schemas/AccountReference"
          }
        },
        "required": [
          "account"
        ]
      },
      "PaymentRequest": {
        "type": "object",
        "description": "Payment request object",
        "properties": {
          "debtorAccount": {
            "$ref": "#/components/schemas/AccountReference"
          },
          "instructedAmount": {
            "$ref": "#/components/schemas/Amount"
          },
          "creditorAccount": {
            "$ref": "#/components/schemas/AccountReference"
          },
          "creditorName": {
            "type": "string",
            "description": "Name of the creditor",
            "example": "Donald Duck",
            "maxLength": 70,
            "minLength": 0
          },
          "remittanceInformationUnstructured": {
            "type": "string",
            "example": "Payment to Donald Duck",
            "maxLength": 140,
            "minLength": 0
          },
          "remittanceInformationStructured": {
            "$ref": "#/components/schemas/RemittanceInformationStructured"
          },
          "requestedExecutionDate": {
            "type": "string",
            "format": "date",
            "description": "Future payment requested execution date",
            "example": "2022-05-18"
          }
        },
        "required": [
          "creditorAccount",
          "creditorName",
          "instructedAmount"
        ]
      },
      "PaymentResponse": {
        "type": "object",
        "description": "Payment response object",
        "properties": {
          "transactionStatus": {
            "type": "string",
            "description": "Payment's status code",
            "enum": [
              "ACCP",
              "ACSC",
              "ACSP",
              "ACTC",
              "ACWC",
              "ACWP",
              "RCVD",
              "PART",
              "PATC",
              "PDNG",
              "RJCT",
              "CANC"
            ]
          },
          "paymentId": {
            "type": "string",
            "description": "Generated payment identifier"
          },
          "scaMethods": {
            "type": "array",
            "description": "Available SCA methods for signing the payment",
            "items": {
              "$ref": "#/components/schemas/ScaMethod"
            }
          },
          "tppMessages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TppMessage"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
