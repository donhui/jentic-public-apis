        "type": "object",
        "description": "Consent information response object",
        "properties": {
          "access": {
            "$ref": "#/components/schemas/AccessReference",
            "description": "Requested access services for a consent."
          },
          "recurringIndicator": {
            "type": "boolean",
            "description": "\"true\", if the consent is for recurring access to the account data. \n \"false\", if the consent is for one access to the account data."
          },
          "validUntil": {
            "type": "string",
            "format": "date",
            "description": "This parameter is requesting a valid until date for the requested consent."
          },
          "frequencyPerDay": {
            "type": "integer",
            "format": "int32",
            "description": "This field indicates the requested maximum frequency for an access without PSU involvement per day."
          },
          "lastActionDate": {
            "type": "string",
            "format": "date",
            "description": "This date is containing the date of the last action on the consent object either through the XS2A interface or the PSU/ASPSP interface having an impact on the status."
          },
          "consentStatus": {
            "type": "string",
            "description": "Consent status",
            "enum": [
              "received",
              "rejected",
              "valid",
              "expired",
              "revokedByPsu",
              "terminatedByTpp"
            ]
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "ConsentStatusResponse": {
        "type": "object",
        "description": "Consent status response",
        "properties": {
          "consentStatus": {
            "type": "string",
            "description": "Consent status",
            "enum": [
              "received",
              "rejected",
              "valid",
              "expired",
              "revokedByPsu",
              "terminatedByTpp"
            ]
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "FundsConfirmationConsentResponse": {
        "type": "object",
        "description": "Consent response object",
        "properties": {
          "accountReference": {
            "$ref": "#/components/schemas/AccountReference",
            "description": "Account"
          },
          "consentStatus": {
            "type": "string",
            "description": "Consent status",
            "enum": [
              "received",
              "rejected",
              "valid",
              "expired",
              "revokedByPsu",
              "terminatedByTpp"
            ]
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "FundsConfirmationConsentStatusResponse": {
        "type": "object",
        "description": "Consent status response object",
        "properties": {
          "consentStatus": {
            "type": "string",
            "description": "Consent status",
            "enum": [
              "received",
              "rejected",
              "valid",
              "expired",
              "revokedByPsu",
              "terminatedByTpp"
            ]
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "AccountResponse": {
        "type": "object",
        "description": "Account response object",
        "properties": {
          "resourceId": {
            "type": "string",
            "description": "Resource ID"
          },
          "iban": {
            "type": "string",
            "description": "IBAN of an account",
            "example": "EE124567"
          },
          "ownerName": {
            "type": "string",
            "description": "Name of account owner",
            "example": "Peter Tamm"
          },
          "currency": {
            "type": "string",
            "description": "Currency code",
            "example": "EUR"
          },
          "product": {
            "type": "string",
            "example": "Multi currency account"
          },
          "cashAccountType": {
            "type": "string",
            "example": "CACC"
          },
          "name": {
            "type": "string",
            "description": "Account nickname"
          },
          "status": {
            "type": "string",
            "description": "Account status",
            "example": "enabled"
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        },
        "required": [
          "cashAccountType",
          "currency",
          "iban",
          "product",
          "resourceId"
        ]
      },
      "AccountsListResponse": {
        "type": "object",
        "description": "Accounts response object",
        "properties": {
          "List of accounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccountResponse"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "AccountInformationResponse": {
        "type": "object",
        "properties": {
          "account": {
            "$ref": "#/components/schemas/AccountResponse"
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "AccountTransactions": {
        "type": "object",
        "description": "Account transactions",
        "properties": {
          "booked": {
            "type": "array",
            "description": "List of booked transactions",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          },
          "pending": {
            "type": "array",
            "description": "List of pending transactions",
            "items": {
              "$ref": "#/components/schemas/PendingTransaction"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "AccountTransactionsResponse": {
        "type": "object",
        "description": "Account transactions response object",
        "properties": {
          "account": {
            "$ref": "#/components/schemas/AccountReference",
            "description": "Account reference"
          },
          "transactions": {
            "$ref": "#/components/schemas/AccountTransactions",
            "description": "Account transactions"
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "PendingTransaction": {
        "type": "object",
        "description": "Account pending transaction object",
        "properties": {
          "reservationDate": {
            "type": "string",
            "format": "date",
            "description": "Date of the reservation on the account"
          },
          "remittanceInformationUnstructured": {
            "type": "string",
            "description": "Free-text payment reference information"
          },
          "transactionAmount": {
            "$ref": "#/components/schemas/Amount",
            "description": "Transaction amount"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "description": "Account transaction object",
        "properties": {
          "entryReference": {
            "type": "string",
            "description": "Unique identifier for the given transaction"
          },
          "bookingDate": {
            "type": "string",
            "format": "date",
            "description": "Date of the related booking on the account"
          },
          "transactionAmount": {
            "$ref": "#/components/schemas/Amount",
            "description": "Transaction amount"
          },
          "creditorName": {
            "type": "string",
            "description": "Name of the creditor"
          },
          "creditorAccount": {
            "$ref": "#/components/schemas/AccountReference",
            "description": "Creditor's account"
          },
          "debtorName": {
            "type": "string",
            "description": "Name of the debtor"
          },
          "debtorAccount": {
            "$ref": "#/components/schemas/AccountReference",
            "description": "Debtor's account"
          },
          "remittanceInformationUnstructured": {
            "type": "string",
            "description": "Unstructured remittance information"
          },
          "remittanceInformationStructured": {
            "type": "string",
            "description": "Structured remittance information"
          },
          "bankTransactionCode": {
            "type": "string",
            "description": "Iso code of bank transaction"
          }
        },
        "required": [
          "bookingDate",
          "entryReference",
          "transactionAmount"
        ]
      },
      "AccountBalancesResponse": {
        "type": "object",
        "description": "Account balances response object",
        "properties": {
          "account": {
            "$ref": "#/components/schemas/AccountReference",
            "description": "Account reference with corresponding iban"
          },
          "balances": {
            "type": "array",
            "description": "Collection of balances",
            "items": {
              "$ref": "#/components/schemas/Balance"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "Balance": {
        "type": "object",
        "description": "Balance object",
        "properties": {
          "balanceType": {
            "type": "string",
            "description": "The type of the balance",
            "enum": [
              "interimAvailable",
              "interimBooked"
            ]
          },
          "balanceAmount": {
            "$ref": "#/components/schemas/Amount",
            "description": "The amount including currency and the amount"
          }
        },
        "required": [
          "balanceAmount",
          "balanceType"
        ]
      },
      "Account": {
        "type": "object",
        "description": "Account response object",
        "properties": {
          "iban": {
            "type": "string",
            "description": "IBAN of an account",
            "example": "EE124567"
          },
          "ownerName": {
            "type": "string",
            "description": "Name of account owner",
            "example": "Peter Tamm"
          },
          "currency": {
            "type": "string",
            "description": "Currency code",
            "example": "EUR"
          },
          "name": {
            "type": "string",
            "description": "Account nickname"
          },
          "product": {
            "type": "string",
            "description": "Account type",
            "example": "Multi currency account"
          },
          "cashAccountType": {
            "type": "string",
            "description": "Cash account type",
            "example": "CARD"
          },
          "status": {
            "type": "string",
            "description": "Account status",
            "example": "enabled"
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        },
        "required": [
          "currency",
          "iban"
        ]
      },
      "AccountsListWithoutConsentResponse": {
        "type": "object",
        "description": "Basic accounts list response object",
        "properties": {
          "List of accounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Account"
            }
          },
          "_links": {
            "$ref": "#/components/schemas/Links",
            "additionalProperties": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "FeatureFlagsResponseDto": {
        "type": "object",
        "properties": {
          "featureFlags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FeatureFlagDto"
            }
          }
        }
      },
      "Link": {
        "type": "object",
        "properties": {
          "href": {
            "type": "string"
          },
          "hreflang": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "deprecation": {
            "type": "string"
          },
          "profile": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "templated": {
            "type": "boolean"
          }
        }
      },
      "Links": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/components/schemas/Link"
        }
      }
    },
    "securitySchemes": {
      "Bearer Token": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
