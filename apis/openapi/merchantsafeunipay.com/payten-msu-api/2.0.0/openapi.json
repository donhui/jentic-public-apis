  "components": {
    "schemas": {
      "SessionRequest": {
        "type": "object",
        "properties": {
          "MERCHANTUSER": {
            "type": "string"
          },
          "MERCHANTPASSWORD": {
            "type": "string"
          },
          "MERCHANT": {
            "type": "string"
          },
          "AMOUNT": {
            "type": "string"
          },
          "CURRENCY": {
            "type": "string"
          },
          "CUSTOMER": {
            "type": "string"
          }
        }
      },
      "SessionResponse": {
        "type": "object",
        "properties": {
          "responseCode": {
            "type": "string"
          },
          "responseMsg": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "TransactionRequest": {
        "type": "object",
        "required": [
          "ACTION",
          "SESSIONTOKEN"
        ],
        "properties": {
          "ACTION": {
            "type": "string"
          },
          "SESSIONTOKEN": {
            "type": "string"
          },
          "AMOUNT": {
            "type": "string"
          },
          "CURRENCY": {
            "type": "string"
          },
          "MERCHANTUSER": {
            "type": "string"
          },
          "MERCHANTPASSWORD": {
            "type": "string"
          },
          "MERCHANT": {
            "type": "string"
          }
        }
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "responseCode": {
            "type": "string",
            "enum": [
              "00",
              "01",
              "98",
              "99"
            ]
          },
          "responseMsg": {
            "type": "string"
          },
          "orderId": {
            "type": "string"
          },
          "transactionId": {
            "type": "string"
          }
        }
      },
      "PostAuthRequest": {
