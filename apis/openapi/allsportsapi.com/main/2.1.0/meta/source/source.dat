{
  "openapi": "3.0.3",
  "info": {
    "title": "All Sports Football API",
    "version": "2.1.0",
    "description": "Football (soccer) API providing live scores, fixtures, standings, team and player data, odds, and more across global leagues and competitions.",
    "x-jentic-source-url": "https://allsportsapi.com/soccer-football-api-documentation"
  },
  "servers": [
    {
      "url": "https://apiv2.allsportsapi.com"
    }
  ],
  "paths": {
    "/football/": {
      "get": {
        "operationId": "getFootballData",
        "summary": "Query football data by method type",
        "description": "A single endpoint that serves multiple data types based on the 'met' query parameter.",
        "tags": ["Football"],
        "parameters": [
          {
            "name": "met",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "Countries",
                "Leagues",
                "Fixtures",
                "H2H",
                "Livescore",
                "Standings",
                "Topscorers",
                "Teams",
                "Players",
                "Videos",
                "Odds",
                "Probabilities",
                "OddsLive",
                "Comments",
                "FullOdds"
              ]
            },
            "description": "The method/data type to query"
          },
          {
            "name": "APIkey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your API authorization key"
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for date-range queries (YYYY-MM-DD)"
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for date-range queries (YYYY-MM-DD)"
          },
          {
            "name": "timezone",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Timezone for results (e.g., Europe/London)"
          },
          {
            "name": "countryId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by country ID"
          },
          {
            "name": "leagueId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by league/competition ID"
          },
          {
            "name": "matchId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by specific match ID"
          },
          {
            "name": "teamId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by team ID"
          },
          {
            "name": "playerId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by player ID"
          },
          {
            "name": "playerName",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by player name"
          },
          {
            "name": "teamName",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by team name"
          },
          {
            "name": "firstTeamId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "First team ID for H2H queries"
          },
          {
            "name": "secondTeamId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Second team ID for H2H queries"
          },
          {
            "name": "leagueGroup",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by league group"
          },
          {
            "name": "withPlayerStats",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include player statistics in response"
          },
          {
            "name": "live",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Filter for live matches only"
          },
          {
            "name": "eventId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Event ID for video queries"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "APIkey",
        "description": "API key provided upon subscription"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "integer",
            "enum": [0, 1]
          },
          "result": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}