    "/v1/references/users_and_resources": {
      "get": {
        "operationId": "listUsersAndResources",
        "summary": "List users and resources",
        "description": "Retrieve users and resources in the workspace.",
        "tags": ["References"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of users and resources",
            "content": {
              "application/json": {
                "schema": {
