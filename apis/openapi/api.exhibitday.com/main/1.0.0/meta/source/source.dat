  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "api_key",
        "description": "API key obtained from Workspace Settings > API & Integrations > API Access"
      }
    },
    "schemas": {
      "Event": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "name": { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "participation_type_id": { "type": "number" },
          "format_id": { "type": "number" },
          "star_rating": { "type": "number" },
          "website_url": { "type": "string" },
          "venue_name": { "type": "string" },
          "booth_size": { "type": "number" },
          "booth_number": { "type": "number" },
          "event_notes": { "type": "string" },
          "booth_notes": { "type": "string" },
          "budget_notes": { "type": "string" },
          "roi_notes": { "type": "string" },
          "budget_booth_reservation": { "type": "number" },
          "budget_booth_services": { "type": "number" },
          "budget_attendee_registrations": { "type": "number" },
          "budget_travel": { "type": "number" },
          "budget_giveaways": { "type": "number" },
          "budget_shipments": { "type": "number" },
          "budget_misc_expenses": { "type": "number" },
          "budget_sponsorships": { "type": "number" },
          "roi_num_leads": { "type": "integer" },
          "roi_num_impressions_booth": { "type": "integer" },
          "roi_num_impressions_sponsorships": { "type": "integer" },
          "roi_num_impressions_media": { "type": "integer" },
          "roi_num_meetings_existing_customers": { "type": "integer" },
          "roi_num_meetings_new_customers": { "type": "integer" },
          "roi_amount_actual_sales": { "type": "number" },
          "roi_amount_potential_sales": { "type": "number" }
        }
      },
      "MiscExpenseCredit": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "event_id": { "type": "number" },
          "description": { "type": "string" },
          "is_credit": { "type": "boolean" },
          "amount": { "type": "number" },
          "payment_status_id": { "type": "number" },
          "payment_due_date": { "type": "string", "format": "date" },
          "next_payment_due_date": { "type": "string", "format": "date" },
          "payment_notes": { "type": "string" },
          "notes": { "type": "string" }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "name": { "type": "string" },
          "event_id": { "type": "number" },
          "task_section_id": { "type": "number" },
          "is_completed": { "type": "boolean" },
          "due_date": { "type": "string", "format": "date" },
          "assignee_user_id": { "type": "string" },
          "details": { "type": "string" }
        }
      },
      "TaskComment": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "task_id": { "type": "number" },
          "comment": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "EventCost": {
        "type": "object",
        "properties": {
          "event_id": { "type": "number" },
          "event_name": { "type": "string" },
          "total_cost": { "type": "number" },
          "budget": { "type": "number" }
        }
      },
      "AnnualExpenseCost": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "description": { "type": "string" },
          "amount": { "type": "number" },
          "budget_year": { "type": "number" }
        }
      },
      "ReferenceItem": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "name": { "type": "string" }
        }
      },
      "UserResource": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "can_have_tasks_assigned": { "type": "boolean" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}