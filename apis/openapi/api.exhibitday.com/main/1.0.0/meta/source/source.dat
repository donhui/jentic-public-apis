{
  "openapi": "3.0.3",
  "info": {
    "title": "ExhibitDay API",
    "description": "ExhibitDay is a trade show planning and event project management platform. The API provides CRUD operations for events, tasks, task comments, miscellaneous expenses/credits, financials, and reference data.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.exhibitday.com"
  },
  "servers": [
    {
      "url": "https://api.exhibitday.com",
      "description": "ExhibitDay API server"
    }
  ],
  "tags": [
    {
      "name": "Events",
      "description": "Manage trade show events"
    },
    {
      "name": "Misc Expenses/Credits",
      "description": "Manage miscellaneous expenses and credits for events"
    },
    {
      "name": "Tasks",
      "description": "Manage event and general tasks"
    },
    {
      "name": "Task Comments",
      "description": "Manage comments on tasks"
    },
    {
      "name": "Financials",
      "description": "Retrieve financial data for events"
    },
    {
      "name": "References",
      "description": "Read-only reference data"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/v1/events/": {
      "get": {
        "operationId": "listEvents",
        "summary": "Retrieve events",
        "description": "Retrieve a list of events with extensive filtering options.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key for authentication"
          },
          {
            "name": "filter_by_event_name_contains_text",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter events by name containing text"
          },
          {
            "name": "filter_by_start_date_greater_than_or_equal_to",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" },
            "description": "Filter by start date (YYYY-MM-DD)"
          },
          {
            "name": "filter_by_start_date_smaller_than_or_equal_to",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" },
            "description": "Filter by start date upper bound (YYYY-MM-DD)"
          },
          {
            "name": "filter_by_end_date_greater_than_or_equal_to",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" },
            "description": "Filter by end date (YYYY-MM-DD)"
          },
          {
            "name": "filter_by_end_date_smaller_than_or_equal_to",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" },
            "description": "Filter by end date upper bound (YYYY-MM-DD)"
          },
          {
            "name": "filter_by_event_participation_type_id",
            "in": "header",
            "required": false,
            "schema": { "type": "number" },
            "description": "Filter by participation type ID"
          },
          {
            "name": "filter_by_event_format_id",
            "in": "header",
            "required": false,
            "schema": { "type": "number" },
            "description": "Filter by event format (1=In-Person, 2=Virtual, 3=Hybrid)"
          },
          {
            "name": "filter_by_event_star_rating",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0, "maximum": 3 },
            "description": "Filter by star rating (0-3)"
          },
          {
            "name": "filter_by_event_tag",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter by event tag"
          },
          {
            "name": "hydrate_tasks",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "default": "false" },
            "description": "Include task data"
          },
          {
            "name": "hydrate_task_sections_list",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "default": "false" },
            "description": "Include task sections list"
          },
          {
            "name": "hydrate_event_misc_expenses_and_credits",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "default": "false" },
            "description": "Include misc expenses/credits data"
          },
          {
            "name": "hydrate_custom_fields",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "default": "false" },
            "description": "Include custom fields data"
          }
        ],
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Event" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded (max 50 calls/second)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "addEvent",
        "summary": "Add an event",
        "description": "Create a new trade show event.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "name",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "Event name"
          },
          {
            "name": "start_date",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "format": "date" },
            "description": "Event start date (YYYY-MM-DD)"
          },
          {
            "name": "end_date",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "format": "date" },
            "description": "Event end date (YYYY-MM-DD)"
          },
          {
            "name": "format_id",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "default": 1 },
            "description": "Event format (1=In-Person, 2=Virtual, 3=Hybrid)"
          },
          {
            "name": "participation_type_id",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "default": 1 },
            "description": "Participation type ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Event created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateEvent",
        "summary": "Update an event",
        "description": "Update properties of an existing event.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "header",
            "required": true,
            "schema": { "type": "number" },
            "description": "Event ID"
          },
          {
            "name": "name",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "start_date",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "end_date",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "participation_type_id",
            "in": "header",
            "required": false,
            "schema": { "type": "number" }
          },
          {
            "name": "format_id",
            "in": "header",
            "required": false,
            "schema": { "type": "number" }
          },
          {
            "name": "star_rating",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0, "maximum": 3 }
          },
          {
            "name": "website_url",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "uri" }
          },
          {
            "name": "venue_name",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "booth_size",
            "in": "header",
            "required": false,
            "schema": { "type": "number" }
          },
          {
            "name": "booth_number",
            "in": "header",
            "required": false,
            "schema": { "type": "number" }
          },
          {
            "name": "event_notes",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Plain text only"
          },
          {
            "name": "booth_notes",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Plain text only"
          },
          {
            "name": "budget_notes",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Plain text only"
          },
          {
            "name": "roi_notes",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Plain text only"
          },
          {
            "name": "budget_booth_reservation",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "budget_booth_services",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "budget_attendee_registrations",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "budget_travel",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "budget_giveaways",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "budget_shipments",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "budget_misc_expenses",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "budget_sponsorships",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "roi_num_leads",
            "in": "header",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "roi_num_impressions_booth",
            "in": "header",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "roi_num_impressions_sponsorships",
            "in": "header",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "roi_num_impressions_media",
            "in": "header",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "roi_num_meetings_existing_customers",
            "in": "header",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "roi_num_meetings_new_customers",
            "in": "header",
            "required": false,
            "schema": { "type": "integer", "minimum": 0 }
          },
          {
            "name": "roi_amount_actual_sales",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          },
          {
            "name": "roi_amount_potential_sales",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "minimum": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Event updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteEvent",
        "summary": "Delete an event",
        "description": "Delete an event by ID.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "header",
            "required": true,
            "schema": { "type": "number" },
            "description": "Event ID to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Event deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/v1/events/info": {
      "get": {
        "operationId": "getEvent",
        "summary": "Retrieve a single event",
        "description": "Retrieve a single event by its ID.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "header",
            "required": true,
            "schema": { "type": "number" },
            "description": "Event ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Event details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/v1/events/miscexpensecredits": {
      "get": {
        "operationId": "listMiscExpenseCredits",
        "summary": "List miscellaneous expenses/credits",
        "description": "Retrieve miscellaneous expenses and credits with optional event filter.",
        "tags": ["Misc Expenses/Credits"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "filter_by_event_id",
            "in": "header",
            "required": false,
            "schema": { "type": "number" },
            "description": "Filter by event ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of misc expenses/credits",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MiscExpenseCredit" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/v1/events/miscexpensecredit": {
      "get": {
        "operationId": "getMiscExpenseCredit",
        "summary": "Retrieve a single misc expense/credit",
        "description": "Retrieve a single miscellaneous expense or credit by ID.",
        "tags": ["Misc Expenses/Credits"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "header",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "Misc expense/credit details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MiscExpenseCredit" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "addMiscExpenseCredit",
        "summary": "Add a misc expense/credit",
        "description": "Create a new miscellaneous expense or credit for an event.",
        "tags": ["Misc Expenses/Credits"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "event_id",
            "in": "header",
            "required": true,
            "schema": { "type": "number" }
          },
          {
            "name": "description",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "is_credit",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "default": 0 },
            "description": "Set to 1 for credit, 0 for expense"
          },
          {
            "name": "amount",
            "in": "header",
            "required": false,
            "schema": { "type": "number", "default": 0 }
          },
          {
            "name": "payment_status_id",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "default": "0" }
          },
          {
            "name": "payment_due_date",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "next_payment_due_date",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "payment_notes",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "notes",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Plain text only"
          }
        ],
        "responses": {
          "200": {
            "description": "Misc expense/credit created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MiscExpenseCredit" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateMiscExpenseCredit",
        "summary": "Update a misc expense/credit",
        "description": "Update an existing miscellaneous expense or credit.",
        "tags": ["Misc Expenses/Credits"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "header",
            "required": true,
            "schema": { "type": "number" }
          },
          {
            "name": "description",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "is_credit",
            "in": "header",
            "required": false,
            "schema": { "type": "number" }
          },
          {
            "name": "amount",
            "in": "header",
            "required": false,
            "schema": { "type": "number" }
          },
          {
            "name": "payment_status_id",
            "in": "header",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "payment_due_date",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "notes",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Misc expense/credit updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MiscExpenseCredit" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteMiscExpenseCredit",
        "summary": "Delete a misc expense/credit",
        "description": "Delete a miscellaneous expense or credit by ID.",
        "tags": ["Misc Expenses/Credits"],
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "id",
            "in": "header",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
