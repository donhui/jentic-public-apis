      "RefundSearchResult": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "FOUND",
              "NOT_FOUND"
            ]
          },
          "data": {
            "$ref": "#/components/schemas/Refund"
