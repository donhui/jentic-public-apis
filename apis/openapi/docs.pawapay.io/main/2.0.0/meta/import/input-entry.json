              "signedCallbacks": {
                "type": "boolean"
              }
            }
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "country": {
                  "type": "string"
                },
                "displayName": {
                  "type": "object",
