          },
          "clientReferenceId": {
            "type": "string"
          },
          "customerMessage": {
            "type": "string",
            "minLength": 4,
            "maxLength": 22
          },
          "metadata": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MetadataItem"
