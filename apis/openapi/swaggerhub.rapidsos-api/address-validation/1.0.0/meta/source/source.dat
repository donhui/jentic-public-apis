{
  "openapi": "3.0.0",
  "info": {
    "contact": {
      "email": "integrations@rapidsos.com"
    },
    "description": "Uses the Emergency Workflow API to confirm a valid street address for dispatch. <br></br> <strong> MUST FOLLOW [standard mailing requirements](https://www.postgrid.com/formatting-street-addresses/). </strong> Comma delimiter is recommended.",
    "title": "Address Validation",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/RapidSOS_API/address-validation/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://{environment}.rapidsos.com/v1/rem",
      "variables": {
        "environment": {
          "default": "api-sandbox",
          "enum": [
            "api",
            "api-sandbox"
          ]
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Validate Address",
      "description": "Checks the validity of an address for dispatch"
    }
  ],
  "paths": {
    "/trigger": {
      "post": {
        "tags": [
          "Validate Address"
        ],
        "description": "Post data to RapidSOS system and trigger a RapidSOS workflow",
        "operationId": "trigger",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TriggerFlowSchema"
              }
            }
          },
          "description": "Flow to trigger"
        },
        "responses": {
          "200": {
            "description": "valid address",
            "content": {
              "application/json": {
                "example": {
                  "detail": "[[data]]"
                },
                "schema": {
                  "properties": {
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "Validation Error - Missing key 'user'"
                },
                "schema": {
                  "properties": {
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthortized"
          },
          "404": {
            "description": "Not Found / Invalid Address",
            "content": {
              "application/json": {
                "example": {
                  "detail": "Invalid Address"
                },
                "schema": {
                  "properties": {
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Server is at capacity"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Validate Address"
      }
    }
  },
  "components": {
    "schemas": {
      "TriggerFlowSchema": {
        "properties": {
          "blocking": {
            "type": "boolean",
            "description": "does the client expect an action to occur first before returning an API response",
            "example": true
          },
          "callflow": {
            "type": "string",
            "description": "the RapidSOS provided callflow name to trigger",
            "example": "BasicFlow"
          },
          "live_call": {
            "type": "boolean",
            "description": "if 911 call routing used, must always be true in Production",
            "example": false
          },
          "test_mode": {
            "type": "boolean",
            "description": "do not allow dispatch to 911",
            "example": false
          },
          "variables": {
            "properties": {
              "address": {
                "type": "string",
                "example": "3 Park Ave, Floor 22, New York, NY 10016",
                "description": "Must follow [standard mailing requirements](https://www.postgrid.com/formatting-street-addresses/)"
              }
            },
            "required": [
              "address"
            ],
            "type": "object"
          }
        },
        "required": [
          "blocking",
          "callflow",
          "variables"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  }
}