{
  "openapi": "3.0.3",
  "info": {
    "title": "CalorieKing Food API",
    "description": "The CalorieKing Food API provides access to a comprehensive food and nutrition database. It supports searching for foods, brands, categories, and tags with filtering, paging, and partial responses.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.calorieking.com/us/en/developers/food-api/documentation/"
  },
  "servers": [
    {
      "url": "https://foodapi.calorieking.com/v1",
      "description": "CalorieKing Food API server"
    }
  ],
  "paths": {
    "/foods": {
      "get": {
        "operationId": "listFoods",
        "summary": "Search and list foods",
        "description": "Returns a collection of foods from the CalorieKing database with support for full-text search, filtering by brands, tags, categories, and classifications.",
        "tags": [
          "Foods"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Filter based on this query string.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query-type",
            "in": "query",
            "description": "How the query parameter is interpreted.",
            "schema": {
              "type": "string",
              "enum": [
                "fts",
                "prefix"
              ]
            }
          },
          {
            "name": "region",
            "in": "query",
            "description": "Filter results by region.",
            "schema": {
              "type": "string",
              "enum": [
                "au",
                "us"
              ]
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Selector for partial responses. Supports fieldset aliases like $summary and $detailed.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results per page.",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                5,
                10,
                20,
                30,
                50,
                100
              ]
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Zero-based index of the first result to return.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "brands",
            "in": "query",
            "description": "Filter by brand IDs. Comma-separated list. Prefix with ! to exclude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "in": "query",
            "description": "Filter by tag IDs. Comma-separated list. Prefix with ! to exclude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "categories",
            "in": "query",
            "description": "Filter by category IDs. Comma-separated list. Prefix with ! to exclude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "classifications",
            "in": "query",
            "description": "Filter by classification strings. Comma-separated. Prefix with ! to exclude.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "grouping",
            "in": "query",
            "description": "Group results by brand or classification.",
            "schema": {
              "type": "string",
              "enum": [
                "brand",
                "classification"
              ]
            }
          },
          {
            "name": "grouping-limit",
            "in": "query",
            "description": "Limit the number of foods within each group.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "grouping-order",
            "in": "query",
            "description": "Order of groups (field:direction).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Order of foods (field:direction). Fields: rank, name.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection of foods returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FoodsListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
