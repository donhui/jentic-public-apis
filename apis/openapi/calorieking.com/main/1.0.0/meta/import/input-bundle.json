  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth. Use your access token as the username and leave password blank."
      }
    },
    "schemas": {
      "PaginationMetadata": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Total number of matching results."
          },
          "limit": {
            "type": "integer",
            "description": "Number of results per page."
          },
          "offset": {
            "type": "integer",
            "description": "Zero-based index of the first result."
          }
        }
      },
      "Food": {
        "type": "object",
        "properties": {
          "foodId": {
            "type": "string",
            "format": "uuid",
            "description": "Stable UUID for the food."
          },
          "revisionId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID for this revision. Changes when the food is updated."
          },
          "region": {
            "type": "string"
          },
          "brand": {
            "$ref": "#/components/schemas/BrandRef"
          },
          "category": {
            "$ref": "#/components/schemas/CategoryRef"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagRef"
            }
          },
          "name": {
            "type": "string"
          },
          "classification": {
            "type": "string"
          },
          "otherNames": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "mass": {
            "type": "number",
            "description": "Mass in grams."
          },
          "volume": {
            "type": "number",
            "description": "Volume in milliliters."
          },
          "servings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Serving"
            }
          },
          "upcs": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/UpcEntry"
            }
          },
          "nutrients": {
            "$ref": "#/components/schemas/Nutrients"
          }
        }
      },
      "BrandRef": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "CategoryRef": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "TagRef": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Serving": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "scale": {
            "type": "number",
            "format": "float"
          },
          "type": {
            "type": "string",
            "enum": [
              "mass",
              "volume",
              "serving"
            ]
          }
        }
      },
      "UpcEntry": {
        "type": "object",
        "properties": {
          "servingIndex": {
            "type": "integer"
          },
          "quantity": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "Nutrients": {
        "type": "object",
        "properties": {
          "energy": {
            "type": "number",
            "description": "Energy in kJ"
          },
          "fat": {
            "type": "number",
            "description": "Fat in g"
          },
          "satFat": {
            "type": "number",
            "description": "Saturated fat in g"
          },
          "transFat": {
            "type": "number",
            "description": "Trans fat in g"
          },
          "cholesterol": {
            "type": "number",
            "description": "Cholesterol in mg"
          },
          "sodium": {
            "type": "number",
            "description": "Sodium in mg"
          },
          "totalCarbs": {
            "type": "number",
            "description": "Total carbohydrate in g"
          },
          "fiber": {
            "type": "number",
            "description": "Fiber in g"
          },
          "sugar": {
            "type": "number",
            "description": "Sugar in g"
          },
          "protein": {
            "type": "number",
            "description": "Protein in g"
          },
          "vitaminA": {
            "type": "number",
            "description": "Vitamin A in IU"
          },
          "vitaminC": {
            "type": "number",
            "description": "Vitamin C in mg"
          },
          "calcium": {
            "type": "number",
            "description": "Calcium in mg"
          },
          "iron": {
            "type": "number",
            "description": "Iron in mg"
          },
          "potassium": {
            "type": "number",
            "description": "Potassium in mg"
          },
          "caffeine": {
            "type": "number",
            "description": "Caffeine in mg"
          },
          "alcohol": {
            "type": "number",
            "description": "Alcohol in g"
          }
        }
      },
      "Brand": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
