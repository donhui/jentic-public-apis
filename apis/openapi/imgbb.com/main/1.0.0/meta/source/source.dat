{
  "openapi": "3.0.3",
  "info": {
    "title": "ImgBB",
    "version": "1.0.0",
    "description": "ImgBB image hosting API for uploading images with optional expiration.",
    "x-jentic-source-url": "https://api.imgbb.com"
  },
  "servers": [
    {
      "url": "https://api.imgbb.com"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    { "name": "Upload", "description": "Image upload operations" }
  ],
  "paths": {
    "/1/upload": {
      "post": {
        "operationId": "uploadImage",
        "summary": "Upload an image",
        "description": "Upload an image via multipart form data, base64 encoded string, or URL. Maximum file size is 32 MB.",
        "tags": ["Upload"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API authentication key",
            "schema": { "type": "string" }
          },
          {
            "name": "expiration",
            "in": "query",
            "required": false,
            "description": "Auto-delete time in seconds (60-15552000)",
            "schema": { "type": "integer", "minimum": 60, "maximum": 15552000 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file, base64 string, or URL (max 32 MB)"
                  },
                  "name": {
                    "type": "string",
                    "description": "Custom filename; auto-detected for multipart uploads"
                  }
                }
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": {
                    "type": "string",
                    "description": "Base64 encoded image data or image URL"
                  },
                  "name": {
                    "type": "string",
                    "description": "Custom filename"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image uploaded successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UploadResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters or image",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "UploadResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "url_viewer": { "type": "string", "format": "uri" },
              "url": { "type": "string", "format": "uri" },
              "display_url": { "type": "string", "format": "uri" },
              "width": { "type": "integer" },
              "height": { "type": "integer" },
              "size": { "type": "integer" },
              "time": { "type": "integer" },
              "expiration": { "type": "integer" },
              "image": {
                "type": "object",
                "properties": {
                  "filename": { "type": "string" },
                  "name": { "type": "string" },
                  "mime": { "type": "string" },
                  "extension": { "type": "string" },
                  "url": { "type": "string", "format": "uri" }
                }
              },
              "thumb": {
                "type": "object",
                "properties": {
                  "filename": { "type": "string" },
                  "name": { "type": "string" },
                  "mime": { "type": "string" },
                  "extension": { "type": "string" },
                  "url": { "type": "string", "format": "uri" }
                }
              },
              "medium": {
                "type": "object",
                "properties": {
                  "filename": { "type": "string" },
                  "name": { "type": "string" },
                  "mime": { "type": "string" },
                  "extension": { "type": "string" },
                  "url": { "type": "string", "format": "uri" }
                }
              },
              "delete_url": { "type": "string", "format": "uri" }
            }
          },
          "success": { "type": "boolean" },
          "status": { "type": "integer" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status_code": { "type": "integer" },
          "error": {
            "type": "object",
            "properties": {
              "message": { "type": "string" },
              "code": { "type": "integer" }
            }
          },
          "status_txt": { "type": "string" }
        }
      }
    }
  }
}