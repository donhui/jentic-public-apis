{
  "openapi": "3.0.3",
  "info": {
    "title": "Penguin Pilot - Zapier Integration API",
    "description": "API documentation for Zapier integration with Penguin Pilot. Use your Bearer token from the integrations page to authenticate requests. The token should be sent in the Authorization header as \"Bearer YOUR_TOKEN\".",
    "version": "1.0",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.penguinpilot.ai",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Zapier Integration",
      "description": "Endpoints for Zapier automation integration"
    }
  ],
  "paths": {
    "/zapier/authenticate": {
      "post": {
        "operationId": "authenticateZapier",
        "summary": "Authenticate Zapier Integration",
        "description": "Authenticates the Zapier integration using API key and returns brand information.",
        "tags": ["Zapier Integration"],
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "example": "My Brand"
                    },
                    "id": {
                      "type": "string",
                      "example": "brand_123"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/zapier/content-streams": {
      "get": {
        "operationId": "getContentStreams",
        "summary": "Get Content Streams",
        "description": "Retrieves all active content streams configured for external automation (Zapier).",
        "tags": ["Zapier Integration"],
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "Content streams retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ContentStream"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/zapier/template-libraries": {
      "get": {
        "operationId": "getTemplateLibraries",
        "summary": "Get Template Libraries",
        "description": "Retrieves all template libraries available for image generation.",
        "tags": ["Zapier Integration"],
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "Template libraries retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TemplateLibrary"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/zapier/posts": {
      "post": {
        "operationId": "createPost",
        "summary": "Create Social Media Post",
        "description": "Creates a new social media post with AI-generated content. Optionally generates images using provided template and instructions.",
        "tags": ["Zapier Integration"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateZapierPostDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Post created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter your integration token from the integrations page"
      }
    },
    "schemas": {
      "ContentStream": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "stream_123"
          },
          "name": {
            "type": "string",
            "example": "Social Media Campaign"
          },
          "postType": {
            "type": "string",
            "enum": ["TEXT", "IMAGE"],
            "example": "IMAGE"
          }
        }
      },
      "TemplateLibrary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "template_123"
          },
          "title": {
            "type": "string",
            "example": "Brand Templates"
          }
        }
      },
      "PostTextLength": {
        "type": "string",
        "enum": ["SHORT", "MEDIUM", "LONG"],
        "description": "Desired length of the post text"
      },
      "CreateZapierPostDto": {
        "type": "object",
        "required": ["contentInstructions", "postTextLength", "toneOfVoice", "languageStyle", "useEmojis", "contentStreamId"],
        "properties": {
          "contentInstructions": {
            "type": "string",
            "description": "Detailed instructions for the AI to generate post content. Be specific about what the post should communicate.",
            "example": "Create a post announcing our new product launch. Highlight the key features and benefits for small business owners."
          },
          "postTextLength": {
            "allOf": [{"$ref": "#/components/schemas/PostTextLength"}],
            "description": "Desired length of the post text",
            "example": "MEDIUM"
          },
          "toneOfVoice": {
            "type": "string",
            "description": "Tone of voice for the generated content (e.g., professional, casual, friendly)",
            "example": "Professional yet approachable"
          },
          "languageStyle": {
            "type": "string",
            "description": "Language style preferences (e.g., simple, technical, conversational)",
            "example": "Conversational with industry terminology"
          },
          "useEmojis": {
            "type": "boolean",
            "description": "Whether to include emojis in the generated content",
            "example": true
          },
          "imageTemplateId": {
            "type": "string",
            "description": "ID of the template library to use for image generation. If provided along with imagePromptInstructions, an image will be generated for the post.",
            "example": "template_lib_123"
          },
          "imagePromptInstructions": {
            "type": "string",
            "description": "Custom instructions for AI image generation. Used in conjunction with imageTemplateId to generate branded social media images.",
            "example": "Use vibrant colors and include our product in the foreground. Make it eye-catching for social media."
          },
          "imageUrl": {
            "type": "string",
            "description": "URL of an existing image to use as a reference for AI image generation.",
            "example": "https://example.com/image.jpg"
          },
          "contentStreamId": {
            "type": "string",
            "description": "ID of the content stream this post belongs to. Determines which platforms the post will be published to and scheduling settings.",
            "example": "stream_123"
          }
        }
      },
      "PlatformPost": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "integrationId": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["TEXT", "IMAGE"]
          }
        }
      },
      "PostResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "postId": {
                "type": "string",
                "example": "post_123"
              },
              "title": {
                "type": "string",
                "example": "Zapier Post"
              },
              "scheduledFor": {
                "type": "string",
                "format": "date-time",
                "example": "2025-01-20T10:00:00Z"
              },
              "status": {
                "type": "string",
                "example": "PENDING"
              },
              "platformPosts": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PlatformPost"
                }
              }
            }
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "data": {
            "type": "string",
            "nullable": true
          },
          "error": {
            "type": "string",
            "example": "Content stream not found"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "example": 401
          },
          "message": {
            "type": "string",
            "example": "Unauthorized"
          }
        }
      }
    }
  }
}