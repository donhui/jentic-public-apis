{
  "openapi": "3.0.3",
  "info": {
    "title": "Kommunicate API",
    "version": "1.0.0",
    "description": "Kommunicate is a human + bot hybrid customer support software. The Platform API provides endpoints to manage conversations, users, messages, and agents.",
    "x-jentic-source-url": "https://docs.kommunicate.io/"
  },
  "servers": [
    {
      "url": "https://services.kommunicate.io",
      "description": "Kommunicate API Server"
    }
  ],
  "paths": {
    "/rest/ws/group/conversation": {
      "post": {
        "operationId": "createConversation",
        "summary": "Create a conversation",
        "description": "Create a new conversation with specified members.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateConversationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversation created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/rest/ws/user/v2/detail": {
      "post": {
        "operationId": "getUserDetail",
        "summary": "Get user detail",
        "description": "Retrieve details for one or more users by their IDs.",
        "parameters": [
          {
            "name": "fetchLatestMessageTime",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Whether to fetch latest message time"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetUserDetailRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserDetail"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/rest/ws/message/v2/send": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send a message",
        "description": "Send a message to a conversation.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/rest/ws/message/send": {
      "post": {
        "operationId": "sendAttachment",
        "summary": "Send an attachment",
        "description": "Send a message with file attachment to a conversation.",
        "parameters": [
          {
            "name": "of-user-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Admin email address"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendAttachmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attachment sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/rest/ws/group/status/change": {
      "patch": {
        "operationId": "changeConversationStatus",
        "summary": "Change conversation status",
        "description": "Change the status of a conversation (open, closed, spam).",
        "parameters": [
          {
            "name": "Of-User-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User ID performing the action"
          },
          {
            "name": "groupId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Conversation identifier"
          },
          {
            "name": "status",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "enum": [0, 2, 3]
            },
            "description": "Status code: 0 (open), 2 (closed), 3 (spam)"
          },
          {
            "name": "sendNotifyMessage",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Whether to send a notification message"
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation status changed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/rest/ws/user/update": {
      "post": {
        "operationId": "updateUserDetails",
        "summary": "Update user details",
        "description": "Update details for a user.",
        "parameters": [
          {
            "name": "Of-User-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User ID to update"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User details updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/rest/ws/group/assignee/change": {
      "patch": {
        "operationId": "changeConversationAssignee",
        "summary": "Change conversation assignee",
        "description": "Change the assigned agent for a conversation.",
        "parameters": [
          {
            "name": "Of-User-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User ID performing the action"
          },
          {
            "name": "groupId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Conversation identifier"
          },
          {
            "name": "assignee",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Agent email or ID to assign"
          },
          {
            "name": "sendNotifyMessage",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Whether to send a notification message"
          },
          {
            "name": "takeOverFromBot",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Remove bots from conversation"
          }
        ],
        "responses": {
          "200": {
            "description": "Assignee changed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangeAssigneeResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateConversationRequest": {
        "type": "object",
        "required": ["groupName", "groupMemberList"],
        "properties": {
          "groupName": {
            "type": "string",
            "description": "Conversation title"
          },
          "groupMemberList": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of user, agent, or bot IDs"
          },
          "clientGroupId": {
            "type": "integer",
            "description": "Custom group identifier"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "SKIP_ROUTING": {
                "type": "boolean",
                "description": "Skip conversation rules"
              },
              "CONVERSATION_ASSIGNEE": {
                "type": "string",
                "description": "Assign specific agent or bot"
              }
            }
          }
        }
      },
      "GetUserDetailRequest": {
        "type": "object",
        "required": ["userIdList"],
        "properties": {
          "userIdList": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of user IDs to fetch"
          }
        }
      },
      "UserDetail": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "userName": {
            "type": "string"
          },
          "connected": {
            "type": "boolean"
          },
          "lastSeenAtTime": {
            "type": "integer",
            "format": "int64"
          },
          "createdAtTime": {
            "type": "integer",
            "format": "int64"
          },
          "imageLink": {
            "type": "string"
          },
          "deactivated": {
            "type": "boolean"
          },
          "phoneNumber": {
            "type": "string"
          },
          "unreadCount": {
            "type": "integer"
          },
          "lastLoggedInAtTime": {
            "type": "integer",
            "format": "int64"
          },
          "lastMessageAtTime": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "SendMessageRequest": {
        "type": "object",
        "required": ["groupId", "message"],
        "properties": {
          "groupId": {
            "type": "string",
            "description": "Conversation identifier"
          },
          "clientGroupId": {
            "type": "string",
            "description": "Custom group ID"
          },
          "message": {
            "type": "string",
            "description": "Message content"
          },
          "fromUserName": {
            "type": "string",
            "description": "Sender user ID"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "contentType": {
                "type": "string",
                "description": "Message type (0-6 or 300)"
              },
              "templateId": {
                "type": "string",
                "description": "Rich message template"
              },
              "skipBot": {
                "type": "boolean",
                "description": "Prevent double execution"
              },
              "payload": {
                "type": "string",
                "description": "Stringified JSON object"
              }
            }
          }
        }
      },
      "SendAttachmentRequest": {
        "type": "object",
        "required": ["groupId", "fileMeta"],
        "properties": {
          "type": {
            "type": "integer",
            "description": "Message type"
          },
          "contentType": {
            "type": "integer",
            "description": "Content format"
          },
          "message": {
            "type": "string",
            "description": "Description"
          },
          "groupId": {
            "type": "string",
            "description": "Conversation ID"
          },
          "fileMeta": {
            "type": "object",
            "properties": {
              "blobKey": {
                "type": "string",
                "description": "File identifier"
              },
              "name": {
                "type": "string",
                "description": "Filename"
              },
              "size": {
                "type": "integer",
                "description": "File size in bytes"
              },
              "contentType": {
                "type": "string",
                "description": "MIME type"
              },
              "thumbnailUrl": {
                "type": "string",
                "description": "Image preview URL"
              },
              "createdAtTime": {
                "type": "integer",
                "format": "int64",
                "description": "Timestamp"
              }
            }
          },
          "metadata": {
            "type": "object",
            "properties": {
              "skipBot": {
                "type": "boolean"
              }
            }
          },
          "key": {
            "type": "string",
            "description": "Reference key"
          },
          "source": {
            "type": "integer",
            "description": "Source identifier"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email"
          },
          "displayName": {
            "type": "string",
            "description": "Display name"
          },
          "imageLink": {
            "type": "string",
            "description": "Profile image URL"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Custom key-value pairs"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "response": {
            "type": "string"
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ChangeAssigneeResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "response": {
            "type": "string"
          },
          "errorResponse": {
            "type": "string"
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Api-Key",
        "description": "API key obtained from the Kommunicate dashboard"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}