{
  "openapi": "3.0.3",
  "info": {
    "title": "Searchify Search",
    "version": "v1",
    "description": "Searchify is a hosted search API that provides real-time full-text search and autocomplete capabilities for web applications.",
    "x-jentic-source-url": "https://searchify.com/documentation/api"
  },
  "servers": [
    {
      "url": "https://{privateUrl}.api.searchify.com/v1",
      "description": "Searchify API (private URL from dashboard)",
      "variables": {
        "privateUrl": {
          "default": "your-private-url",
          "description": "Your private API URL found in the Searchify dashboard"
        }
      }
    }
  ],
  "paths": {
    "/indexes": {
      "get": {
        "operationId": "listIndexes",
        "summary": "List all indexes",
        "tags": [
          "Indexes"
        ],
        "responses": {
          "200": {
            "description": "Map of all indexes with metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/IndexMetadata"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/indexes/{name}": {
      "get": {
        "operationId": "getIndex",
        "summary": "Get index metadata",
        "tags": [
          "Indexes"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          }
        ],
        "responses": {
          "200": {
            "description": "Index metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexMetadata"
                }
              }
            }
          },
          "404": {
            "description": "Index not found"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "put": {
        "operationId": "createOrUpdateIndex",
        "summary": "Create or update an index",
        "tags": [
          "Indexes"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "public_search": {
                    "type": "boolean",
                    "description": "Whether the index allows public searching"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Index created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndexMetadata"
                }
              }
            }
          },
          "204": {
            "description": "Index updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteIndex",
        "summary": "Delete an index",
        "tags": [
          "Indexes"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          }
        ],
        "responses": {
          "200": {
            "description": "Index deleted"
          },
          "404": {
            "description": "Index not found"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/indexes/{name}/docs": {
      "put": {
        "operationId": "indexDocuments",
        "summary": "Add or update documents in an index",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/Document"
                  },
                  {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Document"
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Documents indexed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BatchResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteDocuments",
        "summary": "Delete documents from an index",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          },
          {
            "name": "docid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Document ID to delete (for single deletion via query)"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "docid": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "docid"
                    ]
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "docid": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "docid"
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Documents deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/indexes/{name}/docs/variables": {
      "put": {
        "operationId": "updateDocumentVariables",
        "summary": "Update scoring variables for a document",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "docid": {
                    "type": "string"
                  },
                  "variables": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "number"
                    }
                  }
                },
                "required": [
                  "docid",
                  "variables"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Variables updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/indexes/{name}/docs/categories": {
      "put": {
        "operationId": "updateDocumentCategories",
        "summary": "Update categories for a document",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "docid": {
                    "type": "string"
                  },
                  "categories": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "docid",
                  "categories"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Categories updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/indexes/{name}/functions": {
      "get": {
        "operationId": "listScoringFunctions",
        "summary": "List scoring functions for an index",
        "tags": [
          "Scoring Functions"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          }
        ],
        "responses": {
          "200": {
            "description": "Map of scoring functions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/ScoringFunction"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/indexes/{name}/functions/{num}": {
      "put": {
        "operationId": "createOrUpdateScoringFunction",
        "summary": "Create or update a scoring function",
        "tags": [
          "Scoring Functions"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          },
          {
            "name": "num",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Scoring function number"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "definition": {
                    "type": "string",
                    "description": "Scoring function definition"
                  }
                },
                "required": [
                  "definition"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Function created or updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteScoringFunction",
        "summary": "Delete a scoring function",
        "tags": [
          "Scoring Functions"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          },
          {
            "name": "num",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Scoring function number"
          }
        ],
        "responses": {
          "200": {
            "description": "Function deleted"
          },
          "404": {
            "description": "Function not found"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/indexes/{name}/search": {
      "get": {
        "operationId": "searchIndex",
        "summary": "Search an index",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Starting offset for results"
          },
          {
            "name": "len",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of results to return"
          },
          {
            "name": "function",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Scoring function number to use"
          },
          {
            "name": "fetch",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields to return"
          },
          {
            "name": "fetch_variables",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Whether to return scoring variables"
          },
          {
            "name": "fetch_categories",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Whether to return categories"
          },
          {
            "name": "snippet",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of fields for snippets"
          },
          {
            "name": "category_filters",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Category filters in JSON format"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteBySearch",
        "summary": "Delete documents matching a search query",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query to match documents for deletion"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching documents deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/indexes/{name}/autocomplete": {
      "get": {
        "operationId": "autocomplete",
        "summary": "Get autocomplete suggestions",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IndexName"
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Autocomplete query prefix"
          },
          {
            "name": "field",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Field to search for completions"
          },
          {
            "name": "callback",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSONP callback function name"
          }
        ],
        "responses": {
          "200": {
            "description": "Autocomplete suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutocompleteResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "IndexName": {
        "name": "name",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Index name"
      }
    },
    "schemas": {
      "IndexMetadata": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "public_search": {
            "type": "boolean"
          },
          "creation_time": {
            "type": "string"
          }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "docid": {
            "type": "string",
            "description": "Unique document identifier"
          },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Document fields to index"
          },
          "variables": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            },
            "description": "Scoring variables"
          },
          "categories": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Document categories"
          }
        },
        "required": [
          "docid",
          "fields"
        ]
      },
      "BatchResult": {
        "type": "object",
        "properties": {
          "added": {
            "type": "boolean"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "ScoringFunction": {
        "type": "object",
        "properties": {
          "definition": {
            "type": "string"
          }
        }
      },
      "SearchResults": {
        "type": "object",
        "properties": {
          "matches": {
            "type": "integer",
            "description": "Total number of matching documents"
          },
          "facets": {
            "type": "object",
            "additionalProperties": true
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            }
          },
          "search_time": {
            "type": "number",
            "description": "Time taken in seconds"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "docid": {
            "type": "string"
          },
          "query_relevance_score": {
            "type": "number"
          },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "variables": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          },
          "categories": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "AutocompleteResults": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "suggestions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiUrl": {
        "type": "http",
        "scheme": "basic",
        "description": "Authentication is handled via the private API URL provided in your Searchify dashboard"
      }
    }
  },
  "security": [
    {
      "apiUrl": []
    }
  ]
}