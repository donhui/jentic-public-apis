{
  "openapi": "3.0.3",
  "info": {
    "title": "nBlocks API",
    "version": "1.0.0",
    "description": "nBlocks multi-tenant SaaS platform API for app management, authentication, tenant management, role management, feature flags, and payment plans.",
    "x-jentic-source-url": "https://nebulr-group.github.io/nblocks-api-docs/"
  },
  "servers": [
    {
      "url": "https://account-api.nebulr-core.com",
      "description": "Account API"
    },
    {
      "url": "https://auth.nblocks.cloud",
      "description": "Authentication API"
    }
  ],
  "paths": {
    "/app": {
      "get": {
        "operationId": "getApp",
        "summary": "Get App Profile",
        "description": "Retrieve app configuration settings.",
        "tags": ["App Profile"],
        "responses": {
          "200": {
            "description": "App profile retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppProfile"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateApp",
        "summary": "Update App Profile",
        "description": "Modify app profile details.",
        "tags": ["App Profile"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppProfileInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "App profile updated successfully",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AppProfile" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/app/credentials": {
      "put": {
        "operationId": "updateAppCredentials",
        "summary": "Update App Credentials",
        "description": "Store third-party service credentials such as Stripe keys and SSO secrets.",
        "tags": ["App Profile"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "stripeSecretKey": { "type": "string" },
                  "stripePublicKey": { "type": "string" },
                  "ssoSecret": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Credentials updated successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/app/credentialsState": {
      "get": {
        "operationId": "getAppCredentialsState",
        "summary": "Get Credentials State",
        "description": "Check credential configuration status.",
        "tags": ["App Profile"],
        "responses": {
          "200": {
            "description": "Credentials state retrieved",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "stripeConfigured": { "type": "boolean" }, "ssoConfigured": { "type": "boolean" } } } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/email/template/{templateName}": {
      "get": {
        "operationId": "getEmailTemplate",
        "summary": "Get Email Template",
        "description": "Retrieve a custom email template.",
        "tags": ["Email Templates"],
        "parameters": [
          {
            "name": "templateName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Name of the email template"
          }
        ],
        "responses": {
          "200": { "description": "Email template retrieved", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailTemplate" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateEmailTemplate",
        "summary": "Update Email Template",
        "description": "Set a custom email template.",
        "tags": ["Email Templates"],
        "parameters": [
          {
            "name": "templateName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string", "description": "Email template content" },
                  "testRecipient": { "type": "string", "description": "Test email recipient" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Email template updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteEmailTemplate",
        "summary": "Delete Email Template",
        "description": "Remove a custom email template.",
        "tags": ["Email Templates"],
        "parameters": [
          {
            "name": "templateName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Email template deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/brand/css": {
      "post": {
        "operationId": "uploadBrandCss",
        "summary": "Upload Custom CSS",
        "description": "Upload custom CSS styling for branding.",
        "tags": ["Branding"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "content": { "type": "string", "description": "CSS content string" } }, "required": ["content"] }
            }
          }
        },
        "responses": {
          "200": { "description": "CSS uploaded successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "get": {
        "operationId": "getBrandCss",
        "summary": "Get Custom CSS",
        "description": "Fetch applied custom CSS styling.",
        "tags": ["Branding"],
        "responses": {
          "200": { "description": "CSS retrieved", "content": { "application/json": { "schema": { "type": "object", "properties": { "content": { "type": "string" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteBrandCss",
        "summary": "Delete Custom CSS",
        "description": "Remove custom CSS styling.",
        "tags": ["Branding"],
        "responses": {
          "200": { "description": "CSS deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/brand/translations": {
      "post": {
        "operationId": "setBrandTranslations",
        "summary": "Set Custom Translations",
        "description": "Set custom UI translations.",
        "tags": ["Branding"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": { "type": "string" } }
            }
          }
        },
        "responses": {
          "200": { "description": "Translations set" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "get": {
        "operationId": "getBrandTranslations",
        "summary": "Get Custom Translations",
        "description": "Retrieve custom UI translations.",
        "tags": ["Branding"],
        "responses": {
          "200": { "description": "Translations retrieved", "content": { "application/json": { "schema": { "type": "object", "additionalProperties": { "type": "string" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/role": {
      "get": {
        "operationId": "listRoles",
        "summary": "List Roles",
        "description": "List all access roles.",
        "tags": ["Roles"],
        "responses": {
          "200": { "description": "Roles list", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Role" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createRole",
        "summary": "Create Role",
        "description": "Create a new role definition.",
        "tags": ["Roles"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "key"],
                "properties": {
                  "name": { "type": "string" },
                  "key": { "type": "string" },
                  "privileges": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Role created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Role" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/role/{roleId}": {
      "put": {
        "operationId": "updateRole",
        "summary": "Update Role",
        "description": "Update role configuration.",
        "tags": ["Roles"],
        "parameters": [
          { "name": "roleId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "privileges": { "type": "array", "items": { "type": "string" } },
                  "isDefault": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Role updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Role" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteRole",
        "summary": "Delete Role",
        "description": "Remove a role definition.",
        "tags": ["Roles"],
        "parameters": [
          { "name": "roleId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Role deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/role/privilege": {
      "get": {
        "operationId": "listPrivileges",
        "summary": "List Privileges",
        "description": "List all privileges.",
        "tags": ["Roles"],
        "responses": {
          "200": { "description": "Privileges list", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Privilege" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createPrivilege",
        "summary": "Create Privilege",
        "description": "Create a new privilege.",
        "tags": ["Roles"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["key"],
                "properties": {
                  "key": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Privilege created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Privilege" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/role/privilege/{privilegeId}": {
      "put": {
        "operationId": "updatePrivilege",
        "summary": "Update Privilege",
        "description": "Update privilege details.",
        "tags": ["Roles"],
        "parameters": [
          { "name": "privilegeId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "key": { "type": "string" }, "description": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Privilege updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deletePrivilege",
        "summary": "Delete Privilege",
        "description": "Remove a privilege.",
        "tags": ["Roles"],
        "parameters": [
          { "name": "privilegeId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Privilege deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/tenant": {
      "get": {
        "operationId": "listTenants",
        "summary": "List Tenants",
        "description": "List all tenants.",
        "tags": ["Tenants"],
        "responses": {
          "200": { "description": "Tenants list", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Tenant" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createTenant",
        "summary": "Create Tenant",
        "description": "Create a new tenant with owner.",
        "tags": ["Tenants"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "plan": { "type": "string" },
                  "owner": {
                    "type": "object",
                    "properties": {
                      "email": { "type": "string" },
                      "firstName": { "type": "string" },
                      "lastName": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tenant created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Tenant" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/tenant/byId/{tenantId}": {
      "get": {
        "operationId": "getTenant",
        "summary": "Get Tenant",
        "description": "Retrieve tenant details by ID.",
        "tags": ["Tenants"],
        "parameters": [
          { "name": "tenantId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Tenant details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Tenant" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/tenant/{tenantId}": {
      "put": {
        "operationId": "updateTenant",
        "summary": "Update Tenant",
        "description": "Update tenant settings.",
        "tags": ["Tenants"],
        "parameters": [
          { "name": "tenantId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "locale": { "type": "string" },
                  "logo": { "type": "string" },
                  "mfa": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Tenant updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Tenant" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/tenant/user": {
      "get": {
        "operationId": "listTenantUsers",
        "summary": "List Tenant Users",
        "description": "List users for a tenant.",
        "tags": ["Tenant Users"],
        "parameters": [
          { "name": "x-tenant-id", "in": "header", "required": true, "schema": { "type": "string" }, "description": "Tenant ID" }
        ],
        "responses": {
          "200": { "description": "Tenant users list", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TenantUser" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "addTenantUser",
        "summary": "Add Tenant User",
        "description": "Add a user to a tenant.",
        "tags": ["Tenant Users"],
        "parameters": [
          { "name": "x-tenant-id", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username"],
                "properties": {
                  "username": { "type": "string" },
                  "role": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User added to tenant", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TenantUser" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/tenant/user/{userId}": {
      "get": {
        "operationId": "getTenantUser",
        "summary": "Get Tenant User",
        "description": "Get specific user details within a tenant.",
        "tags": ["Tenant Users"],
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "x-tenant-id", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "User details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TenantUser" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateTenantUser",
        "summary": "Update Tenant User",
        "description": "Modify user settings within a tenant.",
        "tags": ["Tenant Users"],
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "x-tenant-id", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "role": { "type": "string" },
                  "enabled": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
