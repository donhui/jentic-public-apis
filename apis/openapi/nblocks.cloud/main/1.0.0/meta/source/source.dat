  "components": {
    "schemas": {
      "AppProfile": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "logo": { "type": "string" },
          "webhookUrl": { "type": "string" }
        }
      },
      "AppProfileInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "logo": { "type": "string" },
          "webhookUrl": { "type": "string" }
        }
      },
      "EmailTemplate": {
        "type": "object",
        "properties": {
          "templateName": { "type": "string" },
          "content": { "type": "string" }
        }
      },
      "Role": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "key": { "type": "string" },
          "privileges": { "type": "array", "items": { "type": "string" } },
          "isDefault": { "type": "boolean" }
        }
      },
      "Privilege": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "key": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "Tenant": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "plan": { "type": "string" },
          "locale": { "type": "string" },
          "logo": { "type": "string" },
          "mfa": { "type": "boolean" }
        }
      },
      "TenantUser": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "role": { "type": "string" },
          "enabled": { "type": "boolean" }
        }
      },
      "FederationConnection": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["saml", "oidc"] },
          "name": { "type": "string" },
          "loginUrl": { "type": "string" },
          "certificate": { "type": "string" },
          "requestMethod": { "type": "string" },
          "signedRequest": { "type": "boolean" }
        }
      },
      "FeatureFlag": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "key": { "type": "string" },
          "segments": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Segment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "key": { "type": "string" },
          "targets": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Plan": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "key": { "type": "string" },
          "prices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "amount": { "type": "number" },
                "currency": { "type": "string" },
                "interval": { "type": "string" }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error message" },
          "statusCode": { "type": "integer", "description": "HTTP status code" }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Application API key"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ]
}