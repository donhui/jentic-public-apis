    "/claims/summary/status": {
      "get": {
        "tags": [
          "Claims"
        ],
        "summary": "Get a list of Claims for an organisation.",
        "description": "Returns a list of Claims for the digital certificate owners organisation. The query parameters are provided to filter Claims by registration status and date range, define result page size and specify which page of results to return. The maximum date range is 13 months and maximum Claims per page is 25.",
        "operationId": "claims_7",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "status",
            "required": true,
            "type": "string",
            "enum": [
              "FAILED",
              "RECEIPTED"
