    },
    "Diagnosis": {
      "type": "object",
      "required": [
        "diagnosisCode",
        "diagnosisCodeType",
        "diagnosisDescription",
        "diagnosisSide"
      ],
      "properties": {
        "diagnosisCodeType": {
          "type": "string",
          "description": "See the DiagnosisCodingSystem code tables for valid values."
        },
        "diagnosisCode": {
          "type": "string",
          "description": "Alphanumeric, can include '.'"
        },
        "diagnosisDescription": {
          "type": "string"
        },
        "diagnosisSide": {
          "type": "string",
          "enum": [
            "left",
            "right",
            "notApplicable"
          ]
        }
      }
    },
    "Employer": {
      "type": "object",
      "properties": {
        "employerName": {
          "type": "string",
          "description": "Required when inPaidEmployment is true, otherwise optional."
        },
        "address": {
          "$ref": "#/definitions/Address"
        }
      },
      "description": "Only required if paid employment = true."
    },
    "Employment": {
      "type": "object",
      "required": [
        "inPaidEmployment"
      ],
      "properties": {
        "inPaidEmployment": {
          "type": "string",
          "description": "True if patient is in paid employment.",
          "enum": [
            "True",
            "False"
          ]
        },
        "employmentStatusCode": {
          "type": "string",
          "description": "Only required when the patient is in paid employment. See the EmploymentStatus code table for valid values."
        },
        "otherEmployment": {
          "type": "string",
          "description": "Only required when employment status is 5 (other). Describe the employment."
        },
        "workTypeCode": {
          "type": "string",
          "description": "Only required when inPaidEmployment is true. See the WorkType code table for valid values."
        },
        "employer": {
          "$ref": "#/definitions/Employer"
        }
      }
    },
    "Incapacity": {
      "type": "object",
      "required": [
        "incapacityDateRange",
        "incapacityType"
      ],
      "properties": {
        "incapacityType": {
          "type": "string",
          "description": "One type required when canResumeNormalWork is false (both types can be selected); otherwise not permitted.",
          "enum": [
            "Fitforselectedwork",
            "Fullyunfitforwork"
          ]
        },
        "incapacityDateRange": {
          "$ref": "#/definitions/DateRange"
        },
        "selectedAlternativeWork": {
          "$ref": "#/definitions/SelectedAlternativeWork"
        }
      }
    },
    "Injury": {
      "type": "object",
      "required": [
        "accidentDate",
        "accidentLocationCode",
        "accidentSceneCode",
        "causeOfAccident",
        "involvesVehicle",
        "sportingInjury",
        "workInjury"
      ],
      "properties": {
        "accidentDate": {
          "type": "string",
          "format": "date",
          "description": "ISO8601 complete date format YYYY-MM-DD."
        },
        "accidentLocationCode": {
          "type": "string",
          "description": "See GeoLocation codetable for valid codes."
        },
        "accidentSceneCode": {
          "type": "string",
          "description": "See Scene codetable for valid codes."
        },
        "causeOfAccident": {
          "type": "string",
          "example": "fell off ladder",
          "description": "For the specific event."
        },
        "involvesVehicle": {
          "type": "string",
          "description": "True if accident involved a vehicle.",
          "enum": [
            "True",
            "False"
          ]
        },
        "medicalTreatmentInjury": {
          "type": "string",
          "description": "True for an injury received during treatment by a registered health professional.",
          "enum": [
            "True",
            "False"
          ]
        },
        "workInjury": {
          "type": "string",
          "description": "True for an injury related to work.",
          "enum": [
            "True",
            "False"
          ]
        },
        "sportingInjury": {
          "type": "string",
          "description": "True for an accident related to playing sport.",
          "enum": [
            "True",
            "False"
          ]
        },
        "sportNameCode": {
          "type": "string",
          "description": "Only required if sportingInjury=true. See sport codetable for valid codes."
        },
        "gradualProcessInjury": {
          "type": "string",
          "enum": [
            "True",
            "False"
          ]
        },
        "admittedToHospital": {
          "type": "string",
          "description": "Only DHBs can set this to true.",
          "enum": [
            "True",
            "False"
          ]
        },
        "injuryComments": {
          "type": "string"
        },
        "assistanceRequired": {
          "type": "string",
          "description": "Only DHBs can set this to true.",
          "enum": [
            "True",
            "False"
          ]
        },
        "accContactProvider": {
          "type": "string",
          "description": "See the rehabilitation code table for valid values."
        }
      }
    },
    "Patient": {
      "type": "object",
      "required": [
        "address",
        "details"
      ],
      "properties": {
        "details": {
          "$ref": "#/definitions/PatientDetails"
        },
        "occupationCode": {
          "type": "string",
          "description": "See the Occupation code table for valid values."
        },
        "contact": {
          "$ref": "#/definitions/Contact"
        },
        "address": {
          "$ref": "#/definitions/Address"
        }
      }
    },
    "PatientDetails": {
      "type": "object",
      "required": [
        "dateOfBirth",
        "ethnicityCode",
        "firstName",
        "gender",
        "surname"
      ],
      "properties": {
        "nhi": {
          "type": "string",
          "description": "National Health Index number."
        },
        "firstName": {
          "type": "string"
        },
        "middleName": {
          "type": "string"
        },
        "surname": {
          "type": "string"
        },
        "dateOfBirth": {
          "type": "string",
          "format": "date",
          "description": "Mandatory for Claims. ISO8601 complete date format YYYY-MM-DD."
        },
        "gender": {
          "type": "string",
          "enum": [
            "M",
            "F"
          ]
        },
        "ethnicityCode": {
          "type": "string",
          "description": "See the Ethnicity code table for valid values."
        },
        "otherEthnicity": {
          "type": "string",
          "description": "Only required when ethnicityCode is 54."
        }
      }
    },
    "PhysicalRestrictions": {
      "type": "object",
      "properties": {
        "restriction": {
          "type": "string",
          "enum": [
            "Lifting",
            "Posture",
            "Heavy Physical",
            "Repetition",
            "Vibration",
            "Temperature",
            "Driving",
            "Prolonged Sitting",
            "Prolonged Walking",
            "Prolonged Standing",
            "Other"
          ]
        }
      }
    },
    "Provider": {
      "type": "object",
      "required": [
        "address",
        "details"
      ],
      "properties": {
        "details": {
          "$ref": "#/definitions/ProviderDetails"
        },
        "address": {
          "$ref": "#/definitions/Address"
        }
      }
    },
    "ProviderDetails": {
      "type": "object",
      "required": [
        "firstName",
        "providerId",
        "providerTypeCode",
        "surname"
      ],
      "properties": {
        "providerId": {
          "type": "string",
          "description": "ACC provider ID"
        },
        "providerTypeCode": {
          "type": "string",
          "description": "See ProviderType codetable for list of valid codes"
        },
        "firstName": {
          "type": "string"
        },
        "middleName": {
          "type": "string"
        },
        "surname": {
          "type": "string"
        }
      }
    },
    "QueryClaimSummaryResponse": {
      "type": "object",
      "properties": {
        "claimNumber": {
          "type": "string"
        },
        "claimStatus": {
          "type": "string"
        },
        "dateCreated": {
          "type": "string",
          "format": "date"
        },
        "facilityName": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "idType": {
          "type": "string"
        },
        "invalidReason": {
          "type": "string"
        },
        "invalidReasonDescription": {
          "type": "string"
        },
        "lockId": {
          "type": "string"
        },
        "organisation": {
          "type": "string"
        },
        "organisationUser": {
          "type": "string"
        },
        "patientName": {
          "type": "string"
        },
        "pmsName": {
          "type": "string"
        },
        "submissionChannel": {
          "type": "string"
        },
        "treatmentProvider": {
          "type": "string"
        }
      },
      "description": "Response after querying claim summary list"
    },
    "QueryClaimSummaryResponseList": {
      "type": "object",
      "properties": {
        "claimSummaryList": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/QueryClaimSummaryResponse"
          }
        },
        "generatedAt": {
          "type": "string",
          "format": "date"
        },
        "message": {
          "type": "string"
        },
        "page": {
          "type": "integer",
          "format": "int32"
        },
        "pageSize": {
          "type": "integer",
          "format": "int32"
        },
        "totalPages": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "Referral": {
      "type": "object",
      "required": [
        "providerTypeCode",
        "referralReason"
      ],
      "properties": {
        "providerTypeCode": {
          "type": "string",
          "description": "See ProviderType codetable for list of valid codes. Example: referral for Physiotherapy = 81"
        },
        "referralReason": {
          "type": "string"
        }
      }
    },
    "SelectedAlternativeWork": {
      "type": "object",
      "properties": {
        "alternativeWorkTypeCode": {
          "type": "string",
          "description": "Only required when Fitforselectedwork is selected. See the WorkType code table for valid values."
        },
        "physicalRestrictions": {
          "type": "array",
          "description": "When Fitforselectedwork is selected, you may choose one or more options from this list.",
          "items": {
            "$ref": "#/definitions/PhysicalRestrictions"
          }
        },
        "restrictedHoursPerDay": {
          "type": "integer",
          "format": "int32",
          "description": "When Fitforselectedwork is selected, you can choose 1-24."
        },
        "restrictionComment": {
          "type": "string",
          "description": "When Fitforselectedwork is selected, you may add more details here."
        }
      },
      "description": "Required when incapacityType=Fitforselectedwork."
    },
    "Vendor": {
      "type": "object",
      "required": [
        "hpiOrganisationNumber",
        "practiceName"
      ],
      "properties": {
        "practiceName": {
          "type": "string"
        },
        "hpiOrganisationNumber": {
          "type": "string",
          "description": "The ACC vendor ID (doesn\u2019t have to be HPI format)"
        },
        "hpiFacilityNumber": {
          "type": "string",
          "description": "The ACC facility number (doesn\u2019t have to be HPI format)"
        }
      }
    },
    "WorkCapacity": {
      "type": "object",
      "properties": {
        "canResumeNormalWork": {
          "type": "string",
          "description": "Only for a patient who is employed or self-employed.",
          "enum": [
            "True",
            "False"
          ]
        },
        "incapacity": {
          "type": "array",
          "description": "Only required when canResumeNormalWork is false.",
          "items": {
            "$ref": "#/definitions/Incapacity"
          }
        },
        "returnToNormalWorkDate": {
          "type": "string",
          "format": "date",
          "description": "Optional when canResumeNormalWork is false."
        }
      }
    }
  }
}