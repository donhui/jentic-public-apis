        "homePhone": {
          "type": "string",
          "example": "041234567",
          "description": "Include the area code, but no spaces or parentheses."
        },
        "workPhone": {
          "type": "string",
          "example": "041234567",
          "description": "Include the area code, but no spaces or parentheses."
        }
      }
    },
