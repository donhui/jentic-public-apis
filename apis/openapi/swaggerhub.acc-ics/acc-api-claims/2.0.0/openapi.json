          "items": {
            "$ref": "#/definitions/Diagnosis"
          }
        },
        "workCapacity": {
          "$ref": "#/definitions/WorkCapacity"
        },
        "referrals": {
          "type": "array",
          "description": "Up to 5 referrals may be included.",
          "items": {
            "$ref": "#/definitions/Referral"
          }
        },
        "declaration": {
          "$ref": "#/definitions/Declaration"
        }
