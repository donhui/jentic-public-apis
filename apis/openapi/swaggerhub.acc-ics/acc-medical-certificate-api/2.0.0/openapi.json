{
    "openapi": "3.0.0",
    "info": {
        "description": "Welcome to the API design for Medical Certificates at ACC. This API specification has been created to socialise API design with the sector and seek feedback for further refinement. Unplanned API routes have also been specified at a high level, to identify appetite for additional features. The ACC Claims API design principals are based on government standards and guidelines https://www.ict.govt.nz/guidance-and-resources/standards-compliance/api-standard-and-guidelines",
        "version": "2.0.0",
        "title": "ACC Medical Certificate API",
        "termsOfService": "https://developer.acc.co.nz/terms-conditions",
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/ACC-ICS/acc-medical_certificate_api/2.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "Medical Certificates",
            "description": "Medical Certificates Controller"
        }
    ],
    "paths": {
        "/claims/medical-certificates": {
            "post": {
                "tags": [
                    "Medical Certificates"
                ],
                "summary": "Create a new Medical Certificate.",
                "description": "Creates a new Medical Certificate for ACC to register.",
                "operationId": "medical-certificates",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/MedicalCertificate"
                            }
                        }
                    },
                    "description": "The Claim identifier of the Claim for the Medical Certificate to be attached.",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/MedicalCertificateCreatedResponse"
                                }
                            },
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/MedicalCertificateCreatedResponse"
                                }
                            }
                        }
                    },
                    "202": {
                        "description": "Accepted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/MedicalCertificateCreatedResponse"
                                }
                            },
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/MedicalCertificateCreatedResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request: invalid data",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            },
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized: authentication error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            },
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Forbidden: authorization error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            },
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            },
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            },
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiException"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "//localhost:8205/api/v2"
        }
    ],
    "components": {
        "schemas": {
            "AccAssistance": {
                "type": "object",
                "properties": {
                    "issuesDetails": {
                        "type": "string",
                        "description": "What complications or other issues are affecting recovery or rehabilitation?"
                    },
                    "otherComments": {
                        "type": "string",
                        "description": "What other assistance (equipment, home help, transport) should the patient discuss with a case manager?"
                    }
                }
            },
            "AccContact": {
                "type": "object",
                "properties": {
                    "anyDay": {
                        "type": "string",
                        "description": "Only required when contactRequired is true.",
                        "enum": [
                            "True",
                            "False"
                        ]
                    },
                    "preferredContactDay": {
                        "type": "array",
                        "description": "Only required when contactRequired is true and anyDay is false.",
                        "items": {
                            "type": "string",
                            "enum": [
                                "Monday",
                                "Tuesday",
                                "Wednesday",
                                "Thursday",
                                "Friday"
                            ]
                        }
                    },
                    "contactComments": {
                        "type": "string",
                        "description": "Optional when contactRequired is true."
                    }
                }
            },
            "Address": {
                "type": "object",
                "required": [
                    "city",
                    "country",
                    "line1",
                    "postCode",
                    "type"
                ],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "Home",
                            "Postal"
                        ]
                    },
                    "line1": {
                        "type": "string"
                    },
                    "line2": {
                        "type": "string"
                    },
                    "suburb": {
                        "type": "string"
                    },
                    "city": {
                        "type": "string"
                    },
                    "postCode": {
                        "type": "string"
                    },
                    "country": {
                        "type": "string"
                    }
                }
            },
            "ApiError": {
                "type": "object",
                "properties": {
                    "field": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    }
                }
            },
            "ApiException": {
                "type": "object",
                "properties": {
                    "errors": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ApiError"
                        }
                    }
                }
            },
            "Contact": {
                "type": "object",
                "properties": {
                    "emailAddress": {
                        "type": "string"
                    },
                    "mobilePhone": {
                        "type": "string"
                    },
                    "homePhone": {
                        "type": "string"
                    },
                    "workPhone": {
                        "type": "string"
                    }
                }
            },
            "DateRange": {
                "type": "object",
                "required": [
                    "fromDate",
                    "toDate"
                ],
                "properties": {
                    "fromDate": {
                        "type": "string",
                        "format": "date",
                        "description": "Date ranges must have no gaps and no overlaps."
                    },
                    "toDate": {
                        "type": "string",
                        "format": "date",
                        "description": "Date ranges must have no gaps and no overlaps."
                    }
                },
                "description": "A valid date is required for each incapacity type selected."
            },
            "Declaration": {
                "type": "object",
                "required": [
                    "providerDeclaration"
                ],
                "properties": {
                    "providerDeclaration": {
                        "type": "string",
                        "format": "date",
                        "description": "The date the form was submitted."
                    }
                }
            },
            "Diagnosis": {
                "type": "object",
                "required": [
                    "diagnosisAction",
                    "diagnosisCode",
                    "diagnosisCodeType",
                    "diagnosisDescription",
                    "diagnosisSide",
                    "primaryDiagnosisIndicator"
                ],
                "properties": {
                    "diagnosisCodeType": {
                        "type": "string",
                        "description": "See the DiagnosisCodingSystem code tables for valid values."
                    },
                    "diagnosisCode": {
                        "type": "string",
                        "description": "Alphanumeric, can include '.'"
                    },
                    "diagnosisDescription": {
                        "type": "string"
                    },
                    "diagnosisSide": {
                        "type": "string",
                        "enum": [
                            "left",
                            "right",
                            "notApplicable"
                        ]
                    },
                    "diagnosisComment": {
                        "type": "string"
                    },
                    "diagnosisAction": {
                        "type": "string",
                        "enum": [
                            "add",
                            "modify",
                            "delete"
                        ]
                    },
                    "primaryDiagnosisIndicator": {
                        "type": "string",
                        "description": "Select exactly one diagnosis in a request as primary.",
                        "enum": [
                            "True",
                            "False"
                        ]
                    }
                }
            },
            "Incapacity": {
                "type": "object",
                "required": [
                    "incapacityDateRange",
                    "incapacityType",
                    "selectedAlternativeWork"
                ],
                "properties": {
                    "incapacityType": {
                        "type": "string",
                        "description": "You can select 'fully unfit' no more than once, and 'fit for selected' no more than twice.",
                        "enum": [
                            "Fitforselectedwork",
                            "Fullyunfitforwork"
                        ]
                    },
                    "incapacityDateRange": {
                        "$ref": "#/components/schemas/DateRange"
                    },
                    "incapacityComments": {
                        "type": "string",
                        "description": "Only required when Fullyunfitforwork is true."
                    },
                    "selectedAlternativeWork": {
                        "$ref": "#/components/schemas/SelectedAlternativeWork"
                    }
                }
            },
            "MedicalCertificate": {
                "type": "object",
                "required": [
                    "diagnosis",
                    "pmsSoftwareName",
                    "pmsSoftwareVersion"
                ],
                "properties": {
                    "pmsSoftwareName": {
                        "type": "string"
                    },
                    "pmsSoftwareVersion": {
                        "type": "string"
                    },
                    "claimNumber": {
                        "type": "string",
                        "description": "1-12 alphanumeric characters. Examples: A123456, AA12345, 1234567, 12345678901, A1234567890 where A represents an alphabetic character and each digit represents any digit."
                    },
                    "declaration": {
                        "$ref": "#/components/schemas/Declaration"
                    },
                    "diagnosis": {
                        "type": "array",
                        "description": "If present, this must contain at least one diagnosis. 20 diagnoses permitted.",
                        "items": {
                            "$ref": "#/components/schemas/Diagnosis"
                        }
                    },
                    "patient": {
                        "$ref": "#/components/schemas/Patient"
                    },
                    "provider": {
                        "$ref": "#/components/schemas/Provider"
                    },
                    "vendor": {
                        "$ref": "#/components/schemas/Vendor"
                    },
                    "workCapacity": {
                        "$ref": "#/components/schemas/WorkCapacity"
                    }
                }
            },
            "MedicalCertificateCreatedResponse": {
                "type": "object",
                "properties": {
                    "medicalCertificateId": {
                        "type": "string"
                    },
                    "medicalCertificate": {
                        "$ref": "#/components/schemas/MedicalCertificate"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date"
                    },
                    "lastUpdate": {
                        "type": "string",
                        "format": "date"
                    }
                }
            },
            "Patient": {
                "type": "object",
                "required": [
                    "address",
                    "details"
                ],
                "properties": {
                    "address": {
                        "$ref": "#/components/schemas/Address"
                    },
                    "contact": {
                        "$ref": "#/components/schemas/Contact"
                    },
                    "details": {
                        "$ref": "#/components/schemas/PatientDetails"
                    }
                }
            },
            "PatientDetails": {
                "type": "object",
                "required": [
                    "accidentDate",
                    "dateOfBirth",
                    "firstName",
                    "surname"
                ],
                "properties": {
                    "accidentDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "dateOfBirth": {
                        "type": "string",
                        "format": "date"
                    },
                    "nhi": {
                        "type": "string"
                    },
                    "firstName": {
                        "type": "string"
                    },
                    "middleName": {
                        "type": "string"
                    },
                    "surname": {
                        "type": "string"
                    }
                }
            },
            "PhysicalRestrictions": {
                "type": "object",
                "properties": {
                    "restriction": {
                        "type": "string",
                        "enum": [
                            "Lifting",
                            "Posture",
                            "Heavy Physical",
                            "Repetition",
                            "Vibration",
                            "Temperature",
                            "Driving",
                            "Prolonged Sitting",
                            "Prolonged Walking",
                            "Prolonged Standing",
                            "Other"
                        ]
                    }
                }
            },
            "Provider": {
                "type": "object",
                "required": [
                    "address",
                    "details"
                ],
                "properties": {
                    "address": {
                        "$ref": "#/components/schemas/Address"
                    },
                    "contact": {
                        "$ref": "#/components/schemas/Contact"
                    },
                    "details": {
                        "$ref": "#/components/schemas/ProviderDetails"
                    }
                }
            },
            "ProviderDetails": {
                "type": "object",
                "required": [
                    "firstName",
                    "providerId",
                    "providerTypeCode",
                    "surname"
                ],
                "properties": {
                    "providerId": {
                        "type": "string",
                        "description": "The provider's ACC or HPI number, 1-8 characters."
                    },
                    "providerTypeCode": {
                        "type": "string",
                        "description": "See the ProviderType code tables for valid values."
                    },
                    "firstName": {
                        "type": "string"
                    },
                    "middleName": {
                        "type": "string"
                    },
                    "surname": {
                        "type": "string"
                    }
                }
            },
            "ReturnToWork": {
                "type": "object",
                "required": [
                    "assistanceRequired"
                ],
                "properties": {
                    "assistanceRequired": {
                        "type": "string",
                        "description": "Is return to work assistance required?",
                        "enum": [
                            "True",
                            "False"
                        ]
                    },
                    "assistanceType": {
                        "type": "string",
                        "description": "Only required when assistanceRequired is true.",
                        "enum": [
                            "needSupport",
                            "needClinicalReview"
                        ]
                    }
                }
            },
            "SelectedAlternativeWork": {
                "type": "object",
                "properties": {
                    "restrictionComment": {
                        "type": "string",
                        "description": "Optional if Fitforselectedwork is true."
                    },
                    "restrictedHoursPerDay": {
                        "type": "number",
                        "format": "double",
                        "description": "Optional, values 0.50 through 16.00"
                    },
                    "restrictedDaysPerWeek": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Optional, values 1 through 7"
                    },
                    "physicalRestrictions": {
                        "type": "array",
                        "description": "Optional if Fitforselectedwork is true, otherwise not permitted. Any of the listed items can be selected once, up to 11 choices.",
                        "items": {
                            "$ref": "#/components/schemas/PhysicalRestrictions"
                        }
                    }
                }
            },
            "Vendor": {
                "type": "object",
                "required": [
                    "hpiOrganisationNumber",
                    "practiceName"
                ],
                "properties": {
                    "hpiFacilityNumber": {
                        "type": "string",
                        "example": "F2C051, 87",
                        "description": "ID of the facility where the service was provided."
                    },
                    "hpiOrganisationNumber": {
                        "type": "string",
                        "description": "1-12 alphanumeric characters, can include '\\\\'"
                    },
                    "practiceName": {
                        "type": "string",
                        "description": "1-40 characters."
                    }
                }
            },
            "WorkCapacity": {
                "type": "object",
                "required": [
                    "contactRequired",
                    "returnToWork"
                ],
                "properties": {
                    "incapacity": {
                        "type": "array",
                        "description": "You can define up to 3 periods of incapacity. Each one must have a type and a date range.",
                        "items": {
                            "$ref": "#/components/schemas/Incapacity"
                        }
                    },
                    "reviewIncapacityDate": {
                        "type": "string",
                        "format": "date",
                        "description": "The date when ACC should check whether the patient is recovering as expected."
                    },
                    "returnToWork": {
                        "$ref": "#/components/schemas/ReturnToWork"
                    },
                    "accAssistance": {
                        "$ref": "#/components/schemas/AccAssistance"
                    },
                    "contactRequired": {
                        "type": "string",
                        "description": "True if the provider wants an ACC case manager to get in touch.",
                        "enum": [
                            "True",
                            "False"
                        ]
                    },
                    "accContact": {
                        "$ref": "#/components/schemas/AccContact"
                    }
                }
            }
        }
    }
}