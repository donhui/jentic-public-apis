{
  "openapi": "3.0.3",
  "info": {
    "title": "Juniper ATP Cloud API",
    "description": "Juniper ATP Cloud Public API for malware analysis, hash lookups, infected host management, and blocklist/allowlist operations.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://www.juniper.net/documentation/us/en/software/atp-cloud/atp-cloud-api-setup/topics/concept/atp-cloud-api-overview.html"
  },
  "servers": [
    {
      "url": "https://api.sky.junipersecurity.net/v2/skyatp",
      "description": "US Region"
    },
    {
      "url": "https://api-eu.sky.junipersecurity.net/v2/skyatp",
      "description": "EU Region"
    },
    {
      "url": "https://api-apac.sky.junipersecurity.net/v2/skyatp",
      "description": "APAC Region"
    },
    {
      "url": "https://api-canada.sky.junipersecurity.net/v2/skyatp",
      "description": "Canada Region"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check endpoints"
    },
    {
      "name": "Infected Hosts",
      "description": "Manage infected host lists"
    },
    {
      "name": "Malware Analysis",
      "description": "Submit samples and look up hashes"
    },
    {
      "name": "Blocklist/Allowlist File",
      "description": "Manage blocklist and allowlist feeds via file upload"
    },
    {
      "name": "Blocklist/Allowlist Param",
      "description": "Manage blocklist and allowlist feeds via parameters"
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "operationId": "ping",
        "summary": "Health check endpoint",
        "tags": ["Health"],
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy"
          }
        }
      }
    },
    "/infected_hosts": {
      "get": {
        "operationId": "getInfectedHosts",
        "summary": "Get all infected host lists",
        "tags": ["Infected Hosts"],
        "responses": {
          "200": {
            "description": "Infected host lists retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfectedHostsBlwlResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/infected_hosts/{list_type}": {
      "get": {
        "operationId": "getInfectedHostsByListType",
        "summary": "Get infected hosts for a specific list type",
        "tags": ["Infected Hosts"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          }
        ],
        "responses": {
          "200": {
            "description": "Infected host list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfectedHostsBlwlResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteInfectedHosts",
        "summary": "Remove IP addresses from an infected host list",
        "tags": ["Infected Hosts"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InfectedHostsBlwlInput"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestAccepted"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateInfectedHosts",
        "summary": "Add IP addresses to an infected host list",
        "tags": ["Infected Hosts"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InfectedHostsBlwlInput"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestAccepted"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/lookup/hash/{hash_string}": {
      "get": {
        "operationId": "lookupHash",
        "summary": "Look up malware score by SHA256 hash",
        "tags": ["Malware Analysis"],
        "parameters": [
          {
            "name": "hash_string",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 64,
              "maxLength": 64
            },
            "description": "SHA256 hash of the file"
          },
          {
            "name": "full_report",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Whether to return full analysis report"
          }
        ],
        "responses": {
          "200": {
            "description": "Scan result found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/lookup/stix/{hash_string}": {
      "get": {
        "operationId": "lookupStix",
        "summary": "Look up STIX report by SHA256 hash",
        "tags": ["Malware Analysis"],
        "parameters": [
          {
            "name": "hash_string",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 64,
              "maxLength": 64
            },
            "description": "SHA256 hash of the file"
          }
        ],
        "responses": {
          "200": {
            "description": "STIX result found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StixResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/submit/sample": {
      "post": {
        "operationId": "submitSample",
        "summary": "Submit a file for malware analysis",
        "tags": ["Malware Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/SampleSubmission"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scan result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScanResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/{list_type}/file/{server_type}": {
      "get": {
        "operationId": "getBlwlFileFeed",
        "summary": "Get blocklist or allowlist file feed status",
        "tags": ["Blocklist/Allowlist File"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          },
          {
            "$ref": "#/components/parameters/serverType"
          }
        ],
        "responses": {
          "200": {
            "description": "Feed data retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlwlResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteBlwlFileFeed",
        "summary": "Remove entries from a blocklist/allowlist via file",
        "tags": ["Blocklist/Allowlist File"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          },
          {
            "$ref": "#/components/parameters/serverType"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/FileUploadWithFailOnError"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestAccepted"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateBlwlFileFeed",
        "summary": "Update entries in a blocklist/allowlist via file",
        "tags": ["Blocklist/Allowlist File"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          },
          {
            "$ref": "#/components/parameters/serverType"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/FileUploadWithFailOnError"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestAccepted"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/{list_type}/param/{server_type}": {
      "get": {
        "operationId": "getBlwlParamFeed",
        "summary": "Get blocklist or allowlist param feed status",
        "tags": ["Blocklist/Allowlist Param"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          },
          {
            "$ref": "#/components/parameters/serverType"
          }
        ],
        "responses": {
          "200": {
            "description": "Feed data retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlwlResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteBlwlParamFeed",
        "summary": "Remove an entry from a blocklist/allowlist",
        "tags": ["Blocklist/Allowlist Param"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          },
          {
            "$ref": "#/components/parameters/serverType"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ParamServer"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestAccepted"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateBlwlParamFeed",
        "summary": "Update an entry in a blocklist/allowlist",
        "tags": ["Blocklist/Allowlist Param"],
        "parameters": [
          {
            "$ref": "#/components/parameters/listType"
          },
          {
            "$ref": "#/components/parameters/serverType"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ParamServer"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestAccepted"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token generated from Juniper ATP Cloud Web UI (Administration > Application Tokens). Maximum 10 tokens per user, valid for one year."
      }
    },
    "parameters": {
      "listType": {
        "name": "list_type",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "enum": ["blacklist", "whitelist"]
        },
        "description": "List type (blacklist or whitelist)"
      },
      "serverType": {
        "name": "server_type",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "enum": ["ip", "url", "domain"]
        },
        "description": "Type of server entries (ip, url, or domain)"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "err_id": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          }
        }
      },
      "RequestAccepted": {
        "type": "object",
        "properties": {
          "request_id": {
            "type": "string",
            "description": "ID for tracking the asynchronous request"
          }
        }
      },
      "InfectedHostsBlwlResult": {
        "type": "object",
        "properties": {
          "blacklist": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IP addresses on the blacklist"
          },
          "whitelist": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IP addresses on the whitelist"
          }
        }
      },
      "InfectedHostsBlwlInput": {
        "type": "object",
        "required": ["ip"],
        "properties": {
          "ip": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of IP addresses"
          }
        }
      },
      "ScanResult": {
        "type": "object",
        "properties": {
          "hash": {
            "type": "string",
            "description": "SHA256 hash of the analyzed file"
          },
          "score": {
            "type": "integer",
            "description": "Malware threat score"
          },
          "malware_name": {
            "type": "string",
            "description": "Name of detected malware if applicable"
          },
          "status": {
            "type": "string",
            "description": "Analysis status"
          }
        }
      },
      "StixResult": {
        "type": "object",
        "properties": {
          "stix_report": {
            "type": "object",
            "description": "STIX formatted threat intelligence report"
          }
        }
      },
      "SampleSubmission": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "File to submit for malware analysis"
          },
          "full_report": {
            "type": "boolean",
            "description": "Whether to return full analysis report"
          },
          "sample_url": {
            "type": "string",
            "description": "URL where the sample was obtained"
          },
          "remote_ip": {
            "type": "string",
            "description": "Remote IP address associated with the sample"
          },
          "client_ip": {
            "type": "string",
            "description": "Client IP address"
          },
          "client_hostname": {
            "type": "string",
            "description": "Client hostname (FQDN)"
          },
          "username": {
            "type": "string",
            "description": "Username associated with the submission"
          }
        }
      },
      "BlwlResult": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of entries in the feed"
          },
          "count": {
            "type": "integer",
            "description": "Number of entries"
          }
        }
      },
      "FileUploadWithFailOnError": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "CSV file with entries"
          },
          "failOnError": {
            "type": "boolean",
            "default": true,
            "description": "Whether to fail the entire operation on any error"
          }
        }
      },
      "ParamServer": {
        "type": "object",
        "required": ["server"],
        "properties": {
          "server": {
            "type": "string",
            "maxLength": 128,
            "description": "IP address, URL, or domain (IPv4/IPv6/URL/FQDN)"
          }
        }
      }
    }
  }
}