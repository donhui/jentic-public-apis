  "components": {
    "schemas": {
      "DomainResult": {
        "type": "object",
        "properties": {
          "Results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DomainResultItem"
            }
          },
          "Errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "DomainResultItem": {
        "type": "object",
        "properties": {
          "Result": {
            "type": "object",
            "properties": {
              "Paths": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PathInfo"
                }
              },
              "IsDB": {
                "type": "boolean"
              },
              "Spend": {
                "type": "integer"
              },
              "SalesRevenue": {
                "type": "string"
              }
            }
          },
          "Meta": {
            "type": "object"
          },
          "Attributes": {
            "type": "object"
          },
          "Lookup": {
            "type": "string"
          }
        }
      },
      "PathInfo": {
        "type": "object",
        "properties": {
          "FirstIndexed": {
            "type": "string",
            "format": "date-time"
          },
          "LastIndexed": {
            "type": "string",
            "format": "date-time"
          },
          "Domain": {
            "type": "string"
          },
          "Url": {
            "type": "string"
          },
          "SubDomain": {
            "type": "string"
          },
          "Technologies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Technology"
            }
          }
        }
      },
      "Technology": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string"
          },
          "Tag": {
            "type": "string"
          },
          "Description": {
            "type": "string"
          },
          "Link": {
            "type": "string"
          },
          "Categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "FirstDetected": {
            "type": "string",
            "format": "date-time"
          },
          "LastDetected": {
            "type": "string",
            "format": "date-time"
          },
          "IsPremium": {
            "type": "string"
          }
        }
      },
      "FreeDomainResult": {
        "type": "object",
        "properties": {
          "groups": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "RelationshipsResult": {
        "type": "object",
        "properties": {
          "Relationships": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ListResult": {
        "type": "object",
        "properties": {
          "Results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "CompanyResult": {
        "type": "object",
        "properties": {
          "Results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "TrendsResult": {
        "type": "object",
        "properties": {
          "Results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "KeywordsResult": {
        "type": "object",
        "properties": {
          "Results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
