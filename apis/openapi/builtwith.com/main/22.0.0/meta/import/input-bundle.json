{
  "openapi": "3.0.3",
  "info": {
    "title": "BuiltWith Domain API",
    "description": "BuiltWith Domain API provides access to technology information of websites, including all technical information as found on detailed lookups at builtwith.com and additional metadata where available.",
    "version": "22.0.0",
    "x-jentic-source-url": "https://www.builtwith.com/api"
  },
  "servers": [
    {
      "url": "https://api.builtwith.com",
      "description": "BuiltWith API Production"
    }
  ],
  "paths": {
    "/v22/api.json": {
      "get": {
        "tags": [
          "Domain"
        ],
        "summary": "Get domain technology profile (JSON)",
        "operationId": "getDomainJson",
        "parameters": [
          {
            "name": "KEY",
            "in": "query",
            "required": true,
            "description": "API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "LOOKUP",
            "in": "query",
            "required": true,
            "description": "Domain to lookup",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "HIDETEXT",
            "in": "query",
            "description": "Hide descriptive text",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "HIDEDL",
            "in": "query",
            "description": "Hide dead links",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "NOMETA",
            "in": "query",
            "description": "Exclude meta data",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Domain technology data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DomainResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        },
        "security": [
          {
            "apiKey": []
          }
        ]
      }
    },
