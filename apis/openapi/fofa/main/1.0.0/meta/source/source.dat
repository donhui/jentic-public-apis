{
  "openapi": "3.0.3",
  "info": {
    "title": "FOFA API",
    "description": "FOFA network space mapping and security search engine API. Provides endpoints for querying assets, aggregating host data, and managing account information.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://en.fofa.info/api"
  },
  "servers": [
    {
      "url": "https://api.fofa.info/v1",
      "description": "FOFA API server"
    }
  ],
  "paths": {
    "/search/all": {
      "get": {
        "operationId": "searchAll",
        "summary": "Search for assets",
        "description": "Query FOFA for assets matching a search query. Returns IP, port, protocol, and other asset information.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Account email address"
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "API key"
          },
          {
            "name": "qbase64",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Base64-encoded search query"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": { "type": "string", "default": "host,ip,port" },
            "description": "Comma-separated fields to return (e.g., host,ip,port,protocol,title)"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 },
            "description": "Page number"
          },
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer", "default": 100 },
            "description": "Number of results per page"
          },
          {
            "name": "full",
            "in": "query",
            "schema": { "type": "boolean", "default": false },
            "description": "Whether to search all data (true) or only within last year (false)"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResponse" }
              }
            }
          },
          "400": { "description": "Invalid request parameters" },
          "401": { "description": "Invalid email or API key" }
        }
      }
    },
    "/search/stats": {
      "get": {
        "operationId": "searchStats",
        "summary": "Get aggregation statistics for a search query",
        "description": "Return statistical aggregation data for a search query including top countries, ports, protocols, etc.",
        "tags": ["Aggregation"],
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "qbase64",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Base64-encoded search query"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Aggregation fields (e.g., country,protocol)"
          }
        ],
        "responses": {
          "200": {
            "description": "Aggregation statistics",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatsResponse" }
              }
            }
          },
          "400": { "description": "Invalid request" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/host/{host}": {
      "get": {
        "operationId": "getHostDetails",
        "summary": "Get host aggregation details",
        "description": "Retrieve detailed information about a specific host including open ports, protocols, and services.",
        "tags": ["Aggregation"],
        "parameters": [
          {
            "name": "host",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Target host IP or domain"
          },
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "detail",
            "in": "query",
            "schema": { "type": "boolean", "default": false },
            "description": "Include detailed port information"
          }
        ],
        "responses": {
          "200": {
            "description": "Host details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HostResponse" }
              }
            }
          },
          "400": { "description": "Invalid request" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/info/my": {
      "get": {
        "operationId": "getAccountInfo",
        "summary": "Get account information",
        "description": "Retrieve current account details including membership level, remaining API credits, and quota.",
        "tags": ["Account"],
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccountInfo" }
              }
            }
          },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/search/next": {
      "get": {
        "operationId": "searchNext",
        "summary": "Continuous pagination search",
        "description": "Search with continuous pagination support for iterating through large result sets efficiently.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "qbase64",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Base64-encoded search query"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": { "type": "string", "default": "host,ip,port" }
          },
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer", "default": 100 }
          },
          {
            "name": "next",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Pagination cursor from previous response"
          },
          {
            "name": "full",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results with pagination cursor",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchNextResponse" }
              }
            }
          },
          "400": { "description": "Invalid request" },
          "401": { "description": "Invalid credentials" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "boolean" },
          "errmsg": { "type": "string" },
          "size": { "type": "integer", "description": "Total number of results" },
          "page": { "type": "integer" },
          "mode": { "type": "string" },
          "query": { "type": "string" },
          "results": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "string" }
            },
            "description": "Array of result rows, each being an array of field values"
          }
        }
      },
      "SearchNextResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "boolean" },
          "errmsg": { "type": "string" },
          "size": { "type": "integer" },
          "next": { "type": "string", "description": "Cursor for next page" },
          "query": { "type": "string" },
          "results": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "boolean" },
          "errmsg": { "type": "string" },
          "distinct": {
            "type": "object",
            "additionalProperties": { "type": "integer" }
          },
          "aggs": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "count": { "type": "integer" }
                }
              }
            }
          }
        }
      },
      "HostResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "boolean" },
          "errmsg": { "type": "string" },
          "host": { "type": "string" },
          "ip": { "type": "string" },
          "asn": { "type": "integer" },
          "org": { "type": "string" },
          "country_name": { "type": "string" },
          "country_code": { "type": "string" },
          "ports": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "protocols": {
            "type": "array",
            "items": { "type": "string" }
          },
          "categories": {
            "type": "array",
            "items": { "type": "string" }
          },
          "products": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "AccountInfo": {
        "type": "object",
        "properties": {
          "error": { "type": "boolean" },
          "email": { "type": "string" },
          "username": { "type": "string" },
          "fcoin": { "type": "integer", "description": "F-coin balance" },
          "isvip": { "type": "boolean" },
          "vip_level": { "type": "integer" },
          "is_verified": { "type": "boolean" },
          "avatar": { "type": "string" },
          "fofacli_ver": { "type": "string" },
          "fofa_server": { "type": "boolean" }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "FOFA API key (also requires email parameter)"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ]
}