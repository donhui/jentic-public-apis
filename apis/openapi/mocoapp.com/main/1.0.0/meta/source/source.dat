{
  "openapi": "3.0.3",
  "info": {
    "title": "MOCO API",
    "version": "1.0.0",
    "description": "MOCO is a business operating system for service companies. This API provides access to projects, activities, invoices, companies, contacts, deals, purchases, users, and more.",
    "x-jentic-source-url": "https://hundertzehn.github.io/mocoapp-api-docs/"
  },
  "servers": [
    {
      "url": "https://{subdomain}.mocoapp.com/api/v1",
      "description": "MOCO instance API",
      "variables": {
        "subdomain": {
          "description": "Your MOCO account subdomain.",
          "default": "example"
        }
      }
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    { "name": "Activities", "description": "Time tracking activities" },
    { "name": "Comments", "description": "Comments on resources" },
    { "name": "Companies", "description": "Company management" },
    { "name": "Contacts", "description": "Contact people" },
    { "name": "Deals", "description": "Sales deals/opportunities" },
    { "name": "DealCategories", "description": "Deal category management" },
    { "name": "Invoices", "description": "Invoice management" },
    { "name": "InvoicePayments", "description": "Invoice payment records" },
    { "name": "InvoiceReminders", "description": "Invoice reminder management" },
    { "name": "Offers", "description": "Offer/quote management" },
    { "name": "Projects", "description": "Project management" },
    { "name": "ProjectTasks", "description": "Project task management" },
    { "name": "ProjectContracts", "description": "Project staff contracts" },
    { "name": "ProjectExpenses", "description": "Project expense tracking" },
    { "name": "ProjectGroups", "description": "Project group management" },
    { "name": "ProjectPaymentSchedules", "description": "Project payment schedules" },
    { "name": "PlanningEntries", "description": "Resource planning entries" },
    { "name": "Purchases", "description": "Purchase/bill management" },
    { "name": "PurchaseCategories", "description": "Purchase category management" },
    { "name": "PurchaseDrafts", "description": "Purchase draft management" },
    { "name": "PurchasePayments", "description": "Purchase payment records" },
    { "name": "Receipts", "description": "Receipt management" },
    { "name": "RecurringExpenses", "description": "Recurring expense management" },
    { "name": "Reports", "description": "Reporting endpoints" },
    { "name": "Schedules", "description": "Absence/schedule management" },
    { "name": "Tags", "description": "Tag management" },
    { "name": "Taggings", "description": "Tag assignments" },
    { "name": "Units", "description": "Organizational unit management" },
    { "name": "Users", "description": "User management" },
    { "name": "UserEmployments", "description": "User employment records" },
    { "name": "UserHolidays", "description": "User holiday entitlements" },
    { "name": "UserPresences", "description": "User presence/attendance tracking" },
    { "name": "Webhooks", "description": "Webhook management" },
    { "name": "Account", "description": "Account configuration" },
    { "name": "Profile", "description": "Current user profile" },
    { "name": "Session", "description": "Session information" }
  ],
  "paths": {
    "/activities": {
      "get": {
        "operationId": "listActivities",
        "summary": "List activities",
        "tags": ["Activities"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "sort_by", "in": "query", "schema": { "type": "string" } },
          { "name": "ids", "in": "query", "schema": { "type": "string" } },
          { "name": "updated_after", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": { "description": "List of activities.", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      },
      "post": {
        "operationId": "createActivity",
        "summary": "Create an activity",
        "tags": ["Activities"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ActivityInput" } } } },
        "responses": {
          "200": { "description": "Created activity.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Activity" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      }
    },
    "/activities/{id}": {
      "get": {
        "operationId": "getActivity",
        "summary": "Get an activity",
        "tags": ["Activities"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Activity details.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Activity" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      },
      "put": {
        "operationId": "updateActivity",
        "summary": "Update an activity",
        "tags": ["Activities"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ActivityInput" } } } },
        "responses": {
          "200": { "description": "Updated activity.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Activity" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      },
      "delete": {
        "operationId": "deleteActivity",
        "summary": "Delete an activity",
        "tags": ["Activities"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Activity deleted." },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      }
    },
    "/activities/{id}/start_timer": {
      "post": {
        "operationId": "startActivityTimer",
        "summary": "Start timer on an activity",
        "tags": ["Activities"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Timer started.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Activity" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      }
    },
    "/activities/{id}/stop_timer": {
      "post": {
        "operationId": "stopActivityTimer",
        "summary": "Stop timer on an activity",
        "tags": ["Activities"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Timer stopped.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Activity" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      }
    },
    "/activities/bulk": {
      "post": {
        "operationId": "bulkActivities",
        "summary": "Bulk operations on activities",
        "tags": ["Activities"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": {
          "200": { "description": "Bulk operation completed." },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      }
    },
    "/activities/disregard": {
      "post": {
        "operationId": "disregardActivities",
        "summary": "Mark activities as disregarded",
        "tags": ["Activities"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": {
          "200": { "description": "Activities disregarded." },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
        }
      }
    },
