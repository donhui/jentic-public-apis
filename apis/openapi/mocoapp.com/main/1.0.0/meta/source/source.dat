          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageError" } } } }
