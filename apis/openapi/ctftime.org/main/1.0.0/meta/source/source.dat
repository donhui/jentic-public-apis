{
  "openapi": "3.0.3",
  "info": {
    "title": "CTFtime API",
    "description": "CTFtime.org API v1 providing access to CTF (Capture The Flag) competition events, teams, results, and rankings. Data is provided for data analysis and mobile applications only.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://ctftime.org/api"
  },
  "servers": [
    {
      "url": "https://ctftime.org/api/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/top/": {
      "get": {
        "operationId": "getTopTeams",
        "summary": "Get current year's top teams",
        "tags": ["Rankings"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of teams to return",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Top teams for the current year",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/TeamRanking"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/top/{year}/": {
      "get": {
        "operationId": "getTopTeamsByYear",
        "summary": "Get top teams for a specific year",
        "tags": ["Rankings"],
        "parameters": [
          {
            "name": "year",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of teams to return",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Top teams for the specified year",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/TeamRanking"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/top-by-country/{countryCode}/": {
      "get": {
        "operationId": "getTopTeamsByCountry",
        "summary": "Get current year's top teams by country",
        "tags": ["Rankings"],
        "parameters": [
          {
            "name": "countryCode",
            "in": "path",
            "required": true,
            "description": "ISO country code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Top teams for the specified country",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TeamRanking"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/events/": {
      "get": {
        "operationId": "listEvents",
        "summary": "List past and upcoming CTF events",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of events to return",
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Start timestamp filter (Unix timestamp)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "finish",
            "in": "query",
            "required": false,
            "description": "End timestamp filter (Unix timestamp)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of CTF events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/events/{eventId}/": {
      "get": {
        "operationId": "getEvent",
        "summary": "Get details for a specific CTF event",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "eventId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Event not found"
          }
        }
      }
    },
    "/teams/{teamId}/": {
      "get": {
        "operationId": "getTeam",
        "summary": "Get details for a specific team",
        "tags": ["Teams"],
        "parameters": [
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Team details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Team"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Team not found"
          }
        }
      }
    },
    "/results/{year}/": {
      "get": {
        "operationId": "getResultsByYear",
        "summary": "Get event results for a specific year",
        "tags": ["Results"],
        "parameters": [
          {
            "name": "year",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Results for the specified year",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/votes/{year}/": {
      "get": {
        "operationId": "getVotesByYear",
        "summary": "Get event votes for a specific year",
        "tags": ["Votes"],
        "parameters": [
          {
            "name": "year",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Votes for the specified year",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Event ID"
          },
          "title": {
            "type": "string",
            "description": "Event title"
          },
          "description": {
            "type": "string",
            "description": "Event description"
          },
          "url": {
            "type": "string",
            "description": "Event website URL"
          },
          "ctftime_url": {
            "type": "string",
            "description": "CTFtime event page URL"
          },
          "ctf_id": {
            "type": "integer",
            "description": "CTF series ID"
          },
          "logo": {
            "type": "string",
            "description": "Event logo URL"
          },
          "weight": {
            "type": "number",
            "description": "Event weight for rating calculations"
          },
          "start": {
            "type": "string",
            "format": "date-time",
            "description": "Event start time (ISO 8601)"
          },
          "finish": {
            "type": "string",
            "format": "date-time",
            "description": "Event end time (ISO 8601)"
          },
          "duration": {
            "$ref": "#/components/schemas/Duration"
          },
          "format": {
            "type": "string",
            "description": "Competition format (e.g., Jeopardy, Attack-Defense)"
          },
          "format_id": {
            "type": "integer",
            "description": "Format identifier"
          },
          "location": {
            "type": "string",
            "description": "Physical location for onsite events"
          },
          "onsite": {
            "type": "boolean",
            "description": "Whether the event is onsite"
          },
          "restrictions": {
            "type": "string",
            "description": "Participation restrictions"
          },
          "participants": {
            "type": "integer",
            "description": "Number of registered participants"
          },
          "prizes": {
            "type": "string",
            "description": "Prize description"
          },
          "organizers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Organizer"
            }
          },
          "is_votable_now": {
            "type": "boolean",
            "description": "Whether voting is currently open"
          },
          "public_votable": {
            "type": "boolean",
            "description": "Whether public voting is enabled"
          },
          "live_feed": {
            "type": "string",
            "description": "Live feed URL"
          }
        }
      },
      "Duration": {
        "type": "object",
        "properties": {
          "hours": {
            "type": "integer"
          },
          "days": {
            "type": "integer"
          }
        }
      },
      "Organizer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "rating": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "TeamRanking": {
        "type": "object",
        "properties": {
          "team_id": {
            "type": "integer"
          },
          "team_name": {
            "type": "string"
          },
          "points": {
            "type": "number"
          },
          "country": {
            "type": "string"
          }
        }
      }
    }
  }
}