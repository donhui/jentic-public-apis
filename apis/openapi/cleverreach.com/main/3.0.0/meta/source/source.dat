          {
            "name": "pagesize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "Max items."
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "Page."
          }
        ]
      }
    },
