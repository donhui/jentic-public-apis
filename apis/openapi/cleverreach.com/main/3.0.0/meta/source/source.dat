    "/v3/mailings": {
      "get": {
        "summary": "return lists of mailings.  <i class=\"icon-unlock-alt icon-large\"></i>",
        "description": " returns lists of mailings according to following filter settings<br> <br> <strong>NOTE:</strong> The <code>start</code> and <code>end</code> fields depend on the <code>state</code> field.<br> &nbsp;&nbsp;-&nbsp;finished mails are filtered by finished time<br> &nbsp;&nbsp;-&nbsp;draft mails are filtered by creation time<br> &nbsp;&nbsp;-&nbsp;waiting mails are filtered by the time they will be sent<br> &nbsp;&nbsp;-&nbsp;running mails are filtered by the time they have been started<br>",
        "operationId": "list",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "number of items."
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "state of mailing."
          },
          {
            "name": "channel_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "(optional): if specified, it will only return matching results."
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "(optional) Filter by start time (see note)."
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "(optional) Filter by end time (see note)."
          }
        ]
      },
      "post": {
        "summary": "create a mailing.  <i class=\"icon-unlock-alt icon-large\"></i>",
        "description": " create a new mailing<br> <br> <strong>Example Post Data:</strong><br> <code> {<br> &nbsp;&nbsp;&nbsp;&nbsp;\"name\":&nbsp;\"my internal name\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"subject\":&nbsp;\"subject line\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"sender_name\":&nbsp;\"Bruce Wayne (Wayne corp.)\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"sender_email\":&nbsp;\"bruce.wayne@gotham.com\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"content\":&nbsp;{<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"type\":&nbsp;\"html/text\",&nbsp;&nbsp;//&nbsp;\"html\", \"text\" or \"html/text\"<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"html\":&nbsp;\"&lt;html&gt;&lt;body&gt;The two faces of Harvey Dent&lt;/body&gt;&lt;/html&gt;\",<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"text\":&nbsp;\"The two faces of Harvey Dent\"<br> &nbsp;&nbsp;&nbsp;&nbsp;},<br> &nbsp;&nbsp;&nbsp;&nbsp;\"receivers\":&nbsp;{&nbsp;&nbsp;//&nbsp;fill either a list of group ids or a filter id<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"groups\":&nbsp;[&nbsp;\"31939\",&nbsp;\"81942\"&nbsp;],<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"filter\":&nbsp;\"66\"<br> &nbsp;&nbsp;&nbsp;&nbsp;},<br> &nbsp;&nbsp;&nbsp;&nbsp;\"settings\":&nbsp;{<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"editor\": \"wizard\",&nbsp;&nbsp;//&nbsp;\"wizard\", \"freeform\", \"advanced\", \"plaintext\"<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"open_tracking\": true,&nbsp;&nbsp;//&nbsp;track opening of emails<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"click_tracking\": true,&nbsp;&nbsp;//&nbsp;track clicks of emails<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"link_tracking_url\": \"27.wayne.cleverreach.com\",<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"link_tracking_type\": \"google\",&nbsp;&nbsp;//&nbsp;\"google\", \"intelliad\", \"crconnect\"<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"google_campaign_name\": \"My Campaign\",&nbsp;&nbsp;//&nbsp;in case of link_tracking_type == \"google\"<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"unsubscribe_form_id\": \"23\",<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"category_id\": \"54\"<br> &nbsp;&nbsp;&nbsp;&nbsp;}<br> } </code><br> <br> <strong>Note:</strong> For links not to be substituted by tracking links, use 'single quotes' around urls in your html. <br>",
        "operationId": "create",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "/v3/mailings/{id}": {
      "get": {
        "summary": "return mailing.  <i class=\"icon-unlock-alt icon-large\"></i>",
