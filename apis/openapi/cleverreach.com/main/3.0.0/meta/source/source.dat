;//&nbsp;in case of link_tracking_type == \"google\"<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"unsubscribe_form_id\": \"23\",<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"category_id\": \"54\"<br> &nbsp;&nbsp;&nbsp;&nbsp;}<br> } </code>",
        "operationId": "update",
        "responses": {
          "200": {
