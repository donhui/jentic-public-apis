            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "State to get."
          },
          {
            "name": "linkid",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "ID of link that was clicked on."
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "Timestamp of earliest event of state."
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "Timestamp of latest event of state."
          },
          {
            "name": "detail",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "Detail depth (bitwise combinable) (0: none, 1: events, 2: orders, 4: tags)."
