    "/v3/groups/{group_id}/filters": {
      "get": {
        "summary": "return filter.",
        "description": " return filter",
        "operationId": "list_",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      },
      "post": {
        "summary": "creates a filter/segment.",
        "description": " creates a filter/segment<br> <br> <strong>Example Post Data:</strong><br> <code> {<br> &nbsp;&nbsp;&nbsp;&nbsp;\"name\": \"My Filter\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"operator\": \"OR\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"rules\": [<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{ \"field\":\"email\", \"logic\":\"contains\", \"condition\":\"@gotham.com\" },<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{ \"field\":\"activated\", \"logic\":\"bg\", \"condition\":\"1234567\" },<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{ \"field\":\"firstname\", \"logic\":\"eq\", \"condition\":\"bruce\" },<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{ \"field\":\"lastname\", \"logic\":\"eq\", \"condition\":\"wayne\" }<br> &nbsp;&nbsp;&nbsp;&nbsp;]<br> }<br> </code> <br> <hr> <strong>Possible Operators</strong><br> <ol> <li>OR</li> <li>AND (default)</li> </ol> <br> <strong>Available Logics:</strong><br> <ol> <li>eq - <small>equals</small></li> <li>neq - <small>not equals</small></li> <li>sm - <small>smaller</small></li> <li>bg - <small>bigger</small></li> <li>isnull - <small>is empty</small></li> <li>notisnull - <small>not empty</small></li> <li>contains - <small>contains given string</small></li> <li>begins - <small>begins with</small></li> <li>ends - <small>ends with</small></li> <li>ismale - <small>given field is male</small></li> <li>isfemale - <small>given field is female</small></li> </ol> <br> <strong>general available fields:</strong><br> <ol> <li>email - <small>(email of the receiver)</small></li> <li>source - <small>(import source of the email)</small></li> <li>imported - <small>(timestamp of receiver import)</small></li> <li>registered - <small>(timestamp of receiver registration)</small></li> <li>activated - <small>(timestamp of receiver activation)</small></li> <li>deactivated - <small>(timestamp of receiver deactivation)</small></li> <li>bounced - <small>(timestamp of receiver bounce)</small></li> <li>points - <small>(points of the receiver)</small></li> <li>last_location - <small>(last location of receiver)</small></li> <li>last_client - <small>(last mail client used by receiver)</small></li> <li>crevent_mail_send (logic: eq, condition: mailing_id -> receiver of certain mailing)</li> <li>crevent_mail_open (logic: eq, condition: mailing_id -> opened mail of certain mailing)</li> <li>crevent_mail_click (logic: eq, condition: mailing_id -> clicked on mail of certain mailing)</li> <li>crevent_mail_bounce (logic: eq, condition: mailing_id -> bounced mail of certain mailing)</li> <li>all attributes (if global and group attributes have the same name, group ones will be favoured)</li> </ol> <br>",
        "operationId": "createFilter",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "group ID."
          }
        ]
      }
    },
    "/v3/groups/{group_id}/filters/{filter_id}": {
      "get": {
        "summary": "get filter.",
        "description": " get filter",
        "operationId": "retrieve_",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Group ID."
          },
          {
            "name": "filter_id",
            "in": "path",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter ID."
          }
        ]
      },
      "put": {
        "summary": "updates a filter/segment.",
        "description": " updates a filter/segment<br> <br> <strong>Example Post Data:</strong><br> <code> {<br> &nbsp;&nbsp;&nbsp;&nbsp;\"name\": \"My Filter\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"operator\": \"OR\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"rules\": [<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{ \"field\":\"email\", \"logic\":\"contains\", \"condition\":\"@gotham.com\" },<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{ \"field\":\"activated\", \"logic\":\"bg\", \"condition\":\"1234567\" },<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{ \"field\":\"firstname\", \"logic\":\"eq\", \"condition\":\"brooze\" },<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{ \"field\":\"lastname\", \"logic\":\"eq\", \"condition\":\"vain\" }<br> &nbsp;&nbsp;&nbsp;&nbsp;]<br> }<br> </code> <br> <hr> <strong>Possible Operators</strong><br> <ol> <li>OR</li> <li>AND (default)</li> </ol> <br> <strong>Available Logics:</strong><br> <ol> <li>eq - <small>equals</small></li> <li>neq - <small>not equals</small></li> <li>sm - <small>smaller</small></li> <li>bg - <small>bigger</small></li> <li>isnull - <small>is empty</small></li> <li>notisnull - <small>not empty</small></li> <li>contains - <small>contains given string</small></li> <li>begins - <small>begins with</small></li> <li>ends - <small>ends with</small></li> <li>ismale - <small>given field is male</small></li> <li>isfemale - <small>given field is female</small></li> </ol> <br> <strong>general available fields:</strong><br> <ol> <li>email - <small>(email of the receiver)</small></li> <li>source - <small>(import source of the email)</small></li> <li>imported - <small>(timestamp of receiver import)</small></li> <li>registered - <small>(timestamp of receiver registration)</small></li> <li>activated - <small>(timestamp of receiver activation)</small></li> <li>deactivated - <small>(timestamp of receiver deactivation)</small></li> <li>bounced - <small>(timestamp of receiver bounce)</small></li> <li>points - <small>(points of the receiver)</small></li> <li>last_location - <small>(last location of receiver)</small></li> <li>last_client - <small>(last mail client used by receiver)</small></li> <li>crevent_mail_send (logic: eq, condition: mailing_id -> receiver of certain mailing)</li> <li>crevent_mail_open (logic: eq, condition: mailing_id -> opened mail of certain mailing)</li> <li>crevent_mail_click (logic: eq, condition: mailing_id -> clicked on mail of certain mailing)</li> <li>crevent_mail_bounce (logic: eq, condition: mailing_id -> bounced mail of certain mailing)</li> <li>all attributes (if global and group attributes have the same name, group ones will be favoured)</li> </ol> <br>",
        "operationId": "updateFilter",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "group ID."
          },
          {
            "name": "filter_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "filter ID."
          }
        ]
      },
      "delete": {
        "summary": "deletes a filter/segment.",
        "description": " deletes a filter/segment<br>",
        "operationId": "removeFilter",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "group ID."
          },
          {
            "name": "filter_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "filter ID."
          }
        ]
      }
    },
