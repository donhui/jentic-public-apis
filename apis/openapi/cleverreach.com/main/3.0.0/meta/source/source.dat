{
  "openapi": "3.0.3",
  "info": {
    "title": "CleverReach REST API",
    "version": "3.0.0",
    "description": "CleverReach email marketing REST API v3"
  },
  "x-jentic-source-url": "https://rest.cleverreach.com/v3/resources.json",
  "servers": [
    {
      "url": "https://rest.cleverreach.com"
    }
  ],
  "paths": {
    "/v3/clients": {
      "get": {
        "summary": "get clients.",
        "description": " returns a list of clients managed by this account. In case of a single client it returns a object",
        "operationId": "list",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "pagesize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "max amount of entries per query."
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "int"
            },
            "description": "page."
          }
        ]
      }
    },
    "/v3/clients/{id}": {
      "get": {
        "summary": "get info for one client.",
        "description": " get info for single client",
        "operationId": "retrieve",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "client_id."
          }
        ]
      }
    },
    "/v3/clients/{id}/activereceivercount": {
      "get": {
        "summary": "get active receiver count for client.",
        "description": " get only the amount of active receivers of a certain client",
