    "/v3/blacklist": {
      "get": {
        "summary": "get all blacklisted emails.",
        "description": " returns a list with all blacklisted email addresses",
        "operationId": "list",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      },
      "post": {
        "summary": "add entry.",
        "description": " add a new email address to the blacklist<br> <br> <strong>Example Post Data:</strong><br> <code> {<br> &nbsp;&nbsp;&nbsp;&nbsp;\"email\": \"ras@guhl.org\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"comment\": \"not to talk about\"<br> }<br> </code>",
        "operationId": "create",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      },
      "put": {
        "summary": "update entry.",
        "description": " updates an entry of the blacklist by email<br> <br> <strong>Example Post Data:</strong><br> <code> {<br> &nbsp;&nbsp;&nbsp;&nbsp;\"email\": \"ras@guhl.org\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"comment\": \"really not to talk about\"<br> }<br> </code>",
        "operationId": "update",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "/v3/blacklist/{email}": {
      "get": {
        "summary": "get info for blacklisted email.",
        "description": " get infos of a single blacklisted email address. You can use it to check if a email is on the blacklist.",
        "operationId": "retrieve",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "email."
          }
        ]
      },
      "delete": {
        "summary": "delete blacklist entry.",
        "description": " delete an email address from blacklist",
        "operationId": "remove",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "email to be deleted."
          }
        ]
      }
    },
    "/v3/blacklist/validate": {
      "post": {
        "summary": "filter emails, get valid ones.",
        "description": " Filters provided list of emails and returns the not blacklisted ones<br> <br> <strong>Example Post Data:</strong><br> <code> {<br> &nbsp;&nbsp;&nbsp;&nbsp;\"emails\":&nbsp;[<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"joker@blocklisted.com\",<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"robin@gotham.com\",<br> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\"batman@gotham.com\"<br> &nbsp;&nbsp;&nbsp;&nbsp;],<br> &nbsp;&nbsp;&nbsp;&nbsp;\"group_id\":&nbsp;\"11940\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"invert\":&nbsp;false<br> }<br>",
        "operationId": "filterEmailList",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "/v3/groups": {
      "get": {
        "summary": "get list of groups (receiver lists).",
        "description": " returns array of groups (receiver lists)",
        "operationId": "list",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "parameters": [
          {
            "name": "order",
            "in": "query",
            "required": false,
            "schema": {
              "type": "mixed"
            },
            "description": "order by statement (created ASC or DESC, changed ASC or DESC)."
          }
        ]
      },
      "post": {
        "summary": "create group (receiver list).",
        "description": " create a list of receivers<br> <br> <strong>Example Post Data:</strong><br> <code> {<br> &nbsp;&nbsp;&nbsp;&nbsp;\"name\":&nbsp;\"Justice League\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"receiver_info\":&nbsp;\"Superhero colleagues\",<br> &nbsp;&nbsp;&nbsp;&nbsp;\"locked\":&nbsp;false,<br> &nbsp;&nbsp;&nbsp;&nbsp;\"backup\":&nbsp;true<br> }<br> </code>",
        "operationId": "create",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
