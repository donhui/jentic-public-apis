                "parameters": [
                    {
                        "name": "vault",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "block",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TokenListResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Request is not valid"
                    }
                },
                "security": [
                    {
                        "accessToken": []
                    }
                ]
            }
        },
        "/tokenize/retrieve/{vault}/{queryType}/{block}/{attribute}": {
            "get": {
                "tags": [
                    "Tokenization"
                ],
                "summary": "Retrieve",
                "description": "RESTful API to retrieve one token.",
                "operationId": "retrieve",
                "parameters": [
                    {
                        "name": "vault",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "queryType",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "block",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "attribute",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
