                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Request is not valid"
                    }
                },
                "security": [
                    {
                        "accessToken": []
                    }
                ]
            }
        },
        "/tokenize/store": {
            "post": {
                "tags": [
                    "Tokenization"
                ],
                "summary": "Store",
                "description": "RESTful API to store tokens.",
                "operationId": "store",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/TokenizationRequest"
