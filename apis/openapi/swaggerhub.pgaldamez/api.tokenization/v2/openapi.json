    "servers": [
        {
            "url": "http://apitestenv.vnforapps.com/api.tokenization/v2"
        },
        {
            "url": "https://apitestenv.vnforapps.com/api.tokenization/v2"
        }
    ],
    "components": {
        "securitySchemes": {
            "accessToken": {
                "description": "Access token obtained from api.security",
                "type": "apiKey",
                "name": "Authorization",
                "in": "header"
            }
        },
        "schemas": {
            "Payload": {
                "type": "object",
                "properties": {
                    "key": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                }
            },
            "RetrieveResponse": {
                "type": "object",
                "properties": {
                    "responseCode": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "responseMessage": {
                        "type": "string"
                    },
                    "result": {
                        "type": "string"
                    }
                }
            },
            "TokenListResponse": {
                "type": "object",
                "properties": {
                    "responseCode": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "responseMessage": {
                        "type": "string"
                    },
                    "result": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/TokenizerResponse"
                        }
                    }
                }
            },
            "TokenizationRequest": {
                "type": "object",
                "properties": {
                    "vault": {
                        "type": "string"
                    },
                    "block": {
                        "type": "string"
                    },
                    "payload": {
                        "$ref": "#/components/schemas/Payload"
                    }
                }
            },
            "TokenizerResponse": {
                "type": "object",
                "properties": {
                    "token": {
                        "type": "string"
                    },
                    "hash": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                }
            }
        }
    }
