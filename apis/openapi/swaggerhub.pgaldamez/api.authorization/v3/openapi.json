  "paths": {
    "/authorization/{product}/{merchantId}": {
      "post": {
        "tags": [
          "Authorization Api"
        ],
        "summary": "Authorization",
        "description": "RESTful API to authorizate transactions.",
        "operationId": "authorize",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "product",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "merchantId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Authorization request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/AuthorizationRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/AuthorizationResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Request is not valid"
          }
        },
        "security": [
          {
            "accessToken": []
          }
        ]
      }
    },
    "/void/{product}/{merchantId}": {
      "post": {
