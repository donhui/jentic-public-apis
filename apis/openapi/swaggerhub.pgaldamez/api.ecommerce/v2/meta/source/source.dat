                        "type": "string"
                    },
                    "expirationMonth": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "expirationYear": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "cvv2": {
                        "type": "string"
                    },
                    "cardHolderName": {
                        "type": "string"
                    },
                    "tokenId": {
                        "type": "string"
                    },
                    "cardAliasName": {
                        "type": "string"
                    },
                    "verify": {
                        "type": "boolean"
                    },
                    "track2": {
                        "type": "string"
                    },
                    "emv": {
                        "type": "string"
                    },
                    "cardNumberEnc": {
                        "type": "string"
                    },
                    "track2Enc": {
                        "type": "string"
                    },
                    "emvEnc": {
                        "type": "string"
                    },
                    "pinBlockEnc": {
                        "type": "string"
                    },
                    "ksnDukpt": {
                        "type": "string"
                    },
                    "visaCheckout": {
                        "type": "boolean"
                    },
                    "registerCardFrecuent": {
                        "type": "boolean"
                    },
                    "useCardFrecuent": {
                        "type": "boolean"
                    }
                }
            },
            "CardHolder": {
                "type": "object",
                "properties": {
                    "firstName": {
                        "type": "string"
                    },
                    "lastName": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    },
                    "phoneNumber": {
                        "type": "string"
                    },
                    "documentType": {
                        "type": "string"
                    },
                    "documentNumber": {
                        "type": "string"
                    }
                }
            },
            "CardToken": {
                "type": "object",
                "properties": {
                    "tokenId": {
                        "type": "string"
                    },
                    "cardNumber": {
                        "type": "string"
                    },
                    "alias": {
                        "type": "string"
                    },
                    "bin": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "lastFourDigits": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "expirationMonth": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "expirationYear": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "hasInstallments": {
                        "type": "boolean"
                    },
                    "requestCVV2": {
                        "type": "boolean"
                    },
                    "creationDate": {
                        "type": "integer",
                        "format": "int64"
                    }
                }
            },
            "ClientIpResponse": {
                "type": "object",
                "properties": {
                    "clientIp": {
                        "type": "string"
                    }
                }
            },
            "Commerce": {
                "type": "object",
                "properties": {
                    "ruc": {
                        "type": "string"
                    },
                    "merchantGroupId": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "active": {
                        "type": "boolean"
                    },
                    "email": {
                        "type": "string"
                    },
                    "phone": {
                        "type": "string"
                    },
                    "tokenizationEnabled": {
                        "type": "boolean"
                    },
                    "recurrencyEnabled": {
                        "type": "boolean"
                    },
                    "showFirstNameLastNameEnabled": {
                        "type": "boolean"
                    },
                    "installments": {
                        "type": "boolean"
                    },
                    "currency": {
                        "type": "string"
                    },
                    "payButtonEs": {
                        "type": "string"
                    },
                    "payButtonEn": {
                        "type": "string"
                    },
                    "subscribeButtonEs": {
                        "type": "string"
                    },
                    "subscribeButtonEn": {
                        "type": "string"
                    },
                    "verifiedByVisaEnabled": {
                        "type": "boolean"
                    },
                    "commerceLogo": {
                        "type": "string"
                    },
                    "commerceCode": {
                        "type": "string"
                    },
                    "mcc": {
                        "type": "string"
                    }
                }
            },
            "Dictionary": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    }
                }
            },
            "Order": {
                "type": "object",
                "properties": {
                    "tokenId": {
                        "type": "string"
                    },
                    "purchaseNumber": {
                        "type": "string"
                    },
                    "productId": {
                        "type": "string"
                    },
                    "amount": {
                        "type": "number",
                        "format": "double"
                    },
                    "installment": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "currency": {
                        "type": "string"
                    },
                    "externalTransactionId": {
                        "type": "string"
                    },
                    "authorizedAmount": {
                        "type": "number",
                        "format": "double"
                    },
                    "authorizationCode": {
                        "type": "string"
                    },
                    "traceNumber": {
                        "type": "string"
                    },
                    "transactionDate": {
                        "type": "string"
                    },
                    "transactionId": {
                        "type": "string"
                    },
                    "originalTraceNumber": {
                        "type": "string"
                    },
                    "originalDateTime": {
                        "type": "string"
                    },
                    "billingAddress": {
                        "$ref": "#/components/schemas/Address"
                    },
                    "shippingAddress": {
                        "$ref": "#/components/schemas/Address"
                    }
                }
            },
            "Recurrence": {
                "type": "object",
