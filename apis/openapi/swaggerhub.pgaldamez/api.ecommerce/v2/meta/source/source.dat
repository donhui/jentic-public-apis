            },
            "TokenRequest": {
                "type": "object",
                "properties": {
                    "channel": {
                        "type": "string"
                    },
                    "merchantId": {
                        "type": "string"
                    },
                    "clientIp": {
                        "type": "string"
                    },
                    "callbackUrl": {
                        "type": "string"
                    },
                    "antifraud": {
                        "type": "string"
                    },
                    "card": {
                        "$ref": "#/components/schemas/Card"
                    },
                    "customer": {
                        "$ref": "#/components/schemas/CardHolder"
                    },
                    "order": {
                        "$ref": "#/components/schemas/Order"
                    },
                    "alias": {
                        "$ref": "#/components/schemas/Alias"
                    },
                    "recurrence": {
                        "$ref": "#/components/schemas/Recurrence"
                    }
                }
            },
            "TokenResponse": {
                "type": "object",
                "properties": {
                    "responseCode": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "responseMessage": {
                        "type": "string"
                    }
                }
            },
            "TransactionToken": {
                "type": "object",
                "properties": {
                    "tokenId": {
                        "type": "string"
                    },
                    "expiration": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "redirectToVbV": {
                        "type": "boolean"
                    }
                }
            },
            "VaultRequest": {
                "type": "object",
                "properties": {
                    "vault": {
                        "type": "string"
                    },
                    "block": {
                        "type": "string"
                    },
                    "attribute": {
                        "type": "string"
                    }
                }
            }
        }
    }
}