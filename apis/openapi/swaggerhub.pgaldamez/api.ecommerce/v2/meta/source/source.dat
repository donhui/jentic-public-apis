    "components": {
        "securitySchemes": {
            "accessToken": {
                "description": "Access token obtained from api.security",
                "type": "apiKey",
                "name": "Authorization",
                "in": "header"
            }
        },
        "schemas": {
            "Address": {
                "type": "object",
                "properties": {
                    "street1": {
                        "type": "string"
                    },
                    "street2": {
                        "type": "string"
                    },
                    "postalCode": {
                        "type": "string"
                    },
                    "city": {
                        "type": "string"
                    },
                    "state": {
                        "type": "string"
                    },
                    "country": {
                        "type": "string"
                    }
                }
            },
            "Alias": {
                "type": "object",
                "properties": {
                    "aliasId": {
                        "type": "string"
                    },
                    "aliasName": {
                        "type": "string"
                    },
                    "cvv2": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "requestCVV2": {
                        "type": "boolean"
                    },
                    "userToken": {
                        "type": "string"
                    }
                }
            },
            "Antifraud": {
                "type": "object",
                "properties": {
                    "billingAddress": {
                        "$ref": "#/components/schemas/Address"
                    },
                    "shippingAddress": {
                        "$ref": "#/components/schemas/Address"
                    },
                    "clientIp": {
                        "type": "string"
                    },
                    "deviceFingerprintId": {
                        "type": "string"
                    },
                    "merchantDefineData": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    }
                }
            },
            "Ardef": {
                "type": "object",
                "properties": {
                    "bin": {
                        "type": "string"
                    },
                    "region": {
                        "type": "string"
                    },
                    "country": {
                        "type": "string"
                    },
                    "product": {
                        "$ref": "#/components/schemas/Dictionary"
                    },
                    "source": {
                        "$ref": "#/components/schemas/Dictionary"
                    }
                }
            },
            "Bin": {
                "type": "object",
                "properties": {
                    "binNumber": {
                        "type": "string"
                    },
                    "hasInstallments": {
                        "type": "boolean"
                    }
                }
            },
            "Card": {
                "type": "object",
                "properties": {
