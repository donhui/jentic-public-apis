    "paths": {
        "/card/management/remove/{vault}": {
            "post": {
                "tags": [
                    "Api to manage tokenized cards"
                ],
                "summary": "Remove Card Token",
                "description": "RESTful API to remove a token",
                "operationId": "removeWithBody",
                "parameters": [
                    {
                        "name": "vault",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/VaultRequest"
                            }
                        }
                    },
                    "description": "Vault remove token request",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TokenResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Request is not valid"
                    }
                },
                "security": [
                    {
                        "accessToken": []
                    }
                ]
            }
        },
