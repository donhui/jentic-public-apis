{
    "openapi": "3.0.0",
    "info": {
        "description": "Api encargada de la validacion de tarjetas",
        "version": "v1",
        "title": "API Visanet Validation",
        "termsOfService": "http://www.visanet.com.pe",
        "contact": {
            "name": "VisaNet",
            "url": "http://www.visanet.com.pe",
            "email": "visanet@gmail.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/pgaldamez/api.validate/v1/swagger.json"
    },
    "tags": [
        {
            "name": "Validation Api",
            "description": "RESTful API to validate transactions."
        }
    ],
    "paths": {
        "/confirm/{product}/{merchantId}": {
            "post": {
                "tags": [
                    "Validation Api"
                ],
                "summary": "Confirmation",
                "description": "RESTful API to confirm transactions.",
                "operationId": "confirm",
                "parameters": [
                    {
                        "name": "product",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "merchantId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ConfirmationRequest"
                            }
                        }
                    },
                    "description": "Confirm card request",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Request is not valid"
                    }
                },
                "security": [
                    {
                        "accessToken": []
                    }
                ]
            }
        },
        "/validate/{product}/{merchantId}": {
            "post": {
                "tags": [
                    "Validation Api"
                ],
                "summary": "Validation",
                "description": "RESTful API to validate transactions.",
                "operationId": "validate",
                "parameters": [
                    {
                        "name": "product",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "merchantId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ValidationRequest"
                            }
                        }
                    },
                    "description": "Validate card request",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "500": {
                        "description": "Request is not valid"
                    }
                },
                "security": [
                    {
                        "accessToken": []
                    }
                ]
            }
        }
    },
    "servers": [
        {
            "url": "https://testapienv.vnforapps.com/api.validate/v1"
        }
    ],
    "components": {
        "securitySchemes": {
            "accessToken": {
                "description": "Access token obtained from api.security",
                "type": "apiKey",
                "name": "Authorization",
                "in": "header"
            }
        },
