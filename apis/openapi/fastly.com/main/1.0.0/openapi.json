            }
          }
        }
      }
    },
    "/v1/channel/{service_id}/ts/{timestamp_in_seconds}": {
      "get": {
        "operationId": "getRealtimeStats",
        "summary": "Get real-time data from specified time",
        "description": "Retrieves real-time analytics for a specific reporting period. Using 0 as the timestamp returns data for the most recent complete second.",
        "tags": [
          "Real-time Stats"
        ],
        "servers": [
          {
            "url": "https://rt.fastly.com"
          }
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
