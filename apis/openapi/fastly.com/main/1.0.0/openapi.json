    "/stats/usage_by_service": {
      "get": {
        "operationId": "getUsageStatsByService",
        "summary": "Get usage statistics per service",
        "description": "Provides usage metrics aggregated by individual service and region.",
        "tags": [
          "Historical Stats"
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string"
            }
