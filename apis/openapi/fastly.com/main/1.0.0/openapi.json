        "tags": [
          "Historical Stats"
        ],
        "responses": {
          "200": {
            "description": "Region codes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
