          },
          {
            "name": "year",
            "in": "query",
            "description": "Four-digit year value.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "billable_units",
            "in": "query",
            "description": "If true, converts bandwidth to GB and normalizes requests.",
