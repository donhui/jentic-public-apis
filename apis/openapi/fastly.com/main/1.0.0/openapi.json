{
  "openapi": "3.0.3",
  "info": {
    "title": "Fastly API",
    "description": "The Fastly API provides programmatic access to Fastly CDN services including service management, purging, and real-time analytics.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.fastly.com/documentation/reference/api/"
  },
  "servers": [
    {
      "url": "https://api.fastly.com",
      "description": "Fastly API server"
    },
    {
      "url": "https://rt.fastly.com",
      "description": "Fastly Real-time stats server"
    }
  ],
  "paths": {
    "/service": {
      "get": {
        "operationId": "listServices",
        "summary": "List services",
        "description": "Retrieve all services associated with the authenticated account.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "direction",
            "in": "query",
            "description": "Sort direction (ascend or descend).",
            "schema": {
              "type": "string",
              "enum": [
                "ascend",
                "descend"
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Field to sort by.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of services",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Service"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createService",
        "summary": "Create a service",
        "description": "Create a new Fastly service.",
        "tags": [
          "Services"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the service."
                  },
                  "type": {
                    "type": "string",
                    "description": "Type of service (vcl or wasm).",
                    "enum": [
                      "vcl",
                      "wasm"
                    ]
                  },
                  "comment": {
                    "type": "string",
                    "description": "A comment about the service."
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created service",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Service"
                }
              }
            }
          }
        }
      }
    },
    "/service/{service_id}": {
      "get": {
        "operationId": "getService",
        "summary": "Get a service",
        "description": "Retrieve a specific service by its ID.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Service details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Service"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateService",
        "summary": "Update a service",
        "description": "Modify the configuration of a service.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated service",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Service"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteService",
        "summary": "Delete a service",
        "description": "Remove a service.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deletion confirmation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/service/{service_id}/details": {
      "get": {
        "operationId": "getServiceDetails",
        "summary": "Get service details",
        "description": "List detailed information on a specified service.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "description": "Specific version number to retrieve.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Service details with nested configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceDetail"
                }
              }
            }
          }
        }
      }
    },
    "/service/search": {
      "get": {
        "operationId": "searchService",
        "summary": "Search for a service by name",
        "description": "Locate a service using its name.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "description": "The name of the service to search for.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Matching service",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Service"
                }
              }
            }
          }
        }
      }
    },
    "/service/{service_id}/domain": {
      "get": {
        "operationId": "listServiceDomains",
        "summary": "List service domains",
        "description": "List the domains within a service.",
        "tags": [
          "Services"
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of domains",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Domain"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/purge/{cached_url}": {
      "post": {
        "operationId": "purgeUrl",
        "summary": "Purge a URL",
        "description": "Instant Purge an individual URL.",
        "tags": [
          "Purging"
        ],
        "parameters": [
          {
            "name": "cached_url",
            "in": "path",
            "required": true,
            "description": "The URL of the cached object to purge.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fastly-soft-purge",
            "in": "header",
            "description": "Set to 1 to trigger a soft purge.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Purge result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PurgeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/service/{service_id}/purge_all": {
      "post": {
        "operationId": "purgeAll",
        "summary": "Purge everything from a service",
        "description": "Instantly removes all cached content from a service.",
        "tags": [
          "Purging"
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Purge result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PurgeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/service/{service_id}/purge/{surrogate_key}": {
      "post": {
        "operationId": "purgeBySurrogateKey",
        "summary": "Purge by surrogate key tag",
        "description": "Removes cached items tagged with a single surrogate key from a service.",
        "tags": [
          "Purging"
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "surrogate_key",
            "in": "path",
            "required": true,
            "description": "Surrogate key tag for grouped related assets.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fastly-soft-purge",
            "in": "header",
            "description": "Set to 1 to trigger a soft purge.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Purge result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PurgeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/service/{service_id}/purge": {
      "post": {
        "operationId": "purgeMultipleSurrogateKeys",
        "summary": "Purge multiple surrogate key tags",
        "description": "Removes cached items tagged with up to 256 surrogate keys in one batch.",
        "tags": [
          "Purging"
        ],
        "parameters": [
          {
            "name": "service_id",
            "in": "path",
            "required": true,
            "description": "Alphanumeric string identifying the service.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fastly-soft-purge",
            "in": "header",
            "description": "Set to 1 to trigger a soft purge.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "surrogate_keys": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of surrogate keys to purge."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Purge result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stats": {
      "get": {
        "operationId": "getHistoricalStats",
        "summary": "Get historical stats",
        "description": "Fetches historical stats for each of your Fastly services and groups the results by service ID.",
        "tags": [
          "Historical Stats"
        ],
        "parameters": [
          {
            "name": "by",
            "in": "query",
            "description": "Sample window duration (hour, minute, or day).",
            "schema": {
              "type": "string",
              "enum": [
                "hour",
                "minute",
                "day"
              ]
            }
          },
          {
            "name": "datacenter",
            "in": "query",
            "description": "Comma-separated list of POP codes to filter by.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Start timestamp (Unix or natural language).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End timestamp.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "region",
            "in": "query",
            "description": "Geographic region filter.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "services",
            "in": "query",
            "description": "Comma-separated list of service IDs.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Historical stats grouped by service",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoricalStatsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stats/field/{field}": {
      "get": {
        "operationId": "getHistoricalStatsField",
        "summary": "Get historical stats for a single field",
        "description": "Retrieves a specific metric field across all services, grouped by service ID.",
        "tags": [
          "Historical Stats"
        ],
        "parameters": [
          {
            "name": "field",
            "in": "path",
            "required": true,
            "description": "The metric field name to retrieve.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "by",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "hour",
                "minute",
                "day"
              ]
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "region",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "datacenter",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stats for the specified field",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoricalStatsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stats/aggregate": {
      "get": {
        "operationId": "getHistoricalStatsAggregate",
