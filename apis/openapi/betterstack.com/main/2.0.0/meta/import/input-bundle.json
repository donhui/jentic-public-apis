  "components": {
    "schemas": {
      "MonitorResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/MonitorData"
          }
        }
      },
      "MonitorListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MonitorData"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "MonitorData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "example": "monitor"
          },
          "attributes": {
            "$ref": "#/components/schemas/MonitorAttributes"
          }
        }
      },
      "MonitorAttributes": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "pronounceable_name": {
            "type": "string"
          },
          "monitor_type": {
            "type": "string",
            "enum": [
              "status",
              "expected_status_code",
              "keyword",
              "keyword_absence",
              "ping",
              "tcp",
              "udp",
              "smtp",
              "pop",
              "imap",
              "dns",
              "playwright"
            ]
          },
          "monitor_group_id": {
            "type": "integer",
            "nullable": true
          },
          "last_checked_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "up",
              "down",
              "validating",
              "paused",
              "pending"
            ]
          },
          "check_frequency": {
            "type": "integer"
          },
          "required_keyword": {
            "type": "string",
            "nullable": true
          },
          "port": {
            "type": "integer",
            "nullable": true
          },
          "paused": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateMonitorRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          },
          "pronounceable_name": {
            "type": "string"
          },
          "monitor_type": {
            "type": "string",
            "enum": [
              "status",
              "expected_status_code",
              "keyword",
              "keyword_absence",
              "ping",
              "tcp",
              "udp",
              "smtp",
              "pop",
              "imap",
              "dns",
              "playwright"
            ]
          },
          "required_keyword": {
            "type": "string"
          },
          "check_frequency": {
            "type": "integer"
          },
          "port": {
            "type": "integer"
          },
          "monitor_group_id": {
            "type": "integer"
          }
        }
      },
      "CreateHeartbeatRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "period": {
            "type": "integer"
          },
          "grace": {
            "type": "integer"
          }
        }
      },
      "CreateStatusPageRequest": {
        "type": "object",
        "properties": {
          "company_name": {
            "type": "string"
          },
          "company_url": {
            "type": "string"
          },
          "subdomain": {
            "type": "string"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "first": {
            "type": "string"
          },
          "last": {
            "type": "string"
          },
          "prev": {
            "type": "string",
            "nullable": true
          },
          "next": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "message": {
            "type": "string",
            "description": "Detailed error message"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
