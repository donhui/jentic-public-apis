            "description": "Medical dictionary entry or list of suggestions.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
                      }
                    },
                    {
                      "type": "array",
