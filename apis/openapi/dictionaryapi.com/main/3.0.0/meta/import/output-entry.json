      "name": "Thesaurus",
      "description": "Collegiate Thesaurus lookups"
    },
    {
      "name": "Medical",
      "description": "Medical Dictionary lookups"
    },
    {
      "name": "Learners",
      "description": "Learner's Dictionary lookups"
    },
    {
      "name": "Spanish",
      "description": "Spanish-English Dictionary lookups"
    }
  ]
}