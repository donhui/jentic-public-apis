              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DictionaryEntry": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "description": "Entry metadata.",
            "properties": {
              "id": {
                "type": "string",
                "description": "Entry identifier."
              },
              "uuid": {
                "type": "string",
                "description": "Universally unique identifier."
              },
              "src": {
                "type": "string",
                "description": "Source dictionary."
              },
              "stems": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of headwords, variants, inflections, and related words that can be used to search for this entry."
              },
              "offensive": {
                "type": "boolean",
                "description": "Whether the entry is considered offensive."
              }
            }
          },
          "hwi": {
            "type": "object",
            "description": "Headword information.",
            "properties": {
              "hw": {
                "type": "string",
                "description": "Headword with asterisks marking hyphenation points."
              },
              "prs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "mw": {
                      "type": "string",
                      "description": "Written pronunciation."
                    },
                    "sound": {
                      "type": "object",
                      "properties": {
                        "audio": {
                          "type": "string",
                          "description": "Audio file base name."
                        }
                      }
                    }
                  }
                },
                "description": "Pronunciations."
              }
            }
          },
          "fl": {
            "type": "string",
            "description": "Functional label (part of speech)."
          },
          "def": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sseq": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {}
                  },
                  "description": "Sense sequence containing definitions."
                }
              }
            },
            "description": "Definition section."
          },
          "shortdef": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Short definitions (up to 3)."
          },
          "et": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Etymology."
          },
          "date": {
            "type": "string",
            "description": "Date of first known use."
          },
          "uros": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ure": {
                  "type": "string",
                  "description": "Undefined run-on entry word."
                },
                "fl": {
                  "type": "string",
                  "description": "Functional label."
                }
              }
            },
            "description": "Undefined run-on entries (related forms)."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message."
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "Merriam-Webster API key. Each dictionary product requires its own key."
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Collegiate",
      "description": "Collegiate Dictionary lookups"
    },
