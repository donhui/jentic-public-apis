{
  "openapi": "3.0.3",
  "info": {
    "title": "Merriam-Webster Dictionary API",
    "version": "3.0.0",
    "description": "The Merriam-Webster Dictionary API provides access to Merriam-Webster's Collegiate Dictionary and other reference works. Returns word definitions, pronunciations, etymologies, and more in JSON format.",
    "x-jentic-source-url": "https://dictionaryapi.com/"
  },
  "servers": [
    {
      "url": "https://www.dictionaryapi.com/api/v3",
      "description": "Merriam-Webster API v3 server"
    }
  ],
  "paths": {
    "/references/collegiate/json/{word}": {
      "get": {
        "operationId": "lookupCollegiateDictionary",
        "summary": "Look up a word in the Collegiate Dictionary",
        "description": "Returns definitions, pronunciations, etymologies, and more for the specified word from the Merriam-Webster Collegiate Dictionary.",
        "tags": [
          "Collegiate"
        ],
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "required": true,
            "description": "The word to look up.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dictionary entry or list of suggestions if word not found.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of suggested words when the searched word is not found."
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/references/thesaurus/json/{word}": {
      "get": {
        "operationId": "lookupThesaurus",
        "summary": "Look up a word in the Collegiate Thesaurus",
        "description": "Returns synonyms, antonyms, and related words for the specified word from the Merriam-Webster Collegiate Thesaurus.",
        "tags": [
          "Thesaurus"
        ],
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "required": true,
            "description": "The word to look up.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication (thesaurus-specific key).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Thesaurus entry or list of suggestions.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
