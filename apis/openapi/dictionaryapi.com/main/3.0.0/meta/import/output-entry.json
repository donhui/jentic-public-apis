    "/references/spanish/json/{word}": {
      "get": {
        "operationId": "lookupSpanishEnglishDictionary",
        "summary": "Look up a word in the Spanish-English Dictionary",
        "description": "Returns Spanish-English translations for the specified word.",
        "tags": [
          "Spanish"
        ],
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "required": true,
            "description": "The word to look up (Spanish or English).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication (Spanish-English dictionary key).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Spanish-English dictionary entry or list of suggestions.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DictionaryEntry"
