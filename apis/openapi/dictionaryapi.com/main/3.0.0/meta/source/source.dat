{
  "openapi": "3.0.3",
  "info": {
    "title": "Merriam-Webster Collegiate Dictionary API",
    "version": "3.0.0",
    "description": "Access Merriam-Webster's Collegiate Dictionary data including definitions, pronunciations, etymologies, usage examples, and related words.",
    "x-jentic-source-url": "https://dictionaryapi.com/products/api-collegiate-dictionary"
  },
  "servers": [
    {
      "url": "https://www.dictionaryapi.com/api/v3"
    }
  ],
  "paths": {
    "/references/collegiate/json/{word}": {
      "get": {
        "operationId": "lookupWord",
        "summary": "Look up a word",
        "description": "Retrieves dictionary entries for the specified word, including definitions, pronunciations, etymologies, and usage examples.",
        "tags": ["Dictionary"],
        "parameters": [
          {
            "name": "word",
            "in": "path",
            "required": true,
            "description": "The word or stem to look up.",
            "schema": { "type": "string" }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "API key for authentication.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Dictionary entries for the word",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DictionaryEntry"
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid request" },
          "401": { "description": "Invalid API key" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DictionaryEntry": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "hwi": {
            "$ref": "#/components/schemas/HeadwordInfo"
          },
          "fl": {
            "type": "string",
            "description": "Functional label (part of speech)."
          },
          "def": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Definition"
            }
          },
          "et": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "string" }
            },
            "description": "Etymology."
          },
          "date": {
            "type": "string",
            "description": "Date of first known use."
          },
          "shortdef": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Short definitions."
          }
        }
      },
      "Meta": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "uuid": { "type": "string" },
          "src": { "type": "string" },
          "section": { "type": "string" },
          "stems": {
            "type": "array",
            "items": { "type": "string" }
          },
          "offensive": { "type": "boolean" }
        }
      },
      "HeadwordInfo": {
        "type": "object",
        "properties": {
          "hw": {
            "type": "string",
            "description": "Headword with syllable separators."
          },
          "prs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Pronunciation"
            }
          }
        }
      },
      "Pronunciation": {
        "type": "object",
        "properties": {
          "mw": {
            "type": "string",
            "description": "Written pronunciation in Merriam-Webster format."
          },
          "sound": {
            "type": "object",
            "properties": {
              "audio": { "type": "string" },
              "ref": { "type": "string" },
              "stat": { "type": "string" }
            }
          },
          "ipa": { "type": "string" }
        }
      },
      "Definition": {
        "type": "object",
        "properties": {
          "sseq": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {}
              }
            },
            "description": "Sense sequence containing definition text and usage."
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}