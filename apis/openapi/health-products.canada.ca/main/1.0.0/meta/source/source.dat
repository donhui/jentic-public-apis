              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Id": {
        "name": "id",
        "in": "query",
        "description": "Drug product code.",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "Lang": {
        "name": "lang",
        "in": "query",
        "description": "Response language.",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "en",
            "fr"
          ],
          "default": "en"
        }
      },
      "Type": {
        "name": "type",
        "in": "query",
        "description": "Response format.",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "json",
            "xml"
          ],
          "default": "json"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid or missing parameters."
      },
      "NotFound": {
        "description": "No records found for the given drug product code."
      }
    },
    "schemas": {
      "ActiveIngredient": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "active_ingredient_code": {
            "type": "integer",
            "description": "Unique identifier for the active ingredient record."
          },
          "ingredient": {
            "type": "string",
            "description": "Name of the active ingredient."
          },
          "ingredient_supplied_ind": {
            "type": "string",
            "description": "Indicator for ingredient as supplied."
          },
          "strength": {
            "type": "string",
            "description": "Strength of the active ingredient."
          },
          "strength_unit": {
            "type": "string",
            "description": "Unit of measurement for the strength."
          },
          "strength_type": {
            "type": "string",
            "description": "Type of strength measurement."
          },
          "dosage_value": {
            "type": "string",
            "description": "Dosage value."
          },
          "base": {
            "type": "string",
            "description": "Whether the strength is expressed as the base."
          },
          "dosage_unit": {
            "type": "string",
            "description": "Unit of measurement for the dosage."
          },
          "notes": {
            "type": "string",
            "description": "Additional notes."
          }
        }
      },
      "Company": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "mfr_code": {
            "type": "string",
            "description": "Manufacturer code."
          },
          "company_code": {
            "type": "integer",
            "description": "Unique company identifier."
          },
          "company_name": {
            "type": "string",
            "description": "Name of the company."
          },
          "company_type": {
            "type": "string",
            "description": "Type of company (e.g., manufacturer, distributor)."
          },
          "address_mailing_flag": {
            "type": "string",
            "description": "Mailing address flag."
          },
          "address_billing_flag": {
            "type": "string",
            "description": "Billing address flag."
          },
          "address_notification_flag": {
            "type": "string",
            "description": "Notification address flag."
          },
          "address_other": {
            "type": "string",
            "description": "Other address information."
          },
          "suite_number": {
            "type": "string",
            "description": "Suite number."
          },
          "street_name": {
            "type": "string",
            "description": "Street name."
          },
          "city_name": {
            "type": "string",
            "description": "City name."
          },
          "province": {
            "type": "string",
            "description": "Province or state."
          },
          "country": {
            "type": "string",
            "description": "Country."
          },
          "postal_code": {
            "type": "string",
            "description": "Postal or ZIP code."
          },
          "post_office_box": {
            "type": "string",
            "description": "Post office box number."
          }
        }
      },
      "DrugProduct": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "class_name": {
            "type": "string",
            "description": "Product class (e.g., Human, Veterinary)."
          },
          "drug_identification_number": {
            "type": "string",
            "description": "Drug Identification Number (DIN)."
          },
          "brand_name": {
            "type": "string",
            "description": "Brand name of the drug product."
          },
          "descriptor": {
            "type": "string",
            "description": "Product descriptor."
          },
          "pediatric_flag": {
            "type": "string",
            "description": "Pediatric use flag."
          },
          "accession_number": {
            "type": "string",
            "description": "Accession number."
          },
          "number_of_ais": {
            "type": "string",
            "description": "Number of active ingredients."
          },
          "last_update_date": {
            "type": "string",
            "description": "Date of last update."
          },
          "ai_group_no": {
            "type": "string",
            "description": "Active ingredient group number."
          }
        }
      },
      "DosageForm": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "pharmaceutical_form_code": {
            "type": "integer",
            "description": "Pharmaceutical form code."
          },
          "pharmaceutical_form": {
            "type": "string",
            "description": "Dosage form description (e.g., tablet, capsule)."
          },
          "pharmaceutical_form_group": {
            "type": "string",
            "description": "Dosage form group."
          }
        }
      },
      "Packaging": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "upc": {
            "type": "string",
            "description": "Universal Product Code."
          },
          "package_size_unit": {
            "type": "string",
            "description": "Unit of measure for package size."
          },
          "package_type": {
            "type": "string",
            "description": "Type of packaging container."
          },
          "package_size": {
            "type": "string",
            "description": "Size of the package."
          },
          "product_information": {
            "type": "string",
            "description": "Additional product information."
          }
        }
      },
      "PharmaceuticalStandard": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "pharmaceutical_std": {
            "type": "string",
            "description": "Pharmaceutical standard description."
          }
        }
      },
      "Route": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "route_of_administration_code": {
            "type": "integer",
            "description": "Route of administration code."
          },
          "route_of_administration": {
            "type": "string",
            "description": "Route of administration description (e.g., oral, topical)."
          }
        }
      },
      "Schedule": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "schedule": {
            "type": "string",
            "description": "Regulatory schedule classification."
          }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "drug_code": {
            "type": "integer",
            "description": "Drug product code."
          },
          "status_code": {
            "type": "integer",
