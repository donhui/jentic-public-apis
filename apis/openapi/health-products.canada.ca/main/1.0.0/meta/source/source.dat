{
  "openapi": "3.0.3",
  "info": {
    "title": "Health Canada Drug Product Database (DPD) API",
    "description": "Public API for the Health Canada Drug Product Database. Provides access to drug product information including active ingredients, companies, dosage forms, packaging, routes of administration, schedules, statuses, therapeutic classes, and veterinary species.",
    "version": "1.0.0",
    "contact": {
      "name": "Health Canada",
      "url": "https://health-products.canada.ca/api/documentation/dpd-documentation-en.html"
    },
    "x-jentic-source-url": "https://health-products.canada.ca/api/documentation/dpd-documentation-en.html"
  },
  "servers": [
    {
      "url": "https://health-products.canada.ca/api/drug",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "ActiveIngredient",
      "description": "Medicinal components with pharmacological activity"
    },
    {
      "name": "Company",
      "description": "Pharmaceutical manufacturer/distributor information"
    },
    {
      "name": "DrugProduct",
      "description": "Fundamental product data (brand names, DIN, classifications)"
    },
    {
      "name": "DosageForm",
      "description": "Product dosage forms (tablets, capsules, etc.)"
    },
    {
      "name": "Packaging",
      "description": "Package sizes and container specifications"
    },
    {
      "name": "PharmaceuticalStandard",
      "description": "Manufacturing standards"
    },
    {
      "name": "Route",
      "description": "Routes of administration (oral, topical, etc.)"
    },
    {
      "name": "Schedule",
      "description": "Regulatory classifications"
    },
    {
      "name": "Status",
      "description": "Current authorization state"
    },
    {
      "name": "TherapeuticClass",
      "description": "Drug classifications by therapeutic use (ATC codes)"
    },
    {
      "name": "VeterinarySpecies",
      "description": "Target animal species for veterinary products"
    }
  ],
  "paths": {
    "/activeingredient/": {
      "get": {
        "summary": "Get active ingredients",
        "description": "Retrieve medicinal components with pharmacological activity for a given drug product.",
        "operationId": "getactiveingredient",
        "tags": [
          "ActiveIngredient"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          },
          {
            "name": "ingredientname",
            "in": "query",
            "description": "Text search filter for ingredient name.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ActiveIngredient"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/company/": {
      "get": {
        "summary": "Get company information",
        "description": "Retrieve pharmaceutical manufacturer or distributor information for a given drug product.",
        "operationId": "getcompany",
        "tags": [
          "Company"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Company"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drugproduct/": {
      "get": {
        "summary": "Get drug product information",
        "description": "Retrieve fundamental product data including brand names, DIN, and classifications.",
        "operationId": "getdrugproduct",
        "tags": [
          "DrugProduct"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          },
          {
            "name": "din",
            "in": "query",
            "description": "Drug Identification Number.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "brandname",
            "in": "query",
            "description": "Text search filter for brand name.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Product status filter (1-15).",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 15
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DrugProduct"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/form/": {
      "get": {
        "summary": "Get dosage forms",
        "description": "Retrieve product dosage forms (tablets, capsules, etc.) for a given drug product.",
        "operationId": "getdosageform",
        "tags": [
          "DosageForm"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          },
          {
            "name": "active",
            "in": "query",
            "description": "Set to \"yes\" to filter by current date.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "yes"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DosageForm"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/packaging/": {
      "get": {
        "summary": "Get packaging information",
        "description": "Retrieve package sizes and container specifications for a given drug product.",
        "operationId": "getpackaging",
        "tags": [
          "Packaging"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Packaging"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pharmaceuticalstd/": {
      "get": {
        "summary": "Get pharmaceutical standards",
        "description": "Retrieve manufacturing standards for a given drug product.",
        "operationId": "getpharmaceuticalstandard",
        "tags": [
          "PharmaceuticalStandard"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PharmaceuticalStandard"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/route/": {
      "get": {
        "summary": "Get routes of administration",
        "description": "Retrieve routes of administration (oral, topical, etc.) for a given drug product.",
        "operationId": "getroute",
        "tags": [
          "Route"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          },
          {
            "name": "active",
            "in": "query",
            "description": "Set to \"yes\" to filter by current date.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "yes"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Route"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/schedule/": {
      "get": {
        "summary": "Get schedule information",
        "description": "Retrieve regulatory classifications for a given drug product.",
        "operationId": "getschedule",
        "tags": [
          "Schedule"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          },
          {
            "name": "active",
            "in": "query",
            "description": "Filter for active schedules.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Schedule"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/status/": {
      "get": {
        "summary": "Get product status",
        "description": "Retrieve the current authorization state for a given drug product.",
        "operationId": "getstatus",
        "tags": [
          "Status"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Status"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/therapeuticclass/": {
      "get": {
        "summary": "Get therapeutic class",
        "description": "Retrieve drug classifications by therapeutic use (ATC codes) for a given drug product.",
        "operationId": "gettherapeuticclass",
        "tags": [
          "TherapeuticClass"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TherapeuticClass"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/veterinaryspecies/": {
      "get": {
        "summary": "Get veterinary species",
        "description": "Retrieve target animal species for veterinary drug products.",
        "operationId": "getveterinaryspecies",
        "tags": [
          "VeterinarySpecies"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Id"
          },
          {
            "$ref": "#/components/parameters/Lang"
          },
          {
            "$ref": "#/components/parameters/Type"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/VeterinarySpecies"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
