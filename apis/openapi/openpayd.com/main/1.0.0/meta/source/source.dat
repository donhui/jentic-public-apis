  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT access token obtained from the /get-access-token endpoint"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" },
          "status": { "type": "integer" }
        }
      },
      "AccessTokenRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "AccessTokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "tokenType": { "type": "string" },
          "expiresIn": { "type": "integer" }
        }
      },
      "IndividualLinkedClientCreate": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "dateOfBirth": { "type": "string", "format": "date" },
          "nationality": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "BusinessLinkedClientCreate": {
        "type": "object",
        "properties": {
          "companyName": { "type": "string" },
          "registrationNumber": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "country": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "LinkedClient": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "companyName": { "type": "string" },
          "email": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "LinkedClientResponse": {
        "type": "object",
        "properties": {
          "linkedClient": { "$ref": "#/components/schemas/LinkedClient" }
        }
      },
      "LinkedClientListResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LinkedClient" }
          },
          "totalElements": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "addressLine1": { "type": "string" },
          "addressLine2": { "type": "string" },
          "city": { "type": "string" },
          "postCode": { "type": "string" },
          "country": { "type": "string" }
        }
      },
      "AccountCreate": {
        "type": "object",
        "properties": {
          "currency": { "type": "string" },
          "linkedClientId": { "type": "string" },
          "friendlyName": { "type": "string" }
        }
      },
      "AccountUpdate": {
        "type": "object",
        "properties": {
          "friendlyName": { "type": "string" }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "currency": { "type": "string" },
          "balance": { "type": "number" },
          "availableBalance": { "type": "number" },
          "status": { "type": "string" },
          "friendlyName": { "type": "string" },
          "linkedClientId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "account": { "$ref": "#/components/schemas/Account" }
        }
      },
      "AccountListResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Account" }
          },
          "totalElements": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "BeneficiaryCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "accountNumber": { "type": "string" },
          "sortCode": { "type": "string" },
          "iban": { "type": "string" },
          "bic": { "type": "string" },
          "currency": { "type": "string" },
          "country": { "type": "string" }
        }
      },
      "Beneficiary": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "accountNumber": { "type": "string" },
          "iban": { "type": "string" },
          "bic": { "type": "string" },
          "currency": { "type": "string" },
          "country": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "BeneficiaryResponse": {
        "type": "object",
        "properties": {
          "beneficiary": { "$ref": "#/components/schemas/Beneficiary" }
        }
      },
      "BeneficiaryListResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Beneficiary" }
          },
          "totalElements": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      },
      "BankBeneficiaryCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "accountNumber": { "type": "string" },
          "sortCode": { "type": "string" },
