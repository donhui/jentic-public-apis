{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenPayd Banking API",
    "description": "OpenPayd API for managing accounts, beneficiaries, transactions, exchange, direct debits, and open banking payments.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://apidocs.openpayd.com/"
  },
  "servers": [
    {
      "url": "https://sandbox.openpayd.com/api",
      "description": "Sandbox"
    },
    {
      "url": "https://secure.openpayd.com/api",
      "description": "Production (UK)"
    },
    {
      "url": "https://secure-mt.openpayd.com/api",
      "description": "Production (Malta)"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "Obtain access tokens" },
    { "name": "Linked Clients", "description": "Manage linked clients" },
    { "name": "Accounts", "description": "Manage accounts" },
    { "name": "Payment Accounts", "description": "Retrieve payment accounts" },
    { "name": "Beneficiaries", "description": "Manage beneficiaries" },
    { "name": "Bank Beneficiaries", "description": "Manage bank beneficiaries with verification" },
    { "name": "Transactions", "description": "Manage transactions and payouts" },
    { "name": "Exchange", "description": "Currency exchange operations" },
    { "name": "Reference Data", "description": "Retrieve reference data" },
    { "name": "Open Banking", "description": "Open banking payment operations" },
    { "name": "Direct Debit", "description": "Direct debit operations" }
  ],
  "paths": {
    "/get-access-token": {
      "post": {
        "operationId": "getAccessToken",
        "tags": ["Authentication"],
        "summary": "Obtain an authentication access token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccessTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token obtained",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccessTokenResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Invalid credentials", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/linked-clients": {
      "post": {
        "operationId": "createIndividualLinkedClient",
        "tags": ["Linked Clients"],
        "summary": "Create an individual linked client",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/IndividualLinkedClientCreate" } } }
        },
        "responses": {
          "200": { "description": "Linked client created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LinkedClientResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "get": {
        "operationId": "listLinkedClients",
        "tags": ["Linked Clients"],
        "summary": "List all linked clients",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "size", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of linked clients", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LinkedClientListResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
