  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "TaxJar API token"
      }
    },
    "schemas": {
      "Category": {
        "type": "object",
        "properties": {
          "product_tax_code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "TaxCalculationRequest": {
        "type": "object",
        "required": [
          "to_country",
          "to_state",
          "to_zip",
          "shipping"
        ],
        "properties": {
          "from_country": {
            "type": "string",
            "description": "Two-letter ISO origin country code"
          },
          "from_zip": {
            "type": "string",
            "description": "Origin postal code"
          },
          "from_state": {
            "type": "string",
            "description": "Origin state"
          },
          "from_city": {
            "type": "string",
            "description": "Origin city"
          },
          "from_street": {
            "type": "string",
            "description": "Origin street address"
          },
          "to_country": {
            "type": "string",
            "description": "Two-letter ISO destination country code"
          },
          "to_zip": {
            "type": "string",
            "description": "Destination postal code"
          },
          "to_state": {
            "type": "string",
            "description": "Destination state"
          },
          "to_city": {
            "type": "string",
            "description": "Destination city"
          },
          "to_street": {
            "type": "string",
            "description": "Destination street address"
          },
          "amount": {
            "type": "number",
            "description": "Total amount of the order excluding shipping"
          },
          "shipping": {
            "type": "number",
            "description": "Total shipping amount"
          },
          "customer_id": {
            "type": "string",
            "description": "Unique customer identifier for exemptions"
          },
          "exemption_type": {
            "type": "string",
            "enum": [
              "wholesale",
              "government",
              "marketplace",
              "other",
              "non_exempt"
            ]
          },
          "nexus_addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NexusAddress"
            }
          },
          "line_items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxLineItem"
            }
          }
        }
      },
      "TaxResult": {
        "type": "object",
        "properties": {
          "order_total_amount": {
            "type": "number"
          },
          "shipping": {
            "type": "number"
          },
          "taxable_amount": {
