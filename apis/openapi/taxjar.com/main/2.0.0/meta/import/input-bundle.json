    "/rates/{zip}": {
      "get": {
        "operationId": "getRateForLocation",
        "summary": "Show tax rates for a location",
        "description": "Shows the sales tax rates for a given location.",
        "tags": [
          "Rates"
        ],
        "parameters": [
          {
            "name": "zip",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Postal code to look up"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Two-letter ISO country code"
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Two-letter ISO state code"
          },
          {
            "name": "city",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "City name"
          },
          {
            "name": "street",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Street address"
          }
        ],
        "responses": {
          "200": {
            "description": "Tax rates for the location",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rate": {
                      "$ref": "#/components/schemas/Rate"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
