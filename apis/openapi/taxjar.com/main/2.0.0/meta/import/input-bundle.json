    "/addresses/validate": {
      "get": {
        "operationId": "validateAddress",
        "summary": "Validate an address",
        "description": "Validates a customer address and returns back a collection of address matches.",
        "tags": [
          "Validation"
        ],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Two-letter ISO country code"
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Two-letter ISO state code"
          },
          {
            "name": "zip",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Postal code"
          },
          {
            "name": "city",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "City name"
          },
          {
            "name": "street",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Street address"
          }
        ],
        "responses": {
          "200": {
            "description": "Address validation results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "addresses": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ValidatedAddress"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/validation": {
      "get": {
        "operationId": "validateVatNumber",
        "summary": "Validate a VAT number",
        "description": "Validates an existing VAT identification number against VIES.",
        "tags": [
