          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/payments": {
      "get": {
        "operationId": "listPayments",
        "summary": "List payments",
        "description": "Retrieve a paginated list of payment transactions.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "practiceId",
            "in": "query",
            "description": "Filter payments by practice identifier.",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "patientId",
            "in": "query",
            "description": "Filter payments by patient identifier.",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "paymentDateStart",
            "in": "query",
            "description": "Return payments on or after this date.",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "paymentDateEnd",
            "in": "query",
            "description": "Return payments on or before this date.",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "paymentType",
            "in": "query",
            "description": "Filter by payment type.",
            "schema": {
              "type": "string",
              "enum": ["PatientPayment", "InsurancePayment", "Adjustment"]
            }
          },
          { "$ref": "#/components/parameters/PageOffset" },
          { "$ref": "#/components/parameters/PageLimit" }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of payments.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Payment" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "recordPayment",
        "summary": "Record payment",
        "description": "Record a new payment transaction.",
        "tags": ["Payments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PaymentCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payment recorded successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Payment" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/payments/{paymentId}": {
      "get": {
        "operationId": "getPayment",
        "summary": "Get payment",
        "description": "Retrieve a single payment by identifier.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "description": "Unique payment identifier.",
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment record.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Payment" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/practices": {
      "get": {
        "operationId": "listPractices",
        "summary": "List practices",
        "description": "Retrieve a list of practices associated with the authenticated account.",
        "tags": ["Practices"],
        "parameters": [
          { "$ref": "#/components/parameters/PageOffset" },
          { "$ref": "#/components/parameters/PageLimit" }
        ],
        "responses": {
          "200": {
            "description": "A list of practices.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Practice" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/practices/{practiceId}": {
      "get": {
        "operationId": "getPractice",
        "summary": "Get practice",
        "description": "Retrieve a single practice by identifier.",
        "tags": ["Practices"],
        "parameters": [
          {
            "name": "practiceId",
            "in": "path",
            "required": true,
            "description": "Unique practice identifier.",
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "Practice record.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Practice" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/insurance-companies": {
      "get": {
        "operationId": "listInsuranceCompanies",
        "summary": "List insurance companies",
        "description": "Retrieve a paginated list of insurance companies.",
        "tags": ["Insurance"],
        "parameters": [
          {
            "name": "practiceId",
            "in": "query",
            "description": "Filter by practice identifier.",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "companyName",
            "in": "query",
            "description": "Filter by company name (partial match).",
            "schema": { "type": "string" }
          },
          {
            "name": "payerId",
            "in": "query",
            "description": "Filter by electronic payer identifier.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/PageOffset" },
          { "$ref": "#/components/parameters/PageLimit" }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of insurance companies.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/InsuranceCompany" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/insurance-plans": {
      "get": {
        "operationId": "listInsurancePlans",
        "summary": "List insurance plans",
        "description": "Retrieve a paginated list of insurance plans.",
        "tags": ["Insurance"],
        "parameters": [
          {
            "name": "practiceId",
            "in": "query",
            "description": "Filter by practice identifier.",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "insuranceCompanyId",
            "in": "query",
            "description": "Filter plans by insurance company identifier.",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "planName",
            "in": "query",
            "description": "Filter by plan name (partial match).",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/PageOffset" },
          { "$ref": "#/components/parameters/PageLimit" }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of insurance plans.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/InsurancePlan" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "OAuth 2.0 Bearer token or API key. Include in the Authorization header as 'Bearer {token}'."
      }
    },
    "parameters": {
      "PageOffset": {
        "name": "offset",
        "in": "query",
        "description": "Number of records to skip for pagination.",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "PageLimit": {
        "name": "limit",
        "in": "query",
        "description": "Maximum number of records to return.",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "default": 50
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request was invalid or malformed.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication credentials are missing or invalid.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "The requested resource was not found.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable error code.",
                "example": "INVALID_REQUEST"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error description.",
                "example": "The request body is missing required fields."
              },
              "details": {
                "type": "array",
                "description": "Additional detail about specific validation errors.",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": {
                      "type": "string",
                      "description": "The field that caused the error."
                    },
                    "message": {
                      "type": "string",
                      "description": "Description of the field-level error."
                    }
                  }
                }
              }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "integer",
            "description": "Current offset."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum records returned per page."
          },
          "totalCount": {
            "type": "integer",
            "description": "Total number of records matching the query."
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "addressLine1": { "type": "string" },
          "addressLine2": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string", "description": "Two-letter state code." },
          "zipCode": { "type": "string" },
          "country": { "type": "string", "default": "US" }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "patientId": {
            "type": "integer",
            "format": "int64",
            "description": "Unique patient identifier.",
            "readOnly": true
          },
          "practiceId": {
            "type": "integer",
            "format": "int64",
            "description": "Practice the patient belongs to."
          },
          "prefix": {
            "type": "string",
            "description": "Name prefix (e.g. Mr., Mrs., Dr.)."
          },
          "firstName": { "type": "string" },
          "middleName": { "type": "string" },
          "lastName": { "type": "string" },
          "suffix": { "type": "string" },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "Patient date of birth (YYYY-MM-DD)."
          },
          "gender": {
            "type": "string",
            "enum": ["Male", "Female", "Other", "Unknown"]
          },
          "ssn": {
            "type": "string",
            "description": "Social Security Number (masked in responses)."
          },
          "email": { "type": "string", "format": "email" },
          "homePhone": { "type": "string" },
          "mobilePhone": { "type": "string" },
          "workPhone": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" },
          "primaryProviderId": {
            "type": "integer",
            "format": "int64",
            "description": "Identifier for the patient's primary provider."
          },
          "primaryInsurancePlanId": {
            "type": "integer",
            "format": "int64",
            "description": "Identifier for the patient's primary insurance plan."
          },
          "primaryInsurancePolicyNumber": {
            "type": "string",
            "description": "Policy or member number for primary insurance."
          },
          "secondaryInsurancePlanId": {
            "type": "integer",
            "format": "int64"
          },
          "secondaryInsurancePolicyNumber": { "type": "string" },
          "maritalStatus": {
            "type": "string",
            "enum": ["Single", "Married", "Divorced", "Widowed", "Separated", "Other"]
          },
          "employmentStatus": {
            "type": "string",
            "enum": ["Employed", "Unemployed", "Retired", "Student", "Other"]
          },
          "active": {
            "type": "boolean",
            "description": "Whether the patient record is active."
          },
          "createdDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": ["firstName", "lastName", "dateOfBirth", "gender", "practiceId"]
      },
      "PatientCreate": {
        "type": "object",
        "properties": {
          "practiceId": { "type": "integer", "format": "int64" },
          "prefix": { "type": "string" },
          "firstName": { "type": "string" },
          "middleName": { "type": "string" },
          "lastName": { "type": "string" },
          "suffix": { "type": "string" },
          "dateOfBirth": { "type": "string", "format": "date" },
          "gender": {
            "type": "string",
            "enum": ["Male", "Female", "Other", "Unknown"]
          },
          "ssn": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "homePhone": { "type": "string" },
          "mobilePhone": { "type": "string" },
          "workPhone": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" },
          "primaryProviderId": { "type": "integer", "format": "int64" },
          "primaryInsurancePlanId": { "type": "integer", "format": "int64" },
          "primaryInsurancePolicyNumber": { "type": "string" },
          "secondaryInsurancePlanId": { "type": "integer", "format": "int64" },
          "secondaryInsurancePolicyNumber": { "type": "string" },
          "maritalStatus": {
            "type": "string",
            "enum": ["Single", "Married", "Divorced", "Widowed", "Separated", "Other"]
          },
          "employmentStatus": {
            "type": "string",
            "enum": ["Employed", "Unemployed", "Retired", "Student", "Other"]
          }
        },
        "required": ["practiceId", "firstName", "lastName", "dateOfBirth", "gender"]
      },
      "PatientUpdate": {
        "type": "object",
        "description": "Fields to update on the patient record. Only provided fields are modified.",
        "properties": {
          "prefix": { "type": "string" },
          "firstName": { "type": "string" },
          "middleName": { "type": "string" },
          "lastName": { "type": "string" },
          "suffix": { "type": "string" },
          "dateOfBirth": { "type": "string", "format": "date" },
          "gender": {
            "type": "string",
            "enum": ["Male", "Female", "Other", "Unknown"]
          },
          "ssn": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "homePhone": { "type": "string" },
          "mobilePhone": { "type": "string" },
          "workPhone": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" },
          "primaryProviderId": { "type": "integer", "format": "int64" },
          "primaryInsurancePlanId": { "type": "integer", "format": "int64" },
          "primaryInsurancePolicyNumber": { "type": "string" },
          "secondaryInsurancePlanId": { "type": "integer", "format": "int64" },
          "secondaryInsurancePolicyNumber": { "type": "string" },
          "maritalStatus": {
            "type": "string",
            "enum": ["Single", "Married", "Divorced", "Widowed", "Separated", "Other"]
          },
          "employmentStatus": {
            "type": "string",
            "enum": ["Employed", "Unemployed", "Retired", "Student", "Other"]
          },
          "active": { "type": "boolean" }
        }
      },
      "Appointment": {
        "type": "object",
        "properties": {
          "appointmentId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "practiceId": { "type": "integer", "format": "int64" },
          "patientId": { "type": "integer", "format": "int64" },
          "providerId": { "type": "integer", "format": "int64" },
          "appointmentType": {
            "type": "string",
            "description": "Type of appointment (e.g. New Patient, Follow Up, Annual Physical)."
          },
          "appointmentReason": {
            "type": "string",
            "description": "Reason or chief complaint for the visit."
          },
          "startDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "Scheduled start date and time."
          },
          "endDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "Scheduled end date and time."
          },
          "durationMinutes": {
            "type": "integer",
            "description": "Duration of appointment in minutes."
          },
          "status": {
            "type": "string",
            "enum": ["Scheduled", "CheckedIn", "Completed", "Cancelled", "NoShow"]
          },
          "locationName": {
            "type": "string",
            "description": "Office or service location name."
          },
          "notes": { "type": "string" },
          "createdDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": ["practiceId", "patientId", "providerId", "startDateTime", "durationMinutes"]
      },
      "AppointmentCreate": {
        "type": "object",
        "properties": {
          "practiceId": { "type": "integer", "format": "int64" },
          "patientId": { "type": "integer", "format": "int64" },
          "providerId": { "type": "integer", "format": "int64" },
          "appointmentType": { "type": "string" },
          "appointmentReason": { "type": "string" },
          "startDateTime": { "type": "string", "format": "date-time" },
          "durationMinutes": { "type": "integer" },
          "locationName": { "type": "string" },
          "notes": { "type": "string" }
        },
        "required": ["practiceId", "patientId", "providerId", "startDateTime", "durationMinutes"]
      },
      "AppointmentUpdate": {
        "type": "object",
        "description": "Fields to update on the appointment. Only provided fields are modified.",
        "properties": {
          "providerId": { "type": "integer", "format": "int64" },
          "appointmentType": { "type": "string" },
          "appointmentReason": { "type": "string" },
          "startDateTime": { "type": "string", "format": "date-time" },
          "durationMinutes": { "type": "integer" },
          "status": {
            "type": "string",
            "enum": ["Scheduled", "CheckedIn", "Completed", "Cancelled", "NoShow"]
          },
          "locationName": { "type": "string" },
          "notes": { "type": "string" }
        }
      },
      "Provider": {
        "type": "object",
        "properties": {
          "providerId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "practiceId": { "type": "integer", "format": "int64" },
          "prefix": { "type": "string" },
          "firstName": { "type": "string" },
          "middleName": { "type": "string" },
          "lastName": { "type": "string" },
          "suffix": { "type": "string" },
          "degree": {
            "type": "string",
            "description": "Professional degree (e.g. MD, DO, NP, PA)."
          },
          "specialty": {
            "type": "string",
            "description": "Medical specialty."
          },
          "npi": {
            "type": "string",
            "description": "National Provider Identifier (10-digit)."
          },
          "deaNumber": {
            "type": "string",
            "description": "DEA registration number."
          },
          "stateLicenseNumber": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "active": { "type": "boolean" },
          "createdDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": ["firstName", "lastName", "practiceId"]
      },
      "Encounter": {
        "type": "object",
        "properties": {
          "encounterId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "practiceId": { "type": "integer", "format": "int64" },
          "patientId": { "type": "integer", "format": "int64" },
          "providerId": { "type": "integer", "format": "int64" },
          "appointmentId": {
            "type": "integer",
            "format": "int64",
            "description": "Associated appointment identifier, if any."
          },
          "serviceDate": {
            "type": "string",
            "format": "date",
            "description": "Date of service."
          },
          "placeOfService": {
            "type": "string",
            "description": "CMS place of service code (e.g. 11 for Office)."
          },
          "diagnoses": {
            "type": "array",
            "description": "ICD-10 diagnosis codes associated with the encounter.",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string",
                  "description": "ICD-10 diagnosis code."
                },
                "description": {
                  "type": "string",
                  "description": "Diagnosis description."
                },
                "sequence": {
                  "type": "integer",
                  "description": "Order of the diagnosis (1 = primary)."
                }
              }
            }
          },
          "procedures": {
            "type": "array",
            "description": "CPT procedure codes associated with the encounter.",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string",
                  "description": "CPT/HCPCS procedure code."
                },
                "description": { "type": "string" },
                "modifiers": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Procedure modifiers."
                },
                "units": {
                  "type": "number",
                  "format": "float",
                  "description": "Number of units."
                },
                "chargeAmount": {
                  "type": "number",
                  "format": "double",
                  "description": "Charge amount in USD."
                },
                "diagnosisPointers": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "description": "References to diagnosis sequence numbers."
                }
              }
            }
          },
          "status": {
            "type": "string",
            "enum": ["Draft", "Signed", "Billed", "Void"],
            "description": "Current encounter status."
          },
          "notes": { "type": "string" },
          "createdDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": ["practiceId", "patientId", "providerId", "serviceDate"]
      },
      "EncounterCreate": {
        "type": "object",
        "properties": {
          "practiceId": { "type": "integer", "format": "int64" },
          "patientId": { "type": "integer", "format": "int64" },
          "providerId": { "type": "integer", "format": "int64" },
          "appointmentId": { "type": "integer", "format": "int64" },
          "serviceDate": { "type": "string", "format": "date" },
          "placeOfService": { "type": "string" },
          "diagnoses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "description": { "type": "string" },
                "sequence": { "type": "integer" }
              },
              "required": ["code", "sequence"]
            }
          },
          "procedures": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "description": { "type": "string" },
                "modifiers": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "units": { "type": "number", "format": "float" },
                "chargeAmount": { "type": "number", "format": "double" },
                "diagnosisPointers": {
                  "type": "array",
                  "items": { "type": "integer" }
                }
              },
              "required": ["code"]
            }
          },
          "notes": { "type": "string" }
        },
        "required": ["practiceId", "patientId", "providerId", "serviceDate"]
      },
      "EncounterUpdate": {
        "type": "object",
        "description": "Fields to update on the encounter. Only provided fields are modified.",
        "properties": {
          "providerId": { "type": "integer", "format": "int64" },
          "serviceDate": { "type": "string", "format": "date" },
          "placeOfService": { "type": "string" },
          "diagnoses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "description": { "type": "string" },
                "sequence": { "type": "integer" }
              },
              "required": ["code", "sequence"]
            }
          },
          "procedures": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "description": { "type": "string" },
                "modifiers": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "units": { "type": "number", "format": "float" },
                "chargeAmount": { "type": "number", "format": "double" },
                "diagnosisPointers": {
                  "type": "array",
                  "items": { "type": "integer" }
                }
              },
              "required": ["code"]
            }
          },
          "status": {
            "type": "string",
            "enum": ["Draft", "Signed", "Billed", "Void"]
          },
          "notes": { "type": "string" }
        }
      },
      "Claim": {
        "type": "object",
        "properties": {
          "claimId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "practiceId": { "type": "integer", "format": "int64" },
          "patientId": { "type": "integer", "format": "int64" },
          "providerId": { "type": "integer", "format": "int64" },
          "encounterId": {
            "type": "integer",
            "format": "int64",
            "description": "Associated encounter identifier."
          },
          "insuranceCompanyId": { "type": "integer", "format": "int64" },
          "insurancePlanId": { "type": "integer", "format": "int64" },
          "policyNumber": { "type": "string" },
          "serviceDate": { "type": "string", "format": "date" },
          "serviceDateEnd": { "type": "string", "format": "date" },
          "placeOfService": { "type": "string" },
          "totalChargeAmount": {
            "type": "number",
            "format": "double",
            "description": "Total charge amount in USD."
          },
          "totalPaidAmount": {
            "type": "number",
            "format": "double",
            "description": "Total paid amount in USD.",
            "readOnly": true
          },
          "balanceAmount": {
            "type": "number",
            "format": "double",
            "description": "Outstanding balance in USD.",
            "readOnly": true
          },
          "status": {
            "type": "string",
            "enum": ["Draft", "Submitted", "Accepted", "Rejected", "Paid", "Denied"]
          },
          "claimNumber": {
            "type": "string",
            "description": "Payer-assigned claim reference number.",
            "readOnly": true
          },
          "lineItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "procedureCode": { "type": "string" },
                "modifiers": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "diagnosisPointers": {
                  "type": "array",
                  "items": { "type": "integer" }
                },
                "units": { "type": "number", "format": "float" },
                "chargeAmount": { "type": "number", "format": "double" },
                "paidAmount": { "type": "number", "format": "double" }
              }
            }
          },
          "submittedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "createdDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": ["practiceId", "patientId", "providerId", "serviceDate"]
      },
      "ClaimCreate": {
        "type": "object",
        "properties": {
          "practiceId": { "type": "integer", "format": "int64" },
          "patientId": { "type": "integer", "format": "int64" },
          "providerId": { "type": "integer", "format": "int64" },
          "encounterId": { "type": "integer", "format": "int64" },
          "insuranceCompanyId": { "type": "integer", "format": "int64" },
          "insurancePlanId": { "type": "integer", "format": "int64" },
          "policyNumber": { "type": "string" },
          "serviceDate": { "type": "string", "format": "date" },
          "serviceDateEnd": { "type": "string", "format": "date" },
          "placeOfService": { "type": "string" },
          "lineItems": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "procedureCode": { "type": "string" },
                "modifiers": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "diagnosisPointers": {
                  "type": "array",
                  "items": { "type": "integer" }
                },
                "units": { "type": "number", "format": "float" },
                "chargeAmount": { "type": "number", "format": "double" }
              },
              "required": ["procedureCode", "chargeAmount"]
            }
          }
        },
        "required": ["practiceId", "patientId", "providerId", "serviceDate"]
      },
      "Payment": {
        "type": "object",
        "properties": {
          "paymentId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "practiceId": { "type": "integer", "format": "int64" },
          "patientId": { "type": "integer", "format": "int64" },
          "claimId": {
            "type": "integer",
            "format": "int64",
            "description": "Associated claim identifier, if applicable."
          },
          "paymentDate": { "type": "string", "format": "date" },
          "paymentType": {
            "type": "string",
            "enum": ["PatientPayment", "InsurancePayment", "Adjustment"]
          },
          "paymentMethod": {
            "type": "string",
            "enum": ["Cash", "Check", "CreditCard", "EFT", "Other"],
            "description": "Method of payment."
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "Payment amount in USD."
          },
          "referenceNumber": {
            "type": "string",
            "description": "Check number, transaction ID, or other reference."
          },
          "insuranceCompanyId": {
            "type": "integer",
            "format": "int64",
            "description": "Insurance company that made the payment (for insurance payments)."
          },
          "notes": { "type": "string" },
          "createdDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": ["practiceId", "paymentDate", "paymentType", "amount"]
      },
      "PaymentCreate": {
        "type": "object",
        "properties": {
          "practiceId": { "type": "integer", "format": "int64" },
          "patientId": { "type": "integer", "format": "int64" },
          "claimId": { "type": "integer", "format": "int64" },
          "paymentDate": { "type": "string", "format": "date" },
          "paymentType": {
            "type": "string",
            "enum": ["PatientPayment", "InsurancePayment", "Adjustment"]
          },
