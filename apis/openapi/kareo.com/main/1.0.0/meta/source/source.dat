          },
          {
            "name": "patientId",
            "in": "query",
            "description": "Filter encounters by patient identifier.",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "providerId",
            "in": "query",
            "description": "Filter encounters by provider identifier.",
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "serviceDateStart",
            "in": "query",
