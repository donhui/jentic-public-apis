          "createdDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": ["practiceName"]
      },
      "InsuranceCompany": {
        "type": "object",
        "properties": {
          "insuranceCompanyId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "companyName": { "type": "string" },
          "payerId": {
            "type": "string",
            "description": "Electronic payer identifier used for claims submission."
          },
          "phone": { "type": "string" },
          "fax": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" },
          "claimsAddress": {
            "$ref": "#/components/schemas/Address",
            "description": "Address for claims submission, if different from main address."
          },
          "active": { "type": "boolean" },
          "createdDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "modifiedDate": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": ["companyName"]
      },
      "InsurancePlan": {
        "type": "object",
        "properties": {
          "insurancePlanId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "insuranceCompanyId": { "type": "integer", "format": "int64" },
          "planName": { "type": "string" },
          "planType": {
            "type": "string",
            "enum": ["HMO", "PPO", "EPO", "POS", "Medicare", "Medicaid", "Tricare", "WorkersComp", "Other"],
