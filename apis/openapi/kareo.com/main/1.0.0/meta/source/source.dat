            "type": "string",
            "enum": ["Cash", "Check", "CreditCard", "EFT", "Other"]
          },
          "amount": { "type": "number", "format": "double" },
          "referenceNumber": { "type": "string" },
          "insuranceCompanyId": { "type": "integer", "format": "int64" },
          "notes": { "type": "string" }
        },
        "required": ["practiceId", "paymentDate", "paymentType", "amount"]
      },
      "Practice": {
        "type": "object",
        "properties": {
          "practiceId": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
