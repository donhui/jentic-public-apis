{
  "openapi": "3.0.3",
  "info": {
    "title": "Getro Job Board and Network API",
    "description": "Getro API provides access to network companies, job listings, contacts, and related data. Designed for building integrations and backing up network data.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://docs.getro.com/",
    "contact": {
      "name": "Getro",
      "url": "https://www.getro.com"
    }
  },
  "servers": [
    {
      "url": "https://api.getro.com/v2",
      "description": "Getro API v2"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/job_functions": {
      "get": {
        "operationId": "getJobFunctions",
        "summary": "Get all job functions",
        "description": "Retrieve all job functions in the system.",
        "tags": [
          "Job Functions"
        ],
        "responses": {
          "200": {
            "description": "Job functions retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/JobFunction"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/locations/companies": {
      "get": {
        "operationId": "getLocationsForCompanies",
        "summary": "Get locations for companies",
        "description": "Retrieve locations related to companies. Returns maximum 10 results.",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter results by location string"
          }
        ],
        "responses": {
          "200": {
            "description": "Locations retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Location"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/locations/jobs": {
      "get": {
        "operationId": "getLocationsForJobs",
        "summary": "Get locations for jobs",
        "description": "Retrieve locations related to jobs. Returns maximum 10 results.",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter results by location string"
          }
        ],
        "responses": {
          "200": {
            "description": "Locations retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Location"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/networks": {
      "get": {
        "operationId": "getNetworks",
        "summary": "Get all networks",
        "description": "Retrieve information about your networks.",
        "tags": [
          "Networks"
        ],
        "responses": {
          "200": {
            "description": "Networks retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Network"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/networks/{id}": {
      "get": {
        "operationId": "getNetwork",
        "summary": "Get a specific network",
        "description": "Retrieve information about a given network by ID.",
        "tags": [
          "Networks"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Network retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Network"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Network not found"
          }
        }
      }
    },
    "/networks/{id}/companies": {
      "get": {
        "operationId": "getCompanies",
        "summary": "Get all companies",
        "description": "Retrieve all companies in a network.",
        "tags": [
          "Companies"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by company name"
          },
          {
            "name": "topics",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by topics (pipe-separated)"
          },
          {
            "name": "job_functions",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by job functions (pipe-separated)"
          },
          {
            "name": "locations",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by locations (pipe-separated Google Place IDs)"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Companies retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyList"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/networks/{id}/companies/{company_id}": {
      "get": {
        "operationId": "getCompany",
        "summary": "Get a specific company",
        "description": "Retrieve a specific company's information within the network.",
        "tags": [
          "Companies"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          },
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Company ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Company retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Company"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Company not found"
          }
        }
      }
    },
    "/networks/{id}/jobs": {
      "get": {
        "operationId": "searchJobs",
        "summary": "Search jobs",
        "description": "Search through jobs in your network.",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          },
          {
            "name": "title",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by job title"
          },
          {
            "name": "job_functions",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by job functions (pipe-separated)"
          },
          {
            "name": "locations",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by locations (pipe-separated)"
          },
          {
            "name": "companies",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by company names or IDs (pipe-separated)"
          },
          {
            "name": "topics",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by topics (pipe-separated)"
          },
          {
            "name": "industry_tags",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by industry tags (pipe-separated)"
          },
          {
            "name": "work_mode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "remote",
                "on_site"
              ]
            },
            "description": "Filter by work mode"
          },
          {
            "name": "company_sizes",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by company sizes (pipe-separated: xs, s, m, l, xl, xxl)"
          },
          {
            "name": "min_salary",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Minimum salary"
          },
          {
            "name": "has_equity",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by equity offering"
          },
          {
            "name": "seniority",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "internship",
                "entry_level",
                "associate",
                "mid_senior",
                "senior",
                "director",
                "executive",
                "vice_president",
                "cxo",
                "founder"
              ]
            },
            "description": "Filter by seniority level"
          },
          {
            "name": "created_from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Jobs created after this date"
          },
          {
            "name": "created_to",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Jobs created before this date"
          },
          {
            "name": "include_descriptions",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Include job descriptions in response"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Jobs per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Jobs retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobList"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/networks/{id}/jobs/removed": {
      "get": {
        "operationId": "searchRemovedJobs",
        "summary": "Search removed jobs",
        "description": "Search through removed/deactivated jobs in the database.",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          },
          {
            "name": "title",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by job title"
          },
          {
            "name": "deactivated_from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Deactivation date range start"
          },
          {
            "name": "deactivated_to",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Deactivation date range end"
          },
          {
            "name": "locations",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by locations (pipe-separated)"
          },
          {
            "name": "job_functions",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by job functions (pipe-separated)"
          },
          {
            "name": "companies",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by companies (pipe-separated)"
          },
          {
            "name": "industry_tags",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by industry tags (pipe-separated)"
          },
          {
            "name": "work_mode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "remote",
                "on_site"
              ]
            }
          },
          {
            "name": "company_sizes",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "topics",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "min_salary",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "has_equity",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Removed jobs retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobList"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/networks/{network_id}/jobs/{id}": {
      "get": {
        "operationId": "getJob",
        "summary": "Get job details",
        "description": "Retrieve details for a specific job.",
        "tags": [
          "Jobs"
        ],
        "parameters": [
          {
            "name": "network_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Job ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Job details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Job not found"
          }
        }
      }
    },
    "/industry_tags": {
      "get": {
        "operationId": "getIndustryTags",
        "summary": "Get all industry tags",
        "description": "Retrieve all industry tags.",
        "tags": [
          "Industry Tags"
        ],
        "responses": {
          "200": {
            "description": "Industry tags retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndustryTag"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/networks/{id}/contacts": {
      "get": {
        "operationId": "searchContacts",
        "summary": "Search contacts",
        "description": "Search through contacts in your network.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          },
          {
            "name": "keywords",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Keyword search"
          },
          {
            "name": "job_applications_jobs",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by job application job IDs (pipe-separated)"
          },
          {
            "name": "locations",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by locations (pipe-separated)"
          },
          {
            "name": "signup_locations",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by signup locations"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contacts retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactList"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/networks/{network_id}/contacts/{id}": {
      "get": {
        "operationId": "getContact",
        "summary": "Get contact details",
        "description": "Retrieve details for a specific contact.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "network_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Contact ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Contact not found"
          }
        }
      }
    },
    "/contacts/import": {
      "post": {
        "operationId": "importContacts",
        "summary": "Import Contacts",
        "description": "Import contacts into your network.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contacts": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/ContactImport"
                    }
                  }
                },
                "required": [
                  "contacts"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contacts queued for import",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/networks/{network_id}/contacts/notes": {
      "post": {
        "operationId": "createContactNote",
        "summary": "Create Contact Note",
        "description": "Create a note for a contact in your network.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "network_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Network ID"
          },
          {
            "name": "on_missing",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "upsert"
              ]
            },
            "description": "When set to 'upsert', creates a minimal contact if not found"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "linkedin_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Contact's LinkedIn URL"
                  },
                  "title": {
                    "type": "string",
                    "description": "Note title"
                  },
                  "body": {
                    "type": "string",
                    "description": "Note body"
                  }
                },
                "required": [
                  "linkedin_url",
                  "title",
                  "body"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Note created"
          },
          "400": {
            "description": "Bad Request - Invalid LinkedIn URL"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - Only network admins can create notes"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Generate API keys in the Getro Admin Portal."
      }
    },
    "schemas": {
      "JobFunction": {
        "type": "object",
        "properties": {
          "id": {
