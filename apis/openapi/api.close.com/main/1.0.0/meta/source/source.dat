  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use your API key as the username and leave the password empty"
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://app.close.com/oauth2/authorize",
            "tokenUrl": "https://api.close.com/oauth2/token",
            "scopes": {}
          }
        }
      }
    },
    "parameters": {
      "leadId": {
        "name": "lead_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "contactId": {
        "name": "contact_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "opportunityId": {
        "name": "opportunity_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "taskId": {
        "name": "task_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "organizationId": {
        "name": "organization_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "pipelineId": {
        "name": "pipeline_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing credentials",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "status_id": { "type": "string" },
          "status_label": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string", "nullable": true },
          "contacts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Contact" }
          },
          "addresses": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Address" }
          },
          "opportunities": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Opportunity" }
          },
          "tasks": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Task" }
          },
          "organization_id": { "type": "string" },
          "created_by": { "type": "string" },
          "updated_by": { "type": "string" },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" }
        }
      },
      "LeadCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status_id": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string" },
          "contacts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContactCreate" }
          }
        }
      },
      "LeadUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status_id": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "lead_id": { "type": "string" },
          "name": { "type": "string" },
          "title": { "type": "string" },
          "phones": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phone": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" }
        }
      },
      "ContactCreate": {
        "type": "object",
        "properties": {
          "lead_id": { "type": "string" },
          "name": { "type": "string" },
          "title": { "type": "string" },
          "phones": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phone": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "address_1": { "type": "string" },
          "address_2": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zipcode": { "type": "string" },
          "country": { "type": "string" }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "_type": { "type": "string" },
          "lead_id": { "type": "string" },
          "user_id": { "type": "string" },
          "contact_id": { "type": "string", "nullable": true },
          "organization_id": { "type": "string" },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" },
          "activity_at": { "type": "string", "format": "date-time" }
        }
      },
      "Opportunity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "lead_id": { "type": "string" },
          "lead_name": { "type": "string" },
          "status_id": { "type": "string" },
          "status_label": { "type": "string" },
          "status_type": { "type": "string" },
          "value": { "type": "integer" },
          "value_period": { "type": "string" },
          "value_currency": { "type": "string" },
          "confidence": { "type": "integer" },
          "note": { "type": "string" },
          "date_won": { "type": "string", "format": "date", "nullable": true },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" },
          "user_id": { "type": "string" },
          "user_name": { "type": "string" },
          "organization_id": { "type": "string" }
        }
      },
      "OpportunityCreate": {
        "type": "object",
        "properties": {
          "lead_id": { "type": "string" },
          "status_id": { "type": "string" },
          "value": { "type": "integer" },
          "value_period": { "type": "string" },
          "confidence": { "type": "integer" },
          "note": { "type": "string" }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "_type": { "type": "string" },
          "lead_id": { "type": "string" },
          "lead_name": { "type": "string" },
          "assigned_to": { "type": "string" },
          "assigned_to_name": { "type": "string" },
          "text": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "is_complete": { "type": "boolean" },
          "object_id": { "type": "string", "nullable": true },
          "object_type": { "type": "string", "nullable": true },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" }
        }
      },
      "TaskCreate": {
        "type": "object",
        "required": ["_type"],
        "properties": {
          "_type": { "type": "string" },
          "lead_id": { "type": "string" },
          "assigned_to": { "type": "string" },
          "text": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "is_complete": { "type": "boolean" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "image": { "type": "string", "nullable": true },
          "organizations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" }
        }
      },
      "UserAvailability": {
        "type": "object",
        "properties": {
          "user_id": { "type": "string" },
          "active_calls": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "Organization": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "currency": { "type": "string" },
          "memberships": { "type": "array", "items": { "type": "object" } },
          "inactive_memberships": { "type": "array", "items": { "type": "object" } },
          "lead_statuses": { "type": "array", "items": { "type": "object" } },
          "opportunity_statuses": { "type": "array", "items": { "type": "object" } },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" }
        }
      },
      "Pipeline": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "organization_id": { "type": "string" },
          "statuses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" }
        }
      },
      "CustomField": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["text", "number", "date", "datetime", "choices", "user", "contact", "custom_object", "textarea", "hidden"] },
          "choices": {
            "type": "array",
            "items": { "type": "string" },
            "nullable": true
          },
          "accepts_multiple_values": { "type": "boolean" },
          "editable_with_roles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "organization_id": { "type": "string" },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
