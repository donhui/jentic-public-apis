{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenObserve API",
    "version": "1.0.0",
    "description": "OpenObserve API provides programmatic access to interact with OpenObserve for log, metric, and trace management. Supports stream operations, data ingestion, search queries, and user management.",
    "x-jentic-source-url": "https://openobserve.ai/docs/api/"
  },
  "servers": [
    {
      "url": "https://{instance}",
      "variables": {
        "instance": {
          "default": "localhost:5080",
          "description": "OpenObserve instance URL"
        }
      }
    }
  ],
  "paths": {
    "/api/{organization}/streams": {
      "get": {
        "operationId": "listStreams",
        "summary": "List streams",
        "description": "Retrieve a list of streams with optional schema information and filtering by stream type.",
        "tags": [
          "Streams"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "description": "Organization identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fetchSchema",
            "in": "query",
            "required": false,
            "description": "Set to true to include schema details for each stream",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "Filter by stream type",
            "schema": {
              "type": "string",
              "enum": [
                "logs",
                "metrics",
                "traces"
              ],
              "default": "logs"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of streams returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StreamListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/{organization}/streams/{streamName}": {
      "delete": {
        "operationId": "deleteStream",
        "summary": "Delete a stream",
        "description": "Remove a complete stream and all associated data.",
        "tags": [
          "Streams"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "description": "Organization identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streamName",
            "in": "path",
            "required": true,
            "description": "Name of the stream to delete",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "description": "Stream type",
            "schema": {
              "type": "string",
              "enum": [
                "logs",
                "metrics",
                "traces"
              ]
            }
          },
          {
            "name": "delete_all",
            "in": "query",
            "required": false,
            "description": "Delete related resources like alerts and dashboards",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stream deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Stream not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/{organization}/streams/{streamName}/data_by_time_range": {
      "delete": {
        "operationId": "deleteStreamDataByTimeRange",
        "summary": "Delete stream data by time range",
        "description": "Remove stream data within a specific timeframe.",
        "tags": [
          "Streams"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "description": "Organization identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streamName",
            "in": "path",
            "required": true,
            "description": "Stream name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "description": "Start timestamp in microseconds (UTC, inclusive)",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "description": "End timestamp in microseconds (UTC, inclusive)",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deletion job created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Job ID for tracking deletion status"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Stream not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/{organization}/streams/{streamName}/data_by_time_range/status/{jobId}": {
      "get": {
        "operationId": "getDeleteJobStatus",
        "summary": "Get delete job status",
        "description": "Check the status of a time-range deletion job.",
        "tags": [
          "Streams"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streamName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "description": "Job ID from the deletion request",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteJobStatus"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Job not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/{organization}/streams/{streamName}/cache/results": {
      "delete": {
        "operationId": "deleteCacheResults",
        "summary": "Delete cache results",
        "description": "Clear cached query results up to a specified timestamp threshold.",
        "tags": [
          "Streams"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streamName",
            "in": "path",
            "required": true,
            "description": "Stream name (use _all for all streams)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "logs",
                "metrics",
                "traces"
              ]
            }
          },
          {
            "name": "ts",
            "in": "query",
            "required": true,
            "description": "Timestamp threshold in microseconds",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cache deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/{organization}/{stream}/_json": {
      "post": {
        "operationId": "ingestLogsJson",
        "summary": "Ingest JSON logs",
        "description": "Upload multiple log records in batch using standard JSON format. Records limited to 200 fields maximum.",
        "tags": [
          "Ingestion"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "description": "Organization identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stream",
            "in": "path",
            "required": true,
            "description": "Stream name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "_timestamp": {
                      "type": "integer",
                      "format": "int64",
                      "description": "Unix epoch timestamp in microseconds"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ingestion result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/{organization}/ingest/metrics/_json": {
      "post": {
        "operationId": "ingestMetricsJson",
        "summary": "Ingest JSON metrics",
        "description": "Upload multiple metric records in batch with standard JSON format.",
        "tags": [
          "Ingestion"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "description": "Organization identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/MetricRecord"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ingestion result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/{organization}/_search": {
      "post": {
        "operationId": "searchLogs",
        "summary": "Search logs",
        "description": "Execute SQL queries against log streams with time-range filtering and pagination.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "description": "Organization identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/{organization}/users": {
      "post": {
        "operationId": "createUser",
        "summary": "Create a user",
        "description": "Create a new user account within an organization.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "organization",
            "in": "path",
            "required": true,
            "description": "Organization identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusMessage"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StreamListResponse": {
        "type": "object",
        "properties": {
          "list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Stream"
            }
          }
        }
      },
      "Stream": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "storage_type": {
            "type": "string",
            "enum": [
              "s3",
              "disk"
            ]
          },
          "stream_type": {
            "type": "string",
            "enum": [
              "logs",
              "metrics",
              "traces"
            ]
          },
          "stats": {
            "type": "object",
            "properties": {
              "doc_time_min": {
                "type": "integer",
                "format": "int64"
              },
              "doc_time_max": {
                "type": "integer",
                "format": "int64"
              },
              "doc_num": {
                "type": "integer",
                "format": "int64"
              },
              "file_num": {
                "type": "integer",
                "format": "int64"
              },
              "storage_size": {
                "type": "integer",
                "format": "int64"
              },
              "compressed_size": {
                "type": "integer",
                "format": "int64"
              }
            }
          },
          "schema": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "Utf8",
                    "Int64",
                    "Float64",
                    "Timestamp",
                    "Boolean"
                  ]
                }
              }
            }
          },
          "settings": {
            "type": "object",
            "properties": {
              "partition_keys": {
                "type": "object"
              },
              "full_text_search_keys": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "DeleteJobStatus": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "Completed",
              "Pending"
            ]
          },
          "metadata": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "cluster": {
                  "type": "string"
                },
                "region": {
                  "type": "string"
                },
                "id": {
                  "type": "string"
                },
                "key": {
                  "type": "string"
                },
                "created_at": {
                  "type": "integer"
                },
                "ended_at": {
                  "type": "integer"
                },
                "status": {
                  "type": "string"
                }
              }
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "IngestionResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "successful": {
                  "type": "integer"
                },
                "failed": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "MetricRecord": {
        "type": "object",
        "required": [
          "__name__",
          "__type__",
          "value"
        ],
        "properties": {
          "__name__": {
            "type": "string",
            "description": "Stream name identifier"
          },
          "__type__": {
            "type": "string",
            "enum": [
              "counter",
              "gauge",
              "histogram",
              "summary"
            ],
            "description": "Metric type"
          },
          "_timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp in milliseconds"
          },
          "value": {
            "type": "number",
            "description": "Numeric metric value"
          }
        },
        "additionalProperties": {
          "type": "string",
          "description": "Custom labels"
        }
      },
      "SearchRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "object",
            "required": [
              "sql",
              "start_time",
              "end_time"
            ],
            "properties": {
              "sql": {
                "type": "string",
                "description": "SQL query statement"
              },
              "start_time": {
                "type": "integer",
                "format": "int64",
                "description": "Start time in microseconds"
              },
              "end_time": {
                "type": "integer",
                "format": "int64",
                "description": "End time in microseconds"
              },
              "from": {
                "type": "integer",
                "format": "int64",
                "description": "Pagination offset",
                "default": 0
              },
              "size": {
                "type": "integer",
                "format": "int64",
                "description": "Result count limit",
                "default": 0
              }
            }
          },
          "search_type": {
            "type": "string",
            "enum": [
              "ui",
              "dashboards",
              "reports",
              "alerts"
            ]
          },
          "timeout": {
            "type": "integer",
            "description": "Query timeout in seconds"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "took": {
            "type": "integer",
            "format": "int64",
            "description": "Query execution time in milliseconds"
          },
          "hits": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Matching log records"
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "Total matching records"
          },
          "from": {
            "type": "integer",
            "format": "int64"
          },
          "size": {
            "type": "integer",
            "format": "int64"
          },
          "scan_size": {
            "type": "integer",
            "format": "int64",
            "description": "Data volume scanned in MB"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": [
          "email",
          "first_name",
          "last_name",
          "password",
          "role"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "user"
            ]
          }
        }
      },
      "StatusMessage": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using base64-encoded credentials"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ]
}