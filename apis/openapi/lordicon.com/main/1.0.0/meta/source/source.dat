{
  "openapi": "3.0.3",
  "info": {
    "title": "Lordicon API",
    "version": "1.0.0",
    "description": "Lordicon animated icon API providing access to production-ready vector-based animated icons. Supports icon search, variant listing, download tracking, and statistics.",
    "x-jentic-source-url": "https://lordicon.com/docs/api/documentation"
  },
  "servers": [
    {
      "url": "https://api.lordicon.com"
    }
  ],
  "paths": {
    "/v1/variants": {
      "get": {
        "operationId": "listVariants",
        "summary": "List icon families and styles",
        "description": "Returns all available icon families and styles with counts of free and premium icons.",
        "tags": ["Variants"],
        "responses": {
          "200": {
            "description": "List of variants",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Variant"
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/icons": {
      "get": {
        "operationId": "listIcons",
        "summary": "List available icons",
        "description": "Returns available icons with optional search filtering, pagination, and family/style filtering.",
        "tags": ["Icons"],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search query for filtering icons.",
            "schema": { "type": "string" }
          },
          {
            "name": "family",
            "in": "query",
            "description": "Filter by icon family.",
            "schema": { "type": "string" }
          },
          {
            "name": "style",
            "in": "query",
            "description": "Filter by icon style.",
            "schema": { "type": "string" }
          },
          {
            "name": "premium",
            "in": "query",
            "description": "Filter by premium status.",
            "schema": { "type": "boolean" }
          },
          {
            "name": "index",
            "in": "query",
            "description": "Icon index filter.",
            "schema": { "type": "integer" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination.",
            "schema": { "type": "integer" }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (max 100).",
            "schema": { "type": "integer", "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of icons",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Icon"
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/download/track": {
      "post": {
        "operationId": "trackDownload",
        "summary": "Track an icon download",
        "description": "Records a download event for a specific icon.",
        "tags": ["Downloads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackDownloadRequest"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Download tracked successfully" },
          "400": { "description": "Invalid request" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/v1/download/stats": {
      "get": {
        "operationId": "getDownloadStats",
        "summary": "Get download statistics",
        "description": "Returns download statistics with pagination support.",
        "tags": ["Downloads"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "Download statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DownloadStat"
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid request" },
          "401": { "description": "Authentication required" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Variant": {
        "type": "object",
        "properties": {
          "family": { "type": "string" },
          "style": { "type": "string" },
          "freeCount": { "type": "integer" },
          "premiumCount": { "type": "integer" }
        }
      },
      "Icon": {
        "type": "object",
        "properties": {
          "family": { "type": "string" },
          "style": { "type": "string" },
          "name": { "type": "string" },
          "premium": { "type": "boolean" },
          "preview": { "type": "string", "format": "uri" },
          "svg": { "type": "string", "format": "uri" },
          "json": { "type": "string", "format": "uri" }
        }
      },
      "TrackDownloadRequest": {
        "type": "object",
        "required": ["family", "style", "index"],
        "properties": {
          "family": { "type": "string" },
          "style": { "type": "string" },
          "index": { "type": "integer" }
        }
      },
      "DownloadStat": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "freeCount": { "type": "integer" },
          "premiumCount": { "type": "integer" }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}