  "components": {
    "headers": {
      "Content-Type": {
        "description": "The media type of the body",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "application/json;charset=UTF-8"
      },
      "Content-Length": {
        "description": "Response length",
        "required": true,
        "schema": {
          "type": "number"
        },
        "example": 3791
      },
      "Date": {
        "description": "Response timestamp",
        "required": true,
        "schema": {
          "type": "string",
          "format": "date"
        },
        "example": "Mon, 08 May 2017 23:56:58 GMT"
      },
      "X-Transaction-ID": {
        "description": "This is the transaction id provided in the initial request.",
        "schema": {
          "type": "string"
        }
      },
      "X-Ratelimit-Remaining": {
        "description": "Rate limits are disabled as of version v1.3.0 Headers are present to ensure compatibility with previous versions it is left in.",
        "schema": {
          "type": "string"
        }
      },
      "X-Ratelimit-Limit": {
        "description": "Rate limits are disabled as of version v1.3.0 Headers are present to ensure compatibility with previous versions it is left in.",
        "schema": {
          "type": "string"
        }
      },
      "X-Ratelimit-Reset": {
        "description": "Rate limits are disabled as of version v1.3.0 Headers are present to ensure compatibility with previous versions it is left in.",
        "schema": {
          "type": "string"
        }
      },
      "Refresh": {
        "description": "This is the recommended wait time until a response is available. It is a static number based on our average response times.",
        "schema": {
          "type": "string"
        },
        "example": "8"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "cause": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "X-Transaction-ID": {
            "type": "string"
          }
        }
      },
      "Version": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "example": "1.2.0"
          }
        }
      },
      "AddressSearchResult": {
        "required": [
          "links",
          "results"
        ],
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "description": "List of auto-complete address matches.",
            "items": {
              "required": [
                "fsl",
                "label",
                "links"
              ],
              "type": "object",
              "properties": {
                "fsl": {
                  "type": "string",
                  "description": "Enables address Location identifier.",
                  "example": "01234567CESLCLF10"
                },
                "label": {
                  "type": "string",
                  "description": "Formatted matched address string",
                  "example": "123B FAKE STREET, SUBURB, Christchurch"
                },
                "links": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Link"
                  }
                }
              }
            }
          },
          "links": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Link"
            }
          }
        }
      },
      "LookupAddressDetail": {
        "required": [
          "formattedAddress",
          "links",
          "location",
          "references",
          "structuredAddress"
        ],
        "type": "object",
        "properties": {
          "formattedAddress": {
            "$ref": "#/components/schemas/FormattedAddress"
          },
          "structuredAddress": {
            "$ref": "#/components/schemas/StructuredAddress"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "references": {
            "$ref": "#/components/schemas/References"
          },
          "links": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Link"
            }
          }
        },
        "example": {
          "formattedAddress": {
            "line1": "123B FAKE STREET",
            "line3": "SUBURB1"
          },
          "structuredAddress": {
            "streetNumber": "123B",
            "suburb": "SUBURB1",
            "country": "New Zealand"
          },
          "location": {},
          "references": {
            "fsl": "12345678CESL321",
            "tui": 12345678
          },
          "related": [],
          "links": [
            {
              "rel": "self",
              "href": "https://apis.enable.net.nz/addresslookup/v1/addresses/12345678CESL321",
              "method": "GET"
            }
          ]
        }
      },
      "FormattedAddress": {
        "type": "object",
        "properties": {
          "line1": {
            "type": "string",
            "description": "Formatted street or postal address.",
            "example": "123B FAKE STREET"
          },
          "line3": {
            "type": "string",
            "description": "This line returns the suburb the address is located in.",
            "example": "ADDINGTON"
          }
        },
        "description": "Formatted address. Address is divided by lines 1 to 4. Used in the Address Lookup Api"
      },
      "StructuredAddress": {
        "type": "object",
        "properties": {
          "streetNumber": {
            "type": "string",
            "description": "Street number",
            "example": "123B"
          },
          "suburb": {
            "type": "string",
            "description": "Suburb",
            "example": "SUBURB1"
          },
          "country": {
            "type": "string",
            "description": "The country the address is located",
            "example": "New Zealand"
          }
        },
        "description": "Detailed structure of the address."
      },
      "Location": {
        "required": [
          "nztmX",
          "nztmY",
          "wgs84Lat",
          "wgs84Lon"
        ],
        "type": "object",
        "properties": {
          "nztmX": {
            "type": "number",
            "description": "Address Location in NZ Transverse Mercator (NZTM2000) projection X coordinate.",
            "example": 12345678.87654321
          },
          "nztmY": {
            "type": "number",
            "description": "Address Location in NZ Transverse Mercator (NZTM2000) projection Y coordinate.",
            "example": 1234567.7654321
          },
          "wgs84Lat": {
            "type": "number",
            "description": "Address Location in World Geodetic system Latitude.",
            "example": -123.123456789
          },
          "wgs84Lon": {
            "type": "number",
            "description": "Address Location in World Geodetic system Longitude.",
            "example": 123.123456789
          }
        },
        "description": "Geographical coordinates of the address."
      },
      "References": {
        "required": [
          "fsl",
          "tui"
        ],
        "type": "object",
        "properties": {
          "fsl": {
            "type": "string",
            "description": "Enables address identifier.",
            "example": "01234567CESLCLF99"
          },
          "tui": {
            "type": "number",
            "description": "Terralink Unique Identifier. Terralink-internal address identifier, which identifies the vendor master source dataset. This code is made up of 8 or 10 digits.",
            "example": 12345678
          }
        },
        "description": "Other identifiers this address may hold, such as aid, PLSAM, TUI and TLC."
      },
      "Link": {
        "required": [
          "href",
          "method",
          "rel"
        ],
        "type": "object",
        "properties": {
          "rel": {
            "type": "string",
            "description": "Link relation. This could either be: \n<ul> \n<li> 'self' - for a self related link </li> \n<li> 'next' - for the next page of results </li>\n<li> 'previous' - for the previous page of results </li>\n</ul>\n",
            "example": "next",
            "enum": [
              "self",
              "next",
              "previous"
            ]
          },
          "href": {
            "type": "string",
            "description": "The hyperlink reference",
            "example": "https://enable.net.nz"
          },
          "method": {
            "type": "string",
            "description": "The HTTP method to reach the hyperlink reference",
            "example": "GET",
            "enum": [
              "GET"
            ]
          }
        },
        "description": "Pagination links that are in a HATEOAS format and follow HATEOAS principles. It is present if the 'page' query parameter is supplied. Otherwise, no pagination information is returned"
      }
    },
    "securitySchemes": {
      "okta-authorizer": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "x-amazon-apigateway-authtype": "oauth2",
        "x-amazon-apigateway-authorizer": {
          "type": "token",
          "authorizerUri": "${stageVariables.OktaLambdaAuthorizerARN}",
          "authorizerCredentials": "${stageVariables.RoleAPIGatewayInvokeOktaTokenVerifierARN}",
          "identityValidationExpression": "Bearer ([A-Z|a-z|0-9|.|_|-])*",
          "authorizerResultTtlInSeconds": 0
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "400 - The request does not meet the Api specification.",
        "headers": {
          "Content-Type": {
            "$ref": "#/components/headers/Content-Type"
          },
          "Content-Length": {
            "$ref": "#/components/headers/Content-Length"
          },
          "Date": {
            "$ref": "#/components/headers/Date"
          },
          "X-Transaction-ID": {
            "$ref": "#/components/headers/X-Transaction-ID"
          },
          "X-Ratelimit-Remaining": {
            "$ref": "#/components/headers/X-Ratelimit-Remaining"
          },
          "X-Ratelimit-Limit": {
            "$ref": "#/components/headers/X-Ratelimit-Limit"
          },
          "X-Ratelimit-Reset": {
            "$ref": "#/components/headers/X-Ratelimit-Reset",
            "schema": {
              "type": "string"
            }
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            },
            "example": {
              "message": "Bad Request",
              "cause": "Required header X-Transaction-ID not specified",
              "code": "None",
              "X-Transaction-ID": "E4AB9237-776C-44BF-B10A-3466CA5A0849"
            }
          }
        }
      },
