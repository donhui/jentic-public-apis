      }
    }
  },
  "paths": {
    "/addresses": {
      "get": {
        "security": [
          {
            "okta-authorizer": []
          }
        ],
        "x-amazon-apigateway-request-validator": "all",
        "x-amazon-apigateway-integration": {
          "httpMethod": "POST",
          "uri": {
            "Fn::Sub": "arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${LambdaAddressByString.Alias}/invocations"
          },
          "passthroughBehavior": "when_no_match",
          "type": "aws_proxy",
          "contentHandling": "CONVERT_TO_TEXT"
        },
        "description": "Searches matching addresses based on partial address string. The end point accepts this partial address string (\u2018q\u2019) and return the Enable Location identifier field (\u2018FSL\u2019).\n\nThis identifier can be used to retrieve prequalification information from the 'Fibre Broadband Availability' Api. The search parameter has a minimum length of 4 characters.  \n\nThe addresses end point supports pagination so the size of the response can be limited by providing \u2018page\u2019 and \u2018pageSize\u2019 query parameters. The addresses end point applies basic fuzzy logic whereby it will correct simple spelling mistakes in its attempt to return the correct address. Some examples of the fuzzy logic are below:\n<table style=\"width:100%\">\n<tr>\n<th>query</th>\n<th colspan=\"2\">Result</th>\n</tr>\n<tr>\n<td>106 wrights</td>\n<td>[106 WRIGHTS ROAD, 106BUS WRIGHTS ROAD]</td>\n</tr>\n<tr>\n<td>106 wright road</td>\n<td>[106 WRIGHTS ROAD, 106BUS WRIGHTS ROAD]</td>\n</tr>\n<tr>\n<td>106 wrught road</td>\n<td>[]</td>\n</tr>\n<tr>\n<td>wrights road</td>\n<td>[1 WRIGHTS ROAD, 7B WRIGHTS ROAD]</td>\n</tr>\n</table>\n<br> Fuzzy logic is not optional, it is applied by default.\n",
        "parameters": [
          {
            "name": "X-Transaction-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "This header contains the access token issued by the Auth API. The format of the header value is \"Bearer TOKEN\".",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "An address search term. Must be a minimum of 4 characters.",
            "required": true,
            "schema": {
              "minLength": 4,
              "type": "string"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The number of records returned. If not specified, defaults to 5. Maximum value is 20",
            "schema": {
              "maximum": 20,
              "minimum": 1,
              "type": "integer",
              "default": 5
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination. If not specified, defaults to 1.",
            "schema": {
              "maximum": 2147483647,
              "minimum": 1,
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "fuzzy",
            "description": "This query parameter is not option but is included to meet industry standards. Fuzzy logic is applied by default.",
            "required": false,
            "in": "query",
            "schema": {
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Content-Type": {
                "$ref": "#/components/headers/Content-Type"
              },
              "Content-Length": {
                "$ref": "#/components/headers/Content-Length"
              },
              "Date": {
                "$ref": "#/components/headers/Date"
              },
              "X-Transaction-ID": {
                "$ref": "#/components/headers/X-Transaction-ID"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "X-Ratelimit-Limit": {
                "$ref": "#/components/headers/X-Ratelimit-Limit"
              },
              "X-Ratelimit-Reset": {
                "$ref": "#/components/headers/X-Ratelimit-Reset"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddressSearchResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
    "/addresses/{id}": {
      "get": {
        "security": [
          {
            "okta-authorizer": []
          }
        ],
        "x-amazon-apigateway-request-validator": "all",
        "x-amazon-apigateway-integration": {
          "uri": {
            "Fn::Sub": "arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${LambdaAddressById.Alias}/invocations"
          },
          "httpMethod": "POST",
          "passthroughBehavior": "when_no_match",
          "type": "aws_proxy",
          "contentHandling": "CONVERT_TO_TEXT"
        },
        "description": "Returns the address details from the provided fsl or tui.",
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "This header contains the access token issued by the Auth API. The format of the header value is \"Bearer TOKEN\".",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Transaction-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The id parameter can be either FSL or TUI depending on the prefix the client provides. \n<br> <br> The endpoint accepts: <ul> \n<li> id = '{FSL}' - Defaults to be an FSL </li> \n<li> id = 'tui:{TUI}' - TUI with the characters 'tui:' prefixed to the front of the id </li>\n<li> id = 'fsl:{FSL}' - FSL with the characters 'fsl:' prefixed to the front of the id </li>\n</ul>\n",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Content-Type": {
                "$ref": "#/components/headers/Content-Type"
              },
              "Content-Length": {
                "$ref": "#/components/headers/Content-Length"
              },
              "Date": {
                "$ref": "#/components/headers/Date"
              },
              "X-Transaction-ID": {
                "$ref": "#/components/headers/X-Transaction-ID"
              },
              "X-Ratelimit-Remaining": {
                "$ref": "#/components/headers/X-Ratelimit-Remaining"
              },
              "X-Ratelimit-Limit": {
                "$ref": "#/components/headers/X-Ratelimit-Limit"
              },
              "X-Ratelimit-Reset": {
                "$ref": "#/components/headers/X-Ratelimit-Reset"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LookupAddressDetail"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
