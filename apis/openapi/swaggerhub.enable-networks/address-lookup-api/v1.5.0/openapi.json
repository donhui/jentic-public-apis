{
  "openapi": "3.0.3",
  "info": {
    "title": "Address Lookup Api",
    "description": "The Address Lookup Api is used to find unique Enable address identifiers (FSL Fibre Service Location) and associated information.\nThe Api has two endpoints which are: \n- addresses - which is used to return a list of addresses\n- addresses/id - which is used to get detailed information about the address. \n\nBefore you can access the production Apis, you need to complete the production onboarding process. \n\nNote, the production URI will be https://apis.enable.net.nz/addresslookup/v1. \n",
    "version": "v1.5.0",
    "termsOfService": "https://api-developer.enable.net.nz/hc/en-nz/articles/360053801514",
    "contact": {
      "email": "apisupport@enable.net.nz"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Enable-Networks/Address-Lookup-API/v1.5.0/swagger.json"
  },
  "x-amazon-apigateway-api-key-source": "AUTHORIZER",
  "x-amazon-apigateway-request-validators": {
    "all": {
      "validateRequestBody": true,
      "validateRequestParameters": true
    }
  },
