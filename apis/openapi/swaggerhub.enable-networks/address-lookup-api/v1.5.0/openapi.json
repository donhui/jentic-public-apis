      }
    },
    "ACCESS_DENIED": {
      "statusCode": 401,
      "responseTemplates": {
        "application/json": "{\n \"message\": \"$context.authorizer.context.error_type\", \n \"cause\": \"$context.authorizer.context.error_message\", \n \"code\": null, \n \"X-Transaction-ID\": \"$input.params('X-Transaction-ID')\" \n }"
      }
    },
    "BAD_REQUEST_PARAMETERS": {
      "statusCode": 400,
      "responseTemplates": {
        "application/json": "{\n \"message\": \"Bad Request\", \n \"cause\": $context.error.messageString, \n \"code\": null, \n \"X-Transaction-ID\": \"$input.params('X-Transaction-ID')\" \n }"
      }
    },
    "BAD_REQUEST_BODY": {
      "statusCode": 400,
      "responseTemplates": {
        "application/json": "{\n \"message\": \"Bad Request\", \n \"cause\": $context.error.messageString, \n \"code\": null, \n \"X-Transaction-ID\": \"$input.params('X-Transaction-ID')\" \n }"
