  "paths": {
    "/proactive/{fsl_id}": {
      "get": {
        "description": "Allows a user to submit an FSL id and receive back the current proactive value for that location.",
        "operationId": "GET_proactive",
        "security": [
          {
            "okta-authorizer": []
          }
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "This header contains the word Bearer followed by an access token issued by Auth Api",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Transaction-ID",
            "in": "header",
            "description": "This is the transaction id provided in the initial request.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fsl_id",
            "in": "path",
            "description": "The fsl_id parameter is Fibre Service Location (FSL) ID",
            "example": "30000657CESLFE8",
            "required": true,
            "schema": {
              "pattern": "^[0-9]{8}[A-Z]{4}[A-Z|0-9]{3}$",
              "type": "string"
            }
          }
        ],
        "x-amazon-apigateway-request-validator": "all",
        "responses": {
          "200": {
            "description": "Proactive value successfully retrieved\n",
            "headers": {
              "Content-Type": {
                "$ref": "#/components/headers/Content-Type"
              },
              "Content-Length": {
                "$ref": "#/components/headers/Content-Length"
              },
              "Date": {
                "$ref": "#/components/headers/Date"
              },
              "X-Transaction-ID": {
                "$ref": "#/components/headers/X-Transaction-ID"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProactiveGet"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        },
        "x-amazon-apigateway-integration": {
          "uri": {
            "Fn::Sub": "arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${LambdaGetProactive.Alias}/invocations"
          },
          "httpMethod": "POST",
          "responses": {
            "default": {
              "statusCode": "200"
            }
          },
          "passthroughBehavior": "when_no_match",
          "type": "aws_proxy"
        }
      },
      "put": {
        "description": "Allows a user to recalculate and update proactive value.",
        "operationId": "PUT_proactive",
        "security": [
          {
            "okta-authorizer": []
          }
        ],
        "parameters": [
          {
            "in": "header",
            "name": "X-Transaction-ID",
            "description": "This is the transaction id provided in the initial request.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "This header contains the access token issued by the Auth API. The format of the header value is \"Bearer TOKEN\".",
            "schema": {
              "type": "string"
            },
            "example": "Bearer 1234"
          },
          {
            "name": "fsl_id",
            "in": "path",
            "description": "The fsl_id parameter is Fibre Service Location (FSL) ID",
            "example": "30000657CESLFE8",
            "required": true,
            "schema": {
              "pattern": "^[0-9]{8}[A-Z]{4}[A-Z|0-9]{3}$",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "primary_incident_type",
            "description": "A type of (\u201cBuild\u201d, \u201cBuild to ONT\u201d,\u201d\u201d Pali Request\u201d, \u201cBuild to ETP\u201d, \u201cBuild to PALI\u201d and \u201cPali Request.",
            "example": "Build",
            "schema": {
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "work_order_type",
            "description": "An order type of (\u201cROW\u201d, \u201cLAR\u201d, \u201cMDU\u201d, \u201cProactive Build\u201d and \u201cSDU\u201d).",
            "example": "ROW",
            "schema": {
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "field_force_status",
            "description": "A status of field force.",
            "example": "Ready to Invoice",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "x-amazon-apigateway-request-validator": "all",
        "responses": {
          "200": {
            "description": "Proactive value successfully updated.\n",
            "headers": {
              "Content-Type": {
                "$ref": "#/components/headers/Content-Type"
              },
              "Content-Length": {
                "$ref": "#/components/headers/Content-Length"
              },
              "Date": {
                "$ref": "#/components/headers/Date"
              },
              "X-Transaction-ID": {
                "$ref": "#/components/headers/X-Transaction-ID"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProactiveUpdate"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        },
        "x-amazon-apigateway-integration": {
          "uri": {
            "Fn::Sub": "arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${LambdaUpdateProactive.Alias}/invocations"
          },
          "httpMethod": "POST",
          "responses": {
            "default": {
              "statusCode": "200"
            }
          },
          "passthroughBehavior": "when_no_match",
          "type": "aws_proxy"
        }
      }
    }
  },
  "components": {
    "headers": {
      "Content-Type": {
        "description": "The media type of the body",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "application/json;charset=UTF-8"
      },
      "Content-Length": {
        "description": "Response length",
        "required": true,
        "schema": {
          "type": "number"
        },
        "example": 3791
      },
      "Date": {
        "description": "Response timestamp",
        "required": true,
        "schema": {
          "type": "string",
          "format": "date"
        },
        "example": "Mon, 08 May 2017 23:56:58 GMT"
      },
      "X-Transaction-ID": {
        "description": "This is the transaction id provided in the initial request.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Version": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "example": "1.2.0"
          }
        }
      },
      "ProactiveUpdate": {
        "type": "object",
        "properties": {
          "fsl_id": {
            "type": "string",
            "description": "The fsl_id field is the Fibre Service Location (FSL) ID, which is the same as the value that a caller passed to the API endpoint as a parameter.",
            "example": "30000000XYZL100"
          },
          "proactive": {
            "type": "string",
            "description": "The proactive filed will contain the updated proactive value, such as PALI, BROW etc, based on the fsl_id passed in, if success.",
            "example": "BROW"
          },
          "message": {
            "type": "string",
            "description": "The returned message will inform the user whether the action is success or fail. If success the API endpoint will return the updated proactive value.",
            "example": "The request has been processed successfully"
          }
        }
      },
      "ProactiveGet": {
        "type": "object",
        "properties": {
          "fsl_id": {
            "type": "string",
            "description": "The fsl_id field is the Fibre Service Location (FSL) ID, which is the same as the value that a caller passed to the API endpoint as a parameter.",
            "example": "30000000XYZL100"
          },
          "proactive": {
            "type": "string",
            "description": "The proactive filed will contain the current proactive value, such as PALI, BROW etc, based on the fsl_id passed in, if success.",
            "example": "BROW"
          },
          "message": {
            "type": "string",
            "description": "The returned message will inform the user whether the fsl_id is valid or not. If success the API endpoint will return the current proactive value.",
            "example": "Valid FSL ID"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "cause": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "X-Transaction-ID": {
            "type": "string"
          }
        }
      },
      "RateLimitError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
