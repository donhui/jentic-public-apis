{
  "openapi": "3.0.3",
  "info": {
    "title": "Kanboard JSON-RPC API",
    "version": "1.0.0",
    "description": "Kanboard is an open-source project management tool using Kanban methodology. The API uses JSON-RPC 2.0 protocol over HTTP POST. All API calls are made to a single endpoint with the method name specified in the request body. This spec documents the JSON-RPC methods as individual OpenAPI operations for discoverability.",
    "x-jentic-source-url": "https://docs.kanboard.org/v1/api/"
  },
  "servers": [
    {
      "url": "https://{instance}",
      "description": "Kanboard instance",
      "variables": {
        "instance": {
          "default": "localhost",
          "description": "Your Kanboard instance hostname"
        }
      }
    }
  ],
  "paths": {
    "/jsonrpc.php": {
      "post": {
        "operationId": "executeJsonRpc",
        "summary": "Execute a JSON-RPC 2.0 method",
        "description": "All Kanboard API calls use this single endpoint with JSON-RPC 2.0 protocol. The method name and parameters are specified in the request body. Available methods include: getVersion, getTimezone, getDefaultTaskColors, getDefaultTaskColor, getColorList, getApplicationRoles, getProjectRoles, createProject, getProjectById, getProjectByName, getProjectByIdentifier, getProjectByEmail, getAllProjects, updateProject, removeProject, enableProject, disableProject, enableProjectPublicAccess, disableProjectPublicAccess, getProjectActivity, getProjectActivities, getBoard, createTask, getTask, getTaskByReference, getAllTasks, getOverdueTasks, getOverdueTasksByProject, updateTask, openTask, closeTask, removeTask, moveTaskPosition, moveTaskToProject, duplicateTaskToProject, searchTasks, createUser, createLdapUser, getUser, getUserByName, getAllUsers, updateUser, removeUser, disableUser, enableUser, isActiveUser, getColumns, getColumn, changeColumnPosition, updateColumn, addColumn, removeColumn, createComment, getComment, getAllComments, updateComment, removeComment, createCategory, getCategory, getAllCategories, updateCategory, removeCategory, createSubtask, getSubtask, getAllSubtasks, updateSubtask, removeSubtask, getActiveSwimlanes, getAllSwimlanes, getSwimlane, getSwimlaneById, getSwimlaneByName, changeSwimlanePosition, updateSwimlane, addSwimlane, removeSwimlane, disableSwimlane, enableSwimlane, getAllTags, getTagsByProject, createTag, updateTag, removeTag, setTaskTags, getTaskTags, createGroup, updateGroup, removeGroup, getGroup, getAllGroups, getMemberGroups, getGroupMembers, addGroupMember, removeGroupMember, isGroupMember, getAllLinks, getOppositeLinkId, getLinkByLabel, getLinkById, createLink, updateLink, removeLink, createTaskLink, updateTaskLink, getTaskLinkById, getAllTaskLinks, removeTaskLink, getExternalTaskLinkTypes, getExternalTaskLinkProviderDependencies, createExternalTaskLink, updateExternalTaskLink, getExternalTaskLinkById, getAllExternalTaskLinks, removeExternalTaskLink, getProjectUsers, getAssignableUsers, addProjectUser, addProjectGroup, removeProjectUser, removeProjectGroup, changeProjectUserRole, changeProjectGroupRole, getProjectUserRole.",
        "tags": [
          "JSON-RPC"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JsonRpcRequest"
              },
              "examples": {
                "getVersion": {
                  "summary": "Get application version",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "getVersion",
                    "id": 1
                  }
                },
                "createProject": {
                  "summary": "Create a new project",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "createProject",
                    "id": 1,
                    "params": {
                      "name": "My Project"
                    }
                  }
                },
                "createTask": {
                  "summary": "Create a new task",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "createTask",
                    "id": 1,
                    "params": {
                      "title": "My Task",
                      "project_id": 1
                    }
                  }
                },
                "getTask": {
                  "summary": "Get a task by ID",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "getTask",
                    "id": 1,
                    "params": {
                      "task_id": 1
                    }
                  }
                },
                "createUser": {
                  "summary": "Create a new user",
                  "value": {
                    "jsonrpc": "2.0",
                    "method": "createUser",
                    "id": 1,
                    "params": {
                      "username": "johndoe",
                      "password": "secret123"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON-RPC response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JsonRpcResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
