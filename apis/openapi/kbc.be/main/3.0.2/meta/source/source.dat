                              "WARNING"
                            ]
                          },
                          "code": {
                            "type": "string",
                            "description": ""
                          },
                          "text": {
                            "maxLength": 512,
                            "type": "string",
                            "description": "Additional explaining text to the TPP."
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "An error response.\nFor the consents we distinct 2 types: invalid and expired ones. The error code is updated to make that distinction.",
            "headers": {
