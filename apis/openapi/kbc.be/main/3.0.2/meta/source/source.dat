  "components": {
    "schemas": {
      "accountDetails": {
        "required": [
          "currency"
        ],
        "type": "object",
        "properties": {
          "resourceId": {
            "maxLength": 35,
            "type": "string",
            "description": "This is the data element to be used in the path when retrieving data from a dedicated account, cp. Section 6.6.3 or Section 6.6.4 below. This shall be filled, if addressable resource are created by the ASPSP on the /accounts or /card-accounts endpoint."
          },
          "iban": {
            "pattern": "^[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}$",
            "type": "string",
            "description": "This data element can be used in the body of the Consent Request Message for retrieving account access consent from this payment account, cp. Section 6.3."
          },
          "currency": {
            "pattern": "^[A-Z]{3}$",
            "type": "string",
            "description": "An ISO 4217 Currency code."
          },
          "name": {
            "maxLength": 35,
            "type": "string",
            "description": "Name of the account given by the bank or the PSU in Online-Banking"
          },
          "product": {
            "maxLength": 35,
            "type": "string",
            "description": "Product Name of the Bank for this account, proprietary definition"
          },
          "cashAccountType": {
            "maxLength": 4,
            "minLength": 1,
            "type": "string",
            "description": "ExternalCashAccountType1Code from ISO 20022"
          },
          "balances": {
            "type": "array",
            "items": {
              "title": "balance",
              "required": [
                "balanceAmount",
                "balanceType"
              ],
              "type": "object",
              "properties": {
                "balanceAmount": {
                  "title": "amount",
                  "type": "object",
                  "properties": {
                    "currency": {
                      "pattern": "^[A-Z]{3}$",
                      "type": "string",
                      "description": "An ISO 4217 Currency code."
                    },
                    "amount": {
                      "type": "string",
                      "description": "The amount given with fractional digits, where fractions must be compliant to the currency definition. Up to 14 significant figures. Negative amounts are signed by minus.\nThe decimal separator is a dot.\nExample: Valid representations for EUR with up to two decimals are:\n* 1056\n* 5768.2\n* -1.50\n* 5877.78"
                    }
                  }
                },
                "balanceType": {
                  "type": "string",
                  "description": "Current possibilities: closingBooked, expected, authorised, openingBooked, interimAvailable, forwardAvailable.\nOnly closingBooked is currently supported by KBC."
                }
              },
              "description": "Balance information"
            }
          },
          "_links": {
            "type": "object",
            "properties": {
              "balances": {
                "type": "string",
                "description": "",
                "format": "uri-reference"
              },
              "transactions": {
                "type": "string",
                "description": "",
                "format": "uri-reference"
              }
            },
            "description": ""
          }
        }
      },
      "accountReport": {
        "title": "accountReport",
        "required": [
          "_links",
          "booked"
        ],
        "type": "object",
        "properties": {
          "booked": {
            "type": "array",
            "items": {
              "title": "transaction",
              "required": [
                "transactionAmount"
              ],
              "type": "object",
              "properties": {
                "transactionId": {
                  "type": "string"
                },
                "bookingDate": {
                  "type": "string",
                  "description": "The Date when an entry is posted to an account on the ASPSPs books.",
                  "format": "date"
                },
                "valueDate": {
                  "type": "string",
                  "description": "The Date at which assets become available to the account owner in case of a credit",
                  "format": "date"
                },
                "transactionAmount": {
                  "title": "amount",
                  "type": "object",
                  "properties": {
                    "currency": {
                      "pattern": "^[A-Z]{3}$",
                      "type": "string",
                      "description": "An ISO 4217 Currency code."
                    },
                    "amount": {
                      "type": "string",
                      "description": "The amount given with fractional digits, where fractions must be compliant to the currency definition. Up to 14 significant figures. Negative amounts are signed by minus.\nThe decimal separator is a dot.\nExample: Valid representations for EUR with up to two decimals are:\n* 1056\n* 5768.2\n* -1.50\n* 5877.78"
                    }
                  }
                },
                "exchangeRate": {
                  "type": "array",
                  "items": {
                    "title": "exchangeRate",
                    "required": [
                      "currencyFrom",
                      "currencyTo",
                      "rateDate",
                      "rateFrom",
                      "rateTo"
                    ],
                    "type": "object",
                    "properties": {
                      "currencyFrom": {
                        "pattern": "^[A-Z]{3}$",
                        "type": "string",
                        "description": "An ISO 4217 Currency code."
                      },
                      "rateFrom": {
                        "type": "string",
                        "description": ""
                      },
                      "currencyTo": {
                        "pattern": "^[A-Z]{3}$",
                        "type": "string",
                        "description": "An ISO 4217 Currency code."
                      },
                      "rateTo": {
                        "type": "string",
                        "description": ""
                      },
                      "rateDate": {
                        "type": "string",
                        "description": "",
                        "format": "date"
                      }
                    }
                  }
                },
                "creditorName": {
                  "maxLength": 70,
                  "type": "string",
                  "description": "Name  of the creditor if a \u201cdebited\u201d transaction"
                },
                "creditorAccount": {
                  "title": "accountReference",
                  "required": [
                    "iban"
                  ],
                  "type": "object",
                  "properties": {
                    "iban": {
                      "pattern": "^[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}$",
                      "type": "string"
                    },
                    "currency": {
                      "pattern": "^[A-Z]{3}$",
                      "type": "string",
                      "description": "An ISO 4217 Currency code."
                    }
                  },
                  "description": "Account identification"
                },
                "debtorName": {
                  "maxLength": 70,
                  "type": "string",
                  "description": "Name  of the debtor if a \"credited\" transaction"
                },
                "debtorAccount": {
                  "title": "accountReference",
                  "required": [
                    "iban"
                  ],
                  "type": "object",
                  "properties": {
                    "iban": {
                      "pattern": "^[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}$",
