{
  "openapi": "3.0.3",
  "info": {
    "title": "KBC/CBC/KBC Brussels PSD2 API Account Information Services",
    "description": "PSD2 requires banks to share certain account information via AISPs at the specific request of the account holders. It also places specific requirements on these AISPs to ensure the security of those account holders. Any specifications according to the optional request parameters of the Berlin Group NextGenPSD2 Framework Implementation Guidelines V1.1 that are not mentioned in this document should be considered as unsupported. However, in most cases sending such parameters will not lead to any errors. KBC Bank and CBC Banque did not apply for an exception with the National Bank of Belgium and do not possess an exemption from the obligation to set up the contingency mechanism described in article 33 paragraph 4 of the RTS.",
    "contact": {
      "name": "PSD2 API Support",
      "url": "https://developer.kbc.be/",
      "email": "developer@kbc.be"
    },
    "version": "3.0.2",
    "x-jentic-source-url": "https://developer.kbc.be/system/files/api-ref-files/2023-07/swagger%20AIS%203_2_0.json"
  },
  "servers": [
    {
      "url": "https://psd2.api.{company}.be/psd2/v2",
      "description": "KBC/CBC/KBC Brussels PSD2 API server",
      "variables": {
        "company": {
          "default": "kbc",
          "enum": [
            "kbc",
            "cbc",
            "kbcbrussels"
          ]
        }
      }
    }
  ],
  "paths": {
    "/consents": {
      "post": {
        "tags": [
          "Consents"
        ],
        "summary": "Account Information Consent Request",
        "description": "Create a consent resource, defining access rights to dedicated accounts of a given PSU-ID. These accounts are addressed explicitly in the method as parameters as a core function.",
        "operationId": "POST_consents",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer token containing TPP client id, if applicable (portal registered)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "ID of the request, unique to the call, as determined by the initiating party.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "TPP-Redirect-URI",
            "in": "header",
            "description": "URI of the TPP, where the transaction flow shall be redirected to after a Redirect.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "PSU-IP-Address",
            "in": "header",
            "description": "The forwarded IP Address header field consists of the corresponding HTTP request IP Address field between PSU and TPP.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "ipv4"
            }
          },
          {
            "name": "PSU-IP-Port",
            "in": "header",
            "description": "The forwarded IP Port header field consists of the corresponding HTTP request IP Port field between PSU and TPP, if available.",
            "schema": {
              "type": "string",
              "format": ""
            }
          },
          {
            "name": "PSU-Accept",
            "in": "header",
            "description": "The forwarded IP Accept header fields consist of the corresponding HTTP request Accept header fields between PSU and TPP, if available.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PSU-Accept-Charset",
            "in": "header",
            "description": "See PSU-Accept",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PSU-Accept-Encoding",
            "in": "header",
            "description": "See PSU-Accept",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PSU-Accept-Language",
            "in": "header",
            "description": "See PSU-Accept",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PSU-User-Agent",
            "in": "header",
            "description": "The forwarded Agent header field of the HTTP request between PSU and TPP, if available.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PSU-Http-Method",
            "in": "header",
            "description": "HTTP method used at the PSU \u2013 TPP interface, if available.",
            "schema": {
              "type": "string",
              "enum": [
                "GET",
                "POST",
                "PUT",
                "PATCH",
                "DELETE"
              ]
            }
          },
          {
            "name": "PSU-Device-ID",
            "in": "header",
            "description": "UUID (Universally Unique Identifier) for a device, which is used by the PSU, if available.\nUUID identifies either a device or a device dependant application installation. In case of an installation identification this ID need to be unaltered until removal from device.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "PSU-Geo-Location",
            "in": "header",
            "description": "The forwarded Geo Location of the corresponding HTTP request between PSU and TPP if available.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "access",
                  "combinedServiceIndicator",
                  "frequencyPerDay",
                  "recurringIndicator",
                  "validUntil"
                ],
                "type": "object",
                "properties": {
                  "access": {
                    "type": "object",
                    "properties": {
                      "balances": {
                        "type": "array",
                        "items": {
                          "title": "accountReference",
                          "type": "object",
                          "properties": {
                            "iban": {
                              "pattern": "^[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}$",
                              "type": "string"
                            },
                            "currency": {
                              "pattern": "^[A-Z]{3}$",
                              "type": "string",
                              "description": "An ISO 4217 Currency code."
                            }
                          },
                          "description": "Account identification"
                        }
                      },
                      "transactions": {
                        "type": "array",
                        "items": {
                          "title": "accountReference",
                          "type": "object",
                          "properties": {
                            "iban": {
                              "pattern": "^[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}$",
                              "type": "string"
                            },
                            "currency": {
                              "pattern": "^[A-Z]{3}$",
                              "type": "string",
                              "description": "An ISO 4217 Currency code."
                            }
                          },
                          "description": "Account identification"
                        }
                      }
                    },
                    "description": "For v2.0.0, KBC only supports none or one single IBAN in Balances, Transactions or Both.\nNot supported: different IBANs in balances vs transactions and other access types (allPsd2 and allAvailable)."
                  },
                  "recurringIndicator": {
                    "type": "boolean"
                  },
                  "validUntil": {
                    "type": "string",
                    "format": "date"
                  },
                  "frequencyPerDay": {
                    "maximum": 4,
                    "minimum": 1,
                    "exclusiveMinimum": true,
                    "type": "integer",
                    "description": "This field indicates the requested maximum frequency for access to account without PSU involvement per day.",
                    "example": 4
                  },
                  "combinedServiceIndicator": {
                    "type": "boolean",
                    "description": "Only false is supported at KBC."
                  }
                }
              }
            }
          },
          "required": false
        },
        "responses": {
          "201": {
            "description": "A Successfull consent request is created",
            "headers": {
              "X-Request-ID": {
                "description": "ID of the request, unique to the call, as determined by the initiating party.",
                "schema": {
                  "type": "string"
                }
              },
              "ASPSP-SCA-Approach": {
                "description": "KBC will only support \"REDIRECT\"",
                "schema": {
                  "type": "string",
                  "enum": [
                    "EMBEDDED",
                    "DECOUPLED",
                    "REDIRECT"
                  ]
                }
              },
              "Location": {
                "description": "Location of the created resource",
                "schema": {
                  "type": "string",
                  "format": "uri-reference"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "required": [
                    "_links",
                    "consentStatus"
                  ],
                  "type": "object",
                  "properties": {
                    "consentStatus": {
                      "type": "string",
                      "description": "Authentication status of the consent",
                      "enum": [
                        "received",
                        "rejected",
                        "valid",
                        "revokedByPsu",
                        "expired",
                        "terminatedByTpp"
                      ]
                    },
                    "consentId": {
                      "type": "string",
                      "description": "Identification of the consent resource as it is used in the API structure"
                    },
                    "_links": {
                      "type": "object",
                      "properties": {},
                      "description": ""
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "An error response",
            "headers": {
              "X-Request-ID": {
                "description": "ID of the request, unique to the call, as determined by the initiating party.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "required": [
                    "tppMessages"
                  ],
                  "type": "object",
                  "properties": {
                    "tppMessages": {
                      "type": "array",
                      "items": {
                        "title": "tppMessageInformation",
                        "required": [
                          "category",
                          "code"
                        ],
                        "type": "object",
                        "properties": {
                          "category": {
                            "type": "string",
                            "description": "",
                            "enum": [
                              "ERROR",
                              "WARNING"
                            ]
                          },
                          "code": {
                            "type": "string",
                            "description": ""
                          },
                          "text": {
                            "maxLength": 512,
                            "type": "string",
                            "description": "Additional explaining text to the TPP."
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
