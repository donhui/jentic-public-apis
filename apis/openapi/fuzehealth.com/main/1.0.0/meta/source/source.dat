{
  "openapi": "3.0.3",
  "info": {
    "title": "FuzeRx API",
    "description": "The FuzeRx API by Fuze Health provides patient management, prescription management, transfer requests, direct transfers, and webhook event capabilities for pharmacy operations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://rxdocs.fuzehealth.com/index.html"
  },
  "servers": [
    {
      "url": "https://rxapi.fuzehealth.com/v1",
      "description": "Production"
    },
    {
      "url": "https://rxapi.sandbox.fuzehealth.com/v1",
      "description": "Sandbox"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Patient Management",
      "description": "Create, update, search, and retrieve patients and their prescriptions"
    },
    {
      "name": "Prescription Management",
      "description": "Retrieve prescription details"
    },
    {
      "name": "Transfer Requests",
      "description": "Create, list, and retrieve transfer requests"
    },
    {
      "name": "Direct Transfer",
      "description": "Create direct prescription transfers"
    },
    {
      "name": "Webhook Events",
      "description": "Retrieve webhook event logs"
    }
  ],
  "paths": {
    "/patient": {
      "put": {
        "tags": ["Patient Management"],
        "summary": "Create a new patient",
        "operationId": "createPatient",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePatientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patient created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePatientResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Patient Management"],
        "summary": "Search for a patient",
        "operationId": "searchPatient",
        "parameters": [
          {
            "name": "first_name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Patient first name"
          },
          {
            "name": "last_name",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Patient last name"
          },
          {
            "name": "dob",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Patient date of birth"
          },
          {
            "name": "gender",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Patient gender"
          },
          {
            "name": "zip",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Patient zip code"
          }
        ],
        "responses": {
          "200": {
            "description": "Patient found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Patient not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/patient/{patient_token}": {
      "post": {
        "tags": ["Patient Management"],
        "summary": "Update an existing patient",
        "operationId": "updatePatient",
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique patient token"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePatientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patient updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdatePatientResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Patient not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Patient Management"],
        "summary": "Get a patient by token",
        "operationId": "getPatient",
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique patient token"
          }
        ],
        "responses": {
          "200": {
            "description": "Patient details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patient"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Patient not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/patient/{patient_token}/prescriptions": {
      "get": {
        "tags": ["Patient Management"],
        "summary": "Get prescriptions for a patient",
        "operationId": "getPatientPrescriptions",
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique patient token"
          }
        ],
        "responses": {
          "200": {
            "description": "List of prescriptions for the patient",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Prescription"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Patient not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/prescription/{prescription_token}": {
      "get": {
        "tags": ["Prescription Management"],
        "summary": "Get prescription details",
        "operationId": "getPrescription",
        "parameters": [
          {
            "name": "prescription_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique prescription token"
          }
        ],
        "responses": {
          "200": {
            "description": "Prescription details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Prescription"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Prescription not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transfer_request": {
      "post": {
        "tags": ["Transfer Requests"],
        "summary": "Create a transfer request",
        "operationId": "createTransferRequest",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTransferRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer request created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTransferResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Transfer Requests"],
        "summary": "List transfer requests",
        "operationId": "listTransferRequests",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page number for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "List of transfer requests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TransferRequest"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transfer_request/{transfer_token}": {
      "get": {
        "tags": ["Transfer Requests"],
        "summary": "Get a transfer request by token",
        "operationId": "getTransferRequest",
        "parameters": [
          {
            "name": "transfer_token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique transfer token"
          }
        ],
        "responses": {
          "200": {
            "description": "Transfer request details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferRequest"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Transfer request not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/direct_transfer": {
      "post": {
        "tags": ["Direct Transfer"],
        "summary": "Create a direct transfer (v1)",
        "operationId": "createDirectTransfer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDirectTransferV1Request"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Direct transfer created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DirectTransferResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/direct_transfer": {
      "post": {
        "tags": ["Direct Transfer"],
        "summary": "Create a direct transfer (v2)",
        "operationId": "createDirectTransferV2",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDirectTransferV2Request"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Direct transfer accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DirectTransferResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webhook_events/{webhook_type}": {
      "get": {
        "tags": ["Webhook Events"],
        "summary": "Get webhook events by type",
        "operationId": "getWebhookEvents",
        "parameters": [
          {
            "name": "webhook_type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Type of webhook event to retrieve"
          },
          {
            "name": "timestamp",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by timestamp, supports comparison operators"
          },
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by event ID, supports comparison operators"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by status, supports comparison operators"
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookEventsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key authentication. Provide as: ApiKey [YOUR API KEY]"
      }
    },
    "schemas": {
      "Address": {
        "type": "object",
        "properties": {
          "street1": {
            "type": "string",
            "description": "Street address line 1"
          },
          "street2": {
            "type": "string",
            "description": "Street address line 2"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "state": {
            "type": "string",
            "description": "State"
          },
          "zip": {
            "type": "string",
            "description": "ZIP code"
          }
        }
      },
      "Patient": {
        "type": "object",
        "properties": {
          "patient_token": {
            "type": "string",
            "description": "Unique patient token"
          },
          "first_name": {
            "type": "string",
            "description": "Patient first name"
          },
          "last_name": {
            "type": "string",
            "description": "Patient last name"
          },
          "dob": {
            "type": "string",
            "description": "Date of birth"
          },
          "gender": {
            "type": "string",
            "description": "Patient gender"
          },
          "ssn": {
            "type": "string",
            "description": "Social security number"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "email": {
            "type": "string",
            "description": "Email address"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "language_preference": {
            "type": "string",
            "description": "Preferred language"
          },
          "species": {
            "type": "string",
            "description": "Species (for veterinary use)"
          }
        }
      },
      "CreatePatientRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "dob",
          "gender"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "description": "Patient first name"
          },
          "last_name": {
            "type": "string",
            "description": "Patient last name"
          },
          "dob": {
            "type": "string",
            "description": "Date of birth"
          },
          "gender": {
            "type": "string",
            "description": "Patient gender"
          },
          "ssn": {
            "type": "string",
            "description": "Social security number"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "email": {
            "type": "string",
            "description": "Email address"
          },
          "street1": {
            "type": "string",
            "description": "Street address line 1"
          },
          "street2": {
            "type": "string",
            "description": "Street address line 2"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "state": {
            "type": "string",
            "description": "State"
          },
          "zip": {
            "type": "string",
            "description": "ZIP code"
          },
          "language_preference": {
            "type": "string",
            "description": "Preferred language"
          },
          "species": {
            "type": "string",
            "description": "Species (for veterinary use)"
          }
        }
      },
      "CreatePatientResponse": {
        "type": "object",
        "properties": {
          "patient_token": {
            "type": "string",
            "description": "Unique patient token for the newly created patient"
          }
        }
      },
      "UpdatePatientRequest": {
        "type": "object",
        "properties": {
          "ssn": {
            "type": "string",
            "description": "Social security number"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "email": {
            "type": "string",
            "description": "Email address"
          },
          "street1": {
            "type": "string",
            "description": "Street address line 1"
          },
          "street2": {
            "type": "string",
            "description": "Street address line 2"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "state": {
            "type": "string",
            "description": "State"
          },
          "zip": {
            "type": "string",
            "description": "ZIP code"
          },
          "language_preference": {
            "type": "string",
            "description": "Preferred language"
          }
        }
      },
      "UpdatePatientResponse": {
        "type": "object",
        "properties": {
          "patient_token": {
            "type": "string",
            "description": "Unique patient token"
          },
          "timestamp": {
            "type": "string",
            "description": "Timestamp of the update"
          },
          "status": {
            "type": "string",
            "description": "Status of the update operation"
          },
          "details": {
            "type": "string",
            "description": "Additional details about the update"
          }
        }
      },
      "Prescription": {
        "type": "object",
        "properties": {
          "prescription_token": {
            "type": "string",
            "description": "Unique prescription token"
          },
          "patient_token": {
            "type": "string",
            "description": "Associated patient token"
          },
          "medication_name": {
            "type": "string",
            "description": "Name of the medication"
          },
          "dosage": {
            "type": "string",
            "description": "Dosage instructions"
          },
          "quantity": {
            "type": "string",
            "description": "Quantity prescribed"
          },
          "refills": {
            "type": "integer",
            "description": "Number of refills remaining"
          },
          "prescriber_name": {
            "type": "string",
            "description": "Name of the prescriber"
          },
          "status": {
            "type": "string",
            "description": "Prescription status"
          },
          "date_written": {
            "type": "string",
            "description": "Date the prescription was written"
          }
        }
      },
      "TransferMedication": {
        "type": "object",
        "properties": {
          "medication_name": {
            "type": "string",
            "description": "Name of the medication to transfer"
          }
        }
      },
      "CreateTransferRequest": {
        "type": "object",
        "required": [
          "patient_token",
          "pharmacy_name",
          "pharmacy_phone"
        ],
        "properties": {
          "patient_token": {
            "type": "string",
            "description": "Unique patient token"
          },
          "pharmacy_name": {
            "type": "string",
            "description": "Name of the originating pharmacy"
          },
          "pharmacy_phone": {
            "type": "string",
            "description": "Phone number of the originating pharmacy"
          },
          "prescriber_name": {
            "type": "string",
            "description": "Name of the prescriber"
          },
          "medications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransferMedication"
            },
            "description": "List of medications to transfer"
          }
        }
      },
      "CreateTransferResponse": {
        "type": "object",
        "properties": {
