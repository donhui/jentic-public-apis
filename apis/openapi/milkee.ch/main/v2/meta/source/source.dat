{
  "openapi": "3.0.3",
  "info": {
    "title": "MILKEE API",
    "description": "MILKEE is an all-in-one accounting tool for Swiss freelancers and small businesses. This REST API provides programmatic access to manage bookings, accounts, contacts, customers, quotes, products, projects, invoices, tax rates, tags, tasks, and time tracking.",
    "version": "v2",
    "contact": {
      "email": "support@milkee.ch"
    },
    "x-jentic-source-url": "https://apidocs.milkee.ch/"
  },
  "servers": [
    {
      "url": "https://app.milkee.ch/api/v2",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Buchungen",
      "description": "Bookings/transactions management"
    },
    {
      "name": "ImportBuchungen",
      "description": "Import bookings from external sources"
    },
    {
      "name": "Konten",
      "description": "Account management"
    },
    {
      "name": "Kontakte",
      "description": "Contact management"
    },
    {
      "name": "Kunden",
      "description": "Customer management"
    },
    {
      "name": "Offerten",
      "description": "Quote/offer management"
    },
    {
      "name": "Produkte",
      "description": "Product management"
    },
    {
      "name": "Projekte",
      "description": "Project management"
    },
    {
      "name": "Rechnungen",
      "description": "Invoice management"
    },
    {
      "name": "Steuersaetze",
      "description": "Tax rate management"
    },
    {
      "name": "Tags",
      "description": "Tag management"
    },
    {
      "name": "Tasks",
      "description": "Task management"
    },
    {
      "name": "Zeiterfassung",
      "description": "Time tracking"
    }
  ],
  "paths": {
    "/buchungen": {
      "get": {
        "operationId": "listBuchungen",
        "summary": "List bookings",
        "description": "Retrieve a list of all bookings/transactions.",
        "tags": ["Buchungen"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page number for pagination"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of items per page"
          }
        ],
        "responses": {
          "200": {
            "description": "List of bookings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuchungListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing Bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createBuchung",
        "summary": "Create a booking",
        "description": "Create a new booking/transaction.",
        "tags": ["Buchungen"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BuchungInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Booking created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Buchung"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/buchungen/{id}": {
      "get": {
        "operationId": "getBuchung",
        "summary": "Get a booking",
        "description": "Retrieve a specific booking by ID.",
        "tags": ["Buchungen"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Booking ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Booking details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Buchung"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateBuchung",
        "summary": "Update a booking",
        "description": "Update an existing booking.",
        "tags": ["Buchungen"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Booking ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BuchungInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Booking updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Buchung"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteBuchung",
        "summary": "Delete a booking",
        "description": "Delete a booking by ID.",
        "tags": ["Buchungen"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Booking ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Booking deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
