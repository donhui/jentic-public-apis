{
  "openapi": "3.0.3",
  "info": {
    "title": "Instacart Connect Fulfillment Last Mile Delivery API",
    "description": "API for implementing last mile delivery workflows via Instacart Connect, including finding stores, validating addresses, managing time slots, and creating delivery orders.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://docs.instacart.com/connect/fulfillment_guide/tutorials/implement_last_mile_delivery/"
  },
  "servers": [
    {
      "url": "https://{instacart_domain}",
      "description": "Instacart Connect server",
      "variables": {
        "instacart_domain": {
          "default": "connect.instacart.com",
          "description": "Your assigned Instacart domain"
        }
      }
    }
  ],
  "paths": {
    "/v2/fulfillment/lastmile/stores/": {
      "post": {
        "operationId": "findStores",
        "summary": "Find stores offering last mile delivery near an address",
        "tags": [
          "Stores"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindStoresRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of stores near the address",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindStoresResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/fulfillment/lastmile/validate_address": {
      "post": {
        "operationId": "validateAddressAndCreateUser",
        "summary": "Create a Connect user account and validate the customer's address",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateAddressRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address validated and user created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateAddressResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request or user already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/fulfillment/lastmile/service_options": {
      "post": {
        "operationId": "listServiceOptions",
        "summary": "List available delivery time slots",
        "tags": [
          "Service Options"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ServiceOptionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of available time slots",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceOptionsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/fulfillment/lastmile/users/{user_id}/service_options/{service_option_id}/reserve": {
      "post": {
        "operationId": "reserveTimeSlot",
        "summary": "Reserve a delivery time slot for 10 minutes",
        "tags": [
          "Service Options"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "description": "The Connect user ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "service_option_id",
            "in": "path",
            "required": true,
            "description": "The service option (time slot) ID to reserve",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Time slot reserved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReserveTimeSlotResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/fulfillment/lastmile/users/{user_id}/orders": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create a last mile delivery order",
        "tags": [
          "Orders"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "description": "The Connect user ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token generated via Instacart Connect authentication"
      }
    },
    "schemas": {
      "FindStoresRequest": {
        "type": "object",
        "required": [
          "find_by"
        ],
        "properties": {
          "find_by": {
            "type": "object",
            "properties": {
              "address_line_1": {
                "type": "string",
                "description": "Street address"
              },
              "postal_code": {
                "type": "string",
                "description": "Postal code"
              }
            }
          }
        }
      },
      "FindStoresResponse": {
        "type": "object",
        "properties": {
          "stores": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Store"
            }
          },
          "is_partial": {
            "type": "boolean"
          }
        }
      },
      "Store": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "location_code": {
            "type": "string"
          },
          "flags": {
            "type": "object",
            "properties": {
              "alcohol": {
                "type": "boolean"
              },
              "pickup": {
                "type": "boolean"
              },
              "pickup_only": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "ValidateAddressRequest": {
        "type": "object",
        "required": [
          "address_line_1",
          "postal_code",
          "user_id"
        ],
        "properties": {
          "address_line_1": {
            "type": "string",
            "description": "Street address"
          },
          "postal_code": {
            "type": "string",
            "description": "Postal code"
          },
          "user_id": {
            "type": "string",
            "description": "Unique user ID for the customer"
          }
        }
      },
      "ValidateAddressResponse": {
        "type": "object",
        "properties": {
          "address": {
            "type": "object",
            "properties": {
              "address_line_1": {
                "type": "string"
              },
              "postal_code": {
                "type": "string"
              }
            }
          },
          "user_id": {
            "type": "string"
          }
        }
      },
      "ServiceOptionsRequest": {
        "type": "object",
        "required": [
          "postal_code",
          "cart_total_cents",
          "items_count"
        ],
        "properties": {
          "postal_code": {
            "type": "string",
            "description": "Customer postal code"
          },
          "cart_total_cents": {
            "type": "integer",
            "description": "Cart total in cents"
          },
          "items_count": {
            "type": "integer",
            "description": "Number of items in cart"
          }
        }
      },
      "ServiceOptionsResponse": {
        "type": "object",
        "properties": {
          "service_options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ServiceOption"
            }
          }
        }
      },
      "ServiceOption": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "window": {
            "type": "object",
            "properties": {
              "immediate_hour": {
                "type": "integer"
              },
              "start_at": {
                "type": "string",
                "format": "date-time"
              },
              "end_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "availability": {
            "type": "object",
            "properties": {
              "available": {
                "type": "boolean"
              },
              "reasons": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "item_codes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ReserveTimeSlotResponse": {
        "type": "object",
        "properties": {
          "service_option_hold": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "expires_at": {
                "type": "string",
                "format": "date-time"
              },
              "service_option": {
                "$ref": "#/components/schemas/ServiceOption"
              }
            }
          }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": [
          "order_id",
          "service_option_hold_id",
          "location_code",
          "address"
        ],
        "properties": {
          "order_id": {
            "type": "string",
            "description": "Retailer-generated order ID"
          },
          "service_option_hold_id": {
            "type": "string",
            "description": "ID of the reserved time slot"
          },
          "location_code": {
            "type": "string",
            "description": "Store location code"
          },
          "locale": {
            "type": "string",
            "description": "Locale code (e.g., en-US)"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "user_phone": {
            "type": "string"
          },
          "initial_tip_cents": {
            "type": "integer"
          },
          "items_count": {
            "type": "integer"
          },
          "bags_count": {
            "type": "integer"
          },
          "items_weight": {
            "type": "number"
          },
          "cart_total": {
            "type": "integer",
            "description": "Cart total in cents"
          },
          "alcoholic": {
            "type": "boolean"
          },
          "leave_unattended": {
            "type": "boolean"
          },
          "special_instructions": {
            "type": "string"
          },
          "address": {
            "type": "object",
            "required": [
              "address_line_1",
              "postal_code"
            ],
            "properties": {
              "address_line_1": {
                "type": "string"
              },
              "postal_code": {
                "type": "string"
              }
            }
          }
        }
      },
      "CreateOrderResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "order_url": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "cancellation_reason": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "fulfillment_details": {
            "type": "object",
            "properties": {
              "store_location": {
                "type": "string"
              },
              "window_starts_at": {
                "type": "string",
                "format": "date-time"
              },
              "window_ends_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "error_description": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Stores",
      "description": "Find store locations offering last mile delivery"
    },
    {
      "name": "Users",
      "description": "Manage Connect user accounts and validate addresses"
    },
    {
      "name": "Service Options",
      "description": "Manage delivery time slots"
    },
    {
      "name": "Orders",
      "description": "Create and manage last mile delivery orders"
    }
  ]
}