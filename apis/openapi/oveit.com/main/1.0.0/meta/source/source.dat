{
  "openapi": "3.0.3",
  "info": {
    "title": "Oveit API",
    "description": "Oveit simplifies event registration, offering automated processes, data-driven insights, and CRM integration to improve attendee experience.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://l.oveit.com/api-documentation/tickets/"
  },
  "servers": [
    {
      "url": "https://l.oveit.com/api"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Login and session management"
    },
    {
      "name": "Events",
      "description": "Event management"
    },
    {
      "name": "Tickets",
      "description": "Ticket operations"
    },
    {
      "name": "Attendees",
      "description": "Attendee management"
    },
    {
      "name": "RFID",
      "description": "RFID tag operations"
    }
  ],
  "paths": {
    "/seller/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Authenticate user",
        "operationId": "sellerLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid credentials"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/seller/recover_password": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Recover password",
        "operationId": "recoverPassword",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password recovery email sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/seller/events": {
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "List events",
        "operationId": "listEvents",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/events/tickets": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "summary": "List event tickets",
        "operationId": "listEventTickets",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of tickets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/checkin": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "summary": "Check in ticket",
        "operationId": "checkinTicket",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "ticket_code": {
                    "type": "string"
                  },
                  "rfid_code": {
                    "type": "string"
                  },
                  "event_id": {
                    "type": "string"
                  },
                  "ticket_type_id": {
                    "type": "string"
                  },
                  "addon_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Check-in result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckinResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/scan": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "summary": "Scan ticket",
        "operationId": "scanTicket",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "ticket_code": {
                    "type": "string"
                  },
                  "rfid_code": {
                    "type": "string"
                  },
                  "event_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TicketScanResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/enable_addon": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "summary": "Enable unbundled addon",
        "operationId": "enableAddon",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "ticket_code",
                  "addon_id",
                  "uses"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "ticket_code": {
                    "type": "string"
                  },
                  "addon_id": {
                    "type": "string"
                  },
                  "uses": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Addon enabled"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/disable_addon": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "summary": "Disable unbundled addon",
        "operationId": "disableAddon",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "ticket_code",
                  "addon_id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "ticket_code": {
                    "type": "string"
                  },
                  "addon_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Addon disabled"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/import": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "summary": "Import tickets",
        "operationId": "importTickets",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "attendees": {
                    "type": "array",
                    "maxItems": 5000,
                    "items": {
                      "$ref": "#/components/schemas/ImportAttendee"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tickets imported"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/events/attendees": {
      "post": {
        "tags": [
          "Attendees"
        ],
        "summary": "List attendees",
        "operationId": "listAttendees",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "since": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of attendees",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttendeesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/attendees/download_file": {
      "post": {
        "tags": [
          "Attendees"
        ],
        "summary": "Download attendee file",
        "operationId": "downloadAttendeeFile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "event_id",
                  "ticket_code",
                  "id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "event_id": {
                    "type": "string"
                  },
                  "ticket_code": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File data",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/rfid/pair": {
      "post": {
        "tags": [
          "RFID"
        ],
        "summary": "Pair RFID tag with ticket",
        "operationId": "pairRfid",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "ticket_code",
                  "rfid_code"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "ticket_code": {
                    "type": "string"
                  },
                  "rfid_code": {
                    "type": "string"
                  },
                  "event_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "RFID paired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "OkResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "type": "object"
          },
          "expires_at": {
            "type": "string"
          }
        }
      },
      "EventsResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "starts_at": {
            "type": "string",
            "nullable": true
          },
          "location": {
            "type": "string"
          },
          "tickets": {
            "type": "integer"
          },
          "tickets_checked_in": {
            "type": "integer"
          },
          "ticket_types": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TicketType"
            }
          }
        }
      },
      "TicketType": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "string"
          },
          "addons": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "TicketsResponse": {
        "type": "object",
        "properties": {
          "tickets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Ticket"
            }
          }
        }
      },
      "Ticket": {
        "type": "object",
        "properties": {
          "ticket_code": {
            "type": "string"
          },
          "ticket_type_id": {
            "type": "string"
          },
          "checked_in": {
            "type": "boolean"
          }
        }
      },
      "CheckinResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "ticket": {
            "type": "object"
          },
          "event": {
            "type": "object"
          },
          "order": {
            "type": "object"
          },
          "attendee": {
            "type": "object"
          }
        }
      },
      "TicketScanResponse": {
        "type": "object",
        "properties": {
          "ticket": {
            "type": "object"
          },
          "event": {
            "type": "object"
          }
        }
      },
      "ImportAttendee": {
        "type": "object",
        "required": [
          "ticket_type_id",
          "ticket_code"
        ],
        "properties": {
          "ticket_type_id": {
            "type": "string"
          },
          "ticket_code": {
            "type": "string"
          }
        }
      },
      "AttendeesResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "attendees": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}