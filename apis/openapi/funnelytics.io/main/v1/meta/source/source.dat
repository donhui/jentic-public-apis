  "info": {
    "title": "Funnelytics Event Processor 2.0",
    "description": "## Funnelytics Event Processor\n      \n      ### Overview\n      Every request requires headers: `X-API-KEY` and `Content-Type`. These headers are required regardless of the method type (GET, POST, PUT, DELETE, PATCH) used.\n      * The `Content-Type` describes the data format you are transmitting.\n      * The `X-API-KEY` header is where you supply the access token. Application use API Keys for authorization.\n      * !!! Notice that Project UUID should be passed as `X-PROJECT-ID` in header for each request.\n      \n      ### Rules\n      \n      * For successful data processing, please use `session` and `email` keys for session id and email respectively.\n      * To send multiple purchases to a standard webhook route, use the `purchase_data` key in which you list the data for each purchase\n      * Optional parameter `dateTime` added to specify the date of event. Date can be passed in ISO-8601 format.",
    "version": "v1",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "https://events.funnelytics.io",
      "description": "Production"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {}
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "x-jentic-source-url": "https://events.funnelytics.io/api/doc"
