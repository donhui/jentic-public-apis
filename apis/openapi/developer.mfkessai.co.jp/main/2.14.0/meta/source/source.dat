{
  "openapi": "3.0.3",
  "info": {
    "contact": {
      "email": "api.support@mfkessai.co.jp",
      "name": "Support Center",
      "url": "https://support.mfkessai.co.jp/hc/ja"
    },
    "description": "Money Forward Kessai REST API",
    "license": {
      "name": ""
    },
    "termsOfService": "https://corp.mfkessai.co.jp/images/terms/mfkessai.pdf",
    "title": "Money Forward Kessai API v2",
    "version": "2.14.0",
    "x-jentic-source-url": "https://developer.mfkessai.co.jp/docs/v2/swagger.json"
  },
  "servers": [
    {
      "url": "https://sandbox-api.mfkessai.co.jp/v2"
    }
  ],
  "components": {
    "securitySchemes": {
      "apikey": {
        "type": "apiKey",
        "name": "apikey",
        "in": "header"
      }
    },
    "schemas": {
      "AccountTransfer": {
        "description": "口座振替に関する情報です。お支払方法が口座振替の顧客のみ利用できます。",
        "properties": {
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`account_transfer`が入ります。",
            "enum": [
              "account_transfer"
            ],
            "example": "account_transfer",
            "type": "string"
          }
        },
        "type": "object"
      },
      "AccountTransferNotification": {
        "example": {
          "account_transfer_date": "2021-06-09",
          "amount": 20000,
          "billing_id": "79NR-9WR6",
          "created_at": "2021-06-15T10:21:34+09:00",
          "destination_id": "WNAV-37R6",
          "id": "79NR-AP96",
          "invoice_delivery_methods": [
            "posting",
            "email"
          ],
          "object": "account_transfer_notification",
          "uri": "mfk:account_transfer_notification:7679-YW36"
        },
        "properties": {
          "account_transfer_date": {
            "description": "口座振替通知書兼請求書に記載される口座振替日です。",
            "example": "2021-06-15",
            "format": "date",
            "type": "string"
          },
          "amount": {
            "description": "口座振替通知書兼請求書に記載される請求金額です。",
            "example": 20000,
            "type": "integer"
          },
          "billing_id": {
            "description": "請求IDです。",
            "example": "79NR-9WR6",
            "minLength": 1,
            "type": "string"
          },
          "created_at": {
            "description": "口座振替通知書兼請求書の発行日時です。",
            "example": "2021-06-15T10:21:34+09:00",
            "format": "date-time",
            "type": "string"
          },
          "destination_id": {
            "description": "請求先IDです。送付したい請求先を指定してください。",
            "example": "WNAV-37R6",
            "type": "string"
          },
          "id": {
            "description": "口座振替通知書兼請求書IDです。",
            "example": "79NR-AP96",
            "type": "string"
          },
          "invoice_delivery_methods": {
            "description": "口座振替通知書兼請求書送付方法です。郵送(posting) またはメール送付(email)のうちから少なくとも１つになります。",
            "example": [
              "posting",
              "email"
            ],
            "items": {
              "$ref": "#/components/schemas/InvoiceDeliveryMethod"
            },
            "type": "array"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`account_transfer_notification`が入ります。",
            "enum": [
              "account_transfer_notification"
            ],
            "example": "account_transfer_notification",
            "type": "string"
          },
          "uri": {
            "description": "口座振替通知書兼請求書URIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:account_transfer_notification:79NR-AP96",
            "type": "string"
          }
        },
        "type": "object"
      },
      "AccountTransferRequest": {
        "description": "口座振替依頼書の送付先情報です。",
        "example": {
          "address1": "東京都千代田区1-2-3",
          "address2": "サンプルビル3F",
          "department": "経理部",
          "email": "kessai.tanto@example.jp",
          "name": "担当 太郎",
          "object": "account_transfer_request",
          "tel": "03-1234-5678",
          "title": "部長",
          "zip_code": "111-1111"
        },
        "properties": {
          "address1": {
            "$ref": "#/components/schemas/Address1"
          },
          "address2": {
            "$ref": "#/components/schemas/Address2"
          },
          "department": {
            "description": "担当者の部署名です。",
            "example": "経理部",
            "type": "string"
          },
          "email": {
            "$ref": "#/components/schemas/Email"
          },
          "name": {
            "description": "担当者名です。",
            "example": "担当　太郎",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`account_transfer_request`が入ります。",
            "enum": [
              "account_transfer_request"
            ],
            "example": "account_transfer_request",
            "type": "string"
          },
          "tel": {
            "$ref": "#/components/schemas/Tel"
          },
          "title": {
            "description": "担当者の役職です。",
            "example": "部長",
            "type": "string"
          },
          "zip_code": {
            "$ref": "#/components/schemas/ZipCode"
          }
        },
        "type": "object"
      },
      "AccountTransferRequestPayload": {
        "description": "口座振替依頼申請情報です。口座振替依頼申請で利用します。",
        "example": {
          "address1": "東京都千代田区1-2-3",
          "address2": "サンプルビル3F",
          "department": "経理部",
          "email": "kessai.tanto@example.jp",
          "name": "担当 太郎",
          "tel": "03-1234-5678",
          "title": "部長",
          "zip_code": "111-1111"
        },
        "properties": {
          "address1": {
            "$ref": "#/components/schemas/Address1"
          },
          "address2": {
            "$ref": "#/components/schemas/Address2"
          },
          "department": {
            "description": "担当者の部署名です。",
            "example": "経理部",
            "maxLength": 50,
            "type": "string"
          },
          "email": {
            "$ref": "#/components/schemas/Email"
          },
          "name": {
            "description": "担当者名です。",
            "example": "担当　太郎",
            "maxLength": 30,
            "type": "string"
          },
          "tel": {
            "$ref": "#/components/schemas/Tel"
          },
          "title": {
            "description": "担当者の役職です。",
            "example": "部長",
            "maxLength": 30,
            "type": "string"
          },
          "zip_code": {
            "$ref": "#/components/schemas/ZipCode"
          }
        },
        "required": [
          "zip_code",
          "address1",
          "tel",
          "email"
        ],
        "type": "object"
      },
      "Address1": {
        "description": "都道府県・市区町村・番地です。必ず都道府県名から始めてください。",
        "example": "東京都千代田区1-2-3",
        "maxLength": 100,
        "minLength": 1,
        "pattern": "^(北海道|青森県|岩手県|宮城県|秋田県|山形県|福島県|茨城県|栃木県|群馬県|埼玉県|千葉県|東京都|神奈川県|新潟県|富山県|石川県|福井県|山梨県|長野県|岐阜県|静岡県|愛知県|三重県|滋賀県|京都府|大阪府|兵庫県|奈良県|和歌山県|鳥取県|島根県|岡山県|広島県|山口県|徳島県|香川県|愛媛県|高知県|福岡県|佐賀県|長崎県|熊本県|大分県|宮崎県|鹿児島県|沖縄県).+$",
        "type": "string"
      },
      "Address2": {
        "description": "建物名・部屋番号などです。",
        "example": "サンプルビル3F",
        "maxLength": 100,
        "type": "string"
      },
      "AmountPerTaxRateType": {
        "description": "各税率種別毎の**税込**の合計金額です。",
        "example": {
          "amount": 11000,
          "tax_rate_type": "normal_10"
        },
        "properties": {
          "amount": {
            "description": "対象税率種別毎の合計金額です。**税込**金額になります。",
            "example": 12000,
            "maximum": 2147483647,
            "minimum": -2147483648,
            "type": "integer"
          },
          "tax_rate_type": {
            "$ref": "#/components/schemas/TaxRateType"
          }
        },
        "required": [
          "amount",
          "tax_rate_type"
        ],
        "type": "object"
      },
      "Authorization": {
        "example": {
          "amount": 10000,
          "canceled_at": "2019-04-22T10:36:43+09:00",
          "created_at": "2019-04-01T10:36:43+09:00",
          "credit_facility_id": "4N3W-ER7N",
          "customer_id": "W463-AA6V",
          "expiration_date": "2019-06-16",
          "id": "9NR3-P9A6",
          "max_due_date": "2019-06-30",
          "number": "AUTHORIZATION001",
          "object": "authorization",
          "status": "active",
          "transaction_id": "GY9N-EWNM",
          "uri": "mfk:authorization:9NR3-P9A6"
        },
        "properties": {
          "amount": {
            "description": "オーソリゼーション金額です。**税込**金額になります。",
            "example": 10000,
            "type": "integer"
          },
          "canceled_at": {
            "description": "オーソリゼーションがキャンセルされた日時です。未キャンセルの場合は空になります。",
            "example": "2019-04-22T10:36:43+09:00",
            "format": "date-time",
            "type": "string",
            "x-nullable": true
          },
          "created_at": {
            "description": "オーソリゼーションが登録された日時を示します。",
            "example": "2019-04-01T10:36:43+09:00",
            "format": "date-time",
            "type": "string"
          },
          "credit_facility_id": {
            "description": "与信枠IDです。このオーソリゼーションが紐づく与信枠を示します。",
            "example": "4N3W-ER7N",
            "type": "string"
          },
          "customer_id": {
            "description": "顧客IDです。このオーソリゼーションが紐づく顧客を示します。",
            "example": "W463-AA6V",
            "type": "string"
          },
          "expiration_date": {
            "description": "有効期限日です。この日付を含む有効期間中はこのオーソリゼーションを利用して取引登録ができます。",
            "example": "2019-06-16",
            "format": "date",
            "type": "string"
          },
          "id": {
            "description": "オーソリゼーションIDです。一意の識別子として自動で付与されます。",
            "example": "9NR3-P9A6",
            "type": "string"
          },
          "max_due_date": {
            "description": "このオーソリゼーションを利用して取引登録する際に指定可能な最大支払期限です。",
            "example": "2019-06-30",
            "format": "date",
            "type": "string"
          },
          "number": {
            "description": "オーソリゼーションに付与できる任意の番号です。自動で付与されるオーソリゼーションIDとは別に、売り手様が独自に管理する識別子を登録することができます。ただし、売り手様の管理されるオーソリゼーション間で一意でなければなりません。",
            "example": "AUTHORIZATION001",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`authorization`が入ります。",
            "enum": [
              "authorization"
            ],
            "example": "authorization",
            "type": "string"
          },
          "status": {
            "description": "オーソリゼーションステータスです。アクティブ(`active`)、有効期限切れ(`expired`)、取引登録済み(`captured`)、キャンセル済み(`canceled`)があります。",
            "enum": [
              "active",
              "expired",
              "captured",
              "canceled"
            ],
            "example": "active",
            "type": "string"
          },
          "transaction_id": {
            "description": "取引IDです。このオーソリゼーションが紐づく取引を示します。空の場合はそのオーソリゼーションを利用して取引登録がまだされていないことを示します。",
            "example": "GY9N-EWNM",
            "type": "string",
            "x-nullable": true
          },
          "uri": {
            "description": "オーソリゼーションURIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:authorization:9NR3-P9A6",
            "type": "string"
          }
        },
        "type": "object"
      },
      "AuthorizationPayload": {
        "properties": {
          "amount": {
            "description": "オーソリゼーション金額です。必ず**税込**金額を指定してください。",
            "example": 10000,
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer"
          },
          "customer_id": {
            "description": "顧客IDです。このオーソリゼーションが紐づく顧客を指定してください。",
            "example": "W463-AA6V",
            "minLength": 1,
            "type": "string"
          },
          "number": {
            "description": "オーソリゼーションに付与できる任意の番号です。自動で付与されるオーソリゼーションIDとは別に、売り手様が独自に管理する識別子を登録することができます。ただし、売り手様の管理されるオーソリゼーション間で一意でなければなりません。",
            "example": "AUTHORIZATION001",
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "amount",
          "customer_id",
          "number"
        ],
        "type": "object"
      },
      "AuthorizationsList": {
        "properties": {
          "items": {
            "description": "オーソリゼーション一覧です。",
            "items": {
              "$ref": "#/components/schemas/Authorization"
            },
            "type": "array"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず `list`が設定されます。",
            "enum": [
              "list"
            ],
            "example": "list",
            "type": "string"
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        },
        "type": "object"
      },
      "BankTransfer": {
        "description": "銀行振込に関する情報です。お支払方法が銀行振込の顧客のみ利用できます。 初回請求前は振込先口座が未割当のため、`object`以外は空で返却されます。",
        "properties": {
          "account_number": {
            "description": "振込先口座番号です。未割当の場合は空で返却されます。",
            "example": "12345678",
            "type": "string"
          },
          "bank_code": {
            "description": "振込先銀行コードです。未割当の場合は空で返却されます。",
            "example": "0001",
            "type": "string"
          },
          "bank_name": {
            "description": "振込先銀行名です。未割当の場合は空で返却されます。",
            "example": "MFKESSSAI銀行",
            "type": "string"
          },
          "bank_name_kana": {
            "description": "振込先銀行名フリガナです。未割当の場合は空で返却されます。",
            "example": "ｴﾑｴﾌｹﾂｻｲ",
            "type": "string"
          },
          "branch_code": {
            "description": "振込先銀行支店コードです。未割当の場合は空で返却されます。",
            "example": "001",
            "type": "string"
          },
          "branch_name": {
            "description": "振込先銀行支店名です。未割当の場合は空で返却されます。",
            "example": "大手町支店",
            "type": "string"
          },
          "branch_name_kana": {
            "description": "振込先銀行支店名フリガナです。未割当の場合は空で返却されます。",
            "example": "ｵｵﾃﾏﾁ",
            "type": "string"
          },
          "holder_name": {
            "description": "振込先口座名義です。必ず`ﾏﾈ-ﾌｵﾜ-ﾄﾞｹﾂｻｲ(ｶ`になります。未割当の場合は空で返却されます。",
            "example": "ﾏﾈ-ﾌｵﾜ-ﾄﾞｹﾂｻｲ(ｶ",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`bank_transfer`が入ります。",
            "enum": [
              "bank_transfer"
            ],
            "example": "bank_transfer",
            "type": "string"
          },
          "type": {
            "description": "振込先口座種別です。`current`(当座)、`saving`(普通)の2種類のうちどちらかになります。未割当の場合は空で返却されます。",
            "enum": [
              "current",
              "saving"
            ],
            "type": "string"
          }
        },
        "type": "object"
      },
      "Billing": {
        "description": "請求です。取引のうち、請求先・支払期限・請求書発行日・取引登録方式が同一の取引が同じ請求にまとめられます。",
        "example": {
          "account_transfer_notification_ids": [
            "7MW6-AW6A"
          ],
          "amount": 21800,
          "amounts_per_tax_rate_type": [
            {
              "amount": 11000,
              "tax_rate_type": "normal_10"
            },
            {
              "amount": 10800,
              "tax_rate_type": "reduced_8"
            }
          ],
          "customer_id": "WNAV-37R6",
          "destination_id": "7679-YW36",
          "due_date": "2019-04-30",
          "id": "9R6M-VMAN",
          "invoice_delivery_method": [
            "posting",
            "email"
          ],
          "invoice_ids": [
            "W47N-7WNM",
            "AY9N-VPN3"
          ],
          "issue_date": "2019-04-01",
          "object": "billing",
          "status": "scheduled",
          "unpaid": {
            "shortage_amount": 12000,
            "updated_date": "2019-04-30"
          },
          "uri": "mfk:billing:9R6M-VMAN"
        },
        "properties": {
          "account_transfer_notification_ids": {
            "description": "口座振替通知書IDです。取引が紐づく口座振替通知書を示します。口座振替通知書が発行され次第非同期に値が追加されます。",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "amount": {
            "description": "請求の**税込**の合計金額です。区分記載請求書モードの請求では請求に含まれる取引金額の合計となり、インボイスモードの請求では含まれる全ての明細情報からインボイス制度の端数処理方法に則り算出した金額となります。インボイスモードでは審査中の取引を含んだ請求金額となり、請求対象の取引がなければ0になります。",
            "example": 12000,
            "type": "integer",
            "x-omitempty": false
          },
          "amounts_per_tax_rate_type": {
            "description": "各税率種別毎の**税込**の合計金額です。",
            "items": {
              "$ref": "#/components/schemas/AmountPerTaxRateType"
            },
            "type": "array"
          },
          "customer_id": {
            "description": "顧客IDです。請求の顧客を示します。",
            "example": "WNAV-37R6",
            "type": "string"
          },
          "destination_id": {
            "description": "請求先IDです。請求先を示します。",
            "example": "7679-YW36",
            "type": "string"
          },
          "due_date": {
            "description": "支払期限です。",
            "example": "2019-04-30",
            "format": "date",
            "type": "string"
          },
          "id": {
            "description": "請求IDです。一意の識別子として自動で付与されます。請求先ID・支払期限・請求書発行日・取引登録方式が同一の取引がこの請求によってまとめられます。請求書は請求をもとに発行されます。",
            "example": "9R6M-VMAN",
            "type": "string"
          },
          "invoice_delivery_methods": {
            "description": "請求書送付方法です。郵送(posting) またはメール送付(email)のうちから少なくとも１つを指定してください。どちらも選択された場合、どちらの方法でも送付されます。 また、各取引で指定しなかった送付方法でも、請求にまとまった取引のうちでその送付方法を選択しているものがあれば、そちらの送付方法も採用されます。",
            "example": [
              "posting",
              "email"
            ],
            "items": {
              "$ref": "#/components/schemas/InvoiceDeliveryMethod"
            },
            "type": "array"
          },
          "invoice_ids": {
            "description": "請求書IDです。請求に紐づく請求書を示します。請求書が発行され次第非同期で値が追加されます。",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "issue_date": {
            "description": "請求書発行日です。請求書送付日については<a href=\"https://support.mfkessai.co.jp/hc/ja/articles/900002297303\" target=\"_blank\">こちら</a>をご参照ください。",
            "example": "2019-04-20",
            "format": "date",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`billing`が入ります。",
            "enum": [
              "billing"
            ],
            "example": "billing",
            "type": "string"
          },
          "status": {
            "description": "請求ステータスです。請求予定(`scheduled`)、請求書発行済(`invoice_issued`) 、口座振替通知済(`account_transfer_notified`)、請求停止(`stopped`)、請求停止予定(`scheduled_to_be_stopped`)で指定されます。 請求停止(`stopped`)は請求モードがインボイスモードの場合のみ返却されます。",
            "enum": [
              "scheduled",
              "invoice_issued",
              "account_transfer_notified",
              "stopped",
              "scheduled_to_be_stopped"
            ],
            "example": "invoice_issued",
            "type": "string"
          },
          "unpaid": {
            "description": "未入金情報です。請求に対して支払期限後未入金がある場合のみ返却されます。",
            "properties": {
              "shortage_amount": {
                "description": "未入金額です。",
                "example": 12000,
                "type": "integer"
              },
              "updated_date": {
                "description": "入金情報が最後に更新された日付です。この日付以降に入金されている可能性があります。",
                "example": "2019-04-30",
                "format": "date",
                "type": "string"
              }
            },
            "type": "object"
          },
          "uri": {
            "description": "請求URIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:billing:9R6M-VMAN",
            "type": "string"
          }
        },
        "type": "object"
      },
      "BillingCondition": {
        "description": "請求される条件です。登録時は審査結果に関わらずすべて請求する(`all`)、審査通過の取引のみ請求する(`passed`)のうちから選択してください。<br> 空の場合は管理画面の「請求対象の設定」で設定された条件で登録されます。請求対象について詳しくは<a href=\"https://support.mfkessai.co.jp/hc/ja/articles/900002241626\" target=\"_blank\">こちら</a>を参照ください。",
        "enum": [
          "passed",
          "all"
        ],
        "type": "string"
      },
