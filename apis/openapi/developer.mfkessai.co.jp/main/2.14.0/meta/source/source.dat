          },
          "id": {
            "description": "債権IDです。一意の識別子として自動で付与されます。",
            "example": "9NR3-P9A6",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`payout_transaction`が入ります。",
            "enum": [
              "payout_transaction"
            ],
            "example": "payout_transaction",
            "type": "string"
