            "example": "7679-YW36",
            "minLength": 1,
            "type": "string"
          },
          "department": {
            "description": "担当者の部署名です。",
            "example": "経理部",
            "maxLength": 50,
            "type": "string"
          },
          "email": {
            "$ref": "#/components/schemas/Email"
          },
          "name": {
            "description": "担当者氏名です。",
            "example": "担当　太郎",
            "maxLength": 30,
            "type": "string"
          },
          "name_kana": {
            "description": "担当者名カナです。全角カタカナで入力してください。",
            "example": "タントウ　タロウ",
            "maxLength": 60,
            "type": "string"
          },
          "tel": {
            "$ref": "#/components/schemas/Tel"
          },
          "title": {
            "description": "担当者の役職です。",
            "example": "部長",
            "maxLength": 30,
            "type": "string"
          },
          "zip_code": {
            "$ref": "#/components/schemas/ZipCode"
          }
        },
        "required": [
          "address1",
          "customer_id",
          "email",
          "tel",
          "zip_code"
        ],
        "type": "object"
      },
