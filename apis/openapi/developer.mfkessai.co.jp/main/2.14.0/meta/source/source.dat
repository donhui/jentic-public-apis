      "DownloadSignedURL": {
        "example": {
          "expired_at": "2023-03-08T10:36:43+09:00",
          "signed_url": "https://download.mfk.jp/api/billings/7679-YW36/content?Signature=mfkrandomsignature",
          "type": "pdf"
        },
        "properties": {
          "expired_at": {
            "description": "ファイルダウンロード用の署名付きURLの有効期限です。",
            "example": "2023-03-08T10:36:43+09:00",
            "format": "date-time",
            "type": "string"
          },
          "signed_url": {
            "description": "ファイルダウンロード用の署名付きURLです。",
            "example": "https://download.mfk.jp/api/billings/7679-YW36/content?Signature=mfkrandomsignature",
