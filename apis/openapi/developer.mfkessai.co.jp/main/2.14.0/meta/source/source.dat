      "Email": {
        "description": "メールアドレスです。email形式で指定してください。",
        "example": "kessai.tanto@example.jp",
        "maxLength": 255,
        "pattern": "^[\\w.+-]{1,64}@[a-zA-Z\\d](?:[a-zA-Z\\d-]{0,253}[a-zA-Z\\d])?(?:\\.[a-zA-Z\\d](?:[a-zA-Z\\d-]{0,253}[a-zA-Z\\d])?)+$",
        "type": "string"
      },
