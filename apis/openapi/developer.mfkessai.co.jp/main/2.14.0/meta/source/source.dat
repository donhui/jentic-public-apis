      "CreditFacility": {
        "description": "顧客の与信枠です。この枠内の取引登録であれば取引審査なしで登録することができます。",
        "example": {
          "amount": 200000,
          "balance": 100000,
          "customer_examination_id": "WNAV-37R6",
          "customer_id": "9R6M-VMAN",
          "end_date": "2019-04-30",
          "id": "7679-YW36",
          "start_date": "2019-04-01",
          "status": "inactive",
          "uri": "mfk:credit_facility:7679-YW36"
        },
        "properties": {
          "amount": {
            "description": "与信額です。取引登録期間(`start_date`~`end_date`)にこの金額までの取引であれば取引審査なしで登録することができます。",
            "example": 200000,
            "type": "integer"
          },
          "balance": {
            "description": "与信額残高です。与信額からこの与信枠を利用して登録された取引の合計金額を差し引いた金額です。現在与信枠を利用して登録できる取引金額を示しています。",
            "example": 100000,
            "type": "integer",
            "x-nullable": true
          },
          "customer_examination_id": {
            "description": "与信枠審査IDです。",
            "example": "7679-YW36",
            "type": "string"
          },
          "customer_id": {
            "description": "顧客IDです。一意の識別子として自動で付与されます。",
            "example": "9R6M-VMAN",
            "type": "string"
          },
          "end_date": {
            "description": "取引登録期間終了日です。この日付まで対象の与信枠を利用して取引登録ができます。",
            "example": "2019-04-30",
            "format": "date",
            "type": "string"
          },
          "id": {
            "description": "与信枠IDです。一意の識別子として自動で付与されます。",
            "example": "7679-YW36",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`credit_facility`が入ります。",
            "enum": [
              "credit_facility"
            ],
            "example": "credit_facility",
            "type": "string"
          },
          "start_date": {
            "description": "取引登録期間開始日です。この日付から対象の与信枠を利用して取引登録ができます。",
            "example": "2019-04-01",
            "format": "date",
            "type": "string"
          },
          "status": {
            "description": "与信枠ステータスです。未適用(`inactive`)、適用中(`active`)、期限切れ(`expired`)があります。 現在の日付が`start_date`~`end_date`の期間内であれば`active`、`start_date`よりも前であれば`inactive`、`end_date`を過ぎていれば`expired`になります。",
            "enum": [
              "inactive",
              "active",
              "expired"
            ],
            "example": "inactive",
            "type": "string"
          },
          "uri": {
            "description": "与信枠URIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:credit_facility:7679-YW36",
            "type": "string"
          }
        },
        "type": "object"
      },
      "Customer": {
        "description": "顧客です。取引登録や与信枠取得などあらゆる機能を利用する起点となります。",
        "example": {
          "created_at": "2019-04-01T10:36:43+09:00",
          "has_alert": false,
          "id": "7679-YW36",
          "name": "サンプル顧客",
          "number": "CUSTOEMR001",
          "object": "customer",
          "payment_method": {
            "bank_transfer": {
              "account_number": "123456789",
              "bank_name": "MEKESSAI銀行",
              "branch_name": "大手町支店",
              "holder_name": "ﾏﾈ-ﾌｵﾜ-ﾄﾞｹﾂｻｲ(ｶ",
              "object": "bank_transfer",
              "type": "current"
            },
            "object": "payment_method"
          },
          "uri": "mfk:customer:7679-YW36"
        },
        "properties": {
          "created_at": {
            "description": "顧客が登録された日時を示します。",
            "example": "2019-04-01T10:36:43+09:00",
            "format": "date-time",
            "type": "string"
          },
          "has_alert": {
            "default": false,
            "description": "アラートの有無を示します。アラートがある場合は`true`、ない場合は`false`を返します。アラートがあると、自動で毎月付与されている与信枠が停止します。",
            "type": "boolean"
          },
          "id": {
            "description": "顧客IDです。 本サービスによって発番される一意の識別子です。",
            "example": "7679-YW36",
            "type": "string"
          },
          "name": {
            "description": "顧客名です。",
            "example": "サンプル顧客",
            "type": "string"
          },
          "number": {
            "description": "顧客に付与できる任意の顧客番号です。自動で付与される顧客IDとは別に、売り手様が独自に管理する識別子を登録することができます。ただし、売り手様の管理される顧客間で一意でなければなりません。",
            "example": "CUSTOMER0001",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`customer`が入ります。",
            "enum": [
              "customer"
            ],
            "example": "customer",
            "type": "string"
          },
          "payment_method": {
            "$ref": "#/components/schemas/PaymentMethod"
          },
          "uri": {
            "description": "顧客URIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:customer:7679-YW36",
            "type": "string"
          }
        },
        "type": "object"
      },
      "CustomerExamination": {
        "description": "与信枠審査です。顧客に対する与信枠取得のために利用します。申請後２営業日以内に審査いたします。 自動与信枠審査を利用している場合は顧客登録と同時に与信枠審査も申請されます。",
        "example": {
          "address1": "東京都千代田区1-2-3",
          "address2": "サンプルビル3F",
          "amount": 20000,
          "business_description": "クラウド型企業間決済サービス",
          "business_type": "corporate",
          "corporate_number": "1234567890123",
          "created_at": "2019-02-18T10:20:34+09:00",
          "customer_id": "7679-YW36",
          "email": "kessai.tanto@example.jp",
          "end_date": "2019-04-30",
          "id": "WNAV-37R6",
          "remark": "一部上場企業です。",
          "representative_name": "代表太郎",
          "start_date": "2019-04-01",
          "status": "passed",
          "tel": "03-1234-5678",
          "type": "auto",
          "uri": "mfk:customer_examination:WNAV-37R6",
          "website": "https://mfkessai.co.jp",
          "zip_code": "111-1111"
        },
        "properties": {
          "address1": {
            "$ref": "#/components/schemas/Address1"
          },
          "address2": {
            "$ref": "#/components/schemas/Address2"
          },
          "amount": {
            "description": "希望与信額です。審査通過の場合に付与される与信枠の希望金額になります。審査の結果減額されて与信枠付与されることもあります。",
            "example": 200000,
            "type": "integer"
          },
          "business_description": {
            "description": "事業内容です。顧客の主なサービス、商材などです。",
            "example": "クラウド型企業間決済サービス",
            "type": "string"
          },
          "business_type": {
            "description": "事業所区分です。法人(`corporate`)または、個人(`individual`)で指定されます。不明な場合は空になります。",
            "enum": [
              "corporate",
              "individual"
            ],
            "example": "corporate",
            "type": "string"
          },
          "corporate_number": {
            "description": "法人番号です。事業所区分(`business_type`)が法人(`corporate`)の場合にのみ利用されます。",
            "example": "1234567890123",
            "type": "string"
          },
          "created_at": {
            "description": "与信枠審査の申請日時です。",
            "example": "2019-02-18T10:21:34+09:00",
            "format": "date-time",
            "type": "string"
          },
          "customer_id": {
            "description": "顧客IDです。一意の識別子として自動で付与されます。",
            "example": "7679-YW36",
            "type": "string"
          },
          "email": {
            "$ref": "#/components/schemas/Email"
          },
          "end_date": {
            "description": "希望取引登録期間終了日です。この日付まで対象の与信枠を利用して取引登録ができます。",
            "example": "2019-04-30",
            "format": "date",
            "type": "string"
          },
          "id": {
            "description": "与信枠審査IDです。一意の識別子として自動で付与されます。",
            "example": "7679-YW36",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`customer_examination`が入ります。",
            "enum": [
              "customer_examination"
            ],
            "example": "customer_examination",
            "type": "string"
          },
          "remark": {
            "description": "その他情報です。審査に利用できる情報を記載できます。",
            "example": "一部上場企業です。",
            "type": "string"
          },
          "representative_name": {
            "description": "代表者名です。",
            "example": "代表太郎",
            "type": "string"
          },
          "start_date": {
            "description": "希望取引登録期間開始日。この日付から対象の与信枠を利用して取引登録ができます。 手動での申請の場合、審査通過日となるため空で返却されます。自動与信枠審査による申請の場合は、月次での与信枠付与になり対象月の月初日となります。",
            "example": "2019-04-01",
            "format": "date",
            "type": "string",
            "x-nullable": true
          },
          "status": {
            "description": "与信枠審査ステータスです。審査中(`unexamined`)、審査通過(`passed`)、審査否決(`rejected`)があります。審査通過の場合には与信枠が付与されています。",
            "enum": [
              "unexamined",
              "passed",
              "rejected"
            ],
            "example": "passed",
            "maxLength": 60,
            "type": "string"
          },
          "tel": {
            "$ref": "#/components/schemas/Tel"
          },
          "type": {
            "description": "申請理由の種別です。手動(`manual`)、自動(`auto`)、回復(`recovery`)があります。手動(manual)には増枠申請と手動回復審査申請が含まれます。",
            "enum": [
              "manual",
              "auto",
              "recovery"
            ],
            "type": "string"
          },
          "uri": {
            "description": "与信枠審査URIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:customer_examination:7679-YW36",
            "type": "string"
          },
          "website": {
            "description": "顧客企業のwebサイトです。",
            "example": "https://mfkessai.co.jp",
            "type": "string"
          },
          "zip_code": {
            "$ref": "#/components/schemas/ZipCode"
          }
        },
        "type": "object"
      },
      "CustomerExaminationPayload": {
        "description": "与信枠審査申請情報です。与信枠審査申請で利用します。",
        "example": {
          "address1": "東京都千代田区1-2-3",
          "address2": "サンプルビル3F",
          "amount": 20000,
          "business_description": "クラウド型企業間決済サービス",
          "business_type": "corporate",
          "corporate_number": "1234567890123",
          "customer_id": "7679-YW36",
          "email": "kessai.tanto@example.jp",
          "end_date": "2019-04-30",
          "remark": "一部上場企業です。",
          "representative_name": "代表太郎",
          "tel": "03-1234-5678",
          "website": "https://mfkessai.co.jp",
          "zip_code": "111-1111"
        },
        "properties": {
          "address1": {
            "$ref": "#/components/schemas/Address1"
          },
          "address2": {
            "$ref": "#/components/schemas/Address2"
          },
          "amount": {
            "description": "希望与信額です。審査通過の場合に付与される与信枠の金額になります。現在与信枠が適用中の場合は、その与信額未満の金額は指定できません。 審査の結果減額されて与信枠付与されることもあります。",
            "example": 200000,
            "maximum": 150000000,
            "minimum": 1,
            "type": "integer"
          },
          "business_description": {
            "description": "事業内容です。顧客の主なサービス、商材などを記載してください。",
            "example": "クラウド型企業間決済サービス",
            "maxLength": 500,
            "type": "string"
          },
          "business_type": {
            "description": "事業所区分です。法人(`corporate`)または、個人(`individual`)で指定してください。不明な場合は空にしてください。",
            "enum": [
              "corporate",
              "individual"
            ],
            "example": "corporate",
            "type": "string"
          },
          "corporate_number": {
            "description": "法人番号です。事業所区分(`business_type`)が法人(`corporate`)の場合にのみ指定してください。",
            "example": "1234567890123",
            "pattern": "^\\d{13}$",
            "type": "string"
          },
          "customer_id": {
            "description": "与信枠審査を申請する顧客のIDです。",
            "example": "7679-YW36",
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "$ref": "#/components/schemas/Email"
          },
          "end_date": {
            "description": "希望取引登録期間終了日です。この日付まで対象の与信枠を利用して取引登録ができます。 直近三ヶ月の月末のみ指定できます。",
            "example": "2019-04-30",
            "format": "date",
            "type": "string"
          },
          "remark": {
            "description": "与信枠審査に利用できるその他情報を記載できます。<br>Sandbox環境において与信枠審査で任意の結果を指定するためにこの値を用います。詳しくは[審査結果の操作](#environment_magic_number)を参照ください。",
            "example": "一部上場企業です。",
            "maxLength": 500,
            "type": "string"
          },
          "representative_name": {
            "description": "代表者氏名です。",
            "example": "代表太郎",
            "maxLength": 30,
            "type": "string"
          },
          "tel": {
            "$ref": "#/components/schemas/Tel"
          },
          "website": {
            "description": "顧客企業のwebサイトです。",
            "example": "https://mfkessai.co.jp",
            "maxLength": 500,
            "pattern": "^https?://(www\\.)?[-a-zA-Z0-9@:%._+~#=]{1,256}\\.[a-zA-Z0-9()]{1,9}\\b([-a-zA-Z0-9()@:%_+.~#?&/=]*)$",
            "type": "string"
          },
          "zip_code": {
            "$ref": "#/components/schemas/ZipCode"
          }
        },
        "required": [
          "address1",
          "amount",
          "customer_id",
          "email",
          "end_date",
          "tel",
          "zip_code"
        ],
        "type": "object"
      },
