            "example": "payout_refund",
            "type": "string"
          },
          "payout_id": {
            "description": "返金が含まれる振込のIDです。",
            "example": "7679-YW36",
            "type": "string"
          },
          "transaction_id": {
            "description": "取引IDです。この返金が紐づく取引を示します。",
            "example": "GY9N-EWNM",
            "type": "string"
          },
          "uri": {
            "description": "返金URIです。すべてのリソースで一意の識別子として自動で付与されます。",
