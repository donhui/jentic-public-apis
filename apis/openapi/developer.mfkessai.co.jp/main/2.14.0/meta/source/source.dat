      "Errors": {
        "description": "4xx系のエラーが発生した場合にエラー情報を返します。エラーObjectを配列として複数返します。",
        "example": [
          {
            "code": "invalid_after",
            "message": "parameter must be a valid one.",
            "param": "9R6M-VMAN"
          }
        ],
        "items": {
          "$ref": "#/components/schemas/Error"
        },
        "type": "array"
      },
      "Invoice": {
        "example": {
          "amount": 20000,
          "billing_date": "2021-06-09",
          "billing_id": "79NR-9WR6",
          "created_at": "2021-06-15T10:21:34+09:00",
          "destination_id": "WNAV-37R6",
          "id": "79NR-AP96",
          "invoice_delivery_methods": [
            "posting",
            "email"
          ],
          "object": "invoice",
          "uri": "mfk:invoice:7679-YW36"
        },
        "properties": {
          "amount": {
            "description": "請求書に記載される請求金額です。",
            "example": 20000,
            "type": "integer"
          },
          "billing_date": {
            "description": "請求書に記載される請求日です。",
            "example": "2021-06-15",
            "format": "date",
            "type": "string"
          },
          "billing_id": {
            "description": "請求IDです。",
            "example": "79NR-9WR6",
            "minLength": 1,
            "type": "string"
          },
          "created_at": {
            "description": "請求書の発行日時です。",
            "example": "2021-06-15T10:21:34+09:00",
            "format": "date-time",
            "type": "string"
          },
          "destination_id": {
            "description": "請求先IDです。送付したい請求先を指定してください。",
            "example": "WNAV-37R6",
            "type": "string"
          },
          "id": {
            "description": "請求書IDです。",
            "example": "79NR-AP96",
            "type": "string"
          },
          "invoice_delivery_methods": {
            "description": "請求書送付方法です。郵送(posting) またはメール送付(email)のうちから少なくとも１つになります。",
            "example": [
              "posting",
              "email"
            ],
            "items": {
              "$ref": "#/components/schemas/InvoiceDeliveryMethod"
            },
            "type": "array"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`invoice`が入ります。",
            "enum": [
              "invoice"
            ],
            "example": "invoice",
            "type": "string"
          },
          "uri": {
            "description": "請求書URIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:invoice:79NR-AP96",
            "type": "string"
          }
        },
        "type": "object"
      },
      "InvoiceDeliveryMethod": {
        "description": "請求書送付方法です。登録時は郵送(posting) またはメール送付(email)のうちから少なくとも１つを指定してください。",
        "enum": [
          "posting",
          "email"
        ],
        "example": "posting",
        "type": "string"
      },
      "Issue": {
        "example": {
          "created_at": "2019-04-01T10:36:43+09:00",
          "id": "i/79NR-AP96",
          "type": "invoice"
        },
        "properties": {
          "created_at": {
            "description": "請求書または口座振替通知書の発行日時です。",
            "example": "2019-04-01T10:36:43+09:00",
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "description": "発行済の請求書または口座振替通知書を表すIDです。請求書の場合は「i/」、口座振替通知書の場合は「a/」がprefixとして付きます。ファイルダウンロード用URL発行エンドポイントでそのままこのIDを使うことができます。",
            "example": "i/79NR-AP96",
            "type": "string"
          },
          "type": {
            "description": "請求種別です。請求書(invoice)もしくは口座振替通知書(account_transfer_notification)のいずれかになります。",
            "enum": [
              "account_transfer_notification",
              "invoice"
            ],
            "example": "invoice",
            "type": "string"
          }
        },
        "type": "object"
      },
      "IssuesList": {
        "properties": {
          "items": {
            "description": "発行済請求情報の一覧です。",
            "items": {
              "$ref": "#/components/schemas/Issue"
            },
            "type": "array"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず `list`が設定されます。",
            "enum": [
              "list"
            ],
            "example": "list",
            "type": "string"
          }
        },
        "type": "object"
      },
      "Pagination": {
        "description": "ページネーション情報です。各Objectの一覧取得の際にリストとともに返却されます。この情報をもとにページ繰りを行うことができます。",
        "properties": {
          "end": {
            "description": "この一覧に含まれるリソースのうち最後のリソースのIDです。次ページがある場合は、この値をクエリパラメーター`after`に設定することで次ページを取得することができます。",
            "example": "7679-YW36",
            "type": "string"
          },
          "has_next": {
            "default": false,
            "description": "次ページがある場合は`true`、ない場合は`false`が返却されます。",
            "example": true,
            "type": "boolean"
          },
          "has_previous": {
            "default": false,
            "description": "前ページがある場合は`true`、ない場合は`false`が返却されます。",
            "example": false,
            "type": "boolean"
          },
          "limit": {
            "description": "ページ当たりの最大件数です。",
            "example": 20,
            "type": "integer"
          },
          "start": {
            "description": "この一覧に含まれるリソースのうち最初のリソースのIDです。前ページがある場合は、この値をクエリパラメーター`before`に設定することで前ページを取得することができます。",
            "example": "9R6M-VMAN",
            "type": "string"
          },
          "total": {
            "description": "条件に合致するリソースの全件数です。",
            "example": 143,
            "type": "integer",
            "x-nullable": true
          }
        },
        "type": "object"
      },
      "PaymentMethod": {
        "description": "顧客の支払方法です。口座振替(`AccountTransfer`)もしくは銀行振込(`BankTransfer`)のいずれかです。顧客の支払方法に応じたObjectが返却されます。 デフォルトでは銀行振込になっています。ただし、初回請求前には振込先口座が指定されていない場合があります。 口座振替に変更する場合には別途書面でのお手続きが必要であるため、サポートセンターへお問い合わせください。",
        "minProperties": 1,
        "properties": {
          "account_transfer": {
            "$ref": "#/components/schemas/AccountTransfer"
          },
          "bank_transfer": {
            "$ref": "#/components/schemas/BankTransfer"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`payment_method`が入ります。",
            "enum": [
              "payment_method"
            ],
            "example": "payment_method",
            "type": "string"
          }
        },
        "type": "object"
      },
      "Payout": {
        "description": "弊社から売り手様への金額確定済みの振込です。",
        "example": {
          "amount": 300800,
          "collected_amount": 200000,
          "deduction": {
            "amount": 9400,
            "returned_credit_amount": 500,
            "tax": {
              "amount": 500,
              "rate_type": "normal_10"
            },
            "tax_free": {
              "amount": 3200,
              "commission_amount": 2200,
              "early_payout_commission_amount": 1000
            },
            "taxable": {
              "amount": 7000,
              "basic_monthly_charge": 4500,
              "billing_charge": {
                "amount": 2000,
                "quantity": 10,
                "unit_price": 200
              },
              "convenience_billing": {
                "charge": 15000,
                "quantity": 100,
                "unit_price": 150
              },
              "posting": {
                "amount": 500,
                "quantity": 5,
                "unit_price": 100
              }
            },
            "untaxable": {
              "amount": 15000,
              "revenue_stamp": {
                "amount": 15000,
                "quantity": 100,
                "unit_price": 150
              }
            }
          },
          "id": "7679-YW36",
          "payout_date": "2019-07-29",
          "receivables_amount": 110000,
          "returned_commission_amount": 220,
          "status": "completed",
          "type": "normal",
          "uri": "mfk:payout:7679-YW36"
        },
        "properties": {
          "amount": {
            "description": "振込金額です。",
            "example": 1000000,
            "type": "integer"
          },
          "collected_amount": {
            "description": "振込の対象となる回収金額です。",
            "example": 200000,
            "type": "integer",
            "x-nullable": true
          },
          "deduction": {
            "$ref": "#/components/schemas/Deduction"
          },
          "id": {
            "description": "振込IDです。一意の識別子として自動で付与されます。",
            "example": "7679-YW36",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`payout`が入ります。",
            "enum": [
              "payout"
            ],
            "example": "payout",
            "type": "string"
          },
          "payout_date": {
            "description": "振込予定日です。",
            "example": "2019-04-01",
            "format": "date",
            "type": "string"
          },
          "receivables_amount": {
            "description": "振込の対象となる債権金額です。",
            "example": 1100000,
            "type": "integer",
            "x-nullable": true
          },
          "returned_commission_amount": {
            "description": "カード払いが行われた場合に弊社から返還する手数料額です。",
            "example": 220,
            "type": "integer",
            "x-nullable": true
          },
          "status": {
            "description": "振込ステータスです。振込手続中(`in_progress`)、振込完了(`completed`)があります。",
            "enum": [
              "in_progress",
              "completed"
            ],
            "example": "completed",
            "type": "string"
          },
          "type": {
            "description": "振込種別です。通常振込(`normal`)、早期振込(`early`)があります。",
            "enum": [
              "normal",
              "early"
            ],
            "example": "normal",
            "type": "string"
          },
          "uri": {
            "description": "振込URIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:payout:7679-YW36",
            "type": "string"
          }
        },
        "type": "object"
      },
      "PayoutRefund": {
        "description": "売り手さまへの振込金額確定後に発生した取引キャンセルに伴う返金です。",
