      "ReissuingPayload": {
        "example": {
          "destination_id": "WNAV-37R6",
          "invoice_delivery_methods": [
            "posting",
            "email"
          ]
        },
        "properties": {
          "destination_id": {
            "description": "請求先IDです。送付したい請求先を指定してください。",
            "example": "WNAV-37R6",
            "minLength": 1,
            "type": "string"
          },
          "invoice_delivery_methods": {
            "description": "請求書送付方法です。郵送(posting) またはメール送付(email)のうちから少なくとも１つを指定してください。どちらも選択された場合、どちらの方法でも送付されます。 また、各取引で指定しなかった送付方法でも、請求にまとまった取引のうちでその送付方法を選択しているものがあれば、そちらの送付方法も採用されます。",
            "example": [
              "posting",
              "email"
            ],
            "items": {
              "$ref": "#/components/schemas/InvoiceDeliveryMethod"
            },
            "maxItems": 2,
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "destination_id",
          "invoice_delivery_methods"
        ],
        "type": "object"
      },
      "ReissuingResponse": {
        "properties": {
          "account_transfer_notification": {
            "$ref": "#/components/schemas/AccountTransferNotification"
          },
          "invoice": {
            "$ref": "#/components/schemas/Invoice"
          },
          "type": {
            "description": "請求種別です。請求書(invoice)もしくは口座振替通知書(account_transfer_notification)のいずれかになります。",
            "enum": [
              "account_transfer_notification",
              "invoice"
            ],
            "example": "invoice",
            "type": "string"
          }
        },
        "type": "object"
      },
      "TaxIncludedType": {
        "description": "取引明細の単価(`unit_price`), 小計(`amount`)の値が税込(`included`)か税抜(`excluded`)かを示します。返り値が空の場合は旧形式での登録時に指定されなかったことを表します。",
        "enum": [
          "included",
          "excluded"
        ],
        "type": "string"
      },
      "TaxRateType": {
        "description": "税率種別です。登録時は非課税(`non_taxable`)、消費税8%(`normal_8`)、消費税10%(`normal_10`)、軽減税率8%(`reduced_8`)、経過措置8%(`transitional_measures_8`)、対象外(`inapplicable`)のうちいずれかを指定してください。 返り値が空の場合は旧形式での登録時に指定されなかったことを表します。",
        "enum": [
          "non_taxable",
          "normal_8",
          "normal_10",
          "reduced_8",
          "transitional_measures_8",
          "inapplicable"
        ],
        "example": "normal_10",
        "type": "string"
      },
      "Tel": {
        "description": "電話番号です。ハイフン有無は任意になります。一部の形式は許容していません。（例：0570-XXX-XXX、0800-XXX-XXXXなど）",
        "example": "03-1234-5678",
        "pattern": "^((0(\\d{1}-?\\d{4}|\\d{2}-?\\d{3}|\\d{3}-?\\d{2}|\\d{4}-?\\d{1}|[5789]0-?\\d{4})-?\\d{4})|(0120-?\\d{3}-?\\d{3}))$",
        "type": "string"
      },
      "Transaction": {
        "description": "取引です。",
        "example": {
          "accepted_at": "2019-04-03T10:36:43+09:00",
          "amount": 5440,
          "amounts_per_tax_rate_type": [
            {
              "amount": 2200,
              "tax_rate_type": "normal_10"
            },
            {
              "amount": 3240,
              "tax_rate_type": "reduced_8"
            }
          ],
          "billing": true,
          "billing_accepted_at": "2019-04-22T10:36:43+09:00",
          "billing_condition": "passed",
          "billing_id": "9R6M-VMAN",
          "canceled_at": "2019-04-22T10:36:43+09:00",
          "created_at": "2019-04-01T10:36:43+09:00",
          "customer_id": "9PNG-VYR6",
          "date": "2019-04-10",
          "destination_id": "WNAV-37R6",
          "due_date": "2019-04-30",
          "id": "7679-YW36",
          "invoice_delivery_method": [
            "posting",
            "email"
          ],
          "issue_date": "2019-04-20",
          "number": "Transaction-0001",
          "object": "transaction",
          "status": "passed",
          "transaction_details": [
            {
              "amount": 3000,
              "description": "商品名A",
              "quantity": 3,
              "tax_included_type": "excluded",
              "tax_rate_type": "normal_10",
              "unit_price": 1000
            },
            {
              "amount": 3000,
              "description": "商品名B",
              "quantity": 3,
              "tax_included_type": "excluded",
              "tax_rate_type": "reduced_8",
              "unit_price": 1000
            },
            {
              "amount": -1000,
              "description": "商品名A 返品",
              "quantity": -1,
              "tax_included_type": "excluded",
              "tax_rate_type": "normal_10",
              "unit_price": 1000
            }
          ],
          "uri": "mfk:transaction:7679-YW36"
        },
        "properties": {
          "accepted_at": {
            "description": "債権譲受日時です。",
            "example": "2019-04-03T10:36:43+09:00",
            "format": "date-time",
            "type": "string",
            "x-nullable": true
          },
          "amount": {
            "description": "取引金額です。**税込**金額になります。\n請求モードの設定によって値が変わります。\n- 区分記載請求書モード：TransactionPayload.amountで指定した金額\n- インボイスモード（請求単位）：弊社システムにて算出した金額\n- インボイスモード（取引単位）：TransactionPayload.amountで指定した金額\n",
            "example": 2180,
            "type": "integer"
          },
          "amounts_per_tax_rate_type": {
            "description": "各税率種別毎の**税込**の合計金額です。\n請求モードの設定によって値が変わります。各税率種別の取引明細行の小計を合計した値の税込金額になっています。\n- 区分記載請求書モード：TransactionPayload.amounts_per_tax_rate_typeで指定した金額\n- インボイスモード（請求単位）：空の配列\n- インボイスモード（取引単位）：TransactionPayload.amounts_per_tax_rate_typeで指定した金額\n",
            "items": {
              "$ref": "#/components/schemas/AmountPerTaxRateType"
            },
            "type": "array"
          },
          "billing": {
            "description": "請求対象であるかをboolean値で表します。`true`の場合請求対象で、`false`の場合は請求対象ではないことを表します。",
            "example": true,
            "type": "boolean",
            "x-nullable": true
          },
          "billing_accepted_at": {
            "description": "請求依頼受領日時です。請求対象になった日時を表します。請求対象でない場合は空になります。",
            "example": "2019-04-22T10:36:43+09:00",
            "format": "date-time",
            "type": "string",
            "x-nullable": true
          },
          "billing_condition": {
            "$ref": "#/components/schemas/BillingCondition"
          },
          "billing_id": {
            "description": "請求IDです。請求書にまとめられる単位のIDです。同じ請求IDを持つ取引とまとめられて請求書に記載されます。",
            "example": "9R6M-VMAN",
            "type": "string"
          },
          "canceled_at": {
            "description": "取引がキャンセルされた日時です。未キャンセルの場合は空になります。",
            "example": "2019-04-22T10:36:43+09:00",
            "format": "date-time",
            "type": "string",
            "x-nullable": true
          },
          "canceled_transaction_id": {
            "description": "先行してキャンセルし与信に利用したキャンセル済み取引のIDです。キャンセル取引を利用していない場合は空になります。",
            "example": "79NR-9WR6",
            "type": "string",
            "x-nullable": true
          },
          "created_at": {
            "description": "取引が登録された日時です。",
            "example": "2019-04-01T10:36:43+09:00",
            "format": "date-time",
            "type": "string"
          },
          "customer_id": {
            "description": "顧客IDです。",
            "example": "9PNG-VYR6",
            "type": "string"
          },
          "date": {
            "description": "取引日です。売り手様と顧客様の間で取引を行った日付です。",
            "example": "2019-04-01",
            "format": "date",
            "type": "string"
          },
          "destination_id": {
            "description": "請求先IDです。取引の請求先を示します。",
            "example": "WNAV-37R6",
            "type": "string"
          },
          "due_date": {
            "description": "支払期限です。この日付を超えて入金が確認できない場合は未入金になります。",
            "example": "2019-04-30",
            "format": "date",
            "type": "string"
          },
          "id": {
            "description": "取引IDです。一意の識別子として自動で付与されます。",
            "example": "7679-YW36",
            "type": "string"
          },
          "invoice_delivery_methods": {
            "description": "請求書送付方法です。郵送(posting) またはメール送付(email)のうちから少なくとも１つになります。どちらも選択された場合、どちらの方法でも送付されます。 また、各取引で指定しなかった送付方法でも、請求にまとまった取引のうちでその送付方法を選択しているものがあれば、そちらの送付方法も採用されます。",
            "example": [
              "posting",
              "email"
            ],
            "items": {
              "$ref": "#/components/schemas/InvoiceDeliveryMethod"
            },
            "type": "array"
          },
          "issue_date": {
            "description": "請求書発行日です。請求書発送日については<a href=\"https://support.mfkessai.co.jp/hc/ja/articles/900002297303-%E8%AB%8B%E6%B1%82%E6%9B%B8%E7%99%BA%E8%A1%8C%E6%97%A5%E3%81%AB%E3%81%A4%E3%81%84%E3%81%A6\" target=\"_blank\">請求書発行日について</a>を参照ください。",
            "example": "2019-04-20",
            "format": "date",
            "type": "string"
          },
          "number": {
            "description": "取引に付与できる任意の取引番号です。本サービスが自動で付与する取引IDとは別で、売り手様が独自に管理する識別子を登録することができます。ただし、売り手様の所有する取引間で一意である必要があります。",
            "example": "Transaction-0001",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`transaction`が入ります。",
            "enum": [
              "transaction"
            ],
            "example": "transaction",
            "type": "string"
          },
          "offset_at": {
            "description": "譲受した債権の相殺日時です。（本フィールドはマイナス取引の場合に埋まることがあります。0円以下の取引登録をご希望の場合は営業担当までご連絡ください。）",
            "example": "2019-04-03T10:36:43+09:00",
            "format": "date-time",
            "type": "string",
            "x-nullable": true
          },
          "status": {
            "description": "取引ステータスです。審査中(`unexamined`)、審査通過(`passed`)、審査否決(`rejected`)、キャンセル済(`canceled`)、審査対象外(`examination_exempt`)があります。",
            "enum": [
              "unexamined",
              "passed",
              "rejected",
              "canceled",
              "examination_exempt"
            ],
            "example": "passed",
            "type": "string"
          },
          "transaction_details": {
            "description": "取引明細行です。",
            "items": {
              "$ref": "#/components/schemas/TransactionDetail"
            },
            "type": "array"
          },
          "uri": {
            "description": "取引URIです。すべてのリソースで一意の識別子として自動で付与されます。",
            "example": "mfk:transaction:7679-YW36",
            "type": "string"
          }
        },
        "type": "object"
      },
      "TransactionDetail": {
        "description": "取引明細です。請求書に記載される明細行になります。",
        "example": {
          "amount": 3000,
          "description": "商品名A",
          "quantity": 3,
          "tax_rate_type": "normal_10",
          "unit_price": 1000
        },
        "properties": {
          "amount": {
            "description": "小計です。単価(`unit_price`)×数量(`quantity`)の金額、またはその税込金額です。",
            "example": 12000,
            "type": "number"
          },
          "description": {
            "description": "商品名などです。",
            "example": "商品名A",
            "type": "string"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず`transaction_detail`が入ります。",
            "enum": [
              "transaction_detail"
            ],
            "example": "transaction_detail",
            "type": "string"
          },
          "quantity": {
            "description": "数量です。",
            "example": 3,
            "type": "number"
          },
          "tax_included_type": {
            "$ref": "#/components/schemas/TaxIncludedType"
          },
          "tax_rate_type": {
            "$ref": "#/components/schemas/TaxRateType"
          },
          "unit_price": {
            "description": "単価です。",
            "example": 1000,
            "type": "number"
          }
        },
        "type": "object"
      },
      "TransactionDetailPayload": {
        "example": {
          "amount": 3000,
          "description": "商品名A",
          "quantity": 3,
          "tax_included_type": "excluded",
          "tax_rate_type": "normal_10",
          "unit_price": 1000
        },
        "properties": {
          "amount": {
            "description": "小計です。単価(`unit_price`)×数量(`quantity`)の金額を指定してください。またはその金額の税込金額も指定可能です。",
            "example": 12000,
            "maximum": 2147483647,
            "minimum": -2147483648,
            "multipleOf": 0.0001,
            "type": "number"
          },
          "amount_str": {
            "description": "小計を文字列で指定してください。こちらが指定されている場合、数値型のamountは無視されます。単価(`unit_price`)×数量(`quantity`)の金額を指定してください。",
            "example": "12000.5",
            "maxLength": 16,
            "minLength": 1,
            "pattern": "^-?\\d+(\\.\\d{1,4})?$",
            "type": "string"
          },
          "description": {
            "description": "商品名などです。<br>Sandbox環境において取引審査で任意の結果を指定するためにこの値を用います。詳しくは[審査結果の操作](#environment_magic_number)を参照ください。",
            "example": "商品名A",
            "maxLength": 250,
            "minLength": 1,
            "type": "string"
          },
          "quantity": {
            "description": "数量を指定してください。",
            "example": 3,
            "maximum": 2147483647,
            "minimum": -2147483648,
            "multipleOf": 0.0001,
            "type": "number"
          },
          "quantity_str": {
            "description": "数量を文字列で指定してください。こちらが指定されている場合、数値型のquantityは無視されます。",
            "example": "3.14",
            "maxLength": 16,
            "minLength": 1,
            "pattern": "^-?\\d+(\\.\\d{1,4})?$",
            "type": "string"
          },
          "tax_included_type": {
            "$ref": "#/components/schemas/TaxIncludedType"
          },
          "tax_rate_type": {
            "$ref": "#/components/schemas/TaxRateType"
          },
          "unit_price": {
            "description": "単価を指定してください。",
            "example": 1000,
            "maximum": 2147483647,
            "minimum": -2147483648,
            "multipleOf": 0.0001,
            "type": "number"
          },
          "unit_price_str": {
            "description": "単価を文字列で指定してください。こちらが指定されている場合、数値型のunit_priceは無視されます。",
            "example": "1.5",
            "maxLength": 16,
            "minLength": 1,
            "pattern": "^-?\\d+(\\.\\d{1,4})?$",
            "type": "string"
          }
        },
        "required": [
          "description",
          "tax_included_type",
          "tax_rate_type"
        ],
        "type": "object"
      },
      "TransactionPayload": {
        "description": "取引登録情報です。取引登録で利用します。",
        "example": {
          "amount": 5440,
          "amounts_per_tax_rate_type": [
            {
              "amount": 2200,
              "tax_rate_type": "normal_10"
            },
            {
              "amount": 3240,
              "tax_rate_type": "reduced_8"
            }
          ],
          "authorization_id": "WNAV-37R6",
          "billing_condition": "passed",
          "canceled_transaction_id": "79NR-9WR6",
          "date": "2019-04-10",
          "destination_id": "WNAV-37R6",
          "due_date": "2019-04-30",
          "invoice_delivery_methods": [
            "posting",
            "email"
          ],
          "issue_date": "2019-04-20",
          "number": "Transaction-0001",
          "transaction_details": [
            {
              "amount": 3000,
              "description": "商品名A",
              "quantity": 3,
              "tax_included_type": "excluded",
              "tax_rate_type": "normal_10",
              "unit_price": 1000
            },
            {
              "amount": 3000,
              "description": "商品名B",
              "quantity": 3,
              "tax_included_type": "excluded",
              "tax_rate_type": "reduced_8",
              "unit_price": 1000
            },
            {
              "amount": -1000,
              "description": "商品名A 返品",
              "quantity": 1,
              "tax_included_type": "excluded",
              "tax_rate_type": "normal_10",
              "unit_price": -1000
            }
          ]
        },
        "properties": {
          "amount": {
            "description": "取引の税込合計金額です。各課税種別毎の税込金額(amounts_per_tax_rate_type)の合計である必要があります。\n複数取引が請求としてまとまる際に請求金額が2147483647円を超えないようにする必要があります。\n請求モードの設定によって項目の要否が変わります。\n- 区分記載請求書モード：必須項目\n- インボイスモード（請求単位）：任意項目\n- インボイスモード（取引単位）：必須項目\n\nマイナス取引設定が有効な場合、0円以下の値も指定可能です。マイナス取引設定が有効でない場合は1円以上の値を指定する必要があります。\nまた、マイナス取引設定が有効な場合でも月間の取引金額があらかじめ設定されている売り手様ごとの下限を下回らないようにする必要があります。\n0円以下の取引登録をご希望の場合は営業担当までご連絡ください。\n",
            "example": 5000,
            "maximum": 2147483647,
            "minimum": -2147483648,
            "type": "integer",
            "x-nullable": true
          },
          "amounts_per_tax_rate_type": {
            "description": "各課税種別毎の税込の合計金額です。各課税種別の取引明細行の小計を合計した値の税込金額になっていなければなりません。\n請求モードの設定によって項目の要否が変わります。\n- 区分記載請求書モード：必須項目\n- インボイスモード（請求単位）：任意項目\n- インボイスモード（取引単位）：必須項目\n",
            "example": [
              {
                "amount": 1100,
                "tax_rate_type": "normal_10"
              },
              {
                "amount": 1080,
                "tax_rate_type": "reduced_8"
              }
            ],
            "items": {
              "$ref": "#/components/schemas/AmountPerTaxRateType"
            },
            "minItems": 1,
            "type": "array",
            "x-nullable": true
          },
          "authorization_id": {
            "description": "オーソリゼーションIDです。事前に取得したオーソリゼーションを指定してください。利用できないオーソリゼーションである場合は取引登録もできません。 `canceled_transaction_id`と同時に指定はできません。",
            "example": "WNAV-37R6",
            "minLength": 1,
            "type": "string"
          },
          "billing_condition": {
            "$ref": "#/components/schemas/BillingCondition"
          },
          "canceled_transaction_id": {
            "description": "先行してキャンセルした取引のIDです。与信に利用するキャンセル済み取引を指定します。指定された場合、キャンセル済み取引の与信を利用して審査を行います。利用できないキャンセル取引である場合は取引登録もできません。 `authorization_id`と同時に指定はできません。（本フィールドを利用する場合は審査が必要になります。利用をご希望の場合は営業担当までご連絡ください。）",
            "example": "79NR-9WR6",
            "minLength": 1,
            "type": "string"
          },
          "date": {
            "description": "取引日です。売り手様と顧客の間で取引を行った日付を指定してください。",
            "example": "2019-04-01",
            "format": "date",
            "type": "string"
          },
          "destination_id": {
            "description": "請求先IDです。取引の請求先を指定してください。",
            "example": "WNAV-37R6",
            "minLength": 1,
            "type": "string"
          },
          "due_date": {
            "description": "支払期限です。<br>取引登録時の制約事項については<a href=\"https://support.mfkessai.co.jp/hc/ja/articles/900002212123\" target=\"_blank\">サポートページ</a>を確認してください。",
            "example": "2019-04-30",
            "format": "date",
            "type": "string"
          },
          "invoice_delivery_methods": {
            "description": "請求書送付方法です。郵送(posting) またはメール送付(email)のうちから少なくとも１つを指定してください。どちらも選択された場合、どちらの方法でも送付されます。 また、各取引で指定しなかった送付方法でも、請求にまとまった取引のうちでその送付方法を選択しているものがあれば、そちらの送付方法も採用されます。",
            "example": [
              "posting",
              "email"
            ],
            "items": {
              "$ref": "#/components/schemas/InvoiceDeliveryMethod"
            },
            "maxItems": 2,
            "minItems": 1,
            "type": "array"
          },
          "issue_date": {
            "description": "請求書発行日です。請求書が発行される日付を指定します。指定した日付が営業日でない場合は翌営業日になります。また、請求書送付日については<a href=\"https://support.mfkessai.co.jp/hc/ja/articles/900002297303\" target=\"_blank\">こちら</a>を参照ください。<br> 取引登録時の制約事項については<a href=\"https://support.mfkessai.co.jp/hc/ja/articles/900002212123\" target=\"_blank\">サポートページ</a>を確認してください。",
            "example": "2019-04-20",
            "format": "date",
            "type": "string"
          },
          "number": {
            "description": "取引に付与できる任意の取引番号です。本サービスが自動で付与する取引IDとは別で、売り手様が独自に管理する識別子を登録することができます。ただし、売り手様の所有する取引間で一意である必要があります。",
            "example": "Transaction-0001",
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "transaction_details": {
            "description": "取引明細行です。",
            "example": [
              {
                "amount": 3000,
                "description": "商品名A",
                "quantity": 3,
                "tax_included_type": "excluded",
                "tax_rate_type": "normal_8",
                "unit_price": 1000
              },
              {
                "amount": 3000,
                "description": "商品名B",
                "quantity": 3,
                "tax_included_type": "excluded",
                "tax_rate_type": "reduced_8",
                "unit_price": 1000
              },
              {
                "amount": -1000,
                "description": "商品名A 返品",
                "quantity": 1,
                "tax_included_type": "excluded",
                "tax_rate_type": "normal_8",
                "unit_price": -1000
              }
            ],
            "items": {
              "$ref": "#/components/schemas/TransactionDetailPayload"
            },
            "maxItems": 500,
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "date",
          "destination_id",
          "due_date",
          "invoice_delivery_methods",
          "issue_date",
          "number",
          "transaction_details"
        ],
        "type": "object"
      },
      "TransactionsList": {
        "properties": {
          "items": {
            "description": "取引一覧です。",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            },
            "type": "array"
          },
          "object": {
            "description": "このObjectの種別を示します。ここでは必ず `list`が設定されます。",
            "enum": [
              "list"
            ],
            "example": "list",
            "type": "string"
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        },
        "type": "object"
      },
      "UploadSignedURL": {
        "example": {
          "expires_at": "2023-03-08T10:36:43+09:00",
          "url": "https://upload.mfk.jp/billings/7679-YW36/billing_files?signature=mfkrandomsignature"
        },
        "properties": {
          "expires_at": {
            "description": "ファイルアップロード用の署名付きURLの有効期限です。",
            "example": "2023-03-08T10:36:43+09:00",
            "format": "date-time",
            "type": "string"
          },
          "url": {
            "description": "ファイルアップロード用の署名付きURLです。",
            "example": "https://upload.mfk.jp/billings/7679-YW36/billing_files?signature=mfkrandomsignature",
            "type": "string"
          }
        },
        "type": "object"
      },
      "UploadSignedUrlPayload": {
        "example": {
          "content_type": "application/pdf"
        },
        "properties": {
          "content_type": {
            "description": "アップロードするファイルのメディアタイプです。MIME タイプに準拠した文字列を指定します。<br> 値は `application/pdf`, `application/json`, `text/csv`, `text/plain` の中から指定します。",
            "enum": [
              "application/pdf",
              "application/json",
              "text/csv",
              "text/plain"
            ],
            "type": "string"
          }
        },
        "required": [
          "content_type"
        ],
        "type": "object"
      },
      "ZipCode": {
        "description": "郵便番号です。ハイフン有無は任意になります。但しハイフン無しで登録されますと、請求書にもハイフン無しで記載されます。",
        "example": "111-1111",
        "pattern": "^\\d{3}-?\\d{4}$",
        "type": "string"
      }
    },
    "parameters": {
      "after": {
        "name": "after",
        "in": "query",
        "description": "任意のリソースIDを指定します。追加日時の降順でこのIDのリソースよりも後のリソースを取得します。この時`after`で指定したIDのリソースは結果に含まれません。",
        "schema": {
          "type": "string"
        }
      },
      "before": {
        "name": "before",
        "in": "query",
        "description": "任意のリソースIDを指定します。追加日時の降順でこのIDのリソースよりも前のリソースを取得します。この時`before`で指定したIDのリソースは結果に含まれません。",
        "schema": {
          "type": "string"
        }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "description": "取得したいリソースの最大件数を指定します。1~200の間の整数で指定してください。指定がない場合は20になります。",
        "schema": {
          "type": "integer",
          "format": "int32",
          "minimum": 1,
          "maximum": 200
        }
      }
    }
  },
  "paths": {
    "/authorizations": {
      "get": {
        "tags": [
          "Authorization"
        ],
        "summary": "オーソリゼーション登録の一覧を取得します。顧客IDや番号で絞り込んで取得することもできます。",
        "description": "オーソリゼーション一覧取得",
        "operationId": "GetAuthorizationsList",
        "parameters": [
          {
            "name": "customer_id",
            "in": "query",
            "description": "顧客IDを指定します。指定された顧客のオーソリゼーションを取得します。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "number",
            "in": "query",
            "description": "オーソリゼーション番号を指定します。 指定されたオーソリゼーションを取得します。",
            "schema": {
              "type": "string",
              "maxLength": 100
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "ステータスを指定します。該当するステータスのオーソリゼーションが返却されます。指定できる値は `active`(有効), `expired`(期限切れ), `captured`(確定済),　`canceled`(キャンセル済) の4種類のみです。",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "expired",
                "captured",
                "canceled"
              ]
            }
          },
          {
            "name": "created_at_from",
            "in": "query",
            "description": "指定された日時以降に作成されたオーソリゼーションを取得します。指定された日時に作成されたものも含まれます。 RFC3339の`date-time`(2019-04-01T10:36:43%2B09:00)で指定してください。",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created_at_to",
            "in": "query",
            "description": "指定された日時以前に作成されたオーソリゼーションを取得します。指定された日時に作成されたものも含まれます。 RFC3339の`date-time`(2019-04-01T10:36:43%2B09:00)で指定してください。",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "$ref": "#/components/parameters/after"
          },
          {
            "$ref": "#/components/parameters/before"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "オーソリゼーション一覧とページネーション情報です。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizationsList"
                }
              }
            }
          },
          "400": {
            "description": "リクエスト内容の不備によるエラーです。エラー内容を確認してください。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Authorization"
        ],
        "summary": "顧客と金額を指定してオーソリゼーションを登録します。",
        "description": "オーソリゼーション登録",
        "operationId": "CreateAuthorization",
        "requestBody": {
          "description": "オーソリゼーション登録情報です。",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizationPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登録されたオーソリゼーションが返却されます。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Authorization"
                }
              }
            }
          },
          "400": {
            "description": "リクエスト内容の不備によるエラーです。エラー内容を確認してください。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          },
          "404": {
            "description": "顧客IDで指定した顧客が存在しない場合のエラーです。Errorのparamには指定した顧客IDが入ります。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          },
          "409": {
            "description": "登録しようとしたと一致するオーソリゼーションが既に登録されている場合のエラーです。指定した`number`が既に登録済みでないか確認してください。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          }
        }
      }
    },
    "/authorizations/{authorization_id}": {
      "parameters": [
        {
          "name": "authorization_id",
          "in": "path",
          "description": "対象のオーソリゼーションIDを指定してください。",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "tags": [
          "Authorization"
        ],
        "summary": "オーソリゼーションIDを指定して対象オーソリゼーション１件を取得することができます。",
        "description": "オーソリゼーション取得",
        "operationId": "GetAuthorization",
        "responses": {
          "200": {
            "description": "指定したオーソリゼーションが返却されます。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Authorization"
                }
              }
            }
          },
          "400": {
            "description": "リクエスト内容の不備によるエラーです。エラー内容を確認してください。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          },
          "404": {
            "description": "オーソリゼーションIDで指定したオーソリゼーションが存在しない場合のエラーです。Errorのparamには指定したオーソリゼーションIDが入ります。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Authorization"
        ],
        "summary": "オーソリゼーションの状態によってはキャンセルができない場合もあります。",
        "description": "オーソリゼーションキャンセル",
        "operationId": "CancelAuthorization",
        "responses": {
          "200": {
            "description": "キャンセルしたオーソリゼーションが返却されます。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Authorization"
                }
              }
            }
          },
          "400": {
            "description": "リクエスト内容の不備によるエラーです。エラー内容を確認してください。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          },
          "409": {
            "description": "キャンセルしようとしたオーソリゼーションがキャンセルできない状態の場合のエラーです。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          }
        }
      }
    },
    "/billings": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "区分記載請求書等保存方式に対応した請求一覧を取得します。",
        "description": "請求一覧取得",
        "operationId": "GetBillingsList",
        "parameters": [
          {
            "name": "customer_id",
            "in": "query",
            "description": "任意の顧客IDを指定します。指定した顧客への請求が返却されます。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "customer_number",
            "in": "query",
            "description": "顧客番号を指定します。指定された顧客の請求を取得します。",
            "schema": {
              "type": "string",
              "maxLength": 100
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "請求ステータスを指定します。該当するステータスの請求が返却されます。複数指定することが可能です。指定できる値は `scheduled`(請求予定), `invoice_issued`(請求書発行済), `account_transfer_notified`(口座振替通知済)の3種類のみです。",
            "schema": {
              "type": "array",
              "items": {
                "enum": [
                  "scheduled",
                  "invoice_issued",
                  "account_transfer_notified"
                ],
                "type": "string"
              }
            }
          },
          {
            "name": "due_date_from",
            "in": "query",
            "description": "日付を指定します。指定した日付以降の支払期限となっている請求を取得できます。指定された日付のものも含まれます。",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "due_date_to",
            "in": "query",
            "description": "日付を指定します。指定した日付以前の支払期限となっている請求を取得できます。指定された日付のものも含まれます。",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "issue_date_from",
            "in": "query",
            "description": "日付を指定します。指定した日付以降の請求書発行日となっている請求を取得できます。指定された日付のものも含まれます。",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "issue_date_to",
            "in": "query",
            "description": "日付を指定します。指定した日付以前の請求書発行日となっている請求を取得できます。指定された日付のものも含まれます。",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "unpaid",
            "in": "query",
            "description": "未入金のあり(`true`)、なし(`false`)を指定します。空文字が指定された場合、`false`として扱われます。",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "invoice_id",
            "in": "query",
            "description": "任意の請求書IDを指定します。指定した請求書に紐付く請求が返却されます。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "account_transfer_notification_id",
            "in": "query",
            "description": "任意の口座振替通知書IDを指定します。指定した口座振替通知書に紐付く請求が返却されます。",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/after"
          },
          {
            "$ref": "#/components/parameters/before"
          },
          {
            "$ref": "#/components/parameters/limit"
          }
        ],
        "responses": {
          "200": {
            "description": "請求一覧とページネーション情報です。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillingsList"
                }
              }
            }
          },
          "400": {
            "description": "リクエスト内容の不備によるエラーです。エラー内容を確認してください。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          }
        }
      }
    },
