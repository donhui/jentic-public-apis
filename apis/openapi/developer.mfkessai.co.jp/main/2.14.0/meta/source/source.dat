    "/billings/{billing_id}": {
      "parameters": [
        {
          "name": "billing_id",
          "in": "path",
          "description": "対象の請求IDを指定してください。",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "請求IDを指定して請求を取得します。インボイスモードでは請求対象の取引がなくなった請求や、審査中の取引のみを含む請求も取得できます。",
        "description": "請求取得",
        "operationId": "GetBilling",
        "responses": {
          "200": {
            "description": "指定した請求が返却されます。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Billing"
                }
              }
            }
          },
          "400": {
            "description": "リクエスト内容の不備によるエラーです。エラー内容を確認してください。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          },
          "404": {
