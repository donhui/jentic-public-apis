      "CustomerPayload": {
        "description": "顧客登録情報です。顧客登録時に利用します。顧客には必ず一つの請求先が必要であるため同時に請求先一件も登録します。",
        "properties": {
          "customer_examination": {
            "description": "与信枠審査申請情報です。与信枠審査申請で利用します",
            "example": {
              "amount": 20000,
              "business_description": "クラウド型企業間決済サービス",
              "business_type": "corporate",
              "corporate_number": "1234567890123",
              "examinee": {
                "address1": "東京都千代田区1-2-3",
                "address2": "サンプルビル3F",
                "email": "kessai.tanto@example.jp",
                "tel": "03-1234-5678",
                "zip_code": "111-1111"
              },
              "initial_amount": 50000,
              "remark": "一部上場企業です。",
              "representative_name": "代表太郎",
              "website": "https://mfkessai.co.jp"
            },
            "properties": {
              "amount": {
                "description": "希望与信額です。審査通過の場合に付与される与信枠の金額になります。 現在与信枠が適用中の場合は、その与信額未満の金額は指定できません。0円を指定した場合は無視されます。 審査の結果減額されて与信枠付与されることもあります。",
                "example": 200000,
                "maximum": 150000000,
                "minimum": 1,
                "type": "integer"
              },
              "business_description": {
                "description": "事業内容です。顧客の主なサービス、商材などを記載してください。",
                "example": "クラウド型企業間決済サービス",
                "maxLength": 500,
                "type": "string"
              },
              "business_type": {
                "description": "事業所区分です。法人(`corporate`)または、個人(`individual`)で指定してください。不明な場合は空にしてください。",
                "enum": [
                  "corporate",
                  "individual"
                ],
                "example": "corporate",
                "type": "string"
              },
              "corporate_number": {
                "description": "法人番号です。事業所区分(`business_type`)が法人(`corporate`)の場合にのみ指定してください。",
                "example": "1234567890123",
                "pattern": "^\\d{13}$",
                "type": "string"
              },
              "examinee": {
                "description": "与信枠審査時顧客情報です。指定する場合はaddress2以外は必須項目となります。",
                "properties": {
                  "address1": {
                    "$ref": "#/components/schemas/Address1"
                  },
                  "address2": {
                    "$ref": "#/components/schemas/Address2"
                  },
                  "email": {
                    "$ref": "#/components/schemas/Email"
                  },
                  "tel": {
                    "$ref": "#/components/schemas/Tel"
                  },
                  "zip_code": {
                    "$ref": "#/components/schemas/ZipCode"
                  }
                },
                "required": [
                  "zip_code",
                  "address1",
                  "email",
                  "tel"
                ],
                "type": "object"
              },
              "initial_amount": {
                "description": "初月希望与信額です。初月希望与信額については<a href=\"https://support.mfkessai.co.jp/hc/ja/articles/900002208763\" target=\"_blank\">サポートページ</a>を確認してください。 0円を指定した場合は無視されます。審査の結果減額されて与信枠付与されることもあります。",
                "example": 500000,
                "maximum": 150000000,
                "minimum": 1,
                "type": "integer"
              },
              "remark": {
                "description": "与信枠審査に利用できるその他情報を記載できます。",
                "example": "一部上場企業です。",
                "maxLength": 500,
                "type": "string"
              },
              "representative_name": {
                "description": "代表者氏名です。",
                "example": "代表太郎",
                "maxLength": 30,
                "type": "string"
              },
              "website": {
                "description": "顧客企業のwebサイトです。",
                "example": "https://mfkessai.co.jp",
                "maxLength": 500,
                "pattern": "^https?://(www\\.)?[-a-zA-Z0-9@:%._+~#=]{1,256}\\.[a-zA-Z0-9()]{1,9}\\b([-a-zA-Z0-9()@:%_+.~#?&/=]*)$",
                "type": "string"
              }
            },
            "type": "object"
          },
          "destination": {
            "description": "請求先情報です。",
            "example": {
              "address1": "東京都千代田区1-2-3",
              "address2": "サンプルビル3F",
              "cc_emails": [
                "another.tanto1@example.jp",
                "another.tanto2@example.jp"
              ],
              "department": "経理部",
              "email": "kessai.tanto@example.jp",
              "name": "担当 太郎",
              "name_kana": "タントウ　タロウ",
              "tel": "03-1234-5678",
              "title": "部長",
              "zip_code": "111-1111"
            },
            "properties": {
              "address1": {
                "$ref": "#/components/schemas/Address1"
              },
              "address2": {
                "$ref": "#/components/schemas/Address2"
              },
              "cc_emails": {
                "description": "請求書をメール送付する際のCCメールアドレスです。最大で4つまで指定できます。",
                "example": [
                  "another.tanto1@example.jp",
                  "another.tanto2@example.jp"
                ],
                "items": {
                  "$ref": "#/components/schemas/Email"
                },
                "maxItems": 4,
                "type": "array"
              },
              "department": {
                "description": "担当者の部署名です。",
                "example": "経理部",
                "maxLength": 50,
                "type": "string"
              },
              "email": {
                "$ref": "#/components/schemas/Email"
              },
              "name": {
                "description": "担当者氏名です。",
                "example": "担当　太郎",
                "maxLength": 30,
                "type": "string"
              },
              "name_kana": {
                "description": "担当者名カナです。全角カタカナで入力してください。",
                "example": "タントウ　タロウ",
                "maxLength": 60,
                "type": "string"
              },
              "tel": {
                "$ref": "#/components/schemas/Tel"
              },
              "title": {
                "description": "担当者の役職です。",
                "example": "部長",
                "maxLength": 30,
                "type": "string"
              },
              "zip_code": {
                "$ref": "#/components/schemas/ZipCode"
              }
            },
            "required": [
              "address1",
              "email",
              "tel",
              "zip_code"
            ],
            "type": "object"
          },
          "name": {
            "description": "顧客名です。",
            "example": "サンプル顧客",
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "number": {
            "description": "顧客に付与できる任意の顧客番号です。本サービスが発番する顧客IDとは別で、売り手様が独自に管理する識別子を登録することができます。 ただし、売り手様の所有する顧客間で一意である必要があります。",
            "example": "CUSTOMER0001",
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "destination",
          "name",
          "number"
        ],
        "type": "object"
      },
