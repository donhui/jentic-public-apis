                "example": 10000,
                "type": "integer",
                "x-nullable": true
              }
            },
            "type": "object"
          },
          "taxable": {
            "description": "課税対象の控除金額とその内訳です。郵送料と月額基本料が課税対象となります。",
            "properties": {
              "amount": {
                "description": "課税対象の控除金額です。",
