              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Environments"],
        "operationId": "deleteEnvironment",
        "summary": "Delete an environment",
        "description": "Permanently delete an environment from a project.",
        "parameters": [
          {
            "name": "project",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The project's name"
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The environment's slug"
