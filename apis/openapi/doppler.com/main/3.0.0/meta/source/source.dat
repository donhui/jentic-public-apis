        "description": "Retrieve a paginated list of configs for a project.",
        "parameters": [
          {
            "name": "project",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Project identifier"
          },
          {
            "name": "environment",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Environment slug to filter by"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
