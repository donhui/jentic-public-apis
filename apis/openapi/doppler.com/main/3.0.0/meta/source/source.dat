      "put": {
        "tags": ["Environments"],
        "operationId": "renameEnvironment",
        "summary": "Rename an environment",
        "description": "Rename an existing environment.",
        "parameters": [
          {
            "name": "project",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The project's name"
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The environment's slug"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "description": "Desired name" },
                  "slug": { "type": "string", "description": "Desired slug" },
                  "personal_configs": { "type": "boolean", "description": "Whether or not to enable personal configs" }
