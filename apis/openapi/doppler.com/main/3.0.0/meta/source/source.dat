              }
            }
          }
        }
      },
      "post": {
        "tags": ["Configs"],
        "operationId": "createConfig",
        "summary": "Create a config",
        "description": "Create a new branch config within a project and environment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
