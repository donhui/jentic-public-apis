{
  "openapi": "3.0.3",
  "info": {
    "title": "Doppler API",
    "description": "Doppler is a secrets management platform that enables teams to centrally manage and securely access secrets across applications, environments, and infrastructure.",
    "version": "3.0.0",
    "x-jentic-source-url": "https://docs.doppler.com/reference/api"
  },
  "servers": [
    {
      "url": "https://api.doppler.com/v3"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Projects", "description": "Manage projects" },
    { "name": "Environments", "description": "Manage environments within projects" },
    { "name": "Configs", "description": "Manage configs within projects" },
    { "name": "Secrets", "description": "Manage secrets within configs" },
    { "name": "ConfigLogs", "description": "View and rollback config change logs" },
    { "name": "ActivityLogs", "description": "View workplace activity logs" },
    { "name": "Workplace", "description": "Manage workplace settings" },
    { "name": "ServiceTokens", "description": "Manage service tokens for configs" },
    { "name": "DynamicSecrets", "description": "Manage dynamic secret leases" },
    { "name": "Integrations", "description": "Manage third-party integrations" },
    { "name": "Syncs", "description": "Manage secrets syncs to third-party platforms" },
    { "name": "TrustedIPs", "description": "Manage trusted IP addresses for configs" },
    { "name": "Groups", "description": "Manage workplace groups and memberships" },
    { "name": "ServiceAccounts", "description": "Manage service accounts" },
    { "name": "Webhooks", "description": "Manage webhooks" }
  ],
  "paths": {
    "/projects": {
      "get": {
        "tags": ["Projects"],
        "operationId": "listProjects",
        "summary": "List projects",
        "description": "Retrieve a paginated list of all projects in the workplace.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 20 },
            "description": "Items per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectsListResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Projects"],
        "operationId": "createProject",
        "summary": "Create a project",
        "description": "Create a new project in the workplace.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "description": "Project name" },
                  "description": { "type": "string", "description": "Project description" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/projects/project": {
      "get": {
        "tags": ["Projects"],
        "operationId": "getProject",
        "summary": "Retrieve a project",
        "description": "Retrieve details of a specific project.",
        "parameters": [
          {
            "name": "project",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Unique identifier for the project"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Projects"],
        "operationId": "updateProject",
        "summary": "Update a project",
        "description": "Update an existing project's name or description.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["project", "name"],
                "properties": {
                  "project": { "type": "string", "description": "Unique identifier for the project" },
                  "name": { "type": "string", "description": "New project name" },
                  "description": { "type": "string", "description": "New project description" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Projects"],
        "operationId": "deleteProject",
        "summary": "Delete a project",
        "description": "Permanently delete a project and all its associated data.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["project"],
                "properties": {
                  "project": { "type": "string", "description": "Unique identifier for the project" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/environments": {
      "get": {
        "tags": ["Environments"],
        "operationId": "listEnvironments",
        "summary": "List environments",
        "description": "Retrieve a list of all environments for a project.",
        "parameters": [
          {
            "name": "project",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
