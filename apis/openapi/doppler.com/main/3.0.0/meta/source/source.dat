  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Use a Doppler service token or personal token as the bearer token."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Array of error messages"
          },
          "success": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique project identifier" },
          "slug": { "type": "string", "description": "URL-safe project slug" },
          "name": { "type": "string", "description": "Project name" },
          "description": { "type": "string", "description": "Project description" },
          "created_at": { "type": "string", "format": "date-time", "description": "Timestamp when the project was created" }
        }
      },
      "ProjectResponse": {
        "type": "object",
        "properties": {
          "project": { "$ref": "#/components/schemas/Project" }
        }
      },
      "ProjectsListResponse": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "description": "Current page number" },
          "projects": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Project" }
          }
        }
      },
      "Environment": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique environment identifier" },
          "name": { "type": "string", "description": "Environment name" },
          "slug": { "type": "string", "description": "URL-safe environment slug" },
          "initial_fetch_at": { "type": "string", "format": "date-time", "description": "Timestamp of the first secrets fetch" },
          "created_at": { "type": "string", "format": "date-time", "description": "Timestamp when the environment was created" },
          "project": { "type": "string", "description": "Project identifier the environment belongs to" }
        }
      },
      "EnvironmentResponse": {
        "type": "object",
        "properties": {
          "environment": { "$ref": "#/components/schemas/Environment" }
        }
      },
      "EnvironmentsListResponse": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "description": "Current page number" },
          "environments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Environment" }
          }
        }
      },
      "Config": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Config name" },
          "root": { "type": "boolean", "description": "Whether this is a root config" },
          "locked": { "type": "boolean", "description": "Whether the config is locked" },
          "initial_fetch_at": { "type": "string", "format": "date-time", "description": "Timestamp of the first secrets fetch" },
          "last_fetch_at": { "type": "string", "format": "date-time", "description": "Timestamp of the most recent secrets fetch" },
          "created_at": { "type": "string", "format": "date-time", "description": "Timestamp when the config was created" },
          "environment": { "type": "string", "description": "Environment slug" },
          "project": { "type": "string", "description": "Project identifier" }
        }
      },
      "ConfigResponse": {
        "type": "object",
        "properties": {
          "config": { "$ref": "#/components/schemas/Config" }
        }
      },
      "ConfigsListResponse": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "description": "Current page number" },
          "configs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Config" }
          }
        }
      },
      "SecretValue": {
        "type": "object",
        "properties": {
          "raw": { "type": "string", "description": "Raw secret value as set by the user" },
          "computed": { "type": "string", "description": "Computed secret value after resolving references" },
          "note": { "type": "string", "description": "Note attached to the secret" },
          "rawVisibility": { "type": "string", "description": "Visibility of the raw value" },
          "computedVisibility": { "type": "string", "description": "Visibility of the computed value" }
        }
      },
      "SecretsListResponse": {
        "type": "object",
        "properties": {
          "secrets": {
            "type": "object",
            "additionalProperties": { "$ref": "#/components/schemas/SecretValue" },
            "description": "Map of secret names to their values"
          }
        }
      },
      "SecretResponse": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Secret name" },
          "value": {
            "type": "object",
            "properties": {
              "raw": { "type": "string", "description": "Raw secret value" },
              "computed": { "type": "string", "description": "Computed secret value" }
            }
          }
        }
      },
      "SecretNamesResponse": {
        "type": "object",
        "properties": {
          "names": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of secret names"
          }
        }
      },
      "SecretChangeRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Secret name" },
          "originalName": { "type": "string", "description": "Original secret name (for renames)" },
          "value": { "type": "string", "description": "New secret value" },
          "visibility": { "type": "string", "description": "Secret visibility setting" },
          "shouldDelete": { "type": "boolean", "description": "Whether the secret should be deleted" },
          "shouldPromote": { "type": "boolean", "description": "Whether the secret should be promoted" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "description": "User email" },
          "name": { "type": "string", "description": "User display name" },
          "username": { "type": "string", "description": "Username" },
          "profile_image_url": { "type": "string", "description": "URL of the user's profile image" }
        }
      },
      "ConfigLog": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Log entry identifier" },
          "text": { "type": "string", "description": "Description of the change" },
          "html": { "type": "string", "description": "HTML-formatted description" },
          "rollback": { "type": "boolean", "description": "Whether this log entry is a rollback" },
          "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of the log entry" },
          "config": { "type": "string", "description": "Config name" },
          "environment": { "type": "string", "description": "Environment slug" },
          "project": { "type": "string", "description": "Project identifier" },
          "user": { "$ref": "#/components/schemas/User" },
          "diff": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "description": "Secret name that changed" },
                "added": { "type": "string", "description": "Value that was added" },
                "removed": { "type": "string", "description": "Value that was removed" }
              }
            },
            "description": "Array of changes made in this log entry"
          }
        }
      },
      "ConfigLogResponse": {
        "type": "object",
        "properties": {
          "log": { "$ref": "#/components/schemas/ConfigLog" }
        }
      },
      "ConfigLogsListResponse": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "description": "Current page number" },
          "logs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ConfigLog" }
          }
