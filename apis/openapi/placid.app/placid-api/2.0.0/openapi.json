          "width",
          "height"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "custom_data": {
            "type": "string"
          },
          "from_template": {
            "type": "string"
          },
          "add_to_collections": {
            "type": "array",
