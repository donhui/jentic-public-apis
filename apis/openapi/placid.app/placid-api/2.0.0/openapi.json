              "type": "object"
            }
          },
          "webhook_success": {
            "type": "string"
          },
          "modifications": {
            "type": "object"
          },
          "passthrough": {
            "type": "string"
          }
        }
      },
      "MergePdfRequest": {
        "type": "object",
        "properties": {
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 2,
            "maxItems": 10
          },
          "webhook_success": {
            "type": "string"
          },
          "passthrough": {
            "type": "string"
          }
        }
      },
      "PdfResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "finished",
              "error"
            ]
          },
          "pdf_url": {
            "type": "string"
          },
          "polling_url": {
            "type": "string"
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "custom_data": {
            "type": "string"
          }
        }
      },
      "TemplateListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Template"
            }
          }
        }
      },
      "CreateTemplateRequest": {
        "type": "object",
