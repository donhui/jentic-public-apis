              "queued",
              "finished",
              "error"
            ]
          },
          "video_url": {
            "type": "string"
          },
          "polling_url": {
            "type": "string"
          }
        }
      },
      "CreatePdfRequest": {
        "type": "object",
        "properties": {
          "pages": {
            "type": "array",
