{
  "openapi": "3.0.3",
  "info": {
    "title": "Record360 API",
    "version": "1.0",
    "description": "Public API for Record360, a platform for equipment and rental management. Provides endpoints for managing assets, transactions, tasks, users, locations, workflows, form templates, and device logs.",
    "x-jentic-source-url": "https://app.record360.com/api-docs"
  },
  "servers": [
    {
      "url": "https://app.record360.com/api",
      "description": "Record360 Production API"
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "User authentication and management"
    },
    {
      "name": "Assets",
      "description": "Asset management (equipment, vehicles, etc.)"
    },
    {
      "name": "Transactions",
      "description": "Transaction (inspection) management"
    },
    {
      "name": "Tasks",
      "description": "Task management"
    },
    {
      "name": "Locations",
      "description": "Location management"
    },
    {
      "name": "Workflows",
      "description": "Workflow management"
    },
    {
      "name": "FormTemplates",
      "description": "Form template management"
    },
    {
      "name": "Devices",
      "description": "Device management"
    }
  ],
  "security": [
    {
      "BearerToken": []
    }
  ],
  "paths": {
    "/users/authenticate": {
      "post": {
        "operationId": "authenticateUser",
        "summary": "Authenticate as a particular User",
        "description": "Login with a username/password and obtain an authentication token. This token must be included in all subsequent requests.",
        "tags": ["Users"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user"],
                "properties": {
                  "user": {
                    "type": "object",
                    "required": ["username", "password"],
                    "properties": {
                      "username": {
                        "type": "string",
                        "description": "User's login or email address"
                      },
                      "password": {
                        "type": "string",
                        "description": "User's password"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "Index of all Users within a company (manager only)",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "before_id",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Return Users before the specified ID"
          },
          {
            "name": "after_id",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Return Users after the specified ID"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Limit the number of Users to return"
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsersListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create a new User",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user"],
                "properties": {
                  "user": {
                    "$ref": "#/components/schemas/UserInput"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "getUser",
