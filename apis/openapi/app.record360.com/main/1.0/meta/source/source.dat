  "components": {
    "securitySchemes": {
      "BearerToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from the authenticate endpoint. Include as 'Authorization: Token <jwt>'"
      }
    },
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "auth_token": {
            "type": "string",
            "description": "JWT authentication token"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          }
        }
      },
      "UserInput": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "location_id": {
            "type": "string"
          }
        }
      },
      "UsersListResponse": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "links": {
            "$ref": "#/components/schemas/PaginationLinks"
          }
        }
      },
      "Asset": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "make": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "check_in": {
            "type": "boolean"
          },
          "notations": {
            "type": "object"
          },
          "geo_coord": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "email_sent_to": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "damage_cost": {
            "type": "number"
          },
          "location": {
            "$ref": "#/components/schemas/LocationRef"
          },
          "transaction": {
            "$ref": "#/components/schemas/Transaction"
          },
          "photos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Media"
            }
          },
          "videos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Media"
            }
          },
          "signatures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Media"
            }
          },
          "damages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Damage"
            }
          }
        }
      },
      "AssetInput": {
        "type": "object",
        "properties": {
          "external_id": {
            "type": "string"
          },
          "make": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          }
        }
      },
      "AssetsListResponse": {
        "type": "object",
        "properties": {
          "assets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Asset"
            }
          },
          "links": {
            "$ref": "#/components/schemas/PaginationLinks"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "check_in": {
            "type": "boolean"
          },
          "draft": {
            "type": "boolean"
          },
          "damage": {
            "type": "boolean"
          },
          "geo_coord": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "email_sent_to": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "workflow_modules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "archive_status": {
            "type": "string",
            "enum": ["active", "archived", "restoring", "restored"]
          },
          "workflow_id": {
            "type": "string"
          },
          "view_url": {
            "type": "string"
