{
  "openapi": "3.0.3",
  "info": {
    "title": "Destination Motivation API",
    "description": "Destination Motivation is a service that manages vacation vouchers for customers. This API allows integration with HubSpot for ticket creation and management.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://destinationmotivationportal.com/zapier-api-docs"
  },
  "servers": [
    {
      "url": "https://destinationmotivationportal.com/wp-json/hicrm/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "API authentication and validation"
    },
    {
      "name": "HubSpot",
      "description": "HubSpot integration endpoints"
    }
  ],
  "paths": {
    "/auth/validate": {
      "get": {
        "operationId": "validateApiKey",
        "summary": "Validate API Key",
        "description": "Validates the provided API key and returns site information",
        "tags": [
          "Authentication"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "API key is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateApiKeyResponse"
                },
                "example": {
                  "success": true,
                  "site": "Destination Motivation Portal",
                  "time": "2025-09-17 12:00:00"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/hubspot/ticket": {
      "post": {
        "operationId": "createHubspotTicket",
        "summary": "Create HubSpot Ticket",
        "description": "Creates a new ticket in HubSpot and associates it with the corresponding contact and company",
        "tags": [
          "HubSpot"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHubSpotTicketRequest"
              },
              "example": {
                "firstname": "John",
                "lastname": "Doe",
                "branchId": 123,
                "phone": "+123456789",
                "email": "john@example.com",
                "companyId": "567",
                "vacationType": "Condo",
                "address": "123 Main St",
                "city": "Miami",
                "state": "FL",
                "zip": "33101",
                "ticketName": "Custom Ticket Title",
                "external_crm_id": "crm_001",
                "rep": "Jane Smith",
                "location": "Florida",
                "region": "South"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateHubSpotTicketResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid input data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Generate your API Key in WordPress Admin → PWA Settings → Zapier API Settings."
      }
    },
    "schemas": {
      "ValidateApiKeyResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Indicates if the API key is valid"
          },
          "site": {
            "type": "string",
            "description": "Name of the site"
          },
          "time": {
            "type": "string",
            "description": "Current server time"
          }
        },
        "required": [
          "success",
          "site",
          "time"
        ]
      },
      "CreateHubSpotTicketRequest": {
        "type": "object",
        "properties": {
          "firstname": {
            "type": "string",
            "description": "First name of the contact"
          },
          "lastname": {
            "type": "string",
            "description": "Last name of the contact"
          },
          "branchId": {
            "type": "integer",
            "description": "Branch identifier"
          },
          "phone": {
            "type": "string",
            "description": "Contact phone number"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email address"
          },
          "companyId": {
            "type": "string",
            "description": "Company identifier"
          },
          "vacationType": {
            "type": "string",
            "description": "Type of vacation package (e.g., Condo, Resort)"
          },
          "address": {
            "type": "string",
            "description": "Street address"
          },
          "city": {
            "type": "string",
            "description": "City"
          },
          "state": {
            "type": "string",
            "description": "State or province"
          },
          "zip": {
            "type": "string",
            "description": "Postal/ZIP code"
          },
          "ticketName": {
            "type": "string",
            "description": "Custom title for the ticket"
          },
          "external_crm_id": {
            "type": "string",
            "description": "External CRM identifier"
          },
          "rep": {
            "type": "string",
            "description": "Sales representative name"
          },
          "location": {
            "type": "string",
            "description": "Location information"
          },
          "region": {
            "type": "string",
            "description": "Region information"
          }
        },
        "required": [
          "firstname",
          "lastname",
          "email"
        ]
      },
      "CreateHubSpotTicketResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Indicates if the ticket was created successfully"
          },
          "ticketId": {
            "type": "string",
            "description": "ID of the created ticket in HubSpot"
          },
          "contactId": {
            "type": "string",
            "description": "ID of the associated contact in HubSpot"
          },
          "companyId": {
            "type": "string",
            "description": "ID of the associated company in HubSpot"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Always false for errors"
          },
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        },
        "required": [
          "success",
          "error"
        ]
      }
    }
  }
}
