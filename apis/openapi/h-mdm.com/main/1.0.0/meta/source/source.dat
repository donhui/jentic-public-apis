{
  "openapi": "3.0.3",
  "info": {
    "title": "Headwind MDM Push Notifications API",
    "description": "API for sending push notifications to managed devices through the Headwind MDM system.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://h-mdm.com/push-notifications-api/"
  },
  "servers": [
    {
      "url": "https://{your-hmdm-server}",
      "description": "Headwind MDM Server",
      "variables": {
        "your-hmdm-server": {
          "default": "your-hmdm-server.com",
          "description": "Your Headwind MDM server hostname"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Push Notifications",
      "description": "Send push notifications to managed devices"
    }
  ],
  "paths": {
    "/rest/private/push": {
      "post": {
        "operationId": "sendPushNotification",
        "summary": "Send push notification to devices",
        "description": "Sends push notifications to managed devices. You can target specific devices, device groups, or broadcast to all devices.",
        "tags": ["Push Notifications"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushNotificationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Push notification sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PushNotificationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authorization"
      }
    },
    "schemas": {
      "PushNotificationRequest": {
        "type": "object",
        "required": ["messageType"],
        "properties": {
          "messageType": {
            "type": "string",
            "description": "Defines the notification type"
          },
          "payload": {
            "type": "string",
            "description": "JSON object encapsulated as a string containing message data"
          },
          "broadcast": {
            "type": "boolean",
            "description": "Set to true to send the notification to all devices"
          },
          "deviceNumbers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Specific device identifiers to target"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Device group names to target"
          }
        }
      },
      "PushNotificationResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of the push notification delivery"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}